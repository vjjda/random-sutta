{"cp30":{"cp30:0.1":{"pli":"Cariyāpiṭaka ","eng":"The Conduct Leading to Buddhahood ","html":"<article id='cp30'><header><ul><li class='division'>{}</li>"},"cp30:0.2":{"pli":"Yudhañjayavagga ","eng":"The Chapter With Yudhañjaya ","html":"<li>{}</li>"},"cp30:0.3":{"pli":"Saccapāramī 4 ","eng":"The Perfection of Truth (4th) ","html":"<li>{}</li></ul>"},"cp30:0.4":{"pli":"Maccharājacariya ","eng":"The Fish King’s Conduct ","html":"<h1 class='sutta-title'>{}</h1></header>"},"cp30:1.1":{"pli":"“Punāparaṁ yadā homi, ","eng":"“Then again when I was ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"cp30:1.2":{"pli":"maccharājā mahāsare; ","eng":"a fish king in a great lake, ","html":"<span class='verse-line'>{}</span>"},"cp30:1.3":{"pli":"Uṇhe sūriyasantāpe, ","eng":"in the heat of the sun ","html":"<span class='verse-line'>{}</span>"},"cp30:1.4":{"pli":"sare udaka khīyatha. ","eng":"the water in the lake evaporated. ","html":"<span class='verse-line'>{}</span></p>"},"cp30:2.1":{"pli":"Tato kākā ca gijjhā ca, ","eng":"Then crows and vultures, ","html":"<p><span class='verse-line'>{}</span>"},"cp30:2.2":{"pli":"kaṅkā kulalasenakā; ","eng":"herons, hawks, and falcons, ","html":"<span class='verse-line'>{}</span>"},"cp30:2.3":{"pli":"Bhakkhayanti divārattiṁ, ","eng":"perched near the fish ","html":"<span class='verse-line'>{}</span>"},"cp30:2.4":{"pli":"macche upanisīdiya. ","eng":"and devoured them day and night. ","html":"<span class='verse-line'>{}</span></p>"},"cp30:3.1":{"pli":"Evaṁ cintesahaṁ tattha, ","eng":"There I had the following thought, ","html":"<p><span class='verse-line'>{}</span>"},"cp30:3.2":{"pli":"saha ñātīhi pīḷito; ","eng":"being harassed with my relatives: ","html":"<span class='verse-line'>{}</span>"},"cp30:3.3":{"pli":"‘Kena nu kho upāyena, ","eng":"‘By what means ","html":"<span class='verse-line'>{}</span>"},"cp30:3.4":{"pli":"ñātī dukkhā pamocaye’. ","eng":"can I free my relatives from this suffering?’ ","html":"<span class='verse-line'>{}</span></p>"},"cp30:4.1":{"pli":"Vicintayitvā dhammatthaṁ, ","eng":"Considering the value of the Dhamma, ","html":"<p><span class='verse-line'>{}</span>"},"cp30:4.2":{"pli":"saccaṁ addasa passayaṁ; ","eng":"I saw the truth as a support. ","html":"<span class='verse-line'>{}</span>"},"cp30:4.3":{"pli":"Sacce ṭhatvā pamocesiṁ, ","eng":"Standing in the truth, ","html":"<span class='verse-line'>{}</span>"},"cp30:4.4":{"pli":"ñātīnaṁ taṁ atikkhayaṁ. ","eng":"I freed my relatives from that holocaust. ","html":"<span class='verse-line'>{}</span></p>"},"cp30:5.1":{"pli":"Anussaritvā sataṁ dhammaṁ, ","eng":"Recollecting the true Dhamma, ","html":"<p><span class='verse-line'>{}</span>"},"cp30:5.2":{"pli":"paramatthaṁ vicintayaṁ; ","eng":"considered the ultimate goal, ","html":"<span class='verse-line'>{}</span>"},"cp30:5.3":{"pli":"Akāsiṁ saccakiriyaṁ, ","eng":"I made a declaration of truth ","html":"<span class='verse-line'>{}</span>"},"cp30:5.4":{"pli":"yaṁ loke dhuvasassataṁ. ","eng":"that would last eternally in the world. ","html":"<span class='verse-line'>{}</span></p>"},"cp30:6.1":{"pli":"‘Yato sarāmi attānaṁ, ","eng":"‘So long as I can recall myself, ","html":"<p><span class='verse-line'>{}</span>"},"cp30:6.2":{"pli":"yato pattosmi viññutaṁ; ","eng":"since I became aware, ","html":"<span class='verse-line'>{}</span>"},"cp30:6.3":{"pli":"Nābhijānāmi sañcicca, ","eng":"I do not recall deliberately ","html":"<span class='verse-line'>{}</span>"},"cp30:6.4":{"pli":"ekapāṇampi hiṁsitaṁ. ","eng":"harming even a single living creature. ","html":"<span class='verse-line'>{}</span></p>"},"cp30:7.1":{"pli":"Etena saccavajjena, ","eng":"By this declaration of truth, ","html":"<p><span class='verse-line'>{}</span>"},"cp30:7.2":{"pli":"pajjunno abhivassatu; ","eng":"may Pajjuna rain down! ","html":"<span class='verse-line'>{}</span>"},"cp30:7.3":{"pli":"Abhitthanaya pajjunna, ","eng":"Thunder forth, Pajjuna! ","html":"<span class='verse-line'>{}</span>","comm":"This verse also in <a href='index.html?q=ja75'>Ja 75</a>. "},"cp30:7.4":{"pli":"nidhiṁ kākassa nāsaya; ","eng":"Disperse the trove of the crow! ","html":"<span class='verse-line'>{}</span>"},"cp30:7.5":{"pli":"Kākaṁ sokāya randhehi, ","eng":"Subject the crow to sorrow, ","html":"<span class='verse-line'>{}</span>","comm":"It seems a little immoderate. "},"cp30:7.6":{"pli":"macche sokā pamocaya’. ","eng":"and free the fish from sorrow!’ ","html":"<span class='verse-line'>{}</span></p>"},"cp30:8.1":{"pli":"Saha kate saccavare, ","eng":"As this excellent truth was declared, ","html":"<p><span class='verse-line'>{}</span>"},"cp30:8.2":{"pli":"pajjunno abhigajjiya; ","eng":"Pajjuna thundered forth. ","html":"<span class='verse-line'>{}</span>"},"cp30:8.3":{"pli":"Thalaṁ ninnañca pūrento, ","eng":"In an instant the rain poured down, ","html":"<span class='verse-line'>{}</span>"},"cp30:8.4":{"pli":"khaṇena abhivassatha. ","eng":"soaking the uplands and valleys. ","html":"<span class='verse-line'>{}</span></p>"},"cp30:9.1":{"pli":"Evarūpaṁ saccavaraṁ, ","eng":"Having made such supreme effort ","html":"<p><span class='verse-line'>{}</span>"},"cp30:9.2":{"pli":"katvā vīriyamuttamaṁ; ","eng":"for this excellent truth, ","html":"<span class='verse-line'>{}</span>"},"cp30:9.3":{"pli":"Vassāpesiṁ mahāmeghaṁ, ","eng":"I made the great cloud pour down, ","html":"<span class='verse-line'>{}</span>"},"cp30:9.4":{"pli":"saccatejabalassito; ","eng":"relying on the force of the power of truth. ","html":"<span class='verse-line'>{}</span>"},"cp30:9.5":{"pli":"Saccena me samo natthi, ","eng":"There is no-one to equal my truthfulness: ","html":"<span class='verse-line'>{}</span>"},"cp30:9.6":{"pli":"esā me saccapāramī”ti. ","eng":"this is my perfection of truth.” ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"cp30:10.1":{"pli":"Maccharājacariyaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"cp31":{"cp31:0.1":{"pli":"Cariyāpiṭaka ","eng":"The Conduct Leading to Buddhahood ","html":"<article id='cp31'><header><ul><li class='division'>{}</li>"},"cp31:0.2":{"pli":"Yudhañjayavagga ","eng":"The Chapter With Yudhañjaya ","html":"<li>{}</li>"},"cp31:0.3":{"pli":"Saccapāramī 5 ","eng":"The Perfection of Truth (5th) ","html":"<li>{}</li></ul>"},"cp31:0.4":{"pli":"Kaṇhadīpāyanacariya ","eng":"Dark Light’s Conduct ","html":"<h1 class='sutta-title'>{}</h1></header>"},"cp31:1.1":{"pli":"“Punāparaṁ yadā homi, ","eng":"“Then again when I was ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"cp31:1.2":{"pli":"kaṇhadīpāyano isi; ","eng":"the seer Dark Light, ","html":"<span class='verse-line'>{}</span>","comm":"A “dark hermit” comparable to Asita Kaṇhasiri (or Kāladevala) of <a href='index.html?q=snp3.11'>Snp 3.11</a>, Asita Devala of <a href='index.html?q=mn93'>MN 93</a>, and Kaṇha of <a href='index.html?q=dn3'>DN 3</a>. "},"cp31:1.3":{"pli":"Paropaññāsavassāni, ","eng":"for more than fifty years ","html":"<span class='verse-line'>{}</span>"},"cp31:1.4":{"pli":"anabhiratocariṁ ahaṁ. ","eng":"I lived dissatisfied. ","html":"<span class='verse-line'>{}</span></p>"},"cp31:2.1":{"pli":"Na koci etaṁ jānāti, ","eng":"No-one knew of this ","html":"<p><span class='verse-line'>{}</span>"},"cp31:2.2":{"pli":"Anabhiratimanaṁ mama; ","eng":"dissatisfaction of mine, ","html":"<span class='verse-line'>{}</span>"},"cp31:2.3":{"pli":"Ahañhi kassaci nācikkhiṁ, ","eng":"for I mentioned it to no-one, ","html":"<span class='verse-line'>{}</span>"},"cp31:2.4":{"pli":"Arati me carati mānase. ","eng":"it only went on in my mind. ","html":"<span class='verse-line'>{}</span></p>"},"cp31:3.1":{"pli":"Sabrahmacārī maṇḍabyo, ","eng":"Maṇḍabya, a spiritual companion ","html":"<p><span class='verse-line'>{}</span>"},"cp31:3.2":{"pli":"sahāyo me mahāisi; ","eng":"and friend of mine was a great seer. ","html":"<span class='verse-line'>{}</span>"},"cp31:3.3":{"pli":"Pubbakammasamāyutto, ","eng":"Bound to a deed in a past life, ","html":"<span class='verse-line'>{}</span>"},"cp31:3.4":{"pli":"sūlamāropanaṁ labhi. ","eng":"he got impaled on a stake. ","html":"<span class='verse-line'>{}</span></p>"},"cp31:4.1":{"pli":"Tamahaṁ upaṭṭhahitvāna, ","eng":"I nursed him ","html":"<p><span class='verse-line'>{}</span>"},"cp31:4.2":{"pli":"ārogyamanupāpayiṁ; ","eng":"and brought him back to health. ","html":"<span class='verse-line'>{}</span>"},"cp31:4.3":{"pli":"Āpucchitvāna āgañchiṁ, ","eng":"Asking leave, I returned ","html":"<span class='verse-line'>{}</span>"},"cp31:4.4":{"pli":"yaṁ mayhaṁ sakamassamaṁ. ","eng":"to my own hermitage. ","html":"<span class='verse-line'>{}</span></p>"},"cp31:5.1":{"pli":"Sahāyo brāhmaṇo mayhaṁ, ","eng":"A brahmin friend of mine, ","html":"<p><span class='verse-line'>{}</span>"},"cp31:5.2":{"pli":"bhariyaṁ ādāya puttakaṁ; ","eng":"bringing wife and child, ","html":"<span class='verse-line'>{}</span>"},"cp31:5.3":{"pli":"Tayo janā samāgantvā, ","eng":"came to me, all three of them, ","html":"<span class='verse-line'>{}</span>"},"cp31:5.4":{"pli":"āgañchuṁ pāhunāgataṁ. ","eng":"as my guests. ","html":"<span class='verse-line'>{}</span></p>"},"cp31:6.1":{"pli":"Sammodamāno tehi saha, ","eng":"As I exchanged greetings with them, ","html":"<p><span class='verse-line'>{}</span>"},"cp31:6.2":{"pli":"nisinno sakamassame; ","eng":"seated in my own hermitage, ","html":"<span class='verse-line'>{}</span>"},"cp31:6.3":{"pli":"Dārako vaṭṭamanukkhipaṁ, ","eng":"the boy threw a ball ","html":"<span class='verse-line'>{}</span>"},"cp31:6.4":{"pli":"āsīvisamakopayi. ","eng":"and angered a viper. ","html":"<span class='verse-line'>{}</span></p>"},"cp31:7.1":{"pli":"Tato so vaṭṭagataṁ maggaṁ, ","eng":"Then the boy, looking which way ","html":"<p><span class='verse-line'>{}</span>"},"cp31:7.2":{"pli":"anvesanto kumārako; ","eng":"the ball had gone, ","html":"<span class='verse-line'>{}</span>"},"cp31:7.3":{"pli":"Āsīvisassa hatthena, ","eng":"touched the viper’s head ","html":"<span class='verse-line'>{}</span>"},"cp31:7.4":{"pli":"uttamaṅgaṁ parāmasi. ","eng":"with his hand. ","html":"<span class='verse-line'>{}</span></p>"},"cp31:8.1":{"pli":"Tassa āmasane kuddho, ","eng":"Angered at his touch, ","html":"<p><span class='verse-line'>{}</span>"},"cp31:8.2":{"pli":"sappo visabalassito; ","eng":"the snake, relying on its potent poison, ","html":"<span class='verse-line'>{}</span>"},"cp31:8.3":{"pli":"Kupito paramakopena, ","eng":"completely enraged, ","html":"<span class='verse-line'>{}</span>"},"cp31:8.4":{"pli":"aḍaṁsi dārakaṁ khaṇe. ","eng":"bit the boy right away. ","html":"<span class='verse-line'>{}</span></p>"},"cp31:9.1":{"pli":"Sahadaṭṭho āsīvisena, ","eng":"When bitten by the viper, ","html":"<p><span class='verse-line'>{}</span>"},"cp31:9.2":{"pli":"dārako papati bhūmiyaṁ; ","eng":"the boy fainted on the ground. ","html":"<span class='verse-line'>{}</span>"},"cp31:9.3":{"pli":"Tenāhaṁ dukkhito āsiṁ, ","eng":"It made me distraught, ","html":"<span class='verse-line'>{}</span>"},"cp31:9.4":{"pli":"mama vāhasi taṁ dukkhaṁ. ","eng":"the pain became as if mine. ","html":"<span class='verse-line'>{}</span></p>"},"cp31:10.1":{"pli":"Tyāhaṁ assāsayitvāna, ","eng":"Comforting the parents, ","html":"<p><span class='verse-line'>{}</span>"},"cp31:10.2":{"pli":"dukkhite sokasallite; ","eng":"in their suffering and sorrow, ","html":"<span class='verse-line'>{}</span>"},"cp31:10.3":{"pli":"Paṭhamaṁ akāsiṁ kiriyaṁ, ","eng":"I made the first act, ","html":"<span class='verse-line'>{}</span>"},"cp31:10.4":{"pli":"aggaṁ saccaṁ varuttamaṁ. ","eng":"the original, supreme declaration of truth: ","html":"<span class='verse-line'>{}</span></p>"},"cp31:11.1":{"pli":"‘Sattāhamevāhaṁ pasannacitto, ","eng":"‘For just seven days with a mind of faith ","html":"<p><span class='verse-line'>{}</span>"},"cp31:11.2":{"pli":"Puññatthiko acariṁ brahmacariyaṁ; ","eng":"I led the spiritual life seeking merit. ","html":"<span class='verse-line'>{}</span>"},"cp31:11.3":{"pli":"Athāparaṁ yaṁ caritaṁ mamedaṁ, ","eng":"My life since then, ","html":"<span class='verse-line'>{}</span>"},"cp31:11.4":{"pli":"Vassāni paññāsasamādhikāni. ","eng":"for fifty years or more, ","html":"<span class='verse-line'>{}</span></p>"},"cp31:12.1":{"pli":"Akāmako vāhi ahaṁ carāmi, ","eng":"I have lived unwillingly. ","html":"<p><span class='verse-line'>{}</span>"},"cp31:12.2":{"pli":"Etena saccena suvatthi hotu; ","eng":"By this truth, may he be well! ","html":"<span class='verse-line'>{}</span>"},"cp31:12.3":{"pli":"Hataṁ visaṁ jīvatu yaññadatto’. ","eng":"May the poison die! May Yaññadatta live!’ ","html":"<span class='verse-line'>{}</span></p>"},"cp31:13.1":{"pli":"Saha sacce kate mayhaṁ, ","eng":"As I declared this truth, ","html":"<p><span class='verse-line'>{}</span>"},"cp31:13.2":{"pli":"visavegena vedhito; ","eng":"the boy trembling with poison, ","html":"<span class='verse-line'>{}</span>"},"cp31:13.3":{"pli":"Abujjhitvāna vuṭṭhāsi, ","eng":"awoke and got up, ","html":"<span class='verse-line'>{}</span>"},"cp31:13.4":{"pli":"arogo cāsi māṇavo; ","eng":"the brahmin youth was well. ","html":"<span class='verse-line'>{}</span>"},"cp31:13.5":{"pli":"Saccena me samo natthi, ","eng":"There is no-one to equal my truthfulness: ","html":"<span class='verse-line'>{}</span>"},"cp31:13.6":{"pli":"esā me saccapāramī”ti. ","eng":"this is my perfection of truth.” ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"cp31:14.1":{"pli":"Kaṇhadīpāyanacariyaṁ ekādasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"cp32":{"cp32:0.1":{"pli":"Cariyāpiṭaka ","eng":"The Conduct Leading to Buddhahood ","html":"<article id='cp32'><header><ul><li class='division'>{}</li>"},"cp32:0.2":{"pli":"Yudhañjayavagga ","eng":"The Chapter With Yudhañjaya ","html":"<li>{}</li>"},"cp32:0.3":{"pli":"Saccapāramī 6 ","eng":"The Perfection of Truth (6th) ","html":"<li>{}</li></ul>"},"cp32:0.4":{"pli":"Sutasomacariya ","eng":"Sutasoma’s Conduct ","html":"<h1 class='sutta-title'>{}</h1></header>"},"cp32:1.1":{"pli":"“Punāparaṁ yadā homi, ","eng":"“Then again when I was ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"cp32:1.2":{"pli":"sutasomo mahīpati; ","eng":"Sutasoma, Lord of the Earth, ","html":"<span class='verse-line'>{}</span>"},"cp32:1.3":{"pli":"Gahito porisādena, ","eng":"captured by a cannibal ","html":"<span class='verse-line'>{}</span>"},"cp32:1.4":{"pli":"brāhmaṇe saṅgaraṁ sariṁ. ","eng":"I remembered my promise to a brahmin. ","html":"<span class='verse-line'>{}</span></p>"},"cp32:2.1":{"pli":"Khattiyānaṁ ekasataṁ, ","eng":"A hundred aristocrat warriors ","html":"<p><span class='verse-line'>{}</span>"},"cp32:2.2":{"pli":"āvuṇitvā karattale; ","eng":"he strung up by their hands . ","html":"<span class='verse-line'>{}</span>"},"cp32:2.3":{"pli":"Etesaṁ pamilāpetvā, ","eng":"Having drained their blood, ","html":"<span class='verse-line'>{}</span>"},"cp32:2.4":{"pli":"yaññatthe upanayī mamaṁ. ","eng":"he brought me for sacrifice. ","html":"<span class='verse-line'>{}</span></p>"},"cp32:3.1":{"pli":"Apucchi maṁ porisādo, ","eng":"The cannibal asked me, ","html":"<p><span class='verse-line'>{}</span>"},"cp32:3.2":{"pli":"‘kiṁ tvaṁ icchasi nissajaṁ; ","eng":"‘What do you wish for—release? ","html":"<span class='verse-line'>{}</span>"},"cp32:3.3":{"pli":"Yathāmati te kāhāmi, ","eng":"I shall act as you think, ","html":"<span class='verse-line'>{}</span>"},"cp32:3.4":{"pli":"yadi me tvaṁ punehisi’. ","eng":"so long as you will return.’ ","html":"<span class='verse-line'>{}</span></p>"},"cp32:4.1":{"pli":"Tassa paṭissuṇitvāna, ","eng":"I promised him that I ","html":"<p><span class='verse-line'>{}</span>"},"cp32:4.2":{"pli":"paṇhe āgamanaṁ mama; ","eng":"would return at dawn. ","html":"<span class='verse-line'>{}</span>"},"cp32:4.3":{"pli":"Upagantvā puraṁ rammaṁ, ","eng":"I went to the delightful city ","html":"<span class='verse-line'>{}</span>"},"cp32:4.4":{"pli":"rajjaṁ niyyādayiṁ tadā. ","eng":"and then renounced kingship. ","html":"<span class='verse-line'>{}</span></p>"},"cp32:5.1":{"pli":"Anussaritvā sataṁ dhammaṁ, ","eng":"Recollecting the true Dhamma, ","html":"<p><span class='verse-line'>{}</span>"},"cp32:5.2":{"pli":"pubbakaṁ jinasevitaṁ; ","eng":"fostered by former Victors, ","html":"<span class='verse-line'>{}</span>"},"cp32:5.3":{"pli":"Brāhmaṇassa dhanaṁ datvā, ","eng":"I gave money to the brahmin, ","html":"<span class='verse-line'>{}</span>"},"cp32:5.4":{"pli":"porisādaṁ upāgamiṁ. ","eng":"and returned to the cannibal. ","html":"<span class='verse-line'>{}</span></p>"},"cp32:6.1":{"pli":"Natthi me saṁsayo tattha, ","eng":"I had no doubt ","html":"<p><span class='verse-line'>{}</span>"},"cp32:6.2":{"pli":"Ghātayissati vā na vā; ","eng":"that he was going to kill me. ","html":"<span class='verse-line'>{}</span>"},"cp32:6.3":{"pli":"Saccavācānurakkhanto, ","eng":"Protecting my truthful speech, ","html":"<span class='verse-line'>{}</span>"},"cp32:6.4":{"pli":"Jīvitaṁ cajitumupāgamiṁ; ","eng":"I went to give up my life. ","html":"<span class='verse-line'>{}</span>"},"cp32:6.5":{"pli":"Saccena me samo natthi, ","eng":"There is no-one to equal my truthfulness: ","html":"<span class='verse-line'>{}</span>"},"cp32:6.6":{"pli":"Esā me saccapāramī”ti. ","eng":"this is my perfection of truth.” ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"cp32:7.1":{"pli":"Sutasomacariyaṁ dvādasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"cp33":{"cp33:0.1":{"pli":"Cariyāpiṭaka ","eng":"The Conduct Leading to Buddhahood ","html":"<article id='cp33'><header><ul><li class='division'>{}</li>"},"cp33:0.2":{"pli":"Yudhañjayavagga ","eng":"The Chapter With Yudhañjaya ","html":"<li>{}</li>"},"cp33:0.3":{"pli":"Mettāpāramī 1 ","eng":"The Perfection of Love (1st) ","html":"<li>{}</li></ul>"},"cp33:0.4":{"pli":"Suvaṇṇasāmacariya ","eng":"Goldblack’s Conduct ","html":"<h1 class='sutta-title'>{}</h1></header>"},"cp33:1.1":{"pli":"“Sāmo yadā vane āsiṁ, ","eng":"“When in a wood I was Sāma the black, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>","comm":"Yet another dark hermit. "},"cp33:1.2":{"pli":"sakkena abhinimmito; ","eng":"created by Sakka. ","html":"<span class='verse-line'>{}</span>"},"cp33:1.3":{"pli":"Pavane sīhabyagghe ca, ","eng":"I led the lions and tigers ","html":"<span class='verse-line'>{}</span>"},"cp33:1.4":{"pli":"mettāya mupanāmayiṁ. ","eng":"in the forest by love. ","html":"<span class='verse-line'>{}</span></p>"},"cp33:2.1":{"pli":"Sīhabyagghehi dīpīhi, ","eng":"Surrounded by lions and tigers, ","html":"<p><span class='verse-line'>{}</span>"},"cp33:2.2":{"pli":"acchehi mahisehi ca; ","eng":"leopards, bears, buffaloes, ","html":"<span class='verse-line'>{}</span>"},"cp33:2.3":{"pli":"Pasadamigavarāhehi, ","eng":"spotted deer, and wild boar, ","html":"<span class='verse-line'>{}</span>"},"cp33:2.4":{"pli":"parivāretvā vane vasiṁ. ","eng":"I stayed in the forest. ","html":"<span class='verse-line'>{}</span></p>"},"cp33:3.1":{"pli":"Na maṁ koci uttasati, ","eng":"None were scared of me, ","html":"<p><span class='verse-line'>{}</span>"},"cp33:3.2":{"pli":"napi bhāyāmi kassaci; ","eng":"nor I of them. ","html":"<span class='verse-line'>{}</span>"},"cp33:3.3":{"pli":"Mettābalenupatthaddho, ","eng":"Sustained by the power of love ","html":"<span class='verse-line'>{}</span>"},"cp33:3.4":{"pli":"ramāmi pavane tadā”ti. ","eng":"I delighted in the forest then.” ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"cp33:4.1":{"pli":"Suvaṇṇasāmacariyaṁ terasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"cp34":{"cp34:0.1":{"pli":"Cariyāpiṭaka ","eng":"The Conduct Leading to Buddhahood ","html":"<article id='cp34'><header><ul><li class='division'>{}</li>"},"cp34:0.2":{"pli":"Yudhañjayavagga ","eng":"The Chapter With Yudhañjaya ","html":"<li>{}</li>"},"cp34:0.3":{"pli":"Mettāpāramī 2 ","eng":"The Perfection of Love (2nd) ","html":"<li>{}</li></ul>"},"cp34:0.4":{"pli":"Ekarājacariya ","eng":"The One King’s Conduct ","html":"<h1 class='sutta-title'>{}</h1></header>"},"cp34:1.1":{"pli":"“Punāparaṁ yadā homi, ","eng":"“Then again when I was ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"cp34:1.2":{"pli":"ekarājāti vissuto; ","eng":"the renowned One King, ","html":"<span class='verse-line'>{}</span>"},"cp34:1.3":{"pli":"Paramaṁ sīlaṁ adhiṭṭhāya, ","eng":"resolved on highest ethics, ","html":"<span class='verse-line'>{}</span>"},"cp34:1.4":{"pli":"pasāsāmi mahāmahiṁ. ","eng":"I ruled the great earth. ","html":"<span class='verse-line'>{}</span></p>"},"cp34:2.1":{"pli":"Dasa kusalakammapathe, ","eng":"Without exception I followed ","html":"<p><span class='verse-line'>{}</span>"},"cp34:2.2":{"pli":"vattāmi anavasesato; ","eng":"the ten ways of skillful deeds. ","html":"<span class='verse-line'>{}</span>"},"cp34:2.3":{"pli":"Catūhi saṅgahavatthūhi, ","eng":"With the four ways of being inclusive, ","html":"<span class='verse-line'>{}</span>"},"cp34:2.4":{"pli":"saṅgaṇhāmi mahājanaṁ. ","eng":"I brought together the population. ","html":"<span class='verse-line'>{}</span></p>"},"cp34:3.1":{"pli":"Evaṁ me appamattassa, ","eng":"As I was being diligent, ","html":"<p><span class='verse-line'>{}</span>"},"cp34:3.2":{"pli":"idha loke parattha ca; ","eng":"for the sake of this world and the next, ","html":"<span class='verse-line'>{}</span>"},"cp34:3.3":{"pli":"Dabbaseno upagantvā, ","eng":"Dabbasena attacked ","html":"<span class='verse-line'>{}</span>"},"cp34:3.4":{"pli":"acchindanto puraṁ mama. ","eng":"and sacked my city. ","html":"<span class='verse-line'>{}</span></p>"},"cp34:4.1":{"pli":"Rājūpajīve nigame, ","eng":"The royal dependents in the city, ","html":"<p><span class='verse-line'>{}</span>"},"cp34:4.2":{"pli":"sabalaṭṭhe saraṭṭhake; ","eng":"with the military and the citizens—","html":"<span class='verse-line'>{}</span>"},"cp34:4.3":{"pli":"Sabbaṁ hatthagataṁ katvā, ","eng":"he captured them all, ","html":"<span class='verse-line'>{}</span>"},"cp34:4.4":{"pli":"kāsuyā nikhaṇī mamaṁ. ","eng":"and buried me in a pit. ","html":"<span class='verse-line'>{}</span></p>"},"cp34:5.1":{"pli":"Amaccamaṇḍalaṁ rajjaṁ, ","eng":"The court ministers, the flourishing kingdom, ","html":"<p><span class='verse-line'>{}</span>"},"cp34:5.2":{"pli":"phītaṁ antepuraṁ mama; ","eng":"and my royal court—","html":"<span class='verse-line'>{}</span>"},"cp34:5.3":{"pli":"Acchinditvāna gahitaṁ, ","eng":"were captured and held, ","html":"<span class='verse-line'>{}</span>"},"cp34:5.4":{"pli":"piyaṁ puttaṁva passahaṁ; ","eng":"I even saw my beloved son. ","html":"<span class='verse-line'>{}</span>"},"cp34:5.5":{"pli":"Mettāya me samo natthi, ","eng":"There is no-one to equal my love: ","html":"<span class='verse-line'>{}</span>"},"cp34:5.6":{"pli":"esā me mettāpāramī”ti. ","eng":"this is my perfection of love.” ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"cp34:6.1":{"pli":"Ekarājacariyaṁ cuddasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"cp35":{"cp35:0.1":{"pli":"Cariyāpiṭaka ","eng":"The Conduct Leading to Buddhahood ","html":"<article id='cp35'><header><ul><li class='division'>{}</li>"},"cp35:0.2":{"pli":"Yudhañjayavagga ","eng":"The Chapter With Yudhañjaya ","html":"<li>{}</li>"},"cp35:0.3":{"pli":"Upekkhāpāramī 1 ","eng":"The Perfection of Equanimity ","html":"<li>{}</li></ul>"},"cp35:0.4":{"pli":"Mahālomahaṁsacariya ","eng":"The Great Hair-raising Conduct ","html":"<h1 class='sutta-title'>{}</h1></header>"},"cp35:1.1":{"pli":"“Susāne seyyaṁ kappemi, ","eng":"“I made my bed in a charnel ground, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"cp35:1.2":{"pli":"Chavaṭṭhikaṁ upanidhāyahaṁ; ","eng":"resting on a skeleton. ","html":"<span class='verse-line'>{}</span>"},"cp35:1.3":{"pli":"Gāmaṇḍalā upāgantvā, ","eng":"Village louts came up ","html":"<span class='verse-line'>{}</span>"},"cp35:1.4":{"pli":"Rūpaṁ dassentinappakaṁ. ","eng":"and mocked me in all sorts of ways. ","html":"<span class='verse-line'>{}</span></p>"},"cp35:2.1":{"pli":"Apare gandhamālañca, ","eng":"Others brought me ","html":"<p><span class='verse-line'>{}</span>"},"cp35:2.2":{"pli":"bhojanaṁ vividhaṁ bahuṁ; ","eng":"incense and flowers, ","html":"<span class='verse-line'>{}</span>"},"cp35:2.3":{"pli":"Upāyanānūpanenti, ","eng":"and many kinds of cooked food, ","html":"<span class='verse-line'>{}</span>"},"cp35:2.4":{"pli":"haṭṭhā saṁviggamānasā. ","eng":"all thrilled, their minds elated. ","html":"<span class='verse-line'>{}</span></p>"},"cp35:3.1":{"pli":"Ye me dukkhaṁ upaharanti, ","eng":"Those who brought me pain, ","html":"<p><span class='verse-line'>{}</span>"},"cp35:3.2":{"pli":"ye ca denti sukhaṁ mama; ","eng":"and those who gave me happiness, ","html":"<span class='verse-line'>{}</span>"},"cp35:3.3":{"pli":"Sabbesaṁ samako homi, ","eng":"were all the same to me. ","html":"<span class='verse-line'>{}</span>"},"cp35:3.4":{"pli":"dayā kopo na vijjati. ","eng":"I felt no favor or anger. ","html":"<span class='verse-line'>{}</span></p>"},"cp35:4.1":{"pli":"Sukhadukkhe tulābhūto, ","eng":"I became balanced towards pleasure and pain, ","html":"<p><span class='verse-line'>{}</span>"},"cp35:4.2":{"pli":"Yasesu ayasesu ca; ","eng":"fame and disgrace. ","html":"<span class='verse-line'>{}</span>"},"cp35:4.3":{"pli":"Sabbattha samako homi, ","eng":"I was equal in every case: ","html":"<span class='verse-line'>{}</span>"},"cp35:4.4":{"pli":"Esā me upekkhāpāramī”ti. ","eng":"this is my perfection of equanimity.” ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"cp35:5.1":{"pli":"Mahālomahaṁsacariyaṁ pannarasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"cp35:6.1":{"pli":"Yudhañjayavaggo tatiyo. ","html":"<p class='endsection'>{}</p>"},"cp35:7.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"cp35:8.1":{"pli":"Yudhañjayo somanasso, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"cp35:8.2":{"pli":"ayogharabhisena ca; ","html":"<span class='verse-line'>{}</span>"},"cp35:8.3":{"pli":"Soṇanando mūgapakkho, ","html":"<span class='verse-line'>{}</span>"},"cp35:8.4":{"pli":"kapirājā saccasavhayo. ","html":"<span class='verse-line'>{}</span></p>"},"cp35:9.1":{"pli":"Vaṭṭako maccharājā ca, ","html":"<p><span class='verse-line'>{}</span>"},"cp35:9.2":{"pli":"kaṇhadīpāyano isi; ","html":"<span class='verse-line'>{}</span>"},"cp35:9.3":{"pli":"Sutasomo puna āsiṁ, ","html":"<span class='verse-line'>{}</span>"},"cp35:9.4":{"pli":"sāmo ca ekarājahu; ","html":"<span class='verse-line'>{}</span>"},"cp35:9.5":{"pli":"Upekkhāpāramī āsi, ","html":"<span class='verse-line'>{}</span>"},"cp35:9.6":{"pli":"iti vutthaṁ mahesinā. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"cp35:10.1":{"pli":"Evaṁ bahubbidhaṁ dukkhaṁ, ","eng":"Having thus experience many kinds of suffering ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"cp35:10.2":{"pli":"sampattī ca bahubbidhā; ","eng":"and many kinds of success, ","html":"<span class='verse-line'>{}</span>"},"cp35:10.3":{"pli":"Bhavābhave anubhavitvā, ","eng":"in various past lives, ","html":"<span class='verse-line'>{}</span>"},"cp35:10.4":{"pli":"patto sambodhimuttamaṁ. ","eng":"I realized supreme awakening. ","html":"<span class='verse-line'>{}</span></p>"},"cp35:11.1":{"pli":"Datvā dātabbakaṁ dānaṁ, ","eng":"I gave what could be given, ","html":"<p><span class='verse-line'>{}</span>"},"cp35:11.2":{"pli":"sīlaṁ pūretvā asesato; ","eng":"and fulfilled ethics without reserve. ","html":"<span class='verse-line'>{}</span>"},"cp35:11.3":{"pli":"Nekkhamme pāramiṁ gantvā, ","eng":"having won the perfection of renunciation, ","html":"<span class='verse-line'>{}</span>"},"cp35:11.4":{"pli":"patto sambodhimuttamaṁ. ","eng":"I realized supreme awakening. ","html":"<span class='verse-line'>{}</span></p>"},"cp35:12.1":{"pli":"Paṇḍite paripucchitvā, ","eng":"I inquired of the astute, ","html":"<p><span class='verse-line'>{}</span>"},"cp35:12.2":{"pli":"vīriyaṁ katvāna muttamaṁ; ","eng":"and put forth highest effort, ","html":"<span class='verse-line'>{}</span>"},"cp35:12.3":{"pli":"Khantiyā pāramiṁ gantvā, ","eng":"having won the perfection of acceptance, ","html":"<span class='verse-line'>{}</span>"},"cp35:12.4":{"pli":"patto sambodhimuttamaṁ. ","eng":"I realized supreme awakening. ","html":"<span class='verse-line'>{}</span></p>"},"cp35:13.1":{"pli":"Katvā daḷhamadhiṭṭhānaṁ, ","eng":"Having made a firm resolve, ","html":"<p><span class='verse-line'>{}</span>"},"cp35:13.2":{"pli":"saccavācānurakkhiya; ","eng":"and guarded truthful speech, ","html":"<span class='verse-line'>{}</span>"},"cp35:13.3":{"pli":"Mettāya pāramiṁ gantvā, ","eng":"having won the perfection of love, ","html":"<span class='verse-line'>{}</span>"},"cp35:13.4":{"pli":"patto sambodhimuttamaṁ. ","eng":"I realized supreme awakening. ","html":"<span class='verse-line'>{}</span></p>"},"cp35:14.1":{"pli":"Lābhālābhe yasāyase, ","eng":"In gain and loss, fame and disgrace, ","html":"<p><span class='verse-line'>{}</span>"},"cp35:14.2":{"pli":"sammānanāvamānane; ","eng":"respect and contempt, ","html":"<span class='verse-line'>{}</span>"},"cp35:14.3":{"pli":"Sabbattha samako hutvā, ","eng":"having become equal in every case, ","html":"<span class='verse-line'>{}</span>"},"cp35:14.4":{"pli":"patto sambodhimuttamaṁ. ","eng":"I realized supreme awakening. ","html":"<span class='verse-line'>{}</span></p>"},"cp35:15.1":{"pli":"Kosajjaṁ bhayato disvā, ","eng":"Seeing laziness as fearful, ","html":"<p><span class='verse-line'>{}</span>"},"cp35:15.2":{"pli":"vīriyārambhañca khemato; ","eng":"and energy as a sanctuary, ","html":"<span class='verse-line'>{}</span>"},"cp35:15.3":{"pli":"Āraddhavīriyā hotha, ","eng":"rouse up energy: ","html":"<span class='verse-line'>{}</span>"},"cp35:15.4":{"pli":"esā buddhānusāsanī. ","eng":"this is the Buddhas instruction! ","html":"<span class='verse-line'>{}</span></p>"},"cp35:16.1":{"pli":"Vivādaṁ bhayato disvā, ","eng":"Seeing dispute as fearful, ","html":"<p><span class='verse-line'>{}</span>"},"cp35:16.2":{"pli":"avivādañca khemato; ","eng":"and harmony as a sanctuary, ","html":"<span class='verse-line'>{}</span>"},"cp35:16.3":{"pli":"Samaggā sakhilā hotha, ","eng":"be harmonious and courteous: ","html":"<span class='verse-line'>{}</span>"},"cp35:16.4":{"pli":"esā buddhānusāsanī. ","eng":"this is the Buddhas instruction! ","html":"<span class='verse-line'>{}</span></p>"},"cp35:17.1":{"pli":"Pamādaṁ bhayato disvā, ","eng":"Seeing negligence as fearful, ","html":"<p><span class='verse-line'>{}</span>"},"cp35:17.2":{"pli":"appamādañca khemato; ","eng":"and diligence as a sanctuary, ","html":"<span class='verse-line'>{}</span>"},"cp35:17.3":{"pli":"Bhāvethaṭṭhaṅgikaṁ maggaṁ, ","eng":"develop the eightfold path: ","html":"<span class='verse-line'>{}</span>"},"cp35:17.4":{"pli":"esā buddhānusāsanī. ","eng":"this is the Buddhas instruction! ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"cp35:18.1":{"pli":"Itthaṁ sudaṁ bhagavā attano pubbacariyaṁ sambhāvayamāno buddhāpadāniyaṁ nāma dhammapariyāyaṁ abhāsitthāti. ","eng":"That is how the Buddha, illustrating his own conduct in past lives, spoke the exposition of the teaching name the “Legends of the Buddha”. ","html":"<p>{}</p>"},"cp35:19.1":{"pli":"Cariyāpiṭakaṁ niṭṭhitaṁ. ","html":"<p class='endbook'>{}</p></article>"}},"cp4":{"cp4:0.1":{"pli":"Cariyāpiṭaka ","eng":"The Conduct Leading to Buddhahood ","html":"<article id='cp4'><header><ul><li class='division'>{}</li>"},"cp4:0.2":{"pli":"Akittivagga ","eng":"The Chapter With Akitti ","html":"<li>{}</li>"},"cp4:0.3":{"pli":"Dānapāramī 4 ","eng":"The Perfection of Giving (4th) ","html":"<li>{}</li></ul>"},"cp4:0.4":{"pli":"Mahāsudassanacariya ","eng":"Mahāsudassana’s Conduct ","html":"<h1 class='sutta-title'>{}</h1></header>"},"cp4:1.1":{"pli":"“Kusāvatimhi nagare, ","eng":"“In the city of Kusāvatī, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"cp4:1.2":{"pli":"yadā āsiṁ mahīpati; ","eng":"when I was Lord of the Earth, ","html":"<span class='verse-line'>{}</span>"},"cp4:1.3":{"pli":"Mahāsudassano nāma, ","eng":"my name was Sudassana the Great, ","html":"<span class='verse-line'>{}</span>"},"cp4:1.4":{"pli":"cakkavattī mahabbalo. ","eng":"a wheel-turning monarch of great power. ","html":"<span class='verse-line'>{}</span></p>"},"cp4:2.1":{"pli":"Tatthāhaṁ divase tikkhattuṁ, ","eng":"There, thrice a day, ","html":"<p><span class='verse-line'>{}</span>"},"cp4:2.2":{"pli":"ghosāpemi tahiṁ tahiṁ; ","eng":"I declared in one place or another: ","html":"<span class='verse-line'>{}</span>"},"cp4:2.3":{"pli":"‘Ko kiṁ icchati pattheti, ","eng":"‘Who needs what? Who wants what? ","html":"<span class='verse-line'>{}</span>"},"cp4:2.4":{"pli":"kassa kiṁ dīyatū dhanaṁ. ","eng":"To whom ought riches be given? ","html":"<span class='verse-line'>{}</span></p>"},"cp4:3.1":{"pli":"Ko chātako ko tasito, ","eng":"Who needs an umbrella? Who is thirsty? ","html":"<p><span class='verse-line'>{}</span>"},"cp4:3.2":{"pli":"ko mālaṁ ko vilepanaṁ; ","eng":"Who a garland? Who some makeup? ","html":"<span class='verse-line'>{}</span>"},"cp4:3.3":{"pli":"Nānārattāni vatthāni, ","eng":"What person, being naked, ","html":"<span class='verse-line'>{}</span>"},"cp4:3.4":{"pli":"ko naggo paridahissati. ","eng":"and will put on colorful clothes? ","html":"<span class='verse-line'>{}</span></p>"},"cp4:4.1":{"pli":"Ko pathe chattamādeti, ","eng":"Who will take an umbrella on a highway, ","html":"<p><span class='verse-line'>{}</span>"},"cp4:4.2":{"pli":"kopāhanā mudū subhā’; ","eng":"who needs sandals, soft and pretty?’ ","html":"<span class='verse-line'>{}</span>"},"cp4:4.3":{"pli":"Iti sāyañca pāto ca, ","eng":"Thus I had it proclaimed everywhere ","html":"<span class='verse-line'>{}</span>"},"cp4:4.4":{"pli":"ghosāpemi tahiṁ tahiṁ. ","eng":"morning and night. ","html":"<span class='verse-line'>{}</span></p>"},"cp4:5.1":{"pli":"Na taṁ dasasu ṭhānesu, ","eng":"It was not just in ten places, ","html":"<p><span class='verse-line'>{}</span>"},"cp4:5.2":{"pli":"napi ṭhānasatesu vā; ","eng":"or even a hundred, ","html":"<span class='verse-line'>{}</span>"},"cp4:5.3":{"pli":"Anekasataṭhānesu, ","eng":"but in many hundreds of places ","html":"<span class='verse-line'>{}</span>"},"cp4:5.4":{"pli":"paṭiyattaṁ yācake dhanaṁ. ","eng":"riches were prepared for supplicants. ","html":"<span class='verse-line'>{}</span></p>"},"cp4:6.1":{"pli":"Divā vā yadi vā rattiṁ, ","eng":"By day or by night ","html":"<p><span class='verse-line'>{}</span>"},"cp4:6.2":{"pli":"yadi eti vanibbako; ","eng":"if a supplicant comes, ","html":"<span class='verse-line'>{}</span>"},"cp4:6.3":{"pli":"Laddhā yadicchakaṁ bhogaṁ, ","eng":"then having gotten all he wants, ","html":"<span class='verse-line'>{}</span>"},"cp4:6.4":{"pli":"pūrahatthova gacchati. ","eng":"he leaves with full hands. ","html":"<span class='verse-line'>{}</span></p>"},"cp4:7.1":{"pli":"Evarūpaṁ mahādānaṁ, ","eng":"I gave great gifts like this ","html":"<p><span class='verse-line'>{}</span>"},"cp4:7.2":{"pli":"Adāsiṁ yāvajīvikaṁ; ","eng":"for my whole life. ","html":"<span class='verse-line'>{}</span>"},"cp4:7.3":{"pli":"Napāhaṁ dessaṁ dhanaṁ dammi, ","eng":"I did not give because I disliked riches, ","html":"<span class='verse-line'>{}</span>"},"cp4:7.4":{"pli":"Napi natthi nicayo mayi. ","eng":"or because I had a store set aside. ","html":"<span class='verse-line'>{}</span></p>"},"cp4:8.1":{"pli":"Yathāpi āturo nāma, ","eng":"Suppose a person is sick. ","html":"<p><span class='verse-line'>{}</span>"},"cp4:8.2":{"pli":"rogato parimuttiyā; ","eng":"In order to be free of sickness ","html":"<span class='verse-line'>{}</span>"},"cp4:8.3":{"pli":"Dhanena vejjaṁ tappetvā, ","eng":"having compensated the doctor with money, ","html":"<span class='verse-line'>{}</span>"},"cp4:8.4":{"pli":"rogato parimuccati. ","eng":"they become freed from sickness. ","html":"<span class='verse-line'>{}</span></p>"},"cp4:9.1":{"pli":"Tathevāhaṁ jānamāno, ","eng":"Thus I, knowingly, ","html":"<p><span class='verse-line'>{}</span>"},"cp4:9.2":{"pli":"paripūretumasesato; ","eng":"in order to fulfill without remainder, ","html":"<span class='verse-line'>{}</span>"},"cp4:9.3":{"pli":"Ūnamanaṁ pūrayituṁ, ","eng":"to fulfill what is lacking, ","html":"<span class='verse-line'>{}</span>"},"cp4:9.4":{"pli":"demi dānaṁ vanibbake; ","eng":"gave gifts to supplicants ","html":"<span class='verse-line'>{}</span>"},"cp4:9.5":{"pli":"Nirālayo apaccāso, ","eng":"without clinging or reward, ","html":"<span class='verse-line'>{}</span>"},"cp4:9.6":{"pli":"sambodhimanupattiyā”ti. ","eng":"for the attainment of awakening.” ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"cp4:10.1":{"pli":"Mahāsudassanacariyaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"cp5":{"cp5:0.1":{"pli":"Cariyāpiṭaka ","eng":"The Conduct Leading to Buddhahood ","html":"<article id='cp5'><header><ul><li class='division'>{}</li>"},"cp5:0.2":{"pli":"Akittivagga ","eng":"The Chapter With Akitti ","html":"<li>{}</li>"},"cp5:0.3":{"pli":"Dānapāramī 5 ","eng":"The Perfection of Giving (5th) ","html":"<li>{}</li></ul>"},"cp5:0.4":{"pli":"Mahāgovindacariya ","eng":"Mahāgovinda’s Conduct ","html":"<h1 class='sutta-title'>{}</h1></header>"},"cp5:1.1":{"pli":"“Punāparaṁ yadā homi, ","eng":"“Then again when I was ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"cp5:1.2":{"pli":"sattarājapurohito; ","eng":"high priest for seven kings, ","html":"<span class='verse-line'>{}</span>"},"cp5:1.3":{"pli":"Pūjito naradevehi, ","eng":"I was venerated by the gods among men ","html":"<span class='verse-line'>{}</span>"},"cp5:1.4":{"pli":"mahāgovindabrāhmaṇo. ","eng":"as the brahmin Mahāgovinda. ","html":"<span class='verse-line'>{}</span></p>"},"cp5:2.1":{"pli":"Tadāhaṁ sattarajjesu, ","eng":"Then in all seven kingdoms ","html":"<p><span class='verse-line'>{}</span>"},"cp5:2.2":{"pli":"Yaṁ me āsi upāyanaṁ; ","eng":"what I receieved as tribute ","html":"<span class='verse-line'>{}</span>"},"cp5:2.3":{"pli":"Tena demi mahādānaṁ, ","eng":"I used to give a great gift ","html":"<span class='verse-line'>{}</span>"},"cp5:2.4":{"pli":"Akkhobbhaṁ sāgarūpamaṁ. ","eng":"unwavering as the ocean. ","html":"<span class='verse-line'>{}</span></p>"},"cp5:3.1":{"pli":"Na me dessaṁ dhanaṁ dhaññaṁ, ","eng":"It was not because I disliked riches or grain, ","html":"<p><span class='verse-line'>{}</span>"},"cp5:3.2":{"pli":"Napi natthi nicayo mayi; ","eng":"or because I had a store set aside, ","html":"<span class='verse-line'>{}</span>"},"cp5:3.3":{"pli":"Sabbaññutaṁ piyaṁ mayhaṁ, ","eng":"but because omniscience is precious to me, ","html":"<span class='verse-line'>{}</span>"},"cp5:3.4":{"pli":"Tasmā demi varaṁ dhanan”ti. ","eng":"that is why I gave such fine riches.” ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"cp5:4.1":{"pli":"Mahāgovindacariyaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"cp6":{"cp6:0.1":{"pli":"Cariyāpiṭaka ","eng":"The Conduct Leading to Buddhahood ","html":"<article id='cp6'><header><ul><li class='division'>{}</li>"},"cp6:0.2":{"pli":"Akittivagga ","eng":"The Chapter With Akitti ","html":"<li>{}</li>"},"cp6:0.3":{"pli":"Dānapāramī 6 ","eng":"The Perfection of Giving (6th) ","html":"<li>{}</li></ul>"},"cp6:0.4":{"pli":"Nimirājacariya ","eng":"King Nimi’s Conduct ","html":"<h1 class='sutta-title'>{}</h1></header>"},"cp6:1.1":{"pli":"“Punāparaṁ yadā homi, ","eng":"“Then again when I was ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"cp6:1.2":{"pli":"mithilāyaṁ puruttame; ","eng":"in the capital city of Mithilā ","html":"<span class='verse-line'>{}</span>"},"cp6:1.3":{"pli":"Nimi nāma mahārājā, ","eng":"I was the great king named Nimi, ","html":"<span class='verse-line'>{}</span>"},"cp6:1.4":{"pli":"paṇḍito kusalatthiko. ","eng":"astute and seeking the good. ","html":"<span class='verse-line'>{}</span></p>"},"cp6:2.1":{"pli":"Tadāhaṁ māpayitvāna, ","eng":"Then having had constructed ","html":"<p><span class='verse-line'>{}</span>"},"cp6:2.2":{"pli":"catussālaṁ catummukhaṁ; ","eng":"four halls with four openings, ","html":"<span class='verse-line'>{}</span>"},"cp6:2.3":{"pli":"Tattha dānaṁ pavattesiṁ, ","eng":"I provided gifts there ","html":"<span class='verse-line'>{}</span>"},"cp6:2.4":{"pli":"migapakkhinarādinaṁ. ","eng":"for beasts, birds, men, and so forth. ","html":"<span class='verse-line'>{}</span></p>"},"cp6:3.1":{"pli":"Acchādanañca sayanaṁ, ","eng":"Clothing and beds, ","html":"<p><span class='verse-line'>{}</span>"},"cp6:3.2":{"pli":"annaṁ pānañca bhojanaṁ; ","eng":"food and drink to enjoy: ","html":"<span class='verse-line'>{}</span>"},"cp6:3.3":{"pli":"Abbocchinnaṁ karitvāna, ","eng":"I provided them without let, ","html":"<span class='verse-line'>{}</span>"},"cp6:3.4":{"pli":"mahādānaṁ pavattayiṁ. ","eng":"performing a great offering. ","html":"<span class='verse-line'>{}</span></p>"},"cp6:4.1":{"pli":"Yathāpi sevako sāmiṁ, ","eng":"Suppose a servant is looking ","html":"<p><span class='verse-line'>{}</span>"},"cp6:4.2":{"pli":"dhanahetumupāgato; ","eng":"to get a raise from their boss, ","html":"<span class='verse-line'>{}</span>"},"cp6:4.3":{"pli":"Kāyena vācā manasā, ","eng":"they’d seek to fulfill their needs ","html":"<span class='verse-line'>{}</span>"},"cp6:4.4":{"pli":"ārādhanīyamesati. ","eng":"by body, speech, and mind. ","html":"<span class='verse-line'>{}</span></p>"},"cp6:5.1":{"pli":"Tathevāhaṁ sabbabhave, ","eng":"In that way in every life ","html":"<p><span class='verse-line'>{}</span>"},"cp6:5.2":{"pli":"pariyesissāmi bodhijaṁ; ","eng":"I shall seek the wisdom born of awakening. ","html":"<span class='verse-line'>{}</span>"},"cp6:5.3":{"pli":"Dānena satte tappetvā, ","eng":"Having pleased beings with gifts, ","html":"<span class='verse-line'>{}</span>"},"cp6:5.4":{"pli":"icchāmi bodhimuttaman”ti. ","eng":"I wish for the supreme awakening.” ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"cp6:6.1":{"pli":"Nimirājacariyaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"cp7":{"cp7:0.1":{"pli":"Cariyāpiṭaka ","eng":"The Conduct Leading to Buddhahood ","html":"<article id='cp7'><header><ul><li class='division'>{}</li>"},"cp7:0.2":{"pli":"Akittivagga ","eng":"The Chapter With Akitti ","html":"<li>{}</li>"},"cp7:0.3":{"pli":"Dānapāramī 7 ","eng":"The Perfection of Giving (7th) ","html":"<li>{}</li></ul>"},"cp7:0.4":{"pli":"Candakumāracariya ","eng":"Prince Candana’s Conduct ","html":"<h1 class='sutta-title'>{}</h1></header>"},"cp7:1.1":{"pli":"“Punāparaṁ yadā homi, ","eng":"“Then again when I was ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"cp7:1.2":{"pli":"ekarājassa atrajo; ","eng":"the true-born son of the One King ","html":"<span class='verse-line'>{}</span>"},"cp7:1.3":{"pli":"Nagare pupphavatiyā, ","eng":"in the city of flowers, Pupphavatī, ","html":"<span class='verse-line'>{}</span>"},"cp7:1.4":{"pli":"kumāro candasavhayo. ","eng":"I was called Prince Canda, the Moon. ","html":"<span class='verse-line'>{}</span></p>"},"cp7:2.1":{"pli":"Tadāhaṁ yajanā mutto, ","eng":"Then, released from being sacrificed, ","html":"<p><span class='verse-line'>{}</span>","comm":"An example of Frazer’s sacrifice of the king and release therefrom. "},"cp7:2.2":{"pli":"nikkhanto yaññavāṭato; ","eng":"I fled the sacrificial enclosure. ","html":"<span class='verse-line'>{}</span>"},"cp7:2.3":{"pli":"Saṁvegaṁ janayitvāna, ","eng":"Giving rise to a sense of urgency, ","html":"<span class='verse-line'>{}</span>"},"cp7:2.4":{"pli":"mahādānaṁ pavattayiṁ. ","eng":"I performed a great offering. ","html":"<span class='verse-line'>{}</span></p>"},"cp7:3.1":{"pli":"Nāhaṁ pivāmi khādāmi, ","eng":"I did not drink, I did not eat, ","html":"<p><span class='verse-line'>{}</span>"},"cp7:3.2":{"pli":"napi bhuñjāmi bhojanaṁ; ","eng":"I did not enjoy any food ","html":"<span class='verse-line'>{}</span>"},"cp7:3.3":{"pli":"Dakkhiṇeyye adatvāna, ","eng":"for five or six days ","html":"<span class='verse-line'>{}</span>"},"cp7:3.4":{"pli":"api chappañcarattiyo. ","eng":"with having first offering to a worthy recipient. ","html":"<span class='verse-line'>{}</span></p>"},"cp7:4.1":{"pli":"Yathāpi vāṇijo nāma, ","eng":"Suppose there was a merchant ","html":"<p><span class='verse-line'>{}</span>"},"cp7:4.2":{"pli":"Katvāna bhaṇḍasañcayaṁ; ","eng":"who had made a store of goods. ","html":"<span class='verse-line'>{}</span>"},"cp7:4.3":{"pli":"Yattha lābho mahā hoti, ","eng":"They would take those goods ","html":"<span class='verse-line'>{}</span>"},"cp7:4.4":{"pli":"Tattha taṁ harati bhaṇḍakaṁ. ","eng":"to where they could make a large profit. ","html":"<span class='verse-line'>{}</span></p>"},"cp7:5.1":{"pli":"Tatheva sakabhuttāpi, ","eng":"So too, even giving what one has used oneself ","html":"<p><span class='verse-line'>{}</span>"},"cp7:5.2":{"pli":"pare dinnaṁ mahapphalaṁ; ","eng":"to others is very fruitful. ","html":"<span class='verse-line'>{}</span>"},"cp7:5.3":{"pli":"Tasmā parassa dātabbaṁ, ","eng":"That is why what is to be given to others ","html":"<span class='verse-line'>{}</span>"},"cp7:5.4":{"pli":"satabhāgo bhavissati. ","eng":"multiplies a hundredfold. ","html":"<span class='verse-line'>{}</span></p>"},"cp7:6.1":{"pli":"Etamatthavasaṁ ñatvā, ","eng":"Knowing the reason for this, ","html":"<p><span class='verse-line'>{}</span>"},"cp7:6.2":{"pli":"demi dānaṁ bhavābhave; ","eng":"I gave gifts in life after life. ","html":"<span class='verse-line'>{}</span>"},"cp7:6.3":{"pli":"Na paṭikkamāmi dānato, ","eng":"I never relented in giving ","html":"<span class='verse-line'>{}</span>"},"cp7:6.4":{"pli":"sambodhimanupattiyā”ti. ","eng":"for the attainment of awakening.” ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"cp7:7.1":{"pli":"Candakumāracariyaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}