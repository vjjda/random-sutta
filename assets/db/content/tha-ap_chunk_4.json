{"tha-ap132":{"tha-ap132:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap132'><header><ul><li class='division'>{}</li>"},"tha-ap132:0.2":{"pli":"Sereyyavagga ","html":"<li>{}</li></ul>"},"tha-ap132:0.3":{"pli":"Padumapūjakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap132:1.1":{"pli":"“Himavantassāvidūre, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap132:1.2":{"pli":"gotamo nāma pabbato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap132:1.3":{"pli":"Nānārukkhehi sañchanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap132:1.4":{"pli":"mahābhūtagaṇālayo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap132:2.1":{"pli":"Vemajjhamhi ca tassāsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap132:2.2":{"pli":"assamo abhinimmito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap132:2.3":{"pli":"Purakkhato sasissehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap132:2.4":{"pli":"vasāmi assame ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap132:3.1":{"pli":"Āyantu me sissagaṇā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap132:3.2":{"pli":"padumaṁ āharantu me; ","html":"<span class='verse-line'>{}</span>"},"tha-ap132:3.3":{"pli":"Buddhapūjaṁ karissāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap132:3.4":{"pli":"dvipadindassa tādino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap132:4.1":{"pli":"Evanti te paṭissutvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap132:4.2":{"pli":"padumaṁ āhariṁsu me; ","html":"<span class='verse-line'>{}</span>"},"tha-ap132:4.3":{"pli":"Tathā nimittaṁ katvāhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap132:4.4":{"pli":"buddhassa abhiropayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap132:5.1":{"pli":"Sisse tadā samānetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap132:5.2":{"pli":"sādhukaṁ anusāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap132:5.3":{"pli":"Mā kho tumhe pamajjittha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap132:5.4":{"pli":"appamādo sukhāvaho. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap132:6.1":{"pli":"Evaṁ samanusāsitvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap132:6.2":{"pli":"te sisse vacanakkhame; ","html":"<span class='verse-line'>{}</span>"},"tha-ap132:6.3":{"pli":"Appamādaguṇe yutto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap132:6.4":{"pli":"tadā kālaṅkato ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap132:7.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap132:7.2":{"pli":"yaṁ pupphamabhiropayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap132:7.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap132:7.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap132:8.1":{"pli":"Ekapaññāsakappamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap132:8.2":{"pli":"rājā āsiṁ jaluttamo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap132:8.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap132:8.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap132:9.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap132:9.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap132:9.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap132:10.1":{"pli":"Itthaṁ sudaṁ āyasmā padumapūjako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap132:11.1":{"pli":"Padumapūjakattherassāpadānaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap132:12.1":{"pli":"Sereyyavaggo terasamo. ","html":"<p class='endsection'>{}</p>"},"tha-ap132:13.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"tha-ap132:14.1":{"pli":"Sereyyako pupphathūpi, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"tha-ap132:14.2":{"pli":"pāyaso gandhathomako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap132:14.3":{"pli":"Āsani phalasaññī ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap132:14.4":{"pli":"gaṇṭhipadumapupphiyo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap132:14.5":{"pli":"Pañcuttarasatā gāthā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap132:14.6":{"pli":"gaṇitā atthadassibhi. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"tha-ap133":{"tha-ap133:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap133'><header><ul><li class='division'>{}</li>"},"tha-ap133:0.2":{"pli":"Sobhitavagga ","html":"<li>{}</li></ul>"},"tha-ap133:0.3":{"pli":"Sobhitattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap133:1.1":{"pli":"“Padumuttaro nāma jino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap133:1.2":{"pli":"lokajeṭṭho narāsabho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap133:1.3":{"pli":"Mahato janakāyassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap133:1.4":{"pli":"deseti amataṁ padaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap133:2.1":{"pli":"Tassāhaṁ vacanaṁ sutvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap133:2.2":{"pli":"vācāsabhimudīritaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap133:2.3":{"pli":"Añjaliṁ paggahetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap133:2.4":{"pli":"ekaggo āsahaṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap133:3.1":{"pli":"‘Yathā samuddo udadhīnamaggo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap133:3.2":{"pli":"Nerū nagānaṁ pavaro siluccayo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap133:3.3":{"pli":"Tatheva ye cittavasena vattare’, ","html":"<span class='verse-line'>{}</span>"},"tha-ap133:3.4":{"pli":"Na buddhañāṇassa kalaṁ upenti te. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap133:4.1":{"pli":"Dhammavidhiṁ ṭhapetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap133:4.2":{"pli":"buddho kāruṇiko isi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap133:4.3":{"pli":"Bhikkhusaṅghe nisīditvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap133:4.4":{"pli":"imā gāthā abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap133:5.1":{"pli":"‘Yo so ñāṇaṁ pakittesi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap133:5.2":{"pli":"buddhamhi lokanāyake; ","html":"<span class='verse-line'>{}</span>"},"tha-ap133:5.3":{"pli":"Kappānaṁ satasahassaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap133:5.4":{"pli":"duggatiṁ na gamissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap133:6.1":{"pli":"Kilese jhāpayitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap133:6.2":{"pli":"ekaggo susamāhito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap133:6.3":{"pli":"Sobhito nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap133:6.4":{"pli":"hessati satthu sāvako’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap133:7.1":{"pli":"Paññāse kappasahasse, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap133:7.2":{"pli":"sattevāsuṁ yasuggatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap133:7.3":{"pli":"Sattaratanasampannā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap133:7.4":{"pli":"cakkavattī mahabbalā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap133:8.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap133:8.2":{"pli":"bhavā sabbe samūhatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap133:8.3":{"pli":"Tisso vijjā anuppattā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap133:8.4":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap133:9.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap133:9.2":{"pli":"vimokkhāpi ca aṭṭhime; ","html":"<span class='verse-line'>{}</span>"},"tha-ap133:9.3":{"pli":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap133:9.4":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap133:10.1":{"pli":"Itthaṁ sudaṁ āyasmā sobhito thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap133:11.1":{"pli":"Sobhitattherassāpadānaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap134":{"tha-ap134:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap134'><header><ul><li class='division'>{}</li>"},"tha-ap134:0.2":{"pli":"Sobhitavagga ","html":"<li>{}</li></ul>"},"tha-ap134:0.3":{"pli":"Sudassanattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap134:1.1":{"pli":"“Vinatā nadiyā tīre, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap134:1.2":{"pli":"pilakkhu phalito ahu; ","html":"<span class='verse-line'>{}</span>"},"tha-ap134:1.3":{"pli":"Tāhaṁ rukkhaṁ gavesanto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap134:1.4":{"pli":"addasaṁ lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap134:2.1":{"pli":"Ketakaṁ pupphitaṁ disvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap134:2.2":{"pli":"vaṇṭe chetvānahaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap134:2.3":{"pli":"Buddhassa abhiropesiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap134:2.4":{"pli":"sikhino lokabandhuno. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap134:3.1":{"pli":"Yena ñāṇena pattosi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap134:3.2":{"pli":"accutaṁ amataṁ padaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap134:3.3":{"pli":"Taṁ ñāṇaṁ abhipūjemi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap134:3.4":{"pli":"buddhaseṭṭha mahāmuni. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap134:4.1":{"pli":"Ñāṇamhi pūjaṁ katvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap134:4.2":{"pli":"pilakkhumaddasaṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap134:4.3":{"pli":"Paṭiladdhomhi taṁ paññaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap134:4.4":{"pli":"ñāṇapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap134:5.1":{"pli":"Ekattiṁse ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap134:5.2":{"pli":"yaṁ pupphamabhiropayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap134:5.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap134:5.4":{"pli":"ñāṇapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap134:6.1":{"pli":"Ito terasakappamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap134:6.2":{"pli":"dvādasāsuṁ phaluggatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap134:6.3":{"pli":"Sattaratanasampannā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap134:6.4":{"pli":"cakkavattī mahapphalā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap134:7.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap134:7.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap134:7.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap134:8.1":{"pli":"Itthaṁ sudaṁ āyasmā sudassano thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap134:9.1":{"pli":"Sudassanattherassāpadānaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap135":{"tha-ap135:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap135'><header><ul><li class='division'>{}</li>"},"tha-ap135:0.2":{"pli":"Sobhitavagga ","html":"<li>{}</li></ul>"},"tha-ap135:0.3":{"pli":"3 Candanapūjanakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap135:1.1":{"pli":"“Candabhāgānadītīre, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap135:1.2":{"pli":"ahosiṁ kinnaro tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap135:1.3":{"pli":"Pupphabhakkho cahaṁ āsiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap135:1.4":{"pli":"pupphānivasano tathā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap135:2.1":{"pli":"Atthadassī tu bhagavā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap135:2.2":{"pli":"lokajeṭṭho narāsabho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap135:2.3":{"pli":"Vipinaggena niyyāsi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap135:2.4":{"pli":"haṁsarājāva ambare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap135:3.1":{"pli":"Namo te purisājañña, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap135:3.2":{"pli":"cittaṁ te suvisodhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap135:3.3":{"pli":"Pasannamukhavaṇṇosi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap135:3.4":{"pli":"vippasannamukhindriyo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap135:4.1":{"pli":"Orohitvāna ākāsā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap135:4.2":{"pli":"bhūripañño sumedhaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap135:4.3":{"pli":"Saṅghāṭiṁ pattharitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap135:4.4":{"pli":"pallaṅkena upāvisi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap135:5.1":{"pli":"Vilīnaṁ candanādāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap135:5.2":{"pli":"agamāsiṁ jinantikaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap135:5.3":{"pli":"Pasannacitto sumano, ","html":"<span class='verse-line'>{}</span>"},"tha-ap135:5.4":{"pli":"buddhassa abhiropayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap135:6.1":{"pli":"Abhivādetvāna sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap135:6.2":{"pli":"lokajeṭṭhaṁ narāsabhaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap135:6.3":{"pli":"Pāmojjaṁ janayitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap135:6.4":{"pli":"pakkāmiṁ uttarāmukho. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap135:7.1":{"pli":"Aṭṭhārase kappasate, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap135:7.2":{"pli":"candanaṁ yaṁ apūjayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap135:7.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap135:7.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap135:8.1":{"pli":"Catuddase kappasate, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap135:8.2":{"pli":"ito āsiṁsu te tayo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap135:8.3":{"pli":"Rohaṇī nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap135:8.4":{"pli":"cakkavattī mahabbalā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap135:9.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap135:9.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap135:9.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap135:10.1":{"pli":"Itthaṁ sudaṁ āyasmā candanapūjanako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap135:11.1":{"pli":"Candanapūjanakattherassāpadānaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}<br>"},"tha-ap135:11.2":{"pli":"Aṭṭhamabhāṇavāraṁ. ","html":"{}</p></article>"}},"tha-ap136":{"tha-ap136:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap136'><header><ul><li class='division'>{}</li>"},"tha-ap136:0.2":{"pli":"Sobhitavagga ","html":"<li>{}</li></ul>"},"tha-ap136:0.3":{"pli":"4 Pupphacchadaniyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap136:1.1":{"pli":"“Sunando nāma nāmena, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap136:1.2":{"pli":"brāhmaṇo mantapāragū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap136:1.3":{"pli":"Ajjhāyako yācayogo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap136:1.4":{"pli":"vājapeyyaṁ ayājayi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap136:2.1":{"pli":"Padumuttaro lokavidū, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap136:2.2":{"pli":"aggo kāruṇiko isi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap136:2.3":{"pli":"Janataṁ anukampanto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap136:2.4":{"pli":"ambare caṅkamī tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap136:3.1":{"pli":"Caṅkamitvāna sambuddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap136:3.2":{"pli":"sabbaññū lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap136:3.3":{"pli":"Mettāya aphari satte, ","html":"<span class='verse-line'>{}</span>"},"tha-ap136:3.4":{"pli":"appamāṇe nirūpadhi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap136:4.1":{"pli":"Vaṇṭe chetvāna pupphāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap136:4.2":{"pli":"brāhmaṇo mantapāragū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap136:4.3":{"pli":"Sabbe sisse samānetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap136:4.4":{"pli":"ākāse ukkhipāpayi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap136:5.1":{"pli":"Yāvatā nagaraṁ āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap136:5.2":{"pli":"pupphānaṁ chadanaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap136:5.3":{"pli":"Buddhassa ānubhāvena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap136:5.4":{"pli":"sattāhaṁ na vigacchatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap136:6.1":{"pli":"Teneva sukkamūlena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap136:6.2":{"pli":"anubhotvāna sampadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap136:6.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap136:6.4":{"pli":"tiṇṇo loke visattikaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap136:7.1":{"pli":"Ekārase kappasate, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap136:7.2":{"pli":"pañcatiṁsāsu khattiyā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap136:7.3":{"pli":"Ambaraṁsasanāmā te, ","html":"<span class='verse-line'>{}</span>"},"tha-ap136:7.4":{"pli":"cakkavattī mahabbalā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap136:8.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap136:8.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap136:8.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap136:9.1":{"pli":"Itthaṁ sudaṁ āyasmā pupphacchadaniyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap136:10.1":{"pli":"Pupphacchadaniyattherassāpadānaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap137":{"tha-ap137:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap137'><header><ul><li class='division'>{}</li>"},"tha-ap137:0.2":{"pli":"Sobhitavagga ","html":"<li>{}</li></ul>"},"tha-ap137:0.3":{"pli":"5 Rahosaññakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap137:1.1":{"pli":"“Himavantassāvidūre, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap137:1.2":{"pli":"vasabho nāma pabbato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap137:1.3":{"pli":"Tasmiṁ pabbatapādamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap137:1.4":{"pli":"assamo āsi māpito. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap137:2.1":{"pli":"Tīṇi sissasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap137:2.2":{"pli":"vācesiṁ brāhmaṇo tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap137:2.3":{"pli":"Saṁharitvāna te sisse, ","html":"<span class='verse-line'>{}</span>"},"tha-ap137:2.4":{"pli":"ekamantaṁ upāvisiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap137:3.1":{"pli":"Ekamantaṁ nisīditvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap137:3.2":{"pli":"brāhmaṇo mantapāragū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap137:3.3":{"pli":"Buddhavedaṁ gavesanto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap137:3.4":{"pli":"ñāṇe cittaṁ pasādayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap137:4.1":{"pli":"Tattha cittaṁ pasādetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap137:4.2":{"pli":"nisīdiṁ paṇṇasanthare; ","html":"<span class='verse-line'>{}</span>"},"tha-ap137:4.3":{"pli":"Pallaṅkaṁ ābhujitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap137:4.4":{"pli":"tattha kālaṅkato ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap137:5.1":{"pli":"Ekattiṁse ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap137:5.2":{"pli":"yaṁ saññamalabhiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap137:5.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap137:5.4":{"pli":"ñāṇasaññāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap137:6.1":{"pli":"Sattavīsatikappamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap137:6.2":{"pli":"rājā siridharo ahu; ","html":"<span class='verse-line'>{}</span>"},"tha-ap137:6.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap137:6.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap137:7.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap137:7.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap137:7.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap137:8.1":{"pli":"Itthaṁ sudaṁ āyasmā rahosaññako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap137:9.1":{"pli":"Rahosaññakattherassāpadānaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap138":{"tha-ap138:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap138'><header><ul><li class='division'>{}</li>"},"tha-ap138:0.2":{"pli":"Sobhitavagga ","html":"<li>{}</li></ul>"},"tha-ap138:0.3":{"pli":"Campakapupphiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap138:1.1":{"pli":"“Kaṇikāraṁva jotantaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap138:1.2":{"pli":"nisinnaṁ pabbatantare; ","html":"<span class='verse-line'>{}</span>"},"tha-ap138:1.3":{"pli":"Obhāsentaṁ disā sabbā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap138:1.4":{"pli":"osadhiṁ viya tārakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap138:2.1":{"pli":"Tayo māṇavakā āsuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap138:2.2":{"pli":"sake sippe susikkhitā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap138:2.3":{"pli":"Khāribhāraṁ gahetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap138:2.4":{"pli":"anventi mama pacchato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap138:3.1":{"pli":"Puṭake satta pupphāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap138:3.2":{"pli":"nikkhittāni tapassinā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap138:3.3":{"pli":"Gahetvā tāni ñāṇamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap138:3.4":{"pli":"vessabhussābhiropayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap138:4.1":{"pli":"Ekattiṁse ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap138:4.2":{"pli":"yaṁ pupphamabhiropayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap138:4.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap138:4.4":{"pli":"ñāṇapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap138:5.1":{"pli":"Ekūnatiṁsakappamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap138:5.2":{"pli":"vipulābhasanāmako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap138:5.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap138:5.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap138:6.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap138:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap138:6.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap138:7.1":{"pli":"Itthaṁ sudaṁ āyasmā campakapupphiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap138:8.1":{"pli":"Campakapupphiyattherassāpadānaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap139":{"tha-ap139:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap139'><header><ul><li class='division'>{}</li>"},"tha-ap139:0.2":{"pli":"Sobhitavagga ","html":"<li>{}</li></ul>"},"tha-ap139:0.3":{"pli":"Atthasandassakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap139:1.1":{"pli":"“Visālamāḷe āsīno, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap139:1.2":{"pli":"addasaṁ lokanāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap139:1.3":{"pli":"Khīṇāsavaṁ balappattaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap139:1.4":{"pli":"bhikkhusaṅghapurakkhataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap139:2.1":{"pli":"Satasahassā tevijjā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap139:2.2":{"pli":"chaḷabhiññā mahiddhikā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap139:2.3":{"pli":"Parivārenti sambuddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap139:2.4":{"pli":"ko disvā nappasīdati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap139:3.1":{"pli":"Ñāṇe upanidhā yassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap139:3.2":{"pli":"na vijjati sadevake; ","html":"<span class='verse-line'>{}</span>"},"tha-ap139:3.3":{"pli":"Anantañāṇaṁ sambuddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap139:3.4":{"pli":"ko disvā nappasīdati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap139:4.1":{"pli":"Dhammakāyañca dīpentaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap139:4.2":{"pli":"kevalaṁ ratanākaraṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap139:4.3":{"pli":"Vikappetuṁ na sakkonti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap139:4.4":{"pli":"ko disvā nappasīdati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap139:5.1":{"pli":"Imāhi tīhi gāthāhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap139:5.2":{"pli":"nāradovhayavacchalo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap139:5.3":{"pli":"Padumuttaraṁ thavitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap139:5.4":{"pli":"sambuddhaṁ aparājitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap139:6.1":{"pli":"Tena cittappasādena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap139:6.2":{"pli":"buddhasanthavanena ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap139:6.3":{"pli":"Kappānaṁ satasahassaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap139:6.4":{"pli":"duggatiṁ nupapajjahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap139:7.1":{"pli":"Ito tiṁsakappasate, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap139:7.2":{"pli":"sumitto nāma khattiyo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap139:7.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap139:7.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap139:8.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap139:8.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap139:8.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap139:9.1":{"pli":"Itthaṁ sudaṁ āyasmā atthasandassako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap139:10.1":{"pli":"Atthasandassakattherassāpadānaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap14":{"tha-ap14:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap14'><header><ul><li class='division'>{}</li>"},"tha-ap14:0.2":{"pli":"Sīhāsaniyavagga ","html":"<li>{}</li></ul>"},"tha-ap14:0.3":{"pli":"Ekatthambhikattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap14:1.1":{"pli":"“Siddhatthassa bhagavato, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap14:1.2":{"pli":"mahāpūgagaṇo ahu; ","html":"<span class='verse-line'>{}</span>"},"tha-ap14:1.3":{"pli":"Saraṇaṁ gatā ca te buddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap14:1.4":{"pli":"saddahanti tathāgataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap14:2.1":{"pli":"Sabbe saṅgamma mantetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap14:2.2":{"pli":"māḷaṁ kubbanti satthuno; ","html":"<span class='verse-line'>{}</span>"},"tha-ap14:2.3":{"pli":"Ekatthambhaṁ alabhantā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap14:2.4":{"pli":"vicinanti brahāvane. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap14:3.1":{"pli":"Tehaṁ araññe disvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap14:3.2":{"pli":"upagamma gaṇaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap14:3.3":{"pli":"Añjaliṁ paggahetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap14:3.4":{"pli":"paripucchiṁ gaṇaṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap14:4.1":{"pli":"Te me puṭṭhā viyākaṁsu, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap14:4.2":{"pli":"sīlavanto upāsakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap14:4.3":{"pli":"Māḷaṁ mayaṁ kattukāmā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap14:4.4":{"pli":"ekatthambho na labbhati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap14:5.1":{"pli":"Ekatthambhaṁ mamaṁ detha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap14:5.2":{"pli":"ahaṁ dassāmi satthuno; ","html":"<span class='verse-line'>{}</span>"},"tha-ap14:5.3":{"pli":"Āharissāmahaṁ thambhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap14:5.4":{"pli":"appossukkā bhavantu te. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap14:6.1":{"pli":"Te me thambhaṁ pavecchiṁsu, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap14:6.2":{"pli":"pasannā tuṭṭhamānasā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap14:6.3":{"pli":"Tato paṭinivattitvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap14:6.4":{"pli":"agamaṁsu sakaṁ gharaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap14:7.1":{"pli":"Aciraṁ gate pūgagaṇe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap14:7.2":{"pli":"thambhaṁ ahāsahaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap14:7.3":{"pli":"Haṭṭho haṭṭhena cittena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap14:7.4":{"pli":"paṭhamaṁ ussapesahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap14:8.1":{"pli":"Tena cittappasādena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap14:8.2":{"pli":"Vimānaṁ upapajjahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap14:8.3":{"pli":"Ubbiddhaṁ bhavanaṁ mayhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap14:8.4":{"pli":"Sattabhūmaṁ samuggataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap14:9.1":{"pli":"Vajjamānāsu bherīsu, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap14:9.2":{"pli":"paricāremahaṁ sadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap14:9.3":{"pli":"Pañcapaññāsakappamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap14:9.4":{"pli":"rājā āsiṁ yasodharo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap14:10.1":{"pli":"Tatthāpi bhavanaṁ mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap14:10.2":{"pli":"sattabhūmaṁ samuggataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap14:10.3":{"pli":"Kūṭāgāravarūpetaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap14:10.4":{"pli":"ekatthambhaṁ manoramaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap14:11.1":{"pli":"Ekavīsatikappamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap14:11.2":{"pli":"udeno nāma khattiyo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap14:11.3":{"pli":"Tatrāpi bhavanaṁ mayhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap14:11.4":{"pli":"sattabhūmaṁ samuggataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap14:12.1":{"pli":"Yaṁ yaṁ yonupapajjāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap14:12.2":{"pli":"devattaṁ atha mānusaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap14:12.3":{"pli":"Anubhomi sukhaṁ sabbaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap14:12.4":{"pli":"ekatthambhassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap14:13.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap14:13.2":{"pli":"yaṁ thambhamadadaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap14:13.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap14:13.4":{"pli":"ekatthambhassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap14:14.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap14:14.2":{"pli":"vimokkhāpi ca aṭṭhime; ","html":"<span class='verse-line'>{}</span>"},"tha-ap14:14.3":{"pli":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap14:14.4":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap14:15.1":{"pli":"Itthaṁ sudaṁ āyasmā ekatthambhiko thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap14:16.1":{"pli":"Ekatthambhikattherassāpadānaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap140":{"tha-ap140:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap140'><header><ul><li class='division'>{}</li>"},"tha-ap140:0.2":{"pli":"Sobhitavagga ","html":"<li>{}</li></ul>"},"tha-ap140:0.3":{"pli":"8 Ekapasādaniyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap140:1.1":{"pli":"“Nārado iti me nāmaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap140:1.2":{"pli":"kesavo iti maṁ vidū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap140:1.3":{"pli":"Kusalākusalaṁ esaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap140:1.4":{"pli":"agamaṁ buddhasantikaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap140:2.1":{"pli":"Mettacitto kāruṇiko, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap140:2.2":{"pli":"atthadassī mahāmuni; ","html":"<span class='verse-line'>{}</span>"},"tha-ap140:2.3":{"pli":"Assāsayanto satte so, ","html":"<span class='verse-line'>{}</span>"},"tha-ap140:2.4":{"pli":"dhammaṁ deseti cakkhumā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap140:3.1":{"pli":"Sakaṁ cittaṁ pasādetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap140:3.2":{"pli":"sire katvāna añjaliṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap140:3.3":{"pli":"Satthāraṁ abhivādetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap140:3.4":{"pli":"pakkāmiṁ pācināmukho. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap140:4.1":{"pli":"Sattarase kappasate, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap140:4.2":{"pli":"rājā āsi mahīpati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap140:4.3":{"pli":"Amittatāpano nāma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap140:4.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap140:5.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap140:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap140:5.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap140:6.1":{"pli":"Itthaṁ sudaṁ āyasmā ekapasādaniyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap140:7.1":{"pli":"Ekapasādaniyattherassāpadānaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap141":{"tha-ap141:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap141'><header><ul><li class='division'>{}</li>"},"tha-ap141:0.2":{"pli":"Sobhitavagga ","html":"<li>{}</li></ul>"},"tha-ap141:0.3":{"pli":"9 Sālapupphadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap141:1.1":{"pli":"“Migarājā tadā āsiṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap141:1.2":{"pli":"abhijāto sukesarī; ","html":"<span class='verse-line'>{}</span>"},"tha-ap141:1.3":{"pli":"Giriduggaṁ gavesanto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap141:1.4":{"pli":"addasaṁ lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap141:2.1":{"pli":"Ayaṁ nu kho mahāvīro, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap141:2.2":{"pli":"nibbāpeti mahājanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap141:2.3":{"pli":"Yannūnāhaṁ upāseyyaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap141:2.4":{"pli":"devadevaṁ narāsabhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap141:3.1":{"pli":"Sākhaṁ sālassa bhañjitvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap141:3.2":{"pli":"sakosaṁ pupphamāhariṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap141:3.3":{"pli":"Upagantvāna sambuddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap141:3.4":{"pli":"adāsiṁ pupphamuttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap141:4.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap141:4.2":{"pli":"yaṁ pupphamabhiropayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap141:4.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap141:4.4":{"pli":"pupphadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap141:5.1":{"pli":"Ito ca navame kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap141:5.2":{"pli":"virocanasanāmakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap141:5.3":{"pli":"Tayo āsiṁsu rājāno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap141:5.4":{"pli":"cakkavattī mahabbalā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap141:6.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap141:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap141:6.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap141:7.1":{"pli":"Itthaṁ sudaṁ āyasmā sālapupphadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap141:8.1":{"pli":"Sālapupphadāyakattherassāpadānaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap142":{"tha-ap142:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap142'><header><ul><li class='division'>{}</li>"},"tha-ap142:0.2":{"pli":"Sobhitavagga ","html":"<li>{}</li></ul>"},"tha-ap142:0.3":{"pli":"10 Piyālaphaladāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap142:1.1":{"pli":"“Pārāvato tadā āsiṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap142:1.2":{"pli":"paraṁ anuparodhako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap142:1.3":{"pli":"Pabbhāre seyyaṁ kappemi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap142:1.4":{"pli":"avidūre sikhisatthuno. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap142:2.1":{"pli":"Sāyaṁ pātañca passāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap142:2.2":{"pli":"buddhaṁ lokagganāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap142:2.3":{"pli":"Deyyadhammo ca me natthi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap142:2.4":{"pli":"dvipadindassa tādino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap142:3.1":{"pli":"Piyālaphalamādāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap142:3.2":{"pli":"agamaṁ buddhasantikaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap142:3.3":{"pli":"Paṭiggahesi bhagavā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap142:3.4":{"pli":"lokajeṭṭho narāsabho. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap142:4.1":{"pli":"Tato paraṁ upādāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap142:4.2":{"pli":"paricāriṁ vināyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap142:4.3":{"pli":"Tena cittappasādena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap142:4.4":{"pli":"tattha kālaṅkato ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap142:5.1":{"pli":"Ekattiṁse ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap142:5.2":{"pli":"yaṁ phalaṁ adadiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap142:5.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap142:5.4":{"pli":"phaladānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap142:6.1":{"pli":"Ito pannarase kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap142:6.2":{"pli":"tayo āsuṁ piyālino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap142:6.3":{"pli":"Sattaratanasampannā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap142:6.4":{"pli":"cakkavattī mahabbalā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap142:7.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap142:7.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap142:7.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap142:8.1":{"pli":"Itthaṁ sudaṁ āyasmā piyālaphaladāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap142:9.1":{"pli":"Piyālaphaladāyakattherassāpadānaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap142:10.1":{"pli":"Sobhitavaggo cuddasamo. ","html":"<p class='endsection'>{}</p>"},"tha-ap142:11.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"tha-ap142:12.1":{"pli":"Sobhitasudassano ca, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"tha-ap142:12.2":{"pli":"candano pupphachadano; ","html":"<span class='verse-line'>{}</span>"},"tha-ap142:12.3":{"pli":"Raho campakapupphī ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap142:12.4":{"pli":"atthasandassakena ca. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap142:13.1":{"pli":"Ekapasādī sāladado, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap142:13.2":{"pli":"dasamo phaladāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap142:13.3":{"pli":"Gāthāyo sattati dve ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap142:13.4":{"pli":"gaṇitāyo vibhāvibhi. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"tha-ap143":{"tha-ap143:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap143'><header><ul><li class='division'>{}</li>"},"tha-ap143:0.2":{"pli":"Chattavagga ","html":"<li>{}</li></ul>"},"tha-ap143:0.3":{"pli":"1 Atichattiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap143:1.1":{"pli":"“Parinibbute bhagavati, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap143:1.2":{"pli":"atthadassīnaruttame; ","html":"<span class='verse-line'>{}</span>"},"tha-ap143:1.3":{"pli":"Chattātichattaṁ kāretvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap143:1.4":{"pli":"thūpamhi abhiropayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap143:2.1":{"pli":"Kālena kālamāgantvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap143:2.2":{"pli":"namassiṁ lokanāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap143:2.3":{"pli":"Pupphacchadanaṁ katvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap143:2.4":{"pli":"chattamhi abhiropayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap143:3.1":{"pli":"Sattarase kappasate, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap143:3.2":{"pli":"devarajjamakārayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap143:3.3":{"pli":"Manussattaṁ na gacchāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap143:3.4":{"pli":"thūpapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap143:4.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap143:4.2":{"pli":"vimokkhāpi ca aṭṭhime; ","html":"<span class='verse-line'>{}</span>"},"tha-ap143:4.3":{"pli":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap143:4.4":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap143:5.1":{"pli":"Itthaṁ sudaṁ āyasmā atichattiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap143:6.1":{"pli":"Atichattiyattherassāpadānaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}