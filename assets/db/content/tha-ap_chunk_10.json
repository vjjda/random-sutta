{"tha-ap206":{"tha-ap206:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap206'><header><ul><li class='division'>{}</li>"},"tha-ap206:0.2":{"pli":"Kaṇikārapupphiyavagga ","html":"<li>{}</li></ul>"},"tha-ap206:0.3":{"pli":"Taraṇiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap206:1.1":{"pli":"“Atthadassī tu bhagavā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap206:1.2":{"pli":"dvipadindo narāsabho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap206:1.3":{"pli":"Purakkhato sāvakehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap206:1.4":{"pli":"gaṅgātīramupāgami. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap206:2.1":{"pli":"Samatitti kākapeyyā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap206:2.2":{"pli":"gaṅgā āsi duruttarā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap206:2.3":{"pli":"Uttārayiṁ bhikkhusaṅghaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap206:2.4":{"pli":"buddhañca dvipaduttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap206:3.1":{"pli":"Aṭṭhārase kappasate, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap206:3.2":{"pli":"yaṁ kammamakariṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap206:3.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap206:3.4":{"pli":"taraṇāya idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap206:4.1":{"pli":"Teraseto kappasate, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap206:4.2":{"pli":"pañca sabbobhavā ahuṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap206:4.3":{"pli":"Sattaratanasampannā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap206:4.4":{"pli":"cakkavattī mahabbalā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap206:5.1":{"pli":"Pacchime ca bhave asmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap206:5.2":{"pli":"jātohaṁ brāhmaṇe kule; ","html":"<span class='verse-line'>{}</span>"},"tha-ap206:5.3":{"pli":"Saddhiṁ tīhi sahāyehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap206:5.4":{"pli":"pabbajiṁ satthu sāsane. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap206:6.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap206:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap206:6.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap206:7.1":{"pli":"Itthaṁ sudaṁ āyasmā taraṇiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap206:8.1":{"pli":"Taraṇiyattherassāpadānaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap207":{"tha-ap207:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap207'><header><ul><li class='division'>{}</li>"},"tha-ap207:0.2":{"pli":"Kaṇikārapupphiyavagga ","html":"<li>{}</li></ul>"},"tha-ap207:0.3":{"pli":"Nigguṇḍipupphiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap207:1.1":{"pli":"“Vipassissa bhagavato, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap207:1.2":{"pli":"āsimārāmiko ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap207:1.3":{"pli":"Nigguṇḍipupphaṁ paggayha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap207:1.4":{"pli":"buddhassa abhiropayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap207:2.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap207:2.2":{"pli":"yaṁ pupphamabhipūjayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap207:2.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap207:2.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap207:3.1":{"pli":"Pañcavīse ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap207:3.2":{"pli":"eko āsiṁ janādhipo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap207:3.3":{"pli":"Mahāpatāpanāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap207:3.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap207:4.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap207:4.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap207:4.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap207:5.1":{"pli":"Itthaṁ sudaṁ āyasmā nigguṇḍipupphiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap207:6.1":{"pli":"Nigguṇḍipupphiyattherassāpadānaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap208":{"tha-ap208:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap208'><header><ul><li class='division'>{}</li>"},"tha-ap208:0.2":{"pli":"Kaṇikārapupphiyavagga ","html":"<li>{}</li></ul>"},"tha-ap208:0.3":{"pli":"Udakadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap208:1.1":{"pli":"“Bhuñjantaṁ samaṇaṁ disvā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap208:1.2":{"pli":"vippasannamanāvilaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap208:1.3":{"pli":"Ghaṭenodakamādāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap208:1.4":{"pli":"siddhatthassa adāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap208:2.1":{"pli":"Nimmalo homahaṁ ajja, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap208:2.2":{"pli":"vimalo khīṇasaṁsayo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap208:2.3":{"pli":"Bhave nibbattamānamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap208:2.4":{"pli":"phalaṁ nibbattate mama. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap208:3.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap208:3.2":{"pli":"udakaṁ yamadāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap208:3.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap208:3.4":{"pli":"dakadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap208:4.1":{"pli":"Ekasaṭṭhimhito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap208:4.2":{"pli":"ekova vimalo ahu; ","html":"<span class='verse-line'>{}</span>"},"tha-ap208:4.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap208:4.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap208:5.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap208:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap208:5.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap208:6.1":{"pli":"Itthaṁ sudaṁ āyasmā udakadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap208:7.1":{"pli":"Udakadāyakattherassāpadānaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap209":{"tha-ap209:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap209'><header><ul><li class='division'>{}</li>"},"tha-ap209:0.2":{"pli":"Kaṇikārapupphiyavagga ","html":"<li>{}</li></ul>"},"tha-ap209:0.3":{"pli":"7 Salalamāliyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap209:1.1":{"pli":"“Kaṇikāraṁva jotantaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap209:1.2":{"pli":"nisinnaṁ pabbatantare; ","html":"<span class='verse-line'>{}</span>"},"tha-ap209:1.3":{"pli":"Obhāsentaṁ disā sabbā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap209:1.4":{"pli":"siddhatthaṁ narasārathiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap209:2.1":{"pli":"Dhanuṁ advejjhaṁ katvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap209:2.2":{"pli":"usuṁ sannayhahaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap209:2.3":{"pli":"Pupphaṁ savaṇṭaṁ chetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap209:2.4":{"pli":"buddhassa abhiropayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap209:3.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap209:3.2":{"pli":"yaṁ pupphamabhiropayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap209:3.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap209:3.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap209:4.1":{"pli":"Ekapaññāsito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap209:4.2":{"pli":"eko āsiṁ jutindharo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap209:4.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap209:4.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap209:5.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap209:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap209:5.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap209:6.1":{"pli":"Itthaṁ sudaṁ āyasmā salalamāliyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap209:7.1":{"pli":"Salalamāliyattherassāpadānaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap21":{"tha-ap21:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap21'><header><ul><li class='division'>{}</li>"},"tha-ap21:0.2":{"pli":"Sīhāsaniyavagga ","html":"<li>{}</li></ul>"},"tha-ap21:0.3":{"pli":"Sopākattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap21:1.1":{"pli":"“Pabbhāraṁ sodhayantassa, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap21:1.2":{"pli":"vipine pabbatuttame; ","html":"<span class='verse-line'>{}</span>"},"tha-ap21:1.3":{"pli":"Siddhattho nāma bhagavā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap21:1.4":{"pli":"āgacchi mama santikaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap21:2.1":{"pli":"Buddhaṁ upagataṁ disvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap21:2.2":{"pli":"lokajeṭṭhassa tādino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap21:2.3":{"pli":"Santharaṁ paññapetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap21:2.4":{"pli":"pupphāsanamadāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap21:3.1":{"pli":"Pupphāsane nisīditvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap21:3.2":{"pli":"siddhattho lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap21:3.3":{"pli":"Mamañca gatimaññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap21:3.4":{"pli":"aniccatamudāhari. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap21:4.1":{"pli":"‘Aniccā vata saṅkhārā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap21:4.2":{"pli":"uppādavayadhammino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap21:4.3":{"pli":"Uppajjitvā nirujjhanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap21:4.4":{"pli":"tesaṁ vūpasamo sukho’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap21:5.1":{"pli":"Idaṁ vatvāna sabbaññū, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap21:5.2":{"pli":"lokajeṭṭho narāsabho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap21:5.3":{"pli":"Nabhaṁ abbhuggami vīro, ","html":"<span class='verse-line'>{}</span>"},"tha-ap21:5.4":{"pli":"haṁsarājāva ambare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap21:6.1":{"pli":"Sakaṁ diṭṭhiṁ jahitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap21:6.2":{"pli":"bhāvayāniccasaññahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap21:6.3":{"pli":"Ekāhaṁ bhāvayitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap21:6.4":{"pli":"tattha kālaṁ kato ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap21:7.1":{"pli":"Dve sampattī anubhotvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap21:7.2":{"pli":"sukkamūlena codito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap21:7.3":{"pli":"Pacchime bhave sampatte, ","html":"<span class='verse-line'>{}</span>"},"tha-ap21:7.4":{"pli":"sapākayonupāgamiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap21:8.1":{"pli":"Agārā abhinikkhamma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap21:8.2":{"pli":"pabbajiṁ anagāriyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap21:8.3":{"pli":"Jātiyā sattavassohaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap21:8.4":{"pli":"arahattamapāpuṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap21:9.1":{"pli":"Āraddhavīriyo pahitatto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap21:9.2":{"pli":"Sīlesu susamāhito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap21:9.3":{"pli":"Tosetvāna mahānāgaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap21:9.4":{"pli":"Alatthaṁ upasampadaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap21:10.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap21:10.2":{"pli":"yaṁ kammamakariṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap21:10.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap21:10.4":{"pli":"pupphadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap21:11.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap21:11.2":{"pli":"yaṁ saññaṁ bhāvayiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap21:11.3":{"pli":"Taṁ saññaṁ bhāvayantassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap21:11.4":{"pli":"patto me āsavakkhayo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap21:12.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap21:12.2":{"pli":"vimokkhāpi ca aṭṭhime; ","html":"<span class='verse-line'>{}</span>"},"tha-ap21:12.3":{"pli":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap21:12.4":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap21:13.1":{"pli":"Itthaṁ sudaṁ āyasmā sopāko thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap21:14.1":{"pli":"Sopākattherassāpadānaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap210":{"tha-ap210:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap210'><header><ul><li class='division'>{}</li>"},"tha-ap210:0.2":{"pli":"Kaṇikārapupphiyavagga ","html":"<li>{}</li></ul>"},"tha-ap210:0.3":{"pli":"Koraṇḍapupphiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap210:1.1":{"pli":"“Akkantañca padaṁ disvā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap210:1.2":{"pli":"cakkālaṅkārabhūsitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap210:1.3":{"pli":"Padenānupadaṁ yanto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap210:1.4":{"pli":"vipassissa mahesino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap210:2.1":{"pli":"Koraṇḍaṁ pupphitaṁ disvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap210:2.2":{"pli":"samūlaṁ pūjitaṁ mayā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap210:2.3":{"pli":"Haṭṭho haṭṭhena cittena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap210:2.4":{"pli":"avandiṁ padamuttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap210:3.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap210:3.2":{"pli":"yaṁ pupphamabhipūjayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap210:3.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap210:3.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha