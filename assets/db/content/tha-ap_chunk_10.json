:"<p><span class='verse-line'>{}</span>"},"tha-ap214:3.2":{"pli":"yaṁ kammamakariṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap214:3.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap214:3.4":{"pli":"pānadhissa idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap214:4.1":{"pli":"Sattasattatito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap214:4.2":{"pli":"aṭṭha āsiṁsu khattiyā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap214:4.3":{"pli":"Suyānā nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap214:4.4":{"pli":"cakkavattī mahabbalā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap214:5.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap214:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap214:5.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap214:6.1":{"pli":"Itthaṁ sudaṁ āyasmā pānadhidāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap214:7.1":{"pli":"Pānadhidāyakattherassāpadānaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap215":{"tha-ap215:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap215'><header><ul><li class='division'>{}</li>"},"tha-ap215:0.2":{"pli":"Hatthivagga ","html":"<li>{}</li></ul>"},"tha-ap215:0.3":{"pli":"Saccasaññakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap215:1.1":{"pli":"“Vessabhū tamhi samaye, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap215:1.2":{"pli":"bhikkhusaṅghapurakkhato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap215:1.3":{"pli":"Deseti ariyasaccāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap215:1.4":{"pli":"nibbāpento mahājanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap215:2.1":{"pli":"Paramakāruññapattomhi, ","html":"<p><span class='verse-l