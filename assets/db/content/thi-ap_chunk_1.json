{"thi-ap15":{"thi-ap15:0.1":{"pli":"Therīapadāna ","html":"<article id='thi-ap15'><header><ul><li class='division'>{}</li>"},"thi-ap15:0.2":{"pli":"Ekūposathikavagga ","html":"<li>{}</li></ul>"},"thi-ap15:0.3":{"pli":"Pañcadīpadāyikātherīapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"thi-ap15:1.1":{"pli":"“Nagare haṁsavatiyā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"thi-ap15:1.2":{"pli":"cārikī āsahaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:1.3":{"pli":"Ārāmena ca ārāmaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:1.4":{"pli":"carāmi kusalatthikā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap15:2.1":{"pli":"Kāḷapakkhamhi divase, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap15:2.2":{"pli":"addasaṁ bodhimuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:2.3":{"pli":"Tattha cittaṁ pasādetvā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:2.4":{"pli":"bodhimūle nisīdahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap15:3.1":{"pli":"Garucittaṁ upaṭṭhetvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap15:3.2":{"pli":"sire katvāna añjaliṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:3.3":{"pli":"Somanassaṁ pavedetvā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:3.4":{"pli":"evaṁ cintesi tāvade. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap15:4.1":{"pli":"‘Yadi buddho amitaguṇo, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap15:4.2":{"pli":"asamappaṭipuggalo; ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:4.3":{"pli":"Dassetu pāṭihīraṁ me, ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:4.4":{"pli":"bodhi obhāsatu ayaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap15:5.1":{"pli":"Saha āvajjite mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap15:5.2":{"pli":"bodhi pajjali tāvade; ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:5.3":{"pli":"Sabbasoṇṇamayā āsi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:5.4":{"pli":"disā sabbā virocati. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap15:6.1":{"pli":"Sattarattindivaṁ tattha, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap15:6.2":{"pli":"bodhimūle nisīdahaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:6.3":{"pli":"Sattame divase patte, ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:6.4":{"pli":"dīpapūjaṁ akāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap15:7.1":{"pli":"Āsanaṁ parivāretvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap15:7.2":{"pli":"pañca dīpāni pajjaluṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:7.3":{"pli":"Yāva udeti sūriyo, ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:7.4":{"pli":"dīpā me pajjaluṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap15:8.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap15:8.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:8.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:8.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap15:9.1":{"pli":"Tattha me sukataṁ byamhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap15:9.2":{"pli":"pañcadīpāti vuccati; ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:9.3":{"pli":"Saṭṭhiyojanamubbedhaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:9.4":{"pli":"tiṁsayojanavitthataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap15:10.1":{"pli":"Asaṅkhiyāni dīpāni, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap15:10.2":{"pli":"parivāre jaliṁsu me; ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:10.3":{"pli":"Yāvatā devabhavanaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:10.4":{"pli":"dīpālokena jotati. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap15:11.1":{"pli":"Parammukhā nisīditvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap15:11.2":{"pli":"yadi icchāmi passituṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:11.3":{"pli":"Uddhaṁ adho ca tiriyaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:11.4":{"pli":"sabbaṁ passāmi cakkhunā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap15:12.1":{"pli":"Yāvatā abhikaṅkhāmi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap15:12.2":{"pli":"daṭṭhuṁ sugataduggate; ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:12.3":{"pli":"Tattha āvaraṇaṁ natthi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:12.4":{"pli":"rukkhesu pabbatesu vā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap15:13.1":{"pli":"Asīti devarājūnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap15:13.2":{"pli":"mahesittamakārayiṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:13.3":{"pli":"Satānaṁ cakkavattīnaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:13.4":{"pli":"mahesittamakārayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap15:14.1":{"pli":"Yaṁ yaṁ yonupapajjāmi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap15:14.2":{"pli":"devattaṁ atha mānusaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:14.3":{"pli":"Dīpasatasahassāni, ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:14.4":{"pli":"parivāre jalanti me. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap15:15.1":{"pli":"Devalokā cavitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap15:15.2":{"pli":"uppajjiṁ mātukucchiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:15.3":{"pli":"Mātukucchigatā santī, ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:15.4":{"pli":"akkhi me na nimīlati. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap15:16.1":{"pli":"Dīpasatasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap15:16.2":{"pli":"puññakammasamaṅgitā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:16.3":{"pli":"Jalanti sūtikāgehe, ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:16.4":{"pli":"pañcadīpānidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap15:17.1":{"pli":"Pacchime bhave sampatte, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap15:17.2":{"pli":"mānasaṁ vinivattayiṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:17.3":{"pli":"Ajarāmataṁ sītibhāvaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:17.4":{"pli":"nibbānaṁ phassayiṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap15:18.1":{"pli":"Jātiyā sattavassāhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap15:18.2":{"pli":"arahattamapāpuṇiṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:18.3":{"pli":"Upasampādayī buddho, ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:18.4":{"pli":"guṇamaññāya gotamo. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap15:19.1":{"pli":"Maṇḍape rukkhamūle vā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap15:19.2":{"pli":"suññāgāre vasantiyā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:19.3":{"pli":"Sadā pajjalate dīpaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:19.4":{"pli":"pañcadīpānidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap15:20.1":{"pli":"Dibbacakkhuvisuddhaṁ me, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap15:20.2":{"pli":"samādhikusalā ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:20.3":{"pli":"Abhiññāpāramippattā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:20.4":{"pli":"pañcadīpānidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap15:21.1":{"pli":"Sabbavositavosānā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap15:21.2":{"pli":"katakiccā anāsavā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:21.3":{"pli":"Pañcadīpā mahāvīra, ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:21.4":{"pli":"pāde vandāmi cakkhuma. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap15:22.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap15:22.2":{"pli":"yaṁ dīpamadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:22.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:22.4":{"pli":"pañcadīpānidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap15:23.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap15:23.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:23.3":{"pli":"viharāmi anāsavā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap15:24.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap15:24.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:24.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap15:25.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap15:25.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap15:25.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"thi-ap15:26.1":{"pli":"Itthaṁ sudaṁ pañcadīpadāyikā bhikkhunī imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"thi-ap15:27.1":{"pli":"Pañcadīpadāyikātheriyāpadānaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"thi-ap16":{"thi-ap16:0.1":{"pli":"Therīapadāna ","html":"<article id='thi-ap16'><header><ul><li class='division'>{}</li>"},"thi-ap16:0.2":{"pli":"Ekūposathikavagga ","html":"<li>{}</li></ul>"},"thi-ap16:0.3":{"pli":"6 Naḷamālikātherīapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"thi-ap16:1.1":{"pli":"“Candabhāgānadītīre, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"thi-ap16:1.2":{"pli":"ahosiṁ kinnarī tadā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap16:1.3":{"pli":"Addasaṁ virajaṁ buddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap16:1.4":{"pli":"sayambhuṁ aparājitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap16:2.1":{"pli":"Pasannacittā sumanā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap16:2.2":{"pli":"vedajātā katañjalī; ","html":"<span class='verse-line'>{}</span>"},"thi-ap16:2.3":{"pli":"Naḷamālaṁ gahetvāna, ","html":"<span class='verse-line'>{}</span>"},"thi-ap16:2.4":{"pli":"sayambhuṁ abhipūjayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap16:3.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap16:3.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap16:3.3":{"pli":"Jahitvā kinnarīdehaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap16:3.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap16:4.1":{"pli":"Chattiṁsadevarājūnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap16:4.2":{"pli":"mahesittamakārayiṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap16:4.3":{"pli":"Manasā patthitaṁ mayhaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap16:4.4":{"pli":"nibbattati yathicchitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap16:5.1":{"pli":"Dasannaṁ cakkavattīnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap16:5.2":{"pli":"mahesittamakārayiṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap16:5.3":{"pli":"Ocitattāva hutvāna, ","html":"<span class='verse-line'>{}</span>"},"thi-ap16:5.4":{"pli":"saṁsarāmi bhavesvahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap16:6.1":{"pli":"Kusalaṁ vijjate mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap16:6.2":{"pli":"pabbajiṁ anagāriyaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap16:6.3":{"pli":"Pūjārahā ahaṁ ajja, ","html":"<span class='verse-line'>{}</span>"},"thi-ap16:6.4":{"pli":"sakyaputtassa sāsane. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap16:7.1":{"pli":"Visuddhamanasā ajja, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap16:7.2":{"pli":"apetamanapāpikā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap16:7.3":{"pli":"Sabbāsavā parikkhīṇā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap16:7.4":{"pli":"natthi dāni punabbhavo. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap16:8.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap16:8.2":{"pli":"yaṁ buddhamabhipūjayiṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap16:8.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap16:8.4":{"pli":"naḷamālāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap16:9.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap16:9.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap16:9.3":{"pli":"viharāmi anāsavā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap16:10.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap16:10.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap16:10.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap16:11.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap16:11.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap16:11.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"thi-ap16:12.1":{"pli":"Itthaṁ sudaṁ naḷamālikā bhikkhunī imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"thi-ap16:13.1":{"pli":"Naḷamālikātheriyāpadānaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}