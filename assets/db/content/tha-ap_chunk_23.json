{"tha-ap341":{"tha-ap341:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap341'><header><ul><li class='division'>{}</li>"},"tha-ap341:0.2":{"pli":"Gandhodakavagga ","html":"<li>{}</li></ul>"},"tha-ap341:0.3":{"pli":"9 Dhammasavaniyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap341:1.1":{"pli":"“Padumuttaro nāma jino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap341:1.2":{"pli":"sabbadhammāna pāragū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:1.3":{"pli":"Catusaccaṁ pakāsento, ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:1.4":{"pli":"santāresi bahuṁ janaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap341:2.1":{"pli":"Ahaṁ tena samayena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap341:2.2":{"pli":"jaṭilo uggatāpano; ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:2.3":{"pli":"Dhunanto vākacīrāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:2.4":{"pli":"gacchāmi ambare tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap341:3.1":{"pli":"Buddhaseṭṭhassa upari, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap341:3.2":{"pli":"gantuṁ na visahāmahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:3.3":{"pli":"Pakkhīva selamāsajja, ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:3.4":{"pli":"gamanaṁ na labhāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap341:4.1":{"pli":"Na me idaṁ bhūtapubbaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap341:4.2":{"pli":"iriyassa vikopanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:4.3":{"pli":"Dake yathā ummujjitvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:4.4":{"pli":"evaṁ gacchāmi ambare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap341:5.1":{"pli":"Uḷārabhūto manujo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap341:5.2":{"pli":"heṭṭhāsīno bhavissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:5.3":{"pli":"Handa menaṁ gavesissaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:5.4":{"pli":"api atthaṁ labheyyahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap341:6.1":{"pli":"Orohanto antalikkhā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap341:6.2":{"pli":"saddamassosi satthuno; ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:6.3":{"pli":"Aniccataṁ kathentassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:6.4":{"pli":"tamahaṁ uggahiṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap341:7.1":{"pli":"Aniccasaññamuggayha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap341:7.2":{"pli":"agamāsiṁ mamassamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:7.3":{"pli":"Yāvatāyuṁ vasitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:7.4":{"pli":"tattha kālaṅkato ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap341:8.1":{"pli":"Carime vattamānamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap341:8.2":{"pli":"Taṁ dhammasavanaṁ sariṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:8.3":{"pli":"Tena kammena sukatena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:8.4":{"pli":"Tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap341:9.1":{"pli":"Tiṁsakappasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap341:9.2":{"pli":"devaloke ramiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:9.3":{"pli":"Ekapaññāsakkhattuñca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:9.4":{"pli":"devarajjamakārayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap341:10.1":{"pli":"Ekasattatikkhattuñca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap341:10.2":{"pli":"cakkavattī ahosahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:10.3":{"pli":"Padesarajjaṁ vipulaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:10.4":{"pli":"gaṇanāto asaṅkhiyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap341:11.1":{"pli":"Pitugehe nisīditvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap341:11.2":{"pli":"samaṇo bhāvitindriyo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:11.3":{"pli":"Gāthāya paridīpento, ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:11.4":{"pli":"aniccatamudāhari. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap341:12.1":{"pli":"Anussarāmi taṁ saññaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap341:12.2":{"pli":"saṁsaranto bhavābhave; ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:12.3":{"pli":"Na koṭiṁ paṭivijjhāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:12.4":{"pli":"nibbānaṁ accutaṁ padaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap341:13.1":{"pli":"Aniccā vata saṅkhārā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap341:13.2":{"pli":"uppādavayadhammino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:13.3":{"pli":"Uppajjitvā nirujjhanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:13.4":{"pli":"tesaṁ vūpasamo sukho. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap341:14.1":{"pli":"Saha gāthaṁ suṇitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap341:14.2":{"pli":"pubbakammaṁ anussariṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:14.3":{"pli":"Ekāsane nisīditvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:14.4":{"pli":"arahattamapāpuṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap341:15.1":{"pli":"Jātiyā sattavassohaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap341:15.2":{"pli":"arahattamapāpuṇiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:15.3":{"pli":"Upasampādayi buddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:15.4":{"pli":"guṇamaññāya cakkhumā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap341:16.1":{"pli":"Dārakova ahaṁ santo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap341:16.2":{"pli":"karaṇīyaṁ samāpayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:16.3":{"pli":"Kiṁ me karaṇīyaṁ ajja, ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:16.4":{"pli":"sakyaputtassa sāsane. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap341:17.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap341:17.2":{"pli":"yaṁ kammamakariṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:17.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:17.4":{"pli":"saddhammasavane phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap341:18.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap341:18.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap341:18.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap341:19.1":{"pli":"Itthaṁ sudaṁ āyasmā dhammasavaniyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap341:20.1":{"pli":"Dhammasavaniyattherassāpadānaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap342":{"tha-ap342:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap342'><header><ul><li class='division'>{}</li>"},"tha-ap342:0.2":{"pli":"Gandhodakavagga ","html":"<li>{}</li></ul>"},"tha-ap342:0.3":{"pli":"Ukkhittapadumiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap342:1.1":{"pli":"“Nagare haṁsavatiyā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap342:1.2":{"pli":"ahosiṁ māliko tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap342:1.3":{"pli":"Ogāhetvā padumasaraṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap342:1.4":{"pli":"satapattaṁ ocināmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap342:2.1":{"pli":"Padumuttaro nāma jino, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap342:2.2":{"pli":"sabbadhammāna pāragū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap342:2.3":{"pli":"Saha satasahassehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap342:2.4":{"pli":"santacittehi tādibhi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap342:3.1":{"pli":"Khīṇāsavehi suddhehi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap342:3.2":{"pli":"chaḷabhiññehi jhāyibhi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap342:3.3":{"pli":"Mama vuddhiṁ samanvesaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap342:3.4":{"pli":"āgacchi mama santikaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap342:4.1":{"pli":"Disvānahaṁ devadevaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap342:4.2":{"pli":"sayambhuṁ lokanāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap342:4.3":{"pli":"Vaṇṭe chetvā satapattaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap342:4.4":{"pli":"ukkhipimambare tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap342:5.1":{"pli":"Yadi buddho tuvaṁ vīra, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap342:5.2":{"pli":"lokajeṭṭho narāsabho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap342:5.3":{"pli":"Sayaṁ gantvā satapattā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap342:5.4":{"pli":"matthake dhārayantu te. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap342:6.1":{"pli":"Adhiṭṭhahi mahāvīro, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap342:6.2":{"pli":"lokajeṭṭho narāsabho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap342:6.3":{"pli":"Buddhassa ānubhāvena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap342:6.4":{"pli":"matthake dhārayiṁsu te. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap342:7.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap342:7.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap342:7.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap342:7.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap342:8.1":{"pli":"Tattha me sukataṁ byamhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap342:8.2":{"pli":"satapattanti vuccati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap342:8.3":{"pli":"Saṭṭhiyojanamubbiddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap342:8.4":{"pli":"tiṁsayojanavitthataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap342:9.1":{"pli":"Sahassakkhattuṁ devindo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap342:9.2":{"pli":"devarajjamakārayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap342:9.3":{"pli":"Pañcasattatikkhattuñca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap342:9.4":{"pli":"cakkavattī ahosahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap342:10.1":{"pli":"Padesarajjaṁ vipulaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap342:10.2":{"pli":"gaṇanāto asaṅkhiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap342:10.3":{"pli":"Anubhomi sakaṁ kammaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap342:10.4":{"pli":"pubbe sukatamattano. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap342:11.1":{"pli":"Tenevekapadumena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap342:11.2":{"pli":"anubhotvāna sampadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap342:11.3":{"pli":"Gotamassa bhagavato, ","html":"<span class='verse-line'>{}</span>"},"tha-ap342:11.4":{"pli":"dhammaṁ sacchikariṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap342:12.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap342:12.2":{"pli":"bhavā sabbe samūhatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap342:12.3":{"pli":"Nāgova bandhanaṁ chetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap342:12.4":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap342:13.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap342:13.2":{"pli":"yaṁ pupphamabhipūjayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap342:13.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap342:13.4":{"pli":"ekapadumassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap342:14.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap342:14.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap342:14.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap342:15.1":{"pli":"Itthaṁ sudaṁ āyasmā ukkhittapadumiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap342:16.1":{"pli":"Ukkhittapadumiyattherassāpadānaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap342:17.1":{"pli":"Gandhodakavaggo catutiṁsatimo. ","html":"<p class='endsection'>{}</p>"},"tha-ap342:18.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"tha-ap342:19.1":{"pli":"Gandhadhūpo udakañca, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"tha-ap342:19.2":{"pli":"punnāga ekadussakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap342:19.3":{"pli":"Phusito ca pabhaṅkaro, ","html":"<span class='verse-line'>{}</span>"},"tha-ap342:19.4":{"pli":"kuṭido uttarīyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap342:20.1":{"pli":"Savanī ekapadumī, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap342:20.2":{"pli":"gāthāyo sabbapiṇḍitā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap342:20.3":{"pli":"Ekaṁ gāthāsatañceva, ","html":"<span class='verse-line'>{}</span>"},"tha-ap342:20.4"