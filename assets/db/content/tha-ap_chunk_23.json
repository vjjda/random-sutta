e-line'>{}</span></p>"},"tha-ap348:3.1":{"pli":"Satta campakapupphāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap348:3.2":{"pli":"sīse katvānahaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap348:3.3":{"pli":"Buddhassa abhiropesiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap348:3.4":{"pli":"sayambhussa mahesino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap348:4.1":{"pli":"Ekattiṁse ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap348:4.2":{"pli":"yaṁ pupphamabhiropayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap348:4.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap348:4.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap348:5.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap348:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap348:5.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap348:6.1":{"pli":"Itthaṁ sudaṁ āyasmā campakapupphiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap348:7.1":{"pli":"Campakapupphiyattherassāpadānaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap349":{"tha-ap349:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap349'><header><ul><li class='division'>{}</li>"},"tha-ap349:0.2":{"pli":"Ekapadumiyavagga ","html":"<li>{}</li></ul>"},"tha-ap349:0.3":{"pli":"Padumapūjakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap349:1.1":{"pli":"“Himavantassāvidūre, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap349:1.2":{"pli":"romaso nāma pabbato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap349:1.3":{"pli":"Buddhopi sambhavo nāma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap349:1.4":{"pli":"abbhokāse vasī tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap349:2.1":{"pli":"Bhavanā nikkhamitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap349:2.2":{"pli":"padumaṁ dhārayiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap349:2.3":{"pli":"Ekāhaṁ dhārayitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap349:2.4":{"pli":"puna bhavanupāgamiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap349:3.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap349:3.2":{"pli":"yaṁ pupphamabhiropayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap349:3.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap349:3.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap349:4.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap349:4.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap349:4.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap349:5.1":{"pli":"Itthaṁ sudaṁ āyasmā padumapūjako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap349:6.1":{"pli":"Padumapūjakattherassāpadānaṁ sattamaṁ. ","html":"<p class='endsutta'>{}<br>"},"tha-ap349:6.2":{"pli":"Terasamaṁ bhāṇavāraṁ. ","html":"{}</p></article>"}},"tha-ap35":{"tha-ap35:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap35'><header><ul><li class='division'>{}</li>"},"tha-ap35:0.2":{"pli":"Kuṇḍadhānavagga ","html":"<li>{}</li></ul>"},"tha-ap35:0.3":{"pli":"3 Mahākaccānattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap35:1.1":{"pli":"“Padumuttaranāthassa, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap35:1.2":{"pli":"padumaṁ nāma cetiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:1.3":{"pli":"Silāsanaṁ kārayitvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:1.4":{"pli":"suvaṇṇenābhilepayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap35:2.1":{"pli":"Ratanāmayachattañca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap35:2.2":{"pli":"paggayha vāḷabījaniṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:2.3":{"pli":"Buddhassa abhiropesiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:2.4":{"pli":"lokabandhussa tādino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap35:3.1":{"pli":"Yāvatā devatā bhummā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap35:3.2":{"pli":"sabbe sannipatuṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:3.3":{"pli":"Ratanāmayachattānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:3.4":{"pli":"vipākaṁ kathayissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap35:4.1":{"pli":"Tañca sabbaṁ suṇissāma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap35:4.2":{"pli":"kathayantassa satthuno; ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:4.3":{"pli":"Bhiyyo hāsaṁ janeyyāma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:4.4":{"pli":"sammāsambuddhasāsane. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap35:5.1":{"pli":"Hemāsane nisīditvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap35:5.2":{"pli":"sayambhū aggapuggalo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:5.3":{"pli":"Bhikkhusaṅghaparibyūḷho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:5.4":{"pli":"imā gāthā abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap35:6.1":{"pli":"‘Yenidaṁ āsanaṁ dinnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap35:6.2":{"pli":"sovaṇṇaṁ ratanāmayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:6.3":{"pli":"Tamahaṁ kittayissāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:6.4":{"pli":"suṇātha mama bhāsato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap35:7.1":{"pli":"Tiṁsa kappāni devindo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap35:7.2":{"pli":"devarajjaṁ karissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:7.3":{"pli":"Samantā yojanasataṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:7.4":{"pli":"ābhāyābhibhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap35:8.1":{"pli":"Manussalokamāgantvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap35:8.2":{"pli":"cakkavattī bhavissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:8.3":{"pli":"Pabhassaroti nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:8.4":{"pli":"uggatejo bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap35:9.1":{"pli":"Divā vā yadi vā rattiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap35:9.2":{"pli":"sataraṁsīva uggato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:9.3":{"pli":"Samantā aṭṭharatanaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:9.4":{"pli":"ujjotissati khattiyo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap35:10.1":{"pli":"Kappasatasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap35:10.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:10.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:10.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap35:11.1":{"pli":"Tusitā hi cavitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap35:11.2":{"pli":"sukkamūlena codito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:11.3":{"pli":"Kaccāno nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:11.4":{"pli":"brahmabandhu bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap35:12.1":{"pli":"So pacchā pabbajitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap35:12.2":{"pli":"arahā hessatināsavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:12.3":{"pli":"Gotamo lokapajjoto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:12.4":{"pli":"aggaṭṭhāne ṭhapessati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap35:13.1":{"pli":"Saṅkhittapucchitaṁ pañhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap35:13.2":{"pli":"Vitthārena kathessati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:13.3":{"pli":"Kathayanto ca taṁ pañhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:13.4":{"pli":"Ajjhāsayaṁ pūrayissati’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap35:14.1":{"pli":"Aḍḍhe kule abhijāto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap35:14.2":{"pli":"brāhmaṇo mantapāragū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:14.3":{"pli":"Ohāya dhanadhaññāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:14.4":{"pli":"pabbajiṁ anagāriyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap35:15.1":{"pli":"Saṅkhittenapi pucchante, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap35:15.2":{"pli":"vitthārena kathemahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:15.3":{"pli":"Ajjhāsayaṁ tesaṁ pūremi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:15.4":{"pli":"tosemi dvipaduttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap35:16.1":{"pli":"Tosito me mahāvīro, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap35:16.2":{"pli":"sayambhū aggapuggalo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:16.3":{"pli":"Bhikkhusaṅghe nisīditvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:16.4":{"pli":"etadagge ṭhapesi maṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap35:17.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap35:17.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap35:17.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap35:18.1":{"pli":"Itthaṁ sudaṁ āyasmā mahākaccāno thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap35:19.1":{"pli":"Mahākaccānattherassāpadānaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap350":{"tha-ap350:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap350'><header><ul><li class='division'>{}</li>"},"tha-ap350:0.2":{"pli":"Ekapadumiyavagga ","html":"<li>{}</li></ul>"},"tha-ap350:0.3":{"pli":"Tiṇamuṭṭhidāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap350:1.1":{"pli":"“Himavantassāvidūre, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap350:1.2":{"pli":"lambako nāma pabbato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap350:1.3":{"pli":"Upatisso nāma sambuddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap350:1.4":{"pli":"abbhokāsamhi caṅkami. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap350:2.1":{"pli":"Migaluddo tadā āsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap350:2.2":{"pli":"araññe kānane ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap350:2.3":{"pli":"Disvāna taṁ devadevaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap350:2.4":{"pli":"sayambhuṁ aparājitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap350:3.1":{"pli":"Vippasannena cittena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap350:3.2":{"pli":"tadā tassa mahesino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap350:3.3":{"pli":"Nisīdanatthaṁ buddhassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap350:3.4":{"pli":"tiṇamuṭṭhimadāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap350:4.1":{"pli":"Datvāna devadevassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap350:4.2":{"pli":"bhiyyo cittaṁ pasādayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap350:4.3":{"pli":"Sambuddhaṁ abhivādetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap350:4.4":{"pli":"pakkāmiṁ uttarāmukho. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap350:5.1":{"pli":"Aciraṁ gatamattaṁ maṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap350:5.2":{"pli":"migarājā apothayi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap350:5.3":{"pli":"Sīhena pothito santo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap350:5.4":{"pli":"tattha kālaṅkato ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap350:6.1":{"pli":"Āsanne me kataṁ kammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap350:6.2":{"pli":"buddhaseṭṭhe anāsave; ","html":"<span class='verse-line'>{}</span>"},"tha-ap350:6.3":{"pli":"Sumutto saravegova, ","html":"<span class='verse-line'>{}</span>"},"tha-ap350:6.4":{"pli":"devalokaṁ agañchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap350:7.1":{"pli":"Yūpo tattha subho āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap350:7.2":{"pli":"puññakammābhinimmito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap350:7.3":{"pli":"Sahassakaṇḍo satabheṇḍu, ","html":"<span class='verse-line'>{}</span>"},"tha-ap350:7.4":{"pli":"dhajālu haritāmayo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap350:8.1":{"pli":"Pabhā niddhāvate tassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap350:8.2":{"pli":"sataraṁsīva uggato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap350:8.3":{"pli":"Ākiṇṇo devakaññāhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap350:8.4":{"pli":"āmodiṁ kāmakāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap350:9.1":{"pli":"Devalokā cavitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap350:9.2":{"pli":"sukkamūlena codito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap350:9.3":{"pli":"Āgantvāna manussattaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap350:9.4":{"pli":"pattomhi āsavakkhayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap350:10.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap350:10.2":{"pli":"nisīdanamadāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap350:10.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap350:10.4":{"pli":"tiṇamuṭṭhiyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap350:11.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap350:11.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap350:11.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap350:12.1":{"pli":"Itthaṁ sudaṁ āyasmā tiṇamuṭṭhidāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap350:13.1":{"pli":"Tiṇamuṭṭhidāyakattherassāpadānaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}