'verse-line'>{}</span>"},"vv10:7.4":{"pli":"ye keci manaso piyā. ","html":"<span class='verse-line'>{}</span></p>"},"vv10:8.1":{"pli":"Akkhāmi te bhikkhu mahānubhāva, ","html":"<p><span class='verse-line'>{}</span>"},"vv10:8.2":{"pli":"Manussabhūtā yamakāsi puññaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv10:8.3":{"pli":"Tenamhi evaṁ jalitānubhāvā, ","html":"<span class='verse-line'>{}</span>"},"vv10:8.4":{"pli":"Vaṇṇo ca me sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv10:9.1":{"pli":"Tiladakkhiṇavimānaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"vv11":{"vv11:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv11'><header><ul><li class='division'>{}</li>"},"vv11:0.2":{"pli":"Itthivimāna ","html":"<li>{}</li>"},"vv11:0.3":{"pli":"Pīṭhavagga ","html":"<li>{}</li></ul>"},"vv11:0.4":{"pli":"11. Paṭhamapatibbatāvimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv11:1.1":{"pli":"“Koñcā mayūrā diviyā ca haṁsā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv11:1.2":{"pli":"Vaggussarā kokilā sampatanti; ","html":"<span class='verse-line'>{}</span>"},"vv11:1.3":{"pli":"Pupphābhikiṇṇaṁ rammamidaṁ vimānaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv11:1.4":{"pli":"Anekacittaṁ naranārisevitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv11:2.1":{"pli":"Tatthacchasi devi mahānubhāve, ","html":"<p><span class='verse-line'>{}</span>"},"vv11:2.2":{"pli":"Iddhī vikubbanti anekarūpā; ","html":"<span class='verse-line'>{}</span>"},"vv11:2.3":{"pli":"Imā ca te accharāyo samantato, ","html":"<span class='verse-line'>{}</span>"},"vv11:2.4":{"pli":"Naccanti gāyanti pamodayanti ca. ","html":"<span class='verse-line'>{}</span></p>"},"vv11:3.1":{"pli":"Deviddhipattāsi mahānubhāve, ","html":"<p><span class='verse-line'>{}</span>"},"vv11:3.2":{"pli":"Manussabhūtā kimakāsi puññaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv11:3.3":{"pli":"Kenāsi evaṁ jalitānubhāvā, ","html":"<span class='verse-line'>{}</span>"},"vv11:3.4":{"pli":"Vaṇṇo ca te sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv11:4.1":{"pli":"Sā devatā attamanā, ","html":"<p><span class='verse-line'>{}</span>"},"vv11:4.2":{"pli":"moggallānena pucchitā; ","html":"<span class='verse-line'>{}</span>"},"vv11:4.3":{"pli":"Pañhaṁ puṭṭhā viyākāsi, ","html":"<span class='verse-line'>{}</span>"},"vv11:4.4":{"pli":"yassa kammassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv11:5.1":{"pli":"“Ahaṁ manussesu manussabhūtā, ","html":"<p><span class='verse-line'>{}</span>"},"vv11:5.2":{"pli":"Patibbatānaññamanā ahosiṁ; ","html":"<span class='verse-line'>{}</span>"},"vv11:5.3":{"pli":"Mātāva puttaṁ anurakkhamānā, ","html":"<span class='verse-line'>{}</span>"},"vv11:5.4":{"pli":"Kuddhāpihaṁ nappharusaṁ avocaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv11:6.1":{"pli":"Sacce ṭhitā mosavajjaṁ pahāya, ","html":"<p><span class='verse-line'>{}</span>"},"vv11:6.2":{"pli":"Dāne ratā saṅgahitattabhāvā; ","html":"<span class='verse-line'>{}</span>"},"vv11:6.3":{"pli":"Annañca pānañca pasannacittā, ","html":"<span class='verse-line'>{}</span>"},"vv11:6.4":{"pli":"Sakkacca dānaṁ vipulaṁ adāsiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv11:7.1":{"pli":"Tena metādiso vaṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"vv11:7.2":{"pli":"tena me idha mijjhati; ","html":"<span class='verse-line'>{}</span>"},"vv11:7.3":{"pli":"Uppajjanti ca me bhogā, ","html":"<span class='verse-line'>{}</span>"},"vv11:7.4":{"pli":"ye keci manaso piyā. ","html":"<span class='verse-line'>{}</span></p>"},"vv11:8.1":{"pli":"Akkhāmi te bhikkhu mahānubhāva, ","html":"<p><span class='verse-line'>{}</span>"},"vv11:8.2":{"pli":"Manussabhūtā yamakāsi puññaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv11:8.3":{"pli":"Tenamhi evaṁ jalitānubhāvā, ","html":"<span class='verse-line'>{}</span>"},"vv11:8.4":{"pli":"Vaṇṇo ca me sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv11:9.1":{"pli":"Paṭhamapatibbatāvimānaṁ ekādasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"vv12":{"vv12:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv12'><header><ul><li class='division'>{}</li>"},"vv12:0.2":{"pli":"Itthivimāna ","html":"<li>{}</li>"},"vv12:0.3":{"pli":"Pīṭhavagga ","html":"<li>{}</li></ul>"},"vv12:0.4":{"pli":"12. Dutiyapatibbatāvimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv12:1.1":{"pli":"“Veḷuriyathambhaṁ ruciraṁ pabhassaraṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv12:1.2":{"pli":"Vimānamāruyha anekacittaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv12:1.3":{"pli":"Tatthacchasi devi mahānubhāve, ","html":"<span class='verse-line'>{}</span>"},"vv12:1.4":{"pli":"Uccāvacā iddhi vikubbamānā; ","html":"<span class='verse-line'>{}</span>"},"vv12:1.5":{"pli":"Imā ca te accharāyo samantato, ","html":"<span class='verse-line'>{}</span>"},"vv12:1.6":{"pli":"Naccanti gāyanti pamodayanti ca. ","html":"<span class='verse-line'>{}</span></p>"},"vv12:2.1":{"pli":"Deviddhipattāsi mahānubhāve, ","html":"<p><span class='verse-line'>{}</span>"},"vv12:2.2":{"pli":"Manussabhūtā kimakāsi puññaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv12:2.3":{"pli":"Kenāsi evaṁ jalitānubhāvā, ","html":"<span class='verse-line'>{}</span>"},"vv12:2.4":{"pli":"Vaṇṇo ca te sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv12:3.1":{"pli":"Sā devatā attamanā, ","html":"<p><span class='verse-line'>{}</span>"},"vv12:3.2":{"pli":"moggallānena pucchitā; ","html":"<span class='verse-line'>{}</span>"},"vv12:3.3":{"pli":"Pañhaṁ puṭṭhā viyākāsi, ","html":"<span class='verse-line'>{}</span>"},"vv12:3.4":{"pli":"yassa kammassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv12:4.1":{"pli":"“Ahaṁ manussesu manussabhūtā, ","html":"<p><span class='verse-line'>{}</span>"},"vv12:4.2":{"pli":"Upāsikā cakkhumato ahosiṁ; ","html":"<span class='verse-line'>{}</span>"},"vv12:4.3":{"pli":"Pāṇātipātā viratā ahosiṁ, ","html":"<span class='verse-line'>{}</span>"},"vv12:4.4":{"pli":"Loke adinnaṁ parivajjayissaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv12:5.1":{"pli":"Amajjapā no ca musā abhāṇiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv12:5.2":{"pli":"Sakena sāminā ahosiṁ tuṭṭhā; ","html":"<span class='verse-line'>{}</span>"},"vv12:5.3":{"pli":"Annañca pānañca pasannacittā, ","html":"<span class='verse-line'>{}</span>"},"vv12:5.4":{"pli":"Sakkacca dānaṁ vipulaṁ adāsiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv12:6.1":{"pli":"Tena metādiso vaṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"vv12:6.2":{"pli":"tena me idha mijjhati; ","html":"<span class='verse-line'>{}</span>"},"vv12:6.3":{"pli":"Uppajjanti ca me bhogā, ","html":"<span class='verse-line'>{}</span>"},"vv12:6.4":{"pli":"ye keci manaso piyā. ","html":"<span class='verse-line'>{}</span></p>"},"vv12:7.1":{"pli":"Akkhāmi te bhikkhu mahānubhāva, ","html":"<p><span class='verse-line'>{}</span>"},"vv12:7.2":{"pli":"Manussabhūtā yamakāsi puññaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv12:7.3":{"pli":"Tenamhi evaṁ jalitānubhāvā, ","html":"<span class='verse-line'>{}</span>"},"vv12:7.4":{"pli":"Vaṇṇo ca me sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv12:8.1":{"pli":"Dutiyapatibbatāvimānaṁ dvādasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"vv13":{"vv13:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv13'><header><ul><li class='division'>{}</li>"},"vv13:0.2":{"pli":"Itthivimāna ","html":"<li>{}</li>"},"vv13:0.3":{"pli":"Pīṭhavagga ","html":"<li>{}</li></ul>"},"vv13:0.4":{"pli":"13. Paṭhamasuṇisāvimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv13:1.1":{"pli":"“Abhikkantena vaṇṇena, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv13:1.2":{"pli":"yā tvaṁ tiṭṭhasi devate; ","html":"<span class='verse-line'>{}</span>"},"vv13:1.3":{"pli":"Obhāsentī disā sabbā, ","html":"<span class='verse-line'>{}</span>"},"vv13:1.4":{"pli":"osadhī viya tārakā. ","html":"<span class='verse-line'>{}</span></p>"},"vv13:2.1":{"pli":"Kena tetādiso vaṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"vv13:2.2":{"pli":"kena te idha mijjhati; ","html":"<span class='verse-line'>{}</span>"},"vv13:2.3":{"pli":"Uppajjanti ca te bhogā, ","html":"<span class='verse-line'>{}</span>"},"vv13:2.4":{"pli":"ye keci manaso piyā. ","html":"<span class='verse-line'>{}</span></p>"},"vv13:3.1":{"pli":"Pucchāmi taṁ devi mahānubhāve, ","html":"<p><span class='verse-line'>{}</span>"},"vv13:3.2":{"pli":"Manussabhūtā kimakāsi puññaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv13:3.3":{"pli":"Kenāsi evaṁ jalitānubhāvā, ","html":"<span class='verse-line'>{}</span>"},"vv13:3.4":{"pli":"Vaṇṇo ca te sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv13:4.1":{"pli":"Sā devatā attamanā, ","html":"<p><span class='verse-line'>{}</span>"},"vv13:4.2":{"pli":"moggallānena pucchitā; ","html":"<span class='verse-line'>{}</span>"},"vv13:4.3":{"pli":"Pañhaṁ puṭṭhā viyākāsi, ","html":"<span class='verse-line'>{}</span>"},"vv13:4.4":{"pli":"yassa kammassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv13:5.1":{"pli":"“Ahaṁ manussesu manussabhūtā, ","html":"<p><span class='verse-line'>{}</span>"},"vv13:5.2":{"pli":"Suṇisā ahosiṁ sasurassa gehe. ","html":"<span class='verse-line'>{}</span></p>"},"vv13:6.1":{"pli":"Addasaṁ virajaṁ bhikkhuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv13:6.2":{"pli":"vippasannamanāvilaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv13:6.3":{"pli":"Tassa adāsahaṁ pūvaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv13:6.4":{"pli":"pasannā sehi pāṇibhi; ","html":"<span class='verse-line'>{}</span>"},"vv13:6.5":{"pli":"Bhāgaḍḍhabhāgaṁ datvāna, ","html":"<span class='verse-line'>{}</span>"},"vv13:6.6":{"pli":"modāmi nandane vane. ","html":"<span class='verse-line'>{}</span></p>"},"vv13:7.1":{"pli":"Tena metādiso vaṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"vv13:7.2":{"pli":"tena me idha mijjhati; ","html":"<span class='verse-line'>{}</span>"},"vv13:7.3":{"pli":"Uppajjanti ca me bhogā, ","html":"<span class='verse-line'>{}</span>"},"vv13:7.4":{"pli":"ye keci manaso piyā. ","html":"<span class='verse-line'>{}</span></p>"},"vv13:8.1":{"pli":"Akkhāmi te bhikkhu mahānubhāva, ","html":"<p><span class='verse-line'>{}</span>"},"vv13:8.2":{"pli":"Manussabhūtā yamakāsi puññaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv13:8.3":{"pli":"Tenamhi evaṁ jalitānubhāvā, ","html":"<span class='verse-line'>{}</span>"},"vv13:8.4":{"pli":"Vaṇṇo ca me sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv13:9.1":{"pli":"Paṭhamasuṇisāvimānaṁ terasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"vv14":{"vv14:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv14'><header><ul><li class='division'>{}</li>"},"vv14:0.2":{"pli":"Itthivimāna ","html":"<li>{}</li>"},"vv14:0.3":{"pli":"Pīṭhavagga ","html":"<li>{}</li></ul>"},"vv14:0.4":{"pli":"14. Dutiyasuṇisāvimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv14:1.1":{"pli":"“Abhikkantena vaṇṇena, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv14:1.2":{"pli":"yā tvaṁ tiṭṭhasi devate; ","html":"<span class='verse-line'>{}</span>"},"vv14:1.3":{"pli":"Obhāsentī disā sabbā, ","html":"<span class='verse-line'>{}</span>"},"vv14:1.4":{"pli":"osadhī viya tārakā. ","html":"<span class='verse-line'>{}</span></p>"},"vv14:2.1":{"pli":"Kena tetādiso vaṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"vv14:2.2":{"pli":"kena te idha mijjhati; ","html":"<span class='verse-line'>{}</span>"},"vv14:2.3":{"pli":"Uppajjanti ca te bhogā, ","html":"<span class='verse-line'>{}</span>"},"vv14:2.4":{"pli":"ye keci manaso piyā. ","html":"<span class='verse-line'>{}</span></p>"},"vv14:3.1":{"pli":"Pucchāmi taṁ devi mahānubhāve, ","html":"<p><span class='verse-line'>{}</span>"},"vv14:3.2":{"pli":"Manussabhūtā kimakāsi puññaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv14:3.3":{"pli":"Kenāsi evaṁ jalitānubhāvā, ","html":"<span class='verse-line'>{}</span>"},"vv14:3.4":{"pli":"Vaṇṇo ca te sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv14:4.1":{"pli":"Sā devatā attamanā, ","html":"<p><span class='verse-line'>{}</span>"},"vv14:4.2":{"pli":"moggallānena pucchitā; ","html":"<span class='verse-line'>{}</span>"},"vv14:4.3":{"pli":"Pañhaṁ puṭṭhā viyākāsi, ","html":"<span class='verse-line'>{}</span>"},"vv14:4.4":{"pli":"yassa kammassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv14:5.1":{"pli":"“Ahaṁ manussesu manussabhūtā, ","html":"<p><span class='verse-line'>{}</span>"},"vv14:5.2":{"pli":"Suṇisā ahosiṁ sasurassa gehe. ","html":"<span class='verse-line'>{}</span></p>"},"vv14:6.1":{"pli":"Addasaṁ virajaṁ bhikkhuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv14:6.2":{"pli":"vippasannamanāvilaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv14:6.3":{"pli":"Tassa adāsahaṁ bhāgaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv14:6.4":{"pli":"pasannā sehi pāṇibhi; ","html":"<span class='verse-line'>{}</span>"},"vv14:6.5":{"pli":"Kummāsapiṇḍaṁ datvāna, ","html":"<span class='verse-line'>{}</span>"},"vv14:6.6":{"pli":"modāmi nandane vane. ","html":"<span class='verse-line'>{}</span></p>"},"vv14:7.1":{"pli":"Tena metādiso vaṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"vv14:7.2":{"pli":"tena me idha mijjhati; ","html":"<span class='verse-line'>{}</span>"},"vv14:7.3":{"pli":"Uppajjanti ca me bhogā, ","html":"<span class='verse-line'>{}</span>"},"vv14:7.4":{"pli":"ye keci manaso piyā. ","html":"<span class='verse-line'>{}</span></p>"},"vv14:8.1":{"pli":"Akkhāmi te bhikkhu mahānubhāva, ","html":"<p><span class='verse-line'>{}</span>"},"vv14:8.2":{"pli":"Manussabhūtā yamakāsi puññaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv14:8.3":{"pli":"Tenamhi evaṁ jalitānubhāvā, ","html":"<span class='verse-line'>{}</span>"},"vv14:8.4":{"pli":"Vaṇṇo ca me sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv14:9.1":{"pli":"Dutiyasuṇisāvimānaṁ cuddasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"vv15":{"vv15:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv15'><header><ul><li class='division'>{}</li>"},"vv15:0.2":{"pli":"Itthivimāna ","html":"<li>{}</li>"},"vv15:0.3":{"pli":"Pīṭhavagga ","html":"<li>{}</li></ul>"},"vv15:0.4":{"pli":"15. Uttarāvimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv15:1.1":{"pli":"“Abhikkantena vaṇṇena, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv15:1.2":{"pli":"yā tvaṁ tiṭṭhasi devate; ","html":"<span class='verse-line'>{}</span>"},"vv15:1.3":{"pli":"Obhāsentī disā sabbā, ","html":"<span class='verse-line'>{}</span>"},"vv15:1.4":{"pli":"osadhī viya tārakā. ","html":"<span class='verse-line'>{}</span></p>"},"vv15:2.1":{"pli":"Kena tetādiso vaṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"vv15:2.2":{"pli":"kena te idha mijjhati; ","html":"<span class='verse-line'>{}</span>"},"vv15:2.3":{"pli":"Uppajjanti ca te bhogā, ","html":"<span class='verse-line'>{}</span>"},"vv15:2.4":{"pli":"ye keci manaso piyā. ","html":"<span class='verse-line'>{}</span></p>"},"vv15:3.1":{"pli":"Pucchāmi taṁ devi mahānubhāve, ","html":"<p><span class='verse-line'>{}</span>"},"vv15:3.2":{"pli":"Manussabhūtā kimakāsi puññaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv15:3.3":{"pli":"Kenāsi evaṁ jalitānubhāvā, ","html":"<span class='verse-line'>{}</span>"},"vv15:3.4":{"pli":"Vaṇṇo ca te sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv15:4.1":{"pli":"Sā devatā attamanā, ","html":"<p><span class='verse-line'>{}</span>"},"vv15:4.2":{"pli":"moggallānena pucchitā; ","html":"<span class='verse-line'>{}</span>"},"vv15:4.3":{"pli":"Pañhaṁ puṭṭhā viyākāsi, ","html":"<span class='verse-line'>{}</span>"},"vv15:4.4":{"pli":"yassa kammassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv15:5.1":{"pli":"“Issā ca maccheramatho paḷāso, ","html":"<p><span class='verse-line'>{}</span>"},"vv15:5.2":{"pli":"Nāhosi mayhaṁ gharamāvasantiyā; ","html":"<span class='verse-line'>{}</span>"},"vv15:5.3":{"pli":"Akkodhanā bhattu vasānuvattinī, ","html":"<span class='verse-line'>{}</span>"},"vv15:5.4":{"pli":"Uposathe niccahamappamattā. ","html":"<span class='verse-line'>{}</span></p>"},"vv15:6.1":{"pli":"Cātuddasiṁ pañcadasiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv15:6.2":{"pli":"yā ca pakkhassa aṭṭhamī; ","html":"<span class='verse-line'>{}</span>"},"vv15:6.3":{"pli":"Pāṭihāriyapakkhañca, ","html":"<span class='verse-line'>{}</span>"},"vv15:6.4":{"pli":"aṭṭhaṅgasusamāgataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv15:7.1":{"pli":"Uposathaṁ upavasissaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv15:7.2":{"pli":"sadā sīlesu saṁvutā; ","html":"<span class='verse-line'>{}</span>"},"vv15:7.3":{"pli":"Saññamā saṁvibhāgā ca, ","html":"<span class='verse-line'>{}</span>"},"vv15:7.4":{"pli":"vimānaṁ āvasāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv15:8.1":{"pli":"Pāṇātipātā viratā, ","html":"<p><span class='verse-line'>{}</span>"},"vv15:8.2":{"pli":"musāvādā ca saññatā; ","html":"<span class='verse-line'>{}</span>"},"vv15:8.3":{"pli":"Theyyā ca aticārā ca, ","html":"<span class='verse-line'>{}</span>"},"vv15:8.4":{"pli":"majjapānā ca ārakā. ","html":"<span class='verse-line'>{}</span></p>"},"vv15:9.1":{"pli":"Pañcasikkhāpade ratā, ","html":"<p><span class='verse-line'>{}</span>"},"vv15:9.2":{"pli":"ariyasaccāna kovidā; ","html":"<span class='verse-line'>{}</span>"},"vv15:9.3":{"pli":"Upāsikā cakkhumato, ","html":"<span class='verse-line'>{}</span>"},"vv15:9.4":{"pli":"gotamassa yasassino. ","html":"<span class='verse-line'>{}</span></p>"},"vv15:10.1":{"pli":"Sāhaṁ sakena sīlena, ","html":"<p><span class='verse-line'>{}</span>"},"vv15:10.2":{"pli":"yasasā ca yasassinī; ","html":"<span class='verse-line'>{}</span>"},"vv15:10.3":{"pli":"Anubhomi sakaṁ puññaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv15:10.4":{"pli":"sukhitā camhināmayā. ","html":"<span class='verse-line'>{}</span></p>"},"vv15:11.1":{"pli":"Tena metādiso vaṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"vv15:11.2":{"pli":"tena me idha mijjhati; ","html":"<span class='verse-line'>{}</span>"},"vv15:11.3":{"pli":"Uppajjanti ca me bhogā, ","html":"<span class='verse-line'>{}</span>"},"vv15:11.4":{"pli":"ye keci manaso piyā. ","html":"<span class='verse-line'>{}</span></p>"},"vv15:12.1":{"pli":"Akkhāmi te bhikkhu mahānubhāva, ","html":"<p><span class='verse-line'>{}</span>"},"vv15:12.2":{"pli":"Manussabhūtā yamahaṁ akāsiṁ; ","html":"<span class='verse-line'>{}</span>"},"vv15:12.3":{"pli":"Tenamhi evaṁ jalitānubhāvā, ","html":"<span class='verse-line'>{}</span>"},"vv15:12.4":{"pli":"Vaṇṇo ca me sabbadisā pabhāsatīti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv15:13.1":{"pli":"Mama ca, bhante, vacanena bhagavato pāde sirasā vandeyyāsi—","html":"<p>{}"},"vv15:13.2":{"pli":"‘uttarā nāma, bhante, upāsikā bhagavato pāde sirasā vandatī’ti. ","html":"{}"},"vv15:13.3":{"pli":"Anacchariyaṁ kho panetaṁ, bhante, yaṁ maṁ bhagavā aññatarasmiṁ sāmaññaphale byākareyya, taṁ bhagavā sakadāgāmiphale byākāsī”ti. ","html":"{}</p>"},"vv15:14.1":{"pli":"Uttarāvimānaṁ pannarasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"vv16":{"vv16:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv16'><header><ul><li class='division'>{}</li>"},"vv16:0.2":{"pli":"Itthivimāna ","html":"<li>{}</li>"},"vv16:0.3":{"pli":"Pīṭhavagga ","html":"<li>{}</li></ul>"},"vv16:0.4":{"pli":"16. Sirimāvimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv16:1.1":{"pli":"“Yuttā ca te paramaalaṅkatā hayā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv16:1.2":{"pli":"Adhomukhā aghasigamā balī javā; ","html":"<span class='verse-line'>{}</span>"},"vv16:1.3":{"pli":"Abhinimmitā pañcarathāsatā ca te, ","html":"<span class='verse-line'>{}</span>"},"vv16:1.4":{"pli":"Anventi taṁ sārathicoditā hayā. ","html":"<span class='verse-line'>{}</span></p>"},"vv16:2.1":{"pli":"Sā tiṭṭhasi rathavare alaṅkatā, ","html":"<p><span class='verse-line'>{}</span>"},"vv16:2.2":{"pli":"Obhāsayaṁ jalamiva joti pāvako; ","html":"<span class='verse-line'>{}</span>"},"vv16:2.3":{"pli":"Pucchāmi taṁ varatanu anomadassane, ","html":"<span class='verse-line'>{}</span>"},"vv16:2.4":{"pli":"Kasmā nu kāyā anadhivaraṁ upāgami”. ","html":"<span class='verse-line'>{}</span></p>"},"vv16:3.1":{"pli":"“Kāmaggapattānaṁ yamāhunuttaraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv16:3.2":{"pli":"Nimmāya nimmāya ramanti devatā; ","html":"<span class='verse-line'>{}</span>"},"vv16:3.3":{"pli":"Tasmā kāyā accharā kāmavaṇṇinī, ","html":"<span class='verse-line'>{}</span>"},"vv16:3.4":{"pli":"Idhāgatā anadhivaraṁ namassituṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"vv16:4.1":{"pli":"“Kiṁ tvaṁ pure sucaritamācarīdha, ","html":"<p><span class='verse-line'>{}</span>"},"vv16:4.2":{"pli":"Kenacchasi tvaṁ amitayasā sukhedhitā; ","html":"<span class='verse-line'>{}</span>"},"vv16:4.3":{"pli":"Iddhī ca te anadhivarā vihaṅgamā, ","html":"<span class='verse-line'>{}</span>"},"vv16:4.4":{"pli":"Vaṇṇo ca te dasa disā virocati. ","html":"<span class='verse-line'>{}</span></p>"},"vv16:5.1":{"pli":"Devehi tvaṁ parivutā sakkatā casi, ","html":"<p><span class='verse-line'>{}</span>"},"vv16:5.2":{"pli":"Kuto cutā sugatigatāsi devate; ","html":"<span class='verse-line'>{}</span>"},"vv16:5.3":{"pli":"Kassa vā tvaṁ vacanakarānusāsaniṁ, ","html":"<span class='verse-line'>{}</span>"},"vv16:5.4":{"pli":"Ācikkha me tvaṁ yadi buddhasāvikā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv16:6.1":{"pli":"“Nagantare nagaravare sumāpite, ","html":"<p><span class='verse-line'>{}</span>"},"vv16:6.2":{"pli":"Paricārikā rājavarassa sirimato; ","html":"<span class='verse-line'>{}</span>"},"vv16:6.3":{"pli":"Nacce gīte paramasusikkhitā ahuṁ, ","html":"<span class='verse-line'>{}</span>"},"vv16:6.4":{"pli":"Sirimāti maṁ rājagahe avediṁsu. ","html":"<span class='verse-line'>{}</span></p>"},"vv16:7.1":{"pli":"Buddho ca me isinisabho vināyako, ","html":"<p><span class='verse-line'>{}</span>"},"vv16:7.2":{"pli":"Adesayī samudayadukkhaniccataṁ; ","html":"<span class='verse-line'>{}</span>"},"vv16:7.3":{"pli":"Asaṅkhataṁ dukkhanirodhasassataṁ, ","html":"<span class='verse-line'>{}</span>"},"vv16:7.4":{"pli":"Maggañcimaṁ akuṭilamañjasaṁ sivaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv16:8.1":{"pli":"Sutvānahaṁ amatapadaṁ asaṅkhataṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv16:8.2":{"pli":"Tathāgatassanadhivarassa sāsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv16:8.3":{"pli":"Sīlesvahaṁ paramasusaṁvutā ahuṁ, ","html":"<span class='verse-line'>{}</span>"},"vv16:8.4":{"pli":"Dhamme ṭhitā naravarabuddhadesite. ","html":"<span class='verse-line'>{}</span></p>"},"vv16:9.1":{"pli":"Ñatvānahaṁ virajapadaṁ asaṅkhataṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv16:9.2":{"pli":"Tathāgatenanadhivarena desitaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv16:9.3":{"pli":"Tatthevahaṁ samathasamādhimāphusiṁ, ","html":"<span class='verse-line'>{}</span>"},"vv16:9.4":{"pli":"Sāyeva me paramaniyāmatā ahu. ","html":"<span class='verse-line'>{}</span></p>"},"vv16:10.1":{"pli":"Laddhānahaṁ amatavaraṁ visesanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv16:10.2":{"pli":"Ekaṁsikā abhisamaye visesiya; ","html":"<span class='verse-line'>{}</span>"},"vv16:10.3":{"pli":"Asaṁsayā bahujanapūjitā ahaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv16:10.4":{"pli":"Khiḍḍāratiṁ paccanubhomanappakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv16:11.1":{"pli":"Evaṁ ahaṁ amatadasamhi devatā, ","html":"<p><span class='verse-line'>{}</span>"},"vv16:11.2":{"pli":"Tathāgatassanadhivarassa sāvikā; ","html":"<span class='verse-line'>{}</span>"},"vv16:11.3":{"pli":"Dhammaddasā paṭhamaphale patiṭṭhitā, ","html":"<span class='verse-line'>{}</span>"},"vv16:11.4":{"pli":"Sotāpannā na ca pana matthi duggati. ","html":"<span class='verse-line'>{}</span></p>"},"vv16:12.1":{"pli":"Sā vandituṁ anadhivaraṁ upāgamiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv16:12.2":{"pli":"Pāsādike kusalarate ca bhikkhavo; ","html":"<span class='verse-line'>{}</span>"},"vv16:12.3":{"pli":"Namassituṁ samaṇasamāgamaṁ sivaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv16:12.4":{"pli":"Sagāravā sirimato dhammarājino. ","html":"<span class='verse-line'>{}</span></p>"},"vv16:13.1":{"pli":"Disvā muniṁ muditamanamhi pīṇitā, ","html":"<p><span class='verse-line'>{}</span>"},"vv16:13.2":{"pli":"Tathāgataṁ naravaradammasārathiṁ; ","html":"<span class='verse-line'>{}</span>"},"vv16:13.3":{"pli":"Taṇhacchidaṁ kusalarataṁ vināyakaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv16:13.4":{"pli":"Vandāmahaṁ paramahitānukampakan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv16:14.1":{"pli":"Sirimāvimānaṁ soḷasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"vv17":{"vv17:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv17'><header><ul><li class='division'>{}</li>"},"vv17:0.2":{"pli":"Itthivimāna ","html":"<li>{}</li>"},"vv17:0.3":{"pli":"Pīṭhavagga ","html":"<li>{}</li></ul>"},"vv17:0.4":{"pli":"17. Kesakārīvimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv17:1.1":{"pli":"“Idaṁ vimānaṁ ruciraṁ pabhassaraṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv17:1.2":{"pli":"Veḷuriyathambhaṁ satataṁ sunimmitaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv17:1.3":{"pli":"Suvaṇṇarukkhehi samantamotthataṁ, ","html":"<span class='verse-line'>{}</span>"},"vv17:1.4":{"pli":"Ṭhānaṁ mamaṁ kammavipākasambhavaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv17:2.1":{"pli":"Tatrūpapannā purimaccharā imā, ","html":"<p><span class='verse-line'>{}</span>"},"vv17:2.2":{"pli":"Sataṁ sahassāni sakena kammunā; ","html":"<span class='verse-line'>{}</span>"},"vv17:2.3":{"pli":"Tuvaṁsi ajjhupagatā yasassinī, ","html":"<span class='verse-line'>{}</span>"},"vv17:2.4":{"pli":"Obhāsayaṁ tiṭṭhasi pubbadevatā. ","html":"<span class='verse-line'>{}</span></p>"},"vv17:3.1":{"pli":"Sasī adhiggayha yathā virocati, ","html":"<p><span class='verse-line'>{}</span>"},"vv17:3.2":{"pli":"Nakkhattarājāriva tārakāgaṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv17:3.3":{"pli":"Tatheva tvaṁ accharāsaṅgaṇaṁ imaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv17:3.4":{"pli":"Daddallamānā yasasā virocasi. ","html":"<span class='verse-line'>{}</span></p>"},"vv17:4.1":{"pli":"Kuto nu āgamma anomadassane, ","html":"<p><span class='verse-line'>{}</span>"},"vv17:4.2":{"pli":"Upapannā tvaṁ bhavanaṁ mamaṁ idaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv17:4.3":{"pli":"Brahmaṁva devā tidasā sahindakā, ","html":"<span class='verse-line'>{}</span>"},"vv17:4.4":{"pli":"Sabbe na tappāmase dassanena tan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv17:5.1":{"pli":"“Yametaṁ sakka anupucchase mamaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv17:5.2":{"pli":"‘Kuto cutā tvaṁ idha āgatā’ti; ","html":"<span class='verse-line'>{}</span>"},"vv17:5.3":{"pli":"Bārāṇasī nāma puratthi kāsinaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv17:5.4":{"pli":"Tattha ahosiṁ pure kesakārikā. ","html":"<span class='verse-line'>{}</span></p>"},"vv17:6.1":{"pli":"Buddhe ca dhamme ca pasannamānasā, ","html":"<p><span class='verse-line'>{}</span>"},"vv17:6.2":{"pli":"Saṅghe ca ekantagatā asaṁsayā; ","html":"<span class='verse-line'>{}</span>"},"vv17:6.3":{"pli":"Akhaṇḍasikkhāpadā āgatapphalā, ","html":"<span class='verse-line'>{}</span>"},"vv17:6.4":{"pli":"Sambodhidhamme niyatā anāmayā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv17:7.1":{"pli":"“Tantyābhinandāmase svāgatañca te, ","html":"<p><span class='verse-line'>{}</span>"},"vv17:7.2":{"pli":"Dhammena ca tvaṁ yasasā virocasi; ","html":"<span class='verse-line'>{}</span>"},"vv17:7.3":{"pli":"Buddhe ca dhamme ca pasannamānase, ","html":"<span class='verse-line'>{}</span>"},"vv17:7.4":{"pli":"Saṅghe ca ekantagate asaṁsaye; ","html":"<span class='verse-line'>{}</span>"},"vv17:7.5":{"pli":"Akhaṇḍasikkhāpade āgatapphale, ","html":"<span class='verse-line'>{}</span>"},"vv17:7.6":{"pli":"Sambodhidhamme niyate anāmaye”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv17:8.1":{"pli":"Kesakārīvimānaṁ sattarasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"vv17:9.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"vv17:10.1":{"pli":"Pañca pīṭhā tayo nāvā, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"vv17:10.2":{"pli":"dīpatiladakkhiṇā dve; ","html":"<span class='verse-line'>{}</span>"},"vv17:10.3":{"pli":"Pati dve suṇisā uttarā, ","html":"<span class='verse-line'>{}</span>"},"vv17:10.4":{"pli":"sirimā kesakārikā; ","html":"<span class='verse-line'>{}</span>"},"vv17:10.5":{"pli":"Vaggo tena pavuccatīti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv17:11.1":{"pli":"Itthivimāne paṭhamo vaggo. ","html":"<p class='endsutta'>{}</p></article>"}},"vv18":{"vv18:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv18'><header><ul><li class='division'>{}</li>"},"vv18:0.2":{"pli":"Itthivimāna ","html":"<li>{}</li>"},"vv18:0.3":{"pli":"Cittalatāvagga ","html":"<li>{}</li></ul>"},"vv18:0.4":{"pli":"1. Dāsivimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv18:1.1":{"pli":"“Api sakkova devindo, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv18:1.2":{"pli":"ramme cittalatāvane; ","html":"<span class='verse-line'>{}</span>"},"vv18:1.3":{"pli":"Samantā anupariyāsi, ","html":"<span class='verse-line'>{}</span>"},"vv18:1.4":{"pli":"nārīgaṇapurakkhatā; ","html":"<span class='verse-line'>{}</span>"},"vv18:1.5":{"pli":"Obhāsentī disā sabbā, ","html":"<span class='verse-line'>{}</span>"},"vv18:1.6":{"pli":"osadhī viya tārakā. ","html":"<span class='verse-line'>{}</span></p>"},"vv18:2.1":{"pli":"Kena tetādiso vaṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"vv18:2.2":{"pli":"kena te idha mijjhati; ","html":"<span class='verse-line'>{}</span>"},"vv18:2.3":{"pli":"Uppajjanti ca te bhogā, ","html":"<span class='verse-line'>{}</span>"},"vv18:2.4":{"pli":"ye keci manaso piyā. ","html":"<span class='verse-line'>{}</span></p>"},"vv18:3.1":{"pli":"Pucchāmi taṁ devi mahānubhāve, ","html":"<p><span class='verse-line'>{}</span>"},"vv18:3.2":{"pli":"Manussabhūtā kimakāsi puññaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv18:3.3":{"pli":"Kenāsi evaṁ jalitānubhāvā, ","html":"<span class='verse-line'>{}</span>"},"vv18:3.4":{"pli":"Vaṇṇo ca te sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv18:4.1":{"pli":"Sā devatā attamanā, ","html":"<p><span class='verse-line'>{}</span>"},"vv18:4.2":{"pli":"moggallānena pucchitā; ","html":"<span class='verse-line'>{}</span>"},"vv18:4.3":{"pli":"Pañhaṁ puṭṭhā viyākāsi, ","html":"<span class='verse-line'>{}</span>"},"vv18:4.4":{"pli":"yassa kammassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv18:5.1":{"pli":"“Ahaṁ manussesu manussabhūtā, ","html":"<p><span class='verse-line'>{}</span>"},"vv18:5.2":{"pli":"Dāsī ahosiṁ parapessiyā kule. ","html":"<span class='verse-line'>{}</span></p>"},"vv18:6.1":{"pli":"Upāsikā cakkhumato, ","html":"<p><span class='verse-line'>{}</span>"},"vv18:6.2":{"pli":"gotamassa yasassino; ","html":"<span class='verse-line'>{}</span>"},"vv18:6.3":{"pli":"Tassā me nikkamo āsi, ","html":"<span class='verse-line'>{}</span>"},"vv18:6.4":{"pli":"sāsane tassa tādino. ","html":"<span class='verse-line'>{}</span></p>"},"vv18:7.1":{"pli":"Kāmaṁ bhijjatuyaṁ kāyo, ","html":"<p><span class='verse-line'>{}</span>"},"vv18:7.2":{"pli":"neva atthettha saṇṭhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv18:7.3":{"pli":"Sikkhāpadānaṁ pañcannaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv18:7.4":{"pli":"maggo sovatthiko sivo. ","html":"<span class='verse-line'>{}</span></p>"},"vv18:8.1":{"pli":"Akaṇṭako agahano, ","html":"<p><span class='verse-line'>{}</span>"},"vv18:8.2":{"pli":"uju sabbhi pavedito; ","html":"<span class='verse-line'>{}</span>"},"vv18:8.3":{"pli":"Nikkamassa phalaṁ passa, ","html":"<span class='verse-line'>{}</span>"},"vv18:8.4":{"pli":"yathidaṁ pāpuṇitthikā. ","html":"<span class='verse-line'>{}</span></p>"},"vv18:9.1":{"pli":"Āmantanikā raññomhi, ","html":"<p><span class='verse-line'>{}</span>"},"vv18:9.2":{"pli":"sakkassa vasavattino; ","html":"<span class='verse-line'>{}</span>"},"vv18:9.3":{"pli":"Saṭṭhi tūriyasahassāni, ","html":"<span class='verse-line'>{}</span>"},"vv18:9.4":{"pli":"paṭibodhaṁ karonti me. ","html":"<span class='verse-line'>{}</span></p>"},"vv18:10.1":{"pli":"Ālambo gaggaro bhīmo, ","html":"<p><span class='verse-line'>{}</span>"},"vv18:10.2":{"pli":"sādhuvādī ca saṁsayo; ","html":"<span class='verse-line'>{}</span>"},"vv18:10.3":{"pli":"Pokkharo ca suphasso ca, ","html":"<span class='verse-line'>{}</span>"},"vv18:10.4":{"pli":"viṇāmokkhā ca nāriyo. ","html":"<span class='verse-line'>{}</span></p>"},"vv18:11.1":{"pli":"Nandā ceva sunandā ca, ","html":"<p><span class='verse-line'>{}</span>"},"vv18:11.2":{"pli":"soṇadinnā sucimhitā; ","html":"<span class='verse-line'>{}</span>"},"vv18:11.3":{"pli":"Alambusā missakesī ca, ","html":"<span class='verse-line'>{}</span>"},"vv18:11.4":{"pli":"puṇḍarīkāti dāruṇī. ","html":"<span class='verse-line'>{}</span></p>"},"vv18:12.1":{"pli":"Eṇīphassā suphassā ca, ","html":"<p><span class='verse-line'>{}</span>"},"vv18:12.2":{"pli":"subhaddā muduvādinī; ","html":"<span class='verse-line'>{}</span>"},"vv18:12.3":{"pli":"Etā caññā ca seyyāse, ","html":"<span class='verse-line'>{}</span>"},"vv18:12.4":{"pli":"accharānaṁ pabodhikā. ","html":"<span class='verse-line'>{}</span></p>"},"vv18:13.1":{"pli":"Tā maṁ kālenupāgantvā, ","html":"<p><span class='verse-line'>{}</span>"},"vv18:13.2":{"pli":"abhibhāsanti devatā; ","html":"<span class='verse-line'>{}</span>"},"vv18:13.3":{"pli":"Handa naccāma gāyāma, ","html":"<span class='verse-line'>{}</span>"},"vv18:13.4":{"pli":"handa taṁ ramayāmase. ","html":"<span class='verse-line'>{}</span></p>"},"vv18:14.1":{"pli":"Nayidaṁ akatapuññānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv18:14.2":{"pli":"katapuññānamevidaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv18:14.3":{"pli":"Asokaṁ nandanaṁ rammaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv18:14.4":{"pli":"tidasānaṁ mahāvanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv18:15.1":{"pli":"Sukhaṁ akatapuññānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv18:15.2":{"pli":"idha natthi parattha ca; ","html":"<span class='verse-line'>{}</span>"},"vv18:15.3":{"pli":"Sukhañca katapuññānaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv18:15.4":{"pli":"idha ceva parattha ca. ","html":"<span class='verse-line'>{}</span></p>"},"vv18:16.1":{"pli":"Tesaṁ sahabyakāmānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv18:16.2":{"pli":"kattabbaṁ kusalaṁ bahuṁ; ","html":"<span class='verse-line'>{}</span>"},"vv18:16.3":{"pli":"Katapuññā hi modanti, ","html":"<span class='verse-line'>{}</span>"},"vv18:16.4":{"pli":"sagge bhogasamaṅgino”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv18:17.1":{"pli":"Dāsivimānaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}