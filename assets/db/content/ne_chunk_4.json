{"ne3":{"ne3:0.1":{"pli":"Netti ","html":"<article id='ne3'><header><ul><li class='division'>{}</li></ul>"},"ne3:0.2":{"pli":"3. Niddesavāra ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ne3:1.1":{"pli":"Tattha saṅkhepato netti kittitā. ","html":"<p>{}</p>"},"ne3:2.0":{"pli":"3.1. Hārasaṅkhepa ","html":"<h3>{}</h3>"},"ne3:2.1":{"pli":"Assādādīnavatā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ne3:2.2":{"pli":"Nissaraṇampi ca phalaṁ upāyo ca; ","html":"<span class='verse-line'>{}</span>"},"ne3:2.3":{"pli":"Āṇattī ca bhagavato, ","html":"<span class='verse-line'>{}</span>"},"ne3:2.4":{"pli":"Yogīnaṁ <b>desanāhāro</b>. ","html":"<span class='verse-line'>{}</span></p>"},"ne3:3.1":{"pli":"Yaṁ pucchitañca vissajjitañca, ","html":"<p><span class='verse-line'>{}</span>"},"ne3:3.2":{"pli":"Suttassa yā ca anugīti; ","html":"<span class='verse-line'>{}</span>"},"ne3:3.3":{"pli":"Suttassa yo pavicayo, ","html":"<span class='verse-line'>{}</span>"},"ne3:3.4":{"pli":"Hāro <b>vicayo</b>ti niddiṭṭho. ","html":"<span class='verse-line'>{}</span></p>"},"ne3:4.1":{"pli":"Sabbesaṁ hārānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ne3:4.2":{"pli":"Yā bhūmī yo ca gocaro tesaṁ; ","html":"<span class='verse-line'>{}</span>"},"ne3:4.3":{"pli":"Yuttāyuttaparikkhā, ","html":"<span class='verse-line'>{}</span>"},"ne3:4.4":{"pli":"Hāro <b>yuttī</b>ti niddiṭṭho. ","html":"<span class='verse-line'>{}</span></p>"},"ne3:5.1":{"pli":"Dhammaṁ deseti jino, ","html":"<p><span class='verse-line'>{}</span>"},"ne3:5.2":{"pli":"Tassa ca dhammassa yaṁ padaṭṭhānaṁ; ","html":"<span class='verse-line'>{}</span>"},"ne3:5.3":{"pli":"Iti yāva sabbadhammā, ","html":"<span class='verse-line'>{}</span>"},"ne3:5.4":{"pli":"Eso hāro <b>padaṭṭhāno</b>. ","html":"<span class='verse-line'>{}</span></p>"},"ne3:6.1":{"pli":"Vuttamhi ekadhamme, ","html":"<p><span class='verse-line'>{}</span>"},"ne3:6.2":{"pli":"Ye dhammā ekalakkhaṇā keci; ","html":"<span class='verse-line'>{}</span>"},"ne3:6.3":{"pli":"Vuttā bhavanti sabbe, ","html":"<span class='verse-line'>{}</span>"},"ne3:6.4":{"pli":"So hāro <b>lakkhaṇo</b> nāma. ","html":"<span class='verse-line'>{}</span></p>"},"ne3:7.1":{"pli":"Neruttamadhippāyo, ","html":"<p><span class='verse-line'>{}</span>"},"ne3:7.2":{"pli":"Byañjanamatha desanānidānañca; ","html":"<span class='verse-line'>{}</span>"},"ne3:7.3":{"pli":"Pubbāparānusandhī, ","html":"<span class='verse-line'>{}</span>"},"ne3:7.4":{"pli":"Eso hāro <b>catubyūho</b>. ","html":"<span class='verse-line'>{}</span></p>"},"ne3:8.1":{"pli":"Ekamhi padaṭṭhāne, ","html":"<p><span class='verse-line'>{}</span>"},"ne3:8.2":{"pli":"Pariyesati sesakaṁ padaṭṭhānaṁ; ","html":"<span class='verse-line'>{}</span>"},"ne3:8.3":{"pli":"Āvaṭṭati paṭipakkhe, ","html":"<span class='verse-line'>{}</span>"},"ne3:8.4":{"pli":"<b>Āvaṭṭo</b> nāma so hāro. ","html":"<span class='verse-line'>{}</span></p>"},"ne3:9.1":{"pli":"Dhammañca padaṭṭhānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ne3:9.2":{"pli":"Bhūmiñca vibhajjate ayaṁ hāro; ","html":"<span class='verse-line'>{}</span>"},"ne3:9.3":{"pli":"Sādhāraṇe asādhā- ","html":"<span class='verse-line'>{}</span>"},"ne3:9.4":{"pli":"Raṇe ca neyyo <b>vibhattī</b>ti. ","html":"<span class='verse-line'>{}</span></p>"},"ne3:10.1":{"pli":"Kusalākusale dhamme, ","html":"<p><span class='verse-line'>{}</span>"},"ne3:10.2":{"pli":"Niddiṭṭhe bhāvite pahīne ca; ","html":"<span class='verse-line'>{}</span>"},"ne3:10.3":{"pli":"Parivattati paṭipakkhe, ","html":"<span class='verse-line'>{}</span>"},"ne3:10.4":{"pli":"Hāro <b>parivattano</b> nāma. ","html":"<span class='verse-line'>{}</span></p>"},"ne3:11.1":{"pli":"Vevacanāni bahūni tu, ","html":"<p><span class='verse-line'>{}</span>"},"ne3:11.2":{"pli":"Sutte vuttāni ekadhammassa; ","html":"<span class='verse-line'>{}</span>"},"ne3:11.3":{"pli":"Yo jānāti suttavidū, ","html":"<span class='verse-line'>{}</span>"},"ne3:11.4":{"pli":"<b>Vevacano</b> nāma so hāro. ","html":"<span class='verse-line'>{}</span></p>"},"ne3:12.1":{"pli":"Ekaṁ bhagavā dhammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ne3:12.2":{"pli":"Paññattīhi vividhāhi deseti; ","html":"<span class='verse-line'>{}</span>"},"ne3:12.3":{"pli":"So ākāro ñeyyo, ","html":"<span class='verse-line'>{}</span>"},"ne3:12.4":{"pli":"<b>Paññattī</b> nāma hāroti. ","html":"<span class='verse-line'>{}</span></p>"},"ne3:13.1":{"pli":"Yo ca paṭiccuppādo, ","html":"<p><span class='verse-line'>{}</span>"},"ne3:13.2":{"pli":"Indriyakhandhā ca dhātu āyatanā; ","html":"<span class='verse-line'>{}</span>"},"ne3:13.3":{"pli":"Etehi otarati yo, ","html":"<span class='verse-line'>{}</span>"},"ne3:13.4":{"pli":"<b>Otaraṇo</b> nāma so hāro. ","html":"<span class='verse-line'>{}</span></p>"},"ne3:14.1":{"pli":"Vissajjitamhi pañhe, ","html":"<p><span class='verse-line'>{}</span>"},"ne3:14.2":{"pli":"Gāthāyaṁ pucchitā yamārabbha; ","html":"<span class='verse-line'>{}</span>"},"ne3:14.3":{"pli":"Suddhāsuddhaparikkhā, ","html":"<span class='verse-line'>{}</span>"},"ne3:14.4":{"pli":"Hāro so <b>sodhano</b> nāma. ","html":"<span class='verse-line'>{}</span></p>"},"ne3:15.1":{"pli":"Ekattatāya dhammā, ","html":"<p><span class='verse-line'>{}</span>"},"ne3:15.2":{"pli":"Yepi ca vemattatāya niddiṭṭhā; ","html":"<span class='verse-line'>{}</span>"},"ne3:15.3":{"pli":"Te na vikappayitabbā, ","html":"<span class='verse-line'>{}</span>"},"ne3:15.4":{"pli":"Eso hāro <b>adhiṭṭhāno</b>. ","html":"<span class='verse-line'>{}</span></p>"},"ne3:16.1":{"pli":"Ye dhammā yaṁ dhammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ne3:16.2":{"pli":"Janayantippaccayā paramparato; ","html":"<span class='verse-line'>{}</span>"},"ne3:16.3":{"pli":"Hetumavakaḍḍhayitvā, ","html":"<span class='verse-line'>{}</span>"},"ne3:16.4":{"pli":"Eso hāro <b>parikkhāro</b>. ","html":"<span class='verse-line'>{}</span></p>"},"ne3:17.1":{"pli":"Ye dhammā yaṁmūlā, ","html":"<p><span class='verse-line'>{}</span>"},"ne3:17.2":{"pli":"Ye cekatthā pakāsitā muninā; ","html":"<span class='verse-line'>{}</span>"},"ne3:17.3":{"pli":"Te samaropayitabbā, ","html":"<span class='verse-line'>{}</span>"},"ne3:17.4":{"pli":"Esa <b>samāropano</b> hāro. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ne3:18.0":{"pli":"3.2. Nayasaṅkhepa ","html":"<h3>{}</h3>"},"ne3:18.1":{"pli":"Taṇhañca avijjampi ca, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ne3:18.2":{"pli":"Samathena vipassanāya yo neti; ","html":"<span class='verse-line'>{}</span>"},"ne3:18.3":{"pli":"Saccehi yojayitvā, ","html":"<span class='verse-line'>{}</span>"},"ne3:18.4":{"pli":"Ayaṁ nayo <b>nandiyāvaṭṭo</b>. ","html":"<span class='verse-line'>{}</span></p>"},"ne3:19.1":{"pli":"Yo akusale samūlehi, ","html":"<p><span class='verse-line'>{}</span>"},"ne3:19.2":{"pli":"Neti kusale ca kusalamūlehi; ","html":"<span class='verse-line'>{}</span>"},"ne3:19.3":{"pli":"Bhūtaṁ tathaṁ avitathaṁ, ","html":"<span class='verse-line'>{}</span>"},"ne3:19.4":{"pli":"<b>Tipukkhalaṁ</b> taṁ nayaṁ āhu. ","html":"<span class='verse-line'>{}</span></p>"},"ne3:20.1":{"pli":"Yo neti vipallāsehi, ","html":"<p><span class='verse-line'>{}</span>"},"ne3:20.2":{"pli":"Kilese indriyehi saddhamme; ","html":"<span class='verse-line'>{}</span>"},"ne3:20.3":{"pli":"Etaṁ nayaṁ nayavidū, ","html":"<span class='verse-line'>{}</span>"},"ne3:20.4":{"pli":"<b>Sīhavikkīḷitaṁ</b> āhu. ","html":"<span class='verse-line'>{}</span></p>"},"ne3:21.1":{"pli":"Veyyākaraṇesu hi ye, ","html":"<p><span class='verse-line'>{}</span>"},"ne3:21.2":{"pli":"Kusalākusalā tahiṁ tahiṁ vuttā; ","html":"<span class='verse-line'>{}</span>"},"ne3:21.3":{"pli":"Manasā volokayate, ","html":"<span class='verse-line'>{}</span>"},"ne3:21.4":{"pli":"Taṁ khu <b>disālocanaṁ</b> āhu. ","html":"<span class='verse-line'>{}</span></p>"},"ne3:22.1":{"pli":"Oloketvā disalocanena, ","html":"<p><span class='verse-line'>{}</span>"},"ne3:22.2":{"pli":"Ukkhipiya yaṁ samāneti; ","html":"<span class='verse-line'>{}</span>"},"ne3:22.3":{"pli":"Sabbe kusalākusale, ","html":"<span class='verse-line'>{}</span>"},"ne3:22.4":{"pli":"Ayaṁ nayo <b>aṅkuso</b> nāma. ","html":"<span class='verse-line'>{}</span></p>"},"ne3:23.1":{"pli":"Soḷasa hārā paṭhamaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ne3:23.2":{"pli":"Disalocanato disā viloketvā; ","html":"<span class='verse-line'>{}</span>"},"ne3:23.3":{"pli":"Saṅkhipiya aṅkusena hi, ","html":"<span class='verse-line'>{}</span>"},"ne3:23.4":{"pli":"Nayehi tīhi niddise suttaṁ. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ne3:24.0":{"pli":"3.3. Dvādasapada ","html":"<h3>{}</h3>"},"ne3:24.1":{"pli":"Akkharaṁ padaṁ byañjanaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ne3:24.2":{"pli":"nirutti tatheva niddeso; ","html":"<span class='verse-line'>{}</span>"},"ne3:24.3":{"pli":"Ākārachaṭṭhavacanaṁ, ","html":"<span class='verse-line'>{}</span>"},"ne3:24.4":{"pli":"ettāva byañjanaṁ sabbaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ne3:25.1":{"pli":"Saṅkāsanā pakāsanā, ","html":"<p><span class='verse-line'>{}</span>"},"ne3:25.2":{"pli":"Vivaraṇā vibhajanuttānīkammapaññatti; ","html":"<span class='verse-line'>{}</span>"},"ne3:25.3":{"pli":"Etehi chahi padehi, ","html":"<span class='verse-line'>{}</span>"},"ne3:25.4":{"pli":"Attho kammañca niddiṭṭhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ne3:26.1":{"pli":"Tīṇi ca nayā anūnā, ","html":"<p><span class='verse-line'>{}</span>"},"ne3:26.2":{"pli":"Atthassa ca chappadāni gaṇitāni; ","html":"<span class='verse-line'>{}</span>"},"ne3:26.3":{"pli":"Navahi padehi bhagavato, ","html":"<span class='verse-line'>{}</span>"},"ne3:26.4":{"pli":"Vacanassattho samāyutto. ","html":"<span class='verse-line'>{}</span></p>"},"ne3:27.1":{"pli":"Atthassa navappadāni, ","html":"<p><span class='verse-line'>{}</span>"},"ne3:27.2":{"pli":"Byañjanapariyeṭṭhiyā catubbīsa; ","html":"<span class='verse-line'>{}</span>"},"ne3:27.3":{"pli":"Ubhayaṁ saṅkalayitvā, ","html":"<span class='verse-line'>{}</span>"},"ne3:27.4":{"pli":"Tettiṁsā ettikā nettīti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ne3:27.5":{"pli":"Niddesavāro. ","html":"<p class='endsutta'>{}</p></article>"}},"ne30":{"ne30:0.1":{"pli":"Netti ","html":"<article id='ne30'><header><ul><li class='division'>{}</li>"},"ne30:0.2":{"pli":"Paṭiniddesavāra ","html":"<li>{}</li>"},"ne30:0.3":{"pli":"Sampāta 11 ","html":"<li>{}</li></ul>"},"ne30:0.4":{"pli":"Paññattihārasampāta ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ne30:1.1":{"pli":"Tattha katamo paññattihārasampāto? ","html":"<p>{}</p>"},"ne30:2.1":{"pli":"“Tasmā rakkhitacittassa, sammāsaṅkappagocaro”ti gāthā. ","html":"<p>{}"},"ne30:2.2":{"pli":"“Tasmā rakkhitacittassā”ti padaṭṭhānapaññatti satiyā. ","html":"{}"},"ne30:2.3":{"pli":"“Sammāsaṅkappagocaro”ti bhāvanāpaññatti samathassa. ","html":"{}"},"ne30:2.4":{"pli":"“Sammādiṭṭhipurekkhāro, ñatvāna udayabbayan”ti dassanabhūmiyā nikkhepapaññatti. ","html":"{}"},"ne30:2.5":{"pli":"“Thinamiddhābhibhū bhikkhū”ti samudayassa anavasesappahānapaññatti, “sabbā duggatiyo jahe”ti bhāvanāpaññatti maggassa. ","html":"{}</p>"},"ne30:2.6":{"pli":"Niyutto paññattihārasampāto. ","html":"<p class='endsutta'>{}</p></article>"}},"ne31":{"ne31:0.1":{"pli":"Netti ","html":"<article id='ne31'><header><ul><li class='division'>{}</li>"},"ne31:0.2":{"pli":"Paṭiniddesavāra ","html":"<li>{}</li>"},"ne31:0.3":{"pli":"Sampāta 12 ","html":"<li>{}</li></ul>"},"ne31:0.4":{"pli":"Otaraṇahārasampāta ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ne31:1.1":{"pli":"Tattha katamo otaraṇo hārasampāto? ","html":"<p>{}</p>"},"ne31:2.1":{"pli":"“Tasmā rakkhitacittassa, sammāsaṅkappagocaro”ti gāthā. ","html":"<p>{}"},"ne31:2.2":{"pli":"“Tasmā rakkhitacittassa, sammāsaṅkappagocaro”. ","html":"{}"},"ne31:2.3":{"pli":"“Sammādiṭṭhipurekkhāro”ti sammādiṭṭhiyā gahitāya gahitāni bhavanti pañcindriyāni, ayaṁ indriyehi otaraṇā. ","html":"{}</p>"},"ne31:3.1":{"pli":"Tāniyeva indriyāni vijjā, vijjuppādā avijjānirodho, avijjānirodhā saṅkhāranirodho, saṅkhāranirodhā viññāṇanirodho, evaṁ sabbaṁ, ayaṁ paṭiccasamuppādena otaraṇā. ","html":"<p>{}</p>"},"ne31:4.1":{"pli":"Tāniyeva pañcindriyāni tīhi khandhehi saṅgahitāni—","html":"<p>{}"},"ne31:4.2":{"pli":"sīlakkhandhena samādhikkhandhena paññākkhandhena. ","html":"{}"},"ne31:4.3":{"pli":"Ayaṁ khandhehi otaraṇā. ","html":"{}</p>"},"ne31:5.1":{"pli":"Tāni yeva pañcindriyāni saṅkhārapariyāpannāni. ","html":"<p>{}"},"ne31:5.2":{"pli":"Ye saṅkhārā anāsavā no ca bhavaṅgā, te saṅkhārā dhammadhātusaṅgahitā, ayaṁ dhātūhi otaraṇā. ","html":"{}</p>"},"ne31:6.1":{"pli":"Sā dhammadhātu dhammāyatanapariyāpannā, yaṁ āyatanaṁ anāsavaṁ no ca bhavaṅgaṁ, ayaṁ āyatanehi otaraṇā. ","html":"<p>{}</p>"},"ne31:6.2":{"pli":"Niyutto otaraṇo hārasampāto. ","html":"<p class='endsutta'>{}</p></article>"}},"ne32":{"ne32:0.1":{"pli":"Netti ","html":"<article id='ne32'><header><ul><li class='division'>{}</li>"},"ne32:0.2":{"pli":"Paṭiniddesavāra ","html":"<li>{}</li>"},"ne32:0.3":{"pli":"Sampāta 13 ","html":"<li>{}</li></ul>"},"ne32:0.4":{"pli":"Sodhanahārasampāta ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ne32:1.1":{"pli":"Tattha katamo sodhano hārasampāto? ","html":"<p>{}</p>"},"ne32:2.1":{"pli":"“Tasmā rakkhitacittassa, sammāsaṅkappagocaro”ti gāthā. ","html":"<p>{}"},"ne32:2.2":{"pli":"Yattha ārambho suddho, so pañho visajjito bhavati. ","html":"{}"},"ne32:2.3":{"pli":"Yattha pana ārambho na suddho, na tāva so pañho visajjito bhavati. ","html":"{}</p>"},"ne32:2.4":{"pli":"Niyutto sodhano hārasampāto. ","html":"<p class='endsutta'>{}</p></article>"}},"ne33":{"ne33:0.1":{"pli":"Netti ","html":"<article id='ne33'><header><ul><li class='division'>{}</li>"},"ne33:0.2":{"pli":"Paṭiniddesavāra ","html":"<li>{}</li>"},"ne33:0.3":{"pli":"Sampāta 14 ","html":"<li>{}</li></ul>"},"ne33:0.4":{"pli":"Adhiṭṭhānahārasampāta ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ne33:1.1":{"pli":"Tattha katamo adhiṭṭhāno hārasampāto? ","html":"<p>{}</p>"},"ne33:2.1":{"pli":"“Tasmā rakkhitacittassa, sammāsaṅkappagocaro”ti gāthā. ","html":"<p>{}"},"ne33:2.2":{"pli":"Tasmā rakkhitacittassāti ekattatā. ","html":"{}"},"ne33:2.3":{"pli":"Cittaṁ mano viññāṇaṁ, ayaṁ vemattatā. ","html":"{}"},"ne33:2.4":{"pli":"Sammāsaṅkappagocaroti ekattatā. ","html":"{}"},"ne33:2.5":{"pli":"Nekkhammasaṅkappo abyāpādasaṅkappo avihiṁsāsaṅkappo ayaṁ vemattatā. ","html":"{}"},"ne33:2.6":{"pli":"Sammādiṭṭhipurekkhāroti ekattatā. ","html":"{}"},"ne33:2.7":{"pli":"Sammādiṭṭhi nāma yaṁ dukkhe ñāṇaṁ dukkhasamudaye ñāṇaṁ dukkhanirodhe ñāṇaṁ dukkhanirodhagāminiyā paṭipadāya ñāṇaṁ magge ñāṇaṁ hetumhi ñāṇaṁ hetusamuppannesu dhammesu ñāṇaṁ paccaye ñāṇaṁ paccayasamuppannesu dhammesu ñāṇaṁ, yaṁ tattha tattha yathābhūtaṁ ñāṇadassanaṁ abhisamayo sampaṭivedho saccāgamanaṁ, ayaṁ vemattatā. ","html":"{}"},"ne33:2.8":{"pli":"Ñatvāna udayabbayanti ekattatā, udayena avijjāpaccayā saṅkhārā, saṅkhārapaccayā viññāṇaṁ, evaṁ sabbaṁ samudayo bhavati. ","html":"{}"},"ne33:2.9":{"pli":"Vayena avijjānirodhā saṅkhāranirodho, evaṁ sabbaṁ nirodho hoti, ayaṁ vemattatā. ","html":"{}"},"ne33:2.10":{"pli":"Thinamiddhābhibhū bhikkhūti ekattatā, thinaṁ nāma yā cittassa akallatā akammaniyatā, middhaṁ nāma yaṁ kāyassa līnattaṁ, ayaṁ vemattatā. ","html":"{}"},"ne33:2.11":{"pli":"Sabbā duggatiyo jaheti ekattatā, devamanusse vā upanidhāya apāyā duggati, nibbānaṁ vā upanidhāya sabbā upapattiyo duggati, ayaṁ vemattatā. ","html":"{}</p>"},"ne33:2.12":{"pli":"Niyutto adhiṭṭhāno hārasampāto. ","html":"<p class='endsutta'>{}</p></article>"}},"ne34":{"ne34:0.1":{"pli":"Netti ","html":"<article id='ne34'><header><ul><li class='division'>{}</li>"},"ne34:0.2":{"pli":"Paṭiniddesavāra ","html":"<li>{}</li>"},"ne34:0.3":{"pli":"Sampāta 15 ","html":"<li>{}</li></ul>"},"ne34:0.4":{"pli":"Parikkhārahārasampāta ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ne34:1.1":{"pli":"Tattha katamo parikkhāro hārasampāto? ","html":"<p>{}</p>"},"ne34:2.1":{"pli":"“Tasmā rakkhitacittassa, sammāsaṅkappagocaro”ti gāthā. ","html":"<p>{}"},"ne34:2.2":{"pli":"Ayaṁ samathavipassanāya parikkhāro. ","html":"{}</p>"},"ne34:2.3":{"pli":"Niyutto parikkhāro hārasampāto. ","html":"<p class='endsutta'>{}</p></article>"}},"ne35":{"ne35:0.1":{"pli":"Netti ","html":"<article id='ne35'><header><ul><li class='division'>{}</li>"},"ne35:0.2":{"pli":"Paṭiniddesavāra ","html":"<li>{}</li>"},"ne35:0.3":{"pli":"Sampāta 16 ","html":"<li>{}</li></ul>"},"ne35:0.4":{"pli":"Samāropanahārasampāta ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ne35:1.1":{"pli":"Tattha katamo samāropano hārasampāto? ","html":"<p>{}</p>"},"ne35:2.1":{"pli":"“Tasmā rakkhitacittassa, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ne35:2.2":{"pli":"sammāsaṅkappagocaro; ","html":"<span class='verse-line'>{}</span>"},"ne35:2.3":{"pli":"Sammādiṭṭhipurekkhāro, ","html":"<span class='verse-line'>{}</span>"},"ne35:2.4":{"pli":"ñatvāna udayabbayaṁ; ","html":"<span class='verse-line'>{}</span>"},"ne35:2.5":{"pli":"Thinamiddhābhibhū bhikkhu, ","html":"<span class='verse-line'>{}</span>"},"ne35:2.6":{"pli":"sabbā duggatiyo jahe”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ne35:3.1":{"pli":"“Tasmā rakkhitacittassā”ti tiṇṇaṁ sucaritānaṁ padaṭṭhānaṁ, citte rakkhite taṁ rakkhitaṁ bhavati kāyakammaṁ vacīkammaṁ manokammaṁ. ","html":"<p>{}"},"ne35:3.2":{"pli":"Sammādiṭṭhipurekkhāroti sammādiṭṭhiyā bhāvitāya bhāvito bhavati ariyo aṭṭhaṅgiko maggo. ","html":"{}"},"ne35:3.3":{"pli":"Kena kāraṇena? ","html":"{}"},"ne35:3.4":{"pli":"Sammādiṭṭhito hi sammāsaṅkappo pabhavati, sammāsaṅkappato sammāvācā pabhavati, sammāvācāto sammākammanto pabhavati, sammākammantato sammāājīvo pabhavati, sammāājīvato sammāvāyāmo pabhavati, sammāvāyāmato sammāsati pabhavati, sammāsatito sammāsamādhi pabhavati, sammāsamādhito sammāvimutti pabhavati, sammāvimuttito sammāvimuttiñāṇadassanaṁ pabhavati. ","html":"{}"},"ne35:3.5":{"pli":"Ayaṁ anupādiseso puggalo anupādisesā ca nibbānadhātu. ","html":"{}</p>"},"ne35:3.6":{"pli":"Niyutto samāropano hārasampāto. ","html":"<p class='endsutta'>{}</p>"},"ne35:4.1":{"pli":"Tenāha āyasmā mahākaccāyano—","html":"<p>{}</p>"},"ne35:5.1":{"pli":"“Soḷasa hārā paṭhamaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ne35:5.2":{"pli":"Disalocanato disā viloketvā; ","html":"<span class='verse-line'>{}</span>"},"ne35:5.3":{"pli":"Saṅkhipiya aṅkusena hi, ","html":"<span class='verse-line'>{}</span>"},"ne35:5.4":{"pli":"Nayehi tīhi niddise suttan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ne35:5.5":{"pli":"Niyutto hārasampāto. ","html":"<p class='endsutta'>{}</p></article>"}}}