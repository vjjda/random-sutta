{"ja516":{"ja516:0.1":{"pli":"Jātaka ","html":"<article id='ja516'><header><ul><li class='division'>{}</li>"},"ja516:0.2":{"pli":"Tiṁsanipāta ","html":"<li>{}</li>"},"ja516:0.3":{"pli":"Kiṁchandavagga ","html":"<li>{}</li></ul>"},"ja516:0.4":{"pli":"6. Mahākapijātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja516:1.1":{"pli":"Bārāṇasyaṁ ahū rājā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja516:1.2":{"pli":"kāsīnaṁ raṭṭhavaḍḍhano; ","html":"<span class='verse-line'>{}</span>"},"ja516:1.3":{"pli":"Mittāmaccaparibyūḷho, ","html":"<span class='verse-line'>{}</span>"},"ja516:1.4":{"pli":"agamāsi migājinaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:2.1":{"pli":"Tattha brāhmaṇamaddakkhi, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:2.2":{"pli":"setaṁ citraṁ kilāsinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja516:2.3":{"pli":"Viddhastaṁ koviḷāraṁva, ","html":"<span class='verse-line'>{}</span>"},"ja516:2.4":{"pli":"kisaṁ dhamanisanthataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:3.1":{"pli":"Paramakāruññataṁ pattaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:3.2":{"pli":"disvā kicchagataṁ naraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja516:3.3":{"pli":"Avaca byamhito rājā, ","html":"<span class='verse-line'>{}</span>"},"ja516:3.4":{"pli":"“yakkhānaṁ katamo nusi. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:4.1":{"pli":"Hatthapādā ca te setā, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:4.2":{"pli":"tato setataraṁ siro; ","html":"<span class='verse-line'>{}</span>"},"ja516:4.3":{"pli":"Gattaṁ kammāsavaṇṇaṁ te, ","html":"<span class='verse-line'>{}</span>"},"ja516:4.4":{"pli":"kilāsabahulo casi. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:5.1":{"pli":"Vaṭṭanāvaḷi saṅkāsā, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:5.2":{"pli":"piṭṭhi te ninnatunnatā; ","html":"<span class='verse-line'>{}</span>"},"ja516:5.3":{"pli":"Kāḷapabbāva te aṅgā, ","html":"<span class='verse-line'>{}</span>"},"ja516:5.4":{"pli":"nāññaṁ passāmi edisaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:6.1":{"pli":"Ugghaṭṭapādo tasito, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:6.2":{"pli":"kiso dhamanisanthato; ","html":"<span class='verse-line'>{}</span>"},"ja516:6.3":{"pli":"Chāto ātattarūposi, ","html":"<span class='verse-line'>{}</span>"},"ja516:6.4":{"pli":"kutosi kattha gacchasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:7.1":{"pli":"Duddasī appakārosi, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:7.2":{"pli":"dubbaṇṇo bhīmadassano; ","html":"<span class='verse-line'>{}</span>"},"ja516:7.3":{"pli":"Janetti yāpi te mātā, ","html":"<span class='verse-line'>{}</span>"},"ja516:7.4":{"pli":"na taṁ iccheyya passituṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:8.1":{"pli":"Kiṁ kammamakaraṁ pubbe, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:8.2":{"pli":"Kaṁ avajjhaṁ aghātayi; ","html":"<span class='verse-line'>{}</span>"},"ja516:8.3":{"pli":"Kibbisaṁ yaṁ karitvāna, ","html":"<span class='verse-line'>{}</span>"},"ja516:8.4":{"pli":"Idaṁ dukkhaṁ upāgami”. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:9.1":{"pli":"“Taggha te ahamakkhissaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:9.2":{"pli":"yathāpi kusalo tathā; ","html":"<span class='verse-line'>{}</span>"},"ja516:9.3":{"pli":"Saccavādiñhi lokasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja516:9.4":{"pli":"pasaṁsantīdha paṇḍitā. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:10.1":{"pli":"Eko caraṁ gogaveso, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:10.2":{"pli":"mūḷho accasariṁ vane; ","html":"<span class='verse-line'>{}</span>"},"ja516:10.3":{"pli":"Araññe irīṇe vivane, ","html":"<span class='verse-line'>{}</span>"},"ja516:10.4":{"pli":"nānākuñjarasevite. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:11.1":{"pli":"Vāḷamigānucarite, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:11.2":{"pli":"vippanaṭṭhosmi kānane; ","html":"<span class='verse-line'>{}</span>"},"ja516:11.3":{"pli":"Acariṁ tattha sattāhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja516:11.4":{"pli":"khuppipāsasamappito. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:12.1":{"pli":"Tattha tindukamaddakkhiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:12.2":{"pli":"visamaṭṭhaṁ bubhukkhito; ","html":"<span class='verse-line'>{}</span>"},"ja516:12.3":{"pli":"Papātamabhilambantaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja516:12.4":{"pli":"sampannaphaladhārinaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:13.1":{"pli":"Vātassitāni bhakkhesiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:13.2":{"pli":"tāni rucciṁsu me bhusaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja516:13.3":{"pli":"Atitto rukkhamārūhiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja516:13.4":{"pli":"tattha hessāmi āsito. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:14.1":{"pli":"Ekaṁ me bhakkhitaṁ āsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:14.2":{"pli":"dutiyaṁ abhipatthitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja516:14.3":{"pli":"Tato sā bhañjatha sākhā, ","html":"<span class='verse-line'>{}</span>"},"ja516:14.4":{"pli":"chinnā pharasunā viya. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:15.1":{"pli":"Sohaṁ sahāva sākhāhi, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:15.2":{"pli":"uddhampādo avaṁsiro; ","html":"<span class='verse-line'>{}</span>"},"ja516:15.3":{"pli":"Appatiṭṭhe anālambe, ","html":"<span class='verse-line'>{}</span>"},"ja516:15.4":{"pli":"giriduggasmi pāpataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:16.1":{"pli":"Yasmā ca vāri gambhīraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:16.2":{"pli":"tasmā na samapajjisaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja516:16.3":{"pli":"Tattha sesiṁ nirānando, ","html":"<span class='verse-line'>{}</span>"},"ja516:16.4":{"pli":"anūnā dasa rattiyo. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:17.1":{"pli":"Athettha kapi māgañchi, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:17.2":{"pli":"gonaṅgulo darīcaro; ","html":"<span class='verse-line'>{}</span>"},"ja516:17.3":{"pli":"Sākhāhi sākhaṁ vicaranto, ","html":"<span class='verse-line'>{}</span>"},"ja516:17.4":{"pli":"khādamāno dumapphalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:18.1":{"pli":"So maṁ disvā kisaṁ paṇḍuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:18.2":{"pli":"kāruññamakaraṁ mayi; ","html":"<span class='verse-line'>{}</span>"},"ja516:18.3":{"pli":"Ambho ko nāma so ettha, ","html":"<span class='verse-line'>{}</span>"},"ja516:18.4":{"pli":"evaṁ dukkhena aṭṭito. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:19.1":{"pli":"Manusso amanusso vā, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:19.2":{"pli":"attānaṁ me pavedaya; ","html":"<span class='verse-line'>{}</span>"},"ja516:19.3":{"pli":"Tassañjaliṁ paṇāmetvā, ","html":"<span class='verse-line'>{}</span>"},"ja516:19.4":{"pli":"idaṁ vacanamabraviṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:20.1":{"pli":"Manussohaṁ byasampatto, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:20.2":{"pli":"sā me natthi ito gati; ","html":"<span class='verse-line'>{}</span>"},"ja516:20.3":{"pli":"Taṁ vo vadāmi bhaddaṁ vo, ","html":"<span class='verse-line'>{}</span>"},"ja516:20.4":{"pli":"tvañca me saraṇaṁ bhava. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:21.1":{"pli":"Garuṁ silaṁ gahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:21.2":{"pli":"vicarī pabbate kapi; ","html":"<span class='verse-line'>{}</span>"},"ja516:21.3":{"pli":"Silāya yoggaṁ katvāna, ","html":"<span class='verse-line'>{}</span>"},"ja516:21.4":{"pli":"nisabho etadabravi. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:22.1":{"pli":"Ehi me piṭṭhimāruyha, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:22.2":{"pli":"gīvaṁ gaṇhāhi bāhubhi; ","html":"<span class='verse-line'>{}</span>"},"ja516:22.3":{"pli":"Ahaṁ taṁ uddharissāmi, ","html":"<span class='verse-line'>{}</span>"},"ja516:22.4":{"pli":"giriduggata vegasā. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:23.1":{"pli":"Tassa taṁ vacanaṁ sutvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:23.2":{"pli":"vānarindassa sirīmato; ","html":"<span class='verse-line'>{}</span>"},"ja516:23.3":{"pli":"Piṭṭhimāruyha dhīrassa, ","html":"<span class='verse-line'>{}</span>"},"ja516:23.4":{"pli":"gīvaṁ bāhāhi aggahiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:24.1":{"pli":"So maṁ tato samuṭṭhāsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:24.2":{"pli":"tejassī balavā kapi; ","html":"<span class='verse-line'>{}</span>"},"ja516:24.3":{"pli":"Vihaññamāno kicchena, ","html":"<span class='verse-line'>{}</span>"},"ja516:24.4":{"pli":"giriduggata vegasā. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:25.1":{"pli":"Uddharitvāna maṁ santo, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:25.2":{"pli":"nisabho etadabravi; ","html":"<span class='verse-line'>{}</span>"},"ja516:25.3":{"pli":"Iṅgha maṁ samma rakkhassu, ","html":"<span class='verse-line'>{}</span>"},"ja516:25.4":{"pli":"pasupissaṁ muhuttakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:26.1":{"pli":"Sīhā byagghā ca dīpī ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:26.2":{"pli":"acchakokataracchayo; ","html":"<span class='verse-line'>{}</span>"},"ja516:26.3":{"pli":"Te maṁ pamattaṁ hiṁseyyuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja516:26.4":{"pli":"te tvaṁ disvā nivāraya. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:27.1":{"pli":"Evaṁ me parittātūna, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:27.2":{"pli":"pasupī so muhuttakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja516:27.3":{"pli":"Tadāhaṁ pāpikaṁ diṭṭhiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja516:27.4":{"pli":"paṭilacchiṁ ayoniso. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:28.1":{"pli":"Bhakkho ayaṁ manussānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:28.2":{"pli":"yathā caññe vane migā; ","html":"<span class='verse-line'>{}</span>"},"ja516:28.3":{"pli":"Yaṁ nūnimaṁ vadhitvāna, ","html":"<span class='verse-line'>{}</span>"},"ja516:28.4":{"pli":"chāto khādeyya vānaraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:29.1":{"pli":"Asito ca gamissāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:29.2":{"pli":"maṁsamādāya sambalaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja516:29.3":{"pli":"Kantāraṁ nittharissāmi, ","html":"<span class='verse-line'>{}</span>"},"ja516:29.4":{"pli":"pātheyyaṁ me bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:30.1":{"pli":"Tato silaṁ gahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:30.2":{"pli":"matthakaṁ sannitāḷayiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja516:30.3":{"pli":"Mama gattakilantassa, ","html":"<span class='verse-line'>{}</span>"},"ja516:30.4":{"pli":"pahāro dubbalo ahu. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:31.1":{"pli":"So ca vegenudappatto, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:31.2":{"pli":"kapi ruhira makkhito; ","html":"<span class='verse-line'>{}</span>"},"ja516:31.3":{"pli":"Assupuṇṇehi nettehi, ","html":"<span class='verse-line'>{}</span>"},"ja516:31.4":{"pli":"rodanto maṁ udikkhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:32.1":{"pli":"‘Māyyomaṁ kari bhaddante, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:32.2":{"pli":"tvañca nāmedisaṁ kari; ","html":"<span class='verse-line'>{}</span>"},"ja516:32.3":{"pli":"Tvañca kho nāma dīghāvu, ","html":"<span class='verse-line'>{}</span>"},"ja516:32.4":{"pli":"aññe vāretumarahasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:33.1":{"pli":"Aho vata re purisa, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:33.2":{"pli":"tāvadukkarakāraka; ","html":"<span class='verse-line'>{}</span>"},"ja516:33.3":{"pli":"Edisā visamā duggā, ","html":"<span class='verse-line'>{}</span>"},"ja516:33.4":{"pli":"papātā uddhato mayā. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:34.1":{"pli":"Ānīto paralokāva, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:34.2":{"pli":"dubbheyyaṁ maṁ amaññatha; ","html":"<span class='verse-line'>{}</span>"},"ja516:34.3":{"pli":"Taṁ tena pāpadhammena, ","html":"<span class='verse-line'>{}</span>"},"ja516:34.4":{"pli":"pāpaṁ pāpena cintitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:35.1":{"pli":"Mā heva tvaṁ adhammaṭṭha, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:35.2":{"pli":"vedanaṁ kaṭukaṁ phusi; ","html":"<span class='verse-line'>{}</span>"},"ja516:35.3":{"pli":"Mā heva pāpakammaṁ taṁ, ","html":"<span class='verse-line'>{}</span>"},"ja516:35.4":{"pli":"phalaṁ veḷuṁva taṁ vadhi. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:36.1":{"pli":"Tayime natthi vissāso, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:36.2":{"pli":"pāpadhamma asaññata; ","html":"<span class='verse-line'>{}</span>"},"ja516:36.3":{"pli":"Ehi me piṭṭhito gaccha, ","html":"<span class='verse-line'>{}</span>"},"ja516:36.4":{"pli":"dissamānova santike. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:37.1":{"pli":"Muttosi hatthā vāḷānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:37.2":{"pli":"pattosi mānusiṁ padaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja516:37.3":{"pli":"Esa maggo adhammaṭṭha, ","html":"<span class='verse-line'>{}</span>"},"ja516:37.4":{"pli":"tena gaccha yathāsukhaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:38.1":{"pli":"Idaṁ vatvā giricaro, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:38.2":{"pli":"rahade pakkhalya matthakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja516:38.3":{"pli":"Assūni sampamajjitvā, ","html":"<span class='verse-line'>{}</span>"},"ja516:38.4":{"pli":"tato pabbatamāruhi. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:39.1":{"pli":"Sohaṁ tenābhisattosmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:39.2":{"pli":"pariḷāhena aṭṭito; ","html":"<span class='verse-line'>{}</span>"},"ja516:39.3":{"pli":"Ḍayhamānena gattena, ","html":"<span class='verse-line'>{}</span>"},"ja516:39.4":{"pli":"vāriṁ pātuṁ upāgamiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:40.1":{"pli":"Agginā viya santatto, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:40.2":{"pli":"rahado ruhiramakkhito; ","html":"<span class='verse-line'>{}</span>"},"ja516:40.3":{"pli":"Pubbalohitasaṅkāso, ","html":"<span class='verse-line'>{}</span>"},"ja516:40.4":{"pli":"sabbo me samapajjatha. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:41.1":{"pli":"Yāvanto udabindūni, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:41.2":{"pli":"kāyasmiṁ nipatiṁsu me; ","html":"<span class='verse-line'>{}</span>"},"ja516:41.3":{"pli":"Tāvanto gaṇḍa jāyetha, ","html":"<span class='verse-line'>{}</span>"},"ja516:41.4":{"pli":"addhabeluvasādisā. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:42.1":{"pli":"Pabhinnā pagghariṁsu me, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:42.2":{"pli":"kuṇapā pubbalohitā; ","html":"<span class='verse-line'>{}</span>"},"ja516:42.3":{"pli":"Yena yeneva gacchāmi, ","html":"<span class='verse-line'>{}</span>"},"ja516:42.4":{"pli":"gāmesu nigamesu ca. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:43.1":{"pli":"Daṇḍahatthā nivārenti, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:43.2":{"pli":"itthiyo purisā ca maṁ; ","html":"<span class='verse-line'>{}</span>"},"ja516:43.3":{"pli":"Okkitā pūtigandhena, ","html":"<span class='verse-line'>{}</span>"},"ja516:43.4":{"pli":"māssu orena āgamā. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:44.1":{"pli":"Etādisaṁ idaṁ dukkhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:44.2":{"pli":"satta vassāni dāni me; ","html":"<span class='verse-line'>{}</span>"},"ja516:44.3":{"pli":"Anubhomi sakaṁ kammaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja516:44.4":{"pli":"pubbe dukkaṭamattano. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:45.1":{"pli":"Taṁ vo vadāmi bhaddante, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:45.2":{"pli":"yāvantettha samāgatā; ","html":"<span class='verse-line'>{}</span>"},"ja516:45.3":{"pli":"Māssu mittāna dubbhittho, ","html":"<span class='verse-line'>{}</span>"},"ja516:45.4":{"pli":"mittadubbho hi pāpako. ","html":"<span class='verse-line'>{}</span></p>"},"ja516:46.1":{"pli":"Kuṭṭhī kilāsī bhavati, ","html":"<p><span class='verse-line'>{}</span>"},"ja516:46.2":{"pli":"yo mittānidha dubbhati; ","html":"<span class='verse-line'>{}</span>"},"ja516:46.3":{"pli":"Kāyassa bhedā mittaddu, ","html":"<span class='verse-line'>{}</span>"},"ja516:46.4":{"pli":"nirayaṁ sopapajjatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja516:47.1":{"pli":"Mahākapijātakaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja517":{"ja517:0.1":{"pli":"Jātaka ","html":"<article id='ja517'><header><ul><li class='division'>{}</li>"},"ja517:0.2":{"pli":"Tiṁsanipāta ","html":"<li>{}</li>"},"ja517:0.3":{"pli":"Kiṁchandavagga ","html":"<li>{}</li></ul>"},"ja517:0.4":{"pli":"7. Dakarakkhasajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja517:1.1":{"pli":"“Sace vo vuyhamānānaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja517:1.2":{"pli":"sattannaṁ udakaṇṇave; ","html":"<span class='verse-line'>{}</span>"},"ja517:1.3":{"pli":"Manussabalimesāno, ","html":"<span class='verse-line'>{}</span>"},"ja517:1.4":{"pli":"nāvaṁ gaṇheyya rakkhaso; ","html":"<span class='verse-line'>{}</span>"},"ja517:1.5":{"pli":"Anupubbaṁ kathaṁ datvā, ","html":"<span class='verse-line'>{}</span>"},"ja517:1.6":{"pli":"muñcesi dakarakkhasā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:2.1":{"pli":"“Mātaraṁ paṭhamaṁ dajjaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:2.2":{"pli":"Bhariyaṁ datvāna bhātaraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja517:2.3":{"pli":"Tato sahāyaṁ datvāna, ","html":"<span class='verse-line'>{}</span>"},"ja517:2.4":{"pli":"Pañcamaṁ dajjaṁ brāhmaṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja517:2.5":{"pli":"Chaṭṭhāhaṁ dajjamattānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja517:2.6":{"pli":"Neva dajjaṁ mahosadhaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:3.1":{"pli":"“Posetā te janettī ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:3.2":{"pli":"dīgharattānukampikā; ","html":"<span class='verse-line'>{}</span>"},"ja517:3.3":{"pli":"Chabbhī tayi padussati, ","html":"<span class='verse-line'>{}</span>"},"ja517:3.4":{"pli":"paṇḍitā atthadassinī; ","html":"<span class='verse-line'>{}</span>"},"ja517:3.5":{"pli":"Aññaṁ upanisaṁ katvā, ","html":"<span class='verse-line'>{}</span>"},"ja517:3.6":{"pli":"vadhā taṁ parimocayi. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:4.1":{"pli":"Taṁ tādisiṁ pāṇadadiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:4.2":{"pli":"orasaṁ gabbhadhāriniṁ; ","html":"<span class='verse-line'>{}</span>"},"ja517:4.3":{"pli":"Mātaraṁ kena dosena, ","html":"<span class='verse-line'>{}</span>"},"ja517:4.4":{"pli":"dajjāsi dakarakkhino”. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:5.1":{"pli":"“Daharā viyalaṅkāraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:5.2":{"pli":"dhāreti apiḷandhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja517:5.3":{"pli":"Dovārike anīkaṭṭhe, ","html":"<span class='verse-line'>{}</span>"},"ja517:5.4":{"pli":"ativelaṁ pajagghati. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:6.1":{"pli":"Athopi paṭirājūnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:6.2":{"pli":"sayaṁ dūtāni sāsati; ","html":"<span class='verse-line'>{}</span>"},"ja517:6.3":{"pli":"Mātaraṁ tena dosena, ","html":"<span class='verse-line'>{}</span>"},"ja517:6.4":{"pli":"dajjāhaṁ dakarakkhino”. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:7.1":{"pli":"“Itthigumbassa pavarā, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:7.2":{"pli":"accantaṁ piyabhāṇinī; ","html":"<span class='verse-line'>{}</span>"},"ja517:7.3":{"pli":"Anuggatā sīlavatī, ","html":"<span class='verse-line'>{}</span>"},"ja517:7.4":{"pli":"chāyāva anapāyinī. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:8.1":{"pli":"Akkodhanā puññavatī, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:8.2":{"pli":"paṇḍitā atthadassinī; ","html":"<span class='verse-line'>{}</span>"},"ja517:8.3":{"pli":"Ubbariṁ kena dosena, ","html":"<span class='verse-line'>{}</span>"},"ja517:8.4":{"pli":"dajjāsi dakarakkhino”. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:9.1":{"pli":"“Khiḍḍāratisamāpannaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:9.2":{"pli":"anatthavasamāgataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja517:9.3":{"pli":"Sā maṁ sakāna puttānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja517:9.4":{"pli":"ayācaṁ yācate dhanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:10.1":{"pli":"Sohaṁ dadāmi sāratto, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:10.2":{"pli":"bahuṁ uccāvacaṁ dhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja517:10.3":{"pli":"Suduccajaṁ cajitvāna, ","html":"<span class='verse-line'>{}</span>"},"ja517:10.4":{"pli":"pacchā socāmi dummano; ","html":"<span class='verse-line'>{}</span>"},"ja517:10.5":{"pli":"Ubbariṁ tena dosena, ","html":"<span class='verse-line'>{}</span>"},"ja517:10.6":{"pli":"dajjāhaṁ dakarakkhino”. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:11.1":{"pli":"“Yenocitā janapadā, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:11.2":{"pli":"ānītā ca paṭiggahaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja517:11.3":{"pli":"Ābhataṁ pararajjebhi, ","html":"<span class='verse-line'>{}</span>"},"ja517:11.4":{"pli":"abhiṭṭhāya bahuṁ dhanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:12.1":{"pli":"Dhanuggahānaṁ pavaraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:12.2":{"pli":"sūraṁ tikhiṇamantinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja517:12.3":{"pli":"Bhātaraṁ kena dosena, ","html":"<span class='verse-line'>{}</span>"},"ja517:12.4":{"pli":"dajjāsi dakarakkhino”. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:13.1":{"pli":"“Yenocitā janapadā, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:13.2":{"pli":"ānītā ca paṭiggahaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja517:13.3":{"pli":"Ābhataṁ pararajjebhi, ","html":"<span class='verse-line'>{}</span>"},"ja517:13.4":{"pli":"abhiṭṭhāya bahuṁ dhanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:14.1":{"pli":"Dhanuggahānaṁ pavaro, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:14.2":{"pli":"sūro tikhiṇamanti ca; ","html":"<span class='verse-line'>{}</span>"},"ja517:14.3":{"pli":"Mayāyaṁ sukhito rājā, ","html":"<span class='verse-line'>{}</span>"},"ja517:14.4":{"pli":"atimaññati dārako. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:15.1":{"pli":"Upaṭṭhānampi me ayye, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:15.2":{"pli":"na so eti yathā pure; ","html":"<span class='verse-line'>{}</span>"},"ja517:15.3":{"pli":"Bhātaraṁ tena dosena, ","html":"<span class='verse-line'>{}</span>"},"ja517:15.4":{"pli":"dajjāhaṁ dakarakkhino”. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:16.1":{"pli":"“Ekarattena ubhayo, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:16.2":{"pli":"tvañceva dhanusekha ca; ","html":"<span class='verse-line'>{}</span>"},"ja517:16.3":{"pli":"Ubho jātettha pañcālā, ","html":"<span class='verse-line'>{}</span>"},"ja517:16.4":{"pli":"sahāyā susamāvayā. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:17.1":{"pli":"Cariyā taṁ anubandhittho, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:17.2":{"pli":"ekadukkhasukho tava; ","html":"<span class='verse-line'>{}</span>"},"ja517:17.3":{"pli":"Ussukko te divārattiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja517:17.4":{"pli":"sabbakiccesu byāvaṭo; ","html":"<span class='verse-line'>{}</span>"},"ja517:17.5":{"pli":"Sahāyaṁ kena dosena, ","html":"<span class='verse-line'>{}</span>"},"ja517:17.6":{"pli":"dajjāsi dakarakkhino”. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:18.1":{"pli":"“Cariyā maṁ ayaṁ ayye, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:18.2":{"pli":"pajagghittho mayā saha; ","html":"<span class='verse-line'>{}</span>"},"ja517:18.3":{"pli":"Ajjāpi tena vaṇṇena, ","html":"<span class='verse-line'>{}</span>"},"ja517:18.4":{"pli":"ativelaṁ pajagghati. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:19.1":{"pli":"Ubbariyāpihaṁ ayye, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:19.2":{"pli":"mantayāmi rahogato; ","html":"<span class='verse-line'>{}</span>"},"ja517:19.3":{"pli":"Anāmanto pavisati, ","html":"<span class='verse-line'>{}</span>"},"ja517:19.4":{"pli":"pubbe appaṭivedito. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:20.1":{"pli":"Laddhadvāro katokāso, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:20.2":{"pli":"ahirikaṁ anādaraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja517:20.3":{"pli":"Sahāyaṁ tena dosena, ","html":"<span class='verse-line'>{}</span>"},"ja517:20.4":{"pli":"dajjāhaṁ dakarakkhino”. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:21.1":{"pli":"“Kusalo sabbanimittānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:21.2":{"pli":"rutaññū āgatāgamo; ","html":"<span class='verse-line'>{}</span>"},"ja517:21.3":{"pli":"Uppāte supine yutto, ","html":"<span class='verse-line'>{}</span>"},"ja517:21.4":{"pli":"niyyāne ca pavesane. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:22.1":{"pli":"Paṭṭho bhūmantalikkhasmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:22.2":{"pli":"Nakkhattapadakovido; ","html":"<span class='verse-line'>{}</span>"},"ja517:22.3":{"pli":"Brāhmaṇaṁ kena dosena, ","html":"<span class='verse-line'>{}</span>"},"ja517:22.4":{"pli":"Dajjāsi dakarakkhino”. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:23.1":{"pli":"“Parisāyampi me ayye, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:23.2":{"pli":"ummīlitvā udikkhati; ","html":"<span class='verse-line'>{}</span>"},"ja517:23.3":{"pli":"Tasmā accabhamuṁ luddaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja517:23.4":{"pli":"dajjāhaṁ dakarakkhino”. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:24.1":{"pli":"“Sasamuddapariyāyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:24.2":{"pli":"mahiṁ sāgarakuṇḍalaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja517:24.3":{"pli":"Vasundharaṁ āvasasi, ","html":"<span class='verse-line'>{}</span>"},"ja517:24.4":{"pli":"amaccaparivārito. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:25.1":{"pli":"Cāturanto mahāraṭṭho, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:25.2":{"pli":"vijitāvī mahabbalo; ","html":"<span class='verse-line'>{}</span>"},"ja517:25.3":{"pli":"Pathabyā ekarājāsi, ","html":"<span class='verse-line'>{}</span>"},"ja517:25.4":{"pli":"yaso te vipulaṁ gato. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:26.1":{"pli":"Soḷasitthisahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:26.2":{"pli":"āmuttamaṇikuṇḍalā; ","html":"<span class='verse-line'>{}</span>"},"ja517:26.3":{"pli":"Nānājanapadā nārī, ","html":"<span class='verse-line'>{}</span>"},"ja517:26.4":{"pli":"devakaññūpamā subhā. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:27.1":{"pli":"Evaṁ sabbaṅgasampannaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:27.2":{"pli":"sabbakāmasamiddhinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja517:27.3":{"pli":"Sukhitānaṁ piyaṁ dīghaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja517:27.4":{"pli":"jīvitaṁ āhu khattiya. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:28.1":{"pli":"Atha tvaṁ kena vaṇṇena, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:28.2":{"pli":"kena vā pana hetunā; ","html":"<span class='verse-line'>{}</span>"},"ja517:28.3":{"pli":"Paṇḍitaṁ anurakkhanto, ","html":"<span class='verse-line'>{}</span>"},"ja517:28.4":{"pli":"pāṇaṁ cajasi duccajaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:29.1":{"pli":"“Yatopi āgato ayye, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:29.2":{"pli":"mama hatthaṁ mahosadho; ","html":"<span class='verse-line'>{}</span>"},"ja517:29.3":{"pli":"Nābhijānāmi dhīrassa, ","html":"<span class='verse-line'>{}</span>"},"ja517:29.4":{"pli":"anumattampi dukkaṭaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:30.1":{"pli":"Sace ca kismici kāle, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:30.2":{"pli":"maraṇaṁ me pure siyā; ","html":"<span class='verse-line'>{}</span>"},"ja517:30.3":{"pli":"So me putte paputte ca, ","html":"<span class='verse-line'>{}</span>"},"ja517:30.4":{"pli":"sukhāpeyya mahosadho. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:31.1":{"pli":"Anāgataṁ paccuppannaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:31.2":{"pli":"sabbamatthampi passati; ","html":"<span class='verse-line'>{}</span>"},"ja517:31.3":{"pli":"Anāparādhakammantaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja517:31.4":{"pli":"na dajjaṁ dakarakkhino”. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:32.1":{"pli":"“Idaṁ suṇātha pañcālā, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:32.2":{"pli":"cūḷaneyyassa bhāsitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja517:32.3":{"pli":"Paṇḍitaṁ anurakkhanto, ","html":"<span class='verse-line'>{}</span>"},"ja517:32.4":{"pli":"pāṇaṁ cajati duccajaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:33.1":{"pli":"Mātu bhariyāya bhātucca, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:33.2":{"pli":"sakhino brāhmaṇassa ca; ","html":"<span class='verse-line'>{}</span>"},"ja517:33.3":{"pli":"Attano cāpi pañcālo, ","html":"<span class='verse-line'>{}</span>"},"ja517:33.4":{"pli":"channaṁ cajati jīvitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja517:34.1":{"pli":"Evaṁ mahatthikā paññā, ","html":"<p><span class='verse-line'>{}</span>"},"ja517:34.2":{"pli":"nipuṇā sādhucintinī; ","html":"<span class='verse-line'>{}</span>"},"ja517:34.3":{"pli":"Diṭṭhadhammahitatthāya, ","html":"<span class='verse-line'>{}</span>"},"ja517:34.4":{"pli":"samparāyasukhāya cā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja517:35.1":{"pli":"Dakarakkhasajātakaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}