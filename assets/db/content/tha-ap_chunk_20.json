{"tha-ap316":{"tha-ap316:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap316'><header><ul><li class='division'>{}</li>"},"tha-ap316:0.2":{"pli":"Ārakkhadāyakavagga ","html":"<li>{}</li></ul>"},"tha-ap316:0.3":{"pli":"Sattapadumiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap316:1.1":{"pli":"“Nadīkūle vasāmahaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap316:1.2":{"pli":"nesādo nāma brāhmaṇo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap316:1.3":{"pli":"Satapattehi pupphehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap316:1.4":{"pli":"sammajjitvāna assamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap316:2.1":{"pli":"Suvaṇṇavaṇṇaṁ sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap316:2.2":{"pli":"Siddhatthaṁ lokanāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap316:2.3":{"pli":"Disvā nabhena gacchantaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap316:2.4":{"pli":"Hāso me udapajjatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap316:3.1":{"pli":"Paccuggantvāna sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap316:3.2":{"pli":"lokajeṭṭhaṁ narāsabhaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap316:3.3":{"pli":"Assamaṁ atināmetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap316:3.4":{"pli":"jalajaggehi okiriṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap316:4.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap316:4.2":{"pli":"yaṁ pupphamabhiropayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap316:4.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap316:4.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap316:5.1":{"pli":"Ito te sattame kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap316:5.2":{"pli":"caturo pādapāvarā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap316:5.3":{"pli":"Sattaratanasampannā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap316:5.4":{"pli":"cakkavattī mahabbalā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap316:6.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap316:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap316:6.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap316:7.1":{"pli":"Itthaṁ sudaṁ āyasmā sattapadumiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap316:8.1":{"pli":"Sattapadumiyattherassāpadānaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap317":{"tha-ap317:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap317'><header><ul><li class='division'>{}</li>"},"tha-ap317:0.2":{"pli":"Ārakkhadāyakavagga ","html":"<li>{}</li></ul>"},"tha-ap317:0.3":{"pli":"Pupphāsanadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap317:1.1":{"pli":"“Suvaṇṇavaṇṇaṁ sambuddhaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap317:1.2":{"pli":"Pītaraṁsiṁva bhāṇumaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap317:1.3":{"pli":"Avidūrena gacchantaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap317:1.4":{"pli":"Siddhatthaṁ aparājitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap317:2.1":{"pli":"Tassa paccuggamitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap317:2.2":{"pli":"pavesetvāna assamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap317:2.3":{"pli":"Pupphāsanaṁ mayā dinnaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap317:2.4":{"pli":"vippasannena cetasā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap317:3.1":{"pli":"Añjaliṁ paggahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap317:3.2":{"pli":"vedajāto tadā ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap317:3.3":{"pli":"Buddhe cittaṁ pasādetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap317:3.4":{"pli":"taṁ kammaṁ pariṇāmayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap317:4.1":{"pli":"Yaṁ me atthi kataṁ puññaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap317:4.2":{"pli":"sayambhumhaparājite; ","html":"<span class='verse-line'>{}</span>"},"tha-ap317:4.3":{"pli":"Sabbena tena kusalena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap317:4.4":{"pli":"vimalo homi sāsane. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap317:5.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap317:5.2":{"pli":"pupphāsanamadaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap317:5.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap317:5.4":{"pli":"pupphāsanassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap317:6.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap317:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap317:6.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap317:7.1":{"pli":"Itthaṁ sudaṁ āyasmā pupphāsanadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap317:8.1":{"pli":"Pupphāsanadāyakattherassāpadānaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap318":{"tha-ap318:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap318'><header><ul><li class='division'>{}</li>"},"tha-ap318:0.2":{"pli":"Ārakkhadāyakavagga ","html":"<li>{}</li></ul>"},"tha-ap318:0.3":{"pli":"6 Āsanasanthavikattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap318:1.1":{"pli":"“Cetiyaṁ uttamaṁ nāma, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap318:1.2":{"pli":"sikhino lokabandhuno; ","html":"<span class='verse-line'>{}</span>"},"tha-ap318:1.3":{"pli":"Araññe irīṇe vane, ","html":"<span class='verse-line'>{}</span>"},"tha-ap318:1.4":{"pli":"andhāhiṇḍāmahaṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap318:2.1":{"pli":"Pavanā nikkhamantena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap318:2.2":{"pli":"diṭṭhaṁ sīhāsanaṁ mayā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap318:2.3":{"pli":"Ekaṁsaṁ añjaliṁ katvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap318:2.4":{"pli":"santhaviṁ lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap318:3.1":{"pli":"Divasabhāgaṁ thavitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap318:3.2":{"pli":"buddhaṁ lokagganāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap318:3.3":{"pli":"Haṭṭho haṭṭhena cittena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap318:3.4":{"pli":"imaṁ vācaṁ udīrayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap318:4.1":{"pli":"‘Namo te purisājañña, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap318:4.2":{"pli":"namo te purisuttama; ","html":"<span class='verse-line'>{}</span>"},"tha-ap318:4.3":{"pli":"Sabbaññūsi mahāvīra, ","html":"<span class='verse-line'>{}</span>"},"tha-ap318:4.4":{"pli":"lokajeṭṭha narāsabha’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap318:5.1":{"pli":"Abhitthavitvā sikhinaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap318:5.2":{"pli":"nimittakaraṇenahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap318:5.3":{"pli":"Āsanaṁ abhivādetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap318:5.4":{"pli":"pakkāmiṁ uttarāmukho. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap318:6.1":{"pli":"Ekattiṁse ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap318:6.2":{"pli":"yaṁ thaviṁ vadataṁ varaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap318:6.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap318:6.4":{"pli":"thomanāya idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap318:7.1":{"pli":"Sattavīse ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap318:7.2":{"pli":"atulā satta āsu te; ","html":"<span class='verse-line'>{}</span>"},"tha-ap318:7.3":{"pli":"Sattaratanasampannā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap318:7.4":{"pli":"cakkavattī mahabbalā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap318:8.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap318:8.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap318:8.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap318:9.1":{"pli":"Itthaṁ sudaṁ āyasmā āsanasanthaviko thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap318:10.1":{"pli":"Āsanasanthavikattherassāpadānaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap319":{"tha-ap319:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap319'><header><ul><li class='division'>{}</li>"},"tha-ap319:0.2":{"pli":"Ārakkhadāyakavagga ","html":"<li>{}</li></ul>"},"tha-ap319:0.3":{"pli":"Saddasaññakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap319:1.1":{"pli":"“Sudassano mahāvīro, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap319:1.2":{"pli":"deseti amataṁ padaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap319:1.3":{"pli":"Parivuto sāvakehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap319:1.4":{"pli":"vasati gharamuttame. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap319:2.1":{"pli":"Tāya vācāya madhurāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap319:2.2":{"pli":"saṅgaṇhāti mahājanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap319:2.3":{"pli":"Ghoso ca vipulo āsi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap319:2.4":{"pli":"āsīso devamānuse. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap319:3.1":{"pli":"Nigghosasaddaṁ sutvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap319:3.2":{"pli":"siddhatthassa mahesino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap319:3.3":{"pli":"Sadde cittaṁ pasādetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap319:3.4":{"pli":"avandiṁ lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap319:4.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap319:4.2":{"pli":"yaṁ saññamalabhiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap319:4.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap319:4.4":{"pli":"buddhasaññāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap319:5.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap319:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap319:5.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap319:6.1":{"pli":"Itthaṁ sudaṁ āyasmā saddasaññako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap319:7.1":{"pli":"Saddasaññakattherassāpadānaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap32":{"tha-ap32:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap32'><header><ul><li class='division'>{}</li>"},"tha-ap32:0.2":{"pli":"Subhūtivagga ","html":"<li>{}</li></ul>"},"tha-ap32:0.3":{"pli":"Khomadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap32:1.1":{"pli":"“Nagare bandhumatiyā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap32:1.2":{"pli":"ahosiṁ vāṇijo tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap32:1.3":{"pli":"Teneva dāraṁ posemi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap32:1.4":{"pli":"ropemi bījasampadaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap32:2.1":{"pli":"Rathiyaṁ paṭipannassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap32:2.2":{"pli":"vipassissa mahesino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap32:2.3":{"pli":"Ekaṁ khomaṁ mayā dinnaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap32:2.4":{"pli":"kusalatthāya satthuno. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap32:3.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap32:3.2":{"pli":"yaṁ khomamadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap32:3.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap32:3.4":{"pli":"khomadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap32:4.1":{"pli":"Sattarase ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap32:4.2":{"pli":"eko sindhavasandhano; ","html":"<span class='verse-line'>{}</span>"},"tha-ap32:4.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap32:4.4":{"pli":"catudīpamhi issaro. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap32:5.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap32:5.2":{"pli":"Vimokkhāpi ca aṭṭhime; ","html":"<span class='verse-line'>{}</span>"},"tha-ap32:5.3":{"pli":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap32:5.4":{"pli":"Kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap32:6.1":{"pli":"Itthaṁ sudaṁ āyasmā khomadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap32:7.1":{"pli":"Khomadāyakattherassāpadānaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap32:8.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"tha-ap32:9.1":{"pli":"Subhūti upavāno ca, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"tha-ap32:9.2":{"pli":"saraṇo sīlagāhako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap32:9.3":{"pli":"Annasaṁsāvako dhūpo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap32:9.4":{"pli":"pulino uttiyena ca. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap32:10.1":{"pli":"Añjalī khomadāyī ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap32:10.2":{"pli":"daseva tatiye gaṇe; ","html":"<span class='verse-line'>{}</span>"},"tha-ap32:10.3":{"pli":"Pañcāsītisataṁ vuttā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap32:10.4":{"pli":"gāthāyo sabbapiṇḍitā. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap32:11.1":{"pli":"Subhūtivaggo tatiyo. ","html":"<p class='endsection'>{}</p>"},"tha-ap32:12.1":{"pli":"Catutthabhāṇavāraṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap320":{"tha-ap320:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap320'><header><ul><li class='division'>{}</li>"},"tha-ap320:0.2":{"pli":"Ārakkhadāyakavagga ","html":"<li>{}</li></ul>"},"tha-ap320:0.3":{"pli":"Tiraṁsiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap320:1.1":{"pli":"“Kesariṁ abhijātaṁva, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap320:1.2":{"pli":"aggikkhandhaṁva pabbate; ","html":"<span class='verse-line'>{}</span>"},"tha-ap320:1.3":{"pli":"Obhāsentaṁ disā sabbā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap320:1.4":{"pli":"siddhatthaṁ pabbatantare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap320:2.1":{"pli":"Sūriyassa ca ālokaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap320:2.2":{"pli":"candālokaṁ tatheva ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap320:2.3":{"pli":"Buddhālokañca disvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap320:2.4":{"pli":"vitti me udapajjatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap320:3.1":{"pli":"Tayo āloke disvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap320:3.2":{"pli":"sambuddhaṁ sāvakuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap320:3.3":{"pli":"Ekaṁsaṁ ajinaṁ katvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap320:3.4":{"pli":"santhaviṁ lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap320:4.1":{"pli":"Tayo hi ālokakarā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap320:4.2":{"pli":"loke lokatamonudā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap320:4.3":{"pli":"Cando ca sūriyo cāpi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap320:4.4":{"pli":"buddho ca lokanāyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap320:5.1":{"pli":"Opammaṁ upadassetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap320:5.2":{"pli":"kittito me mahāmuni; ","html":"<span class='verse-line'>{}</span>"},"tha-ap320:5.3":{"pli":"Buddhassa vaṇṇaṁ kittetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap320:5.4":{"pli":"kappaṁ saggamhi modahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap320:6.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap320:6.2":{"pli":"yaṁ buddhamabhikittayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap320:6.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap320:6.4":{"pli":"kittanāya idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap320:7.1":{"pli":"Ekasaṭṭhimhito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap320:7.2":{"pli":"eko ñāṇadharo ahu; ","html":"<span class='verse-line'>{}</span>"},"tha-ap320:7.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap320:7.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap320:8.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap320:8.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap320:8.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap320:9.1":{"pli":"Itthaṁ sudaṁ āyasmā tiraṁsiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap320:10.1":{"pli":"Tiraṁsiyattherassāpadānaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap321":{"tha-ap321:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap321'><header><ul><li class='division'>{}</li>"},"tha-ap321:0.2":{"pli":"Ārakkhadāyakavagga ","html":"<li>{}</li></ul>"},"tha-ap321:0.3":{"pli":"9 Kandalipupphiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap321:1.1":{"pli":"“Sindhuyā nadiyā tīre, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap321:1.2":{"pli":"ahosiṁ kassako tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap321:1.3":{"pli":"Parakammāyane yutto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap321:1.4":{"pli":"parabhattaṁ apassito. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap321:2.1":{"pli":"Sindhuṁ anucarantohaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap321:2.2":{"pli":"siddhatthaṁ jinamaddasaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap321:2.3":{"pli":"Samādhinā nisinnaṁva, ","html":"<span class='verse-line'>{}</span>"},"tha-ap321:2.4":{"pli":"satapattaṁva pupphitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap321:3.1":{"pli":"Satta kandalipupphāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap321:3.2":{"pli":"vaṇṭe chetvānahaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap321:3.3":{"pli":"Matthake abhiropesiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap321:3.4":{"pli":"buddhassādiccabandhuno. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap321:4.1":{"pli":"Suvaṇṇavaṇṇaṁ sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap321:4.2":{"pli":"Anukūle samāhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap321:4.3":{"pli":"Tidhāpabhinnamātaṅgaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap321:4.4":{"pli":"Kuñjaraṁva durāsadaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap321:5.1":{"pli":"Tamahaṁ upagantvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap321:5.2":{"pli":"nipakaṁ bhāvitindriyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap321:5.3":{"pli":"Añjaliṁ paggahetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap321:5.4":{"pli":"avandiṁ satthuno ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap321:6.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap321:6.2":{"pli":"yaṁ pupphamabhiropayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap321:6.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap321:6.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap321:7.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap321:7.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap321:7.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap321:8.1":{"pli":"Itthaṁ sudaṁ āyasmā kandalipupphiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap321:9.1":{"pli":"Kandalipupphiyattherassāpadānaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap322":{"tha-ap322:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap322'><header><ul><li class='division'>{}</li>"},"tha-ap322:0.2":{"pli":"Ārakkhadāyakavagga ","html":"<li>{}</li></ul>"},"tha-ap322:0.3":{"pli":"Kumudamāliyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap322:1.1":{"pli":"“Usabhaṁ pavaraṁ vīraṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap322:1.2":{"pli":"mahesiṁ vijitāvinaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap322:1.3":{"pli":"Vipassinaṁ mahāvīraṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap322:1.4":{"pli":"abhijātaṁva kesariṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap322:2.1":{"pli":"Rathiyaṁ paṭipajjantaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap322:2.2":{"pli":"āhutīnaṁ paṭiggahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap322:2.3":{"pli":"Gahetvā kumudaṁ mālaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap322:2.4":{"pli":"buddhaseṭṭhaṁ samokiriṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap322:3.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap322:3.2":{"pli":"yaṁ pupphamabhipūjayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap322:3.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap322:3.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap322:4.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap322:4.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap322:4.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap322:5.1":{"pli":"Itthaṁ sudaṁ āyasmā kumudamāliyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap322:6.1":{"pli":"Kumudamāliyattherassāpadānaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap322:7.1":{"pli":"Ārakkhadāyakavaggo bāttiṁsatimo. ","html":"<p class='endsection'>{}</p>"},"tha-ap322:8.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"tha-ap322:9.1":{"pli":"Ārakkhado bhojanado, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"tha-ap322:9.2":{"pli":"gatasaññī padumiyo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap322:9.3":{"pli":"Pupphāsanī santhaviko, ","html":"<span class='verse-line'>{}</span>"},"tha-ap322:9.4":{"pli":"saddasaññī tiraṁsiyo; ","html":"<span class='verse-line'>