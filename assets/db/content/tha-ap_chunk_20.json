sāmikattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap326:1.1":{"pli":"“Jātiyā sattavassohaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap326:1.2":{"pli":"ahosiṁ mantapāragū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap326:1.3":{"pli":"Kulavattaṁ adhāresiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap326:1.4":{"pli":"yañño ussāhito mayā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap326:2.1":{"pli":"Cullāsītisahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap326:2.2":{"pli":"pasū haññanti me tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap326:2.3":{"pli":"Sārathambhupanītāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap326:2.4":{"pli":"yaññatthāya upaṭṭhitā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap326:3.1":{"pli":"Ukkāmukhapahaṭṭhova, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap326:3.2":{"pli":"khadiraṅgārasannibho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap326:3.3":{"pli":"Udayantova sūriyo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap326:3.4":{"pli":"puṇṇamāyeva candimā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap326:4.1":{"pli":"Siddhattho sabbasiddhattho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap326:4.2":{"pli":"tilokamahito hito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap326:4.3":{"pli":"Upagantvāna sambuddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap326:4.4":{"pli":"idaṁ vacanamabravi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap326:5.1":{"pli":"‘Ahiṁsā sabbapāṇīnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap326:5.2":{"pli":"kumāra mama ruccati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap326:5.3":{"pli":"Theyyā ca aticārā ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap326:5.4":{"pli":"majjapānā ca ārati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap326:6.1":{"pli":"Rati ca samacariyāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap326:6.2":{"pli":"bāhusaccaṁ kataññutā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap326:6.3":{"pli":"Diṭṭhe dhamme parattha ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap326:6.4":{"pli":"dhammā ete pasaṁsiyā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap326:7.1":{"pli":"Ete dhamme bhāvayitvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap326:7.2":{"pli":"sabbasattahite rato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap326:7.3":{"pli":"Buddhe cittaṁ pasādetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap326:7.4":{"pli":"bhāvehi maggamuttamaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap326:8.1":{"pli":"Idaṁ vatvāna sabbaññū, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap326:8.2":{"pli":"lokajeṭṭho narāsabho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap326:8.3":{"pli":"Mamevaṁ anusāsitvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap326:8.4":{"pli":"vehāsaṁ uggato gato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap326:9.1":{"pli":"Pubbe cittaṁ visodhetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap326:9.2":{"pli":"pacchā cittaṁ pasādayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap326:9.3":{"pli":"Tena cittappasādena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap326:9.4":{"pli":"tusitaṁ upapajjahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap326:10.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap326:10.2":{"pli":"yadā cittaṁ pasādayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap326:10.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap326:10.4":{"pli":"buddhasaññāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap326:11.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap326:11.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap326:11.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap326:12.1":{"pli":"Itthaṁ sudaṁ āyasmā yaññasāmiko thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap326:13.1":{"pli":"Yaññasāmikattherassāpadānaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap327":{"tha-ap327:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap327'><header><ul><li class='division'>{}</li>"},"tha-ap327:0.2":{"pli":"Umāpupphiyavagga ","html":"<li>{}</li></ul>"},"tha-ap327:0.3":{"pli":"Nimittasaññakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap327:1.1":{"pli":"“Candabhāgānadītīre, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap327:1.2":{"pli":"vasāmi assame ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap327:1.3":{"pli":"Suvaṇṇamigamaddakkhiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap327:1.4":{"pli":"carantaṁ vipine ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap327:2.1":{"pli":"Mige cittaṁ pasādetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap327:2.2":{"pli":"lokajeṭṭhaṁ anussariṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap327:2.3":{"pli":"Tena cittappasādena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap327:2.4":{"pli":"aññe buddhe anussariṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap327:3.1":{"pli":"Abbhatītā ca ye buddhā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap327:3.2":{"pli":"vattamānā anāgatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap327:3.3":{"pli":"Evamevaṁ virocanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap327:3.4":{"pli":"migarājāva te tayo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap327:4.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap327:4.2":{"pli":"yaṁ saññamalabhiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap327:4.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap327:4.4":{"pli":"buddhasaññāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap327:5.1":{"pli":"Sattavīse ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap327:5.2":{"pli":"eko āsiṁ mahīpati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap327:5.3":{"pli":"Araññasattho nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap327:5.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap327:6.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap327:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap327:6.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap327:7.1":{"pli":"Itthaṁ sudaṁ āyasmā nimittasaññako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap327:8.1":{"pli":"Nimittasaññakattherassāpadānaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap328":{"tha-ap328:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap328'><header><ul><li class='division'>{}</li>"},"tha-ap328:0.2":{"pli":"Umāpupphiyavagga ","html":"<li>{}</li></ul>"},"tha-ap328:0.3":{"pli":"Annasaṁsāvakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap328:1.1":{"pli":"“Suvaṇṇavaṇṇaṁ sambuddhaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap328:1.2":{"pli":"Gacchantaṁ antarāpaṇe; ","html":"<span class='verse-line'>{}</span>"},"tha-ap328:1.3":{"pli":"Kañcanagghiyasaṅkāsaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap328:1.4":{"pli":"Bāttiṁsavaralakkhaṇaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap328:2.1":{"pli":"Siddhatthaṁ sabbasiddhatthaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap328:2.2":{"pli":"anejaṁ aparājitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap328:2.3":{"pli":"Sambuddhaṁ atināmetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap328:2.4":{"pli":"bhojayiṁ taṁ mahāmuniṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap328:3.1":{"pli":"Muni kāruṇiko loke, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap328:3.2":{"pli":"obhāsayi mamaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap328:3.3":{"pli":"Buddhe cittaṁ pasādetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap328:3.4":{"pli":"kappaṁ saggamhi modahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap328:4.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap328:4.2":{"pli":"yaṁ dānamadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap328:4.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap328:4.4":{"pli":"bhikkhādānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap328:5.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap328:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap328:5.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap328:6.1":{"pli":"Itthaṁ sudaṁ āyasmā annasaṁsāvako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap328:7.1":{"pli":"Annasaṁsāvakattherassāpadānaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}