buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap323:5.1":{"pli":"Pañcapaññāsito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap323:5.2":{"pli":"eko āsiṁ mahīpati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap323:5.3":{"pli":"Samantachadano nāma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap323:5.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap323:6.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap323:6.2":{"pli":"vimokkhāpi ca aṭṭhime; ","html":"<span class='verse-line'>{}</span>"},"tha-ap323:6.3":{"pli":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap323:6.4":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap323:7.1":{"pli":"Itthaṁ sudaṁ āyasmā umāpupphiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap323:8.1":{"pli":"Umāpupphiyattherassāpadānaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap324":{"tha-ap324:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap324'><header><ul><li class='division'>{}</li>"},"tha-ap324:0.2":{"pli":"Umāpupphiyavagga ","html":"<li>{}</li></ul>"},"tha-ap324:0.3":{"pli":"2 Pulinapūjakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap324:1.1":{"pli":"“Kakudhaṁ vilasantaṁva, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap324:1.2":{"pli":"nisabhājāniyaṁ yathā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap324:1.3":{"pli":"Osadhiṁva virocantaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap324:1.4":{"pli":"obhāsantaṁ narāsabhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap324:2.1":{"pli":"Añjaliṁ paggahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap324:2.2":{"pli":"avandiṁ satthuno ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap324:2.3":{"pli":"Satthāraṁ parivaṇṇesiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap324:2.4":{"pli":"sakakammena tosayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap324:3.1":{"pli":"Susuddhaṁ pulinaṁ gayha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap324:3.2":{"pli":"gatamagge samokiriṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap324:3.3":{"pli":"Ucchaṅgena gahetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap324:3.4":{"pli":"vipassissa mahesino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap324:4.1":{"pli":"Tato upaḍḍhapulinaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap324:4.2":{"pli":"vippasannena cetasā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap324:4.3":{"pli":"Divāvihāre osiñciṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap324:4.4":{"pli":"dvipadindassa tādino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap324:5.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap324:5.2":{"pli":"pulinaṁ yamasiñcahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap324:5.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap324:5.4":{"pli":"pulinassa idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap324:6.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap324:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap324:6.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap324:7.1":{"pli":"Itthaṁ sudaṁ āyasmā pulinapūjako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap324:8.1":{"pli":"Pulinapūjakattherassāpadānaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap325":{"tha-ap325:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap325'><header><ul><li class='division'>{}</li>"},"tha-ap325:0.2":{"pli":"Umāpupphiyavagga ","html":"<li>{}</li></ul>"},"t