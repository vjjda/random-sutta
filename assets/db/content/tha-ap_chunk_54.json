{"tha-ap545":{"tha-ap545:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap545'><header><ul><li class='division'>{}</li>"},"tha-ap545:0.2":{"pli":"Bhaddiyavagga ","html":"<li>{}</li></ul>"},"tha-ap545:0.3":{"pli":"Sīvalittheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap545:1.1":{"pli":"“Padumuttaro nāma jino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap545:1.2":{"pli":"sabbadhammesu cakkhumā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:1.3":{"pli":"Ito satasahassamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:1.4":{"pli":"kappe uppajji nāyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:2.1":{"pli":"Sīlaṁ tassa asaṅkheyyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:2.2":{"pli":"samādhi vajirūpamo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:2.3":{"pli":"Asaṅkheyyaṁ ñāṇavaraṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:2.4":{"pli":"vimutti ca anopamā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:3.1":{"pli":"Manujāmaranāgānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:3.2":{"pli":"brahmānañca samāgame; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:3.3":{"pli":"Samaṇabrāhmaṇākiṇṇe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:3.4":{"pli":"dhammaṁ desesi nāyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:4.1":{"pli":"Sasāvakaṁ mahālābhiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:4.2":{"pli":"puññavantaṁ jutindharaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:4.3":{"pli":"Ṭhapesi etadaggamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:4.4":{"pli":"parisāsu visārado. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:5.1":{"pli":"Tadāhaṁ khattiyo āsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:5.2":{"pli":"nagare haṁsasavhaye; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:5.3":{"pli":"Sutvā jinassa taṁ vākyaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:5.4":{"pli":"sāvakassa guṇaṁ bahuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:6.1":{"pli":"Nimantayitvā sattāhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:6.2":{"pli":"bhojayitvā sasāvakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:6.3":{"pli":"Mahādānaṁ daditvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:6.4":{"pli":"taṁ ṭhānamabhipatthayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:7.1":{"pli":"Tadā maṁ vinataṁ pāde, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:7.2":{"pli":"disvāna purisāsabho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:7.3":{"pli":"Sarena mahatā vīro, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:7.4":{"pli":"idaṁ vacanamabravi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:8.1":{"pli":"‘Tato jinassa vacanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:8.2":{"pli":"sotukāmā mahājanā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:8.3":{"pli":"Devadānavagandhabbā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:8.4":{"pli":"brahmāno ca mahiddhikā’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:9.1":{"pli":"Samaṇabrāhmaṇā ceva, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:9.2":{"pli":"namassiṁsu katañjalī; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:9.3":{"pli":"‘Namo te purisājañña, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:9.4":{"pli":"namo te purisuttama. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:10.1":{"pli":"Khattiyena mahādānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:10.2":{"pli":"dinnaṁ sattāhikampi vo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:10.3":{"pli":"Sotukāmā phalaṁ tassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:10.4":{"pli":"byākarohi mahāmune’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:11.1":{"pli":"Tato avoca bhagavā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:11.2":{"pli":"‘suṇātha mama bhāsitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:11.3":{"pli":"Appameyyamhi buddhamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:11.4":{"pli":"sasaṅghamhi patiṭṭhitā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:12.1":{"pli":"Dakkhiṇā tāya ko vattā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:12.2":{"pli":"appameyyaphalā hi sā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:12.3":{"pli":"Api ce sa mahābhogo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:12.4":{"pli":"ṭhānaṁ pattheti uttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:13.1":{"pli":"Lābhī vipulalābhānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:13.2":{"pli":"yathā bhikkhu sudassano; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:13.3":{"pli":"Tathāhampi bhaveyyanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:13.4":{"pli":"lacchase taṁ anāgate. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:14.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:14.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:14.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:14.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:15.1":{"pli":"Tassa dhammesu dāyādo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:15.2":{"pli":"oraso dhammanimmito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:15.3":{"pli":"Sīvali nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:15.4":{"pli":"hessati satthu sāvako’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:16.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:16.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:16.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:16.4":{"pli":"tāvatiṁsūpago ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:17.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:17.2":{"pli":"vipassī lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:17.3":{"pli":"Uppajji cārudassano, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:17.4":{"pli":"sabbadhammavipassako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:18.1":{"pli":"Tadāhaṁ bandhumatiyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:18.2":{"pli":"kulassaññatarassa ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:18.3":{"pli":"Dayito passito ceva, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:18.4":{"pli":"āsiṁ kammantavāvaṭo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:19.1":{"pli":"Tadā aññataro pūgo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:19.2":{"pli":"vipassissa mahesino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:19.3":{"pli":"Parivesaṁ akārayi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:19.4":{"pli":"mahantamativissutaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:20.1":{"pli":"Niṭṭhite ca mahādāne, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:20.2":{"pli":"daduṁ khajjakasañhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:20.3":{"pli":"Navaṁ dadhiṁ madhuñceva, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:20.4":{"pli":"vicinaṁ neva addasuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:21.1":{"pli":"Tadāhaṁ taṁ gahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:21.2":{"pli":"navaṁ dadhiṁ madhumpi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:21.3":{"pli":"Kammassāmigharaṁ gacchiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:21.4":{"pli":"tamesantā mamaddasuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:22.1":{"pli":"Sahassamapi datvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:22.2":{"pli":"nālabhiṁsu ca taṁ dvayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:22.3":{"pli":"Tatohaṁ evaṁ cintesiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:22.4":{"pli":"‘netaṁ hessati orakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:23.1":{"pli":"Yathā ime janā sabbe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:23.2":{"pli":"sakkaronti tathāgataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:23.3":{"pli":"Ahampi kāraṁ kassāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:23.4":{"pli":"sasaṅghe lokanāyake’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:24.1":{"pli":"Tadāhamevaṁ cintetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:24.2":{"pli":"dadhiṁ madhuñca ekato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:24.3":{"pli":"Madditvā lokanāthassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:24.4":{"pli":"sasaṅghassa adāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:25.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:25.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:25.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:25.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:26.1":{"pli":"Punāhaṁ bārāṇasiyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:26.2":{"pli":"rājā hutvā mahāyaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:26.3":{"pli":"Sattukassa tadā duṭṭho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:26.4":{"pli":"dvārarodhamakārayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:27.1":{"pli":"Tadā tapassino ruddhā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:27.2":{"pli":"ekāhaṁ rakkhitā ahuṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:27.3":{"pli":"Tato tassa vipākena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:27.4":{"pli":"pāpatiṁ nirayaṁ bhusaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:28.1":{"pli":"Pacchime ca bhave dāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:28.2":{"pli":"jātohaṁ koliye pure; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:28.3":{"pli":"Suppavāsā ca me mātā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:28.4":{"pli":"mahāli licchavī pitā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:29.1":{"pli":"Khattiye puññakammena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:29.2":{"pli":"dvārarodhassa vāhasā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:29.3":{"pli":"Satta vassāni nivasiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:29.4":{"pli":"mātukucchimhi dukkhito. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:30.1":{"pli":"Sattāhaṁ dvāramūḷhohaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:30.2":{"pli":"mahādukkhasamappito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:30.3":{"pli":"Mātā me chandadānena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:30.4":{"pli":"evaṁ āsi sudukkhitā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:31.1":{"pli":"Suvatthitohaṁ nikkhanto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:31.2":{"pli":"buddhena anukampito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:31.3":{"pli":"Nikkhantadivaseyeva, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:31.4":{"pli":"pabbajiṁ anagāriyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:32.1":{"pli":"Upajjhā sāriputto me, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:32.2":{"pli":"moggallāno mahiddhiko; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:32.3":{"pli":"Kese oropayanto me, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:32.4":{"pli":"anusāsi mahāmati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:33.1":{"pli":"Kesesu chijjamānesu, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:33.2":{"pli":"arahattamapāpuṇiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:33.3":{"pli":"Devā nāgā manussā ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:33.4":{"pli":"paccaye upanenti me. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:34.1":{"pli":"Padumuttaranāthañca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:34.2":{"pli":"vipassiñca vināyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:34.3":{"pli":"Yaṁ pūjayiṁ pamudito, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:34.4":{"pli":"paccayehi visesato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:35.1":{"pli":"Tato tesaṁ visesena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:35.2":{"pli":"kammānaṁ vipuluttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:35.3":{"pli":"Lābhaṁ labhāmi sabbattha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:35.4":{"pli":"vane gāme jale thale. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:36.1":{"pli":"Revataṁ dassanatthāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:36.2":{"pli":"yadā yāti vināyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:36.3":{"pli":"Tiṁsabhikkhusahassehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:36.4":{"pli":"saha lokagganāyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:37.1":{"pli":"Tadā devopaṇītehi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:37.2":{"pli":"mamatthāya mahāmati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:37.3":{"pli":"Paccayehi mahāvīro, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:37.4":{"pli":"sasaṅgho lokanāyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:38.1":{"pli":"Upaṭṭhito mayā buddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:38.2":{"pli":"gantvā revatamaddasa; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:38.3":{"pli":"Tato jetavanaṁ gantvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:38.4":{"pli":"etadagge ṭhapesi maṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:39.1":{"pli":"‘Lābhīnaṁ sīvali aggo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:39.2":{"pli":"mama sissesu bhikkhavo’; ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:39.3":{"pli":"Sabbalokahito satthā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:39.4":{"pli":"kittayī parisāsu maṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:40.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:40.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:40.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:41.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:41.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:41.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap545:42.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap545:42.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap545:42.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap545:43.1":{"pli":"Itthaṁ sudaṁ āyasmā sīvalithero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap545:44.1":{"pli":"Sīvalittherassāpadānaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap546":{"tha-ap546:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap546'><header><ul><li class='division'>{}</li>"},"tha-ap546:0.2":{"pli":"Bhaddiyavagga ","html":"<li>{}</li></ul>"},"tha-ap546:0.3":{"pli":"Vaṅgīsattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap546:1.1":{"pli":"“Padumuttaro nāma jino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap546:1.2":{"pli":"sabbadhammesu cakkhumā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:1.3":{"pli":"Ito satasahassamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:1.4":{"pli":"kappe uppajji nāyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:2.1":{"pli":"Yathāpi sāgare ūmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:2.2":{"pli":"gagane viya tārakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:2.3":{"pli":"Evaṁ pāvacanaṁ tassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:2.4":{"pli":"arahantehi cittitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:3.1":{"pli":"Sadevāsuranāgehi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:3.2":{"pli":"manujehi purakkhato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:3.3":{"pli":"Samaṇabrāhmaṇākiṇṇe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:3.4":{"pli":"janamajjhe jinuttamo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:4.1":{"pli":"Pabhāhi anurañjanto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:4.2":{"pli":"loke lokantagū jino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:4.3":{"pli":"Vacanena vibodhento, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:4.4":{"pli":"veneyyapadumāni so. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:5.1":{"pli":"Vesārajjehi sampanno, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:5.2":{"pli":"catūhi purisuttamo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:5.3":{"pli":"Pahīnabhayasārajjo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:5.4":{"pli":"khemappatto visārado. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:6.1":{"pli":"Āsabhaṁ pavaraṁ ṭhānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:6.2":{"pli":"buddhabhūmiñca kevalaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:6.3":{"pli":"Paṭijānāti lokaggo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:6.4":{"pli":"natthi sañcodako kvaci. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:7.1":{"pli":"Sīhanādamasambhītaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:7.2":{"pli":"nadato tassa tādino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:7.3":{"pli":"Devo naro vā brahmā vā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:7.4":{"pli":"paṭivattā na vijjati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:8.1":{"pli":"Desento pavaraṁ dhammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:8.2":{"pli":"santārento sadevakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:8.3":{"pli":"Dhammacakkaṁ pavatteti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:8.4":{"pli":"parisāsu visārado. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:9.1":{"pli":"Paṭibhānavataṁ aggaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:9.2":{"pli":"sāvakaṁ sādhusammataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:9.3":{"pli":"Guṇaṁ bahuṁ pakittetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:9.4":{"pli":"etadagge ṭhapesi taṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:10.1":{"pli":"Tadāhaṁ haṁsavatiyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:10.2":{"pli":"brāhmaṇo sādhusammato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:10.3":{"pli":"Sabbavedavidū jāto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:10.4":{"pli":"vāgīso vādisūdano. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:11.1":{"pli":"Upecca taṁ mahāvīraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:11.2":{"pli":"sutvāhaṁ dhammadesanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:11.3":{"pli":"Pītivaraṁ paṭilabhiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:11.4":{"pli":"sāvakassa guṇe rato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:12.1":{"pli":"Nimantetvāva sugataṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:12.2":{"pli":"sasaṅghaṁ lokanandanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:12.3":{"pli":"Sattāhaṁ bhojayitvāhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:12.4":{"pli":"dussehacchādayiṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:13.1":{"pli":"Nipacca sirasā pāde, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:13.2":{"pli":"katokāso katañjalī; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:13.3":{"pli":"Ekamantaṁ ṭhito haṭṭho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:13.4":{"pli":"santhaviṁ jinamuttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:14.1":{"pli":"‘Namo te vādimaddana, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:14.2":{"pli":"namo te isisattama; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:14.3":{"pli":"Namo te sabbalokagga, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:14.4":{"pli":"namo te abhayaṁ kara. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:15.1":{"pli":"Namo te māramathana, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:15.2":{"pli":"namo te diṭṭhisūdana; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:15.3":{"pli":"Namo te santisukhada, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:15.4":{"pli":"namo te saraṇaṁ kara. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:16.1":{"pli":"Anāthānaṁ bhavaṁ nātho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:16.2":{"pli":"bhītānaṁ abhayappado; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:16.3":{"pli":"Vissāmabhūmi santānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:16.4":{"pli":"saraṇaṁ saraṇesinaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:17.1":{"pli":"Evamādīhi sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:17.2":{"pli":"santhavitvā mahāguṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:17.3":{"pli":"Avocaṁ vādisūdassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:17.4":{"pli":"gatiṁ pappomi bhikkhuno. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:18.1":{"pli":"Tadā avoca bhagavā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:18.2":{"pli":"anantapaṭibhānavā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:18.3":{"pli":"‘Yo so buddhaṁ abhojesi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:18.4":{"pli":"sattāhaṁ sahasāvakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:19.1":{"pli":"Guṇañca me pakittesi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:19.2":{"pli":"pasanno sehi pāṇibhi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:19.3":{"pli":"Eso patthayate ṭhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:19.4":{"pli":"vādisūdassa bhikkhuno. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:20.1":{"pli":"Anāgatamhi addhāne, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:20.2":{"pli":"lacchase taṁ manorathaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:20.3":{"pli":"Devamānusasampattiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:20.4":{"pli":"anubhotvā anappakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:21.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:21.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:21.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:21.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:22.1":{"pli":"Tassa dhammesu dāyādo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:22.2":{"pli":"oraso dhammanimmito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:22.3":{"pli":"Vaṅgīso nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:22.4":{"pli":"hessati satthu sāvako’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:23.1":{"pli":"Taṁ sutvā mudito hutvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:23.2":{"pli":"yāvajīvaṁ tadā jinaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:23.3":{"pli":"Paccayehi upaṭṭhāsiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:23.4":{"pli":"mettacitto tathāgataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:24.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:24.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:24.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:24.4":{"pli":"tusitaṁ agamāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:25.1":{"pli":"Pacchime ca bhave dāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:25.2":{"pli":"jāto vippakule ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:25.3":{"pli":"Paccājāto yadā āsiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:25.4":{"pli":"jātiyā sattavassiko. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:26.1":{"pli":"Sabbavedavidū jāto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:26.2":{"pli":"vādasatthavisārado; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:26.3":{"pli":"Vādissaro cittakathī, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:26.4":{"pli":"paravādappamaddano. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:27.1":{"pli":"Vaṅge jātoti vaṅgīso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:27.2":{"pli":"vacane issaroti vā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:27.3":{"pli":"Vaṅgīso iti me nāmaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:27.4":{"pli":"abhavī lokasammataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:28.1":{"pli":"Yadāhaṁ viññutaṁ patto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:28.2":{"pli":"ṭhito paṭhamayobbane; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:28.3":{"pli":"Tadā rājagahe ramme, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:28.4":{"pli":"sāriputtamahaddasaṁ. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap546:29.1":{"pli":"Pañcavīsatimaṁ bhāṇavāraṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap546:30.1":{"pli":"Piṇḍāya vicarantaṁ taṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap546:30.2":{"pli":"pattapāṇiṁ susaṁvutaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:30.3":{"pli":"Alolakkhiṁ mitabhāṇiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:30.4":{"pli":"yugamattaṁ nidakkhitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:31.1":{"pli":"Taṁ disvā vimhito hutvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:31.2":{"pli":"avocaṁ mamanucchavaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:31.3":{"pli":"Kaṇikāraṁva nicitaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:31.4":{"pli":"cittaṁ gāthāpadaṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:32.1":{"pli":"Ācikkhi so me satthāraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:32.2":{"pli":"sambuddhaṁ lokanāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:32.3":{"pli":"Tadā so paṇḍito vīro, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:32.4":{"pli":"uttariṁ samavoca me. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:33.1":{"pli":"Virāgasaṁhitaṁ vākyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:33.2":{"pli":"katvā duddasamuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:33.3":{"pli":"Vicittapaṭibhānehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:33.4":{"pli":"tosito tena tādinā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:34.1":{"pli":"Nipacca sirasā pāde, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:34.2":{"pli":"‘pabbājehī’ti maṁ bravi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:34.3":{"pli":"Tato maṁ sa mahāpañño, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:34.4":{"pli":"buddhaseṭṭhamupānayi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:35.1":{"pli":"Nipacca sirasā pāde, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:35.2":{"pli":"nisīdiṁ satthu santike; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:35.3":{"pli":"Mamāha vadataṁ seṭṭho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:35.4":{"pli":"‘kacci vaṅgīsa jānāsi’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:36.1":{"pli":"Kiñci sippanti tassāhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:36.2":{"pli":"‘jānāmī’ti ca abraviṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:36.3":{"pli":"‘Matasīsaṁ vanacchuddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:36.4":{"pli":"api bārasavassikaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:36.5":{"pli":"Tava vijjāvisesena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:36.6":{"pli":"sace sakkosi vācaya’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:37.1":{"pli":"‘Āmoti me paṭiññāte, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:37.2":{"pli":"tīṇi sīsāni dassayi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:37.3":{"pli":"Nirayanaradevesu, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:37.4":{"pli":"upapanne avācayiṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:38.1":{"pli":"Tadā khīṇāsavasseva, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:38.2":{"pli":"sīsaṁ dassesi nāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:38.3":{"pli":"Tatohaṁ vihatārambho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:38.4":{"pli":"pabbajjaṁ samayācisaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:39.1":{"pli":"Pabbajitvāna sugataṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:39.2":{"pli":"santhavāmi tahiṁ tahiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:39.3":{"pli":"Tato maṁ kabbavittosi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:39.4":{"pli":"ujjhāyantiha bhikkhavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:40.1":{"pli":"Tato vīmaṁsanatthaṁ me, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:40.2":{"pli":"āha buddho vināyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:40.3":{"pli":"‘Takkikā panimā gāthā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:40.4":{"pli":"ṭhānaso paṭibhanti taṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:41.1":{"pli":"‘Na kabbavittohaṁ vīra, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:41.2":{"pli":"ṭhānaso paṭibhanti maṁ’; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:41.3":{"pli":"‘Tena hi dāni vaṅgīsa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:41.4":{"pli":"ṭhānaso santhavāhi maṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:42.1":{"pli":"Tadāhaṁ santhaviṁ vīraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:42.2":{"pli":"gāthāhi isisattamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:42.3":{"pli":"Ṭhānaso me tadā tuṭṭho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:42.4":{"pli":"jino agge ṭhapesi maṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:43.1":{"pli":"Paṭibhānena cittena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:43.2":{"pli":"aññesamatimaññahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:43.3":{"pli":"Pesale tena saṁviggo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:43.4":{"pli":"arahattamapāpuṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:44.1":{"pli":"‘Paṭibhānavataṁ aggo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:44.2":{"pli":"añño koci na vijjati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:44.3":{"pli":"Yathāyaṁ bhikkhu vaṅgīso, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:44.4":{"pli":"evaṁ dhāretha bhikkhavo’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:45.1":{"pli":"Satasahasse kataṁ kammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:45.2":{"pli":"phalaṁ dassesi me idha; ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:45.3":{"pli":"Sumutto saravegova, ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:45.4":{"pli":"kilese jhāpayiṁ mama. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:46.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:46.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:46.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:47.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:47.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:47.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap546:48.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap546:48.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap546:48.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap546:49.1":{"pli":"Itthaṁ sudaṁ āyasmā vaṅgīso thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap546:50.1":{"pli":"Vaṅgīsattherassāpadānaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap547":{"tha-ap547:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap547'><header><ul><li class='division'>{}</li>"},"tha-ap547:0.2":{"pli":"Bhaddiyavagga ","html":"<li>{}</li></ul>"},"tha-ap547:0.3":{"pli":"Nandakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap547:1.1":{"pli":"“Padumuttaro nāma jino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap547:1.2":{"pli":"sabbadhammesu cakkhumā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:1.3":{"pli":"Ito satasahassamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:1.4":{"pli":"kappe uppajji nāyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap547:2.1":{"pli":"Hitāya sabbasattānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap547:2.2":{"pli":"sukhāya vadataṁ varo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:2.3":{"pli":"Atthāya purisājañño, ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:2.4":{"pli":"paṭipanno sadevake. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap547:3.1":{"pli":"Yasaggapatto sirimā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap547:3.2":{"pli":"kittivaṇṇabhato jino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:3.3":{"pli":"Pūjito sabbalokassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:3.4":{"pli":"disā sabbāsu vissuto. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap547:4.1":{"pli":"Uttiṇṇavicikiccho so, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap547:4.2":{"pli":"vītivattakathaṅkatho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:4.3":{"pli":"Paripuṇṇamanasaṅkappo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:4.4":{"pli":"patto sambodhimuttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap547:5.1":{"pli":"Anuppannassa maggassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap547:5.2":{"pli":"uppādetā naruttamo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:5.3":{"pli":"Anakkhātañca akkhāsi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:5.4":{"pli":"asañjātañca sañjanī. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap547:6.1":{"pli":"Maggaññū maggavidū ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap547:6.2":{"pli":"maggakkhāyī narāsabho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:6.3":{"pli":"Maggassa kusalo satthā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:6.4":{"pli":"sārathīnaṁ varuttamo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap547:7.1":{"pli":"Tadā mahākāruṇiko, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap547:7.2":{"pli":"dhammaṁ desesi nāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:7.3":{"pli":"Nimugge kāmapaṅkamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:7.4":{"pli":"samuddharati pāṇine. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap547:8.1":{"pli":"Bhikkhunīnaṁ ovadane, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap547:8.2":{"pli":"sāvakaṁ seṭṭhasammataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:8.3":{"pli":"Vaṇṇayaṁ etadaggamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:8.4":{"pli":"paññapesi mahāmuni. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap547:9.1":{"pli":"Taṁ sutvāhaṁ pamudito, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap547:9.2":{"pli":"nimantetvā tathāgataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:9.3":{"pli":"Bhojayitvā sasaṅghaṁ taṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:9.4":{"pli":"patthayiṁ ṭhānamuttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap547:10.1":{"pli":"Tadā pamudito nātho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap547:10.2":{"pli":"maṁ avoca mahāisi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:10.3":{"pli":"‘Sukhī bhavassu dīghāvu, ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:10.4":{"pli":"lacchase taṁ manorathaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap547:11.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap547:11.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:11.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:11.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap547:12.1":{"pli":"Tassa dhammesu dāyādo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap547:12.2":{"pli":"oraso dhammanimmito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:12.3":{"pli":"Nandako nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:12.4":{"pli":"hessati satthu sāvako’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap547:13.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap547:13.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:13.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:13.4":{"pli":"tāvatiṁsūpago ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap547:14.1":{"pli":"Pacchime ca bhave dāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap547:14.2":{"pli":"jāto seṭṭhikule ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:14.3":{"pli":"Sāvatthiyaṁ pure vare, ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:14.4":{"pli":"iddhe phīte mahaddhane. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap547:15.1":{"pli":"Purappavese sugataṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap547:15.2":{"pli":"disvā vimhitamānaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:15.3":{"pli":"Jetārāmapaṭiggāhe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:15.4":{"pli":"pabbajiṁ anagāriyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap547:16.1":{"pli":"Nacireneva kālena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap547:16.2":{"pli":"arahattamapāpuṇiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:16.3":{"pli":"Tatohaṁ tiṇṇasaṁsāro, ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:16.4":{"pli":"sāsito sabbadassinā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap547:17.1":{"pli":"Bhikkhunīnaṁ dhammakathaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap547:17.2":{"pli":"paṭipucchākariṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:17.3":{"pli":"Sāsitā tā mayā sabbā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:17.4":{"pli":"abhaviṁsu anāsavā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap547:18.1":{"pli":"Satāni pañcanūnāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap547:18.2":{"pli":"tadā tuṭṭho mahāhito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:18.3":{"pli":"Bhikkhunīnaṁ ovadataṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:18.4":{"pli":"aggaṭṭhāne ṭhapesi maṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap547:19.1":{"pli":"Satasahasse kataṁ kammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap547:19.2":{"pli":"phalaṁ dassesi me idha; ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:19.3":{"pli":"Sumutto saravegova, ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:19.4":{"pli":"kilese jhāpayiṁ mama. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap547:20.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap547:20.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:20.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap547:21.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap547:21.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:21.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap547:22.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap547:22.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap547:22.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap547:23.1":{"pli":"Itthaṁ sudaṁ āyasmā nandako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap547:24.1":{"pli":"Nandakattherassāpadānaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}