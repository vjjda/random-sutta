{"ja530":{"ja530:0.1":{"pli":"Jātaka ","html":"<article id='ja530'><header><ul><li class='division'>{}</li>"},"ja530:0.2":{"pli":"Saṭṭhinipāta ","html":"<li>{}</li>"},"ja530:0.3":{"pli":"Soṇakavagga ","html":"<li>{}</li></ul>"},"ja530:0.4":{"pli":"2. Saṅkiccajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja530:1.1":{"pli":"Disvā nisinnaṁ rājānaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja530:1.2":{"pli":"brahmadattaṁ rathesabhaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja530:1.3":{"pli":"Athassa paṭivedesi, ","html":"<span class='verse-line'>{}</span>"},"ja530:1.4":{"pli":"“yassāsi anukampako. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:2.1":{"pli":"Saṅkiccāyaṁ anuppatto, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:2.2":{"pli":"isīnaṁ sādhusammato; ","html":"<span class='verse-line'>{}</span>"},"ja530:2.3":{"pli":"Taramānarūpo niyyāhi, ","html":"<span class='verse-line'>{}</span>"},"ja530:2.4":{"pli":"khippaṁ passa mahesinaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:3.1":{"pli":"Tato ca rājā taramāno, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:3.2":{"pli":"yuttamāruyha sandanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja530:3.3":{"pli":"Mittāmaccaparibyūḷho, ","html":"<span class='verse-line'>{}</span>"},"ja530:3.4":{"pli":"agamāsi rathesabho. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:4.1":{"pli":"Nikkhippa pañca kakudhāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:4.2":{"pli":"kāsīnaṁ raṭṭhavaḍḍhano; ","html":"<span class='verse-line'>{}</span>"},"ja530:4.3":{"pli":"Vālabījanimuṇhīsaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja530:4.4":{"pli":"khaggaṁ chattañcupāhanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:5.1":{"pli":"Oruyha rājā yānamhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:5.2":{"pli":"ṭhapayitvā paṭicchadaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja530:5.3":{"pli":"Āsīnaṁ dāyapassasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja530:5.4":{"pli":"saṅkiccamupasaṅkami. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:6.1":{"pli":"Upasaṅkamitvā so rājā, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:6.2":{"pli":"sammodi isinā saha; ","html":"<span class='verse-line'>{}</span>"},"ja530:6.3":{"pli":"Taṁ kathaṁ vītisāretvā, ","html":"<span class='verse-line'>{}</span>"},"ja530:6.4":{"pli":"ekamantaṁ upāvisi. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:7.1":{"pli":"Ekamantaṁ nisinnova, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:7.2":{"pli":"atha kālaṁ amaññatha; ","html":"<span class='verse-line'>{}</span>"},"ja530:7.3":{"pli":"Tato pāpāni kammāni, ","html":"<span class='verse-line'>{}</span>"},"ja530:7.4":{"pli":"pucchituṁ paṭipajjatha. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:8.1":{"pli":"“Isiṁ pucchāma saṅkiccaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:8.2":{"pli":"isīnaṁ sādhusammataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja530:8.3":{"pli":"Āsīnaṁ dāyapassasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja530:8.4":{"pli":"isisaṅghapurakkhataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:9.1":{"pli":"Kaṁ gatiṁ pecca gacchanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:9.2":{"pli":"narā dhammāticārino; ","html":"<span class='verse-line'>{}</span>"},"ja530:9.3":{"pli":"Aticiṇṇo mayā dhammo, ","html":"<span class='verse-line'>{}</span>"},"ja530:9.4":{"pli":"taṁ me akkhāhi pucchito”. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:10.1":{"pli":"Isī avaca saṅkicco, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:10.2":{"pli":"kāsīnaṁ raṭṭhavaḍḍhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja530:10.3":{"pli":"Āsīnaṁ dāyapassasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja530:10.4":{"pli":"“mahārāja suṇohi me. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:11.1":{"pli":"Uppathena vajantassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:11.2":{"pli":"yo maggamanusāsati; ","html":"<span class='verse-line'>{}</span>"},"ja530:11.3":{"pli":"Tassa ce vacanaṁ kayirā, ","html":"<span class='verse-line'>{}</span>"},"ja530:11.4":{"pli":"nāssa maggeyya kaṇṭako. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:12.1":{"pli":"Adhammaṁ paṭipannassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:12.2":{"pli":"yo dhammamanusāsati; ","html":"<span class='verse-line'>{}</span>"},"ja530:12.3":{"pli":"Tassa ce vacanaṁ kayirā, ","html":"<span class='verse-line'>{}</span>"},"ja530:12.4":{"pli":"na so gaccheyya duggatiṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:13.1":{"pli":"“Dhammo patho mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:13.2":{"pli":"adhammo pana uppatho; ","html":"<span class='verse-line'>{}</span>"},"ja530:13.3":{"pli":"Adhammo nirayaṁ neti, ","html":"<span class='verse-line'>{}</span>"},"ja530:13.4":{"pli":"dhammo pāpeti suggatiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:14.1":{"pli":"Adhammacārino rāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:14.2":{"pli":"narā visamajīvino; ","html":"<span class='verse-line'>{}</span>"},"ja530:14.3":{"pli":"Yaṁ gatiṁ pecca gacchanti, ","html":"<span class='verse-line'>{}</span>"},"ja530:14.4":{"pli":"niraye te suṇohi me. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:15.1":{"pli":"Sañjīvo kāḷasutto ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:15.2":{"pli":"saṅghāto dve ca roruvā; ","html":"<span class='verse-line'>{}</span>"},"ja530:15.3":{"pli":"Athāparo mahāvīci, ","html":"<span class='verse-line'>{}</span>"},"ja530:15.4":{"pli":"tāpano ca patāpano. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:16.1":{"pli":"Iccete aṭṭha nirayā, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:16.2":{"pli":"akkhātā duratikkamā; ","html":"<span class='verse-line'>{}</span>"},"ja530:16.3":{"pli":"Ākiṇṇā luddakammehi, ","html":"<span class='verse-line'>{}</span>"},"ja530:16.4":{"pli":"paccekā soḷasussadā. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:17.1":{"pli":"Kadariyatāpanā ghorā, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:17.2":{"pli":"accimanto mahabbhayā; ","html":"<span class='verse-line'>{}</span>"},"ja530:17.3":{"pli":"Lomahaṁsanarūpā ca, ","html":"<span class='verse-line'>{}</span>"},"ja530:17.4":{"pli":"bhesmā paṭibhayā dukhā. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:18.1":{"pli":"Catukkaṇṇā catudvārā, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:18.2":{"pli":"vibhattā bhāgaso mitā; ","html":"<span class='verse-line'>{}</span>"},"ja530:18.3":{"pli":"Ayopākārapariyantā, ","html":"<span class='verse-line'>{}</span>"},"ja530:18.4":{"pli":"ayasā paṭikujjitā. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:19.1":{"pli":"Tesaṁ ayomayā bhūmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:19.2":{"pli":"jalitā tejasā yutā; ","html":"<span class='verse-line'>{}</span>"},"ja530:19.3":{"pli":"Samantā yojanasataṁ, ","html":"<span class='verse-line'>{}</span>"},"ja530:19.4":{"pli":"phuṭā tiṭṭhanti sabbadā. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:20.1":{"pli":"Ete patanti niraye, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:20.2":{"pli":"uddhampādā avaṁsirā; ","html":"<span class='verse-line'>{}</span>"},"ja530:20.3":{"pli":"Isīnaṁ ativattāro, ","html":"<span class='verse-line'>{}</span>"},"ja530:20.4":{"pli":"saññatānaṁ tapassinaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:21.1":{"pli":"Te bhūnahuno paccanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:21.2":{"pli":"macchā bilakatā yathā; ","html":"<span class='verse-line'>{}</span>"},"ja530:21.3":{"pli":"Saṁvacchare asaṅkheyye, ","html":"<span class='verse-line'>{}</span>"},"ja530:21.4":{"pli":"narā kibbisakārino. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:22.1":{"pli":"Ḍayhamānena gattena, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:22.2":{"pli":"niccaṁ santarabāhiraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja530:22.3":{"pli":"Nirayā nādhigacchanti, ","html":"<span class='verse-line'>{}</span>"},"ja530:22.4":{"pli":"dvāraṁ nikkhamanesino. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:23.1":{"pli":"Puratthimena dhāvanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:23.2":{"pli":"tato dhāvanti pacchato; ","html":"<span class='verse-line'>{}</span>"},"ja530:23.3":{"pli":"Uttarenapi dhāvanti, ","html":"<span class='verse-line'>{}</span>"},"ja530:23.4":{"pli":"tato dhāvanti dakkhiṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja530:23.5":{"pli":"Yaṁ yañhi dvāraṁ gacchanti, ","html":"<span class='verse-line'>{}</span>"},"ja530:23.6":{"pli":"taṁ tadeva pidhīyare. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:24.1":{"pli":"Bahūni vassasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:24.2":{"pli":"janā nirayagāmino; ","html":"<span class='verse-line'>{}</span>"},"ja530:24.3":{"pli":"Bāhā paggayha kandanti, ","html":"<span class='verse-line'>{}</span>"},"ja530:24.4":{"pli":"patvā dukkhaṁ anappakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:25.1":{"pli":"Āsīvisaṁva kupitaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:25.2":{"pli":"tejassiṁ duratikkamaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja530:25.3":{"pli":"Na sādhurūpe āsīde, ","html":"<span class='verse-line'>{}</span>"},"ja530:25.4":{"pli":"saññatānaṁ tapassinaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:26.1":{"pli":"Atikāyo mahissāso, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:26.2":{"pli":"ajjuno kekakādhipo; ","html":"<span class='verse-line'>{}</span>"},"ja530:26.3":{"pli":"Sahassabāhu ucchinno, ","html":"<span class='verse-line'>{}</span>"},"ja530:26.4":{"pli":"isimāsajja gotamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:27.1":{"pli":"Arajaṁ rajasā vacchaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:27.2":{"pli":"Kisaṁ avakiriya daṇḍakī; ","html":"<span class='verse-line'>{}</span>"},"ja530:27.3":{"pli":"Tālova mūlato chinno, ","html":"<span class='verse-line'>{}</span>"},"ja530:27.4":{"pli":"Sa rājā vibhavaṅgato. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:28.1":{"pli":"Upahacca manaṁ majjho, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:28.2":{"pli":"mātaṅgasmiṁ yasassine; ","html":"<span class='verse-line'>{}</span>"},"ja530:28.3":{"pli":"Sapārisajjo ucchinno, ","html":"<span class='verse-line'>{}</span>"},"ja530:28.4":{"pli":"majjhāraññaṁ tadā ahu. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:29.1":{"pli":"Kaṇhadīpāyanāsajja, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:29.2":{"pli":"Isiṁ andhakaveṇḍayo; ","html":"<span class='verse-line'>{}</span>"},"ja530:29.3":{"pli":"Aññoññaṁ musalā hantvā, ","html":"<span class='verse-line'>{}</span>"},"ja530:29.4":{"pli":"Sampattā yamasādhanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:30.1":{"pli":"Athāyaṁ isinā satto, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:30.2":{"pli":"antalikkhacaro pure; ","html":"<span class='verse-line'>{}</span>"},"ja530:30.3":{"pli":"Pāvekkhi pathaviṁ cecco, ","html":"<span class='verse-line'>{}</span>"},"ja530:30.4":{"pli":"hīnatto pattapariyāyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:31.1":{"pli":"Tasmā hi chandāgamanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:31.2":{"pli":"nappasaṁsanti paṇḍitā; ","html":"<span class='verse-line'>{}</span>"},"ja530:31.3":{"pli":"Aduṭṭhacitto bhāseyya, ","html":"<span class='verse-line'>{}</span>"},"ja530:31.4":{"pli":"giraṁ saccūpasaṁhitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:32.1":{"pli":"Manasā ce paduṭṭhena, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:32.2":{"pli":"yo naro pekkhate muniṁ; ","html":"<span class='verse-line'>{}</span>"},"ja530:32.3":{"pli":"Vijjācaraṇasampannaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja530:32.4":{"pli":"gantā so nirayaṁ adho. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:33.1":{"pli":"Ye vuḍḍhe paribhāsanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:33.2":{"pli":"pharusūpakkamā janā; ","html":"<span class='verse-line'>{}</span>"},"ja530:33.3":{"pli":"Anapaccā adāyādā, ","html":"<span class='verse-line'>{}</span>"},"ja530:33.4":{"pli":"tālavatthu bhavanti te. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:34.1":{"pli":"Yo ca pabbajitaṁ hanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:34.2":{"pli":"katakiccaṁ mahesinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja530:34.3":{"pli":"Sa kāḷasutte niraye, ","html":"<span class='verse-line'>{}</span>"},"ja530:34.4":{"pli":"cirarattāya paccati. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:35.1":{"pli":"Yo ca rājā adhammaṭṭho, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:35.2":{"pli":"raṭṭhaviddhaṁsano mago; ","html":"<span class='verse-line'>{}</span>"},"ja530:35.3":{"pli":"Tāpayitvā janapadaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja530:35.4":{"pli":"tāpane pecca paccati. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:36.1":{"pli":"So ca vassasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:36.2":{"pli":"sataṁ dibbāni paccati; ","html":"<span class='verse-line'>{}</span>"},"ja530:36.3":{"pli":"Accisaṅghapareto so, ","html":"<span class='verse-line'>{}</span>"},"ja530:36.4":{"pli":"dukkhaṁ vedeti vedanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:37.1":{"pli":"Tassa aggisikhā kāyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:37.2":{"pli":"niccharanti pabhassarā; ","html":"<span class='verse-line'>{}</span>"},"ja530:37.3":{"pli":"Tejobhakkhassa gattāni, ","html":"<span class='verse-line'>{}</span>"},"ja530:37.4":{"pli":"lomehi ca nakhehi ca. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:38.1":{"pli":"Ḍayhamānena gattena, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:38.2":{"pli":"niccaṁ santarabāhiraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja530:38.3":{"pli":"Dukkhābhitunno nadati, ","html":"<span class='verse-line'>{}</span>"},"ja530:38.4":{"pli":"nāgo tuttaṭṭito yathā. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:39.1":{"pli":"Yo lobhā pitaraṁ hanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:39.2":{"pli":"dosā vā purisādhamo; ","html":"<span class='verse-line'>{}</span>"},"ja530:39.3":{"pli":"Sa kāḷasutte niraye, ","html":"<span class='verse-line'>{}</span>"},"ja530:39.4":{"pli":"cirarattāya paccati. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:40.1":{"pli":"Sa tādiso paccati lohakumbhiyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:40.2":{"pli":"Pakkañca sattīhi hananti nittacaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja530:40.3":{"pli":"Andhaṁ karitvā muttakarīsabhakkhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja530:40.4":{"pli":"Khāre nimujjanti tathāvidhaṁ naraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:41.1":{"pli":"Tattaṁ pakkuthitamayoguḷañca, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:41.2":{"pli":"Dīghe ca phāle cirarattatāpite; ","html":"<span class='verse-line'>{}</span>"},"ja530:41.3":{"pli":"Vikkhambhamādāya vibandharajjubhi, ","html":"<span class='verse-line'>{}</span>"},"ja530:41.4":{"pli":"Vivaṭe mukhe sampavisanti rakkhasā. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:42.1":{"pli":"Sāmā ca soṇā sabalā ca gijjhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:42.2":{"pli":"Kākoḷasaṅghā ca dijā ayomukhā; ","html":"<span class='verse-line'>{}</span>"},"ja530:42.3":{"pli":"Saṅgamma khādanti vipphandamānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja530:42.4":{"pli":"Jivhaṁ vibhajja vighāsaṁ salohitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:43.1":{"pli":"Taṁ daḍḍhatālaṁ paribhinnagattaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:43.2":{"pli":"Nippothayantā anuvicaranti rakkhasā; ","html":"<span class='verse-line'>{}</span>"},"ja530:43.3":{"pli":"Ratī hi nesaṁ dukhino panītare, ","html":"<span class='verse-line'>{}</span>"},"ja530:43.4":{"pli":"Etādisasmiṁ niraye vasanti; ","html":"<span class='verse-line'>{}</span>"},"ja530:43.5":{"pli":"Ye keci loke idha pettighātino. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:44.1":{"pli":"Putto ca mātaraṁ hantvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:44.2":{"pli":"ito gantvā yamakkhayaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja530:44.3":{"pli":"Bhusamāpajjate dukkhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja530:44.4":{"pli":"attakammaphalūpago. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:45.1":{"pli":"Amanussā atibalā, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:45.2":{"pli":"hantāraṁ janayantiyā; ","html":"<span class='verse-line'>{}</span>"},"ja530:45.3":{"pli":"Ayomayehi vālehi, ","html":"<span class='verse-line'>{}</span>"},"ja530:45.4":{"pli":"pīḷayanti punappunaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:46.1":{"pli":"Tamassavaṁ sakā gattā, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:46.2":{"pli":"rudhiraṁ attasambhavaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja530:46.3":{"pli":"Tambalohavilīnaṁva, ","html":"<span class='verse-line'>{}</span>"},"ja530:46.4":{"pli":"tattaṁ pāyenti mattighaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:47.1":{"pli":"Jigucchaṁ kuṇapaṁ pūtiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:47.2":{"pli":"Duggandhaṁ gūthakaddamaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja530:47.3":{"pli":"Pubbalohitasaṅkāsaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja530:47.4":{"pli":"Rahadamogayha tiṭṭhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:48.1":{"pli":"Tamenaṁ kimayo tattha, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:48.2":{"pli":"atikāyā ayomukhā; ","html":"<span class='verse-line'>{}</span>"},"ja530:48.3":{"pli":"Chaviṁ bhetvāna khādanti, ","html":"<span class='verse-line'>{}</span>"},"ja530:48.4":{"pli":"saṅgiddhā maṁsalohite. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:49.1":{"pli":"So ca taṁ nirayaṁ patto, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:49.2":{"pli":"nimuggo sataporisaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja530:49.3":{"pli":"Pūtikaṁ kuṇapaṁ vāti, ","html":"<span class='verse-line'>{}</span>"},"ja530:49.4":{"pli":"samantā satayojanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:50.1":{"pli":"Cakkhumāpi hi cakkhūhi, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:50.2":{"pli":"tena gandhena jīyati; ","html":"<span class='verse-line'>{}</span>"},"ja530:50.3":{"pli":"Etādisaṁ brahmadatta, ","html":"<span class='verse-line'>{}</span>"},"ja530:50.4":{"pli":"mātugho labhate dukhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:51.1":{"pli":"Khuradhāramanukkamma, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:51.2":{"pli":"tikkhaṁ durabhisambhavaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja530:51.3":{"pli":"Patanti gabbhapātiyo, ","html":"<span class='verse-line'>{}</span>"},"ja530:51.4":{"pli":"duggaṁ vetaraṇiṁ nadiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:52.1":{"pli":"Ayomayā simbaliyo, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:52.2":{"pli":"soḷasaṅgulakaṇṭakā; ","html":"<span class='verse-line'>{}</span>"},"ja530:52.3":{"pli":"Ubhato abhilambanti, ","html":"<span class='verse-line'>{}</span>"},"ja530:52.4":{"pli":"duggaṁ vetaraṇiṁ nadiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:53.1":{"pli":"Te accimanto tiṭṭhanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:53.2":{"pli":"aggikkhandhāva ārakā; ","html":"<span class='verse-line'>{}</span>"},"ja530:53.3":{"pli":"Ādittā jātavedena, ","html":"<span class='verse-line'>{}</span>"},"ja530:53.4":{"pli":"uddhaṁ yojanamuggatā. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:54.1":{"pli":"Ete vajanti niraye, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:54.2":{"pli":"tatte tikhiṇakaṇṭake; ","html":"<span class='verse-line'>{}</span>"},"ja530:54.3":{"pli":"Nāriyo ca aticārā, ","html":"<span class='verse-line'>{}</span>"},"ja530:54.4":{"pli":"narā ca paradāragū. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:55.1":{"pli":"Te patanti adhokkhandhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:55.2":{"pli":"vivattā vihatā puthū; ","html":"<span class='verse-line'>{}</span>"},"ja530:55.3":{"pli":"Sayanti vinividdhaṅgā, ","html":"<span class='verse-line'>{}</span>"},"ja530:55.4":{"pli":"dīghaṁ jagganti sabbadā. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:56.1":{"pli":"Tato ratyā vivasāne, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:56.2":{"pli":"mahatiṁ pabbatūpamaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja530:56.3":{"pli":"Lohakumbhiṁ pavajjanti, ","html":"<span class='verse-line'>{}</span>"},"ja530:56.4":{"pli":"tattaṁ aggisamūdakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:57.1":{"pli":"Evaṁ divā ca ratto ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:57.2":{"pli":"dussīlā mohapārutā; ","html":"<span class='verse-line'>{}</span>"},"ja530:57.3":{"pli":"Anubhonti sakaṁ kammaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja530:57.4":{"pli":"pubbe dukkaṭamattano. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:58.1":{"pli":"Yā ca bhariyā dhanakkītā, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:58.2":{"pli":"sāmikaṁ atimaññati; ","html":"<span class='verse-line'>{}</span>"},"ja530:58.3":{"pli":"Sassuṁ vā sasuraṁ vāpi, ","html":"<span class='verse-line'>{}</span>"},"ja530:58.4":{"pli":"jeṭṭhaṁ vāpi nanandaraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:59.1":{"pli":"Tassā vaṅkena jivhaggaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:59.2":{"pli":"nibbahanti sabandhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja530:59.3":{"pli":"Sa byāmamattaṁ kiminaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja530:59.4":{"pli":"jivhaṁ passati attani; ","html":"<span class='verse-line'>{}</span>"},"ja530:59.5":{"pli":"Viññāpetuṁ na sakkoti, ","html":"<span class='verse-line'>{}</span>"},"ja530:59.6":{"pli":"tāpane pecca paccati. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:60.1":{"pli":"Orabbhikā sūkarikā, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:60.2":{"pli":"macchikā migabandhakā; ","html":"<span class='verse-line'>{}</span>"},"ja530:60.3":{"pli":"Corā goghātakā luddā, ","html":"<span class='verse-line'>{}</span>"},"ja530:60.4":{"pli":"avaṇṇe vaṇṇakārakā. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:61.1":{"pli":"Sattīhi lohakūṭehi, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:61.2":{"pli":"nettiṁsehi usūhi ca; ","html":"<span class='verse-line'>{}</span>"},"ja530:61.3":{"pli":"Haññamānā khāranadiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja530:61.4":{"pli":"papatanti avaṁsirā. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:62.1":{"pli":"Sāyaṁ pāto kūṭakārī, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:62.2":{"pli":"ayokūṭehi haññati; ","html":"<span class='verse-line'>{}</span>"},"ja530:62.3":{"pli":"Tato vantaṁ durattānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja530:62.4":{"pli":"paresaṁ bhuñjare sadā. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:63.1":{"pli":"Dhaṅkā bheraṇḍakā gijjhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:63.2":{"pli":"kākoḷā ca ayomukhā; ","html":"<span class='verse-line'>{}</span>"},"ja530:63.3":{"pli":"Vipphandamānaṁ khādanti, ","html":"<span class='verse-line'>{}</span>"},"ja530:63.4":{"pli":"naraṁ kibbisakārakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:64.1":{"pli":"Ye migena migaṁ hanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:64.2":{"pli":"pakkhiṁ vā pana pakkhinā; ","html":"<span class='verse-line'>{}</span>"},"ja530:64.3":{"pli":"Asanto rajasā channā, ","html":"<span class='verse-line'>{}</span>"},"ja530:64.4":{"pli":"gantā te nirayussadaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:65.1":{"pli":"Santo ca uddhaṁ gacchanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:65.2":{"pli":"suciṇṇenidha kammunā; ","html":"<span class='verse-line'>{}</span>"},"ja530:65.3":{"pli":"Suciṇṇassa phalaṁ passa, ","html":"<span class='verse-line'>{}</span>"},"ja530:65.4":{"pli":"saindā devā sabrahmakā. ","html":"<span class='verse-line'>{}</span></p>"},"ja530:66.1":{"pli":"Taṁ taṁ brūmi mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja530:66.2":{"pli":"Dhammaṁ raṭṭhapatī cara; ","html":"<span class='verse-line'>{}</span>"},"ja530:66.3":{"pli":"Tathā rāja carāhi dhammaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja530:66.4":{"pli":"Yathā taṁ suciṇṇaṁ nānutappeyya pacchā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja530:67.1":{"pli":"Saṅkiccajātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja530:68.1":{"pli":"Saṭṭhinipātaṁ niṭṭhitaṁ. ","html":"<p class='endsection'>{}</p>"},"ja530:69.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja530:70.1":{"pli":"Atha saṭṭhinipātamhi, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja530:70.2":{"pli":"Suṇātha mama bhāsitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja530:70.3":{"pli":"Jātakasavhayano pavaro, ","html":"<span class='verse-line'>{}</span>"},"ja530:70.4":{"pli":"Soṇakaarindamasavhayano; ","html":"<span class='verse-line'>{}</span>"},"ja530:70.5":{"pli":"Tathā vuttarathesabhakiccavaroti. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}}}