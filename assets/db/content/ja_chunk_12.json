{"ja394":{"ja394:0.1":{"pli":"Jātaka ","html":"<article id='ja394'><header><ul><li class='division'>{}</li>"},"ja394:0.2":{"pli":"Chakkanipāta ","html":"<li>{}</li>"},"ja394:0.3":{"pli":"Kharaputtavagga ","html":"<li>{}</li></ul>"},"ja394:0.4":{"pli":"9. Vaṭṭakajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja394:1.1":{"pli":"“Paṇītaṁ bhuñjase bhattaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja394:1.2":{"pli":"sappitelañca mātula; ","html":"<span class='verse-line'>{}</span>"},"ja394:1.3":{"pli":"Atha kena nu vaṇṇena, ","html":"<span class='verse-line'>{}</span>"},"ja394:1.4":{"pli":"kiso tvamasi vāyasa”. ","html":"<span class='verse-line'>{}</span></p>"},"ja394:2.1":{"pli":"“Amittamajjhe vasato, ","html":"<p><span class='verse-line'>{}</span>"},"ja394:2.2":{"pli":"tesu āmisamesato; ","html":"<span class='verse-line'>{}</span>"},"ja394:2.3":{"pli":"Niccaṁ ubbiggahadayassa, ","html":"<span class='verse-line'>{}</span>"},"ja394:2.4":{"pli":"kuto kākassa daḷhiyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja394:3.1":{"pli":"Niccaṁ ubbegino kākā, ","html":"<p><span class='verse-line'>{}</span>"},"ja394:3.2":{"pli":"dhaṅkā pāpena kammunā; ","html":"<span class='verse-line'>{}</span>"},"ja394:3.3":{"pli":"Laddho piṇḍo na pīṇeti, ","html":"<span class='verse-line'>{}</span>"},"ja394:3.4":{"pli":"kiso tenasmi vaṭṭaka. ","html":"<span class='verse-line'>{}</span></p>"},"ja394:4.1":{"pli":"Lūkhāni tiṇabījāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja394:4.2":{"pli":"appasnehāni bhuñjasi; ","html":"<span class='verse-line'>{}</span>"},"ja394:4.3":{"pli":"Atha kena nu vaṇṇena, ","html":"<span class='verse-line'>{}</span>"},"ja394:4.4":{"pli":"thūlo tvamasi vaṭṭaka”. ","html":"<span class='verse-line'>{}</span></p>"},"ja394:5.1":{"pli":"“Appicchā appacintāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja394:5.2":{"pli":"adūragamanena ca; ","html":"<span class='verse-line'>{}</span>"},"ja394:5.3":{"pli":"Laddhāladdhena yāpento, ","html":"<span class='verse-line'>{}</span>"},"ja394:5.4":{"pli":"thūlo tenasmi vāyasa. ","html":"<span class='verse-line'>{}</span></p>"},"ja394:6.1":{"pli":"Appicchassa hi posassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja394:6.2":{"pli":"appacintasukhassa ca; ","html":"<span class='verse-line'>{}</span>"},"ja394:6.3":{"pli":"Susaṅgahitamānassa, ","html":"<span class='verse-line'>{}</span>"},"ja394:6.4":{"pli":"vuttī susamudānayā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja394:7.1":{"pli":"Vaṭṭakajātakaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja395":{"ja395:0.1":{"pli":"Jātaka ","html":"<article id='ja395'><header><ul><li class='division'>{}</li>"},"ja395:0.2":{"pli":"Chakkanipāta ","html":"<li>{}</li>"},"ja395:0.3":{"pli":"Kharaputtavagga ","html":"<li>{}</li></ul>"},"ja395:0.4":{"pli":"10. Pārāvatajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja395:1.1":{"pli":"“Cirassaṁ vata passāmi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja395:1.2":{"pli":"sahāyaṁ maṇidhārinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja395:1.3":{"pli":"Sukatā massukuttiyā, ","html":"<span class='verse-line'>{}</span>"},"ja395:1.4":{"pli":"sobhate vata me sakhā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja395:2.1":{"pli":"“Parūḷhakacchanakhalomo, ","html":"<p><span class='verse-line'>{}</span>"},"ja395:2.2":{"pli":"ahaṁ kammesu byāvaṭo; ","html":"<span class='verse-line'>{}</span>"},"ja395:2.3":{"pli":"Cirassaṁ nhāpitaṁ laddhā, ","html":"<span class='verse-line'>{}</span>"},"ja395:2.4":{"pli":"lomaṁ taṁ ajja hārayiṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja395:3.1":{"pli":"“Yannu lomaṁ ahāresi, ","html":"<p><span class='verse-line'>{}</span>"},"ja395:3.2":{"pli":"dullabhaṁ laddha kappakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja395:3.3":{"pli":"Atha kiñcarahi te samma, ","html":"<span class='verse-line'>{}</span>"},"ja395:3.4":{"pli":"kaṇṭhe kiṇikiṇāyati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja395:4.1":{"pli":"“Manussasukhumālānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja395:4.2":{"pli":"maṇi kaṇṭhesu lambati; ","html":"<span class='verse-line'>{}</span>"},"ja395:4.3":{"pli":"Tesāhaṁ anusikkhāmi, ","html":"<span class='verse-line'>{}</span>"},"ja395:4.4":{"pli":"mā tvaṁ maññi davā kataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja395:5.1":{"pli":"Sacepimaṁ pihayasi, ","html":"<p><span class='verse-line'>{}</span>"},"ja395:5.2":{"pli":"massukuttiṁ sukāritaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja395:5.3":{"pli":"Kārayissāmi te samma, ","html":"<span class='verse-line'>{}</span>"},"ja395:5.4":{"pli":"maṇiñcāpi dadāmi te”. ","html":"<span class='verse-line'>{}</span></p>"},"ja395:6.1":{"pli":"“Tvaññeva maṇinā channo, ","html":"<p><span class='verse-line'>{}</span>"},"ja395:6.2":{"pli":"Sukatāya ca massuyā; ","html":"<span class='verse-line'>{}</span>"},"ja395:6.3":{"pli":"Āmanta kho taṁ gacchāmi, ","html":"<span class='verse-line'>{}</span>"},"ja395:6.4":{"pli":"Piyaṁ me tavadassanan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja395:7.1":{"pli":"Pārāvatajātakaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja395:7.2":{"pli":"Kharaputtavaggo dutiyo. ","html":"<p class='endvagga'>{}</p>"},"ja395:8.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja395:9.1":{"pli":"Atha passa sasūci ca tuṇḍilako, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja395:9.2":{"pli":"Miga mayhakapañcamapakkhivaro; ","html":"<span class='verse-line'>{}</span>"},"ja395:9.3":{"pli":"Atha pañjali vārija mejjha puna, ","html":"<span class='verse-line'>{}</span>"},"ja395:9.4":{"pli":"Atha vaṭṭa kapotavarena dasāti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja395:10.1":{"pli":"Atha vagguddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja395:11.1":{"pli":"Atha vaggaṁ pakittissaṁ, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja395:11.2":{"pli":"chanipātaṁ varuttame; ","html":"<span class='verse-line'>{}</span>"},"ja395:11.3":{"pli":"Avāriyā ca kharo ca, ","html":"<span class='verse-line'>{}</span>"},"ja395:11.4":{"pli":"dve ca vuttā subyañjanāti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja395:12.1":{"pli":"Chakkanipātaṁ niṭṭhitaṁ. ","html":"<p class='endsection'>{}</p></article>"}},"ja396":{"ja396:0.1":{"pli":"Jātaka ","html":"<article id='ja396'><header><ul><li class='division'>{}</li>"},"ja396:0.2":{"pli":"Sattakanipāta ","html":"<li>{}</li>"},"ja396:0.3":{"pli":"Kukkuvagga ","html":"<li>{}</li></ul>"},"ja396:0.4":{"pli":"1. Kukkujātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja396:1.1":{"pli":"“Diyaḍḍhakukkū udayena kaṇṇikā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja396:1.2":{"pli":"Vidatthiyo aṭṭha parikkhipanti naṁ; ","html":"<span class='verse-line'>{}</span>"},"ja396:1.3":{"pli":"Sā siṁsapā sāramayā apheggukā, ","html":"<span class='verse-line'>{}</span>"},"ja396:1.4":{"pli":"Kuhiṁ ṭhitā upparito na dhaṁsati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja396:2.1":{"pli":"“Yā tiṁsati sāramayā anujjukā, ","html":"<p><span class='verse-line'>{}</span>"},"ja396:2.2":{"pli":"Parikiriya gopānasiyo samaṁ ṭhitā; ","html":"<span class='verse-line'>{}</span>"},"ja396:2.3":{"pli":"Tāhi susaṅgahitā balasā pīḷitā, ","html":"<span class='verse-line'>{}</span>"},"ja396:2.4":{"pli":"Samaṁ ṭhitā upparito na dhaṁsati. ","html":"<span class='verse-line'>{}</span></p>"},"ja396:3.1":{"pli":"Evampi mittehi daḷhehi paṇḍito, ","html":"<p><span class='verse-line'>{}</span>"},"ja396:3.2":{"pli":"Abhejjarūpehi sucīhi mantibhi; ","html":"<span class='verse-line'>{}</span>"},"ja396:3.3":{"pli":"Susaṅgahīto siriyā na dhaṁsati, ","html":"<span class='verse-line'>{}</span>"},"ja396:3.4":{"pli":"Gopānasī bhāravahāva kaṇṇikā. ","html":"<span class='verse-line'>{}</span></p>"},"ja396:4.1":{"pli":"Kharattacaṁ bellaṁ yathāpi satthavā, ","html":"<p><span class='verse-line'>{}</span>"},"ja396:4.2":{"pli":"Anāmasantopi karoti tittakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja396:4.3":{"pli":"Samāharaṁ sāduṁ karoti patthiva, ","html":"<span class='verse-line'>{}</span>"},"ja396:4.4":{"pli":"Asāduṁ kayirā tanubandhamuddharaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja396:5.1":{"pli":"Evampi gāmanigamesu paṇḍito, ","html":"<p><span class='verse-line'>{}</span>"},"ja396:5.2":{"pli":"Asāhasaṁ rājadhanāni saṅgharaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja396:5.3":{"pli":"Dhammānuvattī paṭipajjamāno, ","html":"<span class='verse-line'>{}</span>"},"ja396:5.4":{"pli":"Sa phāti kayirā aviheṭhayaṁ paraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja396:6.1":{"pli":"Odātamūlaṁ sucivārisambhavaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja396:6.2":{"pli":"Jātaṁ yathā pokkharaṇīsu ambujaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja396:6.3":{"pli":"Padumaṁ yathā agginikāsiphālimaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja396:6.4":{"pli":"Na kaddamo na rajo na vāri limpati. ","html":"<span class='verse-line'>{}</span></p>"},"ja396:7.1":{"pli":"Evampi vohārasuciṁ asāhasaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja396:7.2":{"pli":"Visuddhakammantamapetapāpakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja396:7.3":{"pli":"Na limpati kammakilesa tādiso, ","html":"<span class='verse-line'>{}</span>"},"ja396:7.4":{"pli":"Jātaṁ yathā pokkharaṇīsu ambujan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja396:8.1":{"pli":"Kukkujātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja397":{"ja397:0.1":{"pli":"Jātaka ","html":"<article id='ja397'><header><ul><li class='division'>{}</li>"},"ja397:0.2":{"pli":"Sattakanipāta ","html":"<li>{}</li>"},"ja397:0.3":{"pli":"Kukkuvagga ","html":"<li>{}</li></ul>"},"ja397:0.4":{"pli":"2. Manojajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja397:1.1":{"pli":"“Yathā cāpo ninnamati, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja397:1.2":{"pli":"jiyā cāpi nikūjati; ","html":"<span class='verse-line'>{}</span>"},"ja397:1.3":{"pli":"Haññate nūna manojo, ","html":"<span class='verse-line'>{}</span>"},"ja397:1.4":{"pli":"migarājā sakhā mama. ","html":"<span class='verse-line'>{}</span></p>"},"ja397:2.1":{"pli":"Handa dāni vanantāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja397:2.2":{"pli":"pakkamāmi yathāsukhaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja397:2.3":{"pli":"Netādisā sakhā honti, ","html":"<span class='verse-line'>{}</span>"},"ja397:2.4":{"pli":"labbhā me jīvato sakhā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja397:3.1":{"pli":"“Na pāpajanasaṁsevī, ","html":"<p><span class='verse-line'>{}</span>"},"ja397:3.2":{"pli":"accantaṁ sukhamedhati; ","html":"<span class='verse-line'>{}</span>"},"ja397:3.3":{"pli":"Manojaṁ passa semānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja397:3.4":{"pli":"giriyassānusāsanī”. ","html":"<span class='verse-line'>{}</span></p>"},"ja397:4.1":{"pli":"“Na pāpasampavaṅkena, ","html":"<p><span class='verse-line'>{}</span>"},"ja397:4.2":{"pli":"mātā puttena nandati; ","html":"<span class='verse-line'>{}</span>"},"ja397:4.3":{"pli":"Manojaṁ passa semānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja397:4.4":{"pli":"acchannaṁ samhi lohite”. ","html":"<span class='verse-line'>{}</span></p>"},"ja397:5.1":{"pli":"“Evamāpajjate poso, ","html":"<p><span class='verse-line'>{}</span>"},"ja397:5.2":{"pli":"pāpiyo ca nigacchati; ","html":"<span class='verse-line'>{}</span>"},"ja397:5.3":{"pli":"Yo ve hitānaṁ vacanaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja397:5.4":{"pli":"na karoti atthadassinaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja397:6.1":{"pli":"“Evañca so hoti tato ca pāpiyo, ","html":"<p><span class='verse-line'>{}</span>"},"ja397:6.2":{"pli":"Yo uttamo adhamajanūpasevī; ","html":"<span class='verse-line'>{}</span>"},"ja397:6.3":{"pli":"Passuttamaṁ adhamajanūpasevitaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja397:6.4":{"pli":"Migādhipaṁ saravaraveganiddhutaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja397:7.1":{"pli":"“Nihīyati puriso nihīnasevī, ","html":"<p><span class='verse-line'>{}</span>"},"ja397:7.2":{"pli":"Na ca hāyetha kadāci tulyasevī; ","html":"<span class='verse-line'>{}</span>"},"ja397:7.3":{"pli":"Seṭṭhamupagamaṁ udeti khippaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja397:7.4":{"pli":"Tasmāttanā uttaritaraṁ bhajethā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja397:8.1":{"pli":"Manojajātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja398":{"ja398:0.1":{"pli":"Jātaka ","html":"<article id='ja398'><header><ul><li class='division'>{}</li>"},"ja398:0.2":{"pli":"Sattakanipāta ","html":"<li>{}</li>"},"ja398:0.3":{"pli":"Kukkuvagga ","html":"<li>{}</li></ul>"},"ja398:0.4":{"pli":"3. Sutanujātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja398:1.1":{"pli":"“Rājā te bhattaṁ pāhesi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja398:1.2":{"pli":"Suciṁ maṁsūpasecanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja398:1.3":{"pli":"Maghadevasmiṁ adhivatthe, ","html":"<span class='verse-line'>{}</span>"},"ja398:1.4":{"pli":"Ehi nikkhamma bhuñjasu”. ","html":"<span class='verse-line'>{}</span></p>"},"ja398:2.1":{"pli":"“Ehi māṇava orena, ","html":"<p><span class='verse-line'>{}</span>"},"ja398:2.2":{"pli":"bhikkhamādāya sūpitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja398:2.3":{"pli":"Tvañca māṇava bhikkhā ca, ","html":"<span class='verse-line'>{}</span>"},"ja398:2.4":{"pli":"ubho bhakkhā bhavissatha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja398:3.1":{"pli":"“Appakena tuvaṁ yakkha, ","html":"<p><span class='verse-line'>{}</span>"},"ja398:3.2":{"pli":"thullamatthaṁ jahissasi; ","html":"<span class='verse-line'>{}</span>"},"ja398:3.3":{"pli":"Bhikkhaṁ te nāharissanti, ","html":"<span class='verse-line'>{}</span>"},"ja398:3.4":{"pli":"janā maraṇasaññino. ","html":"<span class='verse-line'>{}</span></p>"},"ja398:4.1":{"pli":"Laddhāya yakkhā tava niccabhikkhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja398:4.2":{"pli":"Suciṁ paṇītaṁ rasasā upetaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja398:4.3":{"pli":"Bhikkhañca te āhariyo naro idha, ","html":"<span class='verse-line'>{}</span>"},"ja398:4.4":{"pli":"Sudullabho hehiti bhakkhite mayi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja398:5.1":{"pli":"“Mameva sutano attho, ","html":"<p><span class='verse-line'>{}</span>"},"ja398:5.2":{"pli":"yathā bhāsasi māṇava; ","html":"<span class='verse-line'>{}</span>"},"ja398:5.3":{"pli":"Mayā tvaṁ samanuññāto, ","html":"<span class='verse-line'>{}</span>"},"ja398:5.4":{"pli":"sotthiṁ passāhi mātaraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja398:6.1":{"pli":"Khaggaṁ chattañca pātiñca, ","html":"<p><span class='verse-line'>{}</span>"},"ja398:6.2":{"pli":"gacchamādāya māṇava; ","html":"<span class='verse-line'>{}</span>"},"ja398:6.3":{"pli":"Sotthiṁ passatu te mātā, ","html":"<span class='verse-line'>{}</span>"},"ja398:6.4":{"pli":"tvañca passāhi mātaraṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja398:7.1":{"pli":"“Evaṁ yakkha sukhī hohi, ","html":"<p><span class='verse-line'>{}</span>"},"ja398:7.2":{"pli":"saha sabbehi ñātibhi; ","html":"<span class='verse-line'>{}</span>"},"ja398:7.3":{"pli":"Dhanañca me adhigataṁ, ","html":"<span class='verse-line'>{}</span>"},"ja398:7.4":{"pli":"rañño ca vacanaṁ katan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja398:8.1":{"pli":"Sutanujātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja399":{"ja399:0.1":{"pli":"Jātaka ","html":"<article id='ja399'><header><ul><li class='division'>{}</li>"},"ja399:0.2":{"pli":"Sattakanipāta ","html":"<li>{}</li>"},"ja399:0.3":{"pli":"Kukkuvagga ","html":"<li>{}</li></ul>"},"ja399:0.4":{"pli":"4. Mātuposakagijjhajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja399:1.1":{"pli":"“Te kathaṁ nu karissanti, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja399:1.2":{"pli":"vuddhā giridarīsayā; ","html":"<span class='verse-line'>{}</span>"},"ja399:1.3":{"pli":"Ahaṁ baddhosmi pāsena, ","html":"<span class='verse-line'>{}</span>"},"ja399:1.4":{"pli":"nilīyassa vasaṁ gato”. ","html":"<span class='verse-line'>{}</span></p>"},"ja399:2.1":{"pli":"“Kiṁ gijjha paridevasi, ","html":"<p><span class='verse-line'>{}</span>"},"ja399:2.2":{"pli":"kā nu te paridevanā; ","html":"<span class='verse-line'>{}</span>"},"ja399:2.3":{"pli":"Na me suto vā diṭṭho vā, ","html":"<span class='verse-line'>{}</span>"},"ja399:2.4":{"pli":"bhāsanto mānusiṁ dijo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja399:3.1":{"pli":"“Bharāmi mātāpitaro, ","html":"<p><span class='verse-line'>{}</span>"},"ja399:3.2":{"pli":"vuddhe giridarīsaye; ","html":"<span class='verse-line'>{}</span>"},"ja399:3.3":{"pli":"Te kathaṁ nu karissanti, ","html":"<span class='verse-line'>{}</span>"},"ja399:3.4":{"pli":"ahaṁ vasaṁ gato tava”. ","html":"<span class='verse-line'>{}</span></p>"},"ja399:4.1":{"pli":"“Yannu gijjho yojanasataṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja399:4.2":{"pli":"kuṇapāni avekkhati; ","html":"<span class='verse-line'>{}</span>"},"ja399:4.3":{"pli":"Kasmā jālañca pāsañca, ","html":"<span class='verse-line'>{}</span>"},"ja399:4.4":{"pli":"āsajjāpi na bujjhasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja399:5.1":{"pli":"“Yadā parābhavo hoti, ","html":"<p><span class='verse-line'>{}</span>"},"ja399:5.2":{"pli":"poso jīvitasaṅkhaye; ","html":"<span class='verse-line'>{}</span>"},"ja399:5.3":{"pli":"Atha jālañca pāsañca, ","html":"<span class='verse-line'>{}</span>"},"ja399:5.4":{"pli":"āsajjāpi na bujjhati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja399:6.1":{"pli":"“Bharassu mātāpitaro, ","html":"<p><span class='verse-line'>{}</span>"},"ja399:6.2":{"pli":"vuddhe giridarīsaye; ","html":"<span class='verse-line'>{}</span>"},"ja399:6.3":{"pli":"Mayā tvaṁ samanuññāto, ","html":"<span class='verse-line'>{}</span>"},"ja399:6.4":{"pli":"sotthiṁ passāhi ñātake”. ","html":"<span class='verse-line'>{}</span></p>"},"ja399:7.1":{"pli":"“Evaṁ luddaka nandassu, ","html":"<p><span class='verse-line'>{}</span>"},"ja399:7.2":{"pli":"saha sabbehi ñātibhi; ","html":"<span class='verse-line'>{}</span>"},"ja399:7.3":{"pli":"Bharissaṁ mātāpitaro, ","html":"<span class='verse-line'>{}</span>"},"ja399:7.4":{"pli":"vuddhe giridarīsaye”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja399:8.1":{"pli":"Mātuposakagijjhajātakaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja4":{"ja4:0.1":{"pli":"Jātaka ","eng":"Stories of Past Lives 4 ","html":"<article id='ja4'><header><ul><li class='division'>{}</li>"},"ja4:0.2":{"pli":"Ekakanipāta ","eng":"The Book of the Ones ","html":"<li>{}</li>"},"ja4:0.3":{"pli":"Apaṇṇakavagga ","eng":"Unfailing ","html":"<li>{}</li></ul>"},"ja4:0.4":{"pli":"4. Cūḷaseṭṭhijātaka ","eng":"The Little Financier: a past life story ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja4:1.1":{"pli":"“Appakenapi medhāvī, ","eng":"Even with a little capital ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>","comm":"The prose story tells of an enterprising young man who started his business by trading a dead mouse for a penny as cat food. This concept can be taken as a precursor for the modern concept of microfinance. "},"ja4:1.2":{"pli":"pābhatena vicakkhaṇo; ","eng":"the intelligent and clear-seeing man ","html":"<span class='verse-line'>{}</span>"},"ja4:1.3":{"pli":"Samuṭṭhāpeti attānaṁ, ","eng":"uplifts himself, ","html":"<span class='verse-line'>{}</span>"},"ja4:1.4":{"pli":"aṇuṁ aggiṁva sandhaman”ti. ","eng":"like a tiny flame when fanned. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja4:2.1":{"pli":"Cūḷaseṭṭhijātakaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja40":{"ja40:0.1":{"pli":"Jātaka ","eng":"Stories of Past Lives 40 ","html":"<article id='ja40'><header><ul><li class='division'>{}</li>"},"ja40:0.2":{"pli":"Ekakanipāta ","eng":"The Book of the Ones ","html":"<li>{}</li>"},"ja40:0.3":{"pli":"Kulāvakavagga ","eng":"Nests ","html":"<li>{}</li></ul>"},"ja40:0.4":{"pli":"10. Khadiraṅgārajātaka ","eng":"The Pit of Acacia Coals: a past life story ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja40:1.1":{"pli":"“Kāmaṁ patāmi nirayaṁ, ","eng":"Fine, let me fall ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>","comm":"Māra, in order to prevent the Bodhisatta from giving alms to a Paccekabuddha, creates an illusion of a vast pit burning with coals of acacia wood. But the Bodhisatta is not intimidated. "},"ja40:1.2":{"pli":"uddhampādo avaṁsiro; ","eng":"head over heels into hell, ","html":"<span class='verse-line'>{}</span>"},"ja40:1.3":{"pli":"Nānariyaṁ karissāmi, ","eng":"but I shall not do what is ignoble. ","html":"<span class='verse-line'>{}</span>"},"ja40:1.4":{"pli":"handa piṇḍaṁ paṭiggahā”ti. ","eng":"Please accept my alms offering. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja40:2.1":{"pli":"Khadiraṅgārajātakaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja40:2.2":{"pli":"Kulāvakavaggo catuttho. ","html":"<p class='endvagga'>{}</p>"},"ja40:3.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja40:4.1":{"pli":"Sirimātali dhītara pakkhivaro, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja40:4.2":{"pli":"Ratiyāgato mātāpitā ca puna; ","html":"<span class='verse-line'>{}</span>"},"ja40:4.3":{"pli":"Jagatīruha vuḍḍha sukakkaṭako, ","html":"<span class='verse-line'>{}</span>"},"ja40:4.4":{"pli":"Tathā nandakapiṇḍavarena dasāti. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"ja400":{"ja400:0.1":{"pli":"Jātaka ","html":"<article id='ja400'><header><ul><li class='division'>{}</li>"},"ja400:0.2":{"pli":"Sattakanipāta ","html":"<li>{}</li>"},"ja400:0.3":{"pli":"Kukkuvagga ","html":"<li>{}</li></ul>"},"ja400:0.4":{"pli":"5. Dabbhapupphajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja400:1.1":{"pli":"“Anutīracārī bhaddante, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja400:1.2":{"pli":"sahāyamanudhāva maṁ; ","html":"<span class='verse-line'>{}</span>"},"ja400:1.3":{"pli":"Mahā me gahito maccho, ","html":"<span class='verse-line'>{}</span>"},"ja400:1.4":{"pli":"so maṁ harati vegasā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja400:2.1":{"pli":"“Gambhīracārī bhaddante, ","html":"<p><span class='verse-line'>{}</span>"},"ja400:2.2":{"pli":"daḷhaṁ gaṇhāhi thāmasā; ","html":"<span class='verse-line'>{}</span>"},"ja400:2.3":{"pli":"Ahaṁ taṁ uddharissāmi, ","html":"<span class='verse-line'>{}</span>"},"ja400:2.4":{"pli":"supaṇṇo uragāmiva”. ","html":"<span class='verse-line'>{}</span></p>"},"ja400:3.1":{"pli":"“Vivādo no samuppanno, ","html":"<p><span class='verse-line'>{}</span>"},"ja400:3.2":{"pli":"dabbhapuppha suṇohi me; ","html":"<span class='verse-line'>{}</span>"},"ja400:3.3":{"pli":"Samehi medhagaṁ samma, ","html":"<span class='verse-line'>{}</span>"},"ja400:3.4":{"pli":"vivādo vūpasammataṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja400:4.1":{"pli":"“Dhammaṭṭhohaṁ pure āsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja400:4.2":{"pli":"bahū aḍḍā me tīritā; ","html":"<span class='verse-line'>{}</span>"},"ja400:4.3":{"pli":"Samemi medhagaṁ samma, ","html":"<span class='verse-line'>{}</span>"},"ja400:4.4":{"pli":"vivādo vūpasammataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja400:5.1":{"pli":"Anutīracāri naṅguṭṭhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja400:5.2":{"pli":"sīsaṁ gambhīracārino; ","html":"<span class='verse-line'>{}</span>"},"ja400:5.3":{"pli":"Accāyaṁ majjhimo khaṇḍo, ","html":"<span class='verse-line'>{}</span>"},"ja400:5.4":{"pli":"dhammaṭṭhassa bhavissati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja400:6.1":{"pli":"“Cirampi bhakkho abhavissa, ","html":"<p><span class='verse-line'>{}</span>"},"ja400:6.2":{"pli":"sace na vivademase; ","html":"<span class='verse-line'>{}</span>"},"ja400:6.3":{"pli":"Asīsakaṁ anaṅguṭṭhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja400:6.4":{"pli":"siṅgālo harati rohitaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja400:7.1":{"pli":"“Yathāpi rājā nandeyya, ","html":"<p><span class='verse-line'>{}</span>"},"ja400:7.2":{"pli":"rajjaṁ laddhāna khattiyo; ","html":"<span class='verse-line'>{}</span>"},"ja400:7.3":{"pli":"Evāhamajja nandāmi, ","html":"<span class='verse-line'>{}</span>"},"ja400:7.4":{"pli":"disvā puṇṇamukhaṁ patiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja400:8.1":{"pli":"Kathaṁ nu thalajo santo, ","html":"<p><span class='verse-line'>{}</span>"},"ja400:8.2":{"pli":"udake macchaṁ parāmasi; ","html":"<span class='verse-line'>{}</span>"},"ja400:8.3":{"pli":"Puṭṭho me samma akkhāhi, ","html":"<span class='verse-line'>{}</span>"},"ja400:8.4":{"pli":"kathaṁ adhigataṁ tayā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja400:9.1":{"pli":"“Vivādena kisā honti, ","html":"<p><span class='verse-line'>{}</span>"},"ja400:9.2":{"pli":"vivādena dhanakkhayā; ","html":"<span class='verse-line'>{}</span>"},"ja400:9.3":{"pli":"Jīnā uddā vivādena, ","html":"<span class='verse-line'>{}</span>"},"ja400:9.4":{"pli":"bhuñja māyāvi rohitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja400:10.1":{"pli":"Evameva manussesu, ","html":"<p><span class='verse-line'>{}</span>"},"ja400:10.2":{"pli":"vivādo yattha jāyati; ","html":"<span class='verse-line'>{}</span>"},"ja400:10.3":{"pli":"Dhammaṭṭhaṁ paṭidhāvanti, ","html":"<span class='verse-line'>{}</span>"},"ja400:10.4":{"pli":"so hi nesaṁ vināyako; ","html":"<span class='verse-line'>{}</span>"},"ja400:10.5":{"pli":"Dhanāpi tattha jīyanti, ","html":"<span class='verse-line'>{}</span>"},"ja400:10.6":{"pli":"rājakoso pavaḍḍhatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja400:11.1":{"pli":"Dabbhapupphajātakaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja401":{"ja401:0.1":{"pli":"Jātaka ","html":"<article id='ja401'><header><ul><li class='division'>{}</li>"},"ja401:0.2":{"pli":"Sattakanipāta ","html":"<li>{}</li>"},"ja401:0.3":{"pli":"Kukkuvagga ","html":"<li>{}</li></ul>"},"ja401:0.4":{"pli":"6. Paṇṇakajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja401:1.1":{"pli":"“Paṇṇakaṁ tikhiṇadhāraṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja401:1.2":{"pli":"Asiṁ sampannapāyinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja401:1.3":{"pli":"Parisāyaṁ puriso gilati, ","html":"<span class='verse-line'>{}</span>"},"ja401:1.4":{"pli":"Kiṁ dukkarataraṁ tato; ","html":"<span class='verse-line'>{}</span>"},"ja401:1.5":{"pli":"Yadaññaṁ dukkaraṁ ṭhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja401:1.6":{"pli":"Taṁ me akkhāhi pucchito”. ","html":"<span class='verse-line'>{}</span></p>"},"ja401:2.1":{"pli":"“Gileyya puriso lobhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja401:2.2":{"pli":"asiṁ sampannapāyinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja401:2.3":{"pli":"Yo ca vajjā dadāmīti, ","html":"<span class='verse-line'>{}</span>"},"ja401:2.4":{"pli":"taṁ dukkarataraṁ tato; ","html":"<span class='verse-line'>{}</span>"},"ja401:2.5":{"pli":"Sabbaññaṁ sukaraṁ ṭhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja401:2.6":{"pli":"evaṁ jānāhi maddava”. ","html":"<span class='verse-line'>{}</span></p>"},"ja401:3.1":{"pli":"“Byākāsi āyuro pañhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja401:3.2":{"pli":"atthaṁ dhammassa kovido; ","html":"<span class='verse-line'>{}</span>"},"ja401:3.3":{"pli":"Pukkusaṁ dāni pucchāmi, ","html":"<span class='verse-line'>{}</span>"},"ja401:3.4":{"pli":"kiṁ dukkarataraṁ tato; ","html":"<span class='verse-line'>{}</span>"},"ja401:3.5":{"pli":"Yadaññaṁ dukkaraṁ ṭhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja401:3.6":{"pli":"taṁ me akkhāhi pucchito”. ","html":"<span class='verse-line'>{}</span></p>"},"ja401:4.1":{"pli":"“Na vācamupajīvanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja401:4.2":{"pli":"aphalaṁ giramudīritaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja401:4.3":{"pli":"Yo ca datvā avākayirā, ","html":"<span class='verse-line'>{}</span>"},"ja401:4.4":{"pli":"taṁ dukkarataraṁ tato; ","html":"<span class='verse-line'>{}</span>"},"ja401:4.5":{"pli":"Sabbaññaṁ sukaraṁ ṭhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja401:4.6":{"pli":"evaṁ jānāhi maddava”. ","html":"<span class='verse-line'>{}</span></p>"},"ja401:5.1":{"pli":"“Byākāsi pukkuso pañhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja401:5.2":{"pli":"atthaṁ dhammassa kovido; ","html":"<span class='verse-line'>{}</span>"},"ja401:5.3":{"pli":"Senakaṁ dāni pucchāmi, ","html":"<span class='verse-line'>{}</span>"},"ja401:5.4":{"pli":"kiṁ dukkarataraṁ tato; ","html":"<span class='verse-line'>{}</span>"},"ja401:5.5":{"pli":"Yadaññaṁ dukkaraṁ ṭhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja401:5.6":{"pli":"taṁ me akkhāhi pucchito”. ","html":"<span class='verse-line'>{}</span></p>"},"ja401:6.1":{"pli":"“Dadeyya puriso dānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja401:6.2":{"pli":"appaṁ vā yadi vā bahuṁ; ","html":"<span class='verse-line'>{}</span>"},"ja401:6.3":{"pli":"Yo ca datvā nānutappe, ","html":"<span class='verse-line'>{}</span>"},"ja401:6.4":{"pli":"taṁ dukkarataraṁ tato; ","html":"<span class='verse-line'>{}</span>"},"ja401:6.5":{"pli":"Sabbaññaṁ sukaraṁ ṭhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja401:6.6":{"pli":"evaṁ jānāhi maddava”. ","html":"<span class='verse-line'>{}</span></p>"},"ja401:7.1":{"pli":"“Byākāsi āyuro pañhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja401:7.2":{"pli":"atho pukkusaporiso; ","html":"<span class='verse-line'>{}</span>"},"ja401:7.3":{"pli":"Sabbe pañhe atibhoti, ","html":"<span class='verse-line'>{}</span>"},"ja401:7.4":{"pli":"yathā bhāsati senako”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja401:8.1":{"pli":"Paṇṇakajātakaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja402":{"ja402:0.1":{"pli":"Jātaka ","html":"<article id='ja402'><header><ul><li class='division'>{}</li>"},"ja402:0.2":{"pli":"Sattakanipāta ","html":"<li>{}</li>"},"ja402:0.3":{"pli":"Kukkuvagga ","html":"<li>{}</li></ul>"},"ja402:0.4":{"pli":"7. Sattubhastajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja402:1.1":{"pli":"“Vibbhantacitto kupitindriyosi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja402:1.2":{"pli":"Nettehi te vārigaṇā savanti; ","html":"<span class='verse-line'>{}</span>"},"ja402:1.3":{"pli":"Kiṁ te naṭṭhaṁ kiṁ pana patthayāno, ","html":"<span class='verse-line'>{}</span>"},"ja402:1.4":{"pli":"Idhāgamā brahme tadiṅgha brūhi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja402:2.1":{"pli":"“Miyyetha bhariyā vajato mamajja, ","html":"<p><span class='verse-line'>{}</span>"},"ja402:2.2":{"pli":"Agacchato maraṇamāha yakkho; ","html":"<span class='verse-line'>{}</span>"},"ja402:2.3":{"pli":"Etena dukkhena pavedhitosmi, ","html":"<span class='verse-line'>{}</span>"},"ja402:2.4":{"pli":"Akkhāhi me senaka etamatthaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja402:3.1":{"pli":"“Bahūni ṭhānāni vicintayitvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja402:3.2":{"pli":"Yamettha vakkhāmi tadeva saccaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja402:3.3":{"pli":"Maññāmi te brāhmaṇa sattubhastaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja402:3.4":{"pli":"Ajānato kaṇhasappo paviṭṭho. ","html":"<span class='verse-line'>{}</span></p>"},"ja402:4.1":{"pli":"Ādāya daṇḍaṁ parisumbha bhastaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja402:4.2":{"pli":"Passeḷamūgaṁ uragaṁ dujivhaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja402:4.3":{"pli":"Chindajja kaṅkhaṁ vicikicchitāni, ","html":"<span class='verse-line'>{}</span>"},"ja402:4.4":{"pli":"Bhujaṅgamaṁ passa pamuñca bhastaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja402:5.1":{"pli":"Saṁviggarūpo parisāya majjhe, ","html":"<p><span class='verse-line'>{}</span>"},"ja402:5.2":{"pli":"So brāhmaṇo sattubhastaṁ pamuñci; ","html":"<span class='verse-line'>{}</span>"},"ja402:5.3":{"pli":"Atha nikkhami urago uggatejo, ","html":"<span class='verse-line'>{}</span>"},"ja402:5.4":{"pli":"Āsīviso sappo phaṇaṁ karitvā. ","html":"<span class='verse-line'>{}</span></p>"},"ja402:6.1":{"pli":"“Suladdhalābhā janakassa rañño, ","html":"<p><span class='verse-line'>{}</span>"},"ja402:6.2":{"pli":"Yo passatī senakaṁ sādhupaññaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja402:6.3":{"pli":"Vivaṭṭachaddo nusi sabbadassī, ","html":"<span class='verse-line'>{}</span>"},"ja402:6.4":{"pli":"Ñāṇaṁ nu te brāhmaṇa bhiṁsarūpaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja402:7.1":{"pli":"“Imāni me sattasatāni atthi, ","html":"<p><span class='verse-line'>{}</span>"},"ja402:7.2":{"pli":"Gaṇhāhi sabbāni dadāmi tuyhaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja402:7.3":{"pli":"Tayā hi me jīvitamajja laddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja402:7.4":{"pli":"Athopi bhariyāya makāsi sotthiṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja402:8.1":{"pli":"“Na paṇḍitā vetanamādiyanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja402:8.2":{"pli":"Citrāhi gāthāhi subhāsitāhi; ","html":"<span class='verse-line'>{}</span>"},"ja402:8.3":{"pli":"Itopi te brahme dadantu vittaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja402:8.4":{"pli":"Ādāya tvaṁ gaccha sakaṁ niketan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja402:9.1":{"pli":"Sattubhastajātakaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja403":{"ja403:0.1":{"pli":"Jātaka ","html":"<article id='ja403'><header><ul><li class='division'>{}</li>"},"ja403:0.2":{"pli":"Sattakanipāta ","html":"<li>{}</li>"},"ja403:0.3":{"pli":"Kukkuvagga ","html":"<li>{}</li></ul>"},"ja403:0.4":{"pli":"8. Aṭṭhisenakajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja403:1.1":{"pli":"“Yeme ahaṁ na jānāmi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja403:1.2":{"pli":"aṭṭhisena vanibbake; ","html":"<span class='verse-line'>{}</span>"},"ja403:1.3":{"pli":"Te maṁ saṅgamma yācanti, ","html":"<span class='verse-line'>{}</span>"},"ja403:1.4":{"pli":"kasmā maṁ tvaṁ na yācasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja403:2.1":{"pli":"“Yācako appiyo hoti, ","html":"<p><span class='verse-line'>{}</span>"},"ja403:2.2":{"pli":"yācaṁ adadamappiyo; ","html":"<span class='verse-line'>{}</span>"},"ja403:2.3":{"pli":"Tasmāhaṁ taṁ na yācāmi, ","html":"<span class='verse-line'>{}</span>"},"ja403:2.4":{"pli":"mā me videssanā ahu”. ","html":"<span class='verse-line'>{}</span></p>"},"ja403:3.1":{"pli":"“Yo ve yācanajīvāno, ","html":"<p><span class='verse-line'>{}</span>"},"ja403:3.2":{"pli":"kāle yācaṁ na yācati; ","html":"<span class='verse-line'>{}</span>"},"ja403:3.3":{"pli":"Parañca puññā dhaṁseti, ","html":"<span class='verse-line'>{}</span>"},"ja403:3.4":{"pli":"attanāpi na jīvati. ","html":"<span class='verse-line'>{}</span></p>"},"ja403:4.1":{"pli":"Yo ca yācanajīvāno, ","html":"<p><span class='verse-line'>{}</span>"},"ja403:4.2":{"pli":"kāle yācañhi yācati; ","html":"<span class='verse-line'>{}</span>"},"ja403:4.3":{"pli":"Parañca puññaṁ labbheti, ","html":"<span class='verse-line'>{}</span>"},"ja403:4.4":{"pli":"attanāpi ca jīvati. ","html":"<span class='verse-line'>{}</span></p>"},"ja403:5.1":{"pli":"Na ve dessanti sappaññā, ","html":"<p><span class='verse-line'>{}</span>"},"ja403:5.2":{"pli":"Disvā yācakamāgate; ","html":"<span class='verse-line'>{}</span>"},"ja403:5.3":{"pli":"Brahmacāri piyo mesi, ","html":"<span class='verse-line'>{}</span>"},"ja403:5.4":{"pli":"Vada tvaṁ bhaññamicchasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja403:6.1":{"pli":"“Na ve yācanti sappaññā, ","html":"<p><span class='verse-line'>{}</span>"},"ja403:6.2":{"pli":"Dhīro ca veditumarahati; ","html":"<span class='verse-line'>{}</span>"},"ja403:6.3":{"pli":"Uddissa ariyā tiṭṭhanti, ","html":"<span class='verse-line'>{}</span>"},"ja403:6.4":{"pli":"Esā ariyāna yācanā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja403:7.1":{"pli":"“Dadāmi te brāhmaṇa rohiṇīnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja403:7.2":{"pli":"Gavaṁ sahassaṁ saha puṅgavena; ","html":"<span class='verse-line'>{}</span>"},"ja403:7.3":{"pli":"Ariyo hi ariyassa kathaṁ na dajjā, ","html":"<span class='verse-line'>{}</span>"},"ja403:7.4":{"pli":"Sutvāna gāthā tava dhammayuttā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja403:8.1":{"pli":"Aṭṭhisenakajātakaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja404":{"ja404:0.1":{"pli":"Jātaka ","html":"<article id='ja404'><header><ul><li class='division'>{}</li>"},"ja404:0.2":{"pli":"Sattakanipāta ","html":"<li>{}</li>"},"ja404:0.3":{"pli":"Kukkuvagga ","html":"<li>{}</li></ul>"},"ja404:0.4":{"pli":"9. Kapijātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja404:1.1":{"pli":"“Yattha verī nivasati, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja404:1.2":{"pli":"na vase tattha paṇḍito; ","html":"<span class='verse-line'>{}</span>"},"ja404:1.3":{"pli":"Ekarattaṁ dirattaṁ vā, ","html":"<span class='verse-line'>{}</span>"},"ja404:1.4":{"pli":"dukkhaṁ vasati verisu. ","html":"<span class='verse-line'>{}</span></p>"},"ja404:2.1":{"pli":"Diso ve lahucittassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja404:2.2":{"pli":"posassānuvidhīyato; ","html":"<span class='verse-line'>{}</span>"},"ja404:2.3":{"pli":"Ekassa kapino hetu, ","html":"<span class='verse-line'>{}</span>"},"ja404:2.4":{"pli":"yūthassa anayo kato. ","html":"<span class='verse-line'>{}</span></p>"},"ja404:3.1":{"pli":"Bālova paṇḍitamānī, ","html":"<p><span class='verse-line'>{}</span>"},"ja404:3.2":{"pli":"yūthassa parihārako; ","html":"<span class='verse-line'>{}</span>"},"ja404:3.3":{"pli":"Sacittassa vasaṁ gantvā, ","html":"<span class='verse-line'>{}</span>"},"ja404:3.4":{"pli":"sayethāyaṁ yathā kapi. ","html":"<span class='verse-line'>{}</span></p>"},"ja404:4.1":{"pli":"Na sādhu balavā bālo, ","html":"<p><span class='verse-line'>{}</span>"},"ja404:4.2":{"pli":"yūthassa parihārako; ","html":"<span class='verse-line'>{}</span>"},"ja404:4.3":{"pli":"Ahito bhavati ñātīnaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja404:4.4":{"pli":"sakuṇānaṁva cetako. ","html":"<span class='verse-line'>{}</span></p>"},"ja404:5.1":{"pli":"Dhīrova balavā sādhu, ","html":"<p><span class='verse-line'>{}</span>"},"ja404:5.2":{"pli":"yūthassa parihārako; ","html":"<span class='verse-line'>{}</span>"},"ja404:5.3":{"pli":"Hito bhavati ñātīnaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja404:5.4":{"pli":"tidasānaṁva vāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"ja404:6.1":{"pli":"Yo ca sīlañca paññañca, ","html":"<p><span class='verse-line'>{}</span>"},"ja404:6.2":{"pli":"sutañcattani passati; ","html":"<span class='verse-line'>{}</span>"},"ja404:6.3":{"pli":"Ubhinnamatthaṁ carati, ","html":"<span class='verse-line'>{}</span>"},"ja404:6.4":{"pli":"attano ca parassa ca. ","html":"<span class='verse-line'>{}</span></p>"},"ja404:7.1":{"pli":"Tasmā tuleyya mattānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja404:7.2":{"pli":"sīlapaññāsutāmiva; ","html":"<span class='verse-line'>{}</span>"},"ja404:7.3":{"pli":"Gaṇaṁ vā parihare dhīro, ","html":"<span class='verse-line'>{}</span>"},"ja404:7.4":{"pli":"eko vāpi paribbaje”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja404:8.1":{"pli":"Kapijātakaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja405":{"ja405:0.1":{"pli":"Jātaka ","html":"<article id='ja405'><header><ul><li class='division'>{}</li>"},"ja405:0.2":{"pli":"Sattakanipāta ","html":"<li>{}</li>"},"ja405:0.3":{"pli":"Kukkuvagga ","html":"<li>{}</li></ul>"},"ja405:0.4":{"pli":"10. Bakajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja405:1.1":{"pli":"“Dvāsattati gotama puññakammā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja405:1.2":{"pli":"Vasavattino jātijaraṁ atītā; ","html":"<span class='verse-line'>{}</span>"},"ja405:1.3":{"pli":"Ayamantimā vedagū brahmapatti, ","html":"<span class='verse-line'>{}</span>"},"ja405:1.4":{"pli":"Asmābhijappanti janā anekā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja405:2.1":{"pli":"“Appañhi etaṁ na hi dīghamāyu, ","html":"<p><span class='verse-line'>{}</span>"},"ja405:2.2":{"pli":"Yaṁ tvaṁ baka maññasi dīghamāyuṁ; ","html":"<span class='verse-line'>{}</span>"},"ja405:2.3":{"pli":"Sataṁ sahassāni nirabbudānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja405:2.4":{"pli":"Āyuṁ pajānāmi tavāha brahme”. ","html":"<span class='verse-line'>{}</span></p>"},"ja405:3.1":{"pli":"“Anantadassī bhagavāhamasmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja405:3.2":{"pli":"Jātijjaraṁ sokamupātivatto; ","html":"<span class='verse-line'>{}</span>"},"ja405:3.3":{"pli":"Kiṁ me purāṇaṁ vatasīlavattaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja405:3.4":{"pli":"Ācikkha me taṁ yamahaṁ vijaññaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja405:4.1":{"pli":"“Yaṁ tvaṁ apāyesi bahū manusse, ","html":"<p><span class='verse-line'>{}</span>"},"ja405:4.2":{"pli":"Pipāsite ghammani samparete; ","html":"<span class='verse-line'>{}</span>"},"ja405:4.3":{"pli":"Taṁ te purāṇaṁ vatasīlavattaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja405:4.4":{"pli":"Suttappabuddhova anussarāmi. ","html":"<span class='verse-line'>{}</span></p>"},"ja405:5.1":{"pli":"Yaṁ eṇikūlasmi janaṁ gahītaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja405:5.2":{"pli":"Amocayī gayhaka niyyamānaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja405:5.3":{"pli":"Taṁ te purāṇaṁ vatasīlavattaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja405:5.4":{"pli":"Suttappabuddhova anussarāmi. ","html":"<span class='verse-line'>{}</span></p>"},"ja405:6.1":{"pli":"Gaṅgāya sotasmiṁ gahītanāvaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja405:6.2":{"pli":"Luddena nāgena manussakappā; ","html":"<span class='verse-line'>{}</span>"},"ja405:6.3":{"pli":"Amocayi tvaṁ balasā pasayha, ","html":"<span class='verse-line'>{}</span>"},"ja405:6.4":{"pli":"Taṁ te purāṇaṁ vatasīlavattaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja405:6.5":{"pli":"Suttappabuddhova anussarāmi. ","html":"<span class='verse-line'>{}</span></p>"},"ja405:7.1":{"pli":"Kappo ca te baddhacaro ahosiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja405:7.2":{"pli":"Sambuddhimantaṁ vatinaṁ amaññaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja405:7.3":{"pli":"Taṁ te purāṇaṁ vatasīlavattaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja405:7.4":{"pli":"Suttappabuddhova anussarāmi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja405:8.1":{"pli":"“Addhā pajānāsi mametamāyuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja405:8.2":{"pli":"Aññampi jānāsi tathā hi buddho; ","html":"<span class='verse-line'>{}</span>"},"ja405:8.3":{"pli":"Tathā hi tāyaṁ jalitānubhāvo, ","html":"<span class='verse-line'>{}</span>"},"ja405:8.4":{"pli":"Obhāsayaṁ tiṭṭhati brahmalokan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja405:9.1":{"pli":"Bakajātakaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja405:9.2":{"pli":"Kukkuvaggo paṭhamo. ","html":"<p class='endvagga'>{}</p>"},"ja405:10.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja405:11.1":{"pli":"Varakaṇṇika cāpavaro sutano, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja405:11.2":{"pli":"Atha gijjha sarohitamacchavaro; ","html":"<span class='verse-line'>{}</span>"},"ja405:11.3":{"pli":"Puna paṇṇaka senaka yācanako, ","html":"<span class='verse-line'>{}</span>"},"ja405:11.4":{"pli":"Atha veri sabrahmabakena dasāti. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}}}