{"thi-ap33":{"thi-ap33:0.1":{"pli":"Therīapadāna ","html":"<article id='thi-ap33'><header><ul><li class='division'>{}</li>"},"thi-ap33:0.2":{"pli":"Khattiyāvagga ","html":"<li>{}</li></ul>"},"thi-ap33:0.3":{"pli":"Uppaladāyikātherīapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"thi-ap33:1.1":{"pli":"“Nagare aruṇavatiyā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"thi-ap33:1.2":{"pli":"aruṇo nāma khattiyo; ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:1.3":{"pli":"Tassa rañño ahuṁ bhariyā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:1.4":{"pli":"ekajjhaṁ cārayāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap33:2.1":{"pli":"Rahogatā nisīditvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap33:2.2":{"pli":"evaṁ cintesahaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:2.3":{"pli":"‘Kusalaṁ me kataṁ natthi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:2.4":{"pli":"ādāya gamiyaṁ mama. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap33:3.1":{"pli":"Mahābhitāpaṁ kaṭukaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap33:3.2":{"pli":"ghorarūpaṁ sudāruṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:3.3":{"pli":"Nirayaṁ nūna gacchāmi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:3.4":{"pli":"ettha me natthi saṁsayo’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap33:4.1":{"pli":"Evāhaṁ cintayitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap33:4.2":{"pli":"pahaṁsetvāna mānasaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:4.3":{"pli":"Rājānaṁ upagantvāna, ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:4.4":{"pli":"idaṁ vacanamabraviṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap33:5.1":{"pli":"‘Itthī nāma mayaṁ deva, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap33:5.2":{"pli":"purisānittarā ahu; ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:5.3":{"pli":"Ekaṁ me samaṇaṁ dehi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:5.4":{"pli":"bhojayissāmi khattiya’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap33:6.1":{"pli":"Adāsi me tadā rājā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap33:6.2":{"pli":"samaṇaṁ bhāvitindriyaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:6.3":{"pli":"Tassa pattaṁ gahetvāna, ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:6.4":{"pli":"paramannena pūrayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap33:7.1":{"pli":"Pūretvā paramaṁ annaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap33:7.2":{"pli":"saha sugandhalepanaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:7.3":{"pli":"Mahācelena chāditvā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:7.4":{"pli":"adāsiṁ tuṭṭhamānasā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap33:8.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap33:8.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:8.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:8.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap33:9.1":{"pli":"Sahassadevarājūnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap33:9.2":{"pli":"mahesittamakārayiṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:9.3":{"pli":"Sahassacakkavattīnaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:9.4":{"pli":"mahesittamakārayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap33:10.1":{"pli":"Padesarajjaṁ vipulaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap33:10.2":{"pli":"gaṇanāto asaṅkhiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:10.3":{"pli":"Nānāvidhaṁ bahuṁ aññaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:10.4":{"pli":"tassa kammaphalaṁ tato. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap33:11.1":{"pli":"Uppalasseva me vaṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap33:11.2":{"pli":"abhirūpā sudassanā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:11.3":{"pli":"Itthisabbaṅgasampannā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:11.4":{"pli":"abhijātā jutindharā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap33:12.1":{"pli":"Pacchime bhave sampatte, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap33:12.2":{"pli":"ajāyiṁ sākiye kule; ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:12.3":{"pli":"Nārīsahassapāmokkhā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:12.4":{"pli":"suddhodanasutassahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap33:13.1":{"pli":"Nibbinditvā agārehaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap33:13.2":{"pli":"pabbajiṁ anagāriyaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:13.3":{"pli":"Sattamīrattisampattā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:13.4":{"pli":"catusaccamapāpuṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap33:14.1":{"pli":"Cīvaraṁ piṇḍapātañca, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap33:14.2":{"pli":"paccayaṁ sayanāsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:14.3":{"pli":"Parimetuṁ na sakkomi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:14.4":{"pli":"piṇḍapātassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap33:15.1":{"pli":"Yaṁ mayhaṁ pūritaṁ kammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap33:15.2":{"pli":"Kusalaṁ sarase muni; ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:15.3":{"pli":"Tuyhatthāya mahāvīra, ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:15.4":{"pli":"Paricattaṁ bahuṁ mayā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap33:16.1":{"pli":"Ekattiṁse ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap33:16.2":{"pli":"yaṁ dānamadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:16.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:16.4":{"pli":"piṇḍapātassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap33:17.1":{"pli":"Dve gatiyo pajānāmi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap33:17.2":{"pli":"devattaṁ atha mānusaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:17.3":{"pli":"Aññaṁ gatiṁ na jānāmi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:17.4":{"pli":"piṇḍapātassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap33:18.1":{"pli":"Ucce kule pajānāmi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap33:18.2":{"pli":"mahāsāle mahaddhane; ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:18.3":{"pli":"Aññe kule na jānāmi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:18.4":{"pli":"piṇḍapātassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap33:19.1":{"pli":"Bhavābhave saṁsaritvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap33:19.2":{"pli":"sukkamūlena coditā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:19.3":{"pli":"Amanāpaṁ na passāmi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:19.4":{"pli":"somanassakataṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap33:20.1":{"pli":"Iddhīsu ca vasī homi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap33:20.2":{"pli":"dibbāya sotadhātuyā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:20.3":{"pli":"Cetopariyañāṇassa, ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:20.4":{"pli":"vasī homi mahāmune. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap33:21.1":{"pli":"Pubbenivāsaṁ jānāmi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap33:21.2":{"pli":"dibbacakkhu visodhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:21.3":{"pli":"Sabbāsavā parikkhīṇā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:21.4":{"pli":"natthi dāni punabbhavo. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap33:22.1":{"pli":"Atthadhammaniruttīsu, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap33:22.2":{"pli":"paṭibhāne tatheva ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:22.3":{"pli":"Ñāṇaṁ mama mahāvīra, ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:22.4":{"pli":"uppannaṁ tava santike. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap33:23.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap33:23.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:23.3":{"pli":"viharāmi anāsavā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap33:24.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap33:24.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:24.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap33:25.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap33:25.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap33:25.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"thi-ap33:26.1":{"pli":"Itthaṁ sudaṁ uppaladāyikā bhikkhunī bhagavato sammukhā imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"thi-ap33:27.1":{"pli":"Uppaladāyikātheriyāpadānaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"thi-ap34":{"thi-ap34:0.1":{"pli":"Therīapadāna ","html":"<article id='thi-ap34'><header><ul><li class='division'>{}</li>"},"thi-ap34:0.2":{"pli":"Khattiyāvagga ","html":"<li>{}</li></ul>"},"thi-ap34:0.3":{"pli":"4 Siṅgālamātutherīapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"thi-ap34:1.1":{"pli":"“Padumuttaro nāma jino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"thi-ap34:1.2":{"pli":"sabbadhammāna pāragū; ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:1.3":{"pli":"Ito satasahassamhi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:1.4":{"pli":"kappe uppajji nāyako. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap34:2.1":{"pli":"Tadāhaṁ haṁsavatiyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap34:2.2":{"pli":"jātāmaccakule ahuṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:2.3":{"pli":"Nānāratanapajjote, ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:2.4":{"pli":"iddhe phīte mahaddhane. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap34:3.1":{"pli":"Pitunā saha gantvāna, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap34:3.2":{"pli":"mahājanapurakkhatā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:3.3":{"pli":"Dhammaṁ buddhassa sutvāna, ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:3.4":{"pli":"pabbajiṁ anagāriyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap34:4.1":{"pli":"Pabbajitvāna kāyena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap34:4.2":{"pli":"pāpakammaṁ vivajjayiṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:4.3":{"pli":"Vacīduccaritaṁ hitvā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:4.4":{"pli":"ājīvaṁ parisodhayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap34:5.1":{"pli":"Buddhe pasannā dhamme ca, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap34:5.2":{"pli":"saṅghe ca tibbagāravā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:5.3":{"pli":"Saddhammassavane yuttā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:5.4":{"pli":"buddhadassanalālasā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap34:6.1":{"pli":"Aggaṁ saddhādhimuttānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap34:6.2":{"pli":"assosiṁ bhikkhuniṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:6.3":{"pli":"Taṁ ṭhānaṁ patthayitvāna, ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:6.4":{"pli":"tisso sikkhā apūrayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap34:7.1":{"pli":"Tato maṁ sugato āha, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap34:7.2":{"pli":"karuṇānugatāsayo; ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:7.3":{"pli":"‘Yassa saddhā tathāgate, ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:7.4":{"pli":"acalā suppatiṭṭhitā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:7.5":{"pli":"Sīlañca yassa kalyāṇaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:7.6":{"pli":"ariyakantaṁ pasaṁsitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap34:8.1":{"pli":"Saṅghe pasādo yassatthi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap34:8.2":{"pli":"ujubhūtañca dassanaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:8.3":{"pli":"Adaliddoti taṁ āhu, ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:8.4":{"pli":"amoghaṁ tassa jīvitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap34:9.1":{"pli":"Tasmā saddhañca sīlañca, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap34:9.2":{"pli":"pasādaṁ dhammadassanaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:9.3":{"pli":"Anuyuñjetha medhāvī, ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:9.4":{"pli":"saraṁ buddhāna sāsanaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap34:10.1":{"pli":"Taṁ sutvāhaṁ pamuditā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap34:10.2":{"pli":"apucchiṁ paṇidhiṁ mama; ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:10.3":{"pli":"Tadā anomo amito, ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:10.4":{"pli":"byākarittha vināyako; ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:10.5":{"pli":"‘Buddhe pasannā kalyāṇī, ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:10.6":{"pli":"lacchase taṁ supatthitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap34:11.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap34:11.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:11.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:11.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap34:12.1":{"pli":"Tassa dhammesu dāyādā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap34:12.2":{"pli":"orasā dhammanimmitā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:12.3":{"pli":"Siṅgālakassa mātāti, ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:12.4":{"pli":"hessati satthu sāvikā’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap34:13.1":{"pli":"Taṁ sutvā muditā hutvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap34:13.2":{"pli":"yāvajīvaṁ tadā jinaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:13.3":{"pli":"Mettacittā paricariṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:13.4":{"pli":"paṭipattīhi nāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap34:14.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap34:14.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:14.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:14.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap34:15.1":{"pli":"Pacchime ca bhave dāni, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap34:15.2":{"pli":"giribbajapuruttame; ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:15.3":{"pli":"Jātā seṭṭhikule phīte, ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:15.4":{"pli":"mahāratanasañcaye. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap34:16.1":{"pli":"Putto siṅgālako nāma, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap34:16.2":{"pli":"mamāsi vipathe rato; ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:16.3":{"pli":"Diṭṭhigahanapakkhando, ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:16.4":{"pli":"disāpūjanatapparo. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap34:17.1":{"pli":"Nānādisā namassantaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap34:17.2":{"pli":"piṇḍāya nagaraṁ vajaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:17.3":{"pli":"Taṁ disvā ovadī buddho, ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:17.4":{"pli":"magge ṭhatvā vināyako. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap34:18.1":{"pli":"Tassa desayato dhammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap34:18.2":{"pli":"panādo vimhayo ahu; ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:18.3":{"pli":"Dvekoṭinaranārīnaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:18.4":{"pli":"dhammābhisamayo ahu. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap34:19.1":{"pli":"Tadāhaṁ parisaṁ gantvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap34:19.2":{"pli":"sutvā sugatabhāsitaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:19.3":{"pli":"Sotāpattiphalaṁ pattā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:19.4":{"pli":"pabbajiṁ anagāriyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap34:20.1":{"pli":"Na cireneva kālena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap34:20.2":{"pli":"buddhadassanalālasā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:20.3":{"pli":"Anussatiṁ taṁ bhāvetvā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:20.4":{"pli":"arahattamapāpuṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap34:21.1":{"pli":"Dassanatthāya buddhassa, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap34:21.2":{"pli":"sabbadā ca vajāmahaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:21.3":{"pli":"Atittāyeva passāmi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:21.4":{"pli":"rūpaṁ nayananandanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap34:22.1":{"pli":"Sabbapāramisambhūtaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap34:22.2":{"pli":"lakkhīnilayanaṁ varaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:22.3":{"pli":"Rūpaṁ sabbasubhākiṇṇaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:22.4":{"pli":"atittā viharāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap34:23.1":{"pli":"Jino tasmiṁ guṇe tuṭṭho, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap34:23.2":{"pli":"etadagge ṭhapesi maṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:23.3":{"pli":"‘Siṅgālakassa yā mātā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:23.4":{"pli":"aggā saddhādhimuttikā’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap34:24.1":{"pli":"Iddhīsu ca vasī homi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap34:24.2":{"pli":"dibbāya sotadhātuyā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:24.3":{"pli":"Cetopariyañāṇassa, ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:24.4":{"pli":"vasī homi mahāmuni. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap34:25.1":{"pli":"Pubbenivāsaṁ jānāmi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap34:25.2":{"pli":"dibbacakkhu visodhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:25.3":{"pli":"Sabbāsavā parikkhīṇā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:25.4":{"pli":"natthi dāni punabbhavo. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap34:26.1":{"pli":"Atthadhammaniruttīsu, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap34:26.2":{"pli":"paṭibhāne tatheva ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:26.3":{"pli":"Ñāṇaṁ mama mahāvīra, ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:26.4":{"pli":"uppannaṁ tava santike. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap34:27.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap34:27.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:27.3":{"pli":"viharāmi anāsavā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap34:28.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap34:28.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:28.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap34:29.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap34:29.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap34:29.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"thi-ap34:30.1":{"pli":"Itthaṁ sudaṁ siṅgālamātā bhikkhunī imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"thi-ap34:31.1":{"pli":"Siṅgālamātutheriyāpadānaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"thi-ap35":{"thi-ap35:0.1":{"pli":"Therīapadāna ","html":"<article id='thi-ap35'><header><ul><li class='division'>{}</li>"},"thi-ap35:0.2":{"pli":"Khattiyāvagga ","html":"<li>{}</li></ul>"},"thi-ap35:0.3":{"pli":"Sukkātherīapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"thi-ap35:1.1":{"pli":"“Ekanavutito kappe, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"thi-ap35:1.2":{"pli":"vipassī nāma nāyako; ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:1.3":{"pli":"Uppajji cārudassano, ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:1.4":{"pli":"sabbadhammavipassako. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap35:2.1":{"pli":"Tadāhaṁ bandhumatiyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap35:2.2":{"pli":"jātā aññatare kule; ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:2.3":{"pli":"Dhammaṁ sutvāna munino, ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:2.4":{"pli":"pabbajiṁ anagāriyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap35:3.1":{"pli":"Bahussutā dhammadharā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap35:3.2":{"pli":"paṭibhānavatī tathā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:3.3":{"pli":"Vicittakathikā cāpi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:3.4":{"pli":"jinasāsanakārikā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap35:4.1":{"pli":"Tadā dhammakathaṁ katvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap35:4.2":{"pli":"hitāya janataṁ bahuṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:4.3":{"pli":"Tato cutāhaṁ tusitaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:4.4":{"pli":"upapannā yasassinī. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap35:5.1":{"pli":"Ekattiṁse ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap35:5.2":{"pli":"sikhī viya sikhī jino; ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:5.3":{"pli":"Tapanto yasasā loke, ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:5.4":{"pli":"uppajji vadataṁ varo. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap35:6.1":{"pli":"Tadāpi pabbajitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap35:6.2":{"pli":"buddhasāsanakovidā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:6.3":{"pli":"Jotetvā jinavākyāni, ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:6.4":{"pli":"tatopi tidivaṁ gatā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap35:7.1":{"pli":"Ekattiṁseva kappamhi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap35:7.2":{"pli":"vessabhū nāma nāyako; ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:7.3":{"pli":"Uppajjittha mahāñāṇī, ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:7.4":{"pli":"tadāpi ca tathevahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap35:8.1":{"pli":"Pabbajitvā dhammadharā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap35:8.2":{"pli":"jotayiṁ jinasāsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:8.3":{"pli":"Gantvā marupuraṁ rammaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:8.4":{"pli":"anubhosiṁ mahāsukhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap35:9.1":{"pli":"Imamhi bhaddake kappe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap35:9.2":{"pli":"kakusandho jinuttamo; ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:9.3":{"pli":"Uppajji narasaraṇo, ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:9.4":{"pli":"tadāpi ca tathevahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap35:10.1":{"pli":"Pabbajitvā munimataṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap35:10.2":{"pli":"jotayitvā yathāyukaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:10.3":{"pli":"Tato cutāhaṁ tidivaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:10.4":{"pli":"agaṁ sabhavanaṁ yathā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap35:11.1":{"pli":"Imasmiṁyeva kappamhi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap35:11.2":{"pli":"koṇāgamananāyako; ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:11.3":{"pli":"Uppajji lokasaraṇo, ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:11.4":{"pli":"araṇo amataṅgato. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap35:12.1":{"pli":"Tadāpi pabbajitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap35:12.2":{"pli":"sāsane tassa tādino; ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:12.3":{"pli":"Bahussutā dhammadharā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:12.4":{"pli":"jotayiṁ jinasāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap35:13.1":{"pli":"Imasmiṁyeva kappamhi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap35:13.2":{"pli":"kassapo munimuttamo; ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:13.3":{"pli":"Uppajji lokasaraṇo, ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:13.4":{"pli":"araṇo maraṇantagū. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap35:14.1":{"pli":"Tassāpi naravīrassa, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap35:14.2":{"pli":"pabbajitvāna sāsane; ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:14.3":{"pli":"Pariyāpuṭasaddhammā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:14.4":{"pli":"paripucchā visāradā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap35:15.1":{"pli":"Susīlā lajjinī ceva, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap35:15.2":{"pli":"tīsu sikkhāsu kovidā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:15.3":{"pli":"Bahuṁ dhammakathaṁ katvā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:15.4":{"pli":"yāvajīvaṁ mahāmune. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap35:16.1":{"pli":"Tena kammavipākena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap35:16.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:16.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:16.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap35:17.1":{"pli":"Pacchime ca bhave dāni, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap35:17.2":{"pli":"giribbajapuruttame; ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:17.3":{"pli":"Jātā seṭṭhikule phīte, ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:17.4":{"pli":"mahāratanasañcaye. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap35:18.1":{"pli":"Yadā bhikkhusahassena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap35:18.2":{"pli":"parivuto lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:18.3":{"pli":"Upāgami rājagahaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:18.4":{"pli":"sahassakkhena vaṇṇito. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap35:19.1":{"pli":"Danto dantehi saha purāṇajaṭilehi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap35:19.2":{"pli":"Vippamutto vippamuttehi; ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:19.3":{"pli":"Siṅgīnikkhasavaṇṇo, ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:19.4":{"pli":"Rājagahaṁ pāvisi bhagavā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap35:20.1":{"pli":"Disvā buddhānubhāvaṁ taṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap35:20.2":{"pli":"sutvāva guṇasañcayaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:20.3":{"pli":"Buddhe cittaṁ pasādetvā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:20.4":{"pli":"pūjayiṁ taṁ yathābalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap35:21.1":{"pli":"Aparena ca kālena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap35:21.2":{"pli":"dhammadinnāya santike; ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:21.3":{"pli":"Agārā nikkhamitvāna, ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:21.4":{"pli":"pabbajiṁ anagāriyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap35:22.1":{"pli":"Kesesu chijjamānesu, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap35:22.2":{"pli":"kilese jhāpayiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:22.3":{"pli":"Uggahiṁ sāsanaṁ sabbaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:22.4":{"pli":"pabbajitvā cirenahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap35:23.1":{"pli":"Tato dhammamadesesiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap35:23.2":{"pli":"mahājanasamāgame; ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:23.3":{"pli":"Dhamme desiyamānamhi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:23.4":{"pli":"dhammābhisamayo ahu. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap35:24.1":{"pli":"Nekapāṇasahassānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap35:24.2":{"pli":"taṁ viditvātivimhito; ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:24.3":{"pli":"Abhippasanno me yakkho, ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:24.4":{"pli":"bhamitvāna giribbajaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap35:25.1":{"pli":"Kiṁ me katā rājagahe manussā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap35:25.2":{"pli":"Madhuṁ pītāva acchare; ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:25.3":{"pli":"Ye sukkaṁ na upāsanti, ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:25.4":{"pli":"Desentiṁ amataṁ padaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap35:26.1":{"pli":"Tañca appaṭivānīyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap35:26.2":{"pli":"asecanakamojavaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:26.3":{"pli":"Pivanti maññe sappaññā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:26.4":{"pli":"valāhakamivaddhagū. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap35:27.1":{"pli":"Iddhīsu ca vasī homi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap35:27.2":{"pli":"dibbāya sotadhātuyā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:27.3":{"pli":"Cetopariyañāṇassa, ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:27.4":{"pli":"vasī homi mahāmune. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap35:28.1":{"pli":"Pubbenivāsaṁ jānāmi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap35:28.2":{"pli":"dibbacakkhu visodhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:28.3":{"pli":"Sabbāsavā parikkhīṇā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:28.4":{"pli":"natthi dāni punabbhavo. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap35:29.1":{"pli":"Atthadhammaniruttīsu, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap35:29.2":{"pli":"paṭibhāne tatheva ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:29.3":{"pli":"Ñāṇaṁ mama mahāvīra, ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:29.4":{"pli":"uppannaṁ tava santike. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap35:30.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap35:30.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:30.3":{"pli":"viharāmi anāsavā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap35:31.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap35:31.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:31.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap35:32.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap35:32.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap35:32.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"thi-ap35:33.1":{"pli":"Itthaṁ sudaṁ sukkā bhikkhunī imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"thi-ap35:34.1":{"pli":"Sukkātheriyāpadānaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}<br>"},"thi-ap35:34.2":{"pli":"Pañcamaṁ bhāṇavāraṁ. ","html":"{}</p></article>"}},"thi-ap36":{"thi-ap36:0.1":{"pli":"Therīapadāna ","html":"<article id='thi-ap36'><header><ul><li class='division'>{}</li>"},"thi-ap36:0.2":{"pli":"Khattiyāvagga ","html":"<li>{}</li></ul>"},"thi-ap36:0.3":{"pli":"6 Abhirūpanandātherīapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"thi-ap36:1.1":{"pli":"“Ekanavutito kappe, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"thi-ap36:1.2":{"pli":"vipassī nāma nāyako; ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:1.3":{"pli":"Uppajji cārudassano, ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:1.4":{"pli":"sabbadhammesu cakkhumā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap36:2.1":{"pli":"Tadāhaṁ bandhumatiyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap36:2.2":{"pli":"iddhe phīte mahākule; ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:2.3":{"pli":"Jātā surūpā dayitā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:2.4":{"pli":"pūjanīyā janassa ca. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap36:3.1":{"pli":"Upagantvā mahāvīraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap36:3.2":{"pli":"vipassiṁ lokanāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:3.3":{"pli":"Dhammaṁ suṇitvā saraṇaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:3.4":{"pli":"upesiṁ naranāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap36:4.1":{"pli":"Sīlesu saṁvutā hutvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap36:4.2":{"pli":"nibbute ca naruttame; ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:4.3":{"pli":"Dhātuthūpassa upari, ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:4.4":{"pli":"soṇṇacchattamapūjayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap36:5.1":{"pli":"Muttacāgā sīlavatī, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap36:5.2":{"pli":"yāvajīvaṁ tato cutā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:5.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:5.4":{"pli":"tāvatiṁsūpagā ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap36:6.1":{"pli":"Tadā dasahi ṭhānehi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap36:6.2":{"pli":"adhibhotvāna sesake; ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:6.3":{"pli":"Rūpasaddehi gandhehi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:6.4":{"pli":"rasehi phusanehi ca. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap36:7.1":{"pli":"Āyunāpi ca vaṇṇena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap36:7.2":{"pli":"sukhena yasasāpi ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:7.3":{"pli":"Tathevādhipateyyena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:7.4":{"pli":"adhigayha virocahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap36:8.1":{"pli":"Pacchime ca bhave dāni, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap36:8.2":{"pli":"jātāhaṁ kapilavhaye; ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:8.3":{"pli":"Dhītā khemakasakkassa, ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:8.4":{"pli":"nandā nāmāti vissutā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap36:9.1":{"pli":"Abhirūpasampadampi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap36:9.2":{"pli":"ahu me kantisūcakaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:9.3":{"pli":"Yadāhaṁ yobbanappattā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:9.4":{"pli":"rūpalāvaññabhūsitā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap36:10.1":{"pli":"Tadā mamatthe sakyānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap36:10.2":{"pli":"vivādo sumahā ahu; ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:10.3":{"pli":"Pabbājesi tato tāto, ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:10.4":{"pli":"‘mā sakyā vinassiṁsu’ti. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap36:11.1":{"pli":"Pabbajitvā tathāgataṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap36:11.2":{"pli":"rūpadessiṁ naruttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:11.3":{"pli":"Sutvāna nopagacchāmi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:11.4":{"pli":"mama rūpena gabbitā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap36:12.1":{"pli":"Ovādampi na gacchāmi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap36:12.2":{"pli":"buddhadassanabhīrutā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:12.3":{"pli":"Tadā jino upāyena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:12.4":{"pli":"upanetvā sasantikaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap36:13.1":{"pli":"Tissitthiyo nidassesi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap36:13.2":{"pli":"iddhiyā maggakovido; ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:13.3":{"pli":"Accharārūpasadisaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:13.4":{"pli":"taruṇiṁ jaritaṁ mataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap36:14.1":{"pli":"Tāyo disvā susaṁviggā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap36:14.2":{"pli":"virattāse kaḷevare; ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:14.3":{"pli":"Aṭṭhāsiṁ bhavanibbindā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:14.4":{"pli":"tadā maṁ āha nāyako. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap36:15.1":{"pli":"‘Āturaṁ asuciṁ pūtiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap36:15.2":{"pli":"passa nande samussayaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:15.3":{"pli":"Uggharantaṁ paggharantaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:15.4":{"pli":"bālānaṁ abhinanditaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap36:16.1":{"pli":"Asubhāya cittaṁ bhāvehi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap36:16.2":{"pli":"ekaggaṁ susamāhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:16.3":{"pli":"Yathā idaṁ tathā etaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:16.4":{"pli":"yathā etaṁ tathā idaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap36:17.1":{"pli":"Evametaṁ avekkhantī, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap36:17.2":{"pli":"rattindivamatanditā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:17.3":{"pli":"Tato sakāya paññāya, ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:17.4":{"pli":"abhinibbijjha vacchasi’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap36:18.1":{"pli":"Tassā me appamattāya, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap36:18.2":{"pli":"vicarantiyā yoniso; ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:18.3":{"pli":"Yathābhūtaṁ ayaṁ kāyo, ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:18.4":{"pli":"diṭṭho santarabāhiro. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap36:19.1":{"pli":"Atha nibbindahaṁ kāye, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap36:19.2":{"pli":"ajjhattañca virajjahaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:19.3":{"pli":"Appamattā visaṁyuttā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:19.4":{"pli":"upasantāmhi nibbutā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap36:20.1":{"pli":"Iddhīsu ca vasī homi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap36:20.2":{"pli":"dibbāya sotadhātuyā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:20.3":{"pli":"Cetopariyañāṇassa, ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:20.4":{"pli":"vasī homi mahāmune. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap36:21.1":{"pli":"Pubbenivāsaṁ jānāmi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap36:21.2":{"pli":"dibbacakkhu visodhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:21.3":{"pli":"Sabbāsavā parikkhīṇā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:21.4":{"pli":"natthi dāni punabbhavo. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap36:22.1":{"pli":"Atthadhammaniruttīsu, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap36:22.2":{"pli":"paṭibhāne tatheva ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:22.3":{"pli":"Ñāṇaṁ mama mahāvīra, ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:22.4":{"pli":"uppannaṁ tava santike. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap36:23.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap36:23.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:23.3":{"pli":"viharāmi anāsavā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap36:24.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap36:24.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:24.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap36:25.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap36:25.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap36:25.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"thi-ap36:26.1":{"pli":"Itthaṁ sudaṁ abhirūpanandā bhikkhunī imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"thi-ap36:27.1":{"pli":"Abhirūpanandātheriyāpadānaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}