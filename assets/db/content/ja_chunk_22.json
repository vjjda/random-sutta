{"ja483":{"ja483:0.1":{"pli":"Jātaka ","html":"<article id='ja483'><header><ul><li class='division'>{}</li>"},"ja483:0.2":{"pli":"Terasakanipāta ","html":"<li>{}</li>"},"ja483:0.3":{"pli":"Ambavagga ","html":"<li>{}</li></ul>"},"ja483:0.4":{"pli":"10. Sarabhamigajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja483:1.1":{"pli":"“Āsīsetheva puriso, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja483:1.2":{"pli":"na nibbindeyya paṇḍito; ","html":"<span class='verse-line'>{}</span>"},"ja483:1.3":{"pli":"Passāmi vohaṁ attānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja483:1.4":{"pli":"yathā icchiṁ tathā ahu. ","html":"<span class='verse-line'>{}</span></p>"},"ja483:2.1":{"pli":"Āsīsetheva puriso, ","html":"<p><span class='verse-line'>{}</span>"},"ja483:2.2":{"pli":"na nibbindeyya paṇḍito; ","html":"<span class='verse-line'>{}</span>"},"ja483:2.3":{"pli":"Passāmi vohaṁ attānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja483:2.4":{"pli":"udakā thalamubbhataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja483:3.1":{"pli":"Vāyametheva puriso, ","html":"<p><span class='verse-line'>{}</span>"},"ja483:3.2":{"pli":"na nibbindeyya paṇḍito; ","html":"<span class='verse-line'>{}</span>"},"ja483:3.3":{"pli":"Passāmi vohaṁ attānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja483:3.4":{"pli":"yathā icchiṁ tathā ahu. ","html":"<span class='verse-line'>{}</span></p>"},"ja483:4.1":{"pli":"Vāyametheva puriso, ","html":"<p><span class='verse-line'>{}</span>"},"ja483:4.2":{"pli":"na nibbindeyya paṇḍito; ","html":"<span class='verse-line'>{}</span>"},"ja483:4.3":{"pli":"Passāmi vohaṁ attānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja483:4.4":{"pli":"udakā thalamubbhataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja483:5.1":{"pli":"Dukkhūpanītopi naro sapañño, ","html":"<p><span class='verse-line'>{}</span>"},"ja483:5.2":{"pli":"Āsaṁ na chindeyya sukhāgamāya; ","html":"<span class='verse-line'>{}</span>"},"ja483:5.3":{"pli":"Bahū hi phassā ahitā hitā ca, ","html":"<span class='verse-line'>{}</span>"},"ja483:5.4":{"pli":"Avitakkitā maccamupabbajanti. ","html":"<span class='verse-line'>{}</span></p>"},"ja483:6.1":{"pli":"Acintitampi bhavati, ","html":"<p><span class='verse-line'>{}</span>"},"ja483:6.2":{"pli":"cintitampi vinassati; ","html":"<span class='verse-line'>{}</span>"},"ja483:6.3":{"pli":"Na hi cintāmayā bhogā, ","html":"<span class='verse-line'>{}</span>"},"ja483:6.4":{"pli":"itthiyā purisassa vā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja483:7.1":{"pli":"“Sarabhaṁ giriduggasmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja483:7.2":{"pli":"yaṁ tvaṁ anusarī pure; ","html":"<span class='verse-line'>{}</span>"},"ja483:7.3":{"pli":"Alīnacittassa tuvaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja483:7.4":{"pli":"vikkantamanujīvasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja483:8.1":{"pli":"Yo taṁ viduggā narakā samuddhari, ","html":"<p><span class='verse-line'>{}</span>"},"ja483:8.2":{"pli":"Silāya yoggaṁ sarabho karitvā; ","html":"<span class='verse-line'>{}</span>"},"ja483:8.3":{"pli":"Dukkhūpanītaṁ maccumukhā pamocayi, ","html":"<span class='verse-line'>{}</span>"},"ja483:8.4":{"pli":"Alīnacittaṁ ta migaṁ vadesi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja483:9.1":{"pli":"“Kiṁ tvaṁ nu tattheva tadā ahosi, ","html":"<p><span class='verse-line'>{}</span>"},"ja483:9.2":{"pli":"Udāhu te koci naṁ etadakkhā; ","html":"<span class='verse-line'>{}</span>"},"ja483:9.3":{"pli":"Vivaṭṭacchaddo nusi sabbadassī, ","html":"<span class='verse-line'>{}</span>"},"ja483:9.4":{"pli":"Ñāṇaṁ nu te brāhmaṇa bhiṁsarūpaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja483:10.1":{"pli":"“Na cevahaṁ tattha tadā ahosiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja483:10.2":{"pli":"Na cāpi me koci naṁ etadakkhā; ","html":"<span class='verse-line'>{}</span>"},"ja483:10.3":{"pli":"Gāthāpadānañca subhāsitānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja483:10.4":{"pli":"Atthaṁ tadānenti janinda dhīrā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja483:11.1":{"pli":"“Ādāya pattiṁ paraviriyaghātiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja483:11.2":{"pli":"Cāpe saraṁ kiṁ vicikicchase tuvaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja483:11.3":{"pli":"Nunno saro sarabhaṁ hantu khippaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja483:11.4":{"pli":"Annañhi etaṁ varapañña rañño”. ","html":"<span class='verse-line'>{}</span></p>"},"ja483:12.1":{"pli":"“Addhā pajānāmi ahampi etaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja483:12.2":{"pli":"Annaṁ migo brāhmaṇa khattiyassa; ","html":"<span class='verse-line'>{}</span>"},"ja483:12.3":{"pli":"Pubbe katañca apacāyamāno, ","html":"<span class='verse-line'>{}</span>"},"ja483:12.4":{"pli":"Tasmā migaṁ sarabhaṁ no hanāmi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja483:13.1":{"pli":"“Neso migo mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja483:13.2":{"pli":"asureso disampati; ","html":"<span class='verse-line'>{}</span>"},"ja483:13.3":{"pli":"Etaṁ hantvā manussinda, ","html":"<span class='verse-line'>{}</span>"},"ja483:13.4":{"pli":"bhavassu amarādhipo. ","html":"<span class='verse-line'>{}</span></p>"},"ja483:14.1":{"pli":"Sace ca rājā vicikicchase tuvaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja483:14.2":{"pli":"Hantuṁ migaṁ sarabhaṁ sahāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja483:14.3":{"pli":"Saputtadāro naravīraseṭṭha, ","html":"<span class='verse-line'>{}</span>"},"ja483:14.4":{"pli":"Gantā tuvaṁ vetaraṇiṁ yamassa”. ","html":"<span class='verse-line'>{}</span></p>"},"ja483:15.1":{"pli":"“Kāmaṁ ahaṁ jānapadā ca sabbe, ","html":"<p><span class='verse-line'>{}</span>"},"ja483:15.2":{"pli":"Puttā ca dārā ca sahāyasaṅghā; ","html":"<span class='verse-line'>{}</span>"},"ja483:15.3":{"pli":"Gacchemu taṁ vetaraṇiṁ yamassa, ","html":"<span class='verse-line'>{}</span>"},"ja483:15.4":{"pli":"Na tveva hañño mama pāṇado yo. ","html":"<span class='verse-line'>{}</span></p>"},"ja483:16.1":{"pli":"Ayaṁ migo kicchagatassa mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja483:16.2":{"pli":"Ekassa kattā vivanasmi ghore; ","html":"<span class='verse-line'>{}</span>"},"ja483:16.3":{"pli":"Taṁ tādisaṁ pubbakiccaṁ saranto, ","html":"<span class='verse-line'>{}</span>"},"ja483:16.4":{"pli":"Jānaṁ mahābrahme kathaṁ haneyyaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja483:17.1":{"pli":"“Mittābhirādhī cirameva jīva, ","html":"<p><span class='verse-line'>{}</span>"},"ja483:17.2":{"pli":"Rajjaṁ imaṁ dhammaguṇe pasāsa; ","html":"<span class='verse-line'>{}</span>"},"ja483:17.3":{"pli":"Nārīgaṇehi paricāriyanto, ","html":"<span class='verse-line'>{}</span>"},"ja483:17.4":{"pli":"Modassu raṭṭhe tidiveva vāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"ja483:18.1":{"pli":"Akkodhano niccapasannacitto, ","html":"<p><span class='verse-line'>{}</span>"},"ja483:18.2":{"pli":"Sabbātithī yācayogo bhavitvā; ","html":"<span class='verse-line'>{}</span>"},"ja483:18.3":{"pli":"Datvā ca bhutvā ca yathānubhāvaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja483:18.4":{"pli":"Anindito saggamupehi ṭhānan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja483:19.1":{"pli":"Sarabhamigajātakaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja483:20.1":{"pli":"Terasakanipātaṁ niṭṭhitaṁ. ","html":"<p class='endsection'>{}</p>"},"ja483:21.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja483:22.1":{"pli":"Varaamba kuṭhāri sahaṁsavaro, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja483:22.2":{"pli":"Atharaññasmiṁ dūtakapañcamako; ","html":"<span class='verse-line'>{}</span>"},"ja483:22.3":{"pli":"Atha bodhi akitti sutakkarinā, ","html":"<span class='verse-line'>{}</span>"},"ja483:22.4":{"pli":"Atha rurumigenaparo sarabhoti. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"ja484":{"ja484:0.1":{"pli":"Jātaka ","html":"<article id='ja484'><header><ul><li class='division'>{}</li>"},"ja484:0.2":{"pli":"Pakiṇṇakanipāta ","html":"<li>{}</li>"},"ja484:0.3":{"pli":"Sālikedāravagga ","html":"<li>{}</li></ul>"},"ja484:0.4":{"pli":"1. Sālikedārajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja484:1.1":{"pli":"“Sampannaṁ sālikedāraṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja484:1.2":{"pli":"suvā bhuñjanti kosiya; ","html":"<span class='verse-line'>{}</span>"},"ja484:1.3":{"pli":"Paṭivedemi te brahme, ","html":"<span class='verse-line'>{}</span>"},"ja484:1.4":{"pli":"na ne vāretumussahe. ","html":"<span class='verse-line'>{}</span></p>"},"ja484:2.1":{"pli":"Eko ca tattha sakuṇo, ","html":"<p><span class='verse-line'>{}</span>"},"ja484:2.2":{"pli":"yo nesaṁ sabbasundaro; ","html":"<span class='verse-line'>{}</span>"},"ja484:2.3":{"pli":"Bhutvā sāliṁ yathākāmaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja484:2.4":{"pli":"tuṇḍenādāya gacchati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja484:3.1":{"pli":"“Oḍḍentu vāḷapāsāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja484:3.2":{"pli":"yathā bajjhetha so dijo; ","html":"<span class='verse-line'>{}</span>"},"ja484:3.3":{"pli":"Jīvañca naṁ gahetvāna, ","html":"<span class='verse-line'>{}</span>"},"ja484:3.4":{"pli":"ānayehi mamantike”. ","html":"<span class='verse-line'>{}</span></p>"},"ja484:4.1":{"pli":"“Ete bhutvā pivitvā ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja484:4.2":{"pli":"pakkamanti vihaṅgamā; ","html":"<span class='verse-line'>{}</span>"},"ja484:4.3":{"pli":"Eko baddhosmi pāsena, ","html":"<span class='verse-line'>{}</span>"},"ja484:4.4":{"pli":"kiṁ pāpaṁ pakataṁ mayā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja484:5.1":{"pli":"“Udaraṁ nūna aññesaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja484:5.2":{"pli":"suva accodaraṁ tava; ","html":"<span class='verse-line'>{}</span>"},"ja484:5.3":{"pli":"Bhutvā sāliṁ yathākāmaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja484:5.4":{"pli":"tuṇḍenādāya gacchasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja484:6.1":{"pli":"Koṭṭhaṁ nu tattha pūresi, ","html":"<p><span class='verse-line'>{}</span>"},"ja484:6.2":{"pli":"suva veraṁ nu te mayā; ","html":"<span class='verse-line'>{}</span>"},"ja484:6.3":{"pli":"Puṭṭho me samma akkhāhi, ","html":"<span class='verse-line'>{}</span>"},"ja484:6.4":{"pli":"kuhiṁ sāliṁ nidāhasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja484:7.1":{"pli":"“Na me veraṁ tayā saddhiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja484:7.2":{"pli":"koṭṭho mayhaṁ na vijjati; ","html":"<span class='verse-line'>{}</span>"},"ja484:7.3":{"pli":"Iṇaṁ muñcāmiṇaṁ dammi, ","html":"<span class='verse-line'>{}</span>"},"ja484:7.4":{"pli":"sampatto koṭasimbaliṁ; ","html":"<span class='verse-line'>{}</span>"},"ja484:7.5":{"pli":"Nidhimpi tattha nidahāmi, ","html":"<span class='verse-line'>{}</span>"},"ja484:7.6":{"pli":"evaṁ jānāhi kosiya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja484:8.1":{"pli":"“Kīdisaṁ te iṇadānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja484:8.2":{"pli":"iṇamokkho ca kīdiso; ","html":"<span class='verse-line'>{}</span>"},"ja484:8.3":{"pli":"Nidhinidhānamakkhāhi, ","html":"<span class='verse-line'>{}</span>"},"ja484:8.4":{"pli":"atha pāsā pamokkhasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja484:9.1":{"pli":"“Ajātapakkhā taruṇā, ","html":"<p><span class='verse-line'>{}</span>"},"ja484:9.2":{"pli":"puttakā mayha kosiya; ","html":"<span class='verse-line'>{}</span>"},"ja484:9.3":{"pli":"Te maṁ bhatā bharissanti, ","html":"<span class='verse-line'>{}</span>"},"ja484:9.4":{"pli":"tasmā tesaṁ iṇaṁ dade. ","html":"<span class='verse-line'>{}</span></p>"},"ja484:10.1":{"pli":"Mātā pitā ca me vuddhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja484:10.2":{"pli":"jiṇṇakā gatayobbanā; ","html":"<span class='verse-line'>{}</span>"},"ja484:10.3":{"pli":"Tesaṁ tuṇḍena hātūna, ","html":"<span class='verse-line'>{}</span>"},"ja484:10.4":{"pli":"muñce pubbakataṁ iṇaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja484:11.1":{"pli":"Aññepi tattha sakuṇā, ","html":"<p><span class='verse-line'>{}</span>"},"ja484:11.2":{"pli":"khīṇapakkhā sudubbalā; ","html":"<span class='verse-line'>{}</span>"},"ja484:11.3":{"pli":"Tesaṁ puññatthiko dammi, ","html":"<span class='verse-line'>{}</span>"},"ja484:11.4":{"pli":"taṁ nidhiṁ āhu paṇḍitā. ","html":"<span class='verse-line'>{}</span></p>"},"ja484:12.1":{"pli":"Īdisaṁ me iṇadānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja484:12.2":{"pli":"iṇamokkho ca īdiso; ","html":"<span class='verse-line'>{}</span>"},"ja484:12.3":{"pli":"Nidhinidhānamakkhāmi, ","html":"<span class='verse-line'>{}</span>"},"ja484:12.4":{"pli":"evaṁ jānāhi kosiya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja484:13.1":{"pli":"“Bhaddako vatayaṁ pakkhī, ","html":"<p><span class='verse-line'>{}</span>"},"ja484:13.2":{"pli":"dijo paramadhammiko; ","html":"<span class='verse-line'>{}</span>"},"ja484:13.3":{"pli":"Ekaccesu manussesu, ","html":"<span class='verse-line'>{}</span>"},"ja484:13.4":{"pli":"ayaṁ dhammo na vijjati. ","html":"<span class='verse-line'>{}</span></p>"},"ja484:14.1":{"pli":"Bhuñja sāliṁ yathākāmaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja484:14.2":{"pli":"saha sabbehi ñātibhi; ","html":"<span class='verse-line'>{}</span>"},"ja484:14.3":{"pli":"Punāpi suva passemu, ","html":"<span class='verse-line'>{}</span>"},"ja484:14.4":{"pli":"piyaṁ me tava dassanaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja484:15.1":{"pli":"“Bhuttañca pītañca tavassamamhi, ","html":"<p><span class='verse-line'>{}</span>"},"ja484:15.2":{"pli":"Ratī ca no kosiya te sakāse; ","html":"<span class='verse-line'>{}</span>"},"ja484:15.3":{"pli":"Nikkhittadaṇḍesu dadāhi dānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja484:15.4":{"pli":"Jiṇṇe ca mātāpitaro bharassu”. ","html":"<span class='verse-line'>{}</span></p>"},"ja484:16.1":{"pli":"“Lakkhī vata me udapādi ajja, ","html":"<p><span class='verse-line'>{}</span>"},"ja484:16.2":{"pli":"Yo addasāsiṁ pavaraṁ dijānaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja484:16.3":{"pli":"Suvassa sutvāna subhāsitāni, ","html":"<span class='verse-line'>{}</span>"},"ja484:16.4":{"pli":"Kāhāmi puññāni anappakāni”. ","html":"<span class='verse-line'>{}</span></p>"},"ja484:17.1":{"pli":"So kosiyo attamano udaggo, ","html":"<p><span class='verse-line'>{}</span>"},"ja484:17.2":{"pli":"Annañca pānañcabhisaṅkharitvā; ","html":"<span class='verse-line'>{}</span>"},"ja484:17.3":{"pli":"Annena pānena pasannacitto, ","html":"<span class='verse-line'>{}</span>"},"ja484:17.4":{"pli":"Santappayi samaṇabrāhmaṇe cāti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja484:18.1":{"pli":"Sālikedārajātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja485":{"ja485:0.1":{"pli":"Jātaka ","html":"<article id='ja485'><header><ul><li class='division'>{}</li>"},"ja485:0.2":{"pli":"Pakiṇṇakanipāta ","html":"<li>{}</li>"},"ja485:0.3":{"pli":"Sālikedāravagga ","html":"<li>{}</li></ul>"},"ja485:0.4":{"pli":"2. Candakinnarījātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja485:1.1":{"pli":"“Upanīyatidaṁ maññe, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja485:1.2":{"pli":"cande lohitamaddane; ","html":"<span class='verse-line'>{}</span>"},"ja485:1.3":{"pli":"Ajja jahāmi jīvitaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja485:1.4":{"pli":"pāṇā me cande nirujjhanti. ","html":"<span class='verse-line'>{}</span></p>"},"ja485:2.1":{"pli":"Osīdi me dukkhaṁ hadayaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja485:2.2":{"pli":"Me ḍayhate nitammāmi; ","html":"<span class='verse-line'>{}</span>"},"ja485:2.3":{"pli":"Tava candiyā socantiyā, ","html":"<span class='verse-line'>{}</span>"},"ja485:2.4":{"pli":"Na naṁ aññehi sokehi. ","html":"<span class='verse-line'>{}</span></p>"},"ja485:3.1":{"pli":"Tiṇamiva vanamiva milāyāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja485:3.2":{"pli":"Nadī aparipuṇṇāva sussāmi; ","html":"<span class='verse-line'>{}</span>"},"ja485:3.3":{"pli":"Tava candiyā socantiyā, ","html":"<span class='verse-line'>{}</span>"},"ja485:3.4":{"pli":"Na naṁ aññehi sokehi. ","html":"<span class='verse-line'>{}</span></p>"},"ja485:4.1":{"pli":"Vassamiva sare pāde, ","html":"<p><span class='verse-line'>{}</span>"},"ja485:4.2":{"pli":"Imāni assūni vattare mayhaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja485:4.3":{"pli":"Tava candiyā socantiyā, ","html":"<span class='verse-line'>{}</span>"},"ja485:4.4":{"pli":"Na naṁ aññehi sokehi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja485:5.1":{"pli":"“Pāpo khosi rājaputta, ","html":"<p><span class='verse-line'>{}</span>"},"ja485:5.2":{"pli":"Yo me icchitaṁ patiṁ varākiyā; ","html":"<span class='verse-line'>{}</span>"},"ja485:5.3":{"pli":"Vijjhasi vanamūlasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja485:5.4":{"pli":"Soyaṁ viddho chamā seti. ","html":"<span class='verse-line'>{}</span></p>"},"ja485:6.1":{"pli":"Imaṁ mayhaṁ hadayasokaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja485:6.2":{"pli":"Paṭimuñcatu rājaputta tava mātā; ","html":"<span class='verse-line'>{}</span>"},"ja485:6.3":{"pli":"Yo mayhaṁ hadayasoko, ","html":"<span class='verse-line'>{}</span>"},"ja485:6.4":{"pli":"Kimpurisaṁ avekkhamānāya. ","html":"<span class='verse-line'>{}</span></p>"},"ja485:7.1":{"pli":"Imaṁ mayhaṁ hadayasokaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja485:7.2":{"pli":"Paṭimuñcatu rājaputta tava jāyā; ","html":"<span class='verse-line'>{}</span>"},"ja485:7.3":{"pli":"Yo mayhaṁ hadayasoko, ","html":"<span class='verse-line'>{}</span>"},"ja485:7.4":{"pli":"Kimpurisaṁ avekkhamānāya. ","html":"<span class='verse-line'>{}</span></p>"},"ja485:8.1":{"pli":"Mā ca puttaṁ mā ca patiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja485:8.2":{"pli":"Addakkhi rājaputta tava mātā; ","html":"<span class='verse-line'>{}</span>"},"ja485:8.3":{"pli":"Yo kimpurisaṁ avadhi, ","html":"<span class='verse-line'>{}</span>"},"ja485:8.4":{"pli":"Adūsakaṁ mayha kāmā hi. ","html":"<span class='verse-line'>{}</span></p>"},"ja485:9.1":{"pli":"Mā ca puttaṁ mā ca patiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja485:9.2":{"pli":"Addakkhi rājaputta tava jāyā; ","html":"<span class='verse-line'>{}</span>"},"ja485:9.3":{"pli":"Yo kimpurisaṁ avadhi, ","html":"<span class='verse-line'>{}</span>"},"ja485:9.4":{"pli":"Adūsakaṁ mayha kāmā hi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja485:10.1":{"pli":"“Mā tvaṁ cande rodi, ","html":"<p><span class='verse-line'>{}</span>"},"ja485:10.2":{"pli":"Mā soci vanatimiramattakkhi; ","html":"<span class='verse-line'>{}</span>"},"ja485:10.3":{"pli":"Mama tvaṁ hehisi bhariyā, ","html":"<span class='verse-line'>{}</span>"},"ja485:10.4":{"pli":"Rājakule pūjitā nārībhi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja485:11.1":{"pli":"“Api nūnahaṁ marissaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja485:11.2":{"pli":"Nāhaṁ rājaputta tava hessaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja485:11.3":{"pli":"Yo kimpurisaṁ avadhi, ","html":"<span class='verse-line'>{}</span>"},"ja485:11.4":{"pli":"Adūsakaṁ mayha kāmā hi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja485:12.1":{"pli":"“Api bhīruke api jīvitukāmike, ","html":"<p><span class='verse-line'>{}</span>"},"ja485:12.2":{"pli":"Kimpurisi gaccha himavantaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja485:12.3":{"pli":"Tālīsatagarabhojanā, ","html":"<span class='verse-line'>{}</span>"},"ja485:12.4":{"pli":"Aññe taṁ migā ramissanti”. ","html":"<span class='verse-line'>{}</span></p>"},"ja485:13.1":{"pli":"“Te pabbatā tā ca kandarā, ","html":"<p><span class='verse-line'>{}</span>"},"ja485:13.2":{"pli":"Tā ca giriguhāyo tatheva tiṭṭhanti; ","html":"<span class='verse-line'>{}</span>"},"ja485:13.3":{"pli":"Tattheva taṁ apassantī, ","html":"<span class='verse-line'>{}</span>"},"ja485:13.4":{"pli":"Kimpurisa kathaṁ ahaṁ kassaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja485:14.1":{"pli":"Te paṇṇasanthatā ramaṇīyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja485:14.2":{"pli":"Vāḷamigehi anuciṇṇā; ","html":"<span class='verse-line'>{}</span>"},"ja485:14.3":{"pli":"Tattheva taṁ apassantī, ","html":"<span class='verse-line'>{}</span>"},"ja485:14.4":{"pli":"Kimpurisa kathaṁ ahaṁ kassaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja485:15.1":{"pli":"Te pupphasanthatā ramaṇīyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja485:15.2":{"pli":"Vāḷamigehi anuciṇṇā; ","html":"<span class='verse-line'>{}</span>"},"ja485:15.3":{"pli":"Tattheva taṁ apassantī, ","html":"<span class='verse-line'>{}</span>"},"ja485:15.4":{"pli":"Kimpurisa kathaṁ ahaṁ kassaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja485:16.1":{"pli":"Acchā savanti girivananadiyo, ","html":"<p><span class='verse-line'>{}</span>"},"ja485:16.2":{"pli":"Kusumābhikiṇṇasotāyo; ","html":"<span class='verse-line'>{}</span>"},"ja485:16.3":{"pli":"Tattheva taṁ apassantī, ","html":"<span class='verse-line'>{}</span>"},"ja485:16.4":{"pli":"Kimpurisa kathaṁ ahaṁ kassaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja485:17.1":{"pli":"Nīlāni himavato pabbatassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja485:17.2":{"pli":"Kūṭāni dassanīyāni; ","html":"<span class='verse-line'>{}</span>"},"ja485:17.3":{"pli":"Tattheva taṁ apassantī, ","html":"<span class='verse-line'>{}</span>"},"ja485:17.4":{"pli":"Kimpurisa kathaṁ ahaṁ kassaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja485:18.1":{"pli":"Pītāni himavato pabbatassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja485:18.2":{"pli":"Kūṭāni dassanīyāni; ","html":"<span class='verse-line'>{}</span>"},"ja485:18.3":{"pli":"Tattheva taṁ apassantī, ","html":"<span class='verse-line'>{}</span>"},"ja485:18.4":{"pli":"Kimpurisa kathaṁ ahaṁ kassaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja485:19.1":{"pli":"Tambāni himavato pabbatassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja485:19.2":{"pli":"Kūṭāni dassanīyāni; ","html":"<span class='verse-line'>{}</span>"},"ja485:19.3":{"pli":"Tattheva taṁ apassantī, ","html":"<span class='verse-line'>{}</span>"},"ja485:19.4":{"pli":"Kimpurisa kathaṁ ahaṁ kassaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja485:20.1":{"pli":"Tuṅgāni himavato pabbatassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja485:20.2":{"pli":"Kūṭāni dassanīyāni; ","html":"<span class='verse-line'>{}</span>"},"ja485:20.3":{"pli":"Tattheva taṁ apassantī, ","html":"<span class='verse-line'>{}</span>"},"ja485:20.4":{"pli":"Kimpurisa kathaṁ ahaṁ kassaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja485:21.1":{"pli":"Setāni himavato pabbatassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja485:21.2":{"pli":"Kūṭāni dassanīyāni; ","html":"<span class='verse-line'>{}</span>"},"ja485:21.3":{"pli":"Tattheva taṁ apassantī, ","html":"<span class='verse-line'>{}</span>"},"ja485:21.4":{"pli":"Kimpurisa kathaṁ ahaṁ kassaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja485:22.1":{"pli":"Citrāni himavato pabbatassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja485:22.2":{"pli":"Kūṭāni dassanīyāni; ","html":"<span class='verse-line'>{}</span>"},"ja485:22.3":{"pli":"Tattheva taṁ apassantī, ","html":"<span class='verse-line'>{}</span>"},"ja485:22.4":{"pli":"Kimpurisa kathaṁ ahaṁ kassaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja485:23.1":{"pli":"Yakkhagaṇasevite gandhamādane, ","html":"<p><span class='verse-line'>{}</span>"},"ja485:23.2":{"pli":"Osadhebhi sañchanne; ","html":"<span class='verse-line'>{}</span>"},"ja485:23.3":{"pli":"Tattheva taṁ apassantī, ","html":"<span class='verse-line'>{}</span>"},"ja485:23.4":{"pli":"Kimpurisa kathaṁ ahaṁ kassaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja485:24.1":{"pli":"Kimpurisasevite gandhamādane, ","html":"<p><span class='verse-line'>{}</span>"},"ja485:24.2":{"pli":"Osadhebhi sañchanne; ","html":"<span class='verse-line'>{}</span>"},"ja485:24.3":{"pli":"Tattheva taṁ apassantī, ","html":"<span class='verse-line'>{}</span>"},"ja485:24.4":{"pli":"Kimpurisa kathaṁ ahaṁ kassaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja485:25.1":{"pli":"“Vande te ayirabrahme, ","html":"<p><span class='verse-line'>{}</span>"},"ja485:25.2":{"pli":"Yo me icchitaṁ patiṁ varākiyā; ","html":"<span class='verse-line'>{}</span>"},"ja485:25.3":{"pli":"Amatena abhisiñci, ","html":"<span class='verse-line'>{}</span>"},"ja485:25.4":{"pli":"Samāgatāsmi piyatamena. ","html":"<span class='verse-line'>{}</span></p>"},"ja485:26.1":{"pli":"Vicarāma dāni girivana nadiyo, ","html":"<p><span class='verse-line'>{}</span>"},"ja485:26.2":{"pli":"Kusumābhikiṇṇasotāyo; ","html":"<span class='verse-line'>{}</span>"},"ja485:26.3":{"pli":"Nānādumavasanāyo, ","html":"<span class='verse-line'>{}</span>"},"ja485:26.4":{"pli":"Piyaṁvadā aññamaññassā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja485:27.1":{"pli":"Candakinnarījātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja486":{"ja486:0.1":{"pli":"Jātaka ","html":"<article id='ja486'><header><ul><li class='division'>{}</li>"},"ja486:0.2":{"pli":"Pakiṇṇakanipāta ","html":"<li>{}</li>"},"ja486:0.3":{"pli":"Sālikedāravagga ","html":"<li>{}</li></ul>"},"ja486:0.4":{"pli":"3. Mahāukkusajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja486:1.1":{"pli":"“Ukkā cilācā bandhanti dīpe, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja486:1.2":{"pli":"Pajā mamaṁ khādituṁ patthayanti; ","html":"<span class='verse-line'>{}</span>"},"ja486:1.3":{"pli":"Mittaṁ sahāyañca vadehi senaka, ","html":"<span class='verse-line'>{}</span>"},"ja486:1.4":{"pli":"Ācikkha ñātibyasanaṁ dijānaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja486:2.1":{"pli":"“Dijo dijānaṁ pavarosi pakkhima, ","html":"<p><span class='verse-line'>{}</span>"},"ja486:2.2":{"pli":"Ukkusarāja saraṇaṁ taṁ upema; ","html":"<span class='verse-line'>{}</span>"},"ja486:2.3":{"pli":"Pajā mamaṁ khādituṁ patthayanti, ","html":"<span class='verse-line'>{}</span>"},"ja486:2.4":{"pli":"Luddā cilācā bhava me sukhāya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja486:3.1":{"pli":"“Mittaṁ sahāyañca karonti paṇḍitā, ","html":"<p><span class='verse-line'>{}</span>"},"ja486:3.2":{"pli":"Kāle akāle sukhamesamānā; ","html":"<span class='verse-line'>{}</span>"},"ja486:3.3":{"pli":"Karomi te senaka etamatthaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja486:3.4":{"pli":"Ariyo hi ariyassa karoti kiccaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja486:4.1":{"pli":"“Yaṁ hoti kiccaṁ anukampakena, ","html":"<p><span class='verse-line'>{}</span>"},"ja486:4.2":{"pli":"Ariyassa ariyena kataṁ tayīdaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja486:4.3":{"pli":"Attānurakkhī bhava mā adayhi, ","html":"<span class='verse-line'>{}</span>"},"ja486:4.4":{"pli":"Lacchāma putte tayi jīvamāne”. ","html":"<span class='verse-line'>{}</span></p>"},"ja486:5.1":{"pli":"“Taveva rakkhāvaraṇaṁ karonto, ","html":"<p><span class='verse-line'>{}</span>"},"ja486:5.2":{"pli":"Sarīrabhedāpi na santasāmi; ","html":"<span class='verse-line'>{}</span>"},"ja486:5.3":{"pli":"Karonti heke sakhīnaṁ sakhāro, ","html":"<span class='verse-line'>{}</span>"},"ja486:5.4":{"pli":"Pāṇaṁ cajantā satamesa dhammo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja486:6.1":{"pli":"“Sudukkaraṁ kammamakāsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja486:6.2":{"pli":"aṇḍajāyaṁ vihaṅgamo; ","html":"<span class='verse-line'>{}</span>"},"ja486:6.3":{"pli":"Atthāya kuraro putte, ","html":"<span class='verse-line'>{}</span>"},"ja486:6.4":{"pli":"aḍḍharatte anāgate”. ","html":"<span class='verse-line'>{}</span></p>"},"ja486:7.1":{"pli":"“Cutāpi heke khalitā sakammunā, ","html":"<p><span class='verse-line'>{}</span>"},"ja486:7.2":{"pli":"Mittānukampāya patiṭṭhahanti; ","html":"<span class='verse-line'>{}</span>"},"ja486:7.3":{"pli":"Puttā mamaṭṭā gatimāgatosmi, ","html":"<span class='verse-line'>{}</span>"},"ja486:7.4":{"pli":"Atthaṁ caretho mama vāricara”. ","html":"<span class='verse-line'>{}</span></p>"},"ja486:8.1":{"pli":"“Dhanena dhaññena ca attanā ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja486:8.2":{"pli":"Mittaṁ sahāyañca karonti paṇḍitā; ","html":"<span class='verse-line'>{}</span>"},"ja486:8.3":{"pli":"Karomi te senaka etamatthaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja486:8.4":{"pli":"Ariyo hi ariyassa karoti kiccaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja486:9.1":{"pli":"“Appossukko tāta tuvaṁ nisīda, ","html":"<p><span class='verse-line'>{}</span>"},"ja486:9.2":{"pli":"Putto pitu carati atthacariyaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja486:9.3":{"pli":"Ahaṁ carissāmi tavetamatthaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja486:9.4":{"pli":"Senassa putte paritāyamāno”. ","html":"<span class='verse-line'>{}</span></p>"},"ja486:10.1":{"pli":"“Addhā hi tāta satamesa dhammo, ","html":"<p><span class='verse-line'>{}</span>"},"ja486:10.2":{"pli":"Putto pitu yaṁ care atthacariyaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja486:10.3":{"pli":"Appeva maṁ disvāna pavaḍḍhakāyaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja486:10.4":{"pli":"Senassa puttā na viheṭhayeyyuṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja486:11.1":{"pli":"“Pasū manussā migavīraseṭṭha, ","html":"<p><span class='verse-line'>{}</span>"},"ja486:11.2":{"pli":"Bhayaṭṭitā seṭṭhamupabbajanti; ","html":"<span class='verse-line'>{}</span>"},"ja486:11.3":{"pli":"Puttā mamaṭṭā gatimāgatosmi, ","html":"<span class='verse-line'>{}</span>"},"ja486:11.4":{"pli":"Tvaṁ nosi rājā bhava me sukhāya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja486:12.1":{"pli":"“Karomi te senaka etamatthaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja486:12.2":{"pli":"Āyāmi te taṁ disataṁ vadhāya; ","html":"<span class='verse-line'>{}</span>"},"ja486:12.3":{"pli":"Kathañhi viññū pahu sampajāno, ","html":"<span class='verse-line'>{}</span>"},"ja486:12.4":{"pli":"Na vāyame attajanassa guttiyā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja486:13.1":{"pli":"“Mittañca kayirātha suhadayañca, ","html":"<p><span class='verse-line'>{}</span>"},"ja486:13.2":{"pli":"Ayirañca kayirātha sukhāgamāya; ","html":"<span class='verse-line'>{}</span>"},"ja486:13.3":{"pli":"Nivatthakocova sarebhihantvā, ","html":"<span class='verse-line'>{}</span>"},"ja486:13.4":{"pli":"Modāma puttehi samaṅgibhūtā. ","html":"<span class='verse-line'>{}</span></p>"},"ja486:14.1":{"pli":"Sakamittassa kammena, ","html":"<p><span class='verse-line'>{}</span>"},"ja486:14.2":{"pli":"sahāyassāpalāyino; ","html":"<span class='verse-line'>{}</span>"},"ja486:14.3":{"pli":"Kūjantamupakūjanti, ","html":"<span class='verse-line'>{}</span>"},"ja486:14.4":{"pli":"lomasā hadayaṅgamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja486:15.1":{"pli":"Mittaṁ sahāyaṁ adhigamma paṇḍito, ","html":"<p><span class='verse-line'>{}</span>"},"ja486:15.2":{"pli":"So bhuñjatī putta pasuṁ dhanaṁ vā; ","html":"<span class='verse-line'>{}</span>"},"ja486:15.3":{"pli":"Ahañca puttā ca patī ca mayhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja486:15.4":{"pli":"Mittānukampāya samaṅgibhūtā. ","html":"<span class='verse-line'>{}</span></p>"},"ja486:16.1":{"pli":"Rājavatā sūravatā ca attho, ","html":"<p><span class='verse-line'>{}</span>"},"ja486:16.2":{"pli":"Sampannasakhissa bhavanti hete; ","html":"<span class='verse-line'>{}</span>"},"ja486:16.3":{"pli":"So mittavā yasavā uggatatto, ","html":"<span class='verse-line'>{}</span>"},"ja486:16.4":{"pli":"Asmiṁdhaloke modati kāmakāmī. ","html":"<span class='verse-line'>{}</span></p>"},"ja486:17.1":{"pli":"Karaṇīyāni mittāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja486:17.2":{"pli":"daliddenāpi senaka; ","html":"<span class='verse-line'>{}</span>"},"ja486:17.3":{"pli":"Passa mittānukampāya, ","html":"<span class='verse-line'>{}</span>"},"ja486:17.4":{"pli":"samaggamhā sañātake. ","html":"<span class='verse-line'>{}</span></p>"},"ja486:18.1":{"pli":"Sūrena balavantena, ","html":"<p><span class='verse-line'>{}</span>"},"ja486:18.2":{"pli":"yo mitte kurute dijo; ","html":"<span class='verse-line'>{}</span>"},"ja486:18.3":{"pli":"Evaṁ so sukhito hoti, ","html":"<span class='verse-line'>{}</span>"},"ja486:18.4":{"pli":"yathāhaṁ tvañca senakāti”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja486:19.1":{"pli":"Mahāukkusajātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja487":{"ja487:0.1":{"pli":"Jātaka ","html":"<article id='ja487'><header><ul><li class='division'>{}</li>"},"ja487:0.2":{"pli":"Pakiṇṇakanipāta ","html":"<li>{}</li>"},"ja487:0.3":{"pli":"Sālikedāravagga ","html":"<li>{}</li></ul>"},"ja487:0.4":{"pli":"4. Uddālakajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja487:1.1":{"pli":"“Kharājinā jaṭilā paṅkadantā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja487:1.2":{"pli":"Dummakkharūpā ye mantaṁ jappanti; ","html":"<span class='verse-line'>{}</span>"},"ja487:1.3":{"pli":"Kaccinnu te mānusake payoge, ","html":"<span class='verse-line'>{}</span>"},"ja487:1.4":{"pli":"Idaṁ vidū parimuttā apāyā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja487:2.1":{"pli":"“Pāpāni kammāni karetha rāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja487:2.2":{"pli":"Bahussuto ce na careyya dhammaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja487:2.3":{"pli":"Sahassavedopi na taṁ paṭicca, ","html":"<span class='verse-line'>{}</span>"},"ja487:2.4":{"pli":"Dukkhā pamucce caraṇaṁ apatvā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja487:3.1":{"pli":"“Sahassavedopi na taṁ paṭicca, ","html":"<p><span class='verse-line'>{}</span>"},"ja487:3.2":{"pli":"Dukkhā pamucce caraṇaṁ apatvā; ","html":"<span class='verse-line'>{}</span>"},"ja487:3.3":{"pli":"Maññāmi vedā aphalā bhavanti, ","html":"<span class='verse-line'>{}</span>"},"ja487:3.4":{"pli":"Sasaṁyamaṁ caraṇaññeva saccaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja487:4.1":{"pli":"“Na heva vedā aphalā bhavanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja487:4.2":{"pli":"Sasaṁyamaṁ caraṇaññeva saccaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja487:4.3":{"pli":"Kittiñhi pappoti adhicca vede, ","html":"<span class='verse-line'>{}</span>"},"ja487:4.4":{"pli":"Santiṁ puṇāti caraṇena danto”. ","html":"<span class='verse-line'>{}</span></p>"},"ja487:5.1":{"pli":"“Bhaccā mātā pitā bandhū, ","html":"<p><span class='verse-line'>{}</span>"},"ja487:5.2":{"pli":"yena jāto sayeva so; ","html":"<span class='verse-line'>{}</span>"},"ja487:5.3":{"pli":"Uddālako ahaṁ bhoto, ","html":"<span class='verse-line'>{}</span>"},"ja487:5.4":{"pli":"sottiyākulavaṁsako”. ","html":"<span class='verse-line'>{}</span></p>"},"ja487:6.1":{"pli":"“Kathaṁ bho brāhmaṇo hoti, ","html":"<p><span class='verse-line'>{}</span>"},"ja487:6.2":{"pli":"kathaṁ bhavati kevalī; ","html":"<span class='verse-line'>{}</span>"},"ja487:6.3":{"pli":"Kathañca parinibbānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja487:6.4":{"pli":"dhammaṭṭho kinti vuccati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja487:7.1":{"pli":"“Niraṅkatvā aggimādāya brāhmaṇo, ","html":"<p><span class='verse-line'>{}</span>"},"ja487:7.2":{"pli":"Āpo siñcaṁ yajaṁ usseti yūpaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja487:7.3":{"pli":"Evaṅkaro brāhmaṇo hoti khemī, ","html":"<span class='verse-line'>{}</span>"},"ja487:7.4":{"pli":"Dhamme ṭhitaṁ tena amāpayiṁsu”. ","html":"<span class='verse-line'>{}</span></p>"},"ja487:8.1":{"pli":"“Na suddhi secanenatthi, ","html":"<p><span class='verse-line'>{}</span>"},"ja487:8.2":{"pli":"nāpi kevalī brāhmaṇo; ","html":"<span class='verse-line'>{}</span>"},"ja487:8.3":{"pli":"Na khantī nāpi soraccaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja487:8.4":{"pli":"nāpi so parinibbuto”. ","html":"<span class='verse-line'>{}</span></p>"},"ja487:9.1":{"pli":"“Kathaṁ so brāhmaṇo hoti, ","html":"<p><span class='verse-line'>{}</span>"},"ja487:9.2":{"pli":"kathaṁ bhavati kevalī; ","html":"<span class='verse-line'>{}</span>"},"ja487:9.3":{"pli":"Kathañca parinibbānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja487:9.4":{"pli":"dhammaṭṭho kinti vuccati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja487:10.1":{"pli":"“Akhettabandhū amamo nirāso, ","html":"<p><span class='verse-line'>{}</span>"},"ja487:10.2":{"pli":"Nillobhapāpo bhavalobhakhīṇo; ","html":"<span class='verse-line'>{}</span>"},"ja487:10.3":{"pli":"Evaṅkaro brāhmaṇo hoti khemī, ","html":"<span class='verse-line'>{}</span>"},"ja487:10.4":{"pli":"Dhamme ṭhitaṁ tena amāpayiṁsu”. ","html":"<span class='verse-line'>{}</span></p>"},"ja487:11.1":{"pli":"“Khattiyā brāhmaṇā vessā, ","html":"<p><span class='verse-line'>{}</span>"},"ja487:11.2":{"pli":"suddā caṇḍālapukkusā; ","html":"<span class='verse-line'>{}</span>"},"ja487:11.3":{"pli":"Sabbeva soratā dantā, ","html":"<span class='verse-line'>{}</span>"},"ja487:11.4":{"pli":"sabbeva parinibbutā; ","html":"<span class='verse-line'>{}</span>"},"ja487:11.5":{"pli":"Sabbesaṁ sītibhūtānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja487:11.6":{"pli":"atthi seyyotha pāpiyo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja487:12.1":{"pli":"“Khattiyā brāhmaṇā vessā, ","html":"<p><span class='verse-line'>{}</span>"},"ja487:12.2":{"pli":"suddā caṇḍālapukkusā; ","html":"<span class='verse-line'>{}</span>"},"ja487:12.3":{"pli":"Sabbeva soratā dantā, ","html":"<span class='verse-line'>{}</span>"},"ja487:12.4":{"pli":"sabbeva parinibbutā; ","html":"<span class='verse-line'>{}</span>"},"ja487:12.5":{"pli":"Sabbesaṁ sītibhūtānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja487:12.6":{"pli":"natthi seyyotha pāpiyo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja487:13.1":{"pli":"“Khattiyā brāhmaṇā vessā, ","html":"<p><span class='verse-line'>{}</span>"},"ja487:13.2":{"pli":"suddā caṇḍālapukkusā; ","html":"<span class='verse-line'>{}</span>"},"ja487:13.3":{"pli":"Sabbeva soratā dantā, ","html":"<span class='verse-line'>{}</span>"},"ja487:13.4":{"pli":"sabbeva parinibbutā. ","html":"<span class='verse-line'>{}</span></p>"},"ja487:14.1":{"pli":"Sabbesaṁ sītibhūtānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja487:14.2":{"pli":"Natthi seyyotha pāpiyo; ","html":"<span class='verse-line'>{}</span>"},"ja487:14.3":{"pli":"Panatthaṁ carasi brahmaññaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja487:14.4":{"pli":"Sottiyākulavaṁsataṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja487:15.1":{"pli":"“Nānārattehi vatthehi, ","html":"<p><span class='verse-line'>{}</span>"},"ja487:15.2":{"pli":"vimānaṁ bhavati chāditaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja487:15.3":{"pli":"Na tesaṁ chāyā vatthānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja487:15.4":{"pli":"so rāgo anupajjatha. ","html":"<span class='verse-line'>{}</span></p>"},"ja487:16.1":{"pli":"Evameva manussesu, ","html":"<p><span class='verse-line'>{}</span>"},"ja487:16.2":{"pli":"yadā sujjhanti māṇavā; ","html":"<span class='verse-line'>{}</span>"},"ja487:16.3":{"pli":"Te sajātiṁ pamuñcanti, ","html":"<span class='verse-line'>{}</span>"},"ja487:16.4":{"pli":"dhammamaññāya subbatā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja487:17.1":{"pli":"Uddālakajātakaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}