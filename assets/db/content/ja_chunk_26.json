{"ja500":{"ja500:0.1":{"pli":"Jātaka ","html":"<article id='ja500'><header><ul><li class='division'>{}</li>"},"ja500:0.2":{"pli":"Vīsatinipāta ","html":"<li>{}</li>"},"ja500:0.3":{"pli":"Mātaṅgavagga ","html":"<li>{}</li></ul>"},"ja500:0.4":{"pli":"4. Sirīmantajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja500:1.1":{"pli":"“Paññāyupetaṁ siriyā vihīnaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja500:1.2":{"pli":"Yasassinaṁ vāpi apetapaññaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja500:1.3":{"pli":"Pucchāmi taṁ senaka etamatthaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja500:1.4":{"pli":"Kamettha seyyo kusalā vadanti”. ","html":"<span class='verse-line'>{}</span></p>"},"ja500:2.1":{"pli":"“Dhīrā ca bālā ca have janinda, ","html":"<p><span class='verse-line'>{}</span>"},"ja500:2.2":{"pli":"Sippūpapannā ca asippino ca; ","html":"<span class='verse-line'>{}</span>"},"ja500:2.3":{"pli":"Sujātimantopi ajātimassa, ","html":"<span class='verse-line'>{}</span>"},"ja500:2.4":{"pli":"Yasassino pesakarā bhavanti; ","html":"<span class='verse-line'>{}</span>"},"ja500:2.5":{"pli":"Etampi disvāna ahaṁ vadāmi, ","html":"<span class='verse-line'>{}</span>"},"ja500:2.6":{"pli":"Pañño nihīno sirīmāva seyyo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja500:3.1":{"pli":"“Tuvampi pucchāmi anomapañña, ","html":"<p><span class='verse-line'>{}</span>"},"ja500:3.2":{"pli":"Mahosadha kevaladhammadassi; ","html":"<span class='verse-line'>{}</span>"},"ja500:3.3":{"pli":"Bālaṁ yasassiṁ paṇḍitaṁ appabhogaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja500:3.4":{"pli":"Kamettha seyyo kusalā vadanti”. ","html":"<span class='verse-line'>{}</span></p>"},"ja500:4.1":{"pli":"“Pāpāni kammāni karoti bālo, ","html":"<p><span class='verse-line'>{}</span>"},"ja500:4.2":{"pli":"Idhameva seyyo iti maññamāno; ","html":"<span class='verse-line'>{}</span>"},"ja500:4.3":{"pli":"Idhalokadassī paralokamadassī, ","html":"<span class='verse-line'>{}</span>"},"ja500:4.4":{"pli":"Ubhayattha bālo kalimaggahesi; ","html":"<span class='verse-line'>{}</span>"},"ja500:4.5":{"pli":"Etampi disvāna ahaṁ vadāmi, ","html":"<span class='verse-line'>{}</span>"},"ja500:4.6":{"pli":"Paññova seyyo na yasassi bālo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja500:5.1":{"pli":"“Na sippametaṁ vidadhāti bhogaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja500:5.2":{"pli":"Na bandhuvā na sarīravaṇṇo yo; ","html":"<span class='verse-line'>{}</span>"},"ja500:5.3":{"pli":"Passeḷamūgaṁ sukhamedhamānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja500:5.4":{"pli":"Sirī hi naṁ bhajate goravindaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja500:5.5":{"pli":"Etampi disvāna ahaṁ vadāmi, ","html":"<span class='verse-line'>{}</span>"},"ja500:5.6":{"pli":"Pañño nihīno sirīmāva seyyo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja500:6.1":{"pli":"“Laddhā sukhaṁ majjati appapañño, ","html":"<p><span class='verse-line'>{}</span>"},"ja500:6.2":{"pli":"Dukkhena phuṭṭhopi pamohameti; ","html":"<span class='verse-line'>{}</span>"},"ja500:6.3":{"pli":"Āgantunā dukkhasukhena phuṭṭho, ","html":"<span class='verse-line'>{}</span>"},"ja500:6.4":{"pli":"Pavedhati vāricarova ghamme; ","html":"<span class='verse-line'>{}</span>"},"ja500:6.5":{"pli":"Etampi disvāna ahaṁ vadāmi, ","html":"<span class='verse-line'>{}</span>"},"ja500:6.6":{"pli":"Paññova seyyo na yasassi bālo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja500:7.1":{"pli":"“Dumaṁ yathā sāduphalaṁ araññe, ","html":"<p><span class='verse-line'>{}</span>"},"ja500:7.2":{"pli":"Samantato samabhisaranti pakkhī; ","html":"<span class='verse-line'>{}</span>"},"ja500:7.3":{"pli":"Evampi aḍḍhaṁ sadhanaṁ sabhogaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja500:7.4":{"pli":"Bahujjano bhajati atthahetu; ","html":"<span class='verse-line'>{}</span>"},"ja500:7.5":{"pli":"Etampi disvāna ahaṁ vadāmi, ","html":"<span class='verse-line'>{}</span>"},"ja500:7.6":{"pli":"Pañño nihīno sirīmāva seyyo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja500:8.1":{"pli":"“Na sādhu balavā bālo, ","html":"<p><span class='verse-line'>{}</span>"},"ja500:8.2":{"pli":"Sāhasā vindate dhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja500:8.3":{"pli":"Kandantametaṁ dummedhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja500:8.4":{"pli":"Kaḍḍhanti nirayaṁ bhusaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja500:8.5":{"pli":"Etampi disvāna ahaṁ vadāmi, ","html":"<span class='verse-line'>{}</span>"},"ja500:8.6":{"pli":"Paññova seyyo na yasassi bālo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja500:9.1":{"pli":"“Yā kāci najjo gaṅgamabhissavanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja500:9.2":{"pli":"Sabbāva tā nāmagottaṁ jahanti; ","html":"<span class='verse-line'>{}</span>"},"ja500:9.3":{"pli":"Gaṅgā samuddaṁ paṭipajjamānā, ","html":"<span class='verse-line'>{}</span>"},"ja500:9.4":{"pli":"Na khāyate iddhiṁ paññopi loke; ","html":"<span class='verse-line'>{}</span>"},"ja500:9.5":{"pli":"Etampi disvāna ahaṁ vadāmi, ","html":"<span class='verse-line'>{}</span>"},"ja500:9.6":{"pli":"Pañño nihīno sirīmāva seyyo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja500:10.1":{"pli":"“Yametamakkhā udadhiṁ mahantaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja500:10.2":{"pli":"Savanti najjo sabbakālamasaṅkhyaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja500:10.3":{"pli":"So sāgaro niccamuḷāravego, ","html":"<span class='verse-line'>{}</span>"},"ja500:10.4":{"pli":"Velaṁ na acceti mahāsamuddo. ","html":"<span class='verse-line'>{}</span></p>"},"ja500:11.1":{"pli":"Evampi bālassa pajappitāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja500:11.2":{"pli":"Paññaṁ na acceti sirī kadāci; ","html":"<span class='verse-line'>{}</span>"},"ja500:11.3":{"pli":"Etampi disvāna ahaṁ vadāmi, ","html":"<span class='verse-line'>{}</span>"},"ja500:11.4":{"pli":"Paññova seyyo na yasassi bālo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja500:12.1":{"pli":"“Asaññato cepi paresamatthaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja500:12.2":{"pli":"Bhaṇāti sandhānagato yasassī; ","html":"<span class='verse-line'>{}</span>"},"ja500:12.3":{"pli":"Tasseva taṁ rūhati ñātimajjhe, ","html":"<span class='verse-line'>{}</span>"},"ja500:12.4":{"pli":"Sirī hi naṁ kārayate na paññā; ","html":"<span class='verse-line'>{}</span>"},"ja500:12.5":{"pli":"Etampi disvāna ahaṁ vadāmi, ","html":"<span class='verse-line'>{}</span>"},"ja500:12.6":{"pli":"Pañño nihīno sirīmāva seyyo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja500:13.1":{"pli":"“Parassa vā attano vāpi hetu, ","html":"<p><span class='verse-line'>{}</span>"},"ja500:13.2":{"pli":"Bālo musā bhāsati appapañño; ","html":"<span class='verse-line'>{}</span>"},"ja500:13.3":{"pli":"So nindito hoti sabhāya majjhe, ","html":"<span class='verse-line'>{}</span>"},"ja500:13.4":{"pli":"Pacchāpi so duggatigāmī hoti; ","html":"<span class='verse-line'>{}</span>"},"ja500:13.5":{"pli":"Etampi disvāna ahaṁ vadāmi, ","html":"<span class='verse-line'>{}</span>"},"ja500:13.6":{"pli":"Paññova seyyo na yasassi bālo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja500:14.1":{"pli":"“Atthampi ce bhāsati bhūripañño, ","html":"<p><span class='verse-line'>{}</span>"},"ja500:14.2":{"pli":"Anāḷhiyo appadhano daliddo; ","html":"<span class='verse-line'>{}</span>"},"ja500:14.3":{"pli":"Na tassa taṁ rūhati ñātimajjhe, ","html":"<span class='verse-line'>{}</span>"},"ja500:14.4":{"pli":"Sirī ca paññāṇavato na hoti; ","html":"<span class='verse-line'>{}</span>"},"ja500:14.5":{"pli":"Etampi disvāna ahaṁ vadāmi, ","html":"<span class='verse-line'>{}</span>"},"ja500:14.6":{"pli":"Pañño nihīno sirīmāva seyyo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja500:15.1":{"pli":"“Parassa vā attano vāpi hetu, ","html":"<p><span class='verse-line'>{}</span>"},"ja500:15.2":{"pli":"Na bhāsati alikaṁ bhūripañño; ","html":"<span class='verse-line'>{}</span>"},"ja500:15.3":{"pli":"So pūjito hoti sabhāya majjhe, ","html":"<span class='verse-line'>{}</span>"},"ja500:15.4":{"pli":"Pacchāpi so suggatigāmī hoti; ","html":"<span class='verse-line'>{}</span>"},"ja500:15.5":{"pli":"Etampi disvāna ahaṁ vadāmi, ","html":"<span class='verse-line'>{}</span>"},"ja500:15.6":{"pli":"Paññova seyyo na yasassi bālo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja500:16.1":{"pli":"“Hatthī gavassā maṇikuṇḍalā ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja500:16.2":{"pli":"Thiyo ca iddhesu kulesu jātā; ","html":"<span class='verse-line'>{}</span>"},"ja500:16.3":{"pli":"Sabbāva tā upabhogā bhavanti, ","html":"<span class='verse-line'>{}</span>"},"ja500:16.4":{"pli":"Iddhassa posassa aniddhimanto; ","html":"<span class='verse-line'>{}</span>"},"ja500:16.5":{"pli":"Etampi disvāna ahaṁ vadāmi, ","html":"<span class='verse-line'>{}</span>"},"ja500:16.6":{"pli":"Pañño nihīno sirīmāva seyyo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja500:17.1":{"pli":"“Asaṁvihitakammantaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja500:17.2":{"pli":"Bālaṁ dummedhamantinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja500:17.3":{"pli":"Sirī jahati dummedhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja500:17.4":{"pli":"Jiṇṇaṁva urago tacaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja500:17.5":{"pli":"Etampi disvāna ahaṁ vadāmi, ","html":"<span class='verse-line'>{}</span>"},"ja500:17.6":{"pli":"Paññova seyyo na yasassi bālo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja500:18.1":{"pli":"“Pañca paṇḍitā mayaṁ bhaddante, ","html":"<p><span class='verse-line'>{}</span>"},"ja500:18.2":{"pli":"Sabbe pañjalikā upaṭṭhitā; ","html":"<span class='verse-line'>{}</span>"},"ja500:18.3":{"pli":"Tvaṁ no abhibhuyya issarosi, ","html":"<span class='verse-line'>{}</span>"},"ja500:18.4":{"pli":"Sakkova bhūtapati devarājā; ","html":"<span class='verse-line'>{}</span>"},"ja500:18.5":{"pli":"Etampi disvāna ahaṁ vadāmi, ","html":"<span class='verse-line'>{}</span>"},"ja500:18.6":{"pli":"Pañño nihīno sirīmāva seyyo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja500:19.1":{"pli":"“Dāsova paññassa yasassi bālo, ","html":"<p><span class='verse-line'>{}</span>"},"ja500:19.2":{"pli":"Atthesu jātesu tathāvidhesu; ","html":"<span class='verse-line'>{}</span>"},"ja500:19.3":{"pli":"Yaṁ paṇḍito nipuṇaṁ saṁvidheti, ","html":"<span class='verse-line'>{}</span>"},"ja500:19.4":{"pli":"Sammohamāpajjati tattha bālo; ","html":"<span class='verse-line'>{}</span>"},"ja500:19.5":{"pli":"Etampi disvāna ahaṁ vadāmi, ","html":"<span class='verse-line'>{}</span>"},"ja500:19.6":{"pli":"Paññova seyyo na yasassi bālo. ","html":"<span class='verse-line'>{}</span></p>"},"ja500:20.1":{"pli":"Addhā hi paññāva sataṁ pasatthā, ","html":"<p><span class='verse-line'>{}</span>"},"ja500:20.2":{"pli":"Kantā sirī bhogaratā manussā; ","html":"<span class='verse-line'>{}</span>"},"ja500:20.3":{"pli":"Ñāṇañca buddhānamatulyarūpaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja500:20.4":{"pli":"Paññaṁ na acceti sirī kadāci”. ","html":"<span class='verse-line'>{}</span></p>"},"ja500:21.1":{"pli":"“Yaṁ taṁ apucchimha akittayī no, ","html":"<p><span class='verse-line'>{}</span>"},"ja500:21.2":{"pli":"Mahosadha kevaladhammadassī; ","html":"<span class='verse-line'>{}</span>"},"ja500:21.3":{"pli":"Gavaṁ sahassaṁ usabhañca nāgaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja500:21.4":{"pli":"Ājaññayutte ca rathe dasa ime; ","html":"<span class='verse-line'>{}</span>"},"ja500:21.5":{"pli":"Pañhassa veyyākaraṇena tuṭṭho, ","html":"<span class='verse-line'>{}</span>"},"ja500:21.6":{"pli":"Dadāmi te gāmavarāni soḷasā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja500:22.1":{"pli":"Sirīmantajātakaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja501":{"ja501:0.1":{"pli":"Jātaka ","html":"<article id='ja501'><header><ul><li class='division'>{}</li>"},"ja501:0.2":{"pli":"Vīsatinipāta ","html":"<li>{}</li>"},"ja501:0.3":{"pli":"Mātaṅgavagga ","html":"<li>{}</li></ul>"},"ja501:0.4":{"pli":"5. Rohaṇamigajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja501:1.1":{"pli":"“Ete yūthā patiyanti, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja501:1.2":{"pli":"bhītā maraṇassa cittaka; ","html":"<span class='verse-line'>{}</span>"},"ja501:1.3":{"pli":"Gaccha tuvampi mākaṅkhi, ","html":"<span class='verse-line'>{}</span>"},"ja501:1.4":{"pli":"jīvissanti tayā saha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja501:2.1":{"pli":"“Nāhaṁ rohaṇa gacchāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja501:2.2":{"pli":"hadayaṁ me avakassati; ","html":"<span class='verse-line'>{}</span>"},"ja501:2.3":{"pli":"Na taṁ ahaṁ jahissāmi, ","html":"<span class='verse-line'>{}</span>"},"ja501:2.4":{"pli":"idha hissāmi jīvitaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja501:3.1":{"pli":"“Te hi nūna marissanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja501:3.2":{"pli":"andhā apariṇāyakā; ","html":"<span class='verse-line'>{}</span>"},"ja501:3.3":{"pli":"Gaccha tuvampi mākaṅkhi, ","html":"<span class='verse-line'>{}</span>"},"ja501:3.4":{"pli":"jīvissanti tayā saha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja501:4.1":{"pli":"“Nāhaṁ rohaṇa gacchāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja501:4.2":{"pli":"hadayaṁ me avakassati; ","html":"<span class='verse-line'>{}</span>"},"ja501:4.3":{"pli":"Na taṁ baddhaṁ jahissāmi, ","html":"<span class='verse-line'>{}</span>"},"ja501:4.4":{"pli":"idha hissāmi jīvitaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja501:5.1":{"pli":"“Gaccha bhīru palāyassu, ","html":"<p><span class='verse-line'>{}</span>"},"ja501:5.2":{"pli":"kūṭe baddhosmi āyase; ","html":"<span class='verse-line'>{}</span>"},"ja501:5.3":{"pli":"Gaccha tuvampi mākaṅkhi, ","html":"<span class='verse-line'>{}</span>"},"ja501:5.4":{"pli":"jīvissanti tayā saha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja501:6.1":{"pli":"“Nāhaṁ rohaṇa gacchāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja501:6.2":{"pli":"hadayaṁ me avakassati; ","html":"<span class='verse-line'>{}</span>"},"ja501:6.3":{"pli":"Na taṁ ahaṁ jahissāmi, ","html":"<span class='verse-line'>{}</span>"},"ja501:6.4":{"pli":"idha hissāmi jīvitaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja501:7.1":{"pli":"“Te hi nūna marissanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja501:7.2":{"pli":"andhā apariṇāyakā; ","html":"<span class='verse-line'>{}</span>"},"ja501:7.3":{"pli":"Gaccha tuvampi mākaṅkhi, ","html":"<span class='verse-line'>{}</span>"},"ja501:7.4":{"pli":"jīvissanti tayā saha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja501:8.1":{"pli":"“Nāhaṁ rohaṇa gacchāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja501:8.2":{"pli":"hadayaṁ me avakassati; ","html":"<span class='verse-line'>{}</span>"},"ja501:8.3":{"pli":"Na taṁ baddhaṁ jahissāmi, ","html":"<span class='verse-line'>{}</span>"},"ja501:8.4":{"pli":"idha hissāmi jīvitaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja501:9.1":{"pli":"“Ayaṁ so luddako eti, ","html":"<p><span class='verse-line'>{}</span>"},"ja501:9.2":{"pli":"luddarūpo sahāvudho; ","html":"<span class='verse-line'>{}</span>"},"ja501:9.3":{"pli":"Yo no vadhissati ajja, ","html":"<span class='verse-line'>{}</span>"},"ja501:9.4":{"pli":"usunā sattiyā api”. ","html":"<span class='verse-line'>{}</span></p>"},"ja501:10.1":{"pli":"“Sā muhuttaṁ palāyitvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja501:10.2":{"pli":"bhayaṭṭā bhayatajjitā; ","html":"<span class='verse-line'>{}</span>"},"ja501:10.3":{"pli":"Sudukkaraṁ akarā bhīru, ","html":"<span class='verse-line'>{}</span>"},"ja501:10.4":{"pli":"maraṇāyūpanivattatha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja501:11.1":{"pli":"“Kiṁ nu teme migā honti, ","html":"<p><span class='verse-line'>{}</span>"},"ja501:11.2":{"pli":"muttā baddhaṁ upāsare; ","html":"<span class='verse-line'>{}</span>"},"ja501:11.3":{"pli":"Na taṁ cajitumicchanti, ","html":"<span class='verse-line'>{}</span>"},"ja501:11.4":{"pli":"jīvitassapi kāraṇā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja501:12.1":{"pli":"“Bhātaro honti me ludda, ","html":"<p><span class='verse-line'>{}</span>"},"ja501:12.2":{"pli":"sodariyā ekamātukā; ","html":"<span class='verse-line'>{}</span>"},"ja501:12.3":{"pli":"Na maṁ cajitumicchanti, ","html":"<span class='verse-line'>{}</span>"},"ja501:12.4":{"pli":"jīvitassapi kāraṇā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja501:13.1":{"pli":"“Te hi nūna marissanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja501:13.2":{"pli":"andhā apariṇāyakā; ","html":"<span class='verse-line'>{}</span>"},"ja501:13.3":{"pli":"Pañcannaṁ jīvitaṁ dehi, ","html":"<span class='verse-line'>{}</span>"},"ja501:13.4":{"pli":"bhātaraṁ muñca luddaka”. ","html":"<span class='verse-line'>{}</span></p>"},"ja501:14.1":{"pli":"“So vo ahaṁ pamokkhāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja501:14.2":{"pli":"mātāpettibharaṁ migaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja501:14.3":{"pli":"Nandantu mātāpitaro, ","html":"<span class='verse-line'>{}</span>"},"ja501:14.4":{"pli":"muttaṁ disvā mahāmigaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja501:15.1":{"pli":"“Evaṁ luddaka nandassu, ","html":"<p><span class='verse-line'>{}</span>"},"ja501:15.2":{"pli":"saha sabbehi ñātibhi; ","html":"<span class='verse-line'>{}</span>"},"ja501:15.3":{"pli":"Yathāhamajja nandāmi, ","html":"<span class='verse-line'>{}</span>"},"ja501:15.4":{"pli":"muttaṁ disvā mahāmigaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja501:16.1":{"pli":"“Kathaṁ tvaṁ pamokkho āsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja501:16.2":{"pli":"Upanītasmi jīvite; ","html":"<span class='verse-line'>{}</span>"},"ja501:16.3":{"pli":"Kathaṁ putta amocesi, ","html":"<span class='verse-line'>{}</span>"},"ja501:16.4":{"pli":"Kūṭapāsamha luddako”. ","html":"<span class='verse-line'>{}</span></p>"},"ja501:17.1":{"pli":"“Bhaṇaṁ kaṇṇasukhaṁ vācaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja501:17.2":{"pli":"hadayaṅgaṁ hadayassitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja501:17.3":{"pli":"Subhāsitāhi vācāhi, ","html":"<span class='verse-line'>{}</span>"},"ja501:17.4":{"pli":"cittako maṁ amocayi. ","html":"<span class='verse-line'>{}</span></p>"},"ja501:18.1":{"pli":"Bhaṇaṁ kaṇṇasukhaṁ vācaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja501:18.2":{"pli":"hadayaṅgaṁ hadayassitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja501:18.3":{"pli":"Subhāsitāhi vācāhi, ","html":"<span class='verse-line'>{}</span>"},"ja501:18.4":{"pli":"sutanā maṁ amocayi. ","html":"<span class='verse-line'>{}</span></p>"},"ja501:19.1":{"pli":"Sutvā kaṇṇasukhaṁ vācaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja501:19.2":{"pli":"hadayaṅgaṁ hadayassitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja501:19.3":{"pli":"Subhāsitāni sutvāna, ","html":"<span class='verse-line'>{}</span>"},"ja501:19.4":{"pli":"luddako maṁ amocayi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja501:20.1":{"pli":"“Evaṁ ānandito hotu, ","html":"<p><span class='verse-line'>{}</span>"},"ja501:20.2":{"pli":"saha dārehi luddako; ","html":"<span class='verse-line'>{}</span>"},"ja501:20.3":{"pli":"Yathā mayajja nandāma, ","html":"<span class='verse-line'>{}</span>"},"ja501:20.4":{"pli":"disvā rohaṇamāgataṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja501:21.1":{"pli":"“Nanu tvaṁ avaca ludda, ","html":"<p><span class='verse-line'>{}</span>"},"ja501:21.2":{"pli":"‘migacammāni āhariṁ’; ","html":"<span class='verse-line'>{}</span>"},"ja501:21.3":{"pli":"Atha kena nu vaṇṇena, ","html":"<span class='verse-line'>{}</span>"},"ja501:21.4":{"pli":"migacammāni nāhari”. ","html":"<span class='verse-line'>{}</span></p>"},"ja501:22.1":{"pli":"“Āgamā ceva hatthatthaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja501:22.2":{"pli":"kūṭapāsañca so migo; ","html":"<span class='verse-line'>{}</span>"},"ja501:22.3":{"pli":"Abajjhi taṁ migarājaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja501:22.4":{"pli":"tañca muttā upāsare. ","html":"<span class='verse-line'>{}</span></p>"},"ja501:23.1":{"pli":"Tassa me ahu saṁvego, ","html":"<p><span class='verse-line'>{}</span>"},"ja501:23.2":{"pli":"abbhuto lomahaṁsano; ","html":"<span class='verse-line'>{}</span>"},"ja501:23.3":{"pli":"Imañcāhaṁ migaṁ haññe, ","html":"<span class='verse-line'>{}</span>"},"ja501:23.4":{"pli":"ajja hissāmi jīvitaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja501:24.1":{"pli":"“Kīdisā te migā ludda, ","html":"<p><span class='verse-line'>{}</span>"},"ja501:24.2":{"pli":"kīdisā dhammikā migā; ","html":"<span class='verse-line'>{}</span>"},"ja501:24.3":{"pli":"Kathaṁvaṇṇā kathaṁsīlā, ","html":"<span class='verse-line'>{}</span>"},"ja501:24.4":{"pli":"bāḷhaṁ kho ne pasaṁsasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja501:25.1":{"pli":"“Odātasiṅgā sucivālā, ","html":"<p><span class='verse-line'>{}</span>"},"ja501:25.2":{"pli":"jātarūpatacūpamā; ","html":"<span class='verse-line'>{}</span>"},"ja501:25.3":{"pli":"Pādā lohitakā tesaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja501:25.4":{"pli":"añjitakkhā manoramā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja501:26.1":{"pli":"“Edisā te migā deva, ","html":"<p><span class='verse-line'>{}</span>"},"ja501:26.2":{"pli":"edisā dhammikā migā; ","html":"<span class='verse-line'>{}</span>"},"ja501:26.3":{"pli":"Mātāpettibharā deva, ","html":"<span class='verse-line'>{}</span>"},"ja501:26.4":{"pli":"na te so abhihārituṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja501:27.1":{"pli":"“Dammi nikkhasataṁ ludda, ","html":"<p><span class='verse-line'>{}</span>"},"ja501:27.2":{"pli":"thūlañca maṇikuṇḍalaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja501:27.3":{"pli":"Catussadañca pallaṅkaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja501:27.4":{"pli":"umāpupphasarinnibhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja501:28.1":{"pli":"Dve ca sādisiyo bhariyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja501:28.2":{"pli":"usabhañca gavaṁ sataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja501:28.3":{"pli":"Dhammena rajjaṁ kāressaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja501:28.4":{"pli":"bahukāro mesi luddaka. ","html":"<span class='verse-line'>{}</span></p>"},"ja501:29.1":{"pli":"Kasivāṇijjā iṇadānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja501:29.2":{"pli":"uñchācariyā ca luddaka; ","html":"<span class='verse-line'>{}</span>"},"ja501:29.3":{"pli":"Etena dāraṁ posehi, ","html":"<span class='verse-line'>{}</span>"},"ja501:29.4":{"pli":"mā pāpaṁ akarī punāti”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja501:30.1":{"pli":"Rohaṇamigajātakaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja502":{"ja502:0.1":{"pli":"Jātaka ","html":"<article id='ja502'><header><ul><li class='division'>{}</li>"},"ja502:0.2":{"pli":"Vīsatinipāta ","html":"<li>{}</li>"},"ja502:0.3":{"pli":"Mātaṅgavagga ","html":"<li>{}</li></ul>"},"ja502:0.4":{"pli":"6. Cūḷahaṁsajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja502:1.1":{"pli":"“Ete haṁsā pakkamanti, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja502:1.2":{"pli":"vakkaṅgā bhayameritā; ","html":"<span class='verse-line'>{}</span>"},"ja502:1.3":{"pli":"Harittaca hemavaṇṇa, ","html":"<span class='verse-line'>{}</span>"},"ja502:1.4":{"pli":"kāmaṁ sumukha pakkama. ","html":"<span class='verse-line'>{}</span></p>"},"ja502:2.1":{"pli":"Ohāya maṁ ñātigaṇā, ","html":"<p><span class='verse-line'>{}</span>"},"ja502:2.2":{"pli":"ekaṁ pāsavasaṁ gataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja502:2.3":{"pli":"Anapekkhamānā gacchanti, ","html":"<span class='verse-line'>{}</span>"},"ja502:2.4":{"pli":"kiṁ eko avahiyyasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja502:3.1":{"pli":"Pateva patataṁ seṭṭha, ","html":"<p><span class='verse-line'>{}</span>"},"ja502:3.2":{"pli":"natthi baddhe sahāyatā; ","html":"<span class='verse-line'>{}</span>"},"ja502:3.3":{"pli":"Mā anīghāya hāpesi, ","html":"<span class='verse-line'>{}</span>"},"ja502:3.4":{"pli":"kāmaṁ sumukha pakkama”. ","html":"<span class='verse-line'>{}</span></p>"},"ja502:4.1":{"pli":"“Nāhaṁ ‘dukkhapareto’ti, ","html":"<p><span class='verse-line'>{}</span>"},"ja502:4.2":{"pli":"dhataraṭṭha tuvaṁ jahe; ","html":"<span class='verse-line'>{}</span>"},"ja502:4.3":{"pli":"Jīvitaṁ maraṇaṁ vā me, ","html":"<span class='verse-line'>{}</span>"},"ja502:4.4":{"pli":"tayā saddhiṁ bhavissati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja502:5.1":{"pli":"“Etadariyassa kalyāṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja502:5.2":{"pli":"yaṁ tvaṁ sumukha bhāsasi; ","html":"<span class='verse-line'>{}</span>"},"ja502:5.3":{"pli":"Tañca vīmaṁsamānohaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja502:5.4":{"pli":"‘patatetaṁ’ avassajiṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja502:6.1":{"pli":"“Apadena padaṁ yāti, ","html":"<p><span class='verse-line'>{}</span>"},"ja502:6.2":{"pli":"antalikkhacaro dijo; ","html":"<span class='verse-line'>{}</span>"},"ja502:6.3":{"pli":"Ārā pāsaṁ na bujjhi tvaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja502:6.4":{"pli":"haṁsānaṁ pavaruttama”. ","html":"<span class='verse-line'>{}</span></p>"},"ja502:7.1":{"pli":"“Yadā parābhavo hoti, ","html":"<p><span class='verse-line'>{}</span>"},"ja502:7.2":{"pli":"poso jīvitasaṅkhaye; ","html":"<span class='verse-line'>{}</span>"},"ja502:7.3":{"pli":"Atha jālañca pāsañca, ","html":"<span class='verse-line'>{}</span>"},"ja502:7.4":{"pli":"āsajjāpi na bujjhati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja502:8.1":{"pli":"“Ete haṁsā pakkamanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja502:8.2":{"pli":"vakkaṅgā bhayameritā; ","html":"<span class='verse-line'>{}</span>"},"ja502:8.3":{"pli":"Harittaca hemavaṇṇa, ","html":"<span class='verse-line'>{}</span>"},"ja502:8.4":{"pli":"tvaññeva avahiyyasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja502:9.1":{"pli":"Ete bhutvā ca pitvā ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja502:9.2":{"pli":"pakkamanti vihaṅgamā; ","html":"<span class='verse-line'>{}</span>"},"ja502:9.3":{"pli":"Anapekkhamānā vakkaṅgā, ","html":"<span class='verse-line'>{}</span>"},"ja502:9.4":{"pli":"tvaññeveko upāsasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja502:10.1":{"pli":"Kiṁ nu tyāyaṁ dijo hoti, ","html":"<p><span class='verse-line'>{}</span>"},"ja502:10.2":{"pli":"mutto baddhaṁ upāsasi; ","html":"<span class='verse-line'>{}</span>"},"ja502:10.3":{"pli":"Ohāya sakuṇā yanti, ","html":"<span class='verse-line'>{}</span>"},"ja502:10.4":{"pli":"kiṁ eko avahiyyasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja502:11.1":{"pli":"“Rājā me so dijo mitto, ","html":"<p><span class='verse-line'>{}</span>"},"ja502:11.2":{"pli":"sakhā pāṇasamo ca me; ","html":"<span class='verse-line'>{}</span>"},"ja502:11.3":{"pli":"Neva naṁ vijahissāmi, ","html":"<span class='verse-line'>{}</span>"},"ja502:11.4":{"pli":"yāva kālassa pariyāyaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja502:12.1":{"pli":"“Yo ca tvaṁ sakhino hetu, ","html":"<p><span class='verse-line'>{}</span>"},"ja502:12.2":{"pli":"pāṇaṁ cajitumicchasi; ","html":"<span class='verse-line'>{}</span>"},"ja502:12.3":{"pli":"So te sahāyaṁ muñcāmi, ","html":"<span class='verse-line'>{}</span>"},"ja502:12.4":{"pli":"hotu rājā tavānugo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja502:13.1":{"pli":"“Evaṁ luddaka nandassu, ","html":"<p><span class='verse-line'>{}</span>"},"ja502:13.2":{"pli":"saha sabbehi ñātibhi; ","html":"<span class='verse-line'>{}</span>"},"ja502:13.3":{"pli":"Yathāhamajja nandāmi, ","html":"<span class='verse-line'>{}</span>"},"ja502:13.4":{"pli":"muttaṁ disvā dijādhipaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja502:14.1":{"pli":"“Kaccinnu bhoto kusalaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja502:14.2":{"pli":"kacci bhoto anāmayaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja502:14.3":{"pli":"Kacci raṭṭhamidaṁ phītaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja502:14.4":{"pli":"dhammena manusāsasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja502:15.1":{"pli":"“Kusalañceva me haṁsa, ","html":"<p><span class='verse-line'>{}</span>"},"ja502:15.2":{"pli":"atho haṁsa anāmayaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja502:15.3":{"pli":"Atho raṭṭhamidaṁ phītaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja502:15.4":{"pli":"dhammena manusāsahaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja502:16.1":{"pli":"“Kacci bhoto amaccesu, ","html":"<p><span class='verse-line'>{}</span>"},"ja502:16.2":{"pli":"doso koci na vijjati; ","html":"<span class='verse-line'>{}</span>"},"ja502:16.3":{"pli":"Kacci ārā amittā te, ","html":"<span class='verse-line'>{}</span>"},"ja502:16.4":{"pli":"chāyā dakkhiṇatoriva”. ","html":"<span class='verse-line'>{}</span></p>"},"ja502:17.1":{"pli":"“Athopi me amaccesu, ","html":"<p><span class='verse-line'>{}</span>"},"ja502:17.2":{"pli":"doso koci na vijjati; ","html":"<span class='verse-line'>{}</span>"},"ja502:17.3":{"pli":"Atho ārā amittā me, ","html":"<span class='verse-line'>{}</span>"},"ja502:17.4":{"pli":"chāyā dakkhiṇatoriva”. ","html":"<span class='verse-line'>{}</span></p>"},"ja502:18.1":{"pli":"“Kacci te sādisī bhariyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja502:18.2":{"pli":"assavā piyabhāṇinī; ","html":"<span class='verse-line'>{}</span>"},"ja502:18.3":{"pli":"Puttarūpayasūpetā, ","html":"<span class='verse-line'>{}</span>"},"ja502:18.4":{"pli":"tava chandavasānugā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja502:19.1":{"pli":"“Atho me sādisī bhariyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja502:19.2":{"pli":"assavā piyabhāṇinī; ","html":"<span class='verse-line'>{}</span>"},"ja502:19.3":{"pli":"Puttarūpayasūpetā, ","html":"<span class='verse-line'>{}</span>"},"ja502:19.4":{"pli":"mama chandavasānugā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja502:20.1":{"pli":"“Kacci te bahavo puttā, ","html":"<p><span class='verse-line'>{}</span>"},"ja502:20.2":{"pli":"sujātā raṭṭhavaḍḍhana; ","html":"<span class='verse-line'>{}</span>"},"ja502:20.3":{"pli":"Paññājavena sampannā, ","html":"<span class='verse-line'>{}</span>"},"ja502:20.4":{"pli":"sammodanti tato tato”. ","html":"<span class='verse-line'>{}</span></p>"},"ja502:21.1":{"pli":"“Satameko ca me puttā, ","html":"<p><span class='verse-line'>{}</span>"},"ja502:21.2":{"pli":"dhataraṭṭha mayā sutā; ","html":"<span class='verse-line'>{}</span>"},"ja502:21.3":{"pli":"Tesaṁ tvaṁ kiccamakkhāhi, ","html":"<span class='verse-line'>{}</span>"},"ja502:21.4":{"pli":"nāvarujjhanti te vaco”. ","html":"<span class='verse-line'>{}</span></p>"},"ja502:22.1":{"pli":"“Upapannopi ce hoti, ","html":"<p><span class='verse-line'>{}</span>"},"ja502:22.2":{"pli":"jātiyā vinayena vā; ","html":"<span class='verse-line'>{}</span>"},"ja502:22.3":{"pli":"Atha pacchā kurute yogaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja502:22.4":{"pli":"kicche āpāsu sīdati. ","html":"<span class='verse-line'>{}</span></p>"},"ja502:23.1":{"pli":"Tassa saṁhīrapaññassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja502:23.2":{"pli":"vivaro jāyate mahā; ","html":"<span class='verse-line'>{}</span>"},"ja502:23.3":{"pli":"Rattimandhova rūpāni, ","html":"<span class='verse-line'>{}</span>"},"ja502:23.4":{"pli":"thūlāni manupassati. ","html":"<span class='verse-line'>{}</span></p>"},"ja502:24.1":{"pli":"Asāre sārayogaññū, ","html":"<p><span class='verse-line'>{}</span>"},"ja502:24.2":{"pli":"matiṁ na tveva vindati; ","html":"<span class='verse-line'>{}</span>"},"ja502:24.3":{"pli":"Sarabhova giriduggasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja502:24.4":{"pli":"antarāyeva sīdati. ","html":"<span class='verse-line'>{}</span></p>"},"ja502:25.1":{"pli":"Hīnajaccopi ce hoti, ","html":"<p><span class='verse-line'>{}</span>"},"ja502:25.2":{"pli":"uṭṭhātā dhitimā naro; ","html":"<span class='verse-line'>{}</span>"},"ja502:25.3":{"pli":"Ācārasīlasampanno, ","html":"<span class='verse-line'>{}</span>"},"ja502:25.4":{"pli":"nise aggīva bhāsati. ","html":"<span class='verse-line'>{}</span></p>"},"ja502:26.1":{"pli":"Etaṁ me upamaṁ katvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja502:26.2":{"pli":"putte vijjāsu vācaya; ","html":"<span class='verse-line'>{}</span>"},"ja502:26.3":{"pli":"Saṁvirūḷhetha medhāvī, ","html":"<span class='verse-line'>{}</span>"},"ja502:26.4":{"pli":"khette bījaṁva vuṭṭhiyā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja502:27.1":{"pli":"Cūḷahaṁsajātakaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja503":{"ja503:0.1":{"pli":"Jātaka ","html":"<article id='ja503'><header><ul><li class='division'>{}</li>"},"ja503:0.2":{"pli":"Vīsatinipāta ","html":"<li>{}</li>"},"ja503:0.3":{"pli":"Mātaṅgavagga ","html":"<li>{}</li></ul>"},"ja503:0.4":{"pli":"7. Sattigumbajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja503:1.1":{"pli":"Migaluddo mahārājā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja503:1.2":{"pli":"pañcālānaṁ rathesabho; ","html":"<span class='verse-line'>{}</span>"},"ja503:1.3":{"pli":"Nikkhanto saha senāya, ","html":"<span class='verse-line'>{}</span>"},"ja503:1.4":{"pli":"ogaṇo vanamāgamā. ","html":"<span class='verse-line'>{}</span></p>"},"ja503:2.1":{"pli":"Tatthaddasā araññasmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja503:2.2":{"pli":"takkarānaṁ kuṭiṁ kataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja503:2.3":{"pli":"Tassā kuṭiyā nikkhamma, ","html":"<span class='verse-line'>{}</span>"},"ja503:2.4":{"pli":"suvo luddāni bhāsati. ","html":"<span class='verse-line'>{}</span></p>"},"ja503:3.1":{"pli":"“Sampannavāhano poso, ","html":"<p><span class='verse-line'>{}</span>"},"ja503:3.2":{"pli":"yuvā sammaṭṭhakuṇḍalo; ","html":"<span class='verse-line'>{}</span>"},"ja503:3.3":{"pli":"Sobhati lohituṇhīso, ","html":"<span class='verse-line'>{}</span>"},"ja503:3.4":{"pli":"divā sūriyova bhāsati. ","html":"<span class='verse-line'>{}</span></p>"},"ja503:4.1":{"pli":"Majjhanhike sampatike, ","html":"<p><span class='verse-line'>{}</span>"},"ja503:4.2":{"pli":"sutto rājā sasārathi; ","html":"<span class='verse-line'>{}</span>"},"ja503:4.3":{"pli":"Handassābharaṇaṁ sabbaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja503:4.4":{"pli":"gaṇhāma sāhasā mayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja503:5.1":{"pli":"Nisīthepi raho dāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja503:5.2":{"pli":"Sutto rājā sasārathi; ","html":"<span class='verse-line'>{}</span>"},"ja503:5.3":{"pli":"Ādāya vatthaṁ maṇikuṇḍalañca, ","html":"<span class='verse-line'>{}</span>"},"ja503:5.4":{"pli":"Hantvāna sākhāhi avattharāma”. ","html":"<span class='verse-line'>{}</span></p>"},"ja503:6.1":{"pli":"“Kiṁ nu ummattarūpova, ","html":"<p><span class='verse-line'>{}</span>"},"ja503:6.2":{"pli":"sattigumba pabhāsasi; ","html":"<span class='verse-line'>{}</span>"},"ja503:6.3":{"pli":"Durāsadā hi rājāno, ","html":"<span class='verse-line'>{}</span>"},"ja503:6.4":{"pli":"aggi pajjalito yathā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja503:7.1":{"pli":"“Atha tvaṁ patikolamba, ","html":"<p><span class='verse-line'>{}</span>"},"ja503:7.2":{"pli":"matto thullāni gajjasi; ","html":"<span class='verse-line'>{}</span>"},"ja503:7.3":{"pli":"Mātari mayhaṁ naggāya, ","html":"<span class='verse-line'>{}</span>"},"ja503:7.4":{"pli":"kiṁ nu tvaṁ vijigucchase”. ","html":"<span class='verse-line'>{}</span></p>"},"ja503:8.1":{"pli":"“Uṭṭhehi samma taramāno, ","html":"<p><span class='verse-line'>{}</span>"},"ja503:8.2":{"pli":"rathaṁ yojehi sārathi; ","html":"<span class='verse-line'>{}</span>"},"ja503:8.3":{"pli":"Sakuṇo me na ruccati, ","html":"<span class='verse-line'>{}</span>"},"ja503:8.4":{"pli":"aññaṁ gacchāma assamaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja503:9.1":{"pli":"“Yutto ratho mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja503:9.2":{"pli":"yutto ca balavāhano; ","html":"<span class='verse-line'>{}</span>"},"ja503:9.3":{"pli":"Adhitiṭṭha mahārāja, ","html":"<span class='verse-line'>{}</span>"},"ja503:9.4":{"pli":"aññaṁ gacchāma assamaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja503:10.1":{"pli":"“Ko numeva gatā sabbe, ","html":"<p><span class='verse-line'>{}</span>"},"ja503:10.2":{"pli":"ye asmiṁ paricārakā; ","html":"<span class='verse-line'>{}</span>"},"ja503:10.3":{"pli":"Esa gacchati pañcālo, ","html":"<span class='verse-line'>{}</span>"},"ja503:10.4":{"pli":"mutto tesaṁ adassanā. ","html":"<span class='verse-line'>{}</span></p>"},"ja503:11.1":{"pli":"Kodaṇḍakāni gaṇhatha, ","html":"<p><span class='verse-line'>{}</span>"},"ja503:11.2":{"pli":"sattiyo tomarāni ca; ","html":"<span class='verse-line'>{}</span>"},"ja503:11.3":{"pli":"Esa gacchati pañcālo, ","html":"<span class='verse-line'>{}</span>"},"ja503:11.4":{"pli":"mā vo muñcittha jīvataṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja503:12.1":{"pli":"Athāparo paṭinandittha, ","html":"<p><span class='verse-line'>{}</span>"},"ja503:12.2":{"pli":"suvo lohitatuṇḍako; ","html":"<span class='verse-line'>{}</span>"},"ja503:12.3":{"pli":"“Svāgataṁ te mahārāja, ","html":"<span class='verse-line'>{}</span>"},"ja503:12.4":{"pli":"atho te adurāgataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja503:12.5":{"pli":"Issarosi anuppatto, ","html":"<span class='verse-line'>{}</span>"},"ja503:12.6":{"pli":"yaṁ idhatthi pavedaya. ","html":"<span class='verse-line'>{}</span></p>"},"ja503:13.1":{"pli":"Tindukāni piyālāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja503:13.2":{"pli":"madhuke kāsumāriyo; ","html":"<span class='verse-line'>{}</span>"},"ja503:13.3":{"pli":"Phalāni khuddakappāni, ","html":"<span class='verse-line'>{}</span>"},"ja503:13.4":{"pli":"bhuñja rāja varaṁ varaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja503:14.1":{"pli":"Idampi pānīyaṁ sītaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja503:14.2":{"pli":"ābhataṁ girigabbharā; ","html":"<span class='verse-line'>{}</span>"},"ja503:14.3":{"pli":"Tato piva mahārāja, ","html":"<span class='verse-line'>{}</span>"},"ja503:14.4":{"pli":"sace tvaṁ abhikaṅkhasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja503:15.1":{"pli":"Araññaṁ uñchāya gatā, ","html":"<p><span class='verse-line'>{}</span>"},"ja503:15.2":{"pli":"ye asmiṁ paricārakā; ","html":"<span class='verse-line'>{}</span>"},"ja503:15.3":{"pli":"Sayaṁ uṭṭhāya gaṇhavho, ","html":"<span class='verse-line'>{}</span>"},"ja503:15.4":{"pli":"hatthā me natthi dātave”. ","html":"<span class='verse-line'>{}</span></p>"},"ja503:16.1":{"pli":"“Bhaddako vatayaṁ pakkhī, ","html":"<p><span class='verse-line'>{}</span>"},"ja503:16.2":{"pli":"dijo paramadhammiko; ","html":"<span class='verse-line'>{}</span>"},"ja503:16.3":{"pli":"Atheso itaro pakkhī, ","html":"<span class='verse-line'>{}</span>"},"ja503:16.4":{"pli":"suvo luddāni bhāsati. ","html":"<span class='verse-line'>{}</span></p>"},"ja503:17.1":{"pli":"‘Etaṁ hanatha bandhatha, ","html":"<p><span class='verse-line'>{}</span>"},"ja503:17.2":{"pli":"Mā vo muñcittha jīvataṁ’; ","html":"<span class='verse-line'>{}</span>"},"ja503:17.3":{"pli":"Iccevaṁ vilapantassa, ","html":"<span class='verse-line'>{}</span>"},"ja503:17.4":{"pli":"Sotthiṁ pattosmi assamaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja503:18.1":{"pli":"“Bhātarosma mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja503:18.2":{"pli":"sodariyā ekamātukā; ","html":"<span class='verse-line'>{}</span>"},"ja503:18.3":{"pli":"Ekarukkhasmiṁ saṁvaḍḍhā, ","html":"<span class='verse-line'>{}</span>"},"ja503:18.4":{"pli":"nānākhettagatā ubho. ","html":"<span class='verse-line'>{}</span></p>"},"ja503:19.1":{"pli":"Sattigumbo ca corānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja503:19.2":{"pli":"ahañca isīnaṁ idha; ","html":"<span class='verse-line'>{}</span>"},"ja503:19.3":{"pli":"Asataṁ so, sataṁ ahaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja503:19.4":{"pli":"tena dhammena no vinā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja503:20.1":{"pli":"“Tattha vadho ca bandho ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja503:20.2":{"pli":"nikatī vañcanāni ca; ","html":"<span class='verse-line'>{}</span>"},"ja503:20.3":{"pli":"Ālopā sāhasākārā, ","html":"<span class='verse-line'>{}</span>"},"ja503:20.4":{"pli":"tāni so tattha sikkhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja503:21.1":{"pli":"Idha saccañca dhammo ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja503:21.2":{"pli":"Ahiṁsā saṁyamo damo; ","html":"<span class='verse-line'>{}</span>"},"ja503:21.3":{"pli":"Āsanūdakadāyīnaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja503:21.4":{"pli":"Aṅke vaddhosmi bhāradha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja503:22.1":{"pli":"“Yaṁ yañhi rāja bhajati, ","html":"<p><span class='verse-line'>{}</span>"},"ja503:22.2":{"pli":"santaṁ vā yadi vā asaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja503:22.3":{"pli":"Sīlavantaṁ visīlaṁ vā, ","html":"<span class='verse-line'>{}</span>"},"ja503:22.4":{"pli":"vasaṁ tasseva gacchati. ","html":"<span class='verse-line'>{}</span></p>"},"ja503:23.1":{"pli":"Yādisaṁ kurute mittaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja503:23.2":{"pli":"yādisaṁ cūpasevati; ","html":"<span class='verse-line'>{}</span>"},"ja503:23.3":{"pli":"Sopi tādisako hoti, ","html":"<span class='verse-line'>{}</span>"},"ja503:23.4":{"pli":"sahavāso hi tādiso. ","html":"<span class='verse-line'>{}</span></p>"},"ja503:24.1":{"pli":"Sevamāno sevamānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja503:24.2":{"pli":"samphuṭṭho samphusaṁ paraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja503:24.3":{"pli":"Saro diddho kalāpaṁva, ","html":"<span class='verse-line'>{}</span>"},"ja503:24.4":{"pli":"alittamupalimpati; ","html":"<span class='verse-line'>{}</span>"},"ja503:24.5":{"pli":"Upalepabhayā dhīro, ","html":"<span class='verse-line'>{}</span>"},"ja503:24.6":{"pli":"neva pāpasakhā siyā. ","html":"<span class='verse-line'>{}</span></p>"},"ja503:25.1":{"pli":"Pūtimacchaṁ kusaggena, ","html":"<p><span class='verse-line'>{}</span>"},"ja503:25.2":{"pli":"yo naro upanayhati; ","html":"<span class='verse-line'>{}</span>"},"ja503:25.3":{"pli":"Kusāpi pūti vāyanti, ","html":"<span class='verse-line'>{}</span>"},"ja503:25.4":{"pli":"evaṁ bālūpasevanā. ","html":"<span class='verse-line'>{}</span></p>"},"ja503:26.1":{"pli":"Tagarañca palāsena, ","html":"<p><span class='verse-line'>{}</span>"},"ja503:26.2":{"pli":"yo naro upanayhati; ","html":"<span class='verse-line'>{}</span>"},"ja503:26.3":{"pli":"Pattāpi surabhi vāyanti, ","html":"<span class='verse-line'>{}</span>"},"ja503:26.4":{"pli":"evaṁ dhīrūpasevanā. ","html":"<span class='verse-line'>{}</span></p>"},"ja503:27.1":{"pli":"Tasmā pattapuṭasseva, ","html":"<p><span class='verse-line'>{}</span>"},"ja503:27.2":{"pli":"ñatvā sampākamattano; ","html":"<span class='verse-line'>{}</span>"},"ja503:27.3":{"pli":"Asante nopaseveyya, ","html":"<span class='verse-line'>{}</span>"},"ja503:27.4":{"pli":"sante seveyya paṇḍito; ","html":"<span class='verse-line'>{}</span>"},"ja503:27.5":{"pli":"Asanto nirayaṁ nenti, ","html":"<span class='verse-line'>{}</span>"},"ja503:27.6":{"pli":"santo pāpenti suggatin”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja503:28.1":{"pli":"Sattigumbajātakaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}