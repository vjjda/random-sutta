{"ja200":{"ja200:0.1":{"pli":"Jātaka ","html":"<article id='ja200'><header><ul><li class='division'>{}</li>"},"ja200:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja200:0.3":{"pli":"Ruhakavagga ","html":"<li>{}</li></ul>"},"ja200:0.4":{"pli":"10. Sādhusīlajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja200:1.1":{"pli":"“Sarīradabyaṁ vuḍḍhabyaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja200:1.2":{"pli":"sojaccaṁ sādhusīliyaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja200:1.3":{"pli":"Brāhmaṇaṁ teva pucchāma, ","html":"<span class='verse-line'>{}</span>"},"ja200:1.4":{"pli":"kaṁ nu tesaṁ vanimhase”. ","html":"<span class='verse-line'>{}</span></p>"},"ja200:2.1":{"pli":"“Attho atthi sarīrasmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja200:2.2":{"pli":"vuḍḍhabyassa namo kare; ","html":"<span class='verse-line'>{}</span>"},"ja200:2.3":{"pli":"Attho atthi sujātasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja200:2.4":{"pli":"sīlaṁ asmāka ruccatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja200:3.1":{"pli":"Sādhusīlajātakaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja200:3.2":{"pli":"Ruhakavaggo pañcamo. ","html":"<p class='endvagga'>{}</p>"},"ja200:4.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja200:5.1":{"pli":"Apiruhaka rūpavatī musalo, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja200:5.2":{"pli":"Pavasanti sapañcamapokkharaṇī; ","html":"<span class='verse-line'>{}</span>"},"ja200:5.3":{"pli":"Atha muttimavāṇija umhayate, ","html":"<span class='verse-line'>{}</span>"},"ja200:5.4":{"pli":"Ciraāgata koṭṭha sarīra dasāti. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"ja201":{"ja201:0.1":{"pli":"Jātaka ","html":"<article id='ja201'><header><ul><li class='division'>{}</li>"},"ja201:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja201:0.3":{"pli":"Nataṁdaḷhavagga ","html":"<li>{}</li></ul>"},"ja201:0.4":{"pli":"1. Bandhanāgārajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja201:1.1":{"pli":"“Na taṁ daḷhaṁ bandhanamāhu dhīrā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja201:1.2":{"pli":"Yadāyasaṁ dārujapabbajañca; ","html":"<span class='verse-line'>{}</span>"},"ja201:1.3":{"pli":"Sārattarattā maṇikuṇḍalesu, ","html":"<span class='verse-line'>{}</span>"},"ja201:1.4":{"pli":"Puttesu dāresu ca yā apekkhā. ","html":"<span class='verse-line'>{}</span></p>"},"ja201:2.1":{"pli":"Etaṁ daḷhaṁ bandhanamāhu dhīrā, ","html":"<p><span class='verse-line'>{}</span>"},"ja201:2.2":{"pli":"Ohārinaṁ sīthilaṁ duppamuñcaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja201:2.3":{"pli":"Etampi chetvāna vajanti dhīrā, ","html":"<span class='verse-line'>{}</span>"},"ja201:2.4":{"pli":"Anapekkhino kāmasukhaṁ pahāyā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja201:3.1":{"pli":"Bandhanāgārajātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja202":{"ja202:0.1":{"pli":"Jātaka ","html":"<article id='ja202'><header><ul><li class='division'>{}</li>"},"ja202:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja202:0.3":{"pli":"Nataṁdaḷhavagga ","html":"<li>{}</li></ul>"},"ja202:0.4":{"pli":"2. Keḷisīlajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja202:1.1":{"pli":"“Haṁsā koñcā mayūrā ca, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja202:1.2":{"pli":"hatthayo pasadā migā; ","html":"<span class='verse-line'>{}</span>"},"ja202:1.3":{"pli":"Sabbe sīhassa bhāyanti, ","html":"<span class='verse-line'>{}</span>"},"ja202:1.4":{"pli":"natthi kāyasmi tulyatā. ","html":"<span class='verse-line'>{}</span></p>"},"ja202:2.1":{"pli":"Evameva manussesu, ","html":"<p><span class='verse-line'>{}</span>"},"ja202:2.2":{"pli":"daharo cepi paññavā; ","html":"<span class='verse-line'>{}</span>"},"ja202:2.3":{"pli":"So hi tattha mahā hoti, ","html":"<span class='verse-line'>{}</span>"},"ja202:2.4":{"pli":"neva bālo sarīravā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja202:3.1":{"pli":"Keḷisīlajātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja203":{"ja203:0.1":{"pli":"Jātaka ","html":"<article id='ja203'><header><ul><li class='division'>{}</li>"},"ja203:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja203:0.3":{"pli":"Nataṁdaḷhavagga ","html":"<li>{}</li></ul>"},"ja203:0.4":{"pli":"3. Khaṇḍajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja203:1.1":{"pli":"“Virūpakkhehi me mettaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja203:1.2":{"pli":"Mettaṁ erāpathehi me; ","html":"<span class='verse-line'>{}</span>"},"ja203:1.3":{"pli":"Chabyāputtehi me mettaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja203:1.4":{"pli":"Mettaṁ kaṇhāgotamakehi ca. ","html":"<span class='verse-line'>{}</span></p>"},"ja203:2.1":{"pli":"Apādakehi me mettaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja203:2.2":{"pli":"mettaṁ dvipādakehi me; ","html":"<span class='verse-line'>{}</span>"},"ja203:2.3":{"pli":"Catuppadehi me mettaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja203:2.4":{"pli":"mettaṁ bahuppadehi me. ","html":"<span class='verse-line'>{}</span></p>"},"ja203:3.1":{"pli":"Mā maṁ apādako hiṁsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja203:3.2":{"pli":"mā maṁ hiṁsi dvipādako; ","html":"<span class='verse-line'>{}</span>"},"ja203:3.3":{"pli":"Mā maṁ catuppado hiṁsi, ","html":"<span class='verse-line'>{}</span>"},"ja203:3.4":{"pli":"mā maṁ hiṁsi bahuppado. ","html":"<span class='verse-line'>{}</span></p>"},"ja203:4.1":{"pli":"Sabbe sattā sabbe pāṇā, ","html":"<p><span class='verse-line'>{}</span>"},"ja203:4.2":{"pli":"sabbe bhūtā ca kevalā; ","html":"<span class='verse-line'>{}</span>"},"ja203:4.3":{"pli":"Sabbe bhadrāni passantu, ","html":"<span class='verse-line'>{}</span>"},"ja203:4.4":{"pli":"mā kañci pāpamāgamā. ","html":"<span class='verse-line'>{}</span></p>"},"ja203:5.1":{"pli":"Appamāṇo buddho, ","html":"<p><span class='verse-line'>{}</span>"},"ja203:5.2":{"pli":"Appamāṇo dhammo; ","html":"<span class='verse-line'>{}</span>"},"ja203:5.3":{"pli":"Appamāṇo saṅgho, ","html":"<span class='verse-line'>{}</span>"},"ja203:5.4":{"pli":"Pamāṇavantāni sarīsapāni; ","html":"<span class='verse-line'>{}</span>"},"ja203:5.5":{"pli":"Ahivicchikasatapadī, ","html":"<span class='verse-line'>{}</span>"},"ja203:5.6":{"pli":"Uṇṇanābhi sarabū mūsikā. ","html":"<span class='verse-line'>{}</span></p>"},"ja203:6.1":{"pli":"Katā me rakkhā katā me parittā, ","html":"<p><span class='verse-line'>{}</span>"},"ja203:6.2":{"pli":"Paṭikkamantu bhūtāni; ","html":"<span class='verse-line'>{}</span>"},"ja203:6.3":{"pli":"Sohaṁ namo bhagavato, ","html":"<span class='verse-line'>{}</span>"},"ja203:6.4":{"pli":"Namo sattannaṁ sammāsambuddhānan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja203:7.1":{"pli":"Khaṇḍajātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja204":{"ja204:0.1":{"pli":"Jātaka ","html":"<article id='ja204'><header><ul><li class='division'>{}</li>"},"ja204:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja204:0.3":{"pli":"Nataṁdaḷhavagga ","html":"<li>{}</li></ul>"},"ja204:0.4":{"pli":"4. Vīrakajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja204:1.1":{"pli":"“Api vīraka passesi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja204:1.2":{"pli":"sakuṇaṁ mañjubhāṇakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja204:1.3":{"pli":"Mayūragīvasaṅkāsaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja204:1.4":{"pli":"patiṁ mayhaṁ saviṭṭhakaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja204:2.1":{"pli":"“Udakathalacarassa pakkhino, ","html":"<p><span class='verse-line'>{}</span>"},"ja204:2.2":{"pli":"Niccaṁ āmakamacchabhojino; ","html":"<span class='verse-line'>{}</span>"},"ja204:2.3":{"pli":"Tassānukaraṁ saviṭṭhako, ","html":"<span class='verse-line'>{}</span>"},"ja204:2.4":{"pli":"Sevāle paliguṇṭhito mato”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja204:3.1":{"pli":"Vīrakajātakaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja205":{"ja205:0.1":{"pli":"Jātaka ","html":"<article id='ja205'><header><ul><li class='division'>{}</li>"},"ja205:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja205:0.3":{"pli":"Nataṁdaḷhavagga ","html":"<li>{}</li></ul>"},"ja205:0.4":{"pli":"5. Gaṅgeyyajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja205:1.1":{"pli":"“Sobhati maccho gaṅgeyyo, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja205:1.2":{"pli":"atho sobhati yāmuno; ","html":"<span class='verse-line'>{}</span>"},"ja205:1.3":{"pli":"Catuppadoyaṁ puriso, ","html":"<span class='verse-line'>{}</span>"},"ja205:1.4":{"pli":"nigrodhaparimaṇḍalo; ","html":"<span class='verse-line'>{}</span>"},"ja205:1.5":{"pli":"Īsakāyatagīvo ca, ","html":"<span class='verse-line'>{}</span>"},"ja205:1.6":{"pli":"sabbeva atirocati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja205:2.1":{"pli":"“Yaṁ pucchito na taṁ akkhāsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja205:2.2":{"pli":"Aññaṁ akkhāsi pucchito; ","html":"<span class='verse-line'>{}</span>"},"ja205:2.3":{"pli":"Attappasaṁsako poso, ","html":"<span class='verse-line'>{}</span>"},"ja205:2.4":{"pli":"Nāyaṁ asmāka ruccatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja205:3.1":{"pli":"Gaṅgeyyajātakaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja206":{"ja206:0.1":{"pli":"Jātaka ","html":"<article id='ja206'><header><ul><li class='division'>{}</li>"},"ja206:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja206:0.3":{"pli":"Nataṁdaḷhavagga ","html":"<li>{}</li></ul>"},"ja206:0.4":{"pli":"6. Kuruṅgamigajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja206:1.1":{"pli":"“Iṅgha vaṭṭamayaṁ pāsaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja206:1.2":{"pli":"chinda dantehi kacchapa; ","html":"<span class='verse-line'>{}</span>"},"ja206:1.3":{"pli":"Ahaṁ tathā karissāmi, ","html":"<span class='verse-line'>{}</span>"},"ja206:1.4":{"pli":"yathā nehiti luddako”. ","html":"<span class='verse-line'>{}</span></p>"},"ja206:2.1":{"pli":"“Kacchapo pāvisī vāriṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja206:2.2":{"pli":"kuruṅgo pāvisī vanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja206:2.3":{"pli":"Satapatto dumaggamhā, ","html":"<span class='verse-line'>{}</span>"},"ja206:2.4":{"pli":"dūre putte apānayī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja206:3.1":{"pli":"Kuruṅgamigajātakaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja207":{"ja207:0.1":{"pli":"Jātaka ","html":"<article id='ja207'><header><ul><li class='division'>{}</li>"},"ja207:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja207:0.3":{"pli":"Nataṁdaḷhavagga ","html":"<li>{}</li></ul>"},"ja207:0.4":{"pli":"7. Assakajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja207:1.1":{"pli":"“Ayamassakarājena, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja207:1.2":{"pli":"deso vicarito mayā; ","html":"<span class='verse-line'>{}</span>"},"ja207:1.3":{"pli":"Anukāmayakāmena, ","html":"<span class='verse-line'>{}</span>"},"ja207:1.4":{"pli":"piyena patinā saha. ","html":"<span class='verse-line'>{}</span></p>"},"ja207:2.1":{"pli":"Navena sukhadukkhena, ","html":"<p><span class='verse-line'>{}</span>"},"ja207:2.2":{"pli":"porāṇaṁ apidhīyati; ","html":"<span class='verse-line'>{}</span>"},"ja207:2.3":{"pli":"Tasmā assakaraññāva, ","html":"<span class='verse-line'>{}</span>"},"ja207:2.4":{"pli":"kīṭo piyataro mamā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja207:3.1":{"pli":"Assakajātakaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja208":{"ja208:0.1":{"pli":"Jātaka ","html":"<article id='ja208'><header><ul><li class='division'>{}</li>"},"ja208:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja208:0.3":{"pli":"Nataṁdaḷhavagga ","html":"<li>{}</li></ul>"},"ja208:0.4":{"pli":"8. Susumārajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja208:1.1":{"pli":"“Alaṁ metehi ambehi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja208:1.2":{"pli":"jambūhi panasehi ca; ","html":"<span class='verse-line'>{}</span>"},"ja208:1.3":{"pli":"Yāni pāraṁ samuddassa, ","html":"<span class='verse-line'>{}</span>"},"ja208:1.4":{"pli":"varaṁ mayhaṁ udumbaro. ","html":"<span class='verse-line'>{}</span></p>"},"ja208:2.1":{"pli":"Mahatī vata te bondi, ","html":"<p><span class='verse-line'>{}</span>"},"ja208:2.2":{"pli":"na ca paññā tadūpikā; ","html":"<span class='verse-line'>{}</span>"},"ja208:2.3":{"pli":"Susumāra vañcito mesi, ","html":"<span class='verse-line'>{}</span>"},"ja208:2.4":{"pli":"gaccha dāni yathāsukhan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja208:3.1":{"pli":"Susumārajātakaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja209":{"ja209:0.1":{"pli":"Jātaka ","html":"<article id='ja209'><header><ul><li class='division'>{}</li>"},"ja209:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja209:0.3":{"pli":"Nataṁdaḷhavagga ","html":"<li>{}</li></ul>"},"ja209:0.4":{"pli":"9. Kukkuṭajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja209:1.1":{"pli":"“Diṭṭhā mayā vane rukkhā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja209:1.2":{"pli":"assakaṇṇā vibhīṭakā; ","html":"<span class='verse-line'>{}</span>"},"ja209:1.3":{"pli":"Na tāni evaṁ sakkanti, ","html":"<span class='verse-line'>{}</span>"},"ja209:1.4":{"pli":"yathā tvaṁ rukkha sakkasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja209:2.1":{"pli":"“Purāṇakukkuṭo ayaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja209:2.2":{"pli":"bhetvā pañjaramāgato; ","html":"<span class='verse-line'>{}</span>"},"ja209:2.3":{"pli":"Kusalo vāḷapāsānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja209:2.4":{"pli":"apakkamati bhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja209:3.1":{"pli":"Kukkuṭajātakaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja21":{"ja21:0.1":{"pli":"Jātaka ","eng":"Stories of Past Lives 21 ","html":"<article id='ja21'><header><ul><li class='division'>{}</li>"},"ja21:0.2":{"pli":"Ekakanipāta ","eng":"The Book of the Ones ","html":"<li>{}</li>"},"ja21:0.3":{"pli":"Kuruṅgavagga ","eng":"The Four-horned Antelope ","html":"<li>{}</li></ul>"},"ja21:0.4":{"pli":"1. Kuruṅgamigajātaka ","eng":"The Four-horned Antelope: a past life story ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja21:1.1":{"pli":"“Ñātametaṁ kuruṅgassa, ","eng":"The four-horned antelope knows that ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>","comm":"A wary antelope spots a hunter hiding in a tree and seeks elsewhere for fruit. | The <i lang='pi' translate='no'>kuruṅga</i> is the four-horned antelope (Sanskrit <i lang='pi' translate='no'>kuraṅga</i>; <i lang='pi' translate='no'>Tetracerus quadricornis</i>). The Mṛgapakṣiśāstra says they are short and red, with branched horns and wide eyes. They often graze grass and are shrewd and patient. "},"ja21:1.2":{"pli":"yaṁ tvaṁ sepaṇṇi siyyasi; ","eng":"it’s you who tosses fruit from the beechwood tree. ","html":"<span class='verse-line'>{}</span>","comm":"The <i lang='pi' translate='no'>sepaṇṇi</i> is the beechwood or gamhar (<i lang='pi' translate='no'>Gmelina arborea</i>), a Sanskrit name of which is <i lang='pi' translate='no'>śriparṇi</i>, “blessed leaf”. It has edible fruit and grows to a height of 30 metres. "},"ja21:1.3":{"pli":"Aññaṁ sepaṇṇi gacchāmi, ","eng":"I’ll go to another beechwood, ","html":"<span class='verse-line'>{}</span>"},"ja21:1.4":{"pli":"na me te ruccate phalan”ti. ","eng":"I don’t like your fruit. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja21:2.1":{"pli":"Kuruṅgamigajātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja210":{"ja210:0.1":{"pli":"Jātaka ","html":"<article id='ja210'><header><ul><li class='division'>{}</li>"},"ja210:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja210:0.3":{"pli":"Nataṁdaḷhavagga ","html":"<li>{}</li></ul>"},"ja210:0.4":{"pli":"10. Kandagalakajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja210:1.1":{"pli":"“Ambho ko nāma yaṁ rukkho, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja210:1.2":{"pli":"sinnapatto sakaṇṭako; ","html":"<span class='verse-line'>{}</span>"},"ja210:1.3":{"pli":"Yattha ekappahārena, ","html":"<span class='verse-line'>{}</span>"},"ja210:1.4":{"pli":"uttamaṅgaṁ vibhijjitaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja210:2.1":{"pli":"“Acāri vatāyaṁ vitudaṁ vanāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja210:2.2":{"pli":"Kaṭṭhaṅgarukkhesu asārakesu; ","html":"<span class='verse-line'>{}</span>"},"ja210:2.3":{"pli":"Athāsadā khadiraṁ jātasāraṁ, ","html":"<span class='verse-line'>{}</span>"},"ja210:2.4":{"pli":"Yatthabbhidā garuḷo uttamaṅgan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja210:3.1":{"pli":"Kandagalakajātakaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja210:3.2":{"pli":"Nataṁdaḷhavaggo chaṭṭho. ","html":"<p class='endvagga'>{}</p>"},"ja210:4.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja210:5.1":{"pli":"Daḷhabandhana haṁsavaro ca puna, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja210:5.2":{"pli":"Virūpakkha saviṭṭhaka macchavaro; ","html":"<span class='verse-line'>{}</span>"},"ja210:5.3":{"pli":"Sakuruṅga saassaka ambavaro, ","html":"<span class='verse-line'>{}</span>"},"ja210:5.4":{"pli":"Puna kukkuṭako garuḷena dasāti. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"ja211":{"ja211:0.1":{"pli":"Jātaka ","html":"<article id='ja211'><header><ul><li class='division'>{}</li>"},"ja211:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja211:0.3":{"pli":"Bīraṇathambhavagga ","html":"<li>{}</li></ul>"},"ja211:0.4":{"pli":"1. Somadattajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja211:1.1":{"pli":"“Akāsi yoggaṁ dhuvamappamatto, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja211:1.2":{"pli":"Saṁvaccharaṁ bīraṇathambhakasmiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja211:1.3":{"pli":"Byākāsi saññaṁ parisaṁ vigayha, ","html":"<span class='verse-line'>{}</span>"},"ja211:1.4":{"pli":"Na niyyamo tāyati appapaññaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja211:2.1":{"pli":"“Dvayaṁ yācanako tāta, ","html":"<p><span class='verse-line'>{}</span>"},"ja211:2.2":{"pli":"somadatta nigacchati; ","html":"<span class='verse-line'>{}</span>"},"ja211:2.3":{"pli":"Alābhaṁ dhanalābhaṁ vā, ","html":"<span class='verse-line'>{}</span>"},"ja211:2.4":{"pli":"evaṁ dhammā hi yācanā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja211:3.1":{"pli":"Somadattajātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja212":{"ja212:0.1":{"pli":"Jātaka ","html":"<article id='ja212'><header><ul><li class='division'>{}</li>"},"ja212:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja212:0.3":{"pli":"Bīraṇathambhavagga ","html":"<li>{}</li></ul>"},"ja212:0.4":{"pli":"2. Ucchiṭṭhabhattajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja212:1.1":{"pli":"“Añño uparimo vaṇṇo, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja212:1.2":{"pli":"añño vaṇṇo ca heṭṭhimo; ","html":"<span class='verse-line'>{}</span>"},"ja212:1.3":{"pli":"Brāhmaṇī tveva pucchāmi, ","html":"<span class='verse-line'>{}</span>"},"ja212:1.4":{"pli":"kiṁ heṭṭhā kiñca uppari”. ","html":"<span class='verse-line'>{}</span></p>"},"ja212:2.1":{"pli":"“Ahaṁ naṭosmi bhaddante, ","html":"<p><span class='verse-line'>{}</span>"},"ja212:2.2":{"pli":"bhikkhakosmi idhāgato; ","html":"<span class='verse-line'>{}</span>"},"ja212:2.3":{"pli":"Ayañhi koṭṭhamotiṇṇo, ","html":"<span class='verse-line'>{}</span>"},"ja212:2.4":{"pli":"ayaṁ so yaṁ gavesasī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja212:3.1":{"pli":"Ucchiṭṭhabhattajātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja213":{"ja213:0.1":{"pli":"Jātaka ","html":"<article id='ja213'><header><ul><li class='division'>{}</li>"},"ja213:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja213:0.3":{"pli":"Bīraṇathambhavagga ","html":"<li>{}</li></ul>"},"ja213:0.4":{"pli":"3. Bharujātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja213:1.1":{"pli":"“Isīnamantaraṁ katvā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja213:1.2":{"pli":"bharurājāti me sutaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja213:1.3":{"pli":"Ucchinno saha raṭṭhehi, ","html":"<span class='verse-line'>{}</span>"},"ja213:1.4":{"pli":"sarājā vibhavaṅgato. ","html":"<span class='verse-line'>{}</span></p>"},"ja213:2.1":{"pli":"Tasmā hi chandāgamanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja213:2.2":{"pli":"nappasaṁsanti paṇḍitā; ","html":"<span class='verse-line'>{}</span>"},"ja213:2.3":{"pli":"Aduṭṭhacitto bhāseyya, ","html":"<span class='verse-line'>{}</span>"},"ja213:2.4":{"pli":"giraṁ saccupasaṁhitan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja213:3.1":{"pli":"Bharujātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja214":{"ja214:0.1":{"pli":"Jātaka ","html":"<article id='ja214'><header><ul><li class='division'>{}</li>"},"ja214:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja214:0.3":{"pli":"Bīraṇathambhavagga ","html":"<li>{}</li></ul>"},"ja214:0.4":{"pli":"4. Puṇṇanadījātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja214:1.1":{"pli":"“Puṇṇaṁ nadiṁ yena ca peyyamāhu, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja214:1.2":{"pli":"Jātaṁ yavaṁ yena ca guyhamāhu; ","html":"<span class='verse-line'>{}</span>"},"ja214:1.3":{"pli":"Dūraṁ gataṁ yena ca avhayanti, ","html":"<span class='verse-line'>{}</span>"},"ja214:1.4":{"pli":"So tyāgato handa ca bhuñja brāhmaṇa”. ","html":"<span class='verse-line'>{}</span></p>"},"ja214:2.1":{"pli":"“Yato maṁ saratī rājā, ","html":"<p><span class='verse-line'>{}</span>"},"ja214:2.2":{"pli":"vāyasampi pahetave; ","html":"<span class='verse-line'>{}</span>"},"ja214:2.3":{"pli":"Haṁsā koñcā mayūrā ca, ","html":"<span class='verse-line'>{}</span>"},"ja214:2.4":{"pli":"asatīyeva pāpiyā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja214:3.1":{"pli":"Puṇṇanadījātakaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja215":{"ja215:0.1":{"pli":"Jātaka ","html":"<article id='ja215'><header><ul><li class='division'>{}</li>"},"ja215:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja215:0.3":{"pli":"Bīraṇathambhavagga ","html":"<li>{}</li></ul>"},"ja215:0.4":{"pli":"5. Kacchapajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja215:1.1":{"pli":"“Avadhī vata attānaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja215:1.2":{"pli":"kacchapo byāharaṁ giraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja215:1.3":{"pli":"Suggahītasmiṁ kaṭṭhasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja215:1.4":{"pli":"vācāya sakiyāvadhi. ","html":"<span class='verse-line'>{}</span></p>"},"ja215:2.1":{"pli":"Etampi disvā naravīriyaseṭṭha, ","html":"<p><span class='verse-line'>{}</span>"},"ja215:2.2":{"pli":"Vācaṁ pamuñce kusalaṁ nātivelaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja215:2.3":{"pli":"Passasi bahubhāṇena, ","html":"<span class='verse-line'>{}</span>"},"ja215:2.4":{"pli":"Kacchapaṁ byasanaṁ gatan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja215:3.1":{"pli":"Kacchapajātakaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja216":{"ja216:0.1":{"pli":"Jātaka ","html":"<article id='ja216'><header><ul><li class='division'>{}</li>"},"ja216:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja216:0.3":{"pli":"Bīraṇathambhavagga ","html":"<li>{}</li></ul>"},"ja216:0.4":{"pli":"6. Macchajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja216:1.1":{"pli":"“Na māyamaggi tapati, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja216:1.2":{"pli":"na sūlo sādhutacchito; ","html":"<span class='verse-line'>{}</span>"},"ja216:1.3":{"pli":"Yañca maṁ maññate macchī, ","html":"<span class='verse-line'>{}</span>"},"ja216:1.4":{"pli":"aññaṁ so ratiyā gato. ","html":"<span class='verse-line'>{}</span></p>"},"ja216:2.1":{"pli":"So maṁ dahati rāgaggi, ","html":"<p><span class='verse-line'>{}</span>"},"ja216:2.2":{"pli":"cittaṁ cūpatapeti maṁ; ","html":"<span class='verse-line'>{}</span>"},"ja216:2.3":{"pli":"Jālino muñcathāyirā maṁ, ","html":"<span class='verse-line'>{}</span>"},"ja216:2.4":{"pli":"na kāme haññate kvacī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja216:3.1":{"pli":"Macchajātakaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja217":{"ja217:0.1":{"pli":"Jātaka ","html":"<article id='ja217'><header><ul><li class='division'>{}</li>"},"ja217:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja217:0.3":{"pli":"Bīraṇathambhavagga ","html":"<li>{}</li></ul>"},"ja217:0.4":{"pli":"7. Seggujātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja217:1.1":{"pli":"“Sabbo loko attamano ahosi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja217:1.2":{"pli":"Akovidā gāmadhammassa seggu; ","html":"<span class='verse-line'>{}</span>"},"ja217:1.3":{"pli":"Komāri ko nāma tavajja dhammo, ","html":"<span class='verse-line'>{}</span>"},"ja217:1.4":{"pli":"Yaṁ tvaṁ gahitā pavane parodasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja217:2.1":{"pli":"“Yo dukkhaphuṭṭhāya bhaveyya tāṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja217:2.2":{"pli":"So me pitā dubbhi vane karoti; ","html":"<span class='verse-line'>{}</span>"},"ja217:2.3":{"pli":"Sā kassa kandāmi vanassa majjhe, ","html":"<span class='verse-line'>{}</span>"},"ja217:2.4":{"pli":"Yo tāyitā so sahasaṁ karotī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja217:3.1":{"pli":"Seggujātakaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja218":{"ja218:0.1":{"pli":"Jātaka ","html":"<article id='ja218'><header><ul><li class='division'>{}</li>"},"ja218:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja218:0.3":{"pli":"Bīraṇathambhavagga ","html":"<li>{}</li></ul>"},"ja218:0.4":{"pli":"8. Kūṭavāṇijajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja218:1.1":{"pli":"“Saṭhassa sāṭheyyamidaṁ sucintitaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja218:1.2":{"pli":"Paccoḍḍitaṁ paṭikūṭassa kūṭaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja218:1.3":{"pli":"Phālañce khādeyyuṁ mūsikā, ","html":"<span class='verse-line'>{}</span>"},"ja218:1.4":{"pli":"Kasmā kumāraṁ kulalā na hareyyuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja218:2.1":{"pli":"Kūṭassa hi santi kūṭakūṭā, ","html":"<p><span class='verse-line'>{}</span>"},"ja218:2.2":{"pli":"Bhavati cāpi nikatino nikatyā; ","html":"<span class='verse-line'>{}</span>"},"ja218:2.3":{"pli":"Dehi puttanaṭṭha phālanaṭṭhassa phālaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja218:2.4":{"pli":"Mā te puttamahāsi phālanaṭṭho”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja218:3.1":{"pli":"Kūṭavāṇijajātakaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja219":{"ja219:0.1":{"pli":"Jātaka ","html":"<article id='ja219'><header><ul><li class='division'>{}</li>"},"ja219:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja219:0.3":{"pli":"Bīraṇathambhavagga ","html":"<li>{}</li></ul>"},"ja219:0.4":{"pli":"9. Garahitajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja219:1.1":{"pli":"“Hiraññaṁ me suvaṇṇaṁ me, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja219:1.2":{"pli":"esā rattiṁ divā kathā; ","html":"<span class='verse-line'>{}</span>"},"ja219:1.3":{"pli":"Dummedhānaṁ manussānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja219:1.4":{"pli":"ariyadhammaṁ apassataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja219:2.1":{"pli":"Dve dve gahapatayo gehe, ","html":"<p><span class='verse-line'>{}</span>"},"ja219:2.2":{"pli":"eko tattha amassuko; ","html":"<span class='verse-line'>{}</span>"},"ja219:2.3":{"pli":"Lambatthano veṇikato, ","html":"<span class='verse-line'>{}</span>"},"ja219:2.4":{"pli":"atho aṅkitakaṇṇako; ","html":"<span class='verse-line'>{}</span>"},"ja219:2.5":{"pli":"Kīto dhanena bahunā, ","html":"<span class='verse-line'>{}</span>"},"ja219:2.6":{"pli":"so taṁ vitudate janan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja219:3.1":{"pli":"Garahitajātakaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja22":{"ja22:0.1":{"pli":"Jātaka ","eng":"Stories of Past Lives 22 ","html":"<article id='ja22'><header><ul><li class='division'>{}</li>"},"ja22:0.2":{"pli":"Ekakanipāta ","eng":"The Book of the Ones ","html":"<li>{}</li>"},"ja22:0.3":{"pli":"Kuruṅgavagga ","eng":"The Four-horned Antelope ","html":"<li>{}</li></ul>"},"ja22:0.4":{"pli":"2. Kukkurajātaka ","eng":"Hounds: a past life story ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja22:1.1":{"pli":"“Ye kukkurā rājakulamhi vaddhā, ","eng":"The hounds raised in the royal family, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>","comm":"The Bodhisatta, born as a leader of a pack of dogs in the cemetery (!), protests the unjust slaughter of the wild dogs when it is the fancy hounds of the court who are the real culprits. "},"ja22:1.2":{"pli":"Koleyyakā vaṇṇabalūpapannā; ","eng":"pedigreed, handsome and strong, ","html":"<span class='verse-line'>{}</span>","comm":"For <i lang='pi' translate='no'>koleyyakā</i> see <a href='index.html?q=an7.63#10.3'>AN 7.63:10.3</a>. "},"ja22:1.3":{"pli":"Teme na vajjhā mayamasma vajjhā, ","eng":"are not slaughtered, we are slaughtered—","html":"<span class='verse-line'>{}</span>"},"ja22:1.4":{"pli":"Nāyaṁ saghaccā dubbalaghātikāyan”ti. ","eng":"this is not the dogs deserving death, <j>this is the killing of the weak. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja22:2.1":{"pli":"Kukkurajātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja220":{"ja220:0.1":{"pli":"Jātaka ","html":"<article id='ja220'><header><ul><li class='division'>{}</li>"},"ja220:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja220:0.3":{"pli":"Bīraṇathambhavagga ","html":"<li>{}</li></ul>"},"ja220:0.4":{"pli":"10. Dhammadhajajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja220:1.1":{"pli":"“Sukhaṁ jīvitarūposi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja220:1.2":{"pli":"raṭṭhā vivanamāgato; ","html":"<span class='verse-line'>{}</span>"},"ja220:1.3":{"pli":"So ekako rukkhamūle, ","html":"<span class='verse-line'>{}</span>"},"ja220:1.4":{"pli":"kapaṇo viya jhāyasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja220:2.1":{"pli":"“Sukhaṁ jīvitarūposmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja220:2.2":{"pli":"raṭṭhā vivanamāgato; ","html":"<span class='verse-line'>{}</span>"},"ja220:2.3":{"pli":"So ekako rukkhamūle, ","html":"<span class='verse-line'>{}</span>"},"ja220:2.4":{"pli":"kapaṇo viya jhāyāmi; ","html":"<span class='verse-line'>{}</span>"},"ja220:2.5":{"pli":"Sataṁ dhammaṁ anussaran”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja220:3.1":{"pli":"Dhammadhajajātakaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja220:3.2":{"pli":"Bīraṇathambhavaggo sattamo. ","html":"<p class='endvagga'>{}</p>"},"ja220:4.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja220:5.1":{"pli":"Atha bīraṇathambhavaro ca naṭo, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja220:5.2":{"pli":"Bharurājavaruttamapuṇṇanadī; ","html":"<span class='verse-line'>{}</span>"},"ja220:5.3":{"pli":"Bahubhāṇi aggipavane mūsikā, ","html":"<span class='verse-line'>{}</span>"},"ja220:5.4":{"pli":"Sahalambatthano kapaṇena dasāti. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"ja221":{"ja221:0.1":{"pli":"Jātaka ","html":"<article id='ja221'><header><ul><li class='division'>{}</li>"},"ja221:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja221:0.3":{"pli":"Kāsāvavagga ","html":"<li>{}</li></ul>"},"ja221:0.4":{"pli":"1. Kāsāvajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja221:1.1":{"pli":"“Anikkasāvo kāsāvaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja221:1.2":{"pli":"yo vatthaṁ paridahissati; ","html":"<span class='verse-line'>{}</span>"},"ja221:1.3":{"pli":"Apeto damasaccena, ","html":"<span class='verse-line'>{}</span>"},"ja221:1.4":{"pli":"na so kāsāvamarahati. ","html":"<span class='verse-line'>{}</span></p>"},"ja221:2.1":{"pli":"Yo ca vantakasāvassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja221:2.2":{"pli":"Sīlesu susamāhito; ","html":"<span class='verse-line'>{}</span>"},"ja221:2.3":{"pli":"Upeto damasaccena, ","html":"<span class='verse-line'>{}</span>"},"ja221:2.4":{"pli":"Sa ve kāsāvamarahatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja221:3.1":{"pli":"Kāsāvajātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja222":{"ja222:0.1":{"pli":"Jātaka ","html":"<article id='ja222'><header><ul><li class='division'>{}</li>"},"ja222:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja222:0.3":{"pli":"Kāsāvavagga ","html":"<li>{}</li></ul>"},"ja222:0.4":{"pli":"2. Cūḷanandiyajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja222:1.1":{"pli":"“Idaṁ tadācariyavaco, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja222:1.2":{"pli":"pārāsariyo yadabravi; ","html":"<span class='verse-line'>{}</span>"},"ja222:1.3":{"pli":"Māsu tvaṁ akari pāpaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja222:1.4":{"pli":"yaṁ tvaṁ pacchā kataṁ tape. ","html":"<span class='verse-line'>{}</span></p>"},"ja222:2.1":{"pli":"Yāni karoti puriso, ","html":"<p><span class='verse-line'>{}</span>"},"ja222:2.2":{"pli":"tāni attani passati; ","html":"<span class='verse-line'>{}</span>"},"ja222:2.3":{"pli":"Kalyāṇakārī kalyāṇaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja222:2.4":{"pli":"pāpakārī ca pāpakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja222:2.5":{"pli":"Yādisaṁ vapate bījaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja222:2.6":{"pli":"tādisaṁ harate phalan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja222:3.1":{"pli":"Cūḷanandiyajātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja223":{"ja223:0.1":{"pli":"Jātaka ","html":"<article id='ja223'><header><ul><li class='division'>{}</li>"},"ja223:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja223:0.3":{"pli":"Kāsāvavagga ","html":"<li>{}</li></ul>"},"ja223:0.4":{"pli":"3. Puṭabhattajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja223:1.1":{"pli":"“Name namantassa bhaje bhajantaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja223:1.2":{"pli":"Kiccānukubbassa kareyya kiccaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja223:1.3":{"pli":"Nānatthakāmassa kareyya atthaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja223:1.4":{"pli":"Asambhajantampi na sambhajeyya. ","html":"<span class='verse-line'>{}</span></p>"},"ja223:2.1":{"pli":"Caje cajantaṁ vanathaṁ na kayirā, ","html":"<p><span class='verse-line'>{}</span>"},"ja223:2.2":{"pli":"Apetacittena na sambhajeyya; ","html":"<span class='verse-line'>{}</span>"},"ja223:2.3":{"pli":"Dijo dumaṁ khīṇaphalanti ñatvā, ","html":"<span class='verse-line'>{}</span>"},"ja223:2.4":{"pli":"Aññaṁ samekkheyya mahā hi loko”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja223:3.1":{"pli":"Puṭabhattajātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja224":{"ja224:0.1":{"pli":"Jātaka ","html":"<article id='ja224'><header><ul><li class='division'>{}</li>"},"ja224:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja224:0.3":{"pli":"Kāsāvavagga ","html":"<li>{}</li></ul>"},"ja224:0.4":{"pli":"4. Kumbhilajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja224:1.1":{"pli":"“Yassete caturo dhammā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja224:1.2":{"pli":"vānarinda yathā tava; ","html":"<span class='verse-line'>{}</span>"},"ja224:1.3":{"pli":"Saccaṁ dhammo dhiti cāgo, ","html":"<span class='verse-line'>{}</span>"},"ja224:1.4":{"pli":"diṭṭhaṁ so ativattati. ","html":"<span class='verse-line'>{}</span></p>"},"ja224:2.1":{"pli":"Yassa cete na vijjanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja224:2.2":{"pli":"guṇā paramabhaddakā; ","html":"<span class='verse-line'>{}</span>"},"ja224:2.3":{"pli":"Saccaṁ dhammo dhiti cāgo, ","html":"<span class='verse-line'>{}</span>"},"ja224:2.4":{"pli":"diṭṭhaṁ so nātivattatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja224:3.1":{"pli":"Kumbhilajātakaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja225":{"ja225:0.1":{"pli":"Jātaka ","html":"<article id='ja225'><header><ul><li class='division'>{}</li>"},"ja225:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja225:0.3":{"pli":"Kāsāvavagga ","html":"<li>{}</li></ul>"},"ja225:0.4":{"pli":"5. Khantivaṇṇajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja225:1.1":{"pli":"“Atthi me puriso deva, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja225:1.2":{"pli":"sabbakiccesu byāvaṭo; ","html":"<span class='verse-line'>{}</span>"},"ja225:1.3":{"pli":"Tassa cekoparādhatthi, ","html":"<span class='verse-line'>{}</span>"},"ja225:1.4":{"pli":"tattha tvaṁ kinti maññasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja225:2.1":{"pli":"“Amhākampatthi puriso, ","html":"<p><span class='verse-line'>{}</span>"},"ja225:2.2":{"pli":"ediso idha vijjati; ","html":"<span class='verse-line'>{}</span>"},"ja225:2.3":{"pli":"Dullabho aṅgasampanno, ","html":"<span class='verse-line'>{}</span>"},"ja225:2.4":{"pli":"khantirasmāka ruccatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja225:3.1":{"pli":"Khantivaṇṇajātakaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja226":{"ja226:0.1":{"pli":"Jātaka ","html":"<article id='ja226'><header><ul><li class='division'>{}</li>"},"ja226:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja226:0.3":{"pli":"Kāsāvavagga ","html":"<li>{}</li></ul>"},"ja226:0.4":{"pli":"6. Kosiyajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja226:1.1":{"pli":"“Kāle nikkhamanā sādhu, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja226:1.2":{"pli":"nākāle sādhu nikkhamo; ","html":"<span class='verse-line'>{}</span>"},"ja226:1.3":{"pli":"Akālena hi nikkhamma, ","html":"<span class='verse-line'>{}</span>"},"ja226:1.4":{"pli":"ekakampi bahujjano; ","html":"<span class='verse-line'>{}</span>"},"ja226:1.5":{"pli":"Na kiñci atthaṁ joteti, ","html":"<span class='verse-line'>{}</span>"},"ja226:1.6":{"pli":"dhaṅkasenāva kosiyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja226:2.1":{"pli":"Dhīro ca vidhividhānaññū, ","html":"<p><span class='verse-line'>{}</span>"},"ja226:2.2":{"pli":"paresaṁ vivarānugū; ","html":"<span class='verse-line'>{}</span>"},"ja226:2.3":{"pli":"Sabbāmitte vasīkatvā, ","html":"<span class='verse-line'>{}</span>"},"ja226:2.4":{"pli":"kosiyova sukhī siyā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja226:3.1":{"pli":"Kosiyajātakaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja227":{"ja227:0.1":{"pli":"Jātaka ","html":"<article id='ja227'><header><ul><li class='division'>{}</li>"},"ja227:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja227:0.3":{"pli":"Kāsāvavagga ","html":"<li>{}</li></ul>"},"ja227:0.4":{"pli":"7. Gūthapāṇajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja227:1.1":{"pli":"“Sūro sūrena saṅgamma, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja227:1.2":{"pli":"vikkantena pahārinā; ","html":"<span class='verse-line'>{}</span>"},"ja227:1.3":{"pli":"Ehi nāga nivattassu, ","html":"<span class='verse-line'>{}</span>"},"ja227:1.4":{"pli":"kiṁ nu bhīto palāyasi; ","html":"<span class='verse-line'>{}</span>"},"ja227:1.5":{"pli":"Passantu aṅgamagadhā, ","html":"<span class='verse-line'>{}</span>"},"ja227:1.6":{"pli":"mama tuyhañca vikkamaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja227:2.1":{"pli":"“Na taṁ pādā vadhissāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja227:2.2":{"pli":"na dantehi na soṇḍiyā; ","html":"<span class='verse-line'>{}</span>"},"ja227:2.3":{"pli":"Mīḷhena taṁ vadhissāmi, ","html":"<span class='verse-line'>{}</span>"},"ja227:2.4":{"pli":"pūti haññatu pūtinā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja227:3.1":{"pli":"Gūthapāṇajātakaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja228":{"ja228:0.1":{"pli":"Jātaka ","html":"<article id='ja228'><header><ul><li class='division'>{}</li>"},"ja228:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja228:0.3":{"pli":"Kāsāvavagga ","html":"<li>{}</li></ul>"},"ja228:0.4":{"pli":"8. Kāmanītajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja228:1.1":{"pli":"“Tayo giriṁ antaraṁ kāmayāmi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja228:1.2":{"pli":"Pañcālā kuruyo kekake ca; ","html":"<span class='verse-line'>{}</span>"},"ja228:1.3":{"pli":"Tatuttariṁ brāhmaṇa kāmayāmi, ","html":"<span class='verse-line'>{}</span>"},"ja228:1.4":{"pli":"Tikiccha maṁ brāhmaṇa kāmanītaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja228:2.1":{"pli":"“Kaṇhāhidaṭṭhassa karonti heke, ","html":"<p><span class='verse-line'>{}</span>"},"ja228:2.2":{"pli":"Amanussapaviṭṭhassa karonti paṇḍitā; ","html":"<span class='verse-line'>{}</span>"},"ja228:2.3":{"pli":"Na kāmanītassa karoti koci, ","html":"<span class='verse-line'>{}</span>"},"ja228:2.4":{"pli":"Okkantasukkassa hi kā tikicchā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja228:3.1":{"pli":"Kāmanītajātakaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja229":{"ja229:0.1":{"pli":"Jātaka ","html":"<article id='ja229'><header><ul><li class='division'>{}</li>"},"ja229:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja229:0.3":{"pli":"Kāsāvavagga ","html":"<li>{}</li></ul>"},"ja229:0.4":{"pli":"9. Palāyitajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja229:1.1":{"pli":"“Gajaggameghehi hayaggamālibhi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja229:1.2":{"pli":"Rathūmijātehi sarābhivassebhi; ","html":"<span class='verse-line'>{}</span>"},"ja229:1.3":{"pli":"Tharuggahāvaṭṭadaḷhappahāribhi, ","html":"<span class='verse-line'>{}</span>"},"ja229:1.4":{"pli":"Parivāritā takkasilā samantato. ","html":"<span class='verse-line'>{}</span></p>"},"ja229:2.1":{"pli":"Abhidhāvatha cūpadhāvatha ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja229:2.2":{"pli":"Vividhā vināditā vadantibhi; ","html":"<span class='verse-line'>{}</span>"},"ja229:2.3":{"pli":"Vattatajja tumulo ghoso yathā, ","html":"<span class='verse-line'>{}</span>"},"ja229:2.4":{"pli":"Vijjulatā jaladharassa gajjato”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja229:3.1":{"pli":"Palāyitajātakaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja23":{"ja23:0.1":{"pli":"Jātaka ","eng":"Stories of Past Lives 23 ","html":"<article id='ja23'><header><ul><li class='division'>{}</li>"},"ja23:0.2":{"pli":"Ekakanipāta ","eng":"The Book of the Ones ","html":"<li>{}</li>"},"ja23:0.3":{"pli":"Kuruṅgavagga ","eng":"The Four-horned Antelope ","html":"<li>{}</li></ul>"},"ja23:0.4":{"pli":"3. Bhojājānīyajātaka ","eng":"The King’s Thoroughbred ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja23:1.1":{"pli":"“Api passena semāno, ","eng":"Though lying on my side ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>","comm":"A wounded warhouse urges its rider to take one last stand. "},"ja23:1.2":{"pli":"sallebhi sallalīkato; ","eng":"pierced by many arrows, ","html":"<span class='verse-line'>{}</span>"},"ja23:1.3":{"pli":"Seyyova vaḷavā bhojjo, ","eng":"the king’s stallion beats a gelding—","html":"<span class='verse-line'>{}</span>","comm":"<i lang='pi' translate='no'>Bhoja</i> is a common name or term for a king. The commentary says the <i lang='pi' translate='no'>bhojja</i> was a stallion from Sindh (today a province of Pakistan). | <i lang='pi' translate='no'>Vaḷavā</i> is normally “mare”, but here it is masculine ablative, glossed with the masculine <i lang='pi' translate='no'>khaluṅkasso</i> (“wild colt”, see <a href='index.html?q=an8.14#9.1'>AN 8.14:9.1</a>). It is said to be not from Sindh. Monier-Williams defines <i lang='pi' translate='no'>vaḍaba</i> as “a male horse resembling a mare”, perhaps a gelding. "},"ja23:1.4":{"pli":"yuñja maññeva sārathī”ti. ","eng":"harness me now, charioteer. ","html":"<span class='verse-line'>{}</span></p></blockquote>","comm":"Read <i lang='pi' translate='no'>yuñja maṁ yeva</i>. "},"ja23:2.1":{"pli":"Bhojājānīyajātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}