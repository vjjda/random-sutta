{"tha-ap395":{"tha-ap395:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap395'><header><ul><li class='division'>{}</li>"},"tha-ap395:0.2":{"pli":"Pilindavacchavagga ","html":"<li>{}</li></ul>"},"tha-ap395:0.3":{"pli":"Sabbakittikattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap395:1.1":{"pli":"“Kaṇikāraṁva jalitaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap395:1.2":{"pli":"dīparukkhaṁva ujjalaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:1.3":{"pli":"Osadhiṁva virocantaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:1.4":{"pli":"vijjutaṁ gagane yathā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap395:2.1":{"pli":"Asambhītaṁ anuttāsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap395:2.2":{"pli":"migarājaṁva kesariṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:2.3":{"pli":"Ñāṇālokaṁ pakāsentaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:2.4":{"pli":"maddantaṁ titthiye gaṇe. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap395:3.1":{"pli":"Uddharantaṁ imaṁ lokaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap395:3.2":{"pli":"chindantaṁ sabbasaṁsayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:3.3":{"pli":"Gajjantaṁ migarājaṁva, ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:3.4":{"pli":"addasaṁ lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap395:4.1":{"pli":"Jaṭājinadharo āsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap395:4.2":{"pli":"brahā uju patāpavā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:4.3":{"pli":"Vākacīraṁ gahetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:4.4":{"pli":"pādamūle apatthariṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap395:5.1":{"pli":"Kāḷānusāriyaṁ gayha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap395:5.2":{"pli":"anulimpiṁ tathāgataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:5.3":{"pli":"Sambuddhamanulimpetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:5.4":{"pli":"santhaviṁ lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap395:6.1":{"pli":"‘Samuddharasimaṁ lokaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap395:6.2":{"pli":"oghatiṇṇamahāmuni; ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:6.3":{"pli":"Ñāṇālokena jotesi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:6.4":{"pli":"nāvaṭaṁ ñāṇamuttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap395:7.1":{"pli":"Dhammacakkaṁ pavattesi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap395:7.2":{"pli":"maddase paratitthiye; ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:7.3":{"pli":"Usabho jitasaṅgāmo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:7.4":{"pli":"sampakampesi medaniṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap395:8.1":{"pli":"Mahāsamudde ūmiyo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap395:8.2":{"pli":"velantamhi pabhijjare; ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:8.3":{"pli":"Tatheva tava ñāṇamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:8.4":{"pli":"sabbadiṭṭhī pabhijjare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap395:9.1":{"pli":"Sukhumacchikajālena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap395:9.2":{"pli":"saramhi sampatānite; ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:9.3":{"pli":"Antojālikatā pāṇā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:9.4":{"pli":"pīḷitā honti tāvade. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap395:10.1":{"pli":"Tatheva titthiyā loke, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap395:10.2":{"pli":"puthupāsaṇḍanissitā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:10.3":{"pli":"Antoñāṇavare tuyhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:10.4":{"pli":"parivattanti mārisa. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap395:11.1":{"pli":"Patiṭṭhā vuyhataṁ oghe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap395:11.2":{"pli":"tvañhi nātho abandhunaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:11.3":{"pli":"Bhayaṭṭitānaṁ saraṇaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:11.4":{"pli":"muttitthīnaṁ parāyaṇaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap395:12.1":{"pli":"Ekavīro asadiso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap395:12.2":{"pli":"mettākaruṇasañcayo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:12.3":{"pli":"Asamo susamo santo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:12.4":{"pli":"vasī tādī jitañjayo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap395:13.1":{"pli":"Dhīro vigatasammoho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap395:13.2":{"pli":"anejo akathaṅkathī; ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:13.3":{"pli":"Tusito vantadososi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:13.4":{"pli":"nimmalo saṁyato suci. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap395:14.1":{"pli":"Saṅgātigo hatamado, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap395:14.2":{"pli":"tevijjo tibhavantago; ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:14.3":{"pli":"Sīmātigo dhammagaru, ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:14.4":{"pli":"gatattho hitavabbhuto. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap395:15.1":{"pli":"Tārako tvaṁ yathā nāvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap395:15.2":{"pli":"nidhīvassāsakārako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:15.3":{"pli":"Asambhīto yathā sīho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:15.4":{"pli":"gajarājāva dappito’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap395:16.1":{"pli":"Thometvā dasagāthāhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap395:16.2":{"pli":"padumuttaraṁ mahāyasaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:16.3":{"pli":"Vanditvā satthuno pāde, ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:16.4":{"pli":"tuṇhī aṭṭhāsahaṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap395:17.1":{"pli":"Padumuttaro lokavidū, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap395:17.2":{"pli":"āhutīnaṁ paṭiggaho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:17.3":{"pli":"Bhikkhusaṅghe ṭhito satthā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:17.4":{"pli":"imā gāthā abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap395:18.1":{"pli":"‘Yo me sīlañca ñāṇañca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap395:18.2":{"pli":"saddhammañcāpi vaṇṇayi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:18.3":{"pli":"Tamahaṁ kittayissāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:18.4":{"pli":"suṇātha mama bhāsato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap395:19.1":{"pli":"Saṭṭhi kappasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap395:19.2":{"pli":"devaloke ramissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:19.3":{"pli":"Aññe devebhibhavitvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:19.4":{"pli":"issaraṁ kārayissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap395:20.1":{"pli":"So pacchā pabbajitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap395:20.2":{"pli":"sukkamūlena codito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:20.3":{"pli":"Gotamassa bhagavato, ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:20.4":{"pli":"sāsane pabbajissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap395:21.1":{"pli":"Pabbajitvāna kāyena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap395:21.2":{"pli":"pāpakammaṁ vivajjiya; ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:21.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:21.4":{"pli":"nibbāyissatināsavo’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap395:22.1":{"pli":"Yathāpi megho thanayaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap395:22.2":{"pli":"tappeti mediniṁ imaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:22.3":{"pli":"Tatheva tvaṁ mahāvīra, ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:22.4":{"pli":"dhammena tappayī mamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap395:23.1":{"pli":"Sīlaṁ paññañca dhammañca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap395:23.2":{"pli":"thavitvā lokanāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:23.3":{"pli":"Pattomhi paramaṁ santiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:23.4":{"pli":"nibbānaṁ padamaccutaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap395:24.1":{"pli":"Aho nūna sa bhagavā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap395:24.2":{"pli":"Ciraṁ tiṭṭheyya cakkhumā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:24.3":{"pli":"Aññātañca vijāneyyuṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:24.4":{"pli":"Phuseyyuṁ amataṁ padaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap395:25.1":{"pli":"Ayaṁ me pacchimā jāti, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap395:25.2":{"pli":"bhavā sabbe samūhatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:25.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:25.4":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap395:26.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap395:26.2":{"pli":"yaṁ buddhamabhithomayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:26.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:26.4":{"pli":"kittanāya idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap395:27.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap395:27.2":{"pli":"bhavā sabbe samūhatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:27.3":{"pli":"Sabbāsavā parikkhīṇā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:27.4":{"pli":"natthi dāni punabbhavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap395:28.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap395:28.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:28.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap395:29.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap395:29.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap395:29.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap395:30.1":{"pli":"Itthaṁ sudaṁ āyasmā sabbakittiko thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap395:31.1":{"pli":"Sabbakittikattherassāpadānaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap396":{"tha-ap396:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap396'><header><ul><li class='division'>{}</li>"},"tha-ap396:0.2":{"pli":"Pilindavacchavagga ","html":"<li>{}</li></ul>"},"tha-ap396:0.3":{"pli":"Madhudāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap396:1.1":{"pli":"“Sindhuyā nadiyā tīre, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap396:1.2":{"pli":"sukato assamo mama; ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:1.3":{"pli":"Tattha vācemahaṁ sisse, ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:1.4":{"pli":"itihāsaṁ salakkhaṇaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap396:2.1":{"pli":"Dhammakāmā vinītā te, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap396:2.2":{"pli":"sotukāmā susāsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:2.3":{"pli":"Chaḷaṅge pāramippattā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:2.4":{"pli":"sindhukūle vasanti te. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap396:3.1":{"pli":"Uppātagamane ceva, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap396:3.2":{"pli":"lakkhaṇesu ca kovidā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:3.3":{"pli":"Uttamatthaṁ gavesantā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:3.4":{"pli":"vasanti vipine tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap396:4.1":{"pli":"Sumedho nāma sambuddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap396:4.2":{"pli":"loke uppajji tāvade; ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:4.3":{"pli":"Amhākaṁ anukampanto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:4.4":{"pli":"upāgacchi vināyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap396:5.1":{"pli":"Upāgataṁ mahāvīraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap396:5.2":{"pli":"sumedhaṁ lokanāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:5.3":{"pli":"Tiṇasanthārakaṁ katvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:5.4":{"pli":"lokajeṭṭhassadāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap396:6.1":{"pli":"Vipināto madhuṁ gayha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap396:6.2":{"pli":"buddhaseṭṭhassadāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:6.3":{"pli":"Sambuddho paribhuñjitvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:6.4":{"pli":"idaṁ vacanamabravi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap396:7.1":{"pli":"‘Yo taṁ adāsi madhuṁ me, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap396:7.2":{"pli":"pasanno sehi pāṇibhi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:7.3":{"pli":"Tamahaṁ kittayissāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:7.4":{"pli":"suṇātha mama bhāsato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap396:8.1":{"pli":"Iminā madhudānena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap396:8.2":{"pli":"tiṇasanthārakena ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:8.3":{"pli":"Tiṁsa kappasahassāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:8.4":{"pli":"devaloke ramissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap396:9.1":{"pli":"Tiṁsa kappasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap396:9.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:9.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:9.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap396:10.1":{"pli":"Tassa dhammesu dāyādo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap396:10.2":{"pli":"oraso dhammanimmito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:10.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:10.4":{"pli":"nibbāyissatināsavo’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap396:11.1":{"pli":"Devalokā idhāgantvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap396:11.2":{"pli":"mātukucchiṁ upāgate; ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:11.3":{"pli":"Madhuvassaṁ pavassittha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:11.4":{"pli":"chādayaṁ madhunā mahiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap396:12.1":{"pli":"Mayi nikkhantamattamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap396:12.2":{"pli":"kucchiyā ca suduttarā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:12.3":{"pli":"Tatrāpi madhuvassaṁ me, ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:12.4":{"pli":"vassate niccakālikaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap396:13.1":{"pli":"Agārā abhinikkhamma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap396:13.2":{"pli":"pabbajiṁ anagāriyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:13.3":{"pli":"Lābhī annassa pānassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:13.4":{"pli":"madhudānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap396:14.1":{"pli":"Sabbakāmasamiddhohaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap396:14.2":{"pli":"bhavitvā devamānuse; ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:14.3":{"pli":"Teneva madhudānena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:14.4":{"pli":"pattomhi āsavakkhayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap396:15.1":{"pli":"Vuṭṭhamhi deve caturaṅgule tiṇe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap396:15.2":{"pli":"Sampupphite dharaṇīruhe sañchanne; ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:15.3":{"pli":"Suññe ghare maṇḍaparukkhamūlake, ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:15.4":{"pli":"Vasāmi niccaṁ sukhito anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap396:16.1":{"pli":"Majjhe mahante hīne ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap396:16.2":{"pli":"bhave sabbe atikkamiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:16.3":{"pli":"Ajja me āsavā khīṇā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:16.4":{"pli":"natthi dāni punabbhavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap396:17.1":{"pli":"Tiṁsakappasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap396:17.2":{"pli":"yaṁ dānamadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:17.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:17.4":{"pli":"madhudānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap396:18.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap396:18.2":{"pli":"bhavā sabbe samūhatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:18.3":{"pli":"Sabbāsavā parikkhīṇā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:18.4":{"pli":"natthi dāni punabbhavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap396:19.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap396:19.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:19.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap396:20.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap396:20.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap396:20.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap396:21.1":{"pli":"Itthaṁ sudaṁ āyasmā madhudāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap396:22.1":{"pli":"Madhudāyakattherassāpadānaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap397":{"tha-ap397:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap397'><header><ul><li class='division'>{}</li>"},"tha-ap397:0.2":{"pli":"Pilindavacchavagga ","html":"<li>{}</li></ul>"},"tha-ap397:0.3":{"pli":"5 Padumakūṭāgāriyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap397:1.1":{"pli":"“Piyadassī nāma bhagavā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap397:1.2":{"pli":"sayambhū lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:1.3":{"pli":"Vivekakāmo sambuddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:1.4":{"pli":"samādhikusalo muni. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:2.1":{"pli":"Vanasaṇḍaṁ samogayha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:2.2":{"pli":"piyadassī mahāmuni; ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:2.3":{"pli":"Paṁsukūlaṁ pattharitvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:2.4":{"pli":"nisīdi purisuttamo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:3.1":{"pli":"Migaluddo pure āsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:3.2":{"pli":"araññe kānane ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:3.3":{"pli":"Pasadaṁ migamesanto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:3.4":{"pli":"āhiṇḍāmi ahaṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:4.1":{"pli":"Tatthaddasāsiṁ sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:4.2":{"pli":"oghatiṇṇamanāsavaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:4.3":{"pli":"Pupphitaṁ sālarājaṁva, ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:4.4":{"pli":"sataraṁsiṁva uggataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:5.1":{"pli":"Disvānahaṁ devadevaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:5.2":{"pli":"piyadassiṁ mahāyasaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:5.3":{"pli":"Jātassaraṁ samogayha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:5.4":{"pli":"padumaṁ āhariṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:6.1":{"pli":"Āharitvāna padumaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:6.2":{"pli":"satapattaṁ manoramaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:6.3":{"pli":"Kūṭāgāraṁ karitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:6.4":{"pli":"chādayiṁ padumenahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:7.1":{"pli":"Anukampako kāruṇiko, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:7.2":{"pli":"piyadassī mahāmuni; ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:7.3":{"pli":"Sattarattindivaṁ buddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:7.4":{"pli":"kūṭāgāre vasī jino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:8.1":{"pli":"Purāṇaṁ chaḍḍayitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:8.2":{"pli":"navena chādayiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:8.3":{"pli":"Añjaliṁ paggahetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:8.4":{"pli":"aṭṭhāsiṁ tāvade ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:9.1":{"pli":"Vuṭṭhahitvā samādhimhā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:9.2":{"pli":"piyadassī mahāmuni; ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:9.3":{"pli":"Disaṁ anuvilokento, ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:9.4":{"pli":"nisīdi lokanāyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:10.1":{"pli":"Tadā sudassano nāma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:10.2":{"pli":"upaṭṭhāko mahiddhiko; ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:10.3":{"pli":"Cittamaññāya buddhassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:10.4":{"pli":"piyadassissa satthuno. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:11.1":{"pli":"Asītiyā sahassehi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:11.2":{"pli":"bhikkhūhi parivārito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:11.3":{"pli":"Vanante sukhamāsīnaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:11.4":{"pli":"upesi lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:12.1":{"pli":"Yāvatā vanasaṇḍamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:12.2":{"pli":"adhivatthā ca devatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:12.3":{"pli":"Buddhassa cittamaññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:12.4":{"pli":"sabbe sannipatuṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:13.1":{"pli":"Samāgatesu yakkhesu, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:13.2":{"pli":"kumbhaṇḍe saharakkhase; ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:13.3":{"pli":"Bhikkhusaṅghe ca sampatte, ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:13.4":{"pli":"gāthā pabyāharī jino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:14.1":{"pli":"‘Yo maṁ sattāhaṁ pūjesi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:14.2":{"pli":"āvāsañca akāsi me; ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:14.3":{"pli":"Tamahaṁ kittayissāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:14.4":{"pli":"suṇātha mama bhāsato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:15.1":{"pli":"Sududdasaṁ sunipuṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:15.2":{"pli":"gambhīraṁ suppakāsitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:15.3":{"pli":"Ñāṇena kittayissāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:15.4":{"pli":"suṇātha mama bhāsato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:16.1":{"pli":"Catuddasāni kappāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:16.2":{"pli":"devarajjaṁ karissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:16.3":{"pli":"Kūṭāgāraṁ mahantassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:16.4":{"pli":"padmapupphehi chāditaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:17.1":{"pli":"Ākāse dhārayissati, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:17.2":{"pli":"Pupphakammassidaṁ phalaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:17.3":{"pli":"Catubbīse kappasate, ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:17.4":{"pli":"Vokiṇṇaṁ saṁsarissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:18.1":{"pli":"Tattha pupphamayaṁ byamhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:18.2":{"pli":"Ākāse dhārayissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:18.3":{"pli":"Yathā padumapattamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:18.4":{"pli":"Toyaṁ na upalimpati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:19.1":{"pli":"Tathevīmassa ñāṇamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:19.2":{"pli":"kilesā nopalimpare; ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:19.3":{"pli":"Manasā vinivaṭṭetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:19.4":{"pli":"pañca nīvaraṇe ayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:20.1":{"pli":"Cittaṁ janetvā nekkhamme, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:20.2":{"pli":"agārā pabbajissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:20.3":{"pli":"Tato pupphamaye byamhe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:20.4":{"pli":"dhārente nikkhamissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:21.1":{"pli":"Rukkhamūle vasantassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:21.2":{"pli":"Nipakassa satīmato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:21.3":{"pli":"Tattha pupphamayaṁ byamhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:21.4":{"pli":"Matthake dhārayissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:22.1":{"pli":"Cīvaraṁ piṇḍapātañca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:22.2":{"pli":"paccayaṁ sayanāsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:22.3":{"pli":"Datvāna bhikkhusaṅghassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:22.4":{"pli":"nibbāyissatināsavo’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:23.1":{"pli":"Kūṭāgārena caratā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:23.2":{"pli":"pabbajjaṁ abhinikkhamiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:23.3":{"pli":"Rukkhamūle vasantampi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:23.4":{"pli":"kūṭāgāraṁ dharīyati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:24.1":{"pli":"Cīvare piṇḍapāte ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:24.2":{"pli":"cetanā me na vijjati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:24.3":{"pli":"Puññakammena saṁyutto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:24.4":{"pli":"labhāmi pariniṭṭhitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:25.1":{"pli":"Gaṇanāto asaṅkheyyā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:25.2":{"pli":"kappakoṭī bahū mama; ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:25.3":{"pli":"Rittakā te atikkantā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:25.4":{"pli":"pamuttā lokanāyakā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:26.1":{"pli":"Aṭṭhārase kappasate, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:26.2":{"pli":"piyadassī vināyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:26.3":{"pli":"Tamahaṁ payirupāsitvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:26.4":{"pli":"imaṁ yoniṁ upāgato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:27.1":{"pli":"Idha passāmi sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:27.2":{"pli":"anomaṁ nāma cakkhumaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:27.3":{"pli":"Tamahaṁ upagantvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:27.4":{"pli":"pabbajiṁ anagāriyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:28.1":{"pli":"Dukkhassantakaro buddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:28.2":{"pli":"maggaṁ me desayī jino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:28.3":{"pli":"Tassa dhammaṁ suṇitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:28.4":{"pli":"pattomhi acalaṁ padaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:29.1":{"pli":"Tosayitvāna sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:29.2":{"pli":"gotamaṁ sakyapuṅgavaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:29.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:29.4":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:30.1":{"pli":"Aṭṭhārase kappasate, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:30.2":{"pli":"yaṁ buddhamabhipūjayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:30.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:30.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:31.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:31.2":{"pli":"bhavā sabbe samūhatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:31.3":{"pli":"Sabbāsavā parikkhīṇā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:31.4":{"pli":"natthi dāni punabbhavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:32.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:32.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:32.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap397:33.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap397:33.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap397:33.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap397:34.1":{"pli":"Itthaṁ sudaṁ āyasmā padumakūṭāgāriyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap397:35.1":{"pli":"Padumakūṭāgāriyattherassāpadānaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap398":{"tha-ap398:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap398'><header><ul><li class='division'>{}</li>"},"tha-ap398:0.2":{"pli":"Pilindavacchavagga ","html":"<li>{}</li></ul>"},"tha-ap398:0.3":{"pli":"6 Bākulattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap398:1.1":{"pli":"“Himavantassāvidūre, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap398:1.2":{"pli":"sobhito nāma pabbato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:1.3":{"pli":"Assamo sukato mayhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:1.4":{"pli":"sakasissehi māpito. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:2.1":{"pli":"Maṇḍapā ca bahū tattha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:2.2":{"pli":"pupphitā sinduvārakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:2.3":{"pli":"Kapitthā ca bahū tattha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:2.4":{"pli":"pupphitā jīvajīvakā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:3.1":{"pli":"Nigguṇḍiyo bahū tattha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:3.2":{"pli":"badarāmalakāni ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:3.3":{"pli":"Phārusakā alābū ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:3.4":{"pli":"puṇḍarīkā ca pupphitā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:4.1":{"pli":"Āḷakā beluvā tattha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:4.2":{"pli":"kadalī mātuluṅgakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:4.3":{"pli":"Mahānāmā bahū tattha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:4.4":{"pli":"ajjunā ca piyaṅgukā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:5.1":{"pli":"Kosambā saḷalā nimbā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:5.2":{"pli":"nigrodhā ca kapitthanā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:5.3":{"pli":"Ediso assamo mayhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:5.4":{"pli":"sasissohaṁ tahiṁ vasiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:6.1":{"pli":"Anomadassī bhagavā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:6.2":{"pli":"sayambhū lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:6.3":{"pli":"Gavesaṁ paṭisallānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:6.4":{"pli":"mamassamamupāgami. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:7.1":{"pli":"Upetamhi mahāvīre, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:7.2":{"pli":"anomadassimahāyase; ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:7.3":{"pli":"Khaṇena lokanāthassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:7.4":{"pli":"vātābādho samuṭṭhahi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:8.1":{"pli":"Vicaranto araññamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:8.2":{"pli":"addasaṁ lokanāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:8.3":{"pli":"Upagantvāna sambuddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:8.4":{"pli":"cakkhumantaṁ mahāyasaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:9.1":{"pli":"Iriyañcāpi disvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:9.2":{"pli":"upalakkhesahaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:9.3":{"pli":"Asaṁsayañhi buddhassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:9.4":{"pli":"byādhi no udapajjatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:10.1":{"pli":"Khippaṁ assamamāgañchiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:10.2":{"pli":"mama sissāna santike; ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:10.3":{"pli":"Bhesajjaṁ kattukāmohaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:10.4":{"pli":"sisse āmantayiṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:11.1":{"pli":"Paṭissuṇitvāna me vākyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:11.2":{"pli":"sissā sabbe sagāravā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:11.3":{"pli":"Ekajjhaṁ sannipatiṁsu, ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:11.4":{"pli":"satthugāravatā mama. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:12.1":{"pli":"Khippaṁ pabbatamāruyha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:12.2":{"pli":"sabbosadhamahāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:12.3":{"pli":"Pānīyayogaṁ katvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:12.4":{"pli":"buddhaseṭṭhassadāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:13.1":{"pli":"Paribhutte mahāvīre, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:13.2":{"pli":"sabbaññulokanāyake; ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:13.3":{"pli":"Khippaṁ vāto vūpasami, ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:13.4":{"pli":"sugatassa mahesino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:14.1":{"pli":"Passaddhaṁ darathaṁ disvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:14.2":{"pli":"anomadassī mahāyaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:14.3":{"pli":"Sakāsane nisīditvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:14.4":{"pli":"imā gāthā abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:15.1":{"pli":"‘Yo me pādāsi bhesajjaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:15.2":{"pli":"byādhiñca samayī mama; ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:15.3":{"pli":"Tamahaṁ kittayissāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:15.4":{"pli":"suṇātha mama bhāsato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:16.1":{"pli":"Kappasatasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:16.2":{"pli":"devaloke ramissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:16.3":{"pli":"Vādite tūriye tattha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:16.4":{"pli":"modissati sadā ayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:17.1":{"pli":"Manussalokamāgantvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:17.2":{"pli":"sukkamūlena codito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:17.3":{"pli":"Sahassakkhattuṁ rājā ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:17.4":{"pli":"cakkavattī bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:18.1":{"pli":"Pañcapaññāsakappamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:18.2":{"pli":"anomo nāma khattiyo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:18.3":{"pli":"Cāturanto vijitāvī, ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:18.4":{"pli":"jambumaṇḍassa issaro. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:19.1":{"pli":"Sattaratanasampanno, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:19.2":{"pli":"cakkavattī mahabbalo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:19.3":{"pli":"Tāvatiṁsepi khobhetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:19.4":{"pli":"issaraṁ kārayissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:20.1":{"pli":"Devabhūto manusso vā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:20.2":{"pli":"appābādho bhavissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:20.3":{"pli":"Pariggahaṁ vivajjetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:20.4":{"pli":"byādhiṁ loke tarissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:21.1":{"pli":"Apparimeyye ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:21.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:21.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:21.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:22.1":{"pli":"Tassa dhammesu dāyādo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:22.2":{"pli":"oraso dhammanimmito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:22.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:22.4":{"pli":"nibbāyissatināsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:23.1":{"pli":"Kilese jhāpayitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:23.2":{"pli":"taṇhāsotaṁ tarissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:23.3":{"pli":"Bākulo nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:23.4":{"pli":"hessati satthu sāvako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:24.1":{"pli":"Idaṁ sabbaṁ abhiññāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:24.2":{"pli":"gotamo sakyapuṅgavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:24.3":{"pli":"Bhikkhusaṅghe nisīditvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:24.4":{"pli":"etadagge ṭhapessati’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:25.1":{"pli":"Anomadassī bhagavā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:25.2":{"pli":"sayambhū lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:25.3":{"pli":"Vivekānuvilokento, ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:25.4":{"pli":"mamassamamupāgami. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:26.1":{"pli":"Upāgataṁ mahāvīraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:26.2":{"pli":"sabbaññuṁ lokanāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:26.3":{"pli":"Sabbosadhena tappesiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:26.4":{"pli":"pasanno sehi pāṇibhi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:27.1":{"pli":"Tassa me sukataṁ kammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:27.2":{"pli":"sukhette bījasampadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:27.3":{"pli":"Khepetuṁ neva sakkomi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:27.4":{"pli":"tadā hi sukataṁ mama. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:28.1":{"pli":"Lābhā mama suladdhaṁ me, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:28.2":{"pli":"yohaṁ addakkhi nāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:28.3":{"pli":"Tena kammāvasesena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:28.4":{"pli":"pattomhi acalaṁ padaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:29.1":{"pli":"Sabbametaṁ abhiññāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:29.2":{"pli":"gotamo sakyapuṅgavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:29.3":{"pli":"Bhikkhusaṅghe nisīditvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:29.4":{"pli":"etadagge ṭhapesi maṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:30.1":{"pli":"Aparimeyye ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:30.2":{"pli":"yaṁ kammamakariṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:30.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:30.4":{"pli":"bhesajjassa idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:31.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:31.2":{"pli":"bhavā sabbe samūhatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:31.3":{"pli":"Sabbāsavā parikkhīṇā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:31.4":{"pli":"natthi dāni punabbhavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:32.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:32.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:32.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap398:33.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap398:33.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap398:33.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap398:34.1":{"pli":"Itthaṁ sudaṁ āyasmā bākulo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap398:35.1":{"pli":"Bākulattherassāpadānaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}