{"ja418":{"ja418:0.1":{"pli":"Jātaka ","html":"<article id='ja418'><header><ul><li class='division'>{}</li>"},"ja418:0.2":{"pli":"Aṭṭhakanipāta ","html":"<li>{}</li>"},"ja418:0.3":{"pli":"Kaccānivagga ","html":"<li>{}</li></ul>"},"ja418:0.4":{"pli":"2. Aṭṭhasaddajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja418:1.1":{"pli":"“Idaṁ pure ninnamāhu, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja418:1.2":{"pli":"bahumacchaṁ mahodakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja418:1.3":{"pli":"Āvāso bakarājassa, ","html":"<span class='verse-line'>{}</span>"},"ja418:1.4":{"pli":"pettikaṁ bhavanaṁ mama; ","html":"<span class='verse-line'>{}</span>"},"ja418:1.5":{"pli":"Tyajja bhekena yāpema, ","html":"<span class='verse-line'>{}</span>"},"ja418:1.6":{"pli":"okaṁ na vijahāmase”. ","html":"<span class='verse-line'>{}</span></p>"},"ja418:2.1":{"pli":"“Ko dutiyaṁ asīlissa, ","html":"<p><span class='verse-line'>{}</span>"},"ja418:2.2":{"pli":"bandharassakkhi bhecchati; ","html":"<span class='verse-line'>{}</span>"},"ja418:2.3":{"pli":"Ko me putte kulāvakaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja418:2.4":{"pli":"mañca sotthiṁ karissati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja418:3.1":{"pli":"“Sabbā parikkhayā pheggu, ","html":"<p><span class='verse-line'>{}</span>"},"ja418:3.2":{"pli":"yāva tassā gatī ahu; ","html":"<span class='verse-line'>{}</span>"},"ja418:3.3":{"pli":"Khīṇabhakkho mahārāja, ","html":"<span class='verse-line'>{}</span>"},"ja418:3.4":{"pli":"sāre na ramatī ghuṇo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja418:4.1":{"pli":"“Sā nūnāhaṁ ito gantvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja418:4.2":{"pli":"rañño muttā nivesanā; ","html":"<span class='verse-line'>{}</span>"},"ja418:4.3":{"pli":"Attānaṁ ramayissāmi, ","html":"<span class='verse-line'>{}</span>"},"ja418:4.4":{"pli":"dumasākhaniketinī”. ","html":"<span class='verse-line'>{}</span></p>"},"ja418:5.1":{"pli":"“So nūnāhaṁ ito gantvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja418:5.2":{"pli":"rañño mutto nivesanā; ","html":"<span class='verse-line'>{}</span>"},"ja418:5.3":{"pli":"Aggodakāni pissāmi, ","html":"<span class='verse-line'>{}</span>"},"ja418:5.4":{"pli":"yūthassa purato vajaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja418:6.1":{"pli":"“Taṁ maṁ kāmehi sammattaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja418:6.2":{"pli":"rattaṁ kāmesu mucchitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja418:6.3":{"pli":"Ānayī bharato luddo, ","html":"<span class='verse-line'>{}</span>"},"ja418:6.4":{"pli":"bāhiko bhaddamatthu te”. ","html":"<span class='verse-line'>{}</span></p>"},"ja418:7.1":{"pli":"“Andhakāratimisāyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja418:7.2":{"pli":"tuṅge uparipabbate; ","html":"<span class='verse-line'>{}</span>"},"ja418:7.3":{"pli":"Sā maṁ saṇhena mudunā, ","html":"<span class='verse-line'>{}</span>"},"ja418:7.4":{"pli":"mā pādaṁ khali yasmani”. ","html":"<span class='verse-line'>{}</span></p>"},"ja418:8.1":{"pli":"“Asaṁsayaṁ jātikhayantadassī, ","html":"<p><span class='verse-line'>{}</span>"},"ja418:8.2":{"pli":"Na gabbhaseyyaṁ punarāvajissaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja418:8.3":{"pli":"Ayamantimā pacchimā gabbhaseyyā, ","html":"<span class='verse-line'>{}</span>"},"ja418:8.4":{"pli":"Khīṇo me saṁsāro punabbhavāyā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja418:9.1":{"pli":"Aṭṭhasaddajātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja419":{"ja419:0.1":{"pli":"Jātaka ","html":"<article id='ja419'><header><ul><li class='division'>{}</li>"},"ja419:0.2":{"pli":"Aṭṭhakanipāta ","html":"<li>{}</li>"},"ja419:0.3":{"pli":"Kaccānivagga ","html":"<li>{}</li></ul>"},"ja419:0.4":{"pli":"3. Sulasājātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja419:1.1":{"pli":"“Idaṁ suvaṇṇakāyūraṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja419:1.2":{"pli":"muttā veḷuriyā bahū; ","html":"<span class='verse-line'>{}</span>"},"ja419:1.3":{"pli":"Sabbaṁ harassu bhaddante, ","html":"<span class='verse-line'>{}</span>"},"ja419:1.4":{"pli":"mañca dāsīti sāvaya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja419:2.1":{"pli":"“Oropayassu kalyāṇi, ","html":"<p><span class='verse-line'>{}</span>"},"ja419:2.2":{"pli":"mā bāḷhaṁ paridevasi; ","html":"<span class='verse-line'>{}</span>"},"ja419:2.3":{"pli":"Na cāhaṁ abhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"ja419:2.4":{"pli":"ahantvā dhanamābhataṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja419:3.1":{"pli":"“Yato sarāmi attānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja419:3.2":{"pli":"yato pattāsmi viññutaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja419:3.3":{"pli":"Na cāhaṁ abhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"ja419:3.4":{"pli":"aññaṁ piyataraṁ tayā. ","html":"<span class='verse-line'>{}</span></p>"},"ja419:4.1":{"pli":"Ehi taṁ upagūhissaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja419:4.2":{"pli":"karissañca padakkhiṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja419:4.3":{"pli":"Na hi dāni puna atthi, ","html":"<span class='verse-line'>{}</span>"},"ja419:4.4":{"pli":"mama tuyhañca saṅgamo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja419:5.1":{"pli":"“Na hi sabbesu ṭhānesu, ","html":"<p><span class='verse-line'>{}</span>"},"ja419:5.2":{"pli":"puriso hoti paṇḍito; ","html":"<span class='verse-line'>{}</span>"},"ja419:5.3":{"pli":"Itthīpi paṇḍitā hoti, ","html":"<span class='verse-line'>{}</span>"},"ja419:5.4":{"pli":"tattha tattha vicakkhaṇā. ","html":"<span class='verse-line'>{}</span></p>"},"ja419:6.1":{"pli":"Na hi sabbesu ṭhānesu, ","html":"<p><span class='verse-line'>{}</span>"},"ja419:6.2":{"pli":"puriso hoti paṇḍito; ","html":"<span class='verse-line'>{}</span>"},"ja419:6.3":{"pli":"Itthīpi paṇḍitā hoti, ","html":"<span class='verse-line'>{}</span>"},"ja419:6.4":{"pli":"lahuṁ atthaṁ vicintikā. ","html":"<span class='verse-line'>{}</span></p>"},"ja419:7.1":{"pli":"Lahuñca vata khippañca, ","html":"<p><span class='verse-line'>{}</span>"},"ja419:7.2":{"pli":"nikaṭṭhe samacetayi; ","html":"<span class='verse-line'>{}</span>"},"ja419:7.3":{"pli":"Migaṁ puṇṇāyateneva, ","html":"<span class='verse-line'>{}</span>"},"ja419:7.4":{"pli":"sulasā sattukaṁ vadhi. ","html":"<span class='verse-line'>{}</span></p>"},"ja419:8.1":{"pli":"Yodha uppatitaṁ atthaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja419:8.2":{"pli":"na khippamanubujjhati; ","html":"<span class='verse-line'>{}</span>"},"ja419:8.3":{"pli":"So haññati mandamati, ","html":"<span class='verse-line'>{}</span>"},"ja419:8.4":{"pli":"corova girigabbhare. ","html":"<span class='verse-line'>{}</span></p>"},"ja419:9.1":{"pli":"Yo ca uppatitaṁ atthaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja419:9.2":{"pli":"khippameva nibodhati; ","html":"<span class='verse-line'>{}</span>"},"ja419:9.3":{"pli":"Muccate sattusambādhā, ","html":"<span class='verse-line'>{}</span>"},"ja419:9.4":{"pli":"sulasā sattukāmivā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja419:10.1":{"pli":"Sulasājātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja42":{"ja42:0.1":{"pli":"Jātaka ","eng":"Stories of Past Lives 42 ","html":"<article id='ja42'><header><ul><li class='division'>{}</li>"},"ja42:0.2":{"pli":"Ekakanipāta ","eng":"The Book of the Ones ","html":"<li>{}</li>"},"ja42:0.3":{"pli":"Atthakāmavagga ","eng":"Wanting to Help ","html":"<li>{}</li></ul>"},"ja42:0.4":{"pli":"2. Kapotajātaka ","eng":"The Pigeon: a past life story ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja42:1.1":{"pli":"“Yo atthakāmassa hitānukampino, ","eng":"One who does not follow advice when instructed ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>","comm":"A greedy crow, ignoring the warning of the wise pigeon, continues to steal food from the kitchen. "},"ja42:1.2":{"pli":"Ovajjamāno na karoti sāsanaṁ; ","eng":"by an ally who wants to help, ","html":"<span class='verse-line'>{}</span>"},"ja42:1.3":{"pli":"Kapotakassa vacanaṁ akatvā, ","eng":"not following the pigeon’s counsel, ","html":"<span class='verse-line'>{}</span>"},"ja42:1.4":{"pli":"Amittahatthatthagatova setī”ti. ","eng":"ends up in the hands of their foes. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja42:2.1":{"pli":"Kapotajātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja420":{"ja420:0.1":{"pli":"Jātaka ","html":"<article id='ja420'><header><ul><li class='division'>{}</li>"},"ja420:0.2":{"pli":"Aṭṭhakanipāta ","html":"<li>{}</li>"},"ja420:0.3":{"pli":"Kaccānivagga ","html":"<li>{}</li></ul>"},"ja420:0.4":{"pli":"4. Sumaṅgalajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja420:1.1":{"pli":"“Bhusamhi kuddhoti avekkhiyāna, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja420:1.2":{"pli":"Na tāva daṇḍaṁ paṇayeyya issaro; ","html":"<span class='verse-line'>{}</span>"},"ja420:1.3":{"pli":"Aṭṭhānaso appatirūpamattano, ","html":"<span class='verse-line'>{}</span>"},"ja420:1.4":{"pli":"Parassa dukkhāni bhusaṁ udīraye. ","html":"<span class='verse-line'>{}</span></p>"},"ja420:2.1":{"pli":"Yato ca jāneyya pasādamattano, ","html":"<p><span class='verse-line'>{}</span>"},"ja420:2.2":{"pli":"Atthaṁ niyuñjeyya parassa dukkaṭaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja420:2.3":{"pli":"Tadāyamatthoti sayaṁ avekkhiya, ","html":"<span class='verse-line'>{}</span>"},"ja420:2.4":{"pli":"Athassa daṇḍaṁ sadisaṁ nivesaye. ","html":"<span class='verse-line'>{}</span></p>"},"ja420:3.1":{"pli":"Na cāpi jhāpeti paraṁ na attanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja420:3.2":{"pli":"Amucchito yo nayate nayānayaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja420:3.3":{"pli":"Yo daṇḍadhāro bhavatīdha issaro, ","html":"<span class='verse-line'>{}</span>"},"ja420:3.4":{"pli":"Sa vaṇṇagutto siriyā na dhaṁsati. ","html":"<span class='verse-line'>{}</span></p>"},"ja420:4.1":{"pli":"Ye khattiyā se anisammakārino, ","html":"<p><span class='verse-line'>{}</span>"},"ja420:4.2":{"pli":"Paṇenti daṇḍaṁ sahasā pamucchitā; ","html":"<span class='verse-line'>{}</span>"},"ja420:4.3":{"pli":"Avaṇṇasaṁyutā jahanti jīvitaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja420:4.4":{"pli":"Ito vimuttāpi ca yanti duggatiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja420:5.1":{"pli":"Dhamme ca ye ariyappavedite ratā, ","html":"<p><span class='verse-line'>{}</span>"},"ja420:5.2":{"pli":"Anuttarā te vacasā manasā kammunā ca; ","html":"<span class='verse-line'>{}</span>"},"ja420:5.3":{"pli":"Te santisoraccasamādhisaṇṭhitā, ","html":"<span class='verse-line'>{}</span>"},"ja420:5.4":{"pli":"Vajanti lokaṁ dubhayaṁ tathāvidhā. ","html":"<span class='verse-line'>{}</span></p>"},"ja420:6.1":{"pli":"Rājāhamasmi narapamadānamissaro, ","html":"<p><span class='verse-line'>{}</span>"},"ja420:6.2":{"pli":"Sacepi kujjhāmi ṭhapemi attanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja420:6.3":{"pli":"Nisedhayanto janataṁ tathāvidhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja420:6.4":{"pli":"Paṇemi daṇḍaṁ anukampa yoniso”. ","html":"<span class='verse-line'>{}</span></p>"},"ja420:7.1":{"pli":"“Sirī ca lakkhī ca taveva khattiya, ","html":"<p><span class='verse-line'>{}</span>"},"ja420:7.2":{"pli":"Janādhipa mā vijahi kudācanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja420:7.3":{"pli":"Akkodhano niccapasannacitto, ","html":"<span class='verse-line'>{}</span>"},"ja420:7.4":{"pli":"Anīgho tuvaṁ vassasatāni pālaya. ","html":"<span class='verse-line'>{}</span></p>"},"ja420:8.1":{"pli":"Guṇehi etehi upeta khattiya, ","html":"<p><span class='verse-line'>{}</span>"},"ja420:8.2":{"pli":"Ṭhitamariyavattī suvaco akodhano; ","html":"<span class='verse-line'>{}</span>"},"ja420:8.3":{"pli":"Sukhī anuppīḷa pasāsamediniṁ, ","html":"<span class='verse-line'>{}</span>"},"ja420:8.4":{"pli":"Ito vimuttopi ca yāhi suggatiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja420:9.1":{"pli":"Evaṁ sunītena subhāsitena, ","html":"<p><span class='verse-line'>{}</span>"},"ja420:9.2":{"pli":"Dhammena ñāyena upāyaso nayaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja420:9.3":{"pli":"Nibbāpaye saṅkhubhitaṁ mahājanaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja420:9.4":{"pli":"Mahāva megho salilena medinin”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja420:10.1":{"pli":"Sumaṅgalajātakaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja421":{"ja421:0.1":{"pli":"Jātaka ","html":"<article id='ja421'><header><ul><li class='division'>{}</li>"},"ja421:0.2":{"pli":"Aṭṭhakanipāta ","html":"<li>{}</li>"},"ja421:0.3":{"pli":"Kaccānivagga ","html":"<li>{}</li></ul>"},"ja421:0.4":{"pli":"5. Gaṅgamālajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja421:1.1":{"pli":"“Aṅgārajātā pathavī, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja421:1.2":{"pli":"kukkuḷānugatā mahī; ","html":"<span class='verse-line'>{}</span>"},"ja421:1.3":{"pli":"Atha gāyasi vattāni, ","html":"<span class='verse-line'>{}</span>"},"ja421:1.4":{"pli":"na taṁ tapati ātapo. ","html":"<span class='verse-line'>{}</span></p>"},"ja421:2.1":{"pli":"Uddhaṁ tapati ādicco, ","html":"<p><span class='verse-line'>{}</span>"},"ja421:2.2":{"pli":"adho tapati vālukā; ","html":"<span class='verse-line'>{}</span>"},"ja421:2.3":{"pli":"Atha gāyasi vattāni, ","html":"<span class='verse-line'>{}</span>"},"ja421:2.4":{"pli":"na taṁ tapati ātapo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja421:3.1":{"pli":"“Na maṁ tapati ātapo, ","html":"<p><span class='verse-line'>{}</span>"},"ja421:3.2":{"pli":"ātapā tapayanti maṁ; ","html":"<span class='verse-line'>{}</span>"},"ja421:3.3":{"pli":"Atthā hi vividhā rāja, ","html":"<span class='verse-line'>{}</span>"},"ja421:3.4":{"pli":"te tapanti na ātapo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja421:4.1":{"pli":"“Addasaṁ kāma te mūlaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja421:4.2":{"pli":"saṅkappā kāma jāyasi; ","html":"<span class='verse-line'>{}</span>"},"ja421:4.3":{"pli":"Na taṁ saṅkappayissāmi, ","html":"<span class='verse-line'>{}</span>"},"ja421:4.4":{"pli":"evaṁ kāma na hehisi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja421:5.1":{"pli":"“Appāpi kāmā na alaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja421:5.2":{"pli":"bahūhipi na tappati; ","html":"<span class='verse-line'>{}</span>"},"ja421:5.3":{"pli":"Ahahā bālalapanā, ","html":"<span class='verse-line'>{}</span>"},"ja421:5.4":{"pli":"parivajjetha jaggato”. ","html":"<span class='verse-line'>{}</span></p>"},"ja421:6.1":{"pli":"“Appassa kammassa phalaṁ mamedaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja421:6.2":{"pli":"Udayo ajjhāgamā mahattapattaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja421:6.3":{"pli":"Suladdhalābho vata māṇavassa, ","html":"<span class='verse-line'>{}</span>"},"ja421:6.4":{"pli":"Yo pabbajī kāmarāgaṁ pahāya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja421:7.1":{"pli":"“Tapasā pajahanti pāpakammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja421:7.2":{"pli":"Tapasā nhāpitakumbhakārabhāvaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja421:7.3":{"pli":"Tapasā abhibhuyya gaṅgamāla, ","html":"<span class='verse-line'>{}</span>"},"ja421:7.4":{"pli":"Nāmenālapasajja brahmadattaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja421:8.1":{"pli":"“Sandiṭṭhikameva ‘amma’ passatha, ","html":"<p><span class='verse-line'>{}</span>"},"ja421:8.2":{"pli":"Khantīsoraccassa ayaṁ vipāko; ","html":"<span class='verse-line'>{}</span>"},"ja421:8.3":{"pli":"Yo sabbajanassa vanditohu, ","html":"<span class='verse-line'>{}</span>"},"ja421:8.4":{"pli":"Taṁ vandāma sarājikā samaccā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja421:9.1":{"pli":"“Mā kiñci avacuttha gaṅgamālaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja421:9.2":{"pli":"Muninaṁ monapathesu sikkhamānaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja421:9.3":{"pli":"Eso hi atari aṇṇavaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja421:9.4":{"pli":"Yaṁ taritvā caranti vītasokā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja421:10.1":{"pli":"Gaṅgamālajātakaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja422":{"ja422:0.1":{"pli":"Jātaka ","html":"<article id='ja422'><header><ul><li class='division'>{}</li>"},"ja422:0.2":{"pli":"Aṭṭhakanipāta ","html":"<li>{}</li>"},"ja422:0.3":{"pli":"Kaccānivagga ","html":"<li>{}</li></ul>"},"ja422:0.4":{"pli":"6. Cetiyajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja422:1.1":{"pli":"“Dhammo have hato hanti, ","html":"<blockquote class='gatha'><p data-counter='11'><span class='verse-line'>{}</span>"},"ja422:1.2":{"pli":"Nāhato hanti kiñcanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja422:1.3":{"pli":"Tasmā hi dhammaṁ na hane, ","html":"<span class='verse-line'>{}</span>"},"ja422:1.4":{"pli":"Mā tvaṁ dhammo hato hani. ","html":"<span class='verse-line'>{}</span></p>"},"ja422:2.1":{"pli":"Alikaṁ bhāsamānassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja422:2.2":{"pli":"apakkamanti devatā; ","html":"<span class='verse-line'>{}</span>"},"ja422:2.3":{"pli":"Pūtikañca mukhaṁ vāti, ","html":"<span class='verse-line'>{}</span>"},"ja422:2.4":{"pli":"sakaṭṭhānā ca dhaṁsati; ","html":"<span class='verse-line'>{}</span>"},"ja422:2.5":{"pli":"Yo jānaṁ pucchito pañhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja422:2.6":{"pli":"aññathā naṁ viyākare. ","html":"<span class='verse-line'>{}</span></p>"},"ja422:3.1":{"pli":"Sace hi saccaṁ bhaṇasi, ","html":"<p data-counter='21'><span class='verse-line'>{}</span>"},"ja422:3.2":{"pli":"hohi rāja yathā pure; ","html":"<span class='verse-line'>{}</span>"},"ja422:3.3":{"pli":"Musā ce bhāsase rāja, ","html":"<span class='verse-line'>{}</span>"},"ja422:3.4":{"pli":"bhūmiyaṁ tiṭṭha cetiya. ","html":"<span class='verse-line'>{}</span></p>"},"ja422:4.1":{"pli":"Akāle vassatī tassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja422:4.2":{"pli":"kāle tassa na vassati; ","html":"<span class='verse-line'>{}</span>"},"ja422:4.3":{"pli":"Yo jānaṁ pucchito pañhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja422:4.4":{"pli":"aññathā naṁ viyākare. ","html":"<span class='verse-line'>{}</span></p>"},"ja422:5.1":{"pli":"Sace hi saccaṁ bhaṇasi, ","html":"<p data-counter='31'><span class='verse-line'>{}</span>"},"ja422:5.2":{"pli":"hohi rāja yathā pure; ","html":"<span class='verse-line'>{}</span>"},"ja422:5.3":{"pli":"Musā ce bhāsase rāja, ","html":"<span class='verse-line'>{}</span>"},"ja422:5.4":{"pli":"bhūmiṁ pavisa cetiya. ","html":"<span class='verse-line'>{}</span></p>"},"ja422:6.1":{"pli":"Jivhā tassa dvidhā hoti, ","html":"<p><span class='verse-line'>{}</span>"},"ja422:6.2":{"pli":"uragasseva disampati; ","html":"<span class='verse-line'>{}</span>"},"ja422:6.3":{"pli":"Yo jānaṁ pucchito pañhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja422:6.4":{"pli":"aññathā naṁ viyākare. ","html":"<span class='verse-line'>{}</span></p>"},"ja422:7.1":{"pli":"Sace hi saccaṁ bhaṇasi, ","html":"<p data-counter='41'><span class='verse-line'>{}</span>"},"ja422:7.2":{"pli":"hohi rāja yathā pure; ","html":"<span class='verse-line'>{}</span>"},"ja422:7.3":{"pli":"Musā ce bhāsase rāja, ","html":"<span class='verse-line'>{}</span>"},"ja422:7.4":{"pli":"bhiyyo pavisa cetiya. ","html":"<span class='verse-line'>{}</span></p>"},"ja422:8.1":{"pli":"Jivhā tassa na bhavati, ","html":"<p><span class='verse-line'>{}</span>"},"ja422:8.2":{"pli":"macchasseva disampati; ","html":"<span class='verse-line'>{}</span>"},"ja422:8.3":{"pli":"Yo jānaṁ pucchito pañhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja422:8.4":{"pli":"aññathā naṁ viyākare. ","html":"<span class='verse-line'>{}</span></p>"},"ja422:9.1":{"pli":"Sace hi saccaṁ bhaṇasi, ","html":"<p data-counter='51'><span class='verse-line'>{}</span>"},"ja422:9.2":{"pli":"hohi rāja yathā pure; ","html":"<span class='verse-line'>{}</span>"},"ja422:9.3":{"pli":"Musā ce bhāsase rāja, ","html":"<span class='verse-line'>{}</span>"},"ja422:9.4":{"pli":"bhiyyo pavisa cetiya. ","html":"<span class='verse-line'>{}</span></p>"},"ja422:10.1":{"pli":"Thiyova tassa jāyanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja422:10.2":{"pli":"na pumā jāyare kule; ","html":"<span class='verse-line'>{}</span>"},"ja422:10.3":{"pli":"Yo jānaṁ pucchito pañhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja422:10.4":{"pli":"aññathā naṁ viyākare. ","html":"<span class='verse-line'>{}</span></p>"},"ja422:11.1":{"pli":"Sace hi saccaṁ bhaṇasi, ","html":"<p data-counter='61'><span class='verse-line'>{}</span>"},"ja422:11.2":{"pli":"hohi rāja yathā pure; ","html":"<span class='verse-line'>{}</span>"},"ja422:11.3":{"pli":"Musā ce bhāsase rāja, ","html":"<span class='verse-line'>{}</span>"},"ja422:11.4":{"pli":"bhiyyo pavisa cetiya. ","html":"<span class='verse-line'>{}</span></p>"},"ja422:12.1":{"pli":"Puttā tassa na bhavanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja422:12.2":{"pli":"pakkamanti disodisaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja422:12.3":{"pli":"Yo jānaṁ pucchito pañhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja422:12.4":{"pli":"aññathā naṁ viyākare. ","html":"<span class='verse-line'>{}</span></p>"},"ja422:13.1":{"pli":"Sace hi saccaṁ bhaṇasi, ","html":"<p data-counter='71'><span class='verse-line'>{}</span>"},"ja422:13.2":{"pli":"hohi rāja yathā pure; ","html":"<span class='verse-line'>{}</span>"},"ja422:13.3":{"pli":"Musā ce bhāsase rāja, ","html":"<span class='verse-line'>{}</span>"},"ja422:13.4":{"pli":"bhiyyo pavisa cetiya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja422:14.1":{"pli":"“Sa rājā isinā satto, ","html":"<p><span class='verse-line'>{}</span>"},"ja422:14.2":{"pli":"antalikkhacaro pure; ","html":"<span class='verse-line'>{}</span>"},"ja422:14.3":{"pli":"Pāvekkhi pathaviṁ cecco, ","html":"<span class='verse-line'>{}</span>"},"ja422:14.4":{"pli":"hīnatto patva pariyāyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja422:15.1":{"pli":"Tasmā hi chandāgamanaṁ, ","html":"<p data-counter='81'><span class='verse-line'>{}</span>"},"ja422:15.2":{"pli":"Nappasaṁsanti paṇḍitā; ","html":"<span class='verse-line'>{}</span>"},"ja422:15.3":{"pli":"Aduṭṭhacitto bhāseyya, ","html":"<span class='verse-line'>{}</span>"},"ja422:15.4":{"pli":"Giraṁ saccūpasaṁhitanti”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja422:16.1":{"pli":"Cetiyajātakaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja423":{"ja423:0.1":{"pli":"Jātaka ","html":"<article id='ja423'><header><ul><li class='division'>{}</li>"},"ja423:0.2":{"pli":"Aṭṭhakanipāta ","html":"<li>{}</li>"},"ja423:0.3":{"pli":"Kaccānivagga ","html":"<li>{}</li></ul>"},"ja423:0.4":{"pli":"7. Indriyajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja423:1.1":{"pli":"“Yo indriyānaṁ kāmena, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja423:1.2":{"pli":"vasaṁ nārada gacchati; ","html":"<span class='verse-line'>{}</span>"},"ja423:1.3":{"pli":"So pariccajjubho loke, ","html":"<span class='verse-line'>{}</span>"},"ja423:1.4":{"pli":"jīvantova visussati. ","html":"<span class='verse-line'>{}</span></p>"},"ja423:2.1":{"pli":"Sukhassānantaraṁ dukkhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja423:2.2":{"pli":"dukkhassānantaraṁ sukhaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja423:2.3":{"pli":"Sosi patto sukhā dukkhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja423:2.4":{"pli":"pāṭikaṅkha varaṁ sukhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja423:3.1":{"pli":"Kicchakāle kicchasaho, ","html":"<p><span class='verse-line'>{}</span>"},"ja423:3.2":{"pli":"yo kicchaṁ nātivattati; ","html":"<span class='verse-line'>{}</span>"},"ja423:3.3":{"pli":"Sa kicchantaṁ sukhaṁ dhīro, ","html":"<span class='verse-line'>{}</span>"},"ja423:3.4":{"pli":"yogaṁ samadhigacchati. ","html":"<span class='verse-line'>{}</span></p>"},"ja423:4.1":{"pli":"Na heva kāmāna kāmā, ","html":"<p><span class='verse-line'>{}</span>"},"ja423:4.2":{"pli":"nānatthā nātthakāraṇā; ","html":"<span class='verse-line'>{}</span>"},"ja423:4.3":{"pli":"Na katañca niraṅkatvā, ","html":"<span class='verse-line'>{}</span>"},"ja423:4.4":{"pli":"dhammā cavitumarahasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja423:5.1":{"pli":"“Dakkhaṁ gahapatī sādhu, ","html":"<p><span class='verse-line'>{}</span>"},"ja423:5.2":{"pli":"saṁvibhajjañca bhojanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja423:5.3":{"pli":"Ahāso atthalābhesu, ","html":"<span class='verse-line'>{}</span>"},"ja423:5.4":{"pli":"atthabyāpatti abyatho”. ","html":"<span class='verse-line'>{}</span></p>"},"ja423:6.1":{"pli":"“Ettāvatetaṁ paṇḍiccaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja423:6.2":{"pli":"api so devilo bravi; ","html":"<span class='verse-line'>{}</span>"},"ja423:6.3":{"pli":"Na yito kiñci pāpiyo, ","html":"<span class='verse-line'>{}</span>"},"ja423:6.4":{"pli":"yo indriyānaṁ vasaṁ vaje”. ","html":"<span class='verse-line'>{}</span></p>"},"ja423:7.1":{"pli":"“Amittānaṁva hatthatthaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja423:7.2":{"pli":"sivi pappoti māmiva; ","html":"<span class='verse-line'>{}</span>"},"ja423:7.3":{"pli":"Kammaṁ vijjañca dakkheyyaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja423:7.4":{"pli":"vivāhaṁ sīlamaddavaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja423:7.5":{"pli":"Ete ca yase hāpetvā, ","html":"<span class='verse-line'>{}</span>"},"ja423:7.6":{"pli":"nibbatto sehi kammehi. ","html":"<span class='verse-line'>{}</span></p>"},"ja423:8.1":{"pli":"Sohaṁ sahassajīnova, ","html":"<p><span class='verse-line'>{}</span>"},"ja423:8.2":{"pli":"abandhu aparāyaṇo; ","html":"<span class='verse-line'>{}</span>"},"ja423:8.3":{"pli":"Ariyadhammā apakkanto, ","html":"<span class='verse-line'>{}</span>"},"ja423:8.4":{"pli":"yathā peto tathevahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja423:9.1":{"pli":"Sukhakāme dukkhāpetvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja423:9.2":{"pli":"āpannosmi padaṁ imaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja423:9.3":{"pli":"So sukhaṁ nādhigacchāmi, ","html":"<span class='verse-line'>{}</span>"},"ja423:9.4":{"pli":"ṭhito bhāṇumatāmivā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja423:10.1":{"pli":"Indriyajātakaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja424":{"ja424:0.1":{"pli":"Jātaka ","html":"<article id='ja424'><header><ul><li class='division'>{}</li>"},"ja424:0.2":{"pli":"Aṭṭhakanipāta ","html":"<li>{}</li>"},"ja424:0.3":{"pli":"Kaccānivagga ","html":"<li>{}</li></ul>"},"ja424:0.4":{"pli":"8. Ādittajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja424:1.1":{"pli":"“Ādittasmiṁ agārasmiṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja424:1.2":{"pli":"yaṁ nīharati bhājanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja424:1.3":{"pli":"Taṁ tassa hoti atthāya, ","html":"<span class='verse-line'>{}</span>"},"ja424:1.4":{"pli":"no ca yaṁ tattha ḍayhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja424:2.1":{"pli":"Evamādīpito loko, ","html":"<p><span class='verse-line'>{}</span>"},"ja424:2.2":{"pli":"jarāya maraṇena ca; ","html":"<span class='verse-line'>{}</span>"},"ja424:2.3":{"pli":"Nīharetheva dānena, ","html":"<span class='verse-line'>{}</span>"},"ja424:2.4":{"pli":"dinnaṁ hoti sunīhataṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja424:3.1":{"pli":"“Yo dhammaladdhassa dadāti dānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja424:3.2":{"pli":"Uṭṭhānaviriyādhigatassa jantu; ","html":"<span class='verse-line'>{}</span>"},"ja424:3.3":{"pli":"Atikkamma so vetaraṇiṁ yamassa, ","html":"<span class='verse-line'>{}</span>"},"ja424:3.4":{"pli":"Dibbāni ṭhānāni upeti macco. ","html":"<span class='verse-line'>{}</span></p>"},"ja424:4.1":{"pli":"Dānañca yuddhañca samānamāhu, ","html":"<p><span class='verse-line'>{}</span>"},"ja424:4.2":{"pli":"Appāpi santā bahuke jinanti; ","html":"<span class='verse-line'>{}</span>"},"ja424:4.3":{"pli":"Appampi ce saddahāno dadāti, ","html":"<span class='verse-line'>{}</span>"},"ja424:4.4":{"pli":"Teneva so hoti sukhī parattha. ","html":"<span class='verse-line'>{}</span></p>"},"ja424:5.1":{"pli":"Viceyya dānaṁ sugatappasatthaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja424:5.2":{"pli":"Ye dakkhiṇeyyā idha jīvaloke; ","html":"<span class='verse-line'>{}</span>"},"ja424:5.3":{"pli":"Etesu dinnāni mahapphalāni, ","html":"<span class='verse-line'>{}</span>"},"ja424:5.4":{"pli":"Bījāni vuttāni yathā sukhette. ","html":"<span class='verse-line'>{}</span></p>"},"ja424:6.1":{"pli":"Yo pāṇabhūtāni aheṭhayaṁ caraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja424:6.2":{"pli":"Parūpavādā na karoti pāpaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja424:6.3":{"pli":"Bhīruṁ pasaṁsanti na tattha sūraṁ, ","html":"<span class='verse-line'>{}</span>"},"ja424:6.4":{"pli":"Bhayā hi santo na karonti pāpaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja424:7.1":{"pli":"Hīnena brahmacariyena, ","html":"<p><span class='verse-line'>{}</span>"},"ja424:7.2":{"pli":"khattiye upapajjati; ","html":"<span class='verse-line'>{}</span>"},"ja424:7.3":{"pli":"Majjhimena ca devattaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja424:7.4":{"pli":"uttamena visujjhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja424:8.1":{"pli":"Addhā hi dānaṁ bahudhā pasatthaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja424:8.2":{"pli":"Dānā ca kho dhammapadaṁva seyyo; ","html":"<span class='verse-line'>{}</span>"},"ja424:8.3":{"pli":"Pubbeva hi pubbatareva santo, ","html":"<span class='verse-line'>{}</span>"},"ja424:8.4":{"pli":"Nibbānamevajjhagamuṁ sapaññā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja424:9.1":{"pli":"Ādittajātakaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja425":{"ja425:0.1":{"pli":"Jātaka ","html":"<article id='ja425'><header><ul><li class='division'>{}</li>"},"ja425:0.2":{"pli":"Aṭṭhakanipāta ","html":"<li>{}</li>"},"ja425:0.3":{"pli":"Kaccānivagga ","html":"<li>{}</li></ul>"},"ja425:0.4":{"pli":"9. Aṭṭhānajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja425:1.1":{"pli":"“Gaṅgā kumudinī santā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja425:1.2":{"pli":"saṅkhavaṇṇā ca kokilā; ","html":"<span class='verse-line'>{}</span>"},"ja425:1.3":{"pli":"Jambu tālaphalaṁ dajjā, ","html":"<span class='verse-line'>{}</span>"},"ja425:1.4":{"pli":"atha nūna tadā siyā. ","html":"<span class='verse-line'>{}</span></p>"},"ja425:2.1":{"pli":"Yadā kacchapalomānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja425:2.2":{"pli":"pāvāro tividho siyā; ","html":"<span class='verse-line'>{}</span>"},"ja425:2.3":{"pli":"Hemantikaṁ pāvuraṇaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja425:2.4":{"pli":"atha nūna tadā siyā. ","html":"<span class='verse-line'>{}</span></p>"},"ja425:3.1":{"pli":"Yadā makasapādānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja425:3.2":{"pli":"aṭṭālo sukato siyā; ","html":"<span class='verse-line'>{}</span>"},"ja425:3.3":{"pli":"Daḷho ca avikampī ca, ","html":"<span class='verse-line'>{}</span>"},"ja425:3.4":{"pli":"atha nūna tadā siyā. ","html":"<span class='verse-line'>{}</span></p>"},"ja425:4.1":{"pli":"Yadā sasavisāṇānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja425:4.2":{"pli":"nisseṇī sukatā siyā; ","html":"<span class='verse-line'>{}</span>"},"ja425:4.3":{"pli":"Saggassārohaṇatthāya, ","html":"<span class='verse-line'>{}</span>"},"ja425:4.4":{"pli":"atha nūna tadā siyā. ","html":"<span class='verse-line'>{}</span></p>"},"ja425:5.1":{"pli":"Yadā nisseṇimāruyha, ","html":"<p><span class='verse-line'>{}</span>"},"ja425:5.2":{"pli":"candaṁ khādeyyu mūsikā; ","html":"<span class='verse-line'>{}</span>"},"ja425:5.3":{"pli":"Rāhuñca paripāteyyuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja425:5.4":{"pli":"atha nūna tadā siyā. ","html":"<span class='verse-line'>{}</span></p>"},"ja425:6.1":{"pli":"Yadā surāghaṭaṁ pitvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja425:6.2":{"pli":"makkhikā gaṇacāriṇī; ","html":"<span class='verse-line'>{}</span>"},"ja425:6.3":{"pli":"Aṅgāre vāsaṁ kappeyyuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja425:6.4":{"pli":"atha nūna tadā siyā. ","html":"<span class='verse-line'>{}</span></p>"},"ja425:7.1":{"pli":"Yadā bimboṭṭhasampanno, ","html":"<p><span class='verse-line'>{}</span>"},"ja425:7.2":{"pli":"gadrabho sumukho siyā; ","html":"<span class='verse-line'>{}</span>"},"ja425:7.3":{"pli":"Kusalo naccagītassa, ","html":"<span class='verse-line'>{}</span>"},"ja425:7.4":{"pli":"atha nūna tadā siyā. ","html":"<span class='verse-line'>{}</span></p>"},"ja425:8.1":{"pli":"Yadā kākā ulūkā ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja425:8.2":{"pli":"mantayeyyuṁ rahogatā; ","html":"<span class='verse-line'>{}</span>"},"ja425:8.3":{"pli":"Aññamaññaṁ pihayeyyuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja425:8.4":{"pli":"atha nūna tadā siyā. ","html":"<span class='verse-line'>{}</span></p>"},"ja425:9.1":{"pli":"Yadā muḷāla pattānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja425:9.2":{"pli":"chattaṁ thirataraṁ siyā; ","html":"<span class='verse-line'>{}</span>"},"ja425:9.3":{"pli":"Vassassa paṭighātāya, ","html":"<span class='verse-line'>{}</span>"},"ja425:9.4":{"pli":"atha nūna tadā siyā. ","html":"<span class='verse-line'>{}</span></p>"},"ja425:10.1":{"pli":"Yadā kulako sakuṇo, ","html":"<p><span class='verse-line'>{}</span>"},"ja425:10.2":{"pli":"pabbataṁ gandhamādanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja425:10.3":{"pli":"Tuṇḍenādāya gaccheyya, ","html":"<span class='verse-line'>{}</span>"},"ja425:10.4":{"pli":"atha nūna tadā siyā. ","html":"<span class='verse-line'>{}</span></p>"},"ja425:11.1":{"pli":"Yadā sāmuddikaṁ nāvaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja425:11.2":{"pli":"sayantaṁ savaṭākaraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja425:11.3":{"pli":"Ceṭo ādāya gaccheyya, ","html":"<span class='verse-line'>{}</span>"},"ja425:11.4":{"pli":"atha nūna tadā siyā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja425:12.1":{"pli":"Aṭṭhānajātakaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja426":{"ja426:0.1":{"pli":"Jātaka ","html":"<article id='ja426'><header><ul><li class='division'>{}</li>"},"ja426:0.2":{"pli":"Aṭṭhakanipāta ","html":"<li>{}</li>"},"ja426:0.3":{"pli":"Kaccānivagga ","html":"<li>{}</li></ul>"},"ja426:0.4":{"pli":"10. Dīpijātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja426:1.1":{"pli":"“Khamanīyaṁ yāpanīyaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja426:1.2":{"pli":"kacci mātula te sukhaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja426:1.3":{"pli":"Sukhaṁ te ammā avaca, ","html":"<span class='verse-line'>{}</span>"},"ja426:1.4":{"pli":"sukhakāmāva te mayaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja426:2.1":{"pli":"“Naṅguṭṭhaṁ me avakkamma, ","html":"<p><span class='verse-line'>{}</span>"},"ja426:2.2":{"pli":"Heṭhayitvāna eḷike; ","html":"<span class='verse-line'>{}</span>"},"ja426:2.3":{"pli":"Sājja mātulavādena, ","html":"<span class='verse-line'>{}</span>"},"ja426:2.4":{"pli":"Muñcitabbā nu maññasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja426:3.1":{"pli":"“Puratthāmukho nisinnosi, ","html":"<p><span class='verse-line'>{}</span>"},"ja426:3.2":{"pli":"Ahaṁ te mukhamāgatā; ","html":"<span class='verse-line'>{}</span>"},"ja426:3.3":{"pli":"Pacchato tuyhaṁ naṅguṭṭhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja426:3.4":{"pli":"Kathaṁ khvāhaṁ avakkamiṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja426:4.1":{"pli":"“Yāvatā caturo dīpā, ","html":"<p><span class='verse-line'>{}</span>"},"ja426:4.2":{"pli":"sasamuddā sapabbatā; ","html":"<span class='verse-line'>{}</span>"},"ja426:4.3":{"pli":"Tāvatā mayhaṁ naṅguṭṭhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja426:4.4":{"pli":"kathaṁ kho tvaṁ vivajjayi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja426:5.1":{"pli":"“Pubbeva metamakkhiṁsu, ","html":"<p><span class='verse-line'>{}</span>"},"ja426:5.2":{"pli":"mātā pitā ca bhātaro; ","html":"<span class='verse-line'>{}</span>"},"ja426:5.3":{"pli":"Dīghaṁ duṭṭhassa naṅguṭṭhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja426:5.4":{"pli":"sāmhi vehāyasāgatā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja426:6.1":{"pli":"“Tañca disvāna āyantiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja426:6.2":{"pli":"antalikkhasmi eḷike; ","html":"<span class='verse-line'>{}</span>"},"ja426:6.3":{"pli":"Migasaṅgho palāyittha, ","html":"<span class='verse-line'>{}</span>"},"ja426:6.4":{"pli":"bhakkho me nāsito tayā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja426:7.1":{"pli":"“Iccevaṁ vilapantiyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja426:7.2":{"pli":"eḷakiyā ruhagghaso; ","html":"<span class='verse-line'>{}</span>"},"ja426:7.3":{"pli":"Galakaṁ anvāvamaddi, ","html":"<span class='verse-line'>{}</span>"},"ja426:7.4":{"pli":"natthi duṭṭhe subhāsitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja426:8.1":{"pli":"Neva duṭṭhe nayo atthi, ","html":"<p><span class='verse-line'>{}</span>"},"ja426:8.2":{"pli":"Na dhammo na subhāsitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja426:8.3":{"pli":"Nikkamaṁ duṭṭhe yuñjetha, ","html":"<span class='verse-line'>{}</span>"},"ja426:8.4":{"pli":"So ca sabbhiṁ na rañjatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja426:9.1":{"pli":"Dīpijātakaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja426:10.1":{"pli":"Aṭṭhakanipātaṁ niṭṭhitaṁ. ","html":"<p class='endsection'>{}</p>"},"ja426:11.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja426:12.1":{"pli":"Parisuddhā manāvilā vatthadharā, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja426:12.2":{"pli":"Bakarājassa kāyuraṁ daṇḍavaro; ","html":"<span class='verse-line'>{}</span>"},"ja426:12.3":{"pli":"Atha aṅgāra cetiya devilinā, ","html":"<span class='verse-line'>{}</span>"},"ja426:12.4":{"pli":"Atha āditta gaṅgā daseḷakināti. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"ja427":{"ja427:0.1":{"pli":"Jātaka ","html":"<article id='ja427'><header><ul><li class='division'>{}</li>"},"ja427:0.2":{"pli":"Navakanipāta ","html":"<li>{}</li>"},"ja427:0.3":{"pli":"Gijjhavagga ","html":"<li>{}</li></ul>"},"ja427:0.4":{"pli":"1. Gijjhajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja427:1.1":{"pli":"“Parisaṅkupatho nāma, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja427:1.2":{"pli":"gijjhapantho sanantano; ","html":"<span class='verse-line'>{}</span>"},"ja427:1.3":{"pli":"Tatrāsi mātāpitaro, ","html":"<span class='verse-line'>{}</span>"},"ja427:1.4":{"pli":"gijjho posesi jiṇṇake; ","html":"<span class='verse-line'>{}</span>"},"ja427:1.5":{"pli":"Tesaṁ ajagaramedaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja427:1.6":{"pli":"accahāsi bahuttaso. ","html":"<span class='verse-line'>{}</span></p>"},"ja427:2.1":{"pli":"Pitā ca puttaṁ avaca, ","html":"<p><span class='verse-line'>{}</span>"},"ja427:2.2":{"pli":"Jānaṁ uccaṁ papātinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja427:2.3":{"pli":"Supattaṁ thāmasampannaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja427:2.4":{"pli":"Tejassiṁ dūragāminaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja427:3.1":{"pli":"Pariplavantaṁ pathaviṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja427:3.2":{"pli":"yadā tāta vijānahi; ","html":"<span class='verse-line'>{}</span>"},"ja427:3.3":{"pli":"Sāgarena parikkhittaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja427:3.4":{"pli":"cakkaṁva parimaṇḍalaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja427:3.5":{"pli":"Tato tāta nivattassu, ","html":"<span class='verse-line'>{}</span>"},"ja427:3.6":{"pli":"māssu etto paraṁ gami. ","html":"<span class='verse-line'>{}</span></p>"},"ja427:4.1":{"pli":"Udapattosi vegena, ","html":"<p><span class='verse-line'>{}</span>"},"ja427:4.2":{"pli":"balī pakkhī dijuttamo; ","html":"<span class='verse-line'>{}</span>"},"ja427:4.3":{"pli":"Olokayanto vakkaṅgo, ","html":"<span class='verse-line'>{}</span>"},"ja427:4.4":{"pli":"pabbatāni vanāni ca. ","html":"<span class='verse-line'>{}</span></p>"},"ja427:5.1":{"pli":"Addassa pathaviṁ gijjho, ","html":"<p><span class='verse-line'>{}</span>"},"ja427:5.2":{"pli":"yathāsāsi pitussutaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja427:5.3":{"pli":"Sāgarena parikkhittaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja427:5.4":{"pli":"cakkaṁva parimaṇḍalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja427:6.1":{"pli":"Tañca so samatikkamma, ","html":"<p><span class='verse-line'>{}</span>"},"ja427:6.2":{"pli":"paramevaccavattatha; ","html":"<span class='verse-line'>{}</span>"},"ja427:6.3":{"pli":"Tañca vātasikhā tikkhā, ","html":"<span class='verse-line'>{}</span>"},"ja427:6.4":{"pli":"accahāsi baliṁ dijaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja427:7.1":{"pli":"Nāsakkhātigato poso, ","html":"<p><span class='verse-line'>{}</span>"},"ja427:7.2":{"pli":"punadeva nivattituṁ; ","html":"<span class='verse-line'>{}</span>"},"ja427:7.3":{"pli":"Dijo byasanamāpādi, ","html":"<span class='verse-line'>{}</span>"},"ja427:7.4":{"pli":"verambhānaṁ vasaṁ gato. ","html":"<span class='verse-line'>{}</span></p>"},"ja427:8.1":{"pli":"Tassa puttā ca dārā ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja427:8.2":{"pli":"ye caññe anujīvino; ","html":"<span class='verse-line'>{}</span>"},"ja427:8.3":{"pli":"Sabbe byasanamāpāduṁ, ","html":"<span class='verse-line'>{}</span>"},"ja427:8.4":{"pli":"anovādakare dije. ","html":"<span class='verse-line'>{}</span></p>"},"ja427:9.1":{"pli":"Evampi idha vuḍḍhānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja427:9.2":{"pli":"yo vākyaṁ nāvabujjhati; ","html":"<span class='verse-line'>{}</span>"},"ja427:9.3":{"pli":"Atisīmacaro ditto, ","html":"<span class='verse-line'>{}</span>"},"ja427:9.4":{"pli":"gijjhovātītasāsano; ","html":"<span class='verse-line'>{}</span>"},"ja427:9.5":{"pli":"Sa ve byasanaṁ pappoti, ","html":"<span class='verse-line'>{}</span>"},"ja427:9.6":{"pli":"akatvā vuḍḍhasāsanan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja427:10.1":{"pli":"Gijjhajātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}