ass='verse-line'>{}</span>"},"tha-ap5:12.4":{"pli":"disā dasa samantato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap5:13.1":{"pli":"Tesaṁ ujjotamānānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap5:13.2":{"pli":"obhāso vipulo ahu; ","html":"<span class='verse-line'>{}</span>"},"tha-ap5:13.3":{"pli":"Sabbe deve abhibhomi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap5:13.4":{"pli":"puññakammassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap5:14.1":{"pli":"Saṭṭhikappasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap5:14.2":{"pli":"ubbiddho nāma khattiyo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap5:14.3":{"pli":"Cāturanto vijitāvī, ","html":"<span class='verse-line'>{}</span>"},"tha-ap5:14.4":{"pli":"pathaviṁ āvasiṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap5:15.1":{"pli":"Tatheva bhaddake kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap5:15.2":{"pli":"tiṁsakkhattuṁ ahosahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap5:15.3":{"pli":"Sakakammābhiraddhomhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap5:15.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap5:16.1":{"pli":"Sattaratanasampanno, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap5:16.2":{"pli":"catudīpamhi issaro; ","html":"<span class='verse-line'>{}</span>"},"tha-ap5:16.3":{"pli":"Tatthāpi bhavanaṁ mayhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap5:16.4":{"pli":"indalaṭṭhīva uggataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap5:17.1":{"pli":"Āyāmato catubbīsaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap5:17.2":{"pli":"vitthārena ca dvādasa; ","html":"<span class='verse-line'>{}</span>"},"tha-ap5:17.3":{"pli":"Rammaṇaṁ nāma nagaraṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap5:17.4":{"pli":"daḷhapākāratoraṇaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap5:18.1":{"pli":"Āyāmato pañcasataṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap5:18.2":{"pli":"vitthārena tadaḍḍhakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap5:18.3":{"pli":"Ākiṇṇaṁ janakāyehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap5:18.4":{"pli":"tidasānaṁ puraṁ viya. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap5:19.1":{"pli":"Yathā sūcighare sūcī, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap5:19.2":{"pli":"pakkhittā paṇṇavīsati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap5:19.3":{"pli":"Aññamaññaṁ paghaṭṭenti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap5:19.4":{"pli":"ākiṇṇaṁ hoti laṅkataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap5:20.1":{"pli":"Evampi nagaraṁ mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap5:20.2":{"pli":"hatthissarathasaṅkulaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap5:20.3":{"pli":"Manussehi sadākiṇṇaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap5:20.4":{"pli":"rammaṇaṁ nagaruttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap5:21.1":{"pli":"Tattha bhutvā pivitvā ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap5:21.2":{"pli":"puna devattanaṁ gato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap5:21.3":{"pli":"Bhave pacchimake mayhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap5:21.4":{"pli":"ahosi kulasampadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap5:22.1":{"pli":"Brāhmaññakulasambhūto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap5:22.2":{"pli":"mahāratanasañcayo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap5:22.3":{"pli":"Asītikoṭiyo hitvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap5:22.4":{"pli":"hiraññassāpi pabbajiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap5:23.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap5:23.2":{"pli":"vimokkhāpi ca aṭṭhime; ","html":"<span class='verse-line'>{}</span>"},"tha-ap5:23.3":{"pli":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap5:23.4":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap5:24.1":{"pli":"Itthaṁ sudaṁ āyasmā mahākassapo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap5:25.1":{"pli":"Mahākassapattherassāpadānaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap50":{"tha-ap50:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap50'><header><ul><li class='division'>{}</li>"},"tha-ap50:0.2":{"pli":"Upālivagga ","html":"<li>{}</li></ul>"},"tha-ap50:0.3":{"pli":"8 Caṅkamanadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap50:1.1":{"pli":"“Atthadassissa munino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap50:1.2":{"pli":"lokajeṭṭhassa tādino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap50:1.3":{"pli":"Iṭṭhakāhi cinitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap50:1.4":{"pli":"caṅkamaṁ kārayiṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap50:2.1":{"pli":"Uccato pañcaratanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap50:2.2":{"pli":"caṅkamaṁ sādhumāpitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap50:2.3":{"pli":"Āyāmato hatthasataṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap50:2.4":{"pli":"bhāvanīyyaṁ manoramaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap50:3.1":{"pli":"Paṭiggahesi bhagavā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap50:3.2":{"pli":"atthadassī naruttamo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap50:3.3":{"pli":"Hatthena pulinaṁ gayha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap50:3.4":{"pli":"imā gāthā abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap50:4.1":{"pli":"‘Iminā pulinadānena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap50:4.2":{"pli":"caṅkamaṁ sukatena ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap50:4.3":{"pli":"Sattaratanasampannaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap50:4.4":{"pli":"pulinaṁ anubhossati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap50:5.1":{"pli":"Tīṇi kappāni devesu, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap50:5.2":{"pli":"devarajjaṁ karissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap50:5.3":{"pli":"Anubhossati sampattiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap50:5.4":{"pli":"accharāhi purakkhato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap50:6.1":{"pli":"Manussalokamāgantvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap50:6.2":{"pli":"rājā raṭṭhe bhavissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap50:6.3":{"pli":"Tikkhattuṁ cakkavattī ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap50:6.4":{"pli":"mahiyā so bhavissati’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap50:7.1":{"pli":"Aṭṭhārase kappasate, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap50:7.2":{"pli":"yaṁ kammamakariṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap50:7.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap50:7.4":{"pli":"caṅkamassa idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap50:8.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap50:8.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap50:8.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap50:9.1":{"pli":"Itthaṁ sudaṁ āyasmā caṅkamanadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap50:10.1":{"pli":"Caṅkamanadāyakattherassāpadānaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}