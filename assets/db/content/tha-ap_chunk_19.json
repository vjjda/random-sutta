"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap312:5.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap312:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap312:5.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap312:6.1":{"pli":"Itthaṁ sudaṁ āyasmā pabbhāradāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap312:7.1":{"pli":"Pabbhāradāyakattherassāpadānaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap312:8.1":{"pli":"Padumakesaravaggo ekatiṁsatimo. ","html":"<p class='endsection'>{}</p>"},"tha-ap312:9.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"tha-ap312:10.1":{"pli":"Kesaraṁ gandhamannañca, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"tha-ap312:10.2":{"pli":"dhammasaññī phalena ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap312:10.3":{"pli":"Pasādārāmadāyī ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap312:10.4":{"pli":"lepako buddhasaññako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap312:10.5":{"pli":"Pabbhārado ca gāthāyo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap312:10.6":{"pli":"ekapaññāsa kittitā. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"tha-ap313":{"tha-ap313:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap313'><header><ul><li class='division'>{}</li>"},"tha-ap313:0.2":{"pli":"Ārakkhadāyakavagga ","html":"<li>{}</li></ul>"},"tha-ap313:0.3":{"pli":"Ārakkhadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap313:1.1":{"pli":"“Dhammadassissa munino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap313:1.2":{"pli":"vati kārāpitā mayā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap313:1.3":{"pli":"Ārakkho ca mayā dinno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap313:1.4":{"pli":"dvipadindassa tādino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap313:2.1":{"pli":"Aṭṭhārase kappasate, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap313:2.2":{"pli":"yaṁ kammamakariṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap313:2.3":{"pli":"Tena kammavisesena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap313:2.4":{"pli":"patto me āsavakkhayo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap313:3.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap313:3.2":{"pli":"vimokkhāpi ca aṭṭhime; ","html":"<span class='verse-line'>{}</span>"},"tha-ap313:3.3":{"pli":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap313:3.4":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap313:4.1":{"pli":"Itthaṁ sudaṁ āyasmā ārakkhadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap313:5.1":{"pli":"Ārakkhadāyakattherassāpadānaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap314":{"tha-ap314:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap314'><header><ul><li class='division'>{}</li>"},"tha-ap314:0.2":{"pli":"Ārakkhadāyakavagga ","html":"<li>{}</li></ul>"},"tha-ap314:0.3":{"pli":"Bhojanadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap314:1.1":{"pli":"“Sujāto sālalaṭṭhīva, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap314:1.2":{"pli":"sobhañjanamivuggato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap314:1.3":{"pli":"Indalaṭṭhirivākāse, ","html":"<span class='verse-line'>{}</span>"},"tha-ap314:1.4":{"pli":"virocati sadā jino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap314:2.1":{"pli":"Tassa devātidevassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap314:2.2":{"pli":"vessabhussa mahesino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap314:2.3"