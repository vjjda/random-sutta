8.1":{"pli":"Itthaṁ sudaṁ āyasmā ārāmadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap309:9.1":{"pli":"Ārāmadāyakattherassāpadānaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap31":{"tha-ap31:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap31'><header><ul><li class='division'>{}</li>"},"tha-ap31:0.2":{"pli":"Subhūtivagga ","html":"<li>{}</li></ul>"},"tha-ap31:0.3":{"pli":"Ekañjalikattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap31:1.1":{"pli":"“Suvaṇṇavaṇṇaṁ sambuddhaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap31:1.2":{"pli":"Gacchantaṁ antarāpaṇe; ","html":"<span class='verse-line'>{}</span>"},"tha-ap31:1.3":{"pli":"Vipassiṁ satthavāhaggaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap31:1.4":{"pli":"Naravaraṁ vināyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap31:2.1":{"pli":"Adantadamanaṁ tādiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap31:2.2":{"pli":"mahāvādiṁ mahāmatiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap31:2.3":{"pli":"Disvā pasanno sumano, ","html":"<span class='verse-line'>{}</span>"},"tha-ap31:2.4":{"pli":"ekañjalimakāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap31:3.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap31:3.2":{"pli":"yamañjaliṁ kariṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap31:3.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap31:3.4":{"pli":"añjalissa idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap31:4.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap31:4.2":{"pli":"vimokkhāpi ca aṭṭhime; ","html":"<span class='verse-line'>{}</span>"},"tha-ap31:4.3":{"pli":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap31:4.4":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap31:5.1":{"pli":"Itthaṁ sudaṁ āyasmā ekañjaliko thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap31:6.1":{"pli":"Ekañjalikattherassāpadānaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap310":{"tha-ap310:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap310'><header><ul><li class='division'>{}</li>"},"tha-ap310:0.2":{"pli":"Padumakesaravagga ","html":"<li>{}</li></ul>"},"tha-ap310:0.3":{"pli":"Anulepadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap310:1.1":{"pli":"“Atthadassissa munino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap310:1.2":{"pli":"addasaṁ sāvakaṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap310:1.3":{"pli":"Navakammaṁ karontassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap310:1.4":{"pli":"sīmāya upagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap310:2.1":{"pli":"Niṭṭhite navakamme ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap310:2.2":{"pli":"anulepamadāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap310:2.3":{"pli":"Pasannacitto sumano, ","html":"<span class='verse-line'>{}</span>"},"tha-ap310:2.4":{"pli":"puññakkhette anuttare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap310:3.1":{"pli":"Aṭṭhārase kappasate, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap310:3.2":{"pli":"yaṁ kammamakariṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap310:3.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap310:3.4":{"pli":"anulepassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap310:4.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap310:4.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap310:4.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></bl