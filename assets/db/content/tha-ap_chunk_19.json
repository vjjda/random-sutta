hidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap305:4.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap305:4.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap305:5.1":{"pli":"Itthaṁ sudaṁ āyasmā paramannadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap305:6.1":{"pli":"Paramannadāyakattherassāpadānaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap306":{"tha-ap306:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap306'><header><ul><li class='division'>{}</li>"},"tha-ap306:0.2":{"pli":"Padumakesaravagga ","html":"<li>{}</li></ul>"},"tha-ap306:0.3":{"pli":"Dhammasaññakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap306:1.1":{"pli":"“Vipassino bhagavato, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap306:1.2":{"pli":"Mahābodhimaho ahu; ","html":"<span class='verse-line'>{}</span>"},"tha-ap306:1.3":{"pli":"Rukkhaṭṭhasseva sambuddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap306:1.4":{"pli":"Lokajeṭṭho narāsabho. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap306:2.1":{"pli":"Bhagavā tamhi samaye, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap306:2.2":{"pli":"bhikkhusaṅghapurakkhato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap306:2.3":{"pli":"Catusaccaṁ pakāseti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap306:2.4":{"pli":"vācāsabhimudīrayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap306:3.1":{"pli":"Saṅkhittena ca desento, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap306:3.2":{"pli":"vitthārena ca desayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap306:3.3":{"pli":"Vivaṭṭacchado sambuddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap306:3.4":{"pli":"nibbāpesi mahājanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap306:4.1":{"pli":"Tassāhaṁ dhammaṁ sutvā