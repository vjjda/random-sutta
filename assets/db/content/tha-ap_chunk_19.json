ss='verse-line'>{}</span>"},"tha-ap307:1.2":{"pli":"ahosi assamo tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap307:1.3":{"pli":"Tamahaṁ assamaṁ gacchiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap307:1.4":{"pli":"phalahattho apekkhavā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap307:2.1":{"pli":"Vipassiṁ tattha addakkhiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap307:2.2":{"pli":"pītaraṁsiṁva bhāṇumaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap307:2.3":{"pli":"Yaṁ me atthi phalaṁ sabbaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap307:2.4":{"pli":"adāsiṁ satthuno ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap307:3.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap307:3.2":{"pli":"yaṁ phalaṁ adadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap307:3.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap307:3.4":{"pli":"phaladānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap307:4.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap307:4.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap307:4.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap307:5.1":{"pli":"Itthaṁ sudaṁ āyasmā phaladāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap307:6.1":{"pli":"Phaladāyakattherassāpadānaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap308":{"tha-ap308:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap308'><header><ul><li class='division'>{}</li>"},"tha-ap308:0.2":{"pli":"Padumakesaravagga ","html":"<li>{}</li></ul>"},"tha-ap308:0.3":{"pli":"6 Sampasādakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap308:1.1":{"pli":"“‘Namo te buddha vīratthu, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap308:1.2":{"pli":"vippamuttosi sabbadhi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap308:1.3":{"pli":"Byasanamhi anuppatto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap308:1.4":{"pli":"tassa me saraṇaṁ bhava’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap308:2.1":{"pli":"Siddhattho tassa byākāsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap308:2.2":{"pli":"loke appaṭipuggalo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap308:2.3":{"pli":"‘Mahodadhisamo saṅgho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap308:2.4":{"pli":"appameyyo anuttaro. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap308:3.1":{"pli":"Tattha tvaṁ viraje khette, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap308:3.2":{"pli":"anantaphaladāyake; ","html":"<span class='verse-line'>{}</span>"},"tha-ap308:3.3":{"pli":"Saṅghe cittaṁ pasādetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap308:3.4":{"pli":"subījaṁ vāpa ropaya’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap308:4.1":{"pli":"Idaṁ vatvāna sabbaññū, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap308:4.2":{"pli":"lokajeṭṭho narāsabho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap308:4.3":{"pli":"Mameva anusāsitvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap308:4.4":{"pli":"vehāsaṁ nabhamuggami. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap308:5.1":{"pli":"Aciraṁ gatamattamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap308:5.2":{"pli":"sabbaññumhi narāsabhe; ","html":"<span class='verse-line'>{}</span>"},"tha-ap308:5.3":{"pli":"Maraṇaṁ samanuppatto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap308:5.4":{"pli":"tusitaṁ upapajjahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap308:6.1":{"pli":"Tadāhaṁ viraje khette, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap308:6.2":{"pli":"anantaphaladāyake; ","html":"<span class='verse-line'>{}</span>"},"tha-ap308:6.3":{"pli":"Saṅghe cittaṁ pasādetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap308:6.4":{"pli":"kappaṁ saggamhi modahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap308:7.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap308:7.2":{"pli":"pasādamalabhiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap308:7.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap308:7.4":{"pli":"pasādassa idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap308:8.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap308:8.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap308:8.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap308:9.1":{"pli":"Itthaṁ sudaṁ āyasmā sampasādako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap308:10.1":{"pli":"Sampasādakattherassāpadānaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap309":{"tha-ap309:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap309'><header><ul><li class='division'>{}</li>"},"tha-ap309:0.2":{"pli":"Padumakesaravagga ","html":"<li>{}</li></ul>"},"tha-ap309:0.3":{"pli":"Ārāmadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap309:1.1":{"pli":"“Siddhatthassa bhagavato, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap309:1.2":{"pli":"ārāmo ropito mayā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap309:1.3":{"pli":"Sandacchāyesu rukkhesu, ","html":"<span class='verse-line'>{}</span>"},"tha-ap309:1.4":{"pli":"upāsantesu pakkhisu. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap309:2.1":{"pli":"Addasaṁ virajaṁ buddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap309:2.2":{"pli":"āhutīnaṁ paṭiggahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap3