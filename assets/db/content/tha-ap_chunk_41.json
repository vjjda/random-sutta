class='verse-line'>{}</span>"},"tha-ap470:1.3":{"pli":"Pasannacitto sumano, ","html":"<span class='verse-line'>{}</span>"},"tha-ap470:1.4":{"pli":"pilakkhassa phalaṁ adā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap470:2.1":{"pli":"Aṭṭhārase kappasate, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap470:2.2":{"pli":"yaṁ phalaṁ adadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap470:2.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap470:2.4":{"pli":"phaladānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap470:3.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap470:3.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap470:3.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap470:4.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap470:4.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap470:4.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap470:5.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap470:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap470:5.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap470:6.1":{"pli":"Itthaṁ sudaṁ āyasmā pilakkhaphaladāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap470:7.1":{"pli":"Pilakkhaphaladāyakattherassāpadānaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap471":{"tha-ap471:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap471'><header><ul><li class='division'>{}</li>"},"tha-ap471:0.2":{"pli":"Sālakusumiyavagga ","html":"<li>{}</li></ul>"},"tha-ap471:0.3":{"pli":"9 Sayampaṭibhāniyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap471:1.1":{"pli":"“Kakudhaṁ vilasantaṁva, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap471:1.2":{"pli":"devadevaṁ narāsabhaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap471:1.3":{"pli":"Rathiyaṁ paṭipajjantaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap471:1.4":{"pli":"ko disvā na pasīdati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap471:2.1":{"pli":"Tamandhakāraṁ nāsetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap471:2.2":{"pli":"santāretvā bahuṁ janaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap471:2.3":{"pli":"Ñāṇālokena jotantaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap471:2.4":{"pli":"ko disvā na pasīdati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap471:3.1":{"pli":"Vasīsatasahassehi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap471:3.2":{"pli":"nīyantaṁ lokanāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap471:3.3":{"pli":"Uddharantaṁ bahū satte, ","html":"<span class='verse-line'>{}</span>"},"tha-ap471:3.4":{"pli":"ko disvā na pasīdati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap471:4.1":{"pli":"Āhanantaṁ dhammabheriṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap471:4.2":{"pli":"maddantaṁ titthiye gaṇe; ","html":"<span class='verse-line'>{}</span>"},"tha-ap471:4.3":{"pli":"Sīhanādaṁ vinadantaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap471:4.4":{"pli":"ko disvā na pasīdati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap471:5.1":{"pli":"Yāvatā brahmalokato, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap471:5.2":{"pli":"āgantvāna sabrahmakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap471:5.3":{"pli":"Pucchanti nipuṇe pañhe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap471:5.4":{"pli":"ko disvā na pasīdati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap471:6.1":{"pli":"Yassañjaliṁ karitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap471:6.2":{"pli":"āyācanti sadevakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap471:6.3":{"pli":"Tena puññaṁ anubhonti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap471:6.4":{"pli":"ko disvā na pasīdati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap471:7.1":{"pli":"Sabbe janā samāgantvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap471:7.2":{"pli":"sampavārenti cakkhumaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap471:7.3":{"pli":"Na vikampati ajjhiṭṭho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap471:7.4":{"pli":"ko disvā na pasīdati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap471:8.1":{"pli":"Nagaraṁ pavisato yassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap471:8.2":{"pli":"ravanti bheriyo bahū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap471:8.3":{"pli":"Vinadanti gajā mattā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap471:8.4":{"pli":"ko disvā na pasīdati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap471:9.1":{"pli":"Vīthiyā gacchato yassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap471:9.2":{"pli":"sabbābhā jotate sadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap471:9.3":{"pli":"Abbhunnatā samā honti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap471:9.4":{"pli":"ko disvā na pasīdati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap471:10.1":{"pli":"Byāharantassa buddhassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap471:10.2":{"pli":"cakkavāḷampi suyyati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap471:10.3":{"pli":"Sabbe satte viññāpeti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap471:10.4":{"pli":"ko disvā na pasīdati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap471:11.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap471:11.2":{"pli":"yaṁ buddhamabhikittayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap471:11.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap471:11.4":{"pli":"kittanāya idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap471:12.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap471:12.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap471:12.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap471:13.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap471:13.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap471:13.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap471:14.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap471:14.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap471:14.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap471:15.1":{"pli":"Itthaṁ sudaṁ āyasmā sayampaṭibhāniyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap471:16.1":{"pli":"Sayampaṭibhāniyattherassāpadānaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap472":{"tha-ap472:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap472'><header><ul><li class='division'>{}</li>"},"tha-ap472:0.2":{"pli":"Sālakusumiyavagga ","html":"<li>{}</li></ul>"},"tha-ap472:0.3":{"pli":"Nimittabyākaraṇiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap472:1.1":{"pli":"“Ajjhogāhetvā himavaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap472:1.2":{"pli":"mante vāce mahaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap472:1.3":{"pli":"Catupaññāsasahassāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap472:1.4":{"pli":"sissā mayhaṁ upaṭṭhahuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap472:2.1":{"pli":"Adhitā vedagū sabbe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap472:2.2":{"pli":"chaḷaṅge pāramiṁ gatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap472:2.3":{"pli":"Sakavijjāhupatthaddhā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap472:2.4":{"pli":"himavante vasanti te. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap472:3.1":{"pli":"Cavitvā tusitā kāyā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap472:3.2":{"pli":"devaputto mahāyaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap472:3.3":{"pli":"Uppajji mātukucchismiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap472:3.4":{"pli":"sampajāno patissato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap472:4.1":{"pli":"Sambuddhe upapajjante, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap472:4.2":{"pli":"dasasahassi kampatha; ","html":"<span class='verse-line'>{}</span>"},"tha-ap472:4.3":{"pli":"Andhā cakkhuṁ alabhiṁsu, ","html":"<span class='verse-line'>{}</span>"},"tha-ap472:4.4":{"pli":"uppajjantamhi nāyake. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap472:5.1":{"pli":"Sabbākāraṁ pakampittha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap472:5.2":{"pli":"kevalā vasudhā ayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap472:5.3":{"pli":"Nigghosasaddaṁ sutvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap472:5.4":{"pli":"ubbijjiṁsu mahājanā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap472:6.1":{"pli":"Sabbe janā samāgamma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap472:6.2":{"pli":"āgacchuṁ mama santikaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap472:6.3":{"pli":"‘Vasudhāyaṁ pakampittha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap472:6.4":{"pli":"kiṁ vipāko bhavissati’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap472:7.1":{"pli":"Avacāsiṁ tadā tesaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap472:7.2":{"pli":"‘mā bhetha natthi vo bhayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap472:7.3":{"pli":"Vissatthā hotha sabbepi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap472:7.4":{"pli":"uppādoyaṁ suvatthiko. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap472:8.1":{"pli":"Aṭṭhahetūhi samphussa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap472:8.2":{"pli":"vasudhāyaṁ pakampati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap472:8.3":{"pli":"Tathā nimittā dissanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap472:8.4":{"pli":"obhāso vipulo mahā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap472:9.1":{"pli":"Asaṁsayaṁ buddhaseṭṭho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap472:9.2":{"pli":"uppajjissati cakkhumā’; ","html":"<span class='verse-line'>{}</span>"},"tha-ap472:9.3":{"pli":"Saññāpetvāna janataṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap472:9.4":{"pli":"pañca sīle kathesahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap472:10.1":{"pli":"Sutvāna pañca sīlāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap472:10.2":{"pli":"buddhuppādañca dullabhaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap472:10.3":{"pli":"Ubbegajātā sumanā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap472:10.4":{"pli":"tuṭṭhahaṭṭhā ahaṁsu te. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap472:11.1":{"pli":"Dvenavute ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap472:11.2":{"pli":"yaṁ nimittaṁ viyākariṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap472:11.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap472:11.4":{"pli":"byākaraṇassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap472:12.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap472:12.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap472:12.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap472:13.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap472:13.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap472:13.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap472:14.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap472:14.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap472:14.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap472:15.1":{"pli":"Itthaṁ sudaṁ āyasmā nimittabyākaraṇiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap472:16.1":{"pli":"Nimittabyākaraṇiyattherassāpadānaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap472:17.1":{"pli":"Sālakusumiyavaggo sattacattālīsamo. ","html":"<p class='endsection'>{}</p>"},"tha-ap472:18.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"tha-ap472:19.1":{"pli":"Sālakusumiyo thero, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"tha-ap472:19.2":{"pli":"pūjā nibbāpakopi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap472:19.3":{"pli":"Setudo tālavaṇṭī ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap472:19.4":{"pli":"avaṭalabujappado. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap472:20.1":{"pli":"Pilakkhapaṭibhānī ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap472:20.2":{"pli":"veyyākaraṇiyo dijo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap472:20.3":{"pli":"Dvesattati ca gāthāyo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap472:20.4":{"pli":"gaṇitāyo vibhāvibhi. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}}}