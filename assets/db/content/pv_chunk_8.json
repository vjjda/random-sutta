{"pv50":{"pv50:0.1":{"pli":"Petavatthu ","html":"<article id='pv50'><header><ul><li class='division'>{}</li>"},"pv50:0.2":{"pli":"Mahāvagga ","html":"<li>{}</li></ul>"},"pv50:0.3":{"pli":"15. Seṭṭhiputtapetavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv50:1.1":{"pli":"“Saṭṭhivassasahassāni, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv50:1.2":{"pli":"paripuṇṇāni sabbaso; ","html":"<span class='verse-line'>{}</span>"},"pv50:1.3":{"pli":"Niraye paccamānānaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv50:1.4":{"pli":"kadā anto bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"pv50:2.1":{"pli":"Natthi anto kuto anto, ","html":"<p><span class='verse-line'>{}</span>"},"pv50:2.2":{"pli":"na anto paṭidissati; ","html":"<span class='verse-line'>{}</span>"},"pv50:2.3":{"pli":"Tathā hi pakataṁ pāpaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv50:2.4":{"pli":"tuyhaṁ mayhañca mārisā. ","html":"<span class='verse-line'>{}</span></p>"},"pv50:3.1":{"pli":"Dujjīvitamajīvamha, ","html":"<p><span class='verse-line'>{}</span>"},"pv50:3.2":{"pli":"ye sante na dadamhase; ","html":"<span class='verse-line'>{}</span>"},"pv50:3.3":{"pli":"Santesu deyyadhammesu, ","html":"<span class='verse-line'>{}</span>"},"pv50:3.4":{"pli":"dīpaṁ nākamha attano. ","html":"<span class='verse-line'>{}</span></p>"},"pv50:4.1":{"pli":"Sohaṁ nūna ito gantvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv50:4.2":{"pli":"yoniṁ laddhāna mānusiṁ; ","html":"<span class='verse-line'>{}</span>"},"pv50:4.3":{"pli":"Vadaññū sīlasampanno, ","html":"<span class='verse-line'>{}</span>"},"pv50:4.4":{"pli":"kāhāmi kusalaṁ bahun”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv50:5.1":{"pli":"Seṭṭhiputtapetavatthu pannarasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"pv51":{"pv51:0.1":{"pli":"Petavatthu ","html":"<article id='pv51'><header><ul><li class='division'>{}</li>"},"pv51:0.2":{"pli":"Mahāvagga ","html":"<li>{}</li></ul>"},"pv51:0.3":{"pli":"16. Saṭṭhikūṭapetavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv51:1.1":{"pli":"“Kiṁ nu ummattarūpova, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv51:1.2":{"pli":"Migo bhantova dhāvasi; ","html":"<span class='verse-line'>{}</span>"},"pv51:1.3":{"pli":"Nissaṁsayaṁ pāpakammanto, ","html":"<span class='verse-line'>{}</span>"},"pv51:1.4":{"pli":"Kiṁ nu saddāyase tuvan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv51:2.1":{"pli":"“Ahaṁ bhadante petomhi, ","html":"<p><span class='verse-line'>{}</span>"},"pv51:2.2":{"pli":"duggato yamalokiko; ","html":"<span class='verse-line'>{}</span>"},"pv51:2.3":{"pli":"Pāpakammaṁ karitvāna, ","html":"<span class='verse-line'>{}</span>"},"pv51:2.4":{"pli":"petalokaṁ ito gato. ","html":"<span class='verse-line'>{}</span></p>"},"pv51:3.1":{"pli":"Saṭṭhi kūṭasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"pv51:3.2":{"pli":"paripuṇṇāni sabbaso; ","html":"<span class='verse-line'>{}</span>"},"pv51:3.3":{"pli":"Sīse mayhaṁ nipatanti, ","html":"<span class='verse-line'>{}</span>"},"pv51:3.4":{"pli":"te bhindanti ca matthakan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv51:4.1":{"pli":"“Kiṁ nu kāyena vācāya, ","html":"<p><span class='verse-line'>{}</span>"},"pv51:4.2":{"pli":"manasā dukkaṭaṁ kataṁ; ","html":"<span class='verse-line'>{}</span>"},"pv51:4.3":{"pli":"Kissa kammavipākena, ","html":"<span class='verse-line'>{}</span>"},"pv51:4.4":{"pli":"idaṁ dukkhaṁ nigacchasi. ","html":"<span class='verse-line'>{}</span></p>"},"pv51:5.1":{"pli":"Saṭṭhi kūṭasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"pv51:5.2":{"pli":"paripuṇṇāni sabbaso; ","html":"<span class='verse-line'>{}</span>"},"pv51:5.3":{"pli":"Sīse tuyhaṁ nipatanti, ","html":"<span class='verse-line'>{}</span>"},"pv51:5.4":{"pli":"te bhindanti ca matthakan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv51:6.1":{"pli":"“Athaddasāsiṁ sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv51:6.2":{"pli":"sunettaṁ bhāvitindriyaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv51:6.3":{"pli":"Nisinnaṁ rukkhamūlasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"pv51:6.4":{"pli":"jhāyantaṁ akutobhayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv51:7.1":{"pli":"Sālittakappahārena, ","html":"<p><span class='verse-line'>{}</span>"},"pv51:7.2":{"pli":"bhindissaṁ tassa matthakaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv51:7.3":{"pli":"Tassa kammavipākena, ","html":"<span class='verse-line'>{}</span>"},"pv51:7.4":{"pli":"idaṁ dukkhaṁ nigacchisaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv51:8.1":{"pli":"Saṭṭhi kūṭasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"pv51:8.2":{"pli":"Paripuṇṇāni sabbaso; ","html":"<span class='verse-line'>{}</span>"},"pv51:8.3":{"pli":"Sīse mayhaṁ nipatanti, ","html":"<span class='verse-line'>{}</span>"},"pv51:8.4":{"pli":"Te bhindanti ca matthakan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv51:9.1":{"pli":"“Dhammena te kāpurisa, ","html":"<p><span class='verse-line'>{}</span>"},"pv51:9.2":{"pli":"saṭṭhikūṭasahassāni; ","html":"<span class='verse-line'>{}</span>"},"pv51:9.3":{"pli":"Paripuṇṇāni sabbaso, ","html":"<span class='verse-line'>{}</span>"},"pv51:9.4":{"pli":"sīse tuyhaṁ nipatanti; ","html":"<span class='verse-line'>{}</span>"},"pv51:9.5":{"pli":"Te bhindanti ca matthakan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv51:10.1":{"pli":"Saṭṭhikūṭapetavatthu soḷasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"pv51:11.1":{"pli":"Mahāvaggo catuttho. ","html":"<p class='endsection'>{}</p>"},"pv51:12.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"pv51:13.1":{"pli":"Ambasakkaro serīsako, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"pv51:13.2":{"pli":"piṅgalo revati ucchu; ","html":"<span class='verse-line'>{}</span>"},"pv51:13.3":{"pli":"Dve kumārā duve gūthā, ","html":"<span class='verse-line'>{}</span>"},"pv51:13.4":{"pli":"gaṇapāṭaliambavanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv51:14.1":{"pli":"Akkharukkhabhogasaṁharā, ","html":"<p><span class='verse-line'>{}</span>"},"pv51:14.2":{"pli":"seṭṭhiputtasaṭṭhikūṭā; ","html":"<span class='verse-line'>{}</span>"},"pv51:14.3":{"pli":"Iti soḷasavatthūni, ","html":"<span class='verse-line'>{}</span>"},"pv51:14.4":{"pli":"vaggo tena pavuccati. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv51:15.1":{"pli":"Atha vagguddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"pv51:16.1":{"pli":"Urago uparivaggo, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"pv51:16.2":{"pli":"cūḷamahāti catudhā; ","html":"<span class='verse-line'>{}</span>"},"pv51:16.3":{"pli":"Vatthūni ekapaññāsaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv51:16.4":{"pli":"catudhā bhāṇavārato. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv51:17.1":{"pli":"Petavatthupāḷi niṭṭhitā. ","html":"<p class='endbook'>{}</p></article>"}},"pv6":{"pv6:0.1":{"pli":"Petavatthu ","html":"<article id='pv6'><header><ul><li class='division'>{}</li>"},"pv6:0.2":{"pli":"Uragavagga ","html":"<li>{}</li></ul>"},"pv6:0.3":{"pli":"6. Pañcaputtakhādapetivatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv6:1.1":{"pli":"“Naggā dubbaṇṇarūpāsi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv6:1.2":{"pli":"duggandhā pūti vāyasi; ","html":"<span class='verse-line'>{}</span>"},"pv6:1.3":{"pli":"Makkhikāhi parikiṇṇā, ","html":"<span class='verse-line'>{}</span>"},"pv6:1.4":{"pli":"kā nu tvaṁ idha tiṭṭhasī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv6:2.1":{"pli":"“Ahaṁ bhadante petīmhi, ","html":"<p><span class='verse-line'>{}</span>"},"pv6:2.2":{"pli":"duggatā yamalokikā; ","html":"<span class='verse-line'>{}</span>"},"pv6:2.3":{"pli":"Pāpakammaṁ karitvāna, ","html":"<span class='verse-line'>{}</span>"},"pv6:2.4":{"pli":"petalokaṁ ito gatā. ","html":"<span class='verse-line'>{}</span></p>"},"pv6:3.1":{"pli":"Kālena pañca puttāni, ","html":"<p><span class='verse-line'>{}</span>"},"pv6:3.2":{"pli":"sāyaṁ pañca punāpare; ","html":"<span class='verse-line'>{}</span>"},"pv6:3.3":{"pli":"Vijāyitvāna khādāmi, ","html":"<span class='verse-line'>{}</span>"},"pv6:3.4":{"pli":"tepi nā honti me alaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv6:4.1":{"pli":"Pariḍayhati dhūmāyati, ","html":"<p><span class='verse-line'>{}</span>"},"pv6:4.2":{"pli":"khudāya hadayaṁ mama; ","html":"<span class='verse-line'>{}</span>"},"pv6:4.3":{"pli":"Pānīyaṁ na labhe pātuṁ, ","html":"<span class='verse-line'>{}</span>"},"pv6:4.4":{"pli":"passa maṁ byasanaṁ gatan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv6:5.1":{"pli":"“Kiṁ nu kāyena vācāya, ","html":"<p><span class='verse-line'>{}</span>"},"pv6:5.2":{"pli":"manasā dukkaṭaṁ kataṁ; ","html":"<span class='verse-line'>{}</span>"},"pv6:5.3":{"pli":"Kissa kammavipākena, ","html":"<span class='verse-line'>{}</span>"},"pv6:5.4":{"pli":"puttamaṁsāni khādasī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv6:6.1":{"pli":"“Sapatī me gabbhinī āsi, ","html":"<p><span class='verse-line'>{}</span>"},"pv6:6.2":{"pli":"tassā pāpaṁ acetayiṁ; ","html":"<span class='verse-line'>{}</span>"},"pv6:6.3":{"pli":"Sāhaṁ paduṭṭhamanasā, ","html":"<span class='verse-line'>{}</span>"},"pv6:6.4":{"pli":"akariṁ gabbhapātanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv6:7.1":{"pli":"Tassā dvemāsiko gabbho, ","html":"<p><span class='verse-line'>{}</span>"},"pv6:7.2":{"pli":"lohitaññeva pagghari; ","html":"<span class='verse-line'>{}</span>"},"pv6:7.3":{"pli":"Tadassā mātā kupitā, ","html":"<span class='verse-line'>{}</span>"},"pv6:7.4":{"pli":"mayhaṁ ñātī samānayi; ","html":"<span class='verse-line'>{}</span>"},"pv6:7.5":{"pli":"Sapathañca maṁ kāresi, ","html":"<span class='verse-line'>{}</span>"},"pv6:7.6":{"pli":"paribhāsāpayī ca maṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv6:8.1":{"pli":"Sāhaṁ ghorañca sapathaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv6:8.2":{"pli":"musāvādaṁ abhāsisaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv6:8.3":{"pli":"Puttamaṁsāni khādāmi, ","html":"<span class='verse-line'>{}</span>"},"pv6:8.4":{"pli":"sace taṁ pakataṁ mayā. ","html":"<span class='verse-line'>{}</span></p>"},"pv6:9.1":{"pli":"Tassa kammassa vipākena, ","html":"<p><span class='verse-line'>{}</span>"},"pv6:9.2":{"pli":"musāvādassa cūbhayaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv6:9.3":{"pli":"Puttamaṁsāni khādāmi, ","html":"<span class='verse-line'>{}</span>"},"pv6:9.4":{"pli":"pubbalohitamakkhitā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv6:10.1":{"pli":"Pañcaputtakhādapetivatthu chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"pv7":{"pv7:0.1":{"pli":"Petavatthu ","html":"<article id='pv7'><header><ul><li class='division'>{}</li>"},"pv7:0.2":{"pli":"Uragavagga ","html":"<li>{}</li></ul>"},"pv7:0.3":{"pli":"7. Sattaputtakhādapetivatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv7:1.1":{"pli":"“Naggā dubbaṇṇarūpāsi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv7:1.2":{"pli":"duggandhā pūti vāyasi; ","html":"<span class='verse-line'>{}</span>"},"pv7:1.3":{"pli":"Makkhikāhi parikiṇṇā, ","html":"<span class='verse-line'>{}</span>"},"pv7:1.4":{"pli":"kā nu tvaṁ idha tiṭṭhasī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv7:2.1":{"pli":"“Ahaṁ bhadante petīmhi, ","html":"<p><span class='verse-line'>{}</span>"},"pv7:2.2":{"pli":"duggatā yamalokikā; ","html":"<span class='verse-line'>{}</span>"},"pv7:2.3":{"pli":"Pāpakammaṁ karitvāna, ","html":"<span class='verse-line'>{}</span>"},"pv7:2.4":{"pli":"petalokaṁ ito gatā. ","html":"<span class='verse-line'>{}</span></p>"},"pv7:3.1":{"pli":"Kālena satta puttāni, ","html":"<p><span class='verse-line'>{}</span>"},"pv7:3.2":{"pli":"sāyaṁ satta punāpare; ","html":"<span class='verse-line'>{}</span>"},"pv7:3.3":{"pli":"Vijāyitvāna khādāmi, ","html":"<span class='verse-line'>{}</span>"},"pv7:3.4":{"pli":"tepi nā honti me alaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv7:4.1":{"pli":"Pariḍayhati dhūmāyati, ","html":"<p><span class='verse-line'>{}</span>"},"pv7:4.2":{"pli":"khudāya hadayaṁ mama; ","html":"<span class='verse-line'>{}</span>"},"pv7:4.3":{"pli":"Nibbutiṁ nādhigacchāmi, ","html":"<span class='verse-line'>{}</span>"},"pv7:4.4":{"pli":"aggidaḍḍhāva ātape”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv7:5.1":{"pli":"“Kiṁ nu kāyena vācāya, ","html":"<p><span class='verse-line'>{}</span>"},"pv7:5.2":{"pli":"manasā dukkaṭaṁ kataṁ; ","html":"<span class='verse-line'>{}</span>"},"pv7:5.3":{"pli":"Kissa kammavipākena, ","html":"<span class='verse-line'>{}</span>"},"pv7:5.4":{"pli":"puttamaṁsāni khādasī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv7:6.1":{"pli":"“Ahū mayhaṁ duve puttā, ","html":"<p><span class='verse-line'>{}</span>"},"pv7:6.2":{"pli":"ubho sampattayobbanā; ","html":"<span class='verse-line'>{}</span>"},"pv7:6.3":{"pli":"Sāhaṁ puttabalūpetā, ","html":"<span class='verse-line'>{}</span>"},"pv7:6.4":{"pli":"sāmikaṁ atimaññisaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv7:7.1":{"pli":"Tato me sāmiko kuddho, ","html":"<p><span class='verse-line'>{}</span>"},"pv7:7.2":{"pli":"sapatiṁ mayhamānayi; ","html":"<span class='verse-line'>{}</span>"},"pv7:7.3":{"pli":"Sā ca gabbhaṁ alabhittha, ","html":"<span class='verse-line'>{}</span>"},"pv7:7.4":{"pli":"tassā pāpaṁ acetayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv7:8.1":{"pli":"Sāhaṁ paduṭṭhamanasā, ","html":"<p><span class='verse-line'>{}</span>"},"pv7:8.2":{"pli":"akariṁ gabbhapātanaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv7:8.3":{"pli":"Tassā temāsiko gabbho, ","html":"<span class='verse-line'>{}</span>"},"pv7:8.4":{"pli":"pūtilohitako pati. ","html":"<span class='verse-line'>{}</span></p>"},"pv7:9.1":{"pli":"Tadassā mātā kupitā, ","html":"<p><span class='verse-line'>{}</span>"},"pv7:9.2":{"pli":"mayhaṁ ñātī samānayi; ","html":"<span class='verse-line'>{}</span>"},"pv7:9.3":{"pli":"Sapathañca maṁ kāresi, ","html":"<span class='verse-line'>{}</span>"},"pv7:9.4":{"pli":"paribhāsāpayī ca maṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv7:10.1":{"pli":"Sāhaṁ ghorañca sapathaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv7:10.2":{"pli":"musāvādaṁ abhāsisaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv7:10.3":{"pli":"‘Puttamaṁsāni khādāmi, ","html":"<span class='verse-line'>{}</span>"},"pv7:10.4":{"pli":"sace taṁ pakataṁ mayā’. ","html":"<span class='verse-line'>{}</span></p>"},"pv7:11.1":{"pli":"Tassa kammassa vipākena, ","html":"<p><span class='verse-line'>{}</span>"},"pv7:11.2":{"pli":"musāvādassa cūbhayaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv7:11.3":{"pli":"Puttamaṁsāni khādāmi, ","html":"<span class='verse-line'>{}</span>"},"pv7:11.4":{"pli":"pubbalohitamakkhitā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv7:12.1":{"pli":"Sattaputtakhādapetivatthu sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"pv8":{"pv8:0.1":{"pli":"Petavatthu ","html":"<article id='pv8'><header><ul><li class='division'>{}</li>"},"pv8:0.2":{"pli":"Uragavagga ","html":"<li>{}</li></ul>"},"pv8:0.3":{"pli":"8. Goṇapetavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv8:1.1":{"pli":"“Kiṁ nu ummattarūpova, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv8:1.2":{"pli":"lāyitvā haritaṁ tiṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv8:1.3":{"pli":"Khāda khādāti lapasi, ","html":"<span class='verse-line'>{}</span>"},"pv8:1.4":{"pli":"gatasattaṁ jaraggavaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv8:2.1":{"pli":"Na hi annena pānena, ","html":"<p><span class='verse-line'>{}</span>"},"pv8:2.2":{"pli":"mato goṇo samuṭṭhahe; ","html":"<span class='verse-line'>{}</span>"},"pv8:2.3":{"pli":"Tvaṁsi bālo ca dummedho, ","html":"<span class='verse-line'>{}</span>"},"pv8:2.4":{"pli":"yathā taññova dummatī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv8:3.1":{"pli":"“Ime pādā idaṁ sīsaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv8:3.2":{"pli":"ayaṁ kāyo savāladhi; ","html":"<span class='verse-line'>{}</span>"},"pv8:3.3":{"pli":"Nettā tatheva tiṭṭhanti, ","html":"<span class='verse-line'>{}</span>"},"pv8:3.4":{"pli":"ayaṁ goṇo samuṭṭhahe. ","html":"<span class='verse-line'>{}</span></p>"},"pv8:4.1":{"pli":"Nāyyakassa hatthapādā, ","html":"<p><span class='verse-line'>{}</span>"},"pv8:4.2":{"pli":"kāyo sīsañca dissati; ","html":"<span class='verse-line'>{}</span>"},"pv8:4.3":{"pli":"Rudaṁ mattikathūpasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"pv8:4.4":{"pli":"nanu tvaññeva dummatī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv8:5.1":{"pli":"“Ādittaṁ vata maṁ santaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv8:5.2":{"pli":"ghatasittaṁva pāvakaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv8:5.3":{"pli":"Vārinā viya osiñcaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv8:5.4":{"pli":"sabbaṁ nibbāpaye daraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv8:6.1":{"pli":"Abbahī vata me sallaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv8:6.2":{"pli":"sokaṁ hadayanissitaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv8:6.3":{"pli":"Yo me sokaparetassa, ","html":"<span class='verse-line'>{}</span>"},"pv8:6.4":{"pli":"pitusokaṁ apānudi. ","html":"<span class='verse-line'>{}</span></p>"},"pv8:7.1":{"pli":"Svāhaṁ abbūḷhasallosmi, ","html":"<p><span class='verse-line'>{}</span>"},"pv8:7.2":{"pli":"sītibhūtosmi nibbuto; ","html":"<span class='verse-line'>{}</span>"},"pv8:7.3":{"pli":"Na socāmi na rodāmi, ","html":"<span class='verse-line'>{}</span>"},"pv8:7.4":{"pli":"tava sutvāna māṇava”. ","html":"<span class='verse-line'>{}</span></p>"},"pv8:8.1":{"pli":"Evaṁ karonti sappaññā, ","html":"<p><span class='verse-line'>{}</span>"},"pv8:8.2":{"pli":"ye honti anukampakā; ","html":"<span class='verse-line'>{}</span>"},"pv8:8.3":{"pli":"Vinivattayanti sokamhā, ","html":"<span class='verse-line'>{}</span>"},"pv8:8.4":{"pli":"sujāto pitaraṁ yathāti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv8:9.1":{"pli":"Goṇapetavatthu aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"pv9":{"pv9:0.1":{"pli":"Petavatthu ","html":"<article id='pv9'><header><ul><li class='division'>{}</li>"},"pv9:0.2":{"pli":"Uragavagga ","html":"<li>{}</li></ul>"},"pv9:0.3":{"pli":"9. Mahāpesakārapetivatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv9:1.1":{"pli":"“Gūthañca muttaṁ ruhirañca pubbaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv9:1.2":{"pli":"Paribhuñjati kissa ayaṁ vipāko; ","html":"<span class='verse-line'>{}</span>"},"pv9:1.3":{"pli":"Ayaṁ nu kiṁ kammamakāsi nārī, ","html":"<span class='verse-line'>{}</span>"},"pv9:1.4":{"pli":"Yā sabbadā lohitapubbabhakkhā. ","html":"<span class='verse-line'>{}</span></p>"},"pv9:2.1":{"pli":"Navāni vatthāni subhāni ceva, ","html":"<p><span class='verse-line'>{}</span>"},"pv9:2.2":{"pli":"Mudūni suddhāni ca lomasāni; ","html":"<span class='verse-line'>{}</span>"},"pv9:2.3":{"pli":"Dinnānimissā kitakā bhavanti, ","html":"<span class='verse-line'>{}</span>"},"pv9:2.4":{"pli":"Ayaṁ nu kiṁ kammamakāsi nārī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv9:3.1":{"pli":"“Bhariyā mamesā ahū bhadante, ","html":"<p><span class='verse-line'>{}</span>"},"pv9:3.2":{"pli":"Adāyikā maccharinī kadariyā; ","html":"<span class='verse-line'>{}</span>"},"pv9:3.3":{"pli":"Sā maṁ dadantaṁ samaṇabrāhmaṇānaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv9:3.4":{"pli":"Akkosati ca paribhāsati ca. ","html":"<span class='verse-line'>{}</span></p>"},"pv9:4.1":{"pli":"‘Gūthañca muttaṁ ruhirañca pubbaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv9:4.2":{"pli":"Paribhuñja tvaṁ asuciṁ sabbakālaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv9:4.3":{"pli":"Etaṁ te paralokasmiṁ hotu, ","html":"<span class='verse-line'>{}</span>"},"pv9:4.4":{"pli":"Vatthā ca te kitakasamā bhavantu’; ","html":"<span class='verse-line'>{}</span>"},"pv9:4.5":{"pli":"Etādisaṁ duccaritaṁ caritvā, ","html":"<span class='verse-line'>{}</span>"},"pv9:4.6":{"pli":"Idhāgatā cirarattāya khādatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv9:5.1":{"pli":"Mahāpesakārapetivatthu navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}