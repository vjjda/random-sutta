{"tha-ap500":{"tha-ap500:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap500'><header><ul><li class='division'>{}</li>"},"tha-ap500:0.2":{"pli":"Kiṅkaṇipupphavagga ","html":"<li>{}</li></ul>"},"tha-ap500:0.3":{"pli":"8 Pulinathūpiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap500:1.1":{"pli":"“Himavantassāvidūre, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap500:1.2":{"pli":"yamako nāma pabbato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:1.3":{"pli":"Assamo sukato mayhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:1.4":{"pli":"paṇṇasālā sumāpitā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:2.1":{"pli":"Nārado nāma nāmena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:2.2":{"pli":"jaṭilo uggatāpano; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:2.3":{"pli":"Catuddasasahassāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:2.4":{"pli":"sissā paricaranti maṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:3.1":{"pli":"Paṭisallīnako santo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:3.2":{"pli":"evaṁ cintesahaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:3.3":{"pli":"‘Sabbo jano maṁ pūjeti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:3.4":{"pli":"nāhaṁ pūjemi kiñcanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:4.1":{"pli":"Na me ovādako atthi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:4.2":{"pli":"vattā koci na vijjati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:4.3":{"pli":"Anācariyupajjhāyo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:4.4":{"pli":"vane vāsaṁ upemahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:5.1":{"pli":"Upāsamāno yamahaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:5.2":{"pli":"garucittaṁ upaṭṭhahe; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:5.3":{"pli":"So me ācariyo natthi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:5.4":{"pli":"vanavāso niratthako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:6.1":{"pli":"Āyāgaṁ me gavesissaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:6.2":{"pli":"garuṁ bhāvaniyaṁ tathā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:6.3":{"pli":"Sāvassayo vasissāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:6.4":{"pli":"na koci garahissati’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:7.1":{"pli":"Uttānakūlā nadikā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:7.2":{"pli":"supatitthā manoramā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:7.3":{"pli":"Saṁsuddhapulinākiṇṇā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:7.4":{"pli":"avidūre mamassamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:8.1":{"pli":"Nadiṁ amarikaṁ nāma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:8.2":{"pli":"upagantvānahaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:8.3":{"pli":"Saṁvaḍḍhayitvā pulinaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:8.4":{"pli":"akaṁ pulinacetiyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:9.1":{"pli":"Ye te ahesuṁ sambuddhā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:9.2":{"pli":"bhavantakaraṇā munī; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:9.3":{"pli":"Tesaṁ etādiso thūpo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:9.4":{"pli":"taṁ nimittaṁ karomahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:10.1":{"pli":"Karitvā pulinaṁ thūpaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:10.2":{"pli":"sovaṇṇaṁ māpayiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:10.3":{"pli":"Soṇṇakiṅkaṇipupphāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:10.4":{"pli":"sahasse tīṇi pūjayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:11.1":{"pli":"Sāyaṁ pātaṁ namassāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:11.2":{"pli":"vedajāto katañjalī; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:11.3":{"pli":"Sammukhā viya sambuddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:11.4":{"pli":"vandiṁ pulinacetiyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:12.1":{"pli":"Yadā kilesā jāyanti, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:12.2":{"pli":"vitakkā gehanissitā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:12.3":{"pli":"Sarāmi sukataṁ thūpaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:12.4":{"pli":"paccavekkhāmi tāvade. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:13.1":{"pli":"Upanissāya viharaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:13.2":{"pli":"satthavāhaṁ vināyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:13.3":{"pli":"Kilese saṁvaseyyāsi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:13.4":{"pli":"na yuttaṁ tava mārisa. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:14.1":{"pli":"Saha āvajjite thūpe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:14.2":{"pli":"gāravaṁ hoti me tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:14.3":{"pli":"Kuvitakke vinodesiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:14.4":{"pli":"nāgo tuttaṭṭito yathā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:15.1":{"pli":"Evaṁ viharamānaṁ maṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:15.2":{"pli":"maccurājābhimaddatha; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:15.3":{"pli":"Tattha kālaṅkato santo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:15.4":{"pli":"brahmalokamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:16.1":{"pli":"Yāvatāyuṁ vasitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:16.2":{"pli":"tidive upapajjahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:16.3":{"pli":"Asītikkhattuṁ devindo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:16.4":{"pli":"devarajjamakārayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:17.1":{"pli":"Satānaṁ tīṇikkhattuñca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:17.2":{"pli":"cakkavattī ahosahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:17.3":{"pli":"Padesarajjaṁ vipulaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:17.4":{"pli":"gaṇanāto asaṅkhiyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:18.1":{"pli":"Soṇṇakiṅkaṇipupphānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:18.2":{"pli":"vipākaṁ anubhomahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:18.3":{"pli":"Dhātīsatasahassāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:18.4":{"pli":"parivārenti maṁ bhave. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:19.1":{"pli":"Thūpassa pariciṇṇattā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:19.2":{"pli":"rajojallaṁ na limpati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:19.3":{"pli":"Gatte sedā na muccanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:19.4":{"pli":"suppabhāso bhavāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:20.1":{"pli":"Aho me sukato thūpo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:20.2":{"pli":"sudiṭṭhā marikā nadī; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:20.3":{"pli":"Thūpaṁ katvāna pulinaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:20.4":{"pli":"pattomhi acalaṁ padaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:21.1":{"pli":"Kusalaṁ kattukāmena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:21.2":{"pli":"jantunā sāragāhinā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:21.3":{"pli":"Natthi khettaṁ akhettaṁ vā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:21.4":{"pli":"paṭipattīva sādhakā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:22.1":{"pli":"Yathāpi balavā poso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:22.2":{"pli":"aṇṇavaṁ taritussahe; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:22.3":{"pli":"Parittaṁ kaṭṭhamādāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:22.4":{"pli":"pakkhandeyya mahāsaraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:23.1":{"pli":"Imāhaṁ kaṭṭhaṁ nissāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:23.2":{"pli":"tarissāmi mahodadhiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:23.3":{"pli":"Ussāhena vīriyena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:23.4":{"pli":"tareyya udadhiṁ naro. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:24.1":{"pli":"Tatheva me kataṁ kammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:24.2":{"pli":"parittaṁ thokakañca yaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:24.3":{"pli":"Taṁ kammaṁ upanissāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:24.4":{"pli":"saṁsāraṁ samatikkamiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:25.1":{"pli":"Pacchime bhave sampatte, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:25.2":{"pli":"sukkamūlena codito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:25.3":{"pli":"Sāvatthiyaṁ pure jāto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:25.4":{"pli":"mahāsāle suaḍḍhake. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:26.1":{"pli":"Saddhā mātā pitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:26.2":{"pli":"buddhassa saraṇaṁ gatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:26.3":{"pli":"Ubho diṭṭhapadā ete, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:26.4":{"pli":"anuvattanti sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:27.1":{"pli":"Bodhipapaṭikaṁ gayha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:27.2":{"pli":"soṇṇathūpamakārayuṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:27.3":{"pli":"Sāyaṁ pātaṁ namassanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:27.4":{"pli":"sakyaputtassa sammukhā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:28.1":{"pli":"Uposathamhi divase, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:28.2":{"pli":"soṇṇathūpaṁ vinīharuṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:28.3":{"pli":"Buddhassa vaṇṇaṁ kittentā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:28.4":{"pli":"tiyāmaṁ vītināmayuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:29.1":{"pli":"Saha disvānahaṁ thūpaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:29.2":{"pli":"sariṁ pulinacetiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:29.3":{"pli":"Ekāsane nisīditvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:29.4":{"pli":"arahattamapāpuṇiṁ. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap500:30.1":{"pli":"Dvāvīsatimaṁ bhāṇavāraṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap500:31.1":{"pli":"Gavesamāno taṁ vīraṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap500:31.2":{"pli":"dhammasenāpatiddasaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:31.3":{"pli":"Agārā nikkhamitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:31.4":{"pli":"pabbajiṁ tassa santike. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:32.1":{"pli":"Jātiyā sattavassena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:32.2":{"pli":"arahattamapāpuṇiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:32.3":{"pli":"Upasampādayī buddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:32.4":{"pli":"guṇamaññāya cakkhumā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:33.1":{"pli":"Dārakeneva santena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:33.2":{"pli":"kiriyaṁ niṭṭhitaṁ mayā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:33.3":{"pli":"Kataṁ me karaṇīyajja, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:33.4":{"pli":"sakyaputtassa sāsane. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:34.1":{"pli":"Sabbaverabhayātīto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:34.2":{"pli":"sabbasaṅgātigo isi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:34.3":{"pli":"Sāvako te mahāvīra, ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:34.4":{"pli":"soṇṇathūpassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:35.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:35.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:35.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:36.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:36.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:36.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap500:37.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap500:37.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap500:37.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap500:38.1":{"pli":"Itthaṁ sudaṁ āyasmā pulinathūpiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap500:39.1":{"pli":"Pulinathūpiyattherassāpadānaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap501":{"tha-ap501:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap501'><header><ul><li class='division'>{}</li>"},"tha-ap501:0.2":{"pli":"Kiṅkaṇipupphavagga ","html":"<li>{}</li></ul>"},"tha-ap501:0.3":{"pli":"9 Naḷakuṭidāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap501:1.1":{"pli":"“Himavantassāvidūre, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap501:1.2":{"pli":"hārito nāma pabbato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap501:1.3":{"pli":"Sayambhū nārado nāma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap501:1.4":{"pli":"rukkhamūle vasī tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap501:2.1":{"pli":"Naḷāgāraṁ karitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap501:2.2":{"pli":"tiṇena chādayiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap501:2.3":{"pli":"Caṅkamaṁ sodhayitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap501:2.4":{"pli":"sayambhussa adāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap501:3.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap501:3.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap501:3.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap501:3.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap501:4.1":{"pli":"Tattha me sukataṁ byamhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap501:4.2":{"pli":"naḷakuṭikanimmitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap501:4.3":{"pli":"Saṭṭhiyojanamubbedhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap501:4.4":{"pli":"tiṁsayojanavitthataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap501:5.1":{"pli":"Catuddasesu kappesu, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap501:5.2":{"pli":"devaloke ramiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap501:5.3":{"pli":"Ekasattatikkhattuñca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap501:5.4":{"pli":"devarajjamakārayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap501:6.1":{"pli":"Catutiṁsatikkhattuñca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap501:6.2":{"pli":"cakkavattī ahosahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap501:6.3":{"pli":"Padesarajjaṁ vipulaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap501:6.4":{"pli":"gaṇanāto asaṅkhiyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap501:7.1":{"pli":"Dhammapāsādamāruyha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap501:7.2":{"pli":"sabbākāravarūpamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap501:7.3":{"pli":"Yadicchakāhaṁ vihare, ","html":"<span class='verse-line'>{}</span>"},"tha-ap501:7.4":{"pli":"sakyaputtassa sāsane. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap501:8.1":{"pli":"Ekatiṁse ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap501:8.2":{"pli":"yaṁ kammamakariṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap501:8.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap501:8.4":{"pli":"naḷakuṭiyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap501:9.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap501:9.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap501:9.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap501:10.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap501:10.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap501:10.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap501:11.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap501:11.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap501:11.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap501:12.1":{"pli":"Itthaṁ sudaṁ āyasmā naḷakuṭidāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap501:13.1":{"pli":"Naḷakuṭidāyakattherassāpadānaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap502":{"tha-ap502:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap502'><header><ul><li class='division'>{}</li>"},"tha-ap502:0.2":{"pli":"Kiṅkaṇipupphavagga ","html":"<li>{}</li></ul>"},"tha-ap502:0.3":{"pli":"Piyālaphaladāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap502:1.1":{"pli":"“Migaluddo pure āsiṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap502:1.2":{"pli":"vipine vicaraṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap502:1.3":{"pli":"Addasaṁ virajaṁ buddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap502:1.4":{"pli":"sabbadhammāna pāraguṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap502:2.1":{"pli":"Piyālaphalamādāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap502:2.2":{"pli":"buddhaseṭṭhassadāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap502:2.3":{"pli":"Puññakkhettassa vīrassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap502:2.4":{"pli":"pasanno sehi pāṇibhi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap502:3.1":{"pli":"Ekatiṁse ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap502:3.2":{"pli":"yaṁ phalaṁ adadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap502:3.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap502:3.4":{"pli":"phaladānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap502:4.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap502:4.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap502:4.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap502:5.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap502:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap502:5.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap502:6.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap502:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap502:6.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap502:7.1":{"pli":"Itthaṁ sudaṁ āyasmā piyālaphaladāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap502:8.1":{"pli":"Piyālaphaladāyakattherassāpadānaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap502:8.2":{"pli":"Kiṅkaṇipupphavaggo paññāsamo. ","html":"<p class='endsection'>{}</p>"},"tha-ap502:9.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"tha-ap502:10.1":{"pli":"Kiṅkaṇī paṁsukūlañca, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"tha-ap502:10.2":{"pli":"koraṇḍamatha kiṁsukaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap502:10.3":{"pli":"Upaḍḍhadussī ghatado, ","html":"<span class='verse-line'>{}</span>"},"tha-ap502:10.4":{"pli":"udakaṁ thūpakārako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap502:11.1":{"pli":"Naḷakārī ca navamo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap502:11.2":{"pli":"piyālaphaladāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap502:11.3":{"pli":"Satamekañca gāthānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap502:11.4":{"pli":"navakañca taduttari. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap502:12.1":{"pli":"Atha vagguddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"tha-ap502:13.1":{"pli":"Metteyyavaggo bhaddāli, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"tha-ap502:13.2":{"pli":"sakiṁsammajjakopi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap502:13.3":{"pli":"Ekavihārī vibhītakī, ","html":"<span class='verse-line'>{}</span>"},"tha-ap502:13.4":{"pli":"jagatī sālapupphiyo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap502:14.1":{"pli":"Naḷāgāraṁ paṁsukūlaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap502:14.2":{"pli":"kiṅkaṇipupphiyo tathā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap502:14.3":{"pli":"Asīti dve ca gāthāyo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap502:14.4":{"pli":"catuddasasatāni ca. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap502:15.1":{"pli":"Metteyyavaggadasakaṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap502:16.1":{"pli":"Pañcamasatakaṁ samattaṁ. ","html":"<p class='endsection'>{}</p></article>"}},"tha-ap503":{"tha-ap503:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap503'><header><ul><li class='division'>{}</li>"},"tha-ap503:0.2":{"pli":"Kaṇikāravagga ","html":"<li>{}</li></ul>"},"tha-ap503:0.3":{"pli":"1 Tikaṇikārapupphiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap503:1.1":{"pli":"“Sumedho nāma sambuddho, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap503:1.2":{"pli":"bāttiṁsavaralakkhaṇo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:1.3":{"pli":"Vivekakāmo sambuddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:1.4":{"pli":"himavantamupāgamiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:2.1":{"pli":"Ajjhogayha himavantaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:2.2":{"pli":"aggo kāruṇiko muni; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:2.3":{"pli":"Pallaṅkamābhujitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:2.4":{"pli":"nisīdi purisuttamo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:3.1":{"pli":"Vijjādharo tadā āsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:3.2":{"pli":"antalikkhacaro ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:3.3":{"pli":"Tisūlaṁ sukataṁ gayha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:3.4":{"pli":"gacchāmi ambare tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:4.1":{"pli":"Pabbatagge yathā aggi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:4.2":{"pli":"puṇṇamāyeva candimā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:4.3":{"pli":"Vane obhāsate buddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:4.4":{"pli":"sālarājāva phullito. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:5.1":{"pli":"Vanaggā nikkhamitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:5.2":{"pli":"buddharaṁsībhidhāvare; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:5.3":{"pli":"Naḷaggivaṇṇasaṅkāsā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:5.4":{"pli":"disvā cittaṁ pasādayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:6.1":{"pli":"Vicinaṁ addasaṁ pupphaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:6.2":{"pli":"kaṇikāraṁ devagandhikaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:6.3":{"pli":"Tīṇi pupphāni ādāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:6.4":{"pli":"buddhaseṭṭhamapūjayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:7.1":{"pli":"Buddhassa ānubhāvena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:7.2":{"pli":"tīṇi pupphāni me tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:7.3":{"pli":"Uddhaṁvaṇṭā adhopattā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:7.4":{"pli":"chāyaṁ kubbanti satthuno. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:8.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:8.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:8.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:8.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:9.1":{"pli":"Tattha me sukataṁ byamhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:9.2":{"pli":"kaṇikārīti ñāyati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:9.3":{"pli":"Saṭṭhiyojanamubbedhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:9.4":{"pli":"tiṁsayojanavitthataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:10.1":{"pli":"Sahassakaṇḍaṁ satabheṇḍu, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:10.2":{"pli":"dhajāluharitāmayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:10.3":{"pli":"Satasahassaniyyūhā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:10.4":{"pli":"byamhe pātubhaviṁsu me. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:11.1":{"pli":"Soṇṇamayā maṇimayā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:11.2":{"pli":"lohitaṅgamayāpi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:11.3":{"pli":"Phalikāpi ca pallaṅkā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:11.4":{"pli":"yenicchakā yadicchakā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:12.1":{"pli":"Mahārahañca sayanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:12.2":{"pli":"tūlikāvikatīyutaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:12.3":{"pli":"Uddhalomikaekantaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:12.4":{"pli":"bibbohanasamāyutaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:13.1":{"pli":"Bhavanā nikkhamitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:13.2":{"pli":"caranto devacārikaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:13.3":{"pli":"Yadā icchāmi gamanaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:13.4":{"pli":"devasaṅghapurakkhato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:14.1":{"pli":"Pupphassa heṭṭhā tiṭṭhāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:14.2":{"pli":"uparicchadanaṁ mama; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:14.3":{"pli":"Samantā yojanasataṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:14.4":{"pli":"kaṇikārehi chāditaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:15.1":{"pli":"Saṭṭhituriyasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:15.2":{"pli":"sāyaṁ pātamupaṭṭhahuṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:15.3":{"pli":"Parivārenti maṁ niccaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:15.4":{"pli":"rattindivamatanditā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:16.1":{"pli":"Tattha naccehi gītehi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:16.2":{"pli":"tāḷehi vāditehi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:16.3":{"pli":"Ramāmi khiḍḍāratiyā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:16.4":{"pli":"modāmi kāmakāmihaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:17.1":{"pli":"Tattha bhutvā pivitvā ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:17.2":{"pli":"modāmi tidase tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:17.3":{"pli":"Nārīgaṇehi sahito, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:17.4":{"pli":"modāmi byamhamuttame. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:18.1":{"pli":"Satānaṁ pañcakkhattuñca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:18.2":{"pli":"devarajjamakārayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:18.3":{"pli":"Satānaṁ tīṇikkhattuñca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:18.4":{"pli":"cakkavattī ahosahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:18.5":{"pli":"Padesarajjaṁ vipulaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:18.6":{"pli":"gaṇanāto asaṅkhiyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:19.1":{"pli":"Bhavābhave saṁsaranto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:19.2":{"pli":"mahābhogaṁ labhāmahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:19.3":{"pli":"Bhoge me ūnatā natthi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:19.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:20.1":{"pli":"Duve bhave saṁsarāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:20.2":{"pli":"devatte atha mānuse; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:20.3":{"pli":"Aññaṁ gatiṁ na jānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:20.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:21.1":{"pli":"Duve kule pajāyāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:21.2":{"pli":"khattiye cāpi brāhmaṇe; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:21.3":{"pli":"Nīce kule na jāyāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:21.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:22.1":{"pli":"Hatthiyānaṁ assayānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:22.2":{"pli":"sivikaṁ sandamānikaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:22.3":{"pli":"Labhāmi sabbamevetaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:22.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:23.1":{"pli":"Dāsīgaṇaṁ dāsagaṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:23.2":{"pli":"nāriyo samalaṅkatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:23.3":{"pli":"Labhāmi sabbamevetaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:23.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:24.1":{"pli":"Koseyyakambaliyāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:24.2":{"pli":"khomakappāsikāni ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:24.3":{"pli":"Labhāmi sabbamevetaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:24.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:25.1":{"pli":"Navavatthaṁ navaphalaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:25.2":{"pli":"navaggarasabhojanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:25.3":{"pli":"Labhāmi sabbamevetaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:25.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:26.1":{"pli":"Imaṁ khāda imaṁ bhuñja, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:26.2":{"pli":"imamhi sayane saya; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:26.3":{"pli":"Labhāmi sabbamevetaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:26.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:27.1":{"pli":"Sabbattha pūjito homi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:27.2":{"pli":"yaso abbhuggato mama; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:27.3":{"pli":"Mahāpakkho sadā homi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:27.4":{"pli":"abhejjapariso sadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:27.5":{"pli":"Ñātīnaṁ uttamo homi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:27.6":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:28.1":{"pli":"Sītaṁ uṇhaṁ na jānāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:28.2":{"pli":"pariḷāho na vijjati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:28.3":{"pli":"Atho cetasikaṁ dukkhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:28.4":{"pli":"hadaye me na vijjati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:29.1":{"pli":"Suvaṇṇavaṇṇo hutvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:29.2":{"pli":"saṁsarāmi bhavābhave; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:29.3":{"pli":"Vevaṇṇiyaṁ na jānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:29.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:30.1":{"pli":"Devalokā cavitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:30.2":{"pli":"sukkamūlena codito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:30.3":{"pli":"Sāvatthiyaṁ pure jāto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:30.4":{"pli":"mahāsāle suaḍḍhake. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:31.1":{"pli":"Pañca kāmaguṇe hitvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:31.2":{"pli":"pabbajiṁ anagāriyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:31.3":{"pli":"Jātiyā sattavassohaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:31.4":{"pli":"arahattamapāpuṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:32.1":{"pli":"Upasampādayī buddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:32.2":{"pli":"guṇamaññāya cakkhumā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:32.3":{"pli":"Taruṇo pūjanīyohaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:32.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:33.1":{"pli":"Dibbacakkhu visuddhaṁ me, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:33.2":{"pli":"samādhikusalo ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:33.3":{"pli":"Abhiññāpāramippatto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:33.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:34.1":{"pli":"Paṭisambhidā anuppatto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:34.2":{"pli":"iddhipādesu kovido; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:34.3":{"pli":"Dhammesu pāramippatto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:34.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:35.1":{"pli":"Tiṁsakappasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:35.2":{"pli":"yaṁ buddhamabhipūjayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:35.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:35.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:36.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:36.2":{"pli":"bhavā sabbe samūhatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:36.3":{"pli":"Nāgova bandhanaṁ chetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:36.4":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:37.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:37.2":{"pli":"mama buddhassa santike; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:37.3":{"pli":"Tisso vijjā anuppattā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:37.4":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap503:38.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap503:38.2":{"pli":"vimokkhāpi ca aṭṭhime; ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:38.3":{"pli":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap503:38.4":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap503:39.1":{"pli":"Itthaṁ sudaṁ āyasmā tikaṇikārapupphiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap503:40.1":{"pli":"Tikaṇikārapupphiyattherassāpadānaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap504":{"tha-ap504:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap504'><header><ul><li class='division'>{}</li>"},"tha-ap504:0.2":{"pli":"Kaṇikāravagga ","html":"<li>{}</li></ul>"},"tha-ap504:0.3":{"pli":"Ekapattadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap504:1.1":{"pli":"“Nagare haṁsavatiyā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap504:1.2":{"pli":"kumbhakāro ahosahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap504:1.3":{"pli":"Addasaṁ virajaṁ buddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap504:1.4":{"pli":"oghatiṇṇamanāsavaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap504:2.1":{"pli":"Sukataṁ mattikāpattaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap504:2.2":{"pli":"buddhaseṭṭhassadāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap504:2.3":{"pli":"Pattaṁ datvā bhagavato, ","html":"<span class='verse-line'>{}</span>"},"tha-ap504:2.4":{"pli":"ujubhūtassa tādino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap504:3.1":{"pli":"Bhave nibbattamānohaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap504:3.2":{"pli":"soṇṇathāle labhāmahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap504:3.3":{"pli":"Rūpimaye ca sovaṇṇe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap504:3.4":{"pli":"taṭṭike ca maṇīmaye. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap504:4.1":{"pli":"Pātiyo paribhuñjāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap504:4.2":{"pli":"puññakammassidaṁ phalaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap504:4.3":{"pli":"Yasānañca dhanānañca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap504:4.4":{"pli":"aggabhūto ca homahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap504:5.1":{"pli":"Yathāpi bhaddake khette, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap504:5.2":{"pli":"bījaṁ appampi ropitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap504:5.3":{"pli":"Sammādhāraṁ pavecchante, ","html":"<span class='verse-line'>{}</span>"},"tha-ap504:5.4":{"pli":"phalaṁ toseti kassakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap504:6.1":{"pli":"Tathevidaṁ pattadānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap504:6.2":{"pli":"buddhakhettamhi ropitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap504:6.3":{"pli":"Pītidhāre pavassante, ","html":"<span class='verse-line'>{}</span>"},"tha-ap504:6.4":{"pli":"phalaṁ maṁ tosayissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap504:7.1":{"pli":"Yāvatā khettā vijjanti, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap504:7.2":{"pli":"saṅghāpi ca gaṇāpi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap504:7.3":{"pli":"Buddhakhettasamo natthi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap504:7.4":{"pli":"sukhado sabbapāṇinaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap504:8.1":{"pli":"Namo te purisājañña, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap504:8.2":{"pli":"namo te purisuttama; ","html":"<span class='verse-line'>{}</span>"},"tha-ap504:8.3":{"pli":"Ekapattaṁ daditvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap504:8.4":{"pli":"pattomhi acalaṁ padaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap504:9.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap504:9.2":{"pli":"yaṁ pattamadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap504:9.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap504:9.4":{"pli":"pattadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap504:10.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap504:10.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap504:10.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap504:11.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap504:11.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap504:11.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap504:12.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap504:12.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap504:12.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap504:13.1":{"pli":"Itthaṁ sudaṁ āyasmā ekapattadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap504:14.1":{"pli":"Ekapattadāyakattherassāpadānaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap505":{"tha-ap505:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap505'><header><ul><li class='division'>{}</li>"},"tha-ap505:0.2":{"pli":"Kaṇikāravagga ","html":"<li>{}</li></ul>"},"tha-ap505:0.3":{"pli":"3 Kāsumāraphaliyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap505:1.1":{"pli":"“Kaṇikāraṁva jotantaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap505:1.2":{"pli":"nisinnaṁ pabbatantare; ","html":"<span class='verse-line'>{}</span>"},"tha-ap505:1.3":{"pli":"Addasaṁ virajaṁ buddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap505:1.4":{"pli":"lokajeṭṭhaṁ narāsabhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap505:2.1":{"pli":"Pasannacitto sumano, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap505:2.2":{"pli":"sire katvāna añjaliṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap505:2.3":{"pli":"Kāsumārikamādāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap505:2.4":{"pli":"buddhaseṭṭhassadāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap505:3.1":{"pli":"Ekatiṁse ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap505:3.2":{"pli":"yaṁ phalaṁ adadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap505:3.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap505:3.4":{"pli":"phaladānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap505:4.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap505:4.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap505:4.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap505:5.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap505:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap505:5.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap505:6.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap505:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap505:6.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap505:7.1":{"pli":"Itthaṁ sudaṁ āyasmā kāsumāraphaliyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap505:8.1":{"pli":"Kāsumāraphaliyattherassāpadānaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}