ha-ap481:2.2":{"pli":"addhānaṁ paṭipajjahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap481:2.3":{"pli":"Tatthaddasāsiṁ sambuddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap481:2.4":{"pli":"pattikaṁ cārudassanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap481:3.1":{"pli":"Sakaṁ cittaṁ pasādetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap481:3.2":{"pli":"nīharitvāna pānadhiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap481:3.3":{"pli":"Pādamūle ṭhapetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap481:3.4":{"pli":"idaṁ vacanamabraviṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap481:4.1":{"pli":"‘Abhirūha mahāvīra, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap481:4.2":{"pli":"sugatinda vināyaka; ","html":"<span class='verse-line'>{}</span>"},"tha-ap481:4.3":{"pli":"Ito phalaṁ labhissāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap481:4.4":{"pli":"so me attho samijjhatu’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap481:5.1":{"pli":"Anomadassī bhagavā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap481:5.2":{"pli":"lokajeṭṭho narāsabho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap481:5.3":{"pli":"Pānadhiṁ abhirūhitvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap481:5.4":{"pli":"idaṁ vacanamabravi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap481:6.1":{"pli":"‘Yo pānadhiṁ me adāsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap481:6.2":{"pli":"pasanno sehi pāṇibhi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap481:6.3":{"pli":"Tamahaṁ kittayissāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap481:6.4":{"pli":"suṇātha mama bhāsato’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap481:7.1":{"pli":"Buddhassa giramaññāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap481:7.2":{"pli":"sabbe devā samāgatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap481:7.3":{"pli":"Udaggacittā sumanā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap481:7.4":{"pli":"vedajātā katañjalī. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap481:8.1":{"pli":"‘Pānadhīnaṁ padānena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap481:8.2":{"pli":"sukhitoyaṁ bhavissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap481:8.3":{"pli":"Pañcapaññāsakkhattuñca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap481:8.4":{"pli":"devarajjaṁ karissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap481:9.1":{"pli":"Sahassakkhattuṁ rājā ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap481:9.2":{"pli":"cakkavattī bhavissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap481:9.3":{"pli":"Padesarajjaṁ vipulaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap481:9.4":{"pli":"gaṇanāto asaṅkhiyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap481:10.1":{"pli":"Aparimeyye ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap481:10.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap481:10.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap481:10.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap481:11.1":{"pli":"Tassa dhammesu dāyādo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap481:11.2":{"pli":"oraso dhammanimmito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap481:11.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap481:11.4":{"pli":"nibbāyissatināsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap481:12.1":{"pli":"Devaloke manusse vā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap481:12.2":{"pli":"nibbattissati puññavā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap481:12.3":{"pli":"Devayānapaṭibhāgaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap481:12.4":{"pli":"yānaṁ paṭilabhissati’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap481:13.1":{"pli":"Pāsādā sivikā vayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap481:13.2":{"pli":"hatthino samalaṅkatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap481:13.3":{"pli":"Rathā vājaññasaṁyuttā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap481:13.4":{"pli":"sadā pātubhavanti me. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap481:14.1":{"pli":"Agārā nikkhamantopi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap481:14.2":{"pli":"rathena nikkhamiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap481:14.3":{"pli":"Kesesu chijjamānesu, ","html":"<span class='verse-line'>{}</span>"},"tha-ap481:14.4":{"pli":"arahattamapāpuṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap481:15.1":{"pli":"Lābhā mayhaṁ suladdhaṁ me, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap481:15.2":{"pli":"vāṇijjaṁ suppayojitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap481:15.3":{"pli":"Datvāna pānadhiṁ ekaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap481:15.4":{"pli":"pattomhi acalaṁ padaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap481:16.1":{"pli":"Aparimeyye ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap481:16.2":{"pli":"yaṁ pānadhimadāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap481:16.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap481:16.4":{"pli":"pānadhissa idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap481:17.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap481:17.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap481:17.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap481:18.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap48