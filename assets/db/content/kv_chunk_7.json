{"kv10.11":{"kv10.11:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv10.11'><header><ul><li class='division'>{}</li>"},"kv10.11:0.2":{"pli":"Mahāpaṇṇāsaka ","html":"<li>{}</li>"},"kv10.11:0.3":{"pli":"Dasamavagga ","html":"<li>{}</li></ul>"},"kv10.11:0.4":{"pli":"Aviññattidussilyantikathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv10.11:1.1":{"pli":"Aviññatti dussilyanti? ","html":"<p data-doxy='orthodox'>{}"},"kv10.11:1.2":{"pli":"Āmantā. ","html":"{}"},"kv10.11:1.3":{"pli":"Pāṇātipātoti? ","html":"{}"},"kv10.11:1.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv10.11:1.5":{"pli":"adinnādānanti? ","html":"{}"},"kv10.11:1.6":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv10.11:1.7":{"pli":"kāmesumicchācāroti? ","html":"{}"},"kv10.11:1.8":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv10.11:1.9":{"pli":"musāvādoti? ","html":"{}"},"kv10.11:1.10":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv10.11:1.11":{"pli":"surāmerayamajjapamādaṭṭhānanti? ","html":"{}"},"kv10.11:1.12":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv10.11:2.1":{"pli":"Pāpakammaṁ samādiyitvā dānaṁ dadantassa puññañca apuññañca ubho vaḍḍhantīti? ","html":"<p data-doxy='orthodox'>{}"},"kv10.11:2.2":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv10.11:2.3":{"pli":"puññañca apuññañca ubho vaḍḍhantīti? ","html":"{}"},"kv10.11:2.4":{"pli":"Āmantā. ","html":"{}"},"kv10.11:2.5":{"pli":"Dvinnaṁ phassānaṁ …pe… ","html":"{}"},"kv10.11:2.6":{"pli":"dvinnaṁ cittānaṁ samodhānaṁ hotīti? ","html":"{}"},"kv10.11:2.7":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv10.11:2.8":{"pli":"dvinnaṁ phassānaṁ …pe… ","html":"{}"},"kv10.11:2.9":{"pli":"dvinnaṁ cittānaṁ samodhānaṁ hotīti? ","html":"{}"},"kv10.11:2.10":{"pli":"Āmantā. ","html":"{}"},"kv10.11:2.11":{"pli":"Kusalākusalā sāvajjānavajjā hīnapaṇītā kaṇhasukkasappaṭibhāgā dhammā sammukhībhāvaṁ āgacchantīti? ","html":"{}"},"kv10.11:2.12":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv10.11:3.1":{"pli":"Kusalākusalā sāvajjānavajjā hīnapaṇītā kaṇhasukkasappaṭibhāgā dhammā sammukhībhāvaṁ āgacchantīti? ","html":"<p data-doxy='orthodox'>{}"},"kv10.11:3.2":{"pli":"Āmantā. ","html":"{}"},"kv10.11:3.3":{"pli":"Nanu vuttaṁ bhagavatā—","html":"{}"},"kv10.11:3.4":{"pli":"“cattārimāni, bhikkhave, suvidūravidūrāni. ","html":"{}"},"kv10.11:3.5":{"pli":"Katamāni cattāri? ","html":"{}"},"kv10.11:3.6":{"pli":"Nabhañca, bhikkhave, pathavī ca—","html":"{}"},"kv10.11:3.7":{"pli":"idaṁ paṭhamaṁ suvidūravidūraṁ …pe… tasmā sataṁ dhammo asabbhi ārakā”ti. ","html":"{}"},"kv10.11:3.8":{"pli":"Attheva suttantoti? ","html":"{}"},"kv10.11:3.9":{"pli":"Āmantā. ","html":"{}"},"kv10.11:3.10":{"pli":"Tena hi na vattabbaṁ—","html":"{}"},"kv10.11:3.11":{"pli":"“kusalākusalā sāvajjānavajjā hīnapaṇītā kaṇhasukkasappaṭibhāgā dhammā sammukhībhāvaṁ āgacchantī”ti …pe…. ","html":"{}</p>"},"kv10.11:4.1":{"pli":"Na vattabbaṁ—","html":"<p data-doxy='heterodox'>{}"},"kv10.11:4.2":{"pli":"“aviññatti dussilyan”ti? ","html":"{}"},"kv10.11:4.3":{"pli":"Āmantā. ","html":"{}"},"kv10.11:4.4":{"pli":"Nanu pāpakammaṁ samādinno āsīti? ","html":"{}"},"kv10.11:4.5":{"pli":"Āmantā. ","html":"{}"},"kv10.11:4.6":{"pli":"Hañci pāpakammaṁ samādinno āsi, tena vata re vattabbe—","html":"{}"},"kv10.11:4.7":{"pli":"“aviññatti dussilyan”ti. ","html":"{}</p>"},"kv10.11:4.8":{"pli":"Aviññatti dussilyantikathā niṭṭhitā. ","html":"<p class='endsutta'>{}<br>"},"kv10.11:4.9":{"pli":"Dasamo vaggo. ","html":"{}</p>"},"kv10.11:4.10":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"kv10.11:5.1":{"pli":"Upapattesiye pañcakkhandhe aniruddhe kiriyā pañcakkhandhā uppajjanti, maggasamaṅgissa rūpaṁ maggo, pañcaviññāṇasamaṅgissa atthi maggabhāvanā, pañcaviññāṇā kusalāpi akusalāpi, pañcaviññāṇā sābhogā, maggasamaṅgī dvīhi sīlehi samannāgato, sīlaṁ acetasikaṁ, sīlaṁ na cittānuparivatti, samādānahetukaṁ sīlaṁ vaḍḍhatīti, viññattisīlaṁ aviññatti dussilyanti. ","html":"<p class='uddana'>{}</p>"},"kv10.11:5.2":{"pli":"Dutiyo paṇṇāsako. ","html":"<p class='endsutta'>{}</p>"},"kv10.11:5.3":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"kv10.11:6.1":{"pli":"Niyāmasaṅgahagatānisaṁsatā ca nirodhoti. ","html":"<p class='uddana'>{}</p></article>"}},"kv10.2":{"kv10.2:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv10.2'><header><ul><li class='division'>{}</li>"},"kv10.2:0.2":{"pli":"Mahāpaṇṇāsaka ","html":"<li>{}</li>"},"kv10.2:0.3":{"pli":"Dasamavagga ","html":"<li>{}</li></ul>"},"kv10.2:0.4":{"pli":"Rūpaṁmaggotikathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv10.2:1.1":{"pli":"Maggasamaṅgissa rūpaṁ maggoti? ","html":"<p data-doxy='orthodox'>{}"},"kv10.2:1.2":{"pli":"Āmantā. ","html":"{}"},"kv10.2:1.3":{"pli":"Sārammaṇaṁ, atthi tassa āvaṭṭanā ābhogo samannāhāro manasikāro cetanā patthanā paṇidhīti? ","html":"{}"},"kv10.2:1.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv10.2:1.5":{"pli":"nanu anārammaṇaṁ, natthi tassa āvaṭṭanā …pe… paṇidhīti? ","html":"{}"},"kv10.2:1.6":{"pli":"Āmantā. ","html":"{}"},"kv10.2:1.7":{"pli":"Hañci anārammaṇaṁ, natthi tassa āvaṭṭanā …pe… paṇidhi; ","html":"{}"},"kv10.2:1.8":{"pli":"no ca vata re vattabbe—","html":"{}"},"kv10.2:1.9":{"pli":"“maggasamaṅgissa rūpaṁ maggo”ti. ","html":"{}</p>"},"kv10.2:2.1":{"pli":"Sammāvācā maggoti? ","html":"<p data-doxy='orthodox'>{}"},"kv10.2:2.2":{"pli":"Āmantā. ","html":"{}"},"kv10.2:2.3":{"pli":"Sārammaṇā, atthi tāya āvaṭṭanā …pe… paṇidhīti? ","html":"{}"},"kv10.2:2.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv10.2:2.5":{"pli":"nanu anārammaṇā, natthi tāya āvaṭṭanā …pe… paṇidhīti? ","html":"{}"},"kv10.2:2.6":{"pli":"Āmantā. ","html":"{}"},"kv10.2:2.7":{"pli":"Hañci anārammaṇā, natthi tāya āvaṭṭanā …pe… paṇidhi; ","html":"{}"},"kv10.2:2.8":{"pli":"no ca vata re vattabbe—","html":"{}"},"kv10.2:2.9":{"pli":"“sammāvācā maggo”ti. ","html":"{}</p>"},"kv10.2:3.1":{"pli":"Sammākammanto …pe… ","html":"<p data-doxy='orthodox'>{}"},"kv10.2:3.2":{"pli":"sammāājīvo maggoti? ","html":"{}"},"kv10.2:3.3":{"pli":"Āmantā. ","html":"{}"},"kv10.