{"ja529":{"ja529:0.1":{"pli":"Jātaka ","html":"<article id='ja529'><header><ul><li class='division'>{}</li>"},"ja529:0.2":{"pli":"Saṭṭhinipāta ","html":"<li>{}</li>"},"ja529:0.3":{"pli":"Soṇakavagga ","html":"<li>{}</li></ul>"},"ja529:0.4":{"pli":"1 Soṇakajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja529:1.1":{"pli":"“Tassa sutvā sataṁ dammi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja529:1.2":{"pli":"sahassaṁ diṭṭha soṇakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja529:1.3":{"pli":"Ko me soṇakamakkhāti, ","html":"<span class='verse-line'>{}</span>"},"ja529:1.4":{"pli":"sahāyaṁ paṁsukīḷitaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:2.1":{"pli":"“Athabravī māṇavako, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:2.2":{"pli":"daharo pañcacūḷako; ","html":"<span class='verse-line'>{}</span>"},"ja529:2.3":{"pli":"Mayhaṁ sutvā sataṁ dehi, ","html":"<span class='verse-line'>{}</span>"},"ja529:2.4":{"pli":"sahassaṁ diṭṭha soṇakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja529:2.5":{"pli":"Ahaṁ te soṇakakkhissaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja529:2.6":{"pli":"sahāyaṁ paṁsukīḷitaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:3.1":{"pli":"“Katamasmiṁ so janapade, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:3.2":{"pli":"raṭṭhesu nigamesu ca; ","html":"<span class='verse-line'>{}</span>"},"ja529:3.3":{"pli":"Kattha soṇakamaddakkhi, ","html":"<span class='verse-line'>{}</span>"},"ja529:3.4":{"pli":"taṁ me akkhāhi pucchito”. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:4.1":{"pli":"“Taveva deva vijite, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:4.2":{"pli":"tavevuyyānabhūmiyā; ","html":"<span class='verse-line'>{}</span>"},"ja529:4.3":{"pli":"Ujuvaṁsā mahāsālā, ","html":"<span class='verse-line'>{}</span>"},"ja529:4.4":{"pli":"nīlobhāsā manoramā. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:5.1":{"pli":"Tiṭṭhanti meghasamānā, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:5.2":{"pli":"rammā aññoññanissitā; ","html":"<span class='verse-line'>{}</span>"},"ja529:5.3":{"pli":"Tesaṁ mūlamhi soṇako, ","html":"<span class='verse-line'>{}</span>"},"ja529:5.4":{"pli":"jhāyatī anupādano; ","html":"<span class='verse-line'>{}</span>"},"ja529:5.5":{"pli":"Upādānesu lokesu, ","html":"<span class='verse-line'>{}</span>"},"ja529:5.6":{"pli":"ḍayhamānesu nibbuto”. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:6.1":{"pli":"Tato ca rājā pāyāsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:6.2":{"pli":"senāya caturaṅgiyā; ","html":"<span class='verse-line'>{}</span>"},"ja529:6.3":{"pli":"Kārāpetvā samaṁ maggaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja529:6.4":{"pli":"agamā yena soṇako. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:7.1":{"pli":"Uyyānabhūmiṁ gantvāna, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:7.2":{"pli":"vicaranto brahāvane; ","html":"<span class='verse-line'>{}</span>"},"ja529:7.3":{"pli":"Āsīnaṁ soṇakaṁ dakkhi, ","html":"<span class='verse-line'>{}</span>"},"ja529:7.4":{"pli":"ḍayhamānesu nibbutaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:8.1":{"pli":"“Kapaṇo vatayaṁ bhikkhu, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:8.2":{"pli":"muṇḍo saṅghāṭipāruto; ","html":"<span class='verse-line'>{}</span>"},"ja529:8.3":{"pli":"Amātiko apitiko, ","html":"<span class='verse-line'>{}</span>"},"ja529:8.4":{"pli":"rukkhamūlasmi jhāyati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:9.1":{"pli":"Imaṁ vākyaṁ nisāmetvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:9.2":{"pli":"Soṇako etadabravi; ","html":"<span class='verse-line'>{}</span>"},"ja529:9.3":{"pli":"“Na rāja kapaṇo hoti, ","html":"<span class='verse-line'>{}</span>"},"ja529:9.4":{"pli":"Dhammaṁ kāyena phassayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:10.1":{"pli":"Yo ca dhammaṁ niraṅkatvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:10.2":{"pli":"Adhammamanuvattati; ","html":"<span class='verse-line'>{}</span>"},"ja529:10.3":{"pli":"Sa rāja kapaṇo hoti, ","html":"<span class='verse-line'>{}</span>"},"ja529:10.4":{"pli":"Pāpo pāpaparāyaṇo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:11.1":{"pli":"“Arindamoti me nāmaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:11.2":{"pli":"kāsirājāti maṁ vidū; ","html":"<span class='verse-line'>{}</span>"},"ja529:11.3":{"pli":"Kacci bhoto sukhasseyyā, ","html":"<span class='verse-line'>{}</span>"},"ja529:11.4":{"pli":"idha pattassa soṇaka”. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:12.1":{"pli":"“Sadāpi bhadramadhanassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:12.2":{"pli":"Anāgārassa bhikkhuno; ","html":"<span class='verse-line'>{}</span>"},"ja529:12.3":{"pli":"Na tesaṁ koṭṭhe openti, ","html":"<span class='verse-line'>{}</span>"},"ja529:12.4":{"pli":"Na kumbhiṁ na khaḷopiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja529:12.5":{"pli":"Paraniṭṭhitamesānā, ","html":"<span class='verse-line'>{}</span>"},"ja529:12.6":{"pli":"Tena yāpenti subbatā. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:13.1":{"pli":"Dutiyampi bhadramadhanassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:13.2":{"pli":"Anāgārassa bhikkhuno; ","html":"<span class='verse-line'>{}</span>"},"ja529:13.3":{"pli":"Anavajjapiṇḍo bhottabbo, ","html":"<span class='verse-line'>{}</span>"},"ja529:13.4":{"pli":"Na ca kocūparodhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:14.1":{"pli":"Tatiyampi bhadramadhanassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:14.2":{"pli":"Anāgārassa bhikkhuno; ","html":"<span class='verse-line'>{}</span>"},"ja529:14.3":{"pli":"Nibbuto piṇḍo bhottabbo, ","html":"<span class='verse-line'>{}</span>"},"ja529:14.4":{"pli":"Na ca kocūparodhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:15.1":{"pli":"Catutthampi bhadramadhanassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:15.2":{"pli":"Anāgārassa bhikkhuno; ","html":"<span class='verse-line'>{}</span>"},"ja529:15.3":{"pli":"Muttassa raṭṭhe carato, ","html":"<span class='verse-line'>{}</span>"},"ja529:15.4":{"pli":"Saṅgo yassa na vijjati. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:16.1":{"pli":"Pañcamampi bhadramadhanassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:16.2":{"pli":"Anāgārassa bhikkhuno; ","html":"<span class='verse-line'>{}</span>"},"ja529:16.3":{"pli":"Nagaramhi ḍayhamānamhi, ","html":"<span class='verse-line'>{}</span>"},"ja529:16.4":{"pli":"Nāssa kiñci aḍayhatha. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:17.1":{"pli":"Chaṭṭhampi bhadramadhanassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:17.2":{"pli":"Anāgārassa bhikkhuno; ","html":"<span class='verse-line'>{}</span>"},"ja529:17.3":{"pli":"Raṭṭhe vilumpamānamhi, ","html":"<span class='verse-line'>{}</span>"},"ja529:17.4":{"pli":"Nāssa kiñci ahīratha. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:18.1":{"pli":"Sattamampi bhadramadhanassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:18.2":{"pli":"Anāgārassa bhikkhuno; ","html":"<span class='verse-line'>{}</span>"},"ja529:18.3":{"pli":"Corehi rakkhitaṁ maggaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja529:18.4":{"pli":"Ye caññe paripanthikā; ","html":"<span class='verse-line'>{}</span>"},"ja529:18.5":{"pli":"Pattacīvaramādāya, ","html":"<span class='verse-line'>{}</span>"},"ja529:18.6":{"pli":"Sotthiṁ gacchati subbato. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:19.1":{"pli":"Aṭṭhamampi bhadramadhanassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:19.2":{"pli":"Anāgārassa bhikkhuno; ","html":"<span class='verse-line'>{}</span>"},"ja529:19.3":{"pli":"Yaṁ yaṁ disaṁ pakkamati, ","html":"<span class='verse-line'>{}</span>"},"ja529:19.4":{"pli":"Anapekkhova gacchati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:20.1":{"pli":"“Bahūni samaṇabhadrāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:20.2":{"pli":"ye tvaṁ bhikkhu pasaṁsasi; ","html":"<span class='verse-line'>{}</span>"},"ja529:20.3":{"pli":"Ahañca giddho kāmesu, ","html":"<span class='verse-line'>{}</span>"},"ja529:20.4":{"pli":"kathaṁ kāhāmi soṇaka. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:21.1":{"pli":"Piyā me mānusā kāmā, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:21.2":{"pli":"atho dibyāpi me piyā; ","html":"<span class='verse-line'>{}</span>"},"ja529:21.3":{"pli":"Atha kena nu vaṇṇena, ","html":"<span class='verse-line'>{}</span>"},"ja529:21.4":{"pli":"ubho loke labhāmase”. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:22.1":{"pli":"“Kāme giddhā kāmaratā, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:22.2":{"pli":"kāmesu adhimucchitā; ","html":"<span class='verse-line'>{}</span>"},"ja529:22.3":{"pli":"Narā pāpāni katvāna, ","html":"<span class='verse-line'>{}</span>"},"ja529:22.4":{"pli":"upapajjanti duggatiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:23.1":{"pli":"Ye ca kāme pahantvāna, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:23.2":{"pli":"nikkhantā akutobhayā; ","html":"<span class='verse-line'>{}</span>"},"ja529:23.3":{"pli":"Ekodibhāvādhigatā, ","html":"<span class='verse-line'>{}</span>"},"ja529:23.4":{"pli":"na te gacchanti duggatiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:24.1":{"pli":"Upamaṁ te karissāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:24.2":{"pli":"taṁ suṇohi arindama; ","html":"<span class='verse-line'>{}</span>"},"ja529:24.3":{"pli":"Upamāya midhekacce, ","html":"<span class='verse-line'>{}</span>"},"ja529:24.4":{"pli":"atthaṁ jānanti paṇḍitā. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:25.1":{"pli":"Gaṅgāya kuṇapaṁ disvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:25.2":{"pli":"vuyhamānaṁ mahaṇṇave; ","html":"<span class='verse-line'>{}</span>"},"ja529:25.3":{"pli":"Vāyaso samacintesi, ","html":"<span class='verse-line'>{}</span>"},"ja529:25.4":{"pli":"appapañño acetaso. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:26.1":{"pli":"‘Yānañca vatidaṁ laddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:26.2":{"pli":"bhakkho cāyaṁ anappako’; ","html":"<span class='verse-line'>{}</span>"},"ja529:26.3":{"pli":"Tattha rattiṁ tattha divā, ","html":"<span class='verse-line'>{}</span>"},"ja529:26.4":{"pli":"tattheva nirato mano. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:27.1":{"pli":"Khādaṁ nāgassa maṁsāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:27.2":{"pli":"pivaṁ bhāgīrathodakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja529:27.3":{"pli":"Sampassaṁ vanacetyāni, ","html":"<span class='verse-line'>{}</span>"},"ja529:27.4":{"pli":"na palettha vihaṅgamo. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:28.1":{"pli":"Tañca otaraṇī gaṅgā, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:28.2":{"pli":"pamattaṁ kuṇape rataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja529:28.3":{"pli":"Samuddaṁ ajjhagāhāsi, ","html":"<span class='verse-line'>{}</span>"},"ja529:28.4":{"pli":"agatī yattha pakkhinaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:29.1":{"pli":"So ca bhakkhaparikkhīṇo, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:29.2":{"pli":"udapatvā vihaṅgamo; ","html":"<span class='verse-line'>{}</span>"},"ja529:29.3":{"pli":"Na pacchato na purato, ","html":"<span class='verse-line'>{}</span>"},"ja529:29.4":{"pli":"nuttaraṁ nopi dakkhiṇaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:30.1":{"pli":"Dīpaṁ so najjhagāgañchi, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:30.2":{"pli":"agatī yattha pakkhinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja529:30.3":{"pli":"So ca tattheva pāpattha, ","html":"<span class='verse-line'>{}</span>"},"ja529:30.4":{"pli":"yathā dubbalako tathā. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:31.1":{"pli":"Tañca sāmuddikā macchā, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:31.2":{"pli":"kumbhīlā makarā susū; ","html":"<span class='verse-line'>{}</span>"},"ja529:31.3":{"pli":"Pasayhakārā khādiṁsu, ","html":"<span class='verse-line'>{}</span>"},"ja529:31.4":{"pli":"phandamānaṁ vipakkhakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:32.1":{"pli":"Evameva tuvaṁ rāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:32.2":{"pli":"ye caññe kāmabhogino; ","html":"<span class='verse-line'>{}</span>"},"ja529:32.3":{"pli":"Giddhā ce na vamissanti, ","html":"<span class='verse-line'>{}</span>"},"ja529:32.4":{"pli":"kākapaññāva te vidū. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:33.1":{"pli":"Esā te upamā rāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:33.2":{"pli":"atthasandassanī katā; ","html":"<span class='verse-line'>{}</span>"},"ja529:33.3":{"pli":"Tvañca paññāyase tena, ","html":"<span class='verse-line'>{}</span>"},"ja529:33.4":{"pli":"yadi kāhasi vā na vā. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:34.1":{"pli":"Ekavācampi dvivācaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:34.2":{"pli":"bhaṇeyya anukampako; ","html":"<span class='verse-line'>{}</span>"},"ja529:34.3":{"pli":"Tatuttariṁ na bhāseyya, ","html":"<span class='verse-line'>{}</span>"},"ja529:34.4":{"pli":"dāsovayyassa santike”. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:35.1":{"pli":"Idaṁ vatvāna pakkāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:35.2":{"pli":"soṇako amitabuddhimā; ","html":"<span class='verse-line'>{}</span>"},"ja529:35.3":{"pli":"Vehāse antalikkhasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja529:35.4":{"pli":"anusāsitvāna khattiyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:36.1":{"pli":"“Ko nume rājakattāro, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:36.2":{"pli":"suddā veyyattamāgatā; ","html":"<span class='verse-line'>{}</span>"},"ja529:36.3":{"pli":"Rajjaṁ niyyādayissāmi, ","html":"<span class='verse-line'>{}</span>"},"ja529:36.4":{"pli":"nāhaṁ rajjena matthiko. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:37.1":{"pli":"Ajjeva pabbajissāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:37.2":{"pli":"Ko jaññā maraṇaṁ suve; ","html":"<span class='verse-line'>{}</span>"},"ja529:37.3":{"pli":"Māhaṁ kākova dummedho, ","html":"<span class='verse-line'>{}</span>"},"ja529:37.4":{"pli":"Kāmānaṁ vasamanvagaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:38.1":{"pli":"“Atthi te daharo putto, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:38.2":{"pli":"dīghāvu raṭṭhavaḍḍhano; ","html":"<span class='verse-line'>{}</span>"},"ja529:38.3":{"pli":"Taṁ rajje abhisiñcassu, ","html":"<span class='verse-line'>{}</span>"},"ja529:38.4":{"pli":"so no rājā bhavissati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:39.1":{"pli":"“Khippaṁ kumāramānetha, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:39.2":{"pli":"dīghāvuṁ raṭṭhavaḍḍhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja529:39.3":{"pli":"Taṁ rajje abhisiñcissaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja529:39.4":{"pli":"so vo rājā bhavissati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:40.1":{"pli":"Tato kumāramānesuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:40.2":{"pli":"dīghāvuṁ raṭṭhavaḍḍhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja529:40.3":{"pli":"Taṁ disvā ālapī rājā, ","html":"<span class='verse-line'>{}</span>"},"ja529:40.4":{"pli":"ekaputtaṁ manoramaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:41.1":{"pli":"“Saṭṭhi gāmasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:41.2":{"pli":"paripuṇṇāni sabbaso; ","html":"<span class='verse-line'>{}</span>"},"ja529:41.3":{"pli":"Te putta paṭipajjassu, ","html":"<span class='verse-line'>{}</span>"},"ja529:41.4":{"pli":"rajjaṁ niyyādayāmi te. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:42.1":{"pli":"Ajjeva pabbajissāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:42.2":{"pli":"ko jaññā maraṇaṁ suve; ","html":"<span class='verse-line'>{}</span>"},"ja529:42.3":{"pli":"Māhaṁ kākova dummedho, ","html":"<span class='verse-line'>{}</span>"},"ja529:42.4":{"pli":"kāmānaṁ vasamanvagaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:43.1":{"pli":"Saṭṭhi nāgasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:43.2":{"pli":"sabbālaṅkārabhūsitā; ","html":"<span class='verse-line'>{}</span>"},"ja529:43.3":{"pli":"Suvaṇṇakacchā mātaṅgā, ","html":"<span class='verse-line'>{}</span>"},"ja529:43.4":{"pli":"hemakappanavāsasā. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:44.1":{"pli":"Ārūḷhā gāmaṇīyehi, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:44.2":{"pli":"tomaraṅkusapāṇibhi; ","html":"<span class='verse-line'>{}</span>"},"ja529:44.3":{"pli":"Te putta paṭipajjassu, ","html":"<span class='verse-line'>{}</span>"},"ja529:44.4":{"pli":"rajjaṁ niyyādayāmi te. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:45.1":{"pli":"Ajjeva pabbajissāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:45.2":{"pli":"ko jaññā maraṇaṁ suve; ","html":"<span class='verse-line'>{}</span>"},"ja529:45.3":{"pli":"Māhaṁ kākova dummedho, ","html":"<span class='verse-line'>{}</span>"},"ja529:45.4":{"pli":"kāmānaṁ vasamanvagaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:46.1":{"pli":"Saṭṭhi assasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:46.2":{"pli":"sabbālaṅkārabhūsitā; ","html":"<span class='verse-line'>{}</span>"},"ja529:46.3":{"pli":"Ājānīyāva jātiyā, ","html":"<span class='verse-line'>{}</span>"},"ja529:46.4":{"pli":"sindhavā sīghavāhino. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:47.1":{"pli":"Ārūḷhā gāmaṇīyehi, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:47.2":{"pli":"illiyācāpadhāribhi; ","html":"<span class='verse-line'>{}</span>"},"ja529:47.3":{"pli":"Te putta paṭipajjassu, ","html":"<span class='verse-line'>{}</span>"},"ja529:47.4":{"pli":"rajjaṁ niyyādayāmi te. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:48.1":{"pli":"Ajjeva pabbajissāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:48.2":{"pli":"ko jaññā maraṇaṁ suve; ","html":"<span class='verse-line'>{}</span>"},"ja529:48.3":{"pli":"Māhaṁ kākova dummedho, ","html":"<span class='verse-line'>{}</span>"},"ja529:48.4":{"pli":"kāmānaṁ vasamanvagaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:49.1":{"pli":"Saṭṭhi rathasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:49.2":{"pli":"sannaddhā ussitaddhajā; ","html":"<span class='verse-line'>{}</span>"},"ja529:49.3":{"pli":"Dīpā athopi veyyagghā, ","html":"<span class='verse-line'>{}</span>"},"ja529:49.4":{"pli":"sabbālaṅkārabhūsitā. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:50.1":{"pli":"Ārūḷhā gāmaṇīyehi, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:50.2":{"pli":"cāpahatthehi vammibhi; ","html":"<span class='verse-line'>{}</span>"},"ja529:50.3":{"pli":"Te putta paṭipajjassu, ","html":"<span class='verse-line'>{}</span>"},"ja529:50.4":{"pli":"rajjaṁ niyyādayāmi te. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:51.1":{"pli":"Ajjeva pabbajissāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:51.2":{"pli":"ko jaññā maraṇaṁ suve; ","html":"<span class='verse-line'>{}</span>"},"ja529:51.3":{"pli":"Māhaṁ kākova dummedho, ","html":"<span class='verse-line'>{}</span>"},"ja529:51.4":{"pli":"kāmānaṁ vasamanvagaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:52.1":{"pli":"Saṭṭhi dhenusahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:52.2":{"pli":"rohaññā puṅgavūsabhā; ","html":"<span class='verse-line'>{}</span>"},"ja529:52.3":{"pli":"Tā putta paṭipajjassu, ","html":"<span class='verse-line'>{}</span>"},"ja529:52.4":{"pli":"rajjaṁ niyyādayāmi te. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:53.1":{"pli":"Ajjeva pabbajissāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:53.2":{"pli":"ko jaññā maraṇaṁ suve; ","html":"<span class='verse-line'>{}</span>"},"ja529:53.3":{"pli":"Māhaṁ kākova dummedho, ","html":"<span class='verse-line'>{}</span>"},"ja529:53.4":{"pli":"kāmānaṁ vasamanvagaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:54.1":{"pli":"Soḷasitthisahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:54.2":{"pli":"sabbālaṅkārabhūsitā; ","html":"<span class='verse-line'>{}</span>"},"ja529:54.3":{"pli":"Vicitravatthābharaṇā, ","html":"<span class='verse-line'>{}</span>"},"ja529:54.4":{"pli":"āmuttamaṇikuṇḍalā; ","html":"<span class='verse-line'>{}</span>"},"ja529:54.5":{"pli":"Tā putta paṭipajjassu, ","html":"<span class='verse-line'>{}</span>"},"ja529:54.6":{"pli":"rajjaṁ niyyādayāmi te. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:55.1":{"pli":"Ajjeva pabbajissāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:55.2":{"pli":"ko jaññā maraṇaṁ suve; ","html":"<span class='verse-line'>{}</span>"},"ja529:55.3":{"pli":"Māhaṁ kākova dummedho, ","html":"<span class='verse-line'>{}</span>"},"ja529:55.4":{"pli":"kāmānaṁ vasamanvagaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:56.1":{"pli":"“Daharasseva me tāta, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:56.2":{"pli":"mātā matāti me sutaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja529:56.3":{"pli":"Tayā vinā ahaṁ tāta, ","html":"<span class='verse-line'>{}</span>"},"ja529:56.4":{"pli":"jīvitumpi na ussahe. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:57.1":{"pli":"Yathā āraññakaṁ nāgaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:57.2":{"pli":"poto anveti pacchato; ","html":"<span class='verse-line'>{}</span>"},"ja529:57.3":{"pli":"Jessantaṁ giriduggesu, ","html":"<span class='verse-line'>{}</span>"},"ja529:57.4":{"pli":"samesu visamesu ca. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:58.1":{"pli":"Evaṁ taṁ anugacchāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:58.2":{"pli":"pattamādāya pacchato; ","html":"<span class='verse-line'>{}</span>"},"ja529:58.3":{"pli":"Subharo te bhavissāmi, ","html":"<span class='verse-line'>{}</span>"},"ja529:58.4":{"pli":"na te hessāmi dubbharo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:59.1":{"pli":"“Yathā sāmuddikaṁ nāvaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:59.2":{"pli":"vāṇijānaṁ dhanesinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja529:59.3":{"pli":"Vohāro tattha gaṇheyya, ","html":"<span class='verse-line'>{}</span>"},"ja529:59.4":{"pli":"vāṇijā byasanī siyā. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:60.1":{"pli":"Evamevāyaṁ puttakali, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:60.2":{"pli":"antarāyakaro mama; ","html":"<span class='verse-line'>{}</span>"},"ja529:60.3":{"pli":"Imaṁ kumāraṁ pāpetha, ","html":"<span class='verse-line'>{}</span>"},"ja529:60.4":{"pli":"pāsādaṁ rativaḍḍhanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:61.1":{"pli":"Tattha kambusahatthāyo, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:61.2":{"pli":"yathā sakkaṁva accharā; ","html":"<span class='verse-line'>{}</span>"},"ja529:61.3":{"pli":"Tā naṁ tattha ramessanti, ","html":"<span class='verse-line'>{}</span>"},"ja529:61.4":{"pli":"tāhi ceso ramissati. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:62.1":{"pli":"Tato kumāraṁ pāpesuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:62.2":{"pli":"pāsādaṁ rativaḍḍhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja529:62.3":{"pli":"Taṁ disvā avacuṁ kaññā, ","html":"<span class='verse-line'>{}</span>"},"ja529:62.4":{"pli":"dīghāvuṁ raṭṭhavaḍḍhanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:63.1":{"pli":"Devatā nusi gandhabbo, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:63.2":{"pli":"adu sakko purindado; ","html":"<span class='verse-line'>{}</span>"},"ja529:63.3":{"pli":"Ko vā tvaṁ kassa vā putto, ","html":"<span class='verse-line'>{}</span>"},"ja529:63.4":{"pli":"kathaṁ jānemu taṁ mayaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:64.1":{"pli":"“Namhi devo na gandhabbo, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:64.2":{"pli":"Nāpi sakko purindado; ","html":"<span class='verse-line'>{}</span>"},"ja529:64.3":{"pli":"Kāsirañño ahaṁ putto, ","html":"<span class='verse-line'>{}</span>"},"ja529:64.4":{"pli":"Dīghāvu raṭṭhavaḍḍhano; ","html":"<span class='verse-line'>{}</span>"},"ja529:64.5":{"pli":"Mamaṁ bharatha bhaddaṁ vo, ","html":"<span class='verse-line'>{}</span>"},"ja529:64.6":{"pli":"Ahaṁ bhattā bhavāmi vo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:65.1":{"pli":"Taṁ tattha avacuṁ kaññā, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:65.2":{"pli":"dīghāvuṁ raṭṭhavaḍḍhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja529:65.3":{"pli":"“Kuhiṁ rājā anuppatto, ","html":"<span class='verse-line'>{}</span>"},"ja529:65.4":{"pli":"ito rājā kuhiṁ gato”. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:66.1":{"pli":"“Paṅkaṁ rājā atikkanto, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:66.2":{"pli":"thale rājā patiṭṭhito; ","html":"<span class='verse-line'>{}</span>"},"ja529:66.3":{"pli":"Akaṇṭakaṁ agahanaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja529:66.4":{"pli":"paṭipanno mahāpathaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:67.1":{"pli":"Ahañca paṭipannosmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:67.2":{"pli":"maggaṁ duggatigāminaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja529:67.3":{"pli":"Sakaṇṭakaṁ sagahanaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja529:67.4":{"pli":"yena gacchanti duggatiṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja529:68.1":{"pli":"“Tassa te svāgataṁ rāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja529:68.2":{"pli":"sīhasseva giribbajaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja529:68.3":{"pli":"Anusāsa mahārāja, ","html":"<span class='verse-line'>{}</span>"},"ja529:68.4":{"pli":"tvaṁ no sabbāsamissaro”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja529:69.1":{"pli":"Soṇakajātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja53":{"ja53:0.1":{"pli":"Jātaka ","eng":"Stories of Past Lives 53 ","html":"<article id='ja53'><header><ul><li class='division'>{}</li>"},"ja53:0.2":{"pli":"Ekakanipāta ","eng":"The Book of the Ones ","html":"<li>{}</li>"},"ja53:0.3":{"pli":"Āsīsavagga ","eng":"Hope ","html":"<li>{}</li></ul>"},"ja53:0.4":{"pli":"3. Puṇṇapātijātaka ","eng":"The Full Cups: a past life story ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja53:1.1":{"pli":"“Tatheva puṇṇā pātiyo, ","eng":"The cups stay just as full, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>","comm":"Rogues attempt to spike a rich man’s drink with a drug (<i lang='pi' translate='no'>bhesajja</i>) so they can rob him. But he sees that they do not touch their own drinks. "},"ja53:1.2":{"pli":"aññāyaṁ vattate kathā; ","eng":"while the ignorant talk goes on. ","html":"<span class='verse-line'>{}</span>","comm":"Resolve <i lang='pi' translate='no'>aññāyaṁ</i> to <i lang='pi' translate='no'>aññā</i> + <i lang='pi' translate='no'>ayaṁ</i>, where <i lang='pi' translate='no'>aññā</i> (“unknowing”) is an adjective agreeing with <i lang='pi' translate='no'>kathā</i> (“talk”). "},"ja53:1.3":{"pli":"Ākāraṇena jānāmi, ","eng":"For this reason I know ","html":"<span class='verse-line'>{}</span>"},"ja53:1.4":{"pli":"na cāyaṁ bhaddikā surā”ti. ","eng":"this is not an excellent beer. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja53:2.1":{"pli":"Puṇṇapātijātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}