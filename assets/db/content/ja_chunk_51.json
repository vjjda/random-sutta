{"ja540":{"ja540:0.1":{"pli":"Jātaka ","html":"<article id='ja540'><header><ul><li class='division'>{}</li>"},"ja540:0.2":{"pli":"Mahānipāta ","html":"<li>{}</li>"},"ja540:0.3":{"pli":"Mūgapakkhavagga ","html":"<li>{}</li></ul>"},"ja540:0.4":{"pli":"3 Suvaṇṇasāmajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja540:1.1":{"pli":"“Ko nu maṁ usunā vijjhi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja540:1.2":{"pli":"pamattaṁ udahārakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja540:1.3":{"pli":"Khattiyo brāhmaṇo vesso, ","html":"<span class='verse-line'>{}</span>"},"ja540:1.4":{"pli":"ko maṁ viddhā nilīyasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:2.1":{"pli":"Na me maṁsāni khajjāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:2.2":{"pli":"Cammenattho na vijjati; ","html":"<span class='verse-line'>{}</span>"},"ja540:2.3":{"pli":"Atha kena nu vaṇṇena, ","html":"<span class='verse-line'>{}</span>"},"ja540:2.4":{"pli":"Viddheyyaṁ maṁ amaññatha. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:3.1":{"pli":"Ko vā tvaṁ kassa vā putto, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:3.2":{"pli":"kathaṁ jānemu taṁ mayaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja540:3.3":{"pli":"Puṭṭho me samma akkhāhi, ","html":"<span class='verse-line'>{}</span>"},"ja540:3.4":{"pli":"kiṁ maṁ viddhā nilīyasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:4.1":{"pli":"“Rājāhamasmi kāsīnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:4.2":{"pli":"pīḷiyakkhoti maṁ vidū; ","html":"<span class='verse-line'>{}</span>"},"ja540:4.3":{"pli":"Lobhā raṭṭhaṁ pahitvāna, ","html":"<span class='verse-line'>{}</span>"},"ja540:4.4":{"pli":"migamesaṁ carāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:5.1":{"pli":"Issatthe casmi kusalo, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:5.2":{"pli":"daḷhadhammoti vissuto; ","html":"<span class='verse-line'>{}</span>"},"ja540:5.3":{"pli":"Nāgopi me na mucceyya, ","html":"<span class='verse-line'>{}</span>"},"ja540:5.4":{"pli":"āgato usupātanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:6.1":{"pli":"Ko vā tvaṁ kassa vā putto, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:6.2":{"pli":"kathaṁ jānemu taṁ mayaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja540:6.3":{"pli":"Pituno attano cāpi, ","html":"<span class='verse-line'>{}</span>"},"ja540:6.4":{"pli":"nāmagottaṁ pavedaya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:7.1":{"pli":"“Nesādaputto bhaddante, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:7.2":{"pli":"sāmo iti maṁ ñātayo; ","html":"<span class='verse-line'>{}</span>"},"ja540:7.3":{"pli":"Āmantayiṁsu jīvantaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja540:7.4":{"pli":"svajjevāhaṁ gato saye. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:8.1":{"pli":"Viddhosmi puthusallena, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:8.2":{"pli":"savisena yathā migo; ","html":"<span class='verse-line'>{}</span>"},"ja540:8.3":{"pli":"Sakamhi lohite rāja, ","html":"<span class='verse-line'>{}</span>"},"ja540:8.4":{"pli":"passa semi paripluto. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:9.1":{"pli":"Paṭivāmagataṁ sallaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:9.2":{"pli":"passa dhimhāmi lohitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja540:9.3":{"pli":"Āturo tyānupucchāmi, ","html":"<span class='verse-line'>{}</span>"},"ja540:9.4":{"pli":"kiṁ maṁ viddhā nilīyasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:10.1":{"pli":"Ajinamhi haññate dīpi, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:10.2":{"pli":"nāgo dantehi haññate; ","html":"<span class='verse-line'>{}</span>"},"ja540:10.3":{"pli":"Atha kena nu vaṇṇena, ","html":"<span class='verse-line'>{}</span>"},"ja540:10.4":{"pli":"viddheyyaṁ maṁ amaññatha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:11.1":{"pli":"“Migo upaṭṭhito āsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:11.2":{"pli":"āgato usupātanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja540:11.3":{"pli":"Taṁ disvā ubbijī sāma, ","html":"<span class='verse-line'>{}</span>"},"ja540:11.4":{"pli":"tena kodho mamāvisi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:12.1":{"pli":"“Yato sarāmi attānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:12.2":{"pli":"yato pattosmi viññutaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja540:12.3":{"pli":"Na maṁ migā uttasanti, ","html":"<span class='verse-line'>{}</span>"},"ja540:12.4":{"pli":"araññe sāpadānipi. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:13.1":{"pli":"Yato nidhiṁ parihariṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:13.2":{"pli":"yato pattosmi yobbanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja540:13.3":{"pli":"Na maṁ migā uttasanti, ","html":"<span class='verse-line'>{}</span>"},"ja540:13.4":{"pli":"araññe sāpadānipi. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:14.1":{"pli":"Bhīrū kimpurisā rāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:14.2":{"pli":"pabbate gandhamādane; ","html":"<span class='verse-line'>{}</span>"},"ja540:14.3":{"pli":"Sammodamānā gacchāma, ","html":"<span class='verse-line'>{}</span>"},"ja540:14.4":{"pli":"pabbatāni vanāni ca. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:15.1":{"pli":"Na maṁ migā uttasanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:15.2":{"pli":"araññe sāpadānipi; ","html":"<span class='verse-line'>{}</span>"},"ja540:15.3":{"pli":"Atha kena nu vaṇṇena, ","html":"<span class='verse-line'>{}</span>"},"ja540:15.4":{"pli":"utrāsanti migā mamaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:16.1":{"pli":"“Na taṁ tasa migo sāma, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:16.2":{"pli":"kiṁ tāhaṁ alikaṁ bhaṇe; ","html":"<span class='verse-line'>{}</span>"},"ja540:16.3":{"pli":"Kodhalobhābhibhūtāhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja540:16.4":{"pli":"usuṁ te taṁ avassajiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:17.1":{"pli":"Kuto nu sāma āgamma, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:17.2":{"pli":"kassa vā pahito tuvaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja540:17.3":{"pli":"Udahāro nadiṁ gaccha, ","html":"<span class='verse-line'>{}</span>"},"ja540:17.4":{"pli":"āgato migasammataṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:18.1":{"pli":"“Andhā mātāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:18.2":{"pli":"te bharāmi brahāvane; ","html":"<span class='verse-line'>{}</span>"},"ja540:18.3":{"pli":"Tesāhaṁ udakāhāro, ","html":"<span class='verse-line'>{}</span>"},"ja540:18.4":{"pli":"āgato migasammataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:19.1":{"pli":"Atthi nesaṁ usāmattaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:19.2":{"pli":"atha sāhassa jīvitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja540:19.3":{"pli":"Udakassa alābhena, ","html":"<span class='verse-line'>{}</span>"},"ja540:19.4":{"pli":"maññe andhā marissare. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:20.1":{"pli":"Na me idaṁ tathā dukkhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:20.2":{"pli":"labbhā hi pumunā idaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja540:20.3":{"pli":"Yañca ammaṁ na passāmi, ","html":"<span class='verse-line'>{}</span>"},"ja540:20.4":{"pli":"taṁ me dukkhataraṁ ito. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:21.1":{"pli":"Na me idaṁ tathā dukkhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:21.2":{"pli":"labbhā hi pumunā idaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja540:21.3":{"pli":"Yañca tātaṁ na passāmi, ","html":"<span class='verse-line'>{}</span>"},"ja540:21.4":{"pli":"taṁ me dukkhataraṁ ito. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:22.1":{"pli":"Sā nūna kapaṇā ammā, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:22.2":{"pli":"cirarattāya rucchati; ","html":"<span class='verse-line'>{}</span>"},"ja540:22.3":{"pli":"Aḍḍharatte va ratte vā, ","html":"<span class='verse-line'>{}</span>"},"ja540:22.4":{"pli":"nadīva avasucchati. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:23.1":{"pli":"So nūna kapaṇo tāto, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:23.2":{"pli":"cirarattāya rucchati; ","html":"<span class='verse-line'>{}</span>"},"ja540:23.3":{"pli":"Aḍḍharatte va ratte vā, ","html":"<span class='verse-line'>{}</span>"},"ja540:23.4":{"pli":"nadīva avasucchati. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:24.1":{"pli":"Uṭṭhānapādacariyāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:24.2":{"pli":"pādasambāhanassa ca; ","html":"<span class='verse-line'>{}</span>"},"ja540:24.3":{"pli":"Sāma tāta vilapantā, ","html":"<span class='verse-line'>{}</span>"},"ja540:24.4":{"pli":"hiṇḍissanti brahāvane. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:25.1":{"pli":"Idampi dutiyaṁ sallaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:25.2":{"pli":"kampeti hadayaṁ mamaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja540:25.3":{"pli":"Yañca andhe na passāmi, ","html":"<span class='verse-line'>{}</span>"},"ja540:25.4":{"pli":"maññe hissāmi jīvitaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:26.1":{"pli":"“Mā bāḷhaṁ paridevesi, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:26.2":{"pli":"sāma kalyāṇadassana; ","html":"<span class='verse-line'>{}</span>"},"ja540:26.3":{"pli":"Ahaṁ kammakaro hutvā, ","html":"<span class='verse-line'>{}</span>"},"ja540:26.4":{"pli":"bharissaṁ te brahāvane. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:27.1":{"pli":"Issatthe casmi kusalo, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:27.2":{"pli":"daḷhadhammoti vissuto; ","html":"<span class='verse-line'>{}</span>"},"ja540:27.3":{"pli":"Ahaṁ kammakaro hutvā, ","html":"<span class='verse-line'>{}</span>"},"ja540:27.4":{"pli":"bharissaṁ te brahāvane. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:28.1":{"pli":"Migānaṁ vighāsamanvesaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:28.2":{"pli":"Vanamūlaphalāni ca; ","html":"<span class='verse-line'>{}</span>"},"ja540:28.3":{"pli":"Ahaṁ kammakaro hutvā, ","html":"<span class='verse-line'>{}</span>"},"ja540:28.4":{"pli":"Bharissaṁ te brahāvane. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:29.1":{"pli":"Katamaṁ taṁ vanaṁ sāma, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:29.2":{"pli":"yattha mātāpitā tava; ","html":"<span class='verse-line'>{}</span>"},"ja540:29.3":{"pli":"Ahaṁ te tathā bharissaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja540:29.4":{"pli":"yathā te abharī tuvaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:30.1":{"pli":"“Ayaṁ ekapadī rāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:30.2":{"pli":"yoyaṁ ussīsake mama; ","html":"<span class='verse-line'>{}</span>"},"ja540:30.3":{"pli":"Ito gantvā aḍḍhakosaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja540:30.4":{"pli":"tattha nesaṁ agārakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja540:30.5":{"pli":"Yattha mātāpitā mayhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja540:30.6":{"pli":"te bharassu ito gato. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:31.1":{"pli":"Namo te kāsirājatthu, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:31.2":{"pli":"namo te kāsivaḍḍhana; ","html":"<span class='verse-line'>{}</span>"},"ja540:31.3":{"pli":"Andhā mātāpitā mayhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja540:31.4":{"pli":"te bharassu brahāvane. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:32.1":{"pli":"Añjaliṁ te paggaṇhāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:32.2":{"pli":"kāsirāja namatthu te; ","html":"<span class='verse-line'>{}</span>"},"ja540:32.3":{"pli":"Mātaraṁ pitaraṁ mayhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja540:32.4":{"pli":"vutto vajjāsi vandanaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:33.1":{"pli":"Idaṁ vatvāna so sāmo, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:33.2":{"pli":"yuvā kalyāṇadassano; ","html":"<span class='verse-line'>{}</span>"},"ja540:33.3":{"pli":"Mucchito visavegena, ","html":"<span class='verse-line'>{}</span>"},"ja540:33.4":{"pli":"visaññī samapajjatha. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:34.1":{"pli":"Sa rājā paridevesi, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:34.2":{"pli":"bahuṁ kāruññasañhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja540:34.3":{"pli":"“Ajarāmarohaṁ āsiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja540:34.4":{"pli":"ajjetaṁ ñāmi no pure; ","html":"<span class='verse-line'>{}</span>"},"ja540:34.5":{"pli":"Sāmaṁ kālaṅkataṁ disvā, ","html":"<span class='verse-line'>{}</span>"},"ja540:34.6":{"pli":"natthi maccussa nāgamo. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:35.1":{"pli":"Yassu maṁ paṭimanteti, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:35.2":{"pli":"savisena samappito; ","html":"<span class='verse-line'>{}</span>"},"ja540:35.3":{"pli":"Svajja evaṁ gate kāle, ","html":"<span class='verse-line'>{}</span>"},"ja540:35.4":{"pli":"na kiñci mabhibhāsati. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:36.1":{"pli":"Nirayaṁ nūna gacchāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:36.2":{"pli":"ettha me natthi saṁsayo; ","html":"<span class='verse-line'>{}</span>"},"ja540:36.3":{"pli":"Tadā hi pakataṁ pāpaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja540:36.4":{"pli":"cirarattāya kibbisaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:37.1":{"pli":"Bhavanti tassa vattāro, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:37.2":{"pli":"gāme kibbisakārako; ","html":"<span class='verse-line'>{}</span>"},"ja540:37.3":{"pli":"Araññe nimmanussamhi, ","html":"<span class='verse-line'>{}</span>"},"ja540:37.4":{"pli":"ko maṁ vattumarahati. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:38.1":{"pli":"Sārayanti hi kammāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:38.2":{"pli":"gāme saṅgaccha māṇavā; ","html":"<span class='verse-line'>{}</span>"},"ja540:38.3":{"pli":"Araññe nimmanussamhi, ","html":"<span class='verse-line'>{}</span>"},"ja540:38.4":{"pli":"ko nu maṁ sārayissati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:39.1":{"pli":"Sā devatā antarahitā, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:39.2":{"pli":"pabbate gandhamādane; ","html":"<span class='verse-line'>{}</span>"},"ja540:39.3":{"pli":"Raññova anukampāya, ","html":"<span class='verse-line'>{}</span>"},"ja540:39.4":{"pli":"imā gāthā abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:40.1":{"pli":"“Āguṁ kira mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:40.2":{"pli":"akari kamma dukkaṭaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja540:40.3":{"pli":"Adūsakā pitāputtā, ","html":"<span class='verse-line'>{}</span>"},"ja540:40.4":{"pli":"tayo ekūsunā hatā. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:41.1":{"pli":"Ehi taṁ anusikkhāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:41.2":{"pli":"yathā te sugatī siyā; ","html":"<span class='verse-line'>{}</span>"},"ja540:41.3":{"pli":"Dhammenandhe vane posa, ","html":"<span class='verse-line'>{}</span>"},"ja540:41.4":{"pli":"maññehaṁ sugatī tayā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:42.1":{"pli":"Sa rājā paridevitvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:42.2":{"pli":"bahuṁ kāruññasañhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja540:42.3":{"pli":"Udakakumbhamādāya, ","html":"<span class='verse-line'>{}</span>"},"ja540:42.4":{"pli":"pakkāmi dakkhiṇāmukho. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:43.1":{"pli":"“Kassa nu eso padasaddo, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:43.2":{"pli":"manussasseva āgato; ","html":"<span class='verse-line'>{}</span>"},"ja540:43.3":{"pli":"Neso sāmassa nigghoso, ","html":"<span class='verse-line'>{}</span>"},"ja540:43.4":{"pli":"ko nu tvamasi mārisa. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:44.1":{"pli":"Santañhi sāmo vajati, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:44.2":{"pli":"santaṁ pādāni neyati; ","html":"<span class='verse-line'>{}</span>"},"ja540:44.3":{"pli":"Neso sāmassa nigghoso, ","html":"<span class='verse-line'>{}</span>"},"ja540:44.4":{"pli":"ko nu tvamasi mārisa”. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:45.1":{"pli":"“Rājāhamasmi kāsīnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:45.2":{"pli":"pīḷiyakkhoti maṁ vidū; ","html":"<span class='verse-line'>{}</span>"},"ja540:45.3":{"pli":"Lobhā raṭṭhaṁ pahitvāna, ","html":"<span class='verse-line'>{}</span>"},"ja540:45.4":{"pli":"migamesaṁ carāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:46.1":{"pli":"Issatthe casmi kusalo, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:46.2":{"pli":"daḷhadhammoti vissuto; ","html":"<span class='verse-line'>{}</span>"},"ja540:46.3":{"pli":"Nāgopi me na mucceyya, ","html":"<span class='verse-line'>{}</span>"},"ja540:46.4":{"pli":"āgato usupātanaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:47.1":{"pli":"“Svāgataṁ te mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:47.2":{"pli":"atho te adurāgataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja540:47.3":{"pli":"Issarosi anuppatto, ","html":"<span class='verse-line'>{}</span>"},"ja540:47.4":{"pli":"yaṁ idhatthi pavedaya. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:48.1":{"pli":"Tindukāni piyālāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:48.2":{"pli":"madhuke kāsumāriyo; ","html":"<span class='verse-line'>{}</span>"},"ja540:48.3":{"pli":"Phalāni khuddakappāni, ","html":"<span class='verse-line'>{}</span>"},"ja540:48.4":{"pli":"bhuñja rāja varaṁ varaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:49.1":{"pli":"Idampi pānīyaṁ sītaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:49.2":{"pli":"ābhataṁ girigabbharā; ","html":"<span class='verse-line'>{}</span>"},"ja540:49.3":{"pli":"Tato piva mahārāja, ","html":"<span class='verse-line'>{}</span>"},"ja540:49.4":{"pli":"sace tvaṁ abhikaṅkhasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:50.1":{"pli":"“Nālaṁ andhā vane daṭṭhuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:50.2":{"pli":"ko nu vo phalamāhari; ","html":"<span class='verse-line'>{}</span>"},"ja540:50.3":{"pli":"Anandhassevayaṁ sammā, ","html":"<span class='verse-line'>{}</span>"},"ja540:50.4":{"pli":"nivāpo mayha khāyati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:51.1":{"pli":"“Daharo yuvā nātibrahā, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:51.2":{"pli":"sāmo kalyāṇadassano; ","html":"<span class='verse-line'>{}</span>"},"ja540:51.3":{"pli":"Dīghassa kesā asitā, ","html":"<span class='verse-line'>{}</span>"},"ja540:51.4":{"pli":"atho sūnaggavellitā. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:52.1":{"pli":"So have phalamāharitvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:52.2":{"pli":"ito ādāya kamaṇḍaluṁ; ","html":"<span class='verse-line'>{}</span>"},"ja540:52.3":{"pli":"Nadiṁ gato udahāro, ","html":"<span class='verse-line'>{}</span>"},"ja540:52.4":{"pli":"maññe na dūramāgato”. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:53.1":{"pli":"“Ahaṁ taṁ avadhiṁ sāmaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:53.2":{"pli":"yo tuyhaṁ paricārako; ","html":"<span class='verse-line'>{}</span>"},"ja540:53.3":{"pli":"Yaṁ kumāraṁ pavedetha, ","html":"<span class='verse-line'>{}</span>"},"ja540:53.4":{"pli":"sāmaṁ kalyāṇadassanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:54.1":{"pli":"Dīghassa kesā asitā, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:54.2":{"pli":"atho sūnaggavellitā; ","html":"<span class='verse-line'>{}</span>"},"ja540:54.3":{"pli":"Tesu lohitalittesu, ","html":"<span class='verse-line'>{}</span>"},"ja540:54.4":{"pli":"seti sāmo mayā hato”. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:55.1":{"pli":"“Kena dukūla mantesi, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:55.2":{"pli":"hato sāmoti vādinā; ","html":"<span class='verse-line'>{}</span>"},"ja540:55.3":{"pli":"Hato sāmoti sutvāna, ","html":"<span class='verse-line'>{}</span>"},"ja540:55.4":{"pli":"hadayaṁ me pavedhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:56.1":{"pli":"Assatthasseva taruṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:56.2":{"pli":"pavāḷaṁ māluteritaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja540:56.3":{"pli":"Hato sāmoti sutvāna, ","html":"<span class='verse-line'>{}</span>"},"ja540:56.4":{"pli":"hadayaṁ me pavedhati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:57.1":{"pli":"“Pārike kāsirājāyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:57.2":{"pli":"so sāmaṁ migasammate; ","html":"<span class='verse-line'>{}</span>"},"ja540:57.3":{"pli":"Kodhasā usunā vijjhi, ","html":"<span class='verse-line'>{}</span>"},"ja540:57.4":{"pli":"tassa mā pāpamicchimhā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:58.1":{"pli":"“Kicchā laddho piyo putto, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:58.2":{"pli":"yo andhe abharī vane; ","html":"<span class='verse-line'>{}</span>"},"ja540:58.3":{"pli":"Taṁ ekaputtaṁ ghātimhi, ","html":"<span class='verse-line'>{}</span>"},"ja540:58.4":{"pli":"kathaṁ cittaṁ na kopaye”. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:59.1":{"pli":"“Kicchā laddho piyo putto, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:59.2":{"pli":"yo andhe abharī vane; ","html":"<span class='verse-line'>{}</span>"},"ja540:59.3":{"pli":"Taṁ ekaputtaṁ ghātimhi, ","html":"<span class='verse-line'>{}</span>"},"ja540:59.4":{"pli":"akkodhaṁ āhu paṇḍitā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:60.1":{"pli":"“Mā bāḷhaṁ paridevetha, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:60.2":{"pli":"hato sāmoti vādinā; ","html":"<span class='verse-line'>{}</span>"},"ja540:60.3":{"pli":"Ahaṁ kammakaro hutvā, ","html":"<span class='verse-line'>{}</span>"},"ja540:60.4":{"pli":"bharissāmi brahāvane. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:61.1":{"pli":"Issatthe casmi kusalo, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:61.2":{"pli":"daḷhadhammoti vissuto; ","html":"<span class='verse-line'>{}</span>"},"ja540:61.3":{"pli":"Ahaṁ kammakaro hutvā, ","html":"<span class='verse-line'>{}</span>"},"ja540:61.4":{"pli":"bharissāmi brahāvane. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:62.1":{"pli":"Migānaṁ vighāsamanvesaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:62.2":{"pli":"vanamūlaphalāni ca; ","html":"<span class='verse-line'>{}</span>"},"ja540:62.3":{"pli":"Ahaṁ kammakaro hutvā, ","html":"<span class='verse-line'>{}</span>"},"ja540:62.4":{"pli":"bharissāmi brahāvane”. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:63.1":{"pli":"“Nesa dhammo mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:63.2":{"pli":"netaṁ amhesu kappati; ","html":"<span class='verse-line'>{}</span>"},"ja540:63.3":{"pli":"Rājā tvamasi amhākaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja540:63.4":{"pli":"pāde vandāma te mayaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:64.1":{"pli":"“Dhammaṁ nesādā bhaṇatha, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:64.2":{"pli":"katā apacitī tayā; ","html":"<span class='verse-line'>{}</span>"},"ja540:64.3":{"pli":"Pitā tvamasi amhākaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja540:64.4":{"pli":"mātā tvamasi pārike”. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:65.1":{"pli":"“Namo te kāsirājatthu, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:65.2":{"pli":"namo te kāsivaḍḍhana; ","html":"<span class='verse-line'>{}</span>"},"ja540:65.3":{"pli":"Añjaliṁ te paggaṇhāma, ","html":"<span class='verse-line'>{}</span>"},"ja540:65.4":{"pli":"yāva sāmānupāpaya. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:66.1":{"pli":"Tassa pāde samajjantā, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:66.2":{"pli":"mukhañca bhujadassanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja540:66.3":{"pli":"Saṁsumbhamānā attānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja540:66.4":{"pli":"kālamāgamayāmase”. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:67.1":{"pli":"“Brahā vāḷamigākiṇṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:67.2":{"pli":"ākāsantaṁva dissati; ","html":"<span class='verse-line'>{}</span>"},"ja540:67.3":{"pli":"Yattha sāmo hato seti, ","html":"<span class='verse-line'>{}</span>"},"ja540:67.4":{"pli":"candova patito chamā. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:68.1":{"pli":"Brahā vāḷamigākiṇṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:68.2":{"pli":"ākāsantaṁva dissati; ","html":"<span class='verse-line'>{}</span>"},"ja540:68.3":{"pli":"Yattha sāmo hato seti, ","html":"<span class='verse-line'>{}</span>"},"ja540:68.4":{"pli":"sūriyova patito chamā. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:69.1":{"pli":"Brahā vāḷamigākiṇṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:69.2":{"pli":"ākāsantaṁva dissati; ","html":"<span class='verse-line'>{}</span>"},"ja540:69.3":{"pli":"Yattha sāmo hato seti, ","html":"<span class='verse-line'>{}</span>"},"ja540:69.4":{"pli":"paṁsunā patikunthito. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:70.1":{"pli":"Brahā vāḷamigākiṇṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:70.2":{"pli":"ākāsantaṁva dissati; ","html":"<span class='verse-line'>{}</span>"},"ja540:70.3":{"pli":"Yattha sāmo hato seti, ","html":"<span class='verse-line'>{}</span>"},"ja540:70.4":{"pli":"idheva vasathassame”. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:71.1":{"pli":"“Yadi tattha sahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:71.2":{"pli":"satāni niyutāni ca; ","html":"<span class='verse-line'>{}</span>"},"ja540:71.3":{"pli":"Nevamhākaṁ bhayaṁ koci, ","html":"<span class='verse-line'>{}</span>"},"ja540:71.4":{"pli":"vane vāḷesu vijjati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:72.1":{"pli":"Tato andhānamādāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:72.2":{"pli":"kāsirājā brahāvane; ","html":"<span class='verse-line'>{}</span>"},"ja540:72.3":{"pli":"Hatthe gahetvā pakkāmi, ","html":"<span class='verse-line'>{}</span>"},"ja540:72.4":{"pli":"yattha sāmo hato ahu. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:73.1":{"pli":"Disvāna patitaṁ sāmaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:73.2":{"pli":"puttakaṁ paṁsukunthitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja540:73.3":{"pli":"Apaviddhaṁ brahāraññe, ","html":"<span class='verse-line'>{}</span>"},"ja540:73.4":{"pli":"candaṁva patitaṁ chamā. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:74.1":{"pli":"Disvāna patitaṁ sāmaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja540:74.2":{"pli":"puttakaṁ paṁsukunthitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja540:74.3":{"pli":"Apaviddhaṁ brahāraññe, ","html":"<span class='verse-line'>{}</span>"},"ja540:74.4":{"pli":"sūriyaṁva patitaṁ chamā. ","html":"<span class='verse-line'>{}</span></p>"},"ja540:75.1":{"pli":"Dis