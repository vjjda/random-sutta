{"kv14.2":{"kv14.2:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv14.2'><header><ul><li class='division'>{}</li>"},"kv14.2:0.2":{"pli":"Mahāpaṇṇāsaka ","html":"<li>{}</li>"},"kv14.2:0.3":{"pli":"Cuddasamavagga ","html":"<li>{}</li></ul>"},"kv14.2:0.4":{"pli":"Saḷāyatanuppattikathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv14.2:1.1":{"pli":"Saḷāyatanaṁ apubbaṁ acarimaṁ mātukucchismiṁ saṇṭhātīti? ","html":"<p data-doxy='orthodox'>{}"},"kv14.2:1.2":{"pli":"Āmantā. ","html":"{}"},"kv14.2:1.3":{"pli":"Sabbaṅgapaccaṅgī ahīnindriyo mātukucchismiṁ okkamatīti? ","html":"{}"},"kv14.2:1.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv14.2:2.1":{"pli":"Upapattesiyena cittena cakkhāyatanaṁ saṇṭhātīti? ","html":"<p data-doxy='orthodox'>{}"},"kv14.2:2.2":{"pli":"Āmantā. ","html":"{}"},"kv14.2:2.3":{"pli":"Upapattesiyena cittena hatthā saṇṭhanti, pādā saṇṭhanti, sīsaṁ saṇṭhāti, kaṇṇo saṇṭhāti, nāsikā saṇṭhāti, mukhaṁ saṇṭhāti, dantā saṇṭhantīti? ","html":"{}"},"kv14.2:2.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv14.2:3.1":{"pli":"Upapattesiyena cittena sotāyatanaṁ …pe… ","html":"<p data-doxy='orthodox'>{}"},"kv14.2:3.2":{"pli":"ghānāyatanaṁ …pe… ","html":"{}"},"kv14.2:3.3":{"pli":"jivhāyatanaṁ saṇṭhātīti? ","html":"{}"},"kv14.2:3.4":{"pli":"Āmantā. ","html":"{}"},"kv14.2:3.5":{"pli":"Upapattesiyena cittena hatthā saṇṭhanti, pādā saṇṭhanti, sīsaṁ saṇṭhāti, kaṇṇo saṇṭhāti, nāsikā saṇṭhāti, mukhaṁ saṇṭhāti, dantā saṇṭhantīti? ","html":"{}"},"kv14.2:3.6":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv14.2:4.1":{"pli":"Mātukucchigatassa pacchā cakkhāyatanaṁ uppajjatīti? ","html":"<p data-doxy='heterodox'>{}"},"kv14.2:4.2":{"pli":"Āmantā. ","html":"{}"},"kv14.2:4.3":{"pli":"Mātukucchismiṁ cakkhupaṭilābhāya kammaṁ karotīti? ","html":"{}"},"kv14.2:4.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv14.2:4.5":{"pli":"mātukucchigatassa pacchā sotāyatanaṁ …pe… ","html":"{}"},"kv14.2:4.6":{"pli":"ghānāyatanaṁ …pe… ","html":"{}"},"kv14.2:4.7":{"pli":"jivhāyatanaṁ uppajjatīti? ","html":"{}"},"kv14.2:4.8":{"pli":"Āmantā. ","html":"{}"},"kv14.2:4.9":{"pli":"Mātukucchismiṁ jivhāpaṭilābhāya kammaṁ karotīti? ","html":"{}"},"kv14.2:4.10":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv14.2:5.1":{"pli":"Mātukucchigatassa pacchā kesā lomā nakhā dantā aṭṭhī uppajjantīti? ","html":"<p data-doxy='heterodox'>{}"},"kv14.2:5.2":{"pli":"Āmantā. ","html":"{}"},"kv14.2:5.3":{"pli":"Mātukucchismiṁ aṭṭhipaṭilābhāya kammaṁ karotīti? ","html":"{}"},"kv14.2:5.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv14.2:6.1":{"pli":"Na vattabbaṁ—","html":"<p data-doxy='orthodox'>{}"},"kv14.2:6.2":{"pli":"“mātukucchigatassa pacchā kesā lomā nakhā dantā aṭṭhī uppajjantī”ti? ","html":"{}"},"kv14.2:6.3":{"pli":"Āmantā. ","html":"{}"},"kv14.2:6.4":{"pli":"Nanu vuttaṁ bhagavatā—","html":"{}</p>"},"kv14.2:7.1":{"pli":"“Paṭhamaṁ kalalaṁ hoti, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"kv14.2:7.2":{"pli":"kalalā hoti abbudaṁ; ","html":"<span class='verse-line'>{}</span>"},"kv14.2:7.3":{"pli":"Abbudā jāyate pesi, ","html":"<span class='verse-line'>{}</span>"},"kv14.2:7.4":{"pli":"pesi nibbattate ghano; ","html":"<span class='verse-line'>{}</span>"},"kv14.2:7.5":{"pli":"Ghanā pasākhā jāyanti, ","html":"<span class='verse-line'>{}</span>"},"kv14.2:7.6":{"pli":"kesā lomā nakhāpi ca. ","html":"<span class='verse-line'>{}</span></p>"},"kv14.2:8.1":{"pli":"Yañcassa bhuñjati mātā, ","html":"<p><span class='verse-line'>{}</span>"},"kv14.2:8.2":{"pli":"annaṁ pānañca bhojanaṁ; ","html":"<span class='verse-line'>{}</span>"},"kv14.2:8.3":{"pli":"Tena so tattha yāpeti, ","html":"<span class='verse-line'>{}</span>"},"kv14.2:8.4":{"pli":"mātukucchigato naro”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"kv14.2:9.1":{"pli":"Attheva suttantoti? ","html":"<p>{}"},"kv14.2:9.2":{"pli":"Āmantā. ","html":"{}"},"kv14.2:9.3":{"pli":"Tena hi mātukucchigatassa pacchā kesā lomā nakhā dantā aṭṭhī uppajjantīti. ","html":"{}</p>"},"kv14.2:9.4":{"pli":"Saḷāyatanuppattikathā niṭṭhitā. ","html":"<p class='endsutta'>{}</p></article>"}},"kv14.3":{"kv14.3:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv14.3'><header><ul><li class='division'>{}</li>"},"kv14.3:0.2":{"pli":"Mahāpaṇṇāsaka ","html":"<li>{}</li>"},"kv14.3:0.3":{"pli":"Cuddasamavagga ","html":"<li>{}</li></ul>"},"kv14.3:0.4":{"pli":"Anantarapaccayakathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv14.3:1.1":{"pli":"Cakkhuviññāṇassa anantarā sotaviññāṇaṁ uppajjatīti? ","html":"<p data-doxy='orthodox'>{}"},"kv14.3:1.2":{"pli":"Āmantā. ","html":"{}"},"kv14.3:1.3":{"pli":"Yā cakkhuviññāṇassa uppādāya āvaṭṭanā …pe… paṇidhi, sāva sotaviññāṇassa uppādāya āvaṭṭanā …pe… paṇidhīti? ","html":"{}"},"kv14.3:1.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv14.3:2.1":{"pli":"Cakkhuviññāṇassa anantarā sotaviññāṇaṁ uppajjati, na vattabbaṁ—","html":"<p data-doxy='orthodox'>{}"},"kv14.3:2.2":{"pli":"“yā cakkhuviññāṇassa uppādāya āvaṭṭanā …pe… paṇidhi, sāva sotaviññāṇassa uppādāya āvaṭṭanā …pe… paṇidhī”ti? ","html":"{}"},"kv14.3:2.3":{"pli":"Āmantā. ","html":"{}"},"kv14.3:2.4":{"pli":"Sotaviññāṇaṁ anāvaṭṭentassa uppajjati …pe… appaṇidahantassa uppajjatīti? ","html":"{}"},"kv14.3:2.5":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}"},"kv14.3:2.6":{"pli":"Nanu sotaviññāṇaṁ āvaṭṭentassa uppajjati …pe… paṇidahantassa uppajjatīti? ","html":"{}"},"kv14.3:2.7":{"pli":"Āmantā. ","html":"{}"},"kv14.3:2.8":{"pli":"Hañci sotaviññāṇaṁ āvaṭṭentassa uppajjati …pe… paṇidahantassa uppajjati, no ca vata re vattabbe—","html":"{}"},"kv14.3:2.9":{"pli":"“cakkhuviññāṇassa anantarā sotaviññāṇaṁ uppajjatī”ti. ","html":"{}</p>"},"kv14.3:3.1":{"pli":"Cakkhuviññāṇassa anantarā sotaviññāṇaṁ uppajjatīti? ","html":"<p data-doxy='orthodox'>{}"},"kv14.3:3.2":{"pli":"Āmantā. ","html":"{}"},"kv14.3:3.3":{"pli":"Cakkhuviññāṇaṁ rūpanimittaṁ manasikaroto uppajjatīti? ","html":"{}"},"kv14.3:3.4":{"pli":"Āmantā. ","html":"{}"},"kv14.3:3.5":{"pli":"Sotaviññāṇaṁ rūpanimittaṁ manasikaroto uppajjatīti? ","html":"{}"},"kv14.3:3.6":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv14.3:4.1":{"pli":"Cakkhuviññāṇaṁ rūpārammaṇaññeva na aññārammaṇanti? ","html":"<p data-doxy='orthodox'>{}"},"kv14.3:4.2":{"pli":"Āmantā. ","html":"{}"},"kv14.3:4.3":{"pli":"Sotaviññāṇaṁ rūpārammaṇaññeva na aññārammaṇanti? ","html":"{}"},"kv14.3:4.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv14.3:5.1":{"pli":"Cakkhuñca paṭicca rūpe ca uppajjati cakkhuviññāṇanti? ","html":"<p data-doxy='orthodox'>{}"},"kv14.3:5.2":{"pli":"Āmantā. ","html":"{}"},"kv14.3:5.3":{"pli":"Cakkhuñca paṭicca rūpe ca uppajjati sotaviññāṇanti? ","html":"{}"},"kv14.3:5.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv14.3:6.1":{"pli":"Cakkhuñca paṭicca rūpe ca uppajjati sotaviññāṇanti? ","html":"<p data-doxy='orthodox'>{}"},"kv14.3:6.2":{"pli":"Āmantā. ","html":"{}"},"kv14.3:6.3":{"pli":"“Cakkhuñca paṭicca rūpe ca uppajjati sotaviññāṇan”ti—","html":"{}"},"kv14.3:6.4":{"pli":"attheva suttantoti? ","html":"{}"},"kv14.3:6.5":{"pli":"Natthi. ","html":"{}"},"kv14.3:6.6":{"pli":"“Cakkhuñca paṭicca rūpe ca uppajjati cakkhuviññāṇan”ti—","html":"{}"},"kv14.3:6.7":{"pli":"attheva suttantoti? ","html":"{}"},"kv14.3:6.8":{"pli":"Āmantā. ","html":"{}"},"kv14.3:6.9":{"pli":"Hañci “cakkhuñca paṭicca rūpe ca uppajjati cakkhuviññāṇan”ti—","html":"{}"},"kv14.3:6.10":{"pli":"attheva suttanto, no ca vata re vattabbe—","html":"{}"},"kv14.3:6.11":{"pli":"“cakkhuñca paṭicca rūpe ca uppajjati sotaviññāṇan”ti. ","html":"{}</p>"},"kv14.3:7.1":{"pli":"Cakkhuviññāṇassa anantarā sotaviññāṇaṁ uppajjatīti? ","html":"<p data-doxy='orthodox'>{}"},"kv14.3:7.2":{"pli":"Āmantā. ","html":"{}"},"kv14.3:7.3":{"pli":"Taññeva cakkhuviññāṇaṁ taṁ sotaviññāṇanti? ","html":"{}"},"kv14.3:7.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv14.3:8.1":{"pli":"Sotaviññāṇassa anantarā ghānaviññāṇaṁ uppajjati …pe… ","html":"<p data-doxy='orthodox'>{}"},"kv14.3:8.2":{"pli":"ghānaviññāṇassa anan