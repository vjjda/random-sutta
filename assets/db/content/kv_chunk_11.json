"{}"},"kv14.3:14.7":{"pli":"“pañcaviññāṇā aññamaññassa samanantarā uppajjantī”ti. ","html":"{}</p>"},"kv14.3:14.8":{"pli":"Anantarapaccayakathā niṭṭhitā. ","html":"<p class='endsutta'>{}</p></article>"}},"kv14.4":{"kv14.4:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv14.4'><header><ul><li class='division'>{}</li>"},"kv14.4:0.2":{"pli":"Mahāpaṇṇāsaka ","html":"<li>{}</li>"},"kv14.4:0.3":{"pli":"Cuddasamavagga ","html":"<li>{}</li></ul>"},"kv14.4:0.4":{"pli":"Ariyarūpakathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv14.4:1.1":{"pli":"Ariyarūpaṁ mahābhūtānaṁ upādāyāti? ","html":"<p data-doxy='orthodox'>{}"},"kv14.4:1.2":{"pli":"Āmantā. ","html":"{}"},"kv14.4:1.3":{"pli":"Ariyarūpaṁ kusalanti? ","html":"{}"},"kv14.4:1.4":{"pli":"Āmantā. ","html":"{}"},"kv14.4:1.5":{"pli":"Mahābhūtā kusalāti? ","html":"{}"},"kv14.4:1.6":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv14.4:1.7":{"pli":"mahābhūtā abyākatāti? ","html":"{}"},"kv14.4:1.8":{"pli":"Āmantā. ","html":"{}"},"kv14.4:1.9":{"pli":"Ariyarūpaṁ abyākatanti? ","html":"{}"},"kv14.4:1.10":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv14.4:1.11":{"pli":"ariyarūpaṁ mahābhūtānaṁ upādāyāti? ","html":"{}"},"kv14.4:1.12":{"pli":"Āmantā. ","html":"{}"},"kv14.4:1.13":{"pli":"Ariyarūpaṁ anāsavaṁ asaṁyojaniyaṁ aganthaniyaṁ anoghaniyaṁ ayoganiyaṁ anīvaraṇiyaṁ aparāmaṭṭhaṁ anupādāniyaṁ asaṅkilesiyanti? ","html":"{}"},"kv14.4:1.14":{"pli":"Āmantā. ","html":"{}"},"kv14.4:1.15":{"pli":"Mahābhūtā anāsavā …pe… asaṅkilesiyāti? ","html":"{}"},"kv14.4:1.16":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv14.4:1.17":{"pli":"mahābhūtā sāsavā saṁyojaniyā …pe… saṅkilesiyāti? ","html":"{}"},"kv14.4:1.18":{"pli":"Āmantā. ","html":"{}"},"kv14.4:1.19":{"pli":"Ariyarūpaṁ sāsavaṁ saṁyojaniyaṁ …pe… saṅkilesiyanti? ","html":"{}"},"kv14.4:1.20":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv14.4:2.1":{"pli":"Na vattabbaṁ—","html":"<p data-doxy='heterodox'>{}"},"kv14.4:2.2":{"pli":"“ariyarūpaṁ mahābhūtānaṁ upādāyā”ti? ","html":