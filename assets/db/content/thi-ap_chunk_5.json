{"thi-ap20":{"thi-ap20:0.1":{"pli":"Therīapadāna ","html":"<article id='thi-ap20'><header><ul><li class='division'>{}</li>"},"thi-ap20:0.2":{"pli":"Ekūposathikavagga ","html":"<li>{}</li></ul>"},"thi-ap20:0.3":{"pli":"Paṭācārātherīapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"thi-ap20:1.1":{"pli":"“Padumuttaro nāma jino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"thi-ap20:1.2":{"pli":"sabbadhammāna pāragū; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:1.3":{"pli":"Ito satasahassamhi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:1.4":{"pli":"kappe uppajji nāyako. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:2.1":{"pli":"Tadāhaṁ haṁsavatiyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:2.2":{"pli":"jātā seṭṭhikule ahuṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:2.3":{"pli":"Nānāratanapajjote, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:2.4":{"pli":"mahāsukhasamappitā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:3.1":{"pli":"Upetvā taṁ mahāvīraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:3.2":{"pli":"assosiṁ dhammadesanaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:3.3":{"pli":"Tato jātapasādāhaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:3.4":{"pli":"upesiṁ saraṇaṁ jinaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:4.1":{"pli":"Tato vinayadhārīnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:4.2":{"pli":"aggaṁ vaṇṇesi nāyako; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:4.3":{"pli":"Bhikkhuniṁ lajjiniṁ tādiṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:4.4":{"pli":"kappākappavisāradaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:5.1":{"pli":"Tadā muditacittāhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:5.2":{"pli":"taṁ ṭhānamabhikaṅkhinī; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:5.3":{"pli":"Nimantetvā dasabalaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:5.4":{"pli":"sasaṅghaṁ lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:6.1":{"pli":"Bhojayitvāna sattāhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:6.2":{"pli":"daditvāva ticīvaraṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:6.3":{"pli":"Nipacca sirasā pāde, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:6.4":{"pli":"idaṁ vacanamabraviṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:7.1":{"pli":"‘Yā tayā vaṇṇitā vīra, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:7.2":{"pli":"ito aṭṭhamake muni; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:7.3":{"pli":"Tādisāhaṁ bhavissāmi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:7.4":{"pli":"yadi sijjhati nāyaka’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:8.1":{"pli":"Tadā avoca maṁ satthā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:8.2":{"pli":"‘bhadde mā bhāyi assasa; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:8.3":{"pli":"Anāgatamhi addhāne, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:8.4":{"pli":"lacchase taṁ manorathaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:9.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:9.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:9.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:9.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:10.1":{"pli":"Tassa dhammesu dāyādā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:10.2":{"pli":"orasā dhammanimmitā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:10.3":{"pli":"Paṭācārāti nāmena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:10.4":{"pli":"hessati satthu sāvikā’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:11.1":{"pli":"Tadāhaṁ muditā hutvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:11.2":{"pli":"yāvajīvaṁ tadā jinaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:11.3":{"pli":"Mettacittā paricariṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:11.4":{"pli":"sasaṅghaṁ lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:12.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:12.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:12.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:12.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:13.1":{"pli":"Imamhi bhaddake kappe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:13.2":{"pli":"brahmabandhu mahāyaso; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:13.3":{"pli":"Kassapo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:13.4":{"pli":"uppajji vadataṁ varo. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:14.1":{"pli":"Upaṭṭhāko mahesissa, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:14.2":{"pli":"tadā āsi narissaro; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:14.3":{"pli":"Kāsirājā kikī nāma, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:14.4":{"pli":"bārāṇasipuruttame. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:15.1":{"pli":"Tassāsiṁ tatiyā dhītā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:15.2":{"pli":"bhikkhunī iti vissutā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:15.3":{"pli":"Dhammaṁ sutvā jinaggassa, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:15.4":{"pli":"pabbajjaṁ samarocayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:16.1":{"pli":"Anujāni na no tāto, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:16.2":{"pli":"agāreva tadā mayaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:16.3":{"pli":"Vīsavassasahassāni, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:16.4":{"pli":"vicarimha atanditā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:17.1":{"pli":"Komāribrahmacariyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:17.2":{"pli":"rājakaññā sukhedhitā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:17.3":{"pli":"Buddhopaṭṭhānaniratā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:17.4":{"pli":"muditā sattadhītaro. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:18.1":{"pli":"Samaṇī samaṇaguttā ca, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:18.2":{"pli":"bhikkhunī bhikkhudāyikā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:18.3":{"pli":"Dhammā ceva sudhammā ca, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:18.4":{"pli":"sattamī saṅghadāyikā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:19.1":{"pli":"Ahaṁ uppalavaṇṇā ca, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:19.2":{"pli":"khemā bhaddā ca bhikkhunī; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:19.3":{"pli":"Kisāgotamī dhammadinnā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:19.4":{"pli":"visākhā hoti sattamī. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:20.1":{"pli":"Tehi kammehi sukatehi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:20.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:20.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:20.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:21.1":{"pli":"Pacchime ca bhave dāni, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:21.2":{"pli":"jātā seṭṭhikule ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:21.3":{"pli":"Sāvatthiyaṁ puravare, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:21.4":{"pli":"iddhe phīte mahaddhane. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:22.1":{"pli":"Yadā ca yobbanūpetā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:22.2":{"pli":"vitakkavasagā ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:22.3":{"pli":"Naraṁ jārapatiṁ disvā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:22.4":{"pli":"tena saddhiṁ agacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:23.1":{"pli":"Ekaputtapasūtāhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:23.2":{"pli":"dutiyo kucchiyā mamaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:23.3":{"pli":"Tadāhaṁ mātāpitaro, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:23.4":{"pli":"okkhāmīti sunicchitā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:24.1":{"pli":"Nārocesiṁ patiṁ mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:24.2":{"pli":"tadā tamhi pavāsite; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:24.3":{"pli":"Ekikā niggatā gehā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:24.4":{"pli":"gantuṁ sāvatthimuttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:25.1":{"pli":"Tato me sāmi āgantvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:25.2":{"pli":"sambhāvesi pathe mamaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:25.3":{"pli":"Tadā me kammajā vātā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:25.4":{"pli":"uppannā atidāruṇā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:26.1":{"pli":"Uṭṭhito ca mahāmegho, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:26.2":{"pli":"pasūtisamaye mama; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:26.3":{"pli":"Dabbatthāya tadā gantvā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:26.4":{"pli":"sāmi sappena mārito. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:27.1":{"pli":"Tadā vijātadukkhena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:27.2":{"pli":"anāthā kapaṇā ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:27.3":{"pli":"Kunnadiṁ pūritaṁ disvā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:27.4":{"pli":"gacchantī sakulālayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:28.1":{"pli":"Bālaṁ ādāya atariṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:28.2":{"pli":"pārakūle ca ekakaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:28.3":{"pli":"Sāyetvā bālakaṁ puttaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:28.4":{"pli":"itaraṁ taraṇāyahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:29.1":{"pli":"Nivattā ukkuso hāsi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:29.2":{"pli":"taruṇaṁ vilapantakaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:29.3":{"pli":"Itarañca vahī soto, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:29.4":{"pli":"sāhaṁ sokasamappitā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:30.1":{"pli":"Sāvatthinagaraṁ gantvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:30.2":{"pli":"assosiṁ sajane mate; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:30.3":{"pli":"Tadā avocaṁ sokaṭṭā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:30.4":{"pli":"mahāsokasamappitā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:31.1":{"pli":"‘Ubho puttā kālaṅkatā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:31.2":{"pli":"panthe mayhaṁ patī mato; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:31.3":{"pli":"Mātā pitā ca bhātā ca, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:31.4":{"pli":"ekacitamhi ḍayhare’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:32.1":{"pli":"Tadā kisā ca paṇḍu ca, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:32.2":{"pli":"anāthā dīnamānasā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:32.3":{"pli":"Ito tato bhamantīhaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:32.4":{"pli":"addasaṁ narasārathiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:33.1":{"pli":"Tato avoca maṁ satthā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:33.2":{"pli":"‘putte mā soci assasa; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:33.3":{"pli":"Attānaṁ te gavesassu, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:33.4":{"pli":"kiṁ niratthaṁ vihaññasi. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:34.1":{"pli":"Na santi puttā tāṇāya, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:34.2":{"pli":"na ñātī napi bandhavā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:34.3":{"pli":"Antakenādhipannassa, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:34.4":{"pli":"natthi ñātīsu tāṇatā’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:35.1":{"pli":"Taṁ sutvā munino vākyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:35.2":{"pli":"paṭhamaṁ phalamajjhagaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:35.3":{"pli":"Pabbajitvāna naciraṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:35.4":{"pli":"arahattamapāpuṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:36.1":{"pli":"Iddhīsu ca vasī homi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:36.2":{"pli":"dibbāya sotadhātuyā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:36.3":{"pli":"Paracittāni jānāmi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:36.4":{"pli":"satthusāsanakārikā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:37.1":{"pli":"Pubbenivāsaṁ jānāmi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:37.2":{"pli":"dibbacakkhu visodhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:37.3":{"pli":"Khepetvā āsave sabbe, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:37.4":{"pli":"visuddhāsiṁ sunimmalā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:38.1":{"pli":"Tatohaṁ vinayaṁ sabbaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:38.2":{"pli":"santike sabbadassino; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:38.3":{"pli":"Uggahiṁ sabbavitthāraṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:38.4":{"pli":"byāhariñca yathātathaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:39.1":{"pli":"Jino tasmiṁ guṇe tuṭṭho, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:39.2":{"pli":"etadagge ṭhapesi maṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:39.3":{"pli":"‘Aggā vinayadhārīnaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:39.4":{"pli":"paṭācārāva ekikā’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:40.1":{"pli":"Pariciṇṇo mayā satthā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:40.2":{"pli":"kataṁ buddhassa sāsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:40.3":{"pli":"Ohito garuko bhāro, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:40.4":{"pli":"bhavanetti samūhatā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:41.1":{"pli":"Yassatthāya pabbajitā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:41.2":{"pli":"agārasmānagāriyaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:41.3":{"pli":"So me attho anuppatto, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:41.4":{"pli":"sabbasaṁyojanakkhayo. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:42.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:42.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:42.3":{"pli":"viharāmi anāsavā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:43.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:43.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:43.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:44.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:44.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:44.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"thi-ap20:45.1":{"pli":"Itthaṁ sudaṁ paṭācārā bhikkhunī imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"thi-ap20:46.1":{"pli":"Paṭācārātheriyāpadānaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"thi-ap20:47.1":{"pli":"Ekūposathikavaggo dutiyo. ","html":"<p class='endsection'>{}</p>"},"thi-ap20:48.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"thi-ap20:49.1":{"pli":"Ekūposathikā ceva, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"thi-ap20:49.2":{"pli":"saḷalā cātha modakā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:49.3":{"pli":"Ekāsanā pañcadīpā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:49.4":{"pli":"naḷamālī ca gotamī. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap20:50.1":{"pli":"Khemā uppalavaṇṇā ca, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap20:50.2":{"pli":"paṭācārā ca bhikkhunī; ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:50.3":{"pli":"Gāthā satāni pañceva, ","html":"<span class='verse-line'>{}</span>"},"thi-ap20:50.4":{"pli":"nava cāpi taduttari. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"thi-ap21":{"thi-ap21:0.1":{"pli":"Therīapadāna ","html":"<article id='thi-ap21'><header><ul><li class='division'>{}</li>"},"thi-ap21:0.2":{"pli":"Kuṇḍalakesīvagga ","html":"<li>{}</li></ul>"},"thi-ap21:0.3":{"pli":"1 Kuṇḍalakesātherīapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"thi-ap21:1.1":{"pli":"“Padumuttaro nāma jino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"thi-ap21:1.2":{"pli":"sabbadhammāna pāragū; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:1.3":{"pli":"Ito satasahassamhi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:1.4":{"pli":"kappe uppajji nāyako. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:2.1":{"pli":"Tadāhaṁ haṁsavatiyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:2.2":{"pli":"jātā seṭṭhikule ahuṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:2.3":{"pli":"Nānāratanapajjote, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:2.4":{"pli":"mahāsukhasamappitā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:3.1":{"pli":"Upetvā taṁ mahāvīraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:3.2":{"pli":"assosiṁ dhammadesanaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:3.3":{"pli":"Tato jātappasādāhaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:3.4":{"pli":"upesiṁ saraṇaṁ jinaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:4.1":{"pli":"Tadā mahākāruṇiko, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:4.2":{"pli":"padumuttaranāmako; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:4.3":{"pli":"Khippābhiññānamagganti, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:4.4":{"pli":"ṭhapesi bhikkhuniṁ subhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:5.1":{"pli":"Taṁ sutvā muditā hutvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:5.2":{"pli":"dānaṁ datvā mahesino; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:5.3":{"pli":"Nipacca sirasā pāde, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:5.4":{"pli":"taṁ ṭhānamabhipatthayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:6.1":{"pli":"Anumodi mahāvīro, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:6.2":{"pli":"‘bhadde yaṁ tebhipatthitaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:6.3":{"pli":"Samijjhissati taṁ sabbaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:6.4":{"pli":"sukhinī hohi nibbutā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:7.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:7.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:7.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:7.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:8.1":{"pli":"Tassa dhammesu dāyādā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:8.2":{"pli":"orasā dhammanimmitā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:8.3":{"pli":"Bhaddākuṇḍalakesāti, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:8.4":{"pli":"hessati satthu sāvikā’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:9.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:9.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:9.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:9.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:10.1":{"pli":"Tato cutā yāmamagaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:10.2":{"pli":"tatohaṁ tusitaṁ gatā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:10.3":{"pli":"Tato ca nimmānaratiṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:10.4":{"pli":"vasavattipuraṁ tato. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:11.1":{"pli":"Yattha yatthūpapajjāmi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:11.2":{"pli":"tassa kammassa vāhasā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:11.3":{"pli":"Tattha tattheva rājūnaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:11.4":{"pli":"mahesittamakārayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:12.1":{"pli":"Tato cutā manussesu, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:12.2":{"pli":"rājūnaṁ cakkavattinaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:12.3":{"pli":"Maṇḍalīnañca rājūnaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:12.4":{"pli":"mahesittamakārayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:13.1":{"pli":"Sampattiṁ anubhotvāna, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:13.2":{"pli":"devesu mānusesu ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:13.3":{"pli":"Sabbattha sukhitā hutvā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:13.4":{"pli":"nekakappesu saṁsariṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:14.1":{"pli":"Imamhi bhaddake kappe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:14.2":{"pli":"brahmabandhu mahāyaso; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:14.3":{"pli":"Kassapo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:14.4":{"pli":"uppajji vadataṁ varo. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:15.1":{"pli":"Upaṭṭhāko mahesissa, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:15.2":{"pli":"tadā āsi narissaro; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:15.3":{"pli":"Kāsirājā kikī nāma, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:15.4":{"pli":"bārāṇasipuruttame. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:16.1":{"pli":"Tassa dhītā catutthāsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:16.2":{"pli":"bhikkhudāyīti vissutā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:16.3":{"pli":"Dhammaṁ sutvā jinaggassa, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:16.4":{"pli":"pabbajjaṁ samarocayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:17.1":{"pli":"Anujāni na no tāto, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:17.2":{"pli":"agāreva tadā mayaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:17.3":{"pli":"Vīsavassasahassāni, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:17.4":{"pli":"vicarimha atanditā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:18.1":{"pli":"Komāribrahmacariyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:18.2":{"pli":"rājakaññā sukhedhitā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:18.3":{"pli":"Buddhopaṭṭhānaniratā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:18.4":{"pli":"muditā satta dhītaro. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:19.1":{"pli":"Samaṇī samaṇaguttā ca, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:19.2":{"pli":"bhikkhunī bhikkhudāyikā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:19.3":{"pli":"Dhammā ceva sudhammā ca, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:19.4":{"pli":"sattamī saṅghadāyikā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:20.1":{"pli":"Khemā uppalavaṇṇā ca, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:20.2":{"pli":"paṭācārā ahaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:20.3":{"pli":"Kisāgotamī dhammadinnā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:20.4":{"pli":"visākhā hoti sattamī. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:21.1":{"pli":"Tehi kammehi sukatehi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:21.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:21.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:21.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:22.1":{"pli":"Pacchime ca bhave dāni, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:22.2":{"pli":"giribbajapuruttame; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:22.3":{"pli":"Jātā seṭṭhikule phīte, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:22.4":{"pli":"yadāhaṁ yobbane ṭhitā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:23.1":{"pli":"Coraṁ vadhatthaṁ nīyantaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:23.2":{"pli":"disvā rattā tahiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:23.3":{"pli":"Pitā me taṁ sahassena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:23.4":{"pli":"mocayitvā vadhā tato. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:24.1":{"pli":"Adāsi tassa maṁ tāto, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:24.2":{"pli":"viditvāna manaṁ mama; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:24.3":{"pli":"Tassāhamāsiṁ visaṭṭhā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:24.4":{"pli":"atīva dayitā hitā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:25.1":{"pli":"So me bhūsanalobhena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:25.2":{"pli":"balimajjhāsayo diso; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:25.3":{"pli":"Corappapātaṁ netvāna, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:25.4":{"pli":"pabbataṁ cetayī vadhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:26.1":{"pli":"Tadāhaṁ paṇamitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:26.2":{"pli":"sattukaṁ sukatañjalī; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:26.3":{"pli":"Rakkhantī attano pāṇaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:26.4":{"pli":"idaṁ vacanamabraviṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:27.1":{"pli":"‘Idaṁ suvaṇṇakeyūraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:27.2":{"pli":"muttā veḷuriyā bahū; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:27.3":{"pli":"Sabbaṁ harassu bhaddante, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:27.4":{"pli":"mañca dāsīti sāvaya’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:28.1":{"pli":"‘Oropayassu kalyāṇī, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:28.2":{"pli":"mā bāḷhaṁ paridevasi; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:28.3":{"pli":"Na cāhaṁ abhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:28.4":{"pli":"ahantvā dhanamābhataṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:29.1":{"pli":"‘Yato sarāmi attānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:29.2":{"pli":"yato pattosmi viññutaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:29.3":{"pli":"Na cāhaṁ abhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:29.4":{"pli":"aññaṁ piyataraṁ tayā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:30.1":{"pli":"Ehi taṁ upagūhissaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:30.2":{"pli":"katvāna taṁ padakkhiṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:30.3":{"pli":"Na ca dāni puno atthi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:30.4":{"pli":"mama tuyhañca saṅgamo’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:31.1":{"pli":"‘Na hi sabbesu ṭhānesu, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:31.2":{"pli":"puriso hoti paṇḍito; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:31.3":{"pli":"Itthīpi paṇḍitā hoti, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:31.4":{"pli":"tattha tattha vicakkhaṇā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:32.1":{"pli":"Na hi sabbesu ṭhānesu, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:32.2":{"pli":"puriso hoti paṇḍito; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:32.3":{"pli":"Itthīpi paṇḍitā hoti, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:32.4":{"pli":"lahuṁ atthavicintikā’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:33.1":{"pli":"Lahuñca vata khippañca, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:33.2":{"pli":"nikaṭṭhe samacetayiṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:33.3":{"pli":"Migaṁ uṇṇā yathā evaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:33.4":{"pli":"tadāhaṁ sattukaṁ vadhiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:34.1":{"pli":"Yo ca uppatitaṁ atthaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:34.2":{"pli":"na khippamanubujjhati; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:34.3":{"pli":"So haññate mandamati, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:34.4":{"pli":"corova girigabbhare. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:35.1":{"pli":"Yo ca uppatitaṁ atthaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:35.2":{"pli":"khippameva nibodhati; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:35.3":{"pli":"Muccate sattusambādhā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:35.4":{"pli":"tadāhaṁ sattukā yathā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:36.1":{"pli":"Tadāhaṁ pātayitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:36.2":{"pli":"giriduggamhi sattukaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:36.3":{"pli":"Santikaṁ setavatthānaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:36.4":{"pli":"upetvā pabbajiṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:37.1":{"pli":"Saṇḍāsena ca kese me, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:37.2":{"pli":"luñcitvā sabbaso tadā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:37.3":{"pli":"Pabbajitvāna samayaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:37.4":{"pli":"ācikkhiṁsu nirantaraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:38.1":{"pli":"Tato taṁ uggahetvāhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:38.2":{"pli":"nisīditvāna ekikā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:38.3":{"pli":"Samayaṁ taṁ vicintesiṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:38.4":{"pli":"suvāno mānusaṁ karaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:39.1":{"pli":"Chinnaṁ gayha samīpe me, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:39.2":{"pli":"pātayitvā apakkami; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:39.3":{"pli":"Disvā nimittamalabhiṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:39.4":{"pli":"hatthaṁ taṁ puḷavākulaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:40.1":{"pli":"Tato uṭṭhāya saṁviggā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:40.2":{"pli":"apucchiṁ sahadhammike; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:40.3":{"pli":"Te avocuṁ ‘vijānanti, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:40.4":{"pli":"taṁ atthaṁ sakyabhikkhavo’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:41.1":{"pli":"Sāhaṁ tamatthaṁ pucchissaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:41.2":{"pli":"upetvā buddhasāvake; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:41.3":{"pli":"Te mamādāya gacchiṁsu, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:41.4":{"pli":"buddhaseṭṭhassa santikaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:42.1":{"pli":"So me dhammamadesesi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:42.2":{"pli":"khandhāyatanadhātuyo; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:42.3":{"pli":"Asubhāniccadukkhāti, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:42.4":{"pli":"anattāti ca nāyako. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:43.1":{"pli":"Tassa dhammaṁ suṇitvāhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:43.2":{"pli":"dhammacakkhuṁ visodhayiṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:43.3":{"pli":"Tato viññātasaddhammā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:43.4":{"pli":"pabbajjaṁ upasampadaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:44.1":{"pli":"Āyācito tadā āha, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:44.2":{"pli":"‘ehi bhadde’ti nāyako; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:44.3":{"pli":"Tadāhaṁ upasampannā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:44.4":{"pli":"parittaṁ toyamaddasaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:45.1":{"pli":"Pādapakkhālanenāhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:45.2":{"pli":"ñatvā saudayabbayaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:45.3":{"pli":"Tathā sabbepi saṅkhāre, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:45.4":{"pli":"īdisaṁ cintayiṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:46.1":{"pli":"Tato cittaṁ vimucci me, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:46.2":{"pli":"anupādāya sabbaso; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:46.3":{"pli":"Khippābhiññānamaggaṁ me, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:46.4":{"pli":"tadā paññāpayī jino. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:47.1":{"pli":"Iddhīsu ca vasī homi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:47.2":{"pli":"dibbāya sotadhātuyā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:47.3":{"pli":"Paracittāni jānāmi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:47.4":{"pli":"satthusāsanakārikā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:48.1":{"pli":"Pubbenivāsaṁ jānāmi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:48.2":{"pli":"dibbacakkhu visodhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:48.3":{"pli":"Khepetvā āsave sabbe, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:48.4":{"pli":"visuddhāsiṁ sunimmalā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:49.1":{"pli":"Pariciṇṇo mayā satthā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:49.2":{"pli":"kataṁ buddhassa sāsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:49.3":{"pli":"Ohito garuko bhāro, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:49.4":{"pli":"bhavanetti samūhatā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:50.1":{"pli":"Yassatthāya pabbajitā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:50.2":{"pli":"agārasmānagāriyaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:50.3":{"pli":"So me attho anuppatto, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:50.4":{"pli":"sabbasaṁyojanakkhayo. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:51.1":{"pli":"Atthadhammaniruttīsu, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:51.2":{"pli":"paṭibhāne tatheva ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:51.3":{"pli":"Ñāṇaṁ me vimalaṁ suddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:51.4":{"pli":"buddhaseṭṭhassa sāsane. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:52.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:52.2":{"pli":"bhavā sabbe samūhatā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:52.3":{"pli":"Nāgīva bandhanaṁ chetvā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:52.4":{"pli":"viharāmi anāsavā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:53.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:53.2":{"pli":"mama buddhassa santike; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:53.3":{"pli":"Tisso vijjā anuppattā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:53.4":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap21:54.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap21:54.2":{"pli":"vimokkhāpi ca aṭṭhime; ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:54.3":{"pli":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap21:54.4":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"thi-ap21:55.1":{"pli":"Itthaṁ sudaṁ bhaddākuṇḍalakesā bhikkhunī imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"thi-ap21:56.1":{"pli":"Kuṇḍalakesātheriyāpadānaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}