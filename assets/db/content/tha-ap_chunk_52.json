{"tha-ap539":{"tha-ap539:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap539'><header><ul><li class='division'>{}</li>"},"tha-ap539:0.2":{"pli":"Kaccāyanavagga ","html":"<li>{}</li></ul>"},"tha-ap539:0.3":{"pli":"7 Mahākoṭṭhikattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap539:1.1":{"pli":"“Padumuttaro nāma jino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap539:1.2":{"pli":"sabbalokavidū muni; ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:1.3":{"pli":"Ito satasahassamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:1.4":{"pli":"kappe uppajji cakkhumā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap539:2.1":{"pli":"Ovādako viññāpako, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap539:2.2":{"pli":"tārako sabbapāṇinaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:2.3":{"pli":"Desanākusalo buddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:2.4":{"pli":"tāresi janataṁ bahuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap539:3.1":{"pli":"Anukampako kāruṇiko, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap539:3.2":{"pli":"hitesī sabbapāṇinaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:3.3":{"pli":"Sampatte titthiye sabbe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:3.4":{"pli":"pañcasīle patiṭṭhapi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap539:4.1":{"pli":"Evaṁ nirākulaṁ āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap539:4.2":{"pli":"suññataṁ titthiyehi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:4.3":{"pli":"Vicittaṁ arahantehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:4.4":{"pli":"vasībhūtehi tādibhi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap539:5.1":{"pli":"Ratanānaṭṭhapaññāsaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap539:5.2":{"pli":"uggato so mahāmuni; ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:5.3":{"pli":"Kañcanagghiyasaṅkāso, ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:5.4":{"pli":"bāttiṁsavaralakkhaṇo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap539:6.1":{"pli":"Vassasatasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap539:6.2":{"pli":"āyu vijjati tāvade; ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:6.3":{"pli":"Tāvatā tiṭṭhamāno so, ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:6.4":{"pli":"tāresi janataṁ bahuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap539:7.1":{"pli":"Tadāhaṁ haṁsavatiyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap539:7.2":{"pli":"brāhmaṇo vedapāragū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:7.3":{"pli":"Upecca sabbalokaggaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:7.4":{"pli":"assosiṁ dhammadesanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap539:8.1":{"pli":"Tadā so sāvakaṁ vīro, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap539:8.2":{"pli":"pabhinnamatigocaraṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:8.3":{"pli":"Atthe dhamme nirutte ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:8.4":{"pli":"paṭibhāne ca kovidaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap539:9.1":{"pli":"Ṭhapesi etadaggamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap539:9.2":{"pli":"taṁ sutvā mudito ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:9.3":{"pli":"Sasāvakaṁ jinavaraṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:9.4":{"pli":"sattāhaṁ bhojayiṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap539:10.1":{"pli":"Dussehacchādayitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap539:10.2":{"pli":"sasissaṁ buddhisāgaraṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:10.3":{"pli":"Nipacca pādamūlamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:10.4":{"pli":"taṁ ṭhānaṁ patthayiṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap539:11.1":{"pli":"Tato avoca lokaggo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap539:11.2":{"pli":"‘passathetaṁ dijuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:11.3":{"pli":"Vinataṁ pādamūle me, ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:11.4":{"pli":"kamalodarasappabhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap539:12.1":{"pli":"Buddhaseṭṭhassa bhikkhussa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap539:12.2":{"pli":"Ṭhānaṁ patthayate ayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:12.3":{"pli":"Tāya saddhāya cāgena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:12.4":{"pli":"Saddhammassavanena ca. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap539:13.1":{"pli":"Sabbattha sukhito hutvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap539:13.2":{"pli":"saṁsaritvā bhavābhave; ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:13.3":{"pli":"Anāgatamhi addhāne, ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:13.4":{"pli":"lacchase taṁ manorathaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap539:14.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap539:14.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:14.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:14.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap539:15.1":{"pli":"Tassa dhammesu dāyādo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap539:15.2":{"pli":"oraso dhammanimmito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:15.3":{"pli":"Koṭṭhiko nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:15.4":{"pli":"hessati satthu sāvako’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap539:16.1":{"pli":"Taṁ sutvā mudito hutvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap539:16.2":{"pli":"yāvajīvaṁ tadā jinaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:16.3":{"pli":"Mettacitto paricariṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:16.4":{"pli":"sato paññāsamāhito. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap539:17.1":{"pli":"Tena kammavipākena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap539:17.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:17.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:17.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap539:18.1":{"pli":"Satānaṁ tīṇikkhattuñca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap539:18.2":{"pli":"devarajjamakārayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:18.3":{"pli":"Satānaṁ pañcakkhattuñca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:18.4":{"pli":"cakkavattī ahosahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap539:19.1":{"pli":"Padesarajjaṁ vipulaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap539:19.2":{"pli":"gaṇanāto asaṅkhiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:19.3":{"pli":"Sabbattha sukhito āsiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:19.4":{"pli":"tassa kammassa vāhasā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap539:20.1":{"pli":"Duve bhave saṁsarāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap539:20.2":{"pli":"devatte atha mānuse; ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:20.3":{"pli":"Aññaṁ gatiṁ na gacchāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:20.4":{"pli":"suciṇṇassa idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap539:21.1":{"pli":"Duve kule pajāyāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap539:21.2":{"pli":"khattiye atha brāhmaṇe; ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:21.3":{"pli":"Nīce kule na jāyāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:21.4":{"pli":"suciṇṇassa idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap539:22.1":{"pli":"Pacchime bhave sampatte, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap539:22.2":{"pli":"brahmabandhu ahosahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:22.3":{"pli":"Sāvatthiyaṁ vippakule, ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:22.4":{"pli":"paccājāto mahaddhane. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap539:23.1":{"pli":"Mātā candavatī nāma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap539:23.2":{"pli":"pitā me assalāyano; ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:23.3":{"pli":"Yadā me pitaraṁ buddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:23.4":{"pli":"vinayī sabbasuddhiyā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap539:24.1":{"pli":"Tadā pasanno sugate, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap539:24.2":{"pli":"pabbajiṁ anagāriyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:24.3":{"pli":"Moggallāno ācariyo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:24.4":{"pli":"upajjhā sārisambhavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap539:25.1":{"pli":"Kesesu chijjamānesu, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap539:25.2":{"pli":"diṭṭhi chinnā samūlikā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:25.3":{"pli":"Nivāsento ca kāsāvaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:25.4":{"pli":"arahattamapāpuṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap539:26.1":{"pli":"Atthadhammaniruttīsu, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap539:26.2":{"pli":"paṭibhāne ca me mati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:26.3":{"pli":"Pabhinnā tena lokaggo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:26.4":{"pli":"etadagge ṭhapesi maṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap539:27.1":{"pli":"Asandiṭṭhaṁ viyākāsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap539:27.2":{"pli":"upatissena pucchito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:27.3":{"pli":"Paṭisambhidāsu tenāhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:27.4":{"pli":"aggo sambuddhasāsane. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap539:28.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap539:28.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:28.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap539:29.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap539:29.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:29.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap539:30.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap539:30.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap539:30.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap539:31.1":{"pli":"Itthaṁ sudaṁ āyasmā mahākoṭṭhiko thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap539:32.1":{"pli":"Mahākoṭṭhikattherassāpadānaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap54":{"tha-ap54:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap54'><header><ul><li class='division'>{}</li>"},"tha-ap54:0.2":{"pli":"Bījanivagga ","html":"<li>{}</li></ul>"},"tha-ap54:0.3":{"pli":"2 Sataraṁsittheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-