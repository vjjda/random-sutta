{"tha-ap437":{"tha-ap437:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap437'><header><ul><li class='division'>{}</li>"},"tha-ap437:0.2":{"pli":"Ekavihārivagga ","html":"<li>{}</li></ul>"},"tha-ap437:0.3":{"pli":"Ucchukhaṇḍikattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap437:1.1":{"pli":"“Nagare bandhumatiyā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap437:1.2":{"pli":"dvārapālo ahosahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap437:1.3":{"pli":"Addasaṁ virajaṁ buddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap437:1.4":{"pli":"sabbadhammāna pāraguṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap437:2.1":{"pli":"Ucchukhaṇḍikamādāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap437:2.2":{"pli":"buddhaseṭṭhassadāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap437:2.3":{"pli":"Pasannacitto sumano, ","html":"<span class='verse-line'>{}</span>"},"tha-ap437:2.4":{"pli":"vipassissa mahesino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap437:3.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap437:3.2":{"pli":"yaṁ ucchumadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap437:3.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap437:3.4":{"pli":"ucchukhaṇḍassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap437:4.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap437:4.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap437:4.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap437:5.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap437:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap437:5.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap437:6.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap437:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap437:6.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap437:7.1":{"pli":"Itthaṁ sudaṁ āyasmā ucchukhaṇḍiko thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap437:8.1":{"pli":"Ucchukhaṇḍikattherassāpadānaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap438":{"tha-ap438:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap438'><header><ul><li class='division'>{}</li>"},"tha-ap438:0.2":{"pli":"Ekavihārivagga ","html":"<li>{}</li></ul>"},"tha-ap438:0.3":{"pli":"6 Kaḷambadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap438:1.1":{"pli":"“Romaso nāma sambuddho, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap438:1.2":{"pli":"vasate pabbatantare; ","html":"<span class='verse-line'>{}</span>"},"tha-ap438:1.3":{"pli":"Kaḷambaṁ tassa pādāsiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap438:1.4":{"pli":"pasanno sehi pāṇibhi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap438:2.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap438:2.2":{"pli":"yaṁ dānamadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap438:2.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap438:2.4":{"pli":"kaḷambassa idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap438:3.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap438:3.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap438:3.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap438:4.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap438:4.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap438:4.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap438:5.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap438:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap438:5.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap438:6.1":{"pli":"Itthaṁ sudaṁ āyasmā kaḷambadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap438:7.1":{"pli":"Kaḷambadāyakattherassāpadānaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap439":{"tha-ap439:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap439'><header><ul><li class='division'>{}</li>"},"tha-ap439:0.2":{"pli":"Ekavihārivagga ","html":"<li>{}</li></ul>"},"tha-ap439:0.3":{"pli":"Ambāṭakadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap439:1.1":{"pli":"“Vipine buddhaṁ disvāna, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap439:1.2":{"pli":"sayambhuṁ aparājitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap439:1.3":{"pli":"Ambāṭakaṁ gahetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap439:1.4":{"pli":"sayambhussa adāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap439:2.1":{"pli":"Ekatiṁse ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap439:2.2":{"pli":"yaṁ phalamadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap439:2.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap439:2.4":{"pli":"phaladānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap439:3.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap439:3.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap439:3.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap439:4.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap439:4.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap439:4.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap439:5.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap439:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap439:5.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap439:6.1":{"pli":"Itthaṁ sudaṁ āyasmā ambāṭakadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap439:7.1":{"pli":"Ambāṭakadāyakattherassāpadānaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap44":{"tha-ap44:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap44'><header><ul><li class='division'>{}</li>"},"tha-ap44:0.2":{"pli":"Upālivagga ","html":"<li>{}</li></ul>"},"tha-ap44:0.3":{"pli":"2 Soṇakoḷivisattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap44:1.1":{"pli":"“Anomadassissa munino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap44:1.2":{"pli":"lokajeṭṭhassa tādino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:1.3":{"pli":"Sudhāya lepanaṁ katvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:1.4":{"pli":"caṅkamaṁ kārayiṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap44:2.1":{"pli":"Nānāvaṇṇehi pupphehi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap44:2.2":{"pli":"caṅkamaṁ santhariṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:2.3":{"pli":"Ākāse vitānaṁ katvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:2.4":{"pli":"bhojayiṁ buddhamuttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap44:3.1":{"pli":"Añjaliṁ paggahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap44:3.2":{"pli":"abhivādetvāna subbataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:3.3":{"pli":"Dīghasālaṁ bhagavato, ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:3.4":{"pli":"niyyādesimahaṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap44:4.1":{"pli":"Mama saṅkappamaññāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap44:4.2":{"pli":"satthā loke anuttaro; ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:4.3":{"pli":"Paṭiggahesi bhagavā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:4.4":{"pli":"anukampāya cakkhumā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap44:5.1":{"pli":"Paṭiggahetvāna sambuddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap44:5.2":{"pli":"dakkhiṇeyyo sadevake; ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:5.3":{"pli":"Bhikkhusaṅghe nisīditvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:5.4":{"pli":"imā gāthā abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap44:6.1":{"pli":"‘Yo so haṭṭhena cittena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap44:6.2":{"pli":"dīghasālaṁ adāsi me; ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:6.3":{"pli":"Tamahaṁ kittayissāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:6.4":{"pli":"suṇātha mama bhāsato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap44:7.1":{"pli":"Imassa maccukālamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap44:7.2":{"pli":"puññakammasamaṅgino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:7.3":{"pli":"Sahassayuttassaratho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:7.4":{"pli":"upaṭṭhissati tāvade. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap44:8.1":{"pli":"Tena yānenayaṁ poso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap44:8.2":{"pli":"devalokaṁ gamissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:8.3":{"pli":"Anumodissare devā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:8.4":{"pli":"sampatte kusalabbhave. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap44:9.1":{"pli":"Mahārahaṁ byamhaṁ seṭṭhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap44:9.2":{"pli":"ratanamattikalepanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:9.3":{"pli":"Kūṭāgāravarūpetaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:9.4":{"pli":"byamhaṁ ajjhāvasissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap44:10.1":{"pli":"Tiṁsakappasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap44:10.2":{"pli":"devaloke ramissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:10.3":{"pli":"Pañcavīsati kappāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:10.4":{"pli":"devarājā bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap44:11.1":{"pli":"Sattasattatikkhattuñca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap44:11.2":{"pli":"cakkavattī bhavissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:11.3":{"pli":"Yasodharasanāmā te, ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:11.4":{"pli":"sabbepi ekanāmakā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap44:12.1":{"pli":"Dve sampattī anubhotvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap44:12.2":{"pli":"Vaḍḍhetvā puññasañcayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:12.3":{"pli":"Aṭṭhavīsatikappamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:12.4":{"pli":"Cakkavattī bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap44:13.1":{"pli":"Tatrāpi byamhaṁ pavaraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap44:13.2":{"pli":"vissakammena māpitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:13.3":{"pli":"Dasasaddāvivittaṁ taṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:13.4":{"pli":"puramajjhāvasissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap44:14.1":{"pli":"Aparimeyye ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap44:14.2":{"pli":"bhūmipālo mahiddhiko; ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:14.3":{"pli":"Okkāko nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:14.4":{"pli":"rājā raṭṭhe bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap44:15.1":{"pli":"Soḷasitthisahassānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap44:15.2":{"pli":"sabbāsaṁ pavarā ca sā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:15.3":{"pli":"Abhijātā khattiyānī, ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:15.4":{"pli":"nava putte janessati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap44:16.1":{"pli":"Nava putte janetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap44:16.2":{"pli":"khattiyānī marissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:16.3":{"pli":"Taruṇī ca piyā kaññā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:16.4":{"pli":"mahesittaṁ karissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap44:17.1":{"pli":"Okkākaṁ tosayitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap44:17.2":{"pli":"varaṁ kaññā labhissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:17.3":{"pli":"Varaṁ laddhāna sā kaññā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:17.4":{"pli":"putte pabbājayissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap44:18.1":{"pli":"Pabbājitā ca te sabbe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap44:18.2":{"pli":"gamissanti naguttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:18.3":{"pli":"Jātibhedabhayā sabbe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:18.4":{"pli":"bhaginīhi vasissare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap44:19.1":{"pli":"Ekā ca kaññā byādhīhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap44:19.2":{"pli":"bhavissati parikkhatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:19.3":{"pli":"Mā no jāti pabhijjīti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:19.4":{"pli":"nikhaṇissanti khattiyā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap44:20.1":{"pli":"Khattiyo nīharitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap44:20.2":{"pli":"tāya saddhiṁ vasissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:20.3":{"pli":"Bhavissati tadā bhedo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:20.4":{"pli":"okkākakulasambhavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap44:21.1":{"pli":"Tesaṁ pajā bhavissanti, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap44:21.2":{"pli":"koḷiyā nāma jātiyā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:21.3":{"pli":"Tattha mānusakaṁ bhogaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:21.4":{"pli":"anubhossatinappakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap44:22.1":{"pli":"Tamhā kāyā cavitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap44:22.2":{"pli":"devalokaṁ gamissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:22.3":{"pli":"Tatrāpi pavaraṁ byamhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:22.4":{"pli":"labhissati manoramaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap44:23.1":{"pli":"Devalokā cavitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap44:23.2":{"pli":"sukkamūlena codito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:23.3":{"pli":"Āgantvāna manussattaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:23.4":{"pli":"soṇo nāma bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap44:24.1":{"pli":"Āraddhavīriyo pahitatto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap44:24.2":{"pli":"Padahaṁ satthu sāsane; ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:24.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:24.4":{"pli":"Nibbāyissatināsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap44:25.1":{"pli":"Anantadassī bhagavā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap44:25.2":{"pli":"gotamo sakyapuṅgavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:25.3":{"pli":"Visesaññū mahāvīro, ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:25.4":{"pli":"aggaṭṭhāne ṭhapessati’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap44:26.1":{"pli":"Vuṭṭhamhi deve caturaṅgulamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap44:26.2":{"pli":"Tiṇe anileritaaṅgaṇamhi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:26.3":{"pli":"Ṭhatvāna yogassa payuttatādino, ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:26.4":{"pli":"Tatottariṁ pāramatā na vijjati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap44:27.1":{"pli":"Uttame damathe danto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap44:27.2":{"pli":"cittaṁ me supaṇīhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:27.3":{"pli":"Bhāro me ohito sabbo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:27.4":{"pli":"nibbutomhi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap44:28.1":{"pli":"Aṅgīraso mahānāgo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap44:28.2":{"pli":"abhijātova kesarī; ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:28.3":{"pli":"Bhikkhusaṅghe nisīditvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:28.4":{"pli":"etadagge ṭhapesi maṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap44:29.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap44:29.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap44:29.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap44:30.1":{"pli":"Itthaṁ sudaṁ āyasmā soṇo koḷiviso thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap44:31.1":{"pli":"Soṇakoḷivisattherassāpadānaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap440":{"tha-ap440:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap440'><header><ul><li class='division'>{}</li>"},"tha-ap440:0.2":{"pli":"Ekavihārivagga ","html":"<li>{}</li></ul>"},"tha-ap440:0.3":{"pli":"Harītakadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap440:1.1":{"pli":"“Harītakaṁ āmalakaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap440:1.2":{"pli":"ambajambuvibhītakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap440:1.3":{"pli":"Kolaṁ bhallātakaṁ billaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap440:1.4":{"pli":"sayameva harāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap440:2.1":{"pli":"Disvāna pabbhāragataṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap440:2.2":{"pli":"jhāyiṁ jhānarataṁ muniṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap440:2.3":{"pli":"Ābādhena āpīḷentaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap440:2.4":{"pli":"adutīyaṁ mahāmuniṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap440:3.1":{"pli":"Harītakaṁ gahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap440:3.2":{"pli":"sayambhussa adāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap440:3.3":{"pli":"Khādamattamhi bhesajje, ","html":"<span class='verse-line'>{}</span>"},"tha-ap440:3.4":{"pli":"byādhi passambhi tāvade. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap440:4.1":{"pli":"Pahīnadaratho buddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap440:4.2":{"pli":"anumodamakāsi me; ","html":"<span class='verse-line'>{}</span>"},"tha-ap440:4.3":{"pli":"‘Bhesajjadāneniminā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap440:4.4":{"pli":"byādhivūpasamena ca. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap440:5.1":{"pli":"Devabhūto manusso vā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap440:5.2":{"pli":"jāto vā aññajātiyā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap440:5.3":{"pli":"Sabbattha sukhito hotu, ","html":"<span class='verse-line'>{}</span>"},"tha-ap440:5.4":{"pli":"mā ca te byādhimāgamā’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap440:6.1":{"pli":"Idaṁ vatvāna sambuddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap440:6.2":{"pli":"sayambhū aparājito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap440:6.3":{"pli":"Nabhaṁ abbhuggamī dhīro, ","html":"<span class='verse-line'>{}</span>"},"tha-ap440:6.4":{"pli":"haṁsarājāva ambare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap440:7.1":{"pli":"Yato harītakaṁ dinnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap440:7.2":{"pli":"sayambhussa mahesino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap440:7.3":{"pli":"Imaṁ jātiṁ upādāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap440:7.4":{"pli":"byādhi me nupapajjatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap440:8.1":{"pli":"Ayaṁ pacchimako mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap440:8.2":{"pli":"carimo vattate bhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap440:8.3":{"pli":"Tisso vijjā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap440:8.4":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap440:9.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap440:9.2":{"pli":"bhesajjamadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap440:9.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap440:9.4":{"pli":"bhesajjassa idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap440:10.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap440:10.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap440:10.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap440:11.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap440:11.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap440:11.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap440:12.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap440:12.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap440:12.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap440:13.1":{"pli":"Itthaṁ sudaṁ āyasmā harītakadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap440:14.1":{"pli":"Harītakadāyakattherassāpadānaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap441":{"tha-ap441:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap441'><header><ul><li class='division'>{}</li>"},"tha-ap441:0.2":{"pli":"Ekavihārivagga ","html":"<li>{}</li></ul>"},"tha-ap441:0.3":{"pli":"Ambapiṇḍiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap441:1.1":{"pli":"“Hatthirājā tadā āsiṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap441:1.2":{"pli":"īsādanto uruḷhavā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap441:1.3":{"pli":"Vicaranto brahāraññe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap441:1.4":{"pli":"addasaṁ lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap441:2.1":{"pli":"Ambapiṇḍaṁ gahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap441:2.2":{"pli":"adāsiṁ satthuno ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap441:2.3":{"pli":"Paṭiggaṇhi mahāvīro, ","html":"<span class='verse-line'>{}</span>"},"tha-ap441:2.4":{"pli":"siddhattho lokanāyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap441:3.1":{"pli":"Mama nijjhāyamānassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap441:3.2":{"pli":"paribhuñji tadā jino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap441:3.3":{"pli":"Tattha cittaṁ pasādetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap441:3.4":{"pli":"tusitaṁ upapajjahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap441:4.1":{"pli":"Tato ahaṁ cavitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap441:4.2":{"pli":"cakkavattī ahosahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap441:4.3":{"pli":"Eteneva upāyena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap441:4.4":{"pli":"anubhutvāna sampadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap441:5.1":{"pli":"Padhānapahitattohaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap441:5.2":{"pli":"upasanto nirūpadhi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap441:5.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap441:5.4":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap441:6.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap441:6.2":{"pli":"yaṁ phalamadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap441:6.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap441:6.4":{"pli":"phaladānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap441:7.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap441:7.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap441:7.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap441:8.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap441:8.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap441:8.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap441:9.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap441:9.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap441:9.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap441:10.1":{"pli":"Itthaṁ sudaṁ āyasmā ambapiṇḍiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap441:11.1":{"pli":"Ambapiṇḍiyattherassāpadānaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap442":{"tha-ap442:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap442'><header><ul><li class='division'>{}</li>"},"tha-ap442:0.2":{"pli":"Ekavihārivagga ","html":"<li>{}</li></ul>"},"tha-ap442:0.3":{"pli":"10 Ambaphaliyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap442:1.1":{"pli":"“Padumuttarabuddhassa, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap442:1.2":{"pli":"lokajeṭṭhassa tādino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap442:1.3":{"pli":"Piṇḍāya vicarantassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap442:1.4":{"pli":"dhārato uttamaṁ yasaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap442:2.1":{"pli":"Aggaphalaṁ gahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap442:2.2":{"pli":"vippasannena cetasā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap442:2.3":{"pli":"Dakkhiṇeyyassa vīrassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap442:2.4":{"pli":"adāsiṁ satthuno ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap442:3.1":{"pli":"Tena kammena dvipadinda, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap442:3.2":{"pli":"lokajeṭṭha narāsabha; ","html":"<span class='verse-line'>{}</span>"},"tha-ap442:3.3":{"pli":"Pattomhi acalaṁ ṭhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap442:3.4":{"pli":"hitvā jayaparājayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap442:4.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap442:4.2":{"pli":"yaṁ dānamadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap442:4.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap442:4.4":{"pli":"aggadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap442:5.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap442:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap442:5.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap442:6.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap442:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap442:6.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap442:7.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap442:7.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap442:7.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap442:8.1":{"pli":"Itthaṁ sudaṁ āyasmā ambaphaliyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap442:9.1":{"pli":"Ambaphaliyattherassāpadānaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap442:10.1":{"pli":"Ekavihārivaggo catucattālīsamo. ","html":"<p class='endsection'>{}</p>"},"tha-ap442:11.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"tha-ap442:12.1":{"pli":"Thero ekavihārī ca, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"tha-ap442:12.2":{"pli":"saṅkhiyo pāṭihīrako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap442:12.3":{"pli":"Thaviko ucch