{"tha-ap484":{"tha-ap484:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap484'><header><ul><li class='division'>{}</li>"},"tha-ap484:0.2":{"pli":"Paṁsukūlavagga ","html":"<li>{}</li></ul>"},"tha-ap484:0.3":{"pli":"Buddhasaññakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap484:1.1":{"pli":"“Ajjhāyako mantadharo, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap484:1.2":{"pli":"tiṇṇaṁ vedāna pāragū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:1.3":{"pli":"Lakkhaṇe itihāse ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:1.4":{"pli":"sanighaṇḍusakeṭubhe. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap484:2.1":{"pli":"Nadīsotapaṭibhāgā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap484:2.2":{"pli":"sissā āyanti me tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:2.3":{"pli":"Tesāhaṁ mante vācemi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:2.4":{"pli":"rattindivamatandito. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap484:3.1":{"pli":"Siddhattho nāma sambuddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap484:3.2":{"pli":"loke uppajji tāvade; ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:3.3":{"pli":"Tamandhakāraṁ nāsetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:3.4":{"pli":"ñāṇālokaṁ pavattayi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap484:4.1":{"pli":"Mama aññataro sisso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap484:4.2":{"pli":"sissānaṁ so kathesi me; ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:4.3":{"pli":"Sutvāna te etamatthaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:4.4":{"pli":"ārocesuṁ mamaṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap484:5.1":{"pli":"‘Buddho loke samuppanno, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap484:5.2":{"pli":"sabbaññū lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:5.3":{"pli":"Tassānuvattati jano, ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:5.4":{"pli":"lābho amhaṁ na vijjati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap484:6.1":{"pli":"Adhiccuppattikā buddhā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap484:6.2":{"pli":"cakkhumanto mahāyasā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:6.3":{"pli":"Yannūnāhaṁ buddhaseṭṭhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:6.4":{"pli":"passeyyaṁ lokanāyakaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap484:7.1":{"pli":"Ajinaṁ me gahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap484:7.2":{"pli":"vākacīraṁ kamaṇḍaluṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:7.3":{"pli":"Assamā abhinikkhamma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:7.4":{"pli":"sisse āmantayiṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap484:8.1":{"pli":"Odumbarikapupphaṁva, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap484:8.2":{"pli":"candamhi sasakaṁ yathā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:8.3":{"pli":"Vāyasānaṁ yathā khīraṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:8.4":{"pli":"dullabho lokanāyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap484:9.1":{"pli":"Buddho lokamhi uppanno, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap484:9.2":{"pli":"manussattampi dullabhaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:9.3":{"pli":"Ubhosu vijjamānesu, ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:9.4":{"pli":"savanañca sudullabhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap484:10.1":{"pli":"Buddho loke samuppanno, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap484:10.2":{"pli":"cakkhuṁ lacchāma no bhavaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:10.3":{"pli":"Etha sabbe gamissāma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:10.4":{"pli":"sammāsambuddhasantikaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap484:11.1":{"pli":"Kamaṇḍaludharā sabbe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap484:11.2":{"pli":"kharājinanivāsino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:11.3":{"pli":"Te jaṭā bhārabharitā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:11.4":{"pli":"nikkhamuṁ vipinā tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap484:12.1":{"pli":"Yugamattaṁ pekkhamānā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap484:12.2":{"pli":"uttamatthaṁ gavesino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:12.3":{"pli":"Āsattidosarahitā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:12.4":{"pli":"asambhītāva kesarī. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap484:13.1":{"pli":"Appakiccā aloluppā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap484:13.2":{"pli":"nipakā santavuttino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:13.3":{"pli":"Uñchāya caramānā te, ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:13.4":{"pli":"buddhaseṭṭhamupāgamuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap484:14.1":{"pli":"Diyaḍḍhayojane sese, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap484:14.2":{"pli":"byādhi me upapajjatha; ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:14.3":{"pli":"Buddhaseṭṭhaṁ saritvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:14.4":{"pli":"tattha kālaṅkato ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap484:15.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap484:15.2":{"pli":"yaṁ saññamalabhiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:15.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:15.4":{"pli":"buddhasaññāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap484:16.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap484:16.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:16.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap484:17.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap484:17.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:17.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap484:18.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap484:18.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap484:18.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap484:19.1":{"pli":"Itthaṁ sudaṁ āyasmā buddhasaññako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap484:20.1":{"pli":"Buddhasaññakattherassāpadānaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap485":{"tha-ap485:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap485'><header><ul><li class='division'>{}</li>"},"tha-ap485:0.2":{"pli":"Paṁsukūlavagga ","html":"<li>{}</li></ul>"},"tha-ap485:0.3":{"pli":"Bhisadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap485:1.1":{"pli":"“Ogayha yaṁ pokkharaṇiṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap485:1.2":{"pli":"nānākuñjarasevitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:1.3":{"pli":"Uddharāmi bhisaṁ tattha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:1.4":{"pli":"ghāsahetu ahaṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap485:2.1":{"pli":"Bhagavā tamhi samaye, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap485:2.2":{"pli":"padumuttarasavhayo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:2.3":{"pli":"Rattambaradharo buddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:2.4":{"pli":"gacchati anilañjase. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap485:3.1":{"pli":"Dhunanto paṁsukūlāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap485:3.2":{"pli":"saddamassosahaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:3.3":{"pli":"Uddhaṁ nijjhāyamānohaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:3.4":{"pli":"addasaṁ lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap485:4.1":{"pli":"Tattheva ṭhitako santo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap485:4.2":{"pli":"āyāciṁ lokanāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:4.3":{"pli":"‘Madhuṁ bhisehi savati, ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:4.4":{"pli":"khīraṁ sappiṁ muḷālibhi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap485:5.1":{"pli":"Paṭiggaṇhātu me buddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap485:5.2":{"pli":"anukampāya cakkhumā’; ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:5.3":{"pli":"Tato kāruṇiko satthā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:5.4":{"pli":"oruhitvā mahāyaso. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap485:6.1":{"pli":"Paṭiggaṇhi mamaṁ bhikkhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap485:6.2":{"pli":"anukampāya cakkhumā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:6.3":{"pli":"Paṭiggahetvā sambuddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:6.4":{"pli":"akā me anumodanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap485:7.1":{"pli":"‘Sukhī hotu mahāpuñña, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap485:7.2":{"pli":"gati tuyhaṁ samijjhatu; ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:7.3":{"pli":"Iminā bhisadānena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:7.4":{"pli":"labhassu vipulaṁ sukhaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap485:8.1":{"pli":"Idaṁ vatvāna sambuddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap485:8.2":{"pli":"jalajuttamanāmako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:8.3":{"pli":"Bhikkhamādāya sambuddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:8.4":{"pli":"ambarenāgamā jino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap485:9.1":{"pli":"Tato bhisaṁ gahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap485:9.2":{"pli":"āgacchiṁ mama assamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:9.3":{"pli":"Bhisaṁ rukkhe lagetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:9.4":{"pli":"mama dānamanussariṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap485:10.1":{"pli":"Mahāvāto vuṭṭhahitvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap485:10.2":{"pli":"sañcālesi vanaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:10.3":{"pli":"Ākāso abhinādittha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:10.4":{"pli":"asaniyā phalantiyā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap485:11.1":{"pli":"Tato me asanīpāto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap485:11.2":{"pli":"matthake nipatī tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:11.3":{"pli":"Sohaṁ nisinnako santo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:11.4":{"pli":"tattha kālaṅkato ahuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap485:12.1":{"pli":"Puññakammena saṁyutto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap485:12.2":{"pli":"tusitaṁ upapajjahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:12.3":{"pli":"Kaḷevaraṁ me patitaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:12.4":{"pli":"devaloke ramiṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap485:13.1":{"pli":"Chaḷasītisahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap485:13.2":{"pli":"nāriyo samalaṅkatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:13.3":{"pli":"Sāyaṁ pātaṁ upaṭṭhanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:13.4":{"pli":"bhisadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap485:14.1":{"pli":"Manussayonimāgantvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap485:14.2":{"pli":"sukhito homahaṁ sadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:14.3":{"pli":"Bhoge me ūnatā natthi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:14.4":{"pli":"bhisadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap485:15.1":{"pli":"Anukampitako tena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap485:15.2":{"pli":"devadevena tādinā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:15.3":{"pli":"Sabbāsavā parikkhīṇā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:15.4":{"pli":"natthi dāni punabbhavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap485:16.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap485:16.2":{"pli":"yaṁ bhisaṁ adadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:16.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:16.4":{"pli":"bhisadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap485:17.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap485:17.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:17.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap485:18.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap485:18.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:18.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap485:19.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap485:19.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap485:19.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap485:20.1":{"pli":"Itthaṁ sudaṁ āyasmā bhisadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap485:21.1":{"pli":"Bhisadāyakattherassāpadānaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap486":{"tha-ap486:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap486'><header><ul><li class='division'>{}</li>"},"tha-ap486:0.2":{"pli":"Paṁsukūlavagga ","html":"<li>{}</li></ul>"},"tha-ap486:0.3":{"pli":"4 Ñāṇathavikattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap486:1.1":{"pli":"“Dakkhiṇe himavantassa, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap486:1.2":{"pli":"sukato assamo mama; ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:1.3":{"pli":"Uttamatthaṁ gavesanto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:1.4":{"pli":"vasāmi vipine tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap486:2.1":{"pli":"Lābhālābhena santuṭṭho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap486:2.2":{"pli":"mūlena ca phalena ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:2.3":{"pli":"Anvesanto ācariyaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:2.4":{"pli":"vasāmi ekako ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap486:3.1":{"pli":"Sumedho nāma sambuddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap486:3.2":{"pli":"loke uppajji tāvade; ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:3.3":{"pli":"Catusaccaṁ pakāseti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:3.4":{"pli":"uddharanto mahājanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap486:4.1":{"pli":"Nāhaṁ suṇomi sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap486:4.2":{"pli":"napi me koci saṁsati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:4.3":{"pli":"Aṭṭhavasse atikkante, ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:4.4":{"pli":"assosiṁ lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap486:5.1":{"pli":"Aggidāruṁ nīharitvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap486:5.2":{"pli":"sammajjitvāna assamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:5.3":{"pli":"Khāribhāraṁ gahetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:5.4":{"pli":"nikkhamiṁ vipinā ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap486:6.1":{"pli":"Ekarattiṁ vasantohaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap486:6.2":{"pli":"gāmesu nigamesu ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:6.3":{"pli":"Anupubbena candavatiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:6.4":{"pli":"tadāhaṁ upasaṅkamiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap486:7.1":{"pli":"Bhagavā tamhi samaye, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap486:7.2":{"pli":"sumedho lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:7.3":{"pli":"Uddharanto bahū satte, ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:7.4":{"pli":"deseti amataṁ padaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap486:8.1":{"pli":"Janakāyamatikkamma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap486:8.2":{"pli":"vanditvā jinasāgaraṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:8.3":{"pli":"Ekaṁsaṁ ajinaṁ katvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:8.4":{"pli":"santhaviṁ lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap486:9.1":{"pli":"‘Tuvaṁ satthā ca ketu ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap486:9.2":{"pli":"dhajo yūpo ca pāṇinaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:9.3":{"pli":"Parāyaṇo patiṭṭhā ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:9.4":{"pli":"dīpo ca dvipaduttamo. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap486:10.1":{"pli":"Ekavīsatimaṁ bhāṇavāraṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap486:11.1":{"pli":"Nepuñño dassane vīro, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap486:11.2":{"pli":"tāresi janataṁ tuvaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:11.3":{"pli":"Natthañño tārako loke, ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:11.4":{"pli":"tavuttaritaro mune. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap486:12.1":{"pli":"Sakkā theve kusaggena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap486:12.2":{"pli":"pametuṁ sāgaruttame; ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:12.3":{"pli":"Na tveva tava sabbaññu, ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:12.4":{"pli":"ñāṇaṁ sakkā pametave. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap486:13.1":{"pli":"Tuladaṇḍe ṭhapetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap486:13.2":{"pli":"mahiṁ sakkā dharetave; ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:13.3":{"pli":"Na tveva tava paññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:13.4":{"pli":"pamāṇamatthi cakkhuma. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap486:14.1":{"pli":"Ākāso minituṁ sakkā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap486:14.2":{"pli":"rajjuyā aṅgulena vā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:14.3":{"pli":"Na tveva tava sabbaññu, ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:14.4":{"pli":"sīlaṁ sakkā pametave. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap486:15.1":{"pli":"Mahāsamudde udakaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap486:15.2":{"pli":"ākāso ca vasundharā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:15.3":{"pli":"Parimeyyāni etāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:15.4":{"pli":"appameyyosi cakkhuma’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap486:16.1":{"pli":"Chahi gāthāhi sabbaññuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap486:16.2":{"pli":"kittayitvā mahāyasaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:16.3":{"pli":"Añjaliṁ paggahetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:16.4":{"pli":"tuṇhī aṭṭhāsahaṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap486:17.1":{"pli":"Yaṁ vadanti sumedhoti, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap486:17.2":{"pli":"bhūripaññaṁ sumedhasaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:17.3":{"pli":"Bhikkhusaṅghe nisīditvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:17.4":{"pli":"imā gāthā abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap486:18.1":{"pli":"‘Yo me ñāṇaṁ pakittesi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap486:18.2":{"pli":"vippasannena cetasā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:18.3":{"pli":"Tamahaṁ kittayissāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:18.4":{"pli":"suṇātha mama bhāsato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap486:19.1":{"pli":"Sattasattati kappāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap486:19.2":{"pli":"devaloke ramissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:19.3":{"pli":"Sahassakkhattuṁ devindo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:19.4":{"pli":"devarajjaṁ karissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap486:20.1":{"pli":"Anekasatakkhattuñca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap486:20.2":{"pli":"cakkavattī bhavissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:20.3":{"pli":"Padesarajjaṁ vipulaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:20.4":{"pli":"gaṇanāto asaṅkhiyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap486:21.1":{"pli":"Devabhūto manusso vā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap486:21.2":{"pli":"puññakammasamāhito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:21.3":{"pli":"Anūnamanasaṅkappo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:21.4":{"pli":"tikkhapañño bhavissati’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap486:22.1":{"pli":"Tiṁsakappasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap486:22.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:22.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:22.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap486:23.1":{"pli":"Agārā abhinikkhamma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap486:23.2":{"pli":"pabbajissatikiñcano; ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:23.3":{"pli":"Jātiyā sattavassena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:23.4":{"pli":"arahattaṁ phusissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap486:24.1":{"pli":"Yato sarāmi attānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap486:24.2":{"pli":"yato pattosmi sāsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:24.3":{"pli":"Etthantare na jānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:24.4":{"pli":"cetanaṁ amanoramaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap486:25.1":{"pli":"Saṁsaritvā bhave sabbe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap486:25.2":{"pli":"sampattānubhaviṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:25.3":{"pli":"Bhoge me ūnatā natthi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:25.4":{"pli":"phalaṁ ñāṇassa thomane. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap486:26.1":{"pli":"Tiyaggī nibbutā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap486:26.2":{"pli":"bhavā sabbe samūhatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:26.3":{"pli":"Sabbāsavā parikkhīṇā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:26.4":{"pli":"natthi dāni punabbhavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap486:27.1":{"pli":"Tiṁsakappasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap486:27.2":{"pli":"yaṁ ñāṇamathaviṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:27.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:27.4":{"pli":"phalaṁ ñāṇassa thomane. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap486:28.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap486:28.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:28.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap486:29.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap486:29.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:29.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap486:30.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap486:30.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap486:30.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap486:31.1":{"pli":"Itthaṁ sudaṁ āyasmā ñāṇathaviko thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap486:32.1":{"pli":"Ñāṇathavikattherassāpadānaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap487":{"tha-ap487:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap487'><header><ul><li class='division'>{}</li>"},"tha-ap487:0.2":{"pli":"Paṁsukūlavagga ","html":"<li>{}</li></ul>"},"tha-ap487:0.3":{"pli":"Candanamāliyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap487:1.1":{"pli":"“Pañca kāmaguṇe hitvā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap487:1.2":{"pli":"piyarūpe manorame; ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:1.3":{"pli":"Asītikoṭiyo hitvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:1.4":{"pli":"pabbajiṁ anagāriyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap487:2.1":{"pli":"Pabbajitvāna kāyena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap487:2.2":{"pli":"pāpakammaṁ vivajjayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:2.3":{"pli":"Vacīduccaritaṁ hitvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:2.4":{"pli":"nadīkūle vasāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap487:3.1":{"pli":"Ekakaṁ maṁ viharantaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap487:3.2":{"pli":"buddhaseṭṭho upāgami; ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:3.3":{"pli":"Nāhaṁ jānāmi buddhoti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:3.4":{"pli":"akāsiṁ paṭisanthāraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap487:4.1":{"pli":"Karitvā paṭisanthāraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap487:4.2":{"pli":"nāmagottamapucchahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:4.3":{"pli":"‘Devatānusi gandhabbo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:4.4":{"pli":"adu sakko purindado. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap487:5.1":{"pli":"Ko vā tvaṁ kassa vā putto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap487:5.2":{"pli":"mahābrahmā idhāgato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:5.3":{"pli":"Virocesi disā sabbā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:5.4":{"pli":"udayaṁ sūriyo yathā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap487:6.1":{"pli":"Sahassārāni cakkāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap487:6.2":{"pli":"pāde dissanti mārisa; ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:6.3":{"pli":"Ko vā tvaṁ kassa vā putto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:6.4":{"pli":"kathaṁ jānemu taṁ mayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:6.5":{"pli":"Nāmagottaṁ pavedehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:6.6":{"pli":"saṁsayaṁ apanehi me. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap487:7.1":{"pli":"Namhi devo na gandhabbo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap487:7.2":{"pli":"namhi sakko purindado; ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:7.3":{"pli":"Brahmabhāvo ca me natthi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:7.4":{"pli":"etesaṁ uttamo ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap487:8.1":{"pli":"Atīto visayaṁ tesaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap487:8.2":{"pli":"dālayiṁ kāmabandhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:8.3":{"pli":"Sabbe kilese jhāpetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:8.4":{"pli":"patto sambodhimuttamaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap487:9.1":{"pli":"Tassa vācaṁ suṇitvāhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap487:9.2":{"pli":"idaṁ vacanamabraviṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:9.3":{"pli":"‘Yadi buddhoti sabbaññū, ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:9.4":{"pli":"nisīda tvaṁ mahāmune. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap487:10.1":{"pli":"Tamahaṁ pūjayissāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap487:10.2":{"pli":"dukkhassantakaro tuvaṁ’; ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:10.3":{"pli":"Pattharitvā jinacammaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:10.4":{"pli":"adāsi satthuno ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap487:11.1":{"pli":"Nisīdi tattha bhagavā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap487:11.2":{"pli":"sīhova girigabbhare; ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:11.3":{"pli":"Khippaṁ pabbatamāruyha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:11.4":{"pli":"ambassa phalamaggahiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap487:12.1":{"pli":"Sālakalyāṇikaṁ pupphaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap487:12.2":{"pli":"Candanañca mahārahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:12.3":{"pli":"Khippaṁ paggayha taṁ sabbaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:12.4":{"pli":"Upetvā lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap487:13.1":{"pli":"Phalaṁ buddhassa datvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap487:13.2":{"pli":"sālapupphamapūjayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:13.3":{"pli":"Candanaṁ anulimpitvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:13.4":{"pli":"avandiṁ satthuno ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap487:14.1":{"pli":"Pasannacitto sumano, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap487:14.2":{"pli":"vipulāya ca pītiyā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:14.3":{"pli":"Ajinamhi nisīditvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:14.4":{"pli":"sumedho lokanāyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap487:15.1":{"pli":"Mama kammaṁ pakittesi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap487:15.2":{"pli":"hāsayanto mamaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:15.3":{"pli":"‘Iminā phaladānena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:15.4":{"pli":"gandhamālehi cūbhayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap487:16.1":{"pli":"Pañcavīse kappasate, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap487:16.2":{"pli":"devaloke ramissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:16.3":{"pli":"Anūnamanasaṅkappo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:16.4":{"pli":"vasavattī bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap487:17.1":{"pli":"Chabbīsatikappasate, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap487:17.2":{"pli":"manussattaṁ gamissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:17.3":{"pli":"Bhavissati cakkavattī, ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:17.4":{"pli":"cāturanto mahiddhiko. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap487:18.1":{"pli":"Vebhāraṁ nāma nagaraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap487:18.2":{"pli":"vissakammena māpitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:18.3":{"pli":"Hessati sabbasovaṇṇaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:18.4":{"pli":"nānāratanabhūsitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap487:19.1":{"pli":"Eteneva upāyena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap487:19.2":{"pli":"saṁsarissati so bhave; ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:19.3":{"pli":"Sabbattha pūjito hutvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:19.4":{"pli":"devatte atha mānuse. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap487:20.1":{"pli":"Pacchime bhave sampatte, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap487:20.2":{"pli":"brahmabandhu bhavissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:20.3":{"pli":"Agārā abhinikkhamma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:20.4":{"pli":"anagārī bhavissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:20.5":{"pli":"Abhiññāpāragū hutvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:20.6":{"pli":"nibbāyissatināsavo’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap487:21.1":{"pli":"Idaṁ vatvāna sambuddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap487:21.2":{"pli":"sumedho lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:21.3":{"pli":"Mama nijjhāyamānassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:21.4":{"pli":"pakkāmi anilañjase. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap487:22.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap487:22.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:22.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:22.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap487:23.1":{"pli":"Tusitato cavitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap487:23.2":{"pli":"nibbattiṁ mātukucchiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:23.3":{"pli":"Bhoge me ūnatā natthi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:23.4":{"pli":"yamhi gabbhe vasāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap487:24.1":{"pli":"Mātukucchigate mayi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap487:24.2":{"pli":"annapānañca bhojanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:24.3":{"pli":"Mātuyā mama chandena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:24.4":{"pli":"nibbattati yadicchakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap487:25.1":{"pli":"Jātiyā pañcavassena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap487:25.2":{"pli":"pabbajiṁ anagāriyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:25.3":{"pli":"Oropitamhi kesamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:25.4":{"pli":"arahattamapāpuṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap487:26.1":{"pli":"Pubbakammaṁ gavesanto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap487:26.2":{"pli":"orena nāddasaṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:26.3":{"pli":"Tiṁsakappasahassamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:26.4":{"pli":"mama kammamanussariṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap487:27.1":{"pli":"Namo te purisājañña, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap487:27.2":{"pli":"namo te purisuttama; ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:27.3":{"pli":"Tava sāsanamāgamma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:27.4":{"pli":"pattomhi acalaṁ padaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap487:28.1":{"pli":"Tiṁsakappasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap487:28.2":{"pli":"yaṁ buddhamabhipūjayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:28.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:28.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap487:29.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap487:29.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:29.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap487:30.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap487:30.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:30.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap487:31.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap487:31.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap487:31.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap487:32.1":{"pli":"Itthaṁ sudaṁ āyasmā candanamāliyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap487:33.1":{"pli":"Candanamāliyattherassāpadānaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap488":{"tha-ap488:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap488'><header><ul><li class='division'>{}</li>"},"tha-ap488:0.2":{"pli":"Paṁsukūlavagga ","html":"<li>{}</li></ul>"},"tha-ap488:0.3":{"pli":"Dhātupūjakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap488:1.1":{"pli":"“Nibbute lokanāthamhi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap488:1.2":{"pli":"siddhatthe lokanāyake; ","html":"<span class='verse-line'>{}</span>"},"tha-ap488:1.3":{"pli":"Mama ñātī samānetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap488:1.4":{"pli":"dhātupūjaṁ akāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap488:2.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap488:2.2":{"pli":"yaṁ dhātumabhipūjayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap488:2.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap488:2.4":{"pli":"dhātupūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap488:3.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap488:3.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap488:3.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap488:4.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap488:4.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap488:4.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap488:5.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap488:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap488:5.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap488:6.1":{"pli":"Itthaṁ sudaṁ āyasmā dhātupūjako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap488:7.1":{"pli":"Dhātupūjakattherassāpadānaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}