{"ja536":{"ja536:0.1":{"pli":"Jātaka ","html":"<article id='ja536'><header><ul><li class='division'>{}</li>"},"ja536:0.2":{"pli":"Asītinipāta ","html":"<li>{}</li>"},"ja536:0.3":{"pli":"Cūḷahaṁsavagga ","html":"<li>{}</li></ul>"},"ja536:0.4":{"pli":"4. Kuṇālajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja536:1.1":{"pli":"Evamakkhāyati, evamanusūyati. ","html":"<p>{}"},"ja536:1.2":{"pli":"Sabbosadhadharaṇidhare nekapupphamālyavitate gajagavajamahiṁsarurucamarapasadakhaggagokaṇṇasīhabyagghadīpiacchakokataracchauddārakadalimigabiḷārasasakaṇṇikānucarite ākiṇṇanelamaṇḍalamahāvarāhanāgakulakareṇusaṅghādhivuṭṭhe issamigasākhamigasarabhamigaeṇīmigavātamigapasadamigapurisālukimpurisayakkharakkhasanisevite amajjavamañjarīdharapahaṭṭhapupphaphusitaggānekapādapagaṇavitate kuraracakoravāraṇamayūraparabhatajīvañjīvakacelāvakābhiṅkārakaravīkamattavihaṅgagaṇasatatasampaghuṭṭhe añjanamanosilāharitālahiṅgulakahemarajatakanakānekadhātusatavinaddhapaṭimaṇḍitappadese evarūpe khalu, bho, ramme vanasaṇḍe kuṇālo nāma sakuṇo paṭivasati ativiya citto ativiya cittapattacchadano. ","html":"{}</p>"},"ja536:2.1":{"pli":"Tasseva khalu, bho, kuṇālassa sakuṇassa aḍḍhuḍḍhāni itthisahassāni paricārikā dijakaññāyo, atha khalu, bho, dve dijakaññāyo kaṭṭhaṁ mukhena ḍaṁsitvā taṁ kuṇālaṁ sakuṇaṁ majjhe nisīdāpetvā uḍḍenti—","html":"<p>{}"},"ja536:2.2":{"pli":"“mā naṁ kuṇālaṁ sakuṇaṁ addhānapariyāyapathe kilamatho ubbāhetthā”ti. ","html":"{}</p>"},"ja536:3.1":{"pli":"Pañcasatā dijakaññāyo heṭṭhato heṭṭhato uḍḍenti—","html":"<p>{}"},"ja536:3.2":{"pli":"“sacāyaṁ kuṇālo sakuṇo āsanā paripatissati, mayaṁ taṁ pakkhehi paṭiggahessāmā”ti. ","html":"{}</p>"},"ja536:4.1":{"pli":"Pañcasatā dijakaññāyo uparūpari uḍḍenti—","html":"<p>{}"},"ja536:4.2":{"pli":"“mā naṁ kuṇālaṁ sakuṇaṁ ātapo paritāpesī”ti. ","html":"{}</p>"},"ja536:5.1":{"pli":"Pañcasatā pañcasatā dijakaññāyo ubhatopassena uḍḍenti—","html":"<p>{}"},"ja536:5.2":{"pli":"“mā naṁ kuṇālaṁ sakuṇaṁ sītaṁ vā uṇhaṁ vā tiṇaṁ vā rajo vā vāto vā ussāvo vā upapphusī”ti. ","html":"{}</p>"},"ja536:6.1":{"pli":"Pañcasatā dijakaññāyo purato purato uḍḍenti—","html":"<p>{}"},"ja536:6.2":{"pli":"“mā naṁ kuṇālaṁ sakuṇaṁ gopālakā vā pasupālakā vā tiṇahārakā vā kaṭṭhahārakā vā vanakammikā vā kaṭṭhena vā kaṭhalena vā pāṇinā vā (…) leḍḍunā vā daṇḍena vā satthena vā sakkharāhi vā pahāraṁ adaṁsu. ","html":"{}"},"ja536:6.3":{"pli":"Māyaṁ kuṇālo sakuṇo gacchehi vā latāhi vā rukkhehi vā sākhāhi vā thambhehi vā pāsāṇehi vā balavantehi vā pakkhīhi saṅgamesī”ti. ","html":"{}</p>"},"ja536:7.1":{"pli":"Pañcasatā dijakaññāyo pacchato pacchato uḍḍenti saṇhāhi sakhilāhi mañjūhi madhurāhi vācāhi samudācarantiyo—","html":"<p>{}"},"ja536:7.2":{"pli":"“māyaṁ kuṇālo sakuṇo āsane pariyukkaṇṭhī”ti. ","html":"{}</p>"},"ja536:8.1":{"pli":"Pañcasatā dijakaññāyo disodisaṁ uḍḍenti anekarukkhavividhavikatiphalamāharantiyo—","html":"<p>{}"},"ja536:8.2":{"pli":"“māyaṁ kuṇālo sakuṇo khudāya parikilamitthā”ti. ","html":"{}</p>"},"ja536:9.1":{"pli":"Atha khalu, bho, tā dijakaññāyo taṁ kuṇālaṁ sakuṇaṁ ārāmeneva ārāmaṁ uyyāneneva uyyānaṁ nadītittheneva nadītitthaṁ pabbatasikhareneva pabbatasikharaṁ ambavaneneva ambavanaṁ jambuvaneneva jambuvanaṁ labujavaneneva labujavanaṁ nāḷikerasañcāriyeneva nāḷikerasañcāriyaṁ khippameva abhisambhonti ratitthāya. ","html":"<p>{}</p>"},"ja536:10.1":{"pli":"Atha khalu, bho, kuṇālo sakuṇo tāhi dijakaññāhi divasaṁ paribyūḷho evaṁ apasādeti—","html":"<p>{}"},"ja536:10.2":{"pli":"“nassatha tumhe vasaliyo, vinassatha tumhe vasaliyo, coriyo dhuttiyo asatiyo lahucittāyo katassa appaṭikārikāyo anilo viya yenakāmaṅgamāyo”ti. ","html":"{}</p>"},"ja536:11.1":{"pli":"Tasseva khalu, bho, himavato pabbatarājassa puratthimadisābhāge susukhumasunipuṇagirippabhava—","html":"<p>{}"},"ja536:11.2":{"pli":"haritupayantiyo. ","html":"{}</p>"},"ja536:12.1":{"pli":"Uppala paduma kumuda nalina satapatta sogandhika mandālaka sampativirūḷhasucigandhamanuññamāvakappadese. ","html":"<p>{}</p>"},"ja536:13.1":{"pli":"Kuravakamucalindaketakavedisavañjulapunnāgabakulatilakapiyakahasanasālasaḷalacampakaasokanāgarukkhatirīṭibhujapattaloddacandanoghavane kāḷāgarupadmakapiyaṅgudevadārukacocagahane kakudhakuṭajaaṅkolakaccikārakaṇikārakaṇṇikārakanaverakoraṇḍakakoviḷārakiṁsukayodhikavanamallikamanaṅgaṇamanavajjabhaṇḍisurucirabhaginimālāmalyadhare jātisumanamadhugandhikadhanutakkāritālīsatagaramusīrakoṭṭhakacchavitate atimuttakasaṅkusumitalatāvitatapaṭimaṇḍitappadese haṁsapilavakādambakāraṇḍavābhinadite vijjādharasiddhasamaṇatāpasagaṇādhivuṭṭhe varadevayakkharakkhasadānavagandhabbakinnaramahoragānuciṇṇappadese evarūpe khalu, bho, ramme vanasaṇḍe puṇṇamukho nāma phussakokilo paṭivasati ativiya madhuragiro vilāsitanayano mattakkho. ","html":"<p>{}</p>"},"ja536:14.1":{"pli":"Tasseva khalu, bho, puṇṇamukhassa phussakokilassa aḍḍhuḍḍhāni itthisatāni paricārikā dijakaññāyo. ","html":"<p>{}"},"ja536:14.2":{"pli":"Atha khalu, bho, dve dijakaññāyo kaṭṭhaṁ mukhena ḍaṁsitvā taṁ puṇṇamukhaṁ phussakokilaṁ majjhe nisīdāpetvā uḍḍenti—","html":"{}"},"ja536:14.3":{"pli":"“mā naṁ puṇṇamukhaṁ phussakokilaṁ addhānapariyāyapathe kilamatho ubbāhetthā”ti. ","html":"{}</p>"},"ja536:15.1":{"pli":"Paññāsa dijakaññāyo heṭṭhato heṭṭhato uḍḍenti—","html":"<p>{}"},"ja536:15.2":{"pli":"“sacāyaṁ puṇṇamukho phussakokilo āsanā paripatissati, mayaṁ taṁ pakkhehi paṭiggahessāmā”ti. ","html":"{}</p>"},"ja536:16.1":{"pli":"Paññāsa dijakaññāyo uparūpari uḍḍenti—","html":"<p>{}"},"ja536:16.2":{"pli":"“mā naṁ puṇṇamukhaṁ phussakokilaṁ ātapo paritāpesī”ti. ","html":"{}</p>"},"ja536:17.1":{"pli":"Paññāsa paññāsa dijakaññāyo ubhatopassena uḍḍenti—","html":"<p>{}"},"ja536:17.2":{"pli":"“mā naṁ puṇṇamukhaṁ phussakokilaṁ sītaṁ vā uṇhaṁ vā tiṇaṁ vā rajo vā vāto vā ussāvo vā upapphusī”ti. ","html":"{}</p>"},"ja536:18.1":{"pli":"Paññāsa dijakaññāyo purato purato uḍḍenti—","html":"<p>{}"},"ja536:18.2":{"pli":"“mā naṁ puṇṇamukhaṁ phussakokilaṁ gopālakā vā pasupālakā vā tiṇahārakā vā kaṭṭhahārakā vā vanakammikā vā kaṭṭhena vā kaṭhalena vā pāṇinā vā leḍḍunā vā daṇḍena vā satthena vā sakkharāhi vā pahāraṁ adaṁsu. ","html":"{}"},"ja536:18.3":{"pli":"Māyaṁ puṇṇamukho phussakokilo gacchehi vā latāhi vā rukkhehi vā sākhāhi vā thambhehi vā pāsāṇehi vā balavantehi vā pakkhīhi saṅgamesī”ti. ","html":"{}</p>"},"ja536:19.1":{"pli":"Paññāsa dijakaññāyo pacchato pacchato uḍḍenti saṇhāhi sakhilāhi mañjūhi madhurāhi vācāhi samudācarantiyo—","html":"<p>{}"},"ja536:19.2":{"pli":"“māyaṁ puṇṇamukho phussakokilo āsane pariyukkaṇṭhī”ti. ","html":"{}</p>"},"ja536:20.1":{"pli":"Paññāsa dijakaññāyo disodisaṁ uḍḍenti anekarukkhavividhavikatiphalamāharantiyo—","html":"<p>{}"},"ja536:20.2":{"pli":"“māyaṁ puṇṇamukho phussakokilo khudāya parikilamitthā”ti. ","html":"{}</p>"},"ja536:21.1":{"pli":"Atha khalu, bho, tā dijakaññāyo taṁ puṇṇamukhaṁ phussakokilaṁ ārāmeneva ārāmaṁ uyyāneneva uyyānaṁ nadītittheneva nadītitthaṁ pabbatasikhareneva pabbatasikharaṁ ambavaneneva ambavanaṁ jambuvaneneva jambuvanaṁ labujavaneneva labujavanaṁ nāḷikerasañcāriyeneva nāḷikerasañcāriyaṁ khippameva abhisambhonti ratitthāya. ","html":"<p>{}</p>"},"ja536:22.1":{"pli":"Atha khalu, bho, puṇṇamukho phussakokilo tāhi dijakaññāhi divasaṁ paribyūḷho evaṁ pasaṁsati—","html":"<p>{}"},"ja536:22.2":{"pli":"“sādhu sādhu, bhaginiyo, etaṁ kho, bhaginiyo, tumhākaṁ patirūpaṁ kuladhītānaṁ, yaṁ tumhe bhattāraṁ paricareyyāthā”ti. ","html":"{}</p>"},"ja536:23.1":{"pli":"Atha khalu, bho, puṇṇamukho phussakokilo yena kuṇālo sakuṇo tenupasaṅkami. ","html":"<p>{}"},"ja536:23.2":{"pli":"Addasaṁsu kho kuṇālassa sakuṇassa paricārikā dijakaññāyo taṁ puṇṇamukhaṁ phussakokilaṁ dūratova āgacchantaṁ; ","html":"{}"},"ja536:23.3":{"pli":"disvāna yena puṇṇamukho phussakokilo tenupasaṅkamiṁsu; upasaṅkamitvā taṁ puṇṇamukhaṁ phussakokilaṁ etadavocuṁ—","html":"{}"},"ja536:23.4":{"pli":"“ayaṁ, samma puṇṇamukha, kuṇālo sakuṇo ativiya pharuso ativiya pharusavāco, appevanāma tavampi āgamma piyavācaṁ labheyyāmā”ti. ","html":"{}"},"ja536:23.5":{"pli":"“Appevanāma, bhaginiyo”ti vatvā yena kuṇālo sakuṇo tenupasaṅkami; upasaṅkamitvā kuṇālena sakuṇena saddhiṁ paṭisammoditvā ekamantaṁ nisīdi. ","html":"{}"},"ja536:23.6":{"pli":"Ekamantaṁ nisinno kho puṇṇamukho phussakokilo taṁ kuṇālaṁ sakuṇaṁ etadavoca—","html":"{}"},"ja536:23.7":{"pli":"“kissa tvaṁ, samma kuṇāla, itthīnaṁ sujātānaṁ kuladhītānaṁ sammāpaṭipannānaṁ micchāpaṭipannosi? ","html":"{}"},"ja536:23.8":{"pli":"Amanāpabhāṇīnampi kira, samma kuṇāla, itthīnaṁ manāpabhāṇinā bhavitabbaṁ, kimaṅga pana manāpabhāṇīnan”ti. ","html":"{}</p>"},"ja536:24.1":{"pli":"Evaṁ vutte, kuṇālo sakuṇo taṁ puṇṇamukhaṁ phussakokilaṁ evaṁ apasādesi—","html":"<p>{}"},"ja536:24.2":{"pli":"“nassa tvaṁ, samma jamma vasala, vinassa tvaṁ, samma jamma vasala, ko nu tayā viyatto jāyājinenā”ti. ","html":"{}"},"ja536:24.3":{"pli":"Evaṁ apasādito ca pana puṇṇamukho phussakokilo tatoyeva paṭinivatti. ","html":"{}</p>"},"ja536:25.1":{"pli":"Atha khalu, bho, puṇṇamukhassa phussakokilassa aparena samayena nacirasseva kharo ābādho uppajji lohitapakkhandikā bāḷhā vedanā vattanti māraṇantikā. ","html":"<p>{}"},"ja536:25.2":{"pli":"Atha khalu, bho, puṇṇamukhassa phussakokilassa paricārikānaṁ dijakaññānaṁ etadahosi—","html":"{}"},"ja536:25.3":{"pli":"“ābādhiko kho ayaṁ puṇṇamukho phussakokilo, appevanāma imamhā ābādhā vuṭṭhaheyyā”ti ekaṁ adutiyaṁ ohāya yena kuṇālo sakuṇo tenupasaṅkamiṁsu. ","html":"{}"},"ja536:25.4":{"pli":"Addasā kho kuṇālo sakuṇo tā dijakaññāyo dūratova āgacchantiyo, disvāna tā dijakaññāyo etadavoca—","html":"{}"},"ja536:25.5":{"pli":"“kahaṁ pana tumhaṁ vasaliyo bhattā”ti? ","html":"{}"},"ja536:25.6":{"pli":"“Ābādhiko kho, samma kuṇāla, puṇṇamukho phussakokilo appevanāma tamhā ābādhā vuṭṭhaheyyā”ti. ","html":"{}"},"ja536:25.7":{"pli":"Evaṁ vutte, kuṇālo sakuṇo tā dijakaññāyo evaṁ apasādesi—","html":"{}"},"ja536:25.8":{"pli":"“nassatha tumhe vasaliyo, vinassatha tumhe vasaliyo, coriyo dhuttiyo asatiyo lahucittāyo katassa appaṭikārikāyo anilo viya yenakāmaṅgamāyo”ti; ","html":"{}"},"ja536:25.9":{"pli":"vatvā yena puṇṇamukho phussakokilo tenupasaṅkami; upasaṅkamitvā taṁ puṇṇamukhaṁ phussakokilaṁ etadavoca—","html":"{}"},"ja536:25.10":{"pli":"“haṁ, samma, puṇṇamukhā”ti. ","html":"{}"},"ja536:25.11":{"pli":"“Haṁ, samma, kuṇālā”ti. ","html":"{}</p>"},"ja536:26.1":{"pli":"Atha khalu, bho kuṇālo sakuṇo taṁ puṇṇamukhaṁ phussakokilaṁ pakkhehi ca mukhatuṇḍakena ca pariggahetvā vuṭṭhāpetvā nānābhesajjāni pāyāpesi. ","html":"<p>{}"},"ja536:26.2":{"pli":"Atha khalu, bho, puṇṇamukhassa phussakokilassa so ābādho paṭippassambhīti. ","html":"{}"},"ja536:26.3":{"pli":"Atha khalu, bho, kuṇālo sakuṇo taṁ puṇṇamukhaṁ phussakokilaṁ gilānavuṭṭhitaṁ aciravuṭṭhitaṁ gelaññā etadavoca—","html":"{}</p>"},"ja536:27.1":{"pli":"“Diṭṭhā mayā, samma puṇṇamukha, kaṇhā dvepitikā pañcapatikāya chaṭṭhe purise cittaṁ paṭibandhantiyā, yadidaṁ kabandhe pīṭhasappimhī”ti. ","html":"<p>{}"},"ja536:27.2":{"pli":"Bhavati ca panuttarettha vākyaṁ—","html":"{}</p>"},"ja536:28.1":{"pli":"“Athajjuno nakulo bhīmaseno, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja536:28.2":{"pli":"Yudhiṭṭhilo sahadevo ca rājā; ","html":"<span class='verse-line'>{}</span>"},"ja536:28.3":{"pli":"Ete patī pañca maticca nārī, ","html":"<span class='verse-line'>{}</span>"},"ja536:28.4":{"pli":"Akāsi khujjavāmanakena pāpanti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja536:29.1":{"pli":"Diṭṭhā mayā, samma puṇṇamukha, saccatapāpī nāma samaṇī susānamajjhe vasantī catutthabhattaṁ pariṇāmayamānā surādhuttakena pāpamakāsi. ","html":"<p>{}</p>"},"ja536:30.1":{"pli":"Diṭṭhā mayā, samma puṇṇamukha, kākavatī nāma devī samuddamajjhe vasantī bhariyā venateyyassa naṭakuverena pāpamakāsi. ","html":"<p>{}</p>"},"ja536:31.1":{"pli":"Diṭṭhā mayā, samma puṇṇamukha, kuruṅgadevī nāma lomasuddarī eḷikakumāraṁ kāmayamānā chaḷaṅgakumāradhanantevāsinā pāpamakāsi. ","html":"<p>{}</p>"},"ja536:32.1":{"pli":"Evañhetaṁ mayā ñātaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja536:32.2":{"pli":"Brahmadattassa mātaraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja536:32.3":{"pli":"Ohāya kosalarājaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja536:32.4":{"pli":"Pañcālacaṇḍena pāpamakāsi. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:33.1":{"pli":"Etā ca aññā ca akaṁsu pāpaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:33.2":{"pli":"Tasmāhamitthīnaṁ na vissase nappasaṁse; ","html":"<span class='verse-line'>{}</span>"},"ja536:33.3":{"pli":"Mahī yathā jagati samānarattā, ","html":"<span class='verse-line'>{}</span>"},"ja536:33.4":{"pli":"Vasundharā itarītarā patiṭṭhā; ","html":"<span class='verse-line'>{}</span>"},"ja536:33.5":{"pli":"Sabbasahā aphandanā akuppā, ","html":"<span class='verse-line'>{}</span>"},"ja536:33.6":{"pli":"Tathitthiyo tāyo na vissase naro. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:34.1":{"pli":"Sīho yathā lohitamaṁsabhojano, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:34.2":{"pli":"Vāḷamigo pañcāvudho suruddho; ","html":"<span class='verse-line'>{}</span>"},"ja536:34.3":{"pli":"Pasayhakhādī parahiṁsane rato, ","html":"<span class='verse-line'>{}</span>"},"ja536:34.4":{"pli":"Tathitthiyo tāyo na vissase naro. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja536:35.1":{"pli":"Na khalu, samma puṇṇamukha, vesiyo nāriyo gamaniyo, na hetā bandhakiyo nāma, vadhikāyo nāma etāyo, yadidaṁ vesiyo nāriyo gamaniyoti. ","html":"<p>{}</p>"},"ja536:36.1":{"pli":"Coro viya veṇikatā, madirāva diddhā vāṇijo viya vācāsanthutiyo, issasiṅghamiva viparivattāyo, uragāmiva dujivhāyo, sobbhamiva paṭicchannā, pātālamiva duppūrā rakkhasī viya duttosā, yamovekantahāriyo, sikhīriva sabbabhakkhā, nadīriva sabbavāhī, anilo viya yenakāmaṁcarā, neru viya avisesakarā, visarukkho viya niccaphalitāyoti. ","html":"<p>{}"},"ja536:36.2":{"pli":"Bhavati ca panuttarettha vākyaṁ—","html":"{}</p>"},"ja536:37.1":{"pli":"Yathā coro yathā diddho, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja536:37.2":{"pli":"Vāṇijova vikatthanī; ","html":"<span class='verse-line'>{}</span>"},"ja536:37.3":{"pli":"Issasiṅghamiva parivattā, ","html":"<span class='verse-line'>{}</span>"},"ja536:37.4":{"pli":"Dujivhā urago viya. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:38.1":{"pli":"Sobbhamiva paṭicchannā, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:38.2":{"pli":"pātālamiva duppurā; ","html":"<span class='verse-line'>{}</span>"},"ja536:38.3":{"pli":"Rakkhasī viya duttosā, ","html":"<span class='verse-line'>{}</span>"},"ja536:38.4":{"pli":"yamovekantahāriyo. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:39.1":{"pli":"Yathā sikhī nadī vāto, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:39.2":{"pli":"Nerunāva samāgatā; ","html":"<span class='verse-line'>{}</span>"},"ja536:39.3":{"pli":"Visarukkho viya niccaphalā, ","html":"<span class='verse-line'>{}</span>"},"ja536:39.4":{"pli":"Nāsayanti ghare bhogaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja536:39.5":{"pli":"Ratanantakaritthiyoti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja536:40.1":{"pli":"Cattārimāni, samma puṇṇamukha, yāni vatthūni kicce jāte anatthacarāni bhavanti; ","html":"<p>{}"},"ja536:40.2":{"pli":"tāni parakule na vāsetabbāni—","html":"{}"},"ja536:40.3":{"pli":"goṇaṁ dhenuṁ yānaṁ bhariyā. ","html":"{}"},"ja536:40.4":{"pli":"Cattāri etāni paṇḍito dhanāni gharā na vippavāsaye. ","html":"{}</p>"},"ja536:41.1":{"pli":"Goṇaṁ dhenuñca yānañca, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja536:41.2":{"pli":"Bhariyaṁ ñātikule na vāsaye; ","html":"<span class='verse-line'>{}</span>"},"ja536:41.3":{"pli":"Bhañjanti rathaṁ ayānakā, ","html":"<span class='verse-line'>{}</span>"},"ja536:41.4":{"pli":"Ativāhena hananti puṅgavaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja536:41.5":{"pli":"Dohena hananti vacchakaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja536:41.6":{"pli":"Bhariyā ñātikule padussatīti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja536:42.1":{"pli":"Cha imāni, samma puṇṇamukha, yāni vatthūni kicce jāte anatthacarāni bhavanti—","html":"<p>{}</p>"},"ja536:43.1":{"pli":"Aguṇaṁ dhanu ñātikule ca bhariyā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja536:43.2":{"pli":"Pāraṁ nāvā akkhabhaggañca yānaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja536:43.3":{"pli":"Dūre mitto pāpasahāyako ca, ","html":"<span class='verse-line'>{}</span>"},"ja536:43.4":{"pli":"Kicce jāte anatthacarāni bhavanti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja536:44.1":{"pli":"Aṭṭhahi khalu, samma puṇṇamukha, ṭhānehi itthī sāmikaṁ avajānāti. ","html":"<p>{}"},"ja536:44.2":{"pli":"Daliddatā, āturatā, jiṇṇatā, surāsoṇḍatā, muddhatā, pamattatā, sabbakiccesu anuvattanatā, sabbadhanaanuppadānena—","html":"{}"},"ja536:44.3":{"pli":"imehi khalu, samma puṇṇamukha, aṭṭhahi ṭhānehi itthī sāmikaṁ avajānāti. ","html":"{}"},"ja536:44.4":{"pli":"Bhavati ca panuttarettha vākyaṁ—","html":"{}</p>"},"ja536:45.1":{"pli":"Daliddaṁ āturañcāpi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja536:45.2":{"pli":"jiṇṇakaṁ surasoṇḍakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja536:45.3":{"pli":"Pamattaṁ muddhapattañca, ","html":"<span class='verse-line'>{}</span>"},"ja536:45.4":{"pli":"sabbakiccesu hāpanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja536:45.5":{"pli":"Sabbakāmappadānena, ","html":"<span class='verse-line'>{}</span>"},"ja536:45.6":{"pli":"avajānāti sāmikanti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja536:46.1":{"pli":"Navahi khalu, samma puṇṇamukha, ṭhānehi itthī padosamāharati. ","html":"<p>{}"},"ja536:46.2":{"pli":"Ārāmagamanasīlā ca hoti, uyyānagamanasīlā ca hoti, nadītitthagamanasīlā ca hoti, ñātikulagamanasīlā ca hoti, parakulagamanasīlā ca hoti, ādāsadussamaṇḍanānuyogamanuyuttasīlā ca hoti, majjapāyinī ca hoti, nillokanasīlā ca hoti, sadvāraṭhāyinī ca hoti—","html":"{}"},"ja536:46.3":{"pli":"imehi khalu, samma puṇṇamukha, navahi ṭhānehi itthī padosamāharatīti. ","html":"{}"},"ja536:46.4":{"pli":"Bhavati ca panuttarettha vākyaṁ—","html":"{}</p>"},"ja536:47.1":{"pli":"Ārāmasīlā ca uyyānaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja536:47.2":{"pli":"Nadī ñāti parakulaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja536:47.3":{"pli":"Ādāsadussamaṇḍanamanuyuttā, ","html":"<span class='verse-line'>{}</span>"},"ja536:47.4":{"pli":"Yā citthī majjapāyinī. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:48.1":{"pli":"Yā ca nillokanasīlā, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:48.2":{"pli":"Yā ca sadvāraṭhāyinī; ","html":"<span class='verse-line'>{}</span>"},"ja536:48.3":{"pli":"Navahetehi ṭhānehi, ","html":"<span class='verse-line'>{}</span>"},"ja536:48.4":{"pli":"Padosamāharanti itthiyoti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja536:49.1":{"pli":"Cattālīsāya khalu, samma puṇṇamukha, ṭhānehi itthī purisaṁ accācarati. ","html":"<p>{}"},"ja536:49.2":{"pli":"Vijambhati, vinamati, vilasati, vilajjati, nakhena nakhaṁ ghaṭṭeti, pādena pādaṁ akkamati, kaṭṭhena pathaviṁ vilikhati, dārakaṁ ullaṅghati ullaṅghāpeti, kīḷati kīḷāpeti, cumbati cumbāpeti, bhuñjati bhuñjāpeti, dadāti, yācati, katamanukaroti, uccaṁ bhāsati, nīcaṁ bhāsati, aviccaṁ bhāsati, viviccaṁ bhāsati, naccena gītena vāditena rodanena vilasitena vibhūsitena jagghati, pekkhati, kaṭiṁ cāleti, guyhabhaṇḍakaṁ sañcāleti, ūruṁ vivarati, ūruṁ pidahati, thanaṁ dasseti, kacchaṁ dasseti, nābhiṁ dasseti, akkhiṁ nikhanati, bhamukaṁ ukkhipati, oṭṭhaṁ upalikhati, jivhaṁ nillāleti, dussaṁ muñcati, dussaṁ paṭibandhati, sirasaṁ muñcati, sirasaṁ bandhati—","html":"{}"},"ja536:49.3":{"pli":"imehi khalu, samma puṇṇamukha, cattālīsāya ṭhānehi itthī purisaṁ accācarati. ","html":"{}</p>"},"ja536:50.1":{"pli":"Pañcavīsāya khalu, samma puṇṇamukha, ṭhānehi itthī paduṭṭhā veditabbā bhavati. ","html":"<p>{}"},"ja536:50.2":{"pli":"Sāmikassa pavāsaṁ vaṇṇeti, pavuṭṭhaṁ na sarati, āgataṁ nābhinandati, avaṇṇaṁ tassa bhaṇati, vaṇṇaṁ tassa na bhaṇati, anatthaṁ tassa carati, atthaṁ tassa na carati, akiccaṁ tassa karoti, kiccaṁ tassa na karoti, paridahitvā sayati, parammukhī nipajjati, parivattakajātā kho pana hoti kuṅkumiyajātā, dīghaṁ assasati, dukkhaṁ vedayati, uccārapassāvaṁ abhiṇhaṁ gacchati, vilomamācarati, parapurisasaddaṁ sutvā kaṇṇasotaṁ vivaramodahati, nihatabhogā kho pana hoti, paṭivissakehi santhavaṁ karoti, nikkhantapādā kho pana hoti, visikhānucārinī aticārinī kho pana hoti, niccaṁ sāmike agāravā paduṭṭhamanasaṅkappā, abhiṇhaṁ dvāre tiṭṭhati, kacchāni aṅgāni thanāni dasseti, disodisaṁ gantvā pekkhati—","html":"{}"},"ja536:50.3":{"pli":"imehi khalu, samma puṇṇamukha, pañcavīsāya ṭhānehi itthī paduṭṭhā veditabbā bhavati. ","html":"{}"},"ja536:50.4":{"pli":"Bhavati ca panuttarettha vākyaṁ—","html":"{}</p>"},"ja536:51.1":{"pli":"Pavāsaṁ tassa vaṇṇeti, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja536:51.2":{"pli":"Gataṁ tassa na socati; ","html":"<span class='verse-line'>{}</span>"},"ja536:51.3":{"pli":"Disvāna patimāgataṁ nābhinandati, ","html":"<span class='verse-line'>{}</span>"},"ja536:51.4":{"pli":"Bhattāravaṇṇaṁ na kadāci bhāsati; ","html":"<span class='verse-line'>{}</span>"},"ja536:51.5":{"pli":"Ete paduṭṭhāya bhavanti lakkhaṇā. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:52.1":{"pli":"Anatthaṁ tassa carati asaññatā, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:52.2":{"pli":"Atthañca hāpeti akiccakārinī; ","html":"<span class='verse-line'>{}</span>"},"ja536:52.3":{"pli":"Paridahitvā sayati parammukhī, ","html":"<span class='verse-line'>{}</span>"},"ja536:52.4":{"pli":"Ete paduṭṭhāya bhavanti lakkhaṇā. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:53.1":{"pli":"Parivattajātā ca bhavati kuṅkumī, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:53.2":{"pli":"Dīghañca assasati dukkhavedinī; ","html":"<span class='verse-line'>{}</span>"},"ja536:53.3":{"pli":"Uccārapassāvamabhiṇhaṁ gacchati, ","html":"<span class='verse-line'>{}</span>"},"ja536:53.4":{"pli":"Ete paduṭṭhāya bhavanti lakkhaṇā. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:54.1":{"pli":"Vilomamācarati akiccakārinī, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:54.2":{"pli":"Saddaṁ nisāmeti parassa bhāsato; ","html":"<span class='verse-line'>{}</span>"},"ja536:54.3":{"pli":"Nihatabhogā ca karoti santhavaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja536:54.4":{"pli":"Ete paduṭṭhāya bhavanti lakkhaṇā. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:55.1":{"pli":"Kicchena laddhaṁ kasirābhataṁ dhanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:55.2":{"pli":"Vittaṁ vināseti dukkhena sambhataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja536:55.3":{"pli":"Paṭivissakehi ca karoti santhavaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja536:55.4":{"pli":"Ete paduṭṭhāya bhavanti lakkhaṇā. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:56.1":{"pli":"Nikkhantapādā visikhānucārinī, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:56.2":{"pli":"Niccañca sāmimhi paduṭṭhamānasā; ","html":"<span class='verse-line'>{}</span>"},"ja536:56.3":{"pli":"Aticārinī hoti apetagāravā, ","html":"<span class='verse-line'>{}</span>"},"ja536:56.4":{"pli":"Ete paduṭṭhāya bhavanti lakkhaṇā. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:57.1":{"pli":"Abhikkhaṇaṁ tiṭṭhati dvāramūle, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:57.2":{"pli":"Thanāni kacchāni ca dassayantī; ","html":"<span class='verse-line'>{}</span>"},"ja536:57.3":{"pli":"Disodisaṁ pekkhati bhantacittā, ","html":"<span class='verse-line'>{}</span>"},"ja536:57.4":{"pli":"Ete paduṭṭhāya bhavanti lakkhaṇā. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:58.1":{"pli":"Sabbā nadī vaṅkagatī, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:58.2":{"pli":"sabbe kaṭṭhamayā vanā; ","html":"<span class='verse-line'>{}</span>"},"ja536:58.3":{"pli":"Sabbitthiyo kare pāpaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja536:58.4":{"pli":"labhamāne nivātake. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:59.1":{"pli":"Sace labhetha khaṇaṁ vā raho vā, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:59.2":{"pli":"Nivātakaṁ vāpi labhetha tādisaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja536:59.3":{"pli":"Sabbāva itthī kayiruṁ nu pāpaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja536:59.4":{"pli":"Aññaṁ alattha pīṭhasappināpi saddhiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:60.1":{"pli":"Narānamārāmakarāsu nārisu, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:60.2":{"pli":"Anekacittāsu aniggahāsu ca; ","html":"<span class='verse-line'>{}</span>"},"ja536:60.3":{"pli":"Sabbattha nāpītikarāpi ce siyā, ","html":"<span class='verse-line'>{}</span>"},"ja536:60.4":{"pli":"Na vissase titthasamā hi nāriyoti. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:61.1":{"pli":"Yaṁ ve disvā kaṇḍarīkinnarānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:61.2":{"pli":"Sabbitthiyo na ramanti agāre; ","html":"<span class='verse-line'>{}</span>"},"ja536:61.3":{"pli":"Taṁ tādisaṁ maccaṁ cajitvā bhariyā, ","html":"<span class='verse-line'>{}</span>"},"ja536:61.4":{"pli":"Aññaṁ disvā purisaṁ pīṭhasappiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:62.1":{"pli":"Bakassa ca bāvarikassa rañño, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:62.2":{"pli":"Accantakāmānugatassa bhariyā; ","html":"<span class='verse-line'>{}</span>"},"ja536:62.3":{"pli":"Avācarī paṭṭhavasānugassa, ","html":"<span class='verse-line'>{}</span>"},"ja536:62.4":{"pli":"Kaṁ vāpi itthī nāticare tadaññaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:63.1":{"pli":"Piṅgiyānī sabbalokissarassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:63.2":{"pli":"Rañño piyā brahmadattassa bhariyā; ","html":"<span class='verse-line'>{}</span>"},"ja536:63.3":{"pli":"Avācarī paṭṭhavasānugassa, ","html":"<span class='verse-line'>{}</span>"},"ja536:63.4":{"pli":"Taṁ vāpi sā nājjhagā kāmakāminī. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:64.1":{"pli":"Luddhānaṁ lahucittānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:64.2":{"pli":"Akataññūna dubbhinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja536:64.3":{"pli":"Nādevasatto puriso, ","html":"<span class='verse-line'>{}</span>"},"ja536:64.4":{"pli":"Thīnaṁ saddhātumarahati. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:65.1":{"pli":"Na tā pajānanti kataṁ na kiccaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:65.2":{"pli":"Na mātaraṁ pitaraṁ bhātaraṁ vā; ","html":"<span class='verse-line'>{}</span>"},"ja536:65.3":{"pli":"Anariyā samatikkantadhammā, ","html":"<span class='verse-line'>{}</span>"},"ja536:65.4":{"pli":"Sasseva cittassa vasaṁ vajanti. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:66.1":{"pli":"Cirānuvuṭṭhampi piyaṁ manāpaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:66.2":{"pli":"Anukampakaṁ pāṇasamampi bhattuṁ; ","html":"<span class='verse-line'>{}</span>"},"ja536:66.3":{"pli":"Āvāsu kiccesu ca naṁ jahanti, ","html":"<span class='verse-line'>{}</span>"},"ja536:66.4":{"pli":"Tasmāhamitthīnaṁ na vissasāmi. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:67.1":{"pli":"Thīnañhi cittaṁ yathā vānarassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:67.2":{"pli":"Kannappakannaṁ yathā rukkhachāyā; ","html":"<span class='verse-line'>{}</span>"},"ja536:67.3":{"pli":"Calācalaṁ hadayamitthiyānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja536:67.4":{"pli":"Cakkassa nemi viya parivattati. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:68.1":{"pli":"Yadā tā passanti samekkhamānā, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:68.2":{"pli":"Ādeyyarūpaṁ purisassa vittaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja536:68.3":{"pli":"Saṇhāhi vācāhi nayanti menaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja536:68.4":{"pli":"Kambojakā jalajeneva assaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:69.1":{"pli":"Yadā na passanti samekkhamānā, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:69.2":{"pli":"Ādeyyarūpaṁ purisassa vittaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja536:69.3":{"pli":"Samantato naṁ parivajjayanti, ","html":"<span class='verse-line'>{}</span>"},"ja536:69.4":{"pli":"Tiṇṇo nadīpāragatova kullaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:70.1":{"pli":"Silesūpamā sikhiriva sabbabhakkhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:70.2":{"pli":"Tikkhamāyā nadīriva sīghasotā; ","html":"<span class='verse-line'>{}</span>"},"ja536:70.3":{"pli":"Sevanti hetā piyamappiyañca, ","html":"<span class='verse-line'>{}</span>"},"ja536:70.4":{"pli":"Nāvā yathā orakūlaṁ parañca. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:71.1":{"pli":"Na tā ekassa na dvinnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:71.2":{"pli":"āpaṇova pasārito; ","html":"<span class='verse-line'>{}</span>"},"ja536:71.3":{"pli":"Yo tā mayhanti maññeyya, ","html":"<span class='verse-line'>{}</span>"},"ja536:71.4":{"pli":"vātaṁ jālena bādhaye. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:72.1":{"pli":"Yathā nadī ca pantho ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:72.2":{"pli":"pānāgāraṁ sabhā papā; ","html":"<span class='verse-line'>{}</span>"},"ja536:72.3":{"pli":"Evaṁ lokitthiyo nāma, ","html":"<span class='verse-line'>{}</span>"},"ja536:72.4":{"pli":"velā tāsaṁ na vijjati. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:73.1":{"pli":"Ghatāsanasamā etā, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:73.2":{"pli":"kaṇhasappasirūpamā; ","html":"<span class='verse-line'>{}</span>"},"ja536:73.3":{"pli":"Gāvo bahitiṇasseva, ","html":"<span class='verse-line'>{}</span>"},"ja536:73.4":{"pli":"omasanti varaṁ varaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:74.1":{"pli":"Ghatāsanaṁ kuñjaraṁ kaṇhasappaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:74.2":{"pli":"Muddhābhisittaṁ pamadā ca sabbā; ","html":"<span class='verse-line'>{}</span>"},"ja536:74.3":{"pli":"Ete naro niccayato bhajetha, ","html":"<span class='verse-line'>{}</span>"},"ja536:74.4":{"pli":"Tesaṁ have dubbidu sabbabhāvo. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:75.1":{"pli":"Naccantavaṇṇā na bahūna kantā, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:75.2":{"pli":"Na dakkhiṇā pamadā sevitabbā; ","html":"<span class='verse-line'>{}</span>"},"ja536:75.3":{"pli":"Na parassa bhariyā na dhanassa hetu, ","html":"<span class='verse-line'>{}</span>"},"ja536:75.4":{"pli":"Etitthiyo pañca na sevitabbā”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja536:76.1":{"pli":"Atha khalu, bho, ānando gijjharājā kuṇālassa sakuṇassa ādimajjhakathāpariyosānaṁ viditvā tāyaṁ velāyaṁ imā gāthāyo abhāsi—","html":"<p>{}</p>"},"ja536:77.1":{"pli":"“Puṇṇampi cemaṁ pathaviṁ dhanena, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja536:77.2":{"pli":"Dajjitthiyā puriso sammatāya; ","html":"<span class='verse-line'>{}</span>"},"ja536:77.3":{"pli":"Laddhā khaṇaṁ atimaññeyya tampi, ","html":"<span class='verse-line'>{}</span>"},"ja536:77.4":{"pli":"Tāsaṁ vasaṁ asatīnaṁ na gacche. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:78.1":{"pli":"Uṭṭhāhakañcepi alīnavuttiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:78.2":{"pli":"Komārabhattāraṁ piyaṁ manāpaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja536:78.3":{"pli":"Āvāsu kiccesu ca naṁ jahanti, ","html":"<span class='verse-line'>{}</span>"},"ja536:78.4":{"pli":"Tasmāhamitthīnaṁ na vissasāmi. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:79.1":{"pli":"Na vissase icchati manti poso, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:79.2":{"pli":"Na vissase rodati me sakāse; ","html":"<span class='verse-line'>{}</span>"},"ja536:79.3":{"pli":"Sevanti hetā piyamappiyañca, ","html":"<span class='verse-line'>{}</span>"},"ja536:79.4":{"pli":"Nāvā yathā orakūlaṁ parañca. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:80.1":{"pli":"Na vissase sākhapurāṇasanthataṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:80.2":{"pli":"Na vissase mittapurāṇacoraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja536:80.3":{"pli":"Na vissase rājānaṁ sakhā mamanti, ","html":"<span class='verse-line'>{}</span>"},"ja536:80.4":{"pli":"Na vissase itthi dasanna mātaraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:81.1":{"pli":"Na vissase rāmakarāsu nārisu, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:81.2":{"pli":"Accantasīlāsu asaññatāsu; ","html":"<span class='verse-line'>{}</span>"},"ja536:81.3":{"pli":"Accantapemānugatassa bhariyā, ","html":"<span class='verse-line'>{}</span>"},"ja536:81.4":{"pli":"Na vissase titthasamā hi nāriyo. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:82.1":{"pli":"Haneyyuṁ chindeyyuṁ chedāpeyyumpi, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:82.2":{"pli":"Kaṇṭhepi chetvā rudhiraṁ piveyyuṁ; ","html":"<span class='verse-line'>{}</span>"},"ja536:82.3":{"pli":"Mā dīnakāmāsu asaññatāsu, ","html":"<span class='verse-line'>{}</span>"},"ja536:82.4":{"pli":"Bhāvaṁ kare gaṅgatitthūpamāsu. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:83.1":{"pli":"Musā tāsaṁ yathā saccaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:83.2":{"pli":"saccaṁ tāsaṁ yathā musā; ","html":"<span class='verse-line'>{}</span>"},"ja536:83.3":{"pli":"Gāvo bahitiṇasseva, ","html":"<span class='verse-line'>{}</span>"},"ja536:83.4":{"pli":"omasanti varaṁ varaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:84.1":{"pli":"Gatenetā palobhenti, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:84.2":{"pli":"pekkhitena mhitena ca; ","html":"<span class='verse-line'>{}</span>"},"ja536:84.3":{"pli":"Athopi dunnivatthena, ","html":"<span class='verse-line'>{}</span>"},"ja536:84.4":{"pli":"mañjunā bhaṇitena ca. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:85.1":{"pli":"Coriyo kathinā hetā, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:85.2":{"pli":"vāḷā ca lapasakkharā; ","html":"<span class='verse-line'>{}</span>"},"ja536:85.3":{"pli":"Na tā kiñci na jānanti, ","html":"<span class='verse-line'>{}</span>"},"ja536:85.4":{"pli":"yaṁ manussesu vañcanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:86.1":{"pli":"Asā lokitthiyo nāma, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:86.2":{"pli":"velā tāsaṁ na vijjati; ","html":"<span class='verse-line'>{}</span>"},"ja536:86.3":{"pli":"Sārattā ca pagabbhā ca, ","html":"<span class='verse-line'>{}</span>"},"ja536:86.4":{"pli":"sikhī sabbaghaso yathā. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:87.1":{"pli":"Natthitthīnaṁ piyo nāma, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:87.2":{"pli":"Appiyopi na vijjati; ","html":"<span class='verse-line'>{}</span>"},"ja536:87.3":{"pli":"Sevanti hetā piyamappiyañca, ","html":"<span class='verse-line'>{}</span>"},"ja536:87.4":{"pli":"Nāvā yathā orakūlaṁ parañca. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:88.1":{"pli":"Natthitthīnaṁ piyo nāma, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:88.2":{"pli":"appiyopi na vijjati; ","html":"<span class='verse-line'>{}</span>"},"ja536:88.3":{"pli":"Dhanattā paṭivallanti, ","html":"<span class='verse-line'>{}</span>"},"ja536:88.4":{"pli":"latāva dumanissitā. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:89.1":{"pli":"Hatthibandhaṁ assabandhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:89.2":{"pli":"Gopurisañca maṇḍalaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja536:89.3":{"pli":"Chavaḍāhakaṁ pupphachaḍḍakaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja536:89.4":{"pli":"Sadhanamanupatanti nāriyo. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:90.1":{"pli":"Kulaputtampi jahanti akiñcanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:90.2":{"pli":"Chavakasamasadisampi; ","html":"<span class='verse-line'>{}</span>"},"ja536:90.3":{"pli":"Anugacchanti anupatanti, ","html":"<span class='verse-line'>{}</span>"},"ja536:90.4":{"pli":"Dhanahetu hi nāriyo”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja536:91.1":{"pli":"Atha khalu, bho, nārado devabrāhmaṇo ānandassa gijjharājassa ādimajjhakathāpariyosānaṁ viditvā tāyaṁ velāyaṁ imā gāthāyo abhāsi—","html":"<p>{}</p>"},"ja536:92.1":{"pli":"“Cattārome na pūrenti, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja536:92.2":{"pli":"te me suṇātha bhāsato; ","html":"<span class='verse-line'>{}</span>"},"ja536:92.3":{"pli":"Samuddo brāhmaṇo rājā, ","html":"<span class='verse-line'>{}</span>"},"ja536:92.4":{"pli":"itthī cāpi dijampati. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:93.1":{"pli":"Saritā sāgaraṁ yanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:93.2":{"pli":"yā kāci pathavissitā; ","html":"<span class='verse-line'>{}</span>"},"ja536:93.3":{"pli":"Tā samuddaṁ na pūrenti, ","html":"<span class='verse-line'>{}</span>"},"ja536:93.4":{"pli":"ūnattā hi na pūrati. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:94.1":{"pli":"Brāhmaṇo ca adhīyāna, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:94.2":{"pli":"vedamakkhānapañcamaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja536:94.3":{"pli":"Bhiyyopi sutamiccheyya, ","html":"<span class='verse-line'>{}</span>"},"ja536:94.4":{"pli":"ūnattā hi na pūrati. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:95.1":{"pli":"Rājā ca pathaviṁ sabbaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:95.2":{"pli":"sasamuddaṁ sapabbataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja536:95.3":{"pli":"Ajjhāvasaṁ vijinitvā, ","html":"<span class='verse-line'>{}</span>"},"ja536:95.4":{"pli":"anantaratanocitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja536:95.5":{"pli":"Pāraṁ samuddaṁ pattheti, ","html":"<span class='verse-line'>{}</span>"},"ja536:95.6":{"pli":"ūnattā hi na pūrati. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:96.1":{"pli":"Ekamekāya itthiyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:96.2":{"pli":"aṭṭhaṭṭha patino siyā; ","html":"<span class='verse-line'>{}</span>"},"ja536:96.3":{"pli":"Sūrā ca balavanto ca, ","html":"<span class='verse-line'>{}</span>"},"ja536:96.4":{"pli":"sabbakāmarasāharā; ","html":"<span class='verse-line'>{}</span>"},"ja536:96.5":{"pli":"Kareyya navame chandaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja536:96.6":{"pli":"ūnattā hi na pūrati. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:97.1":{"pli":"Sabbitthiyo sikhiriva sabbabhakkhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:97.2":{"pli":"Sabbitthiyo nadīriva sabbavāhī; ","html":"<span class='verse-line'>{}</span>"},"ja536:97.3":{"pli":"Sabbitthiyo kaṇṭakānaṁva sākhā, ","html":"<span class='verse-line'>{}</span>"},"ja536:97.4":{"pli":"Sabbitthiyo dhanahetu vajanti. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:98.1":{"pli":"Vātañca jālena naro parāmase, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:98.2":{"pli":"Osiñcaye sāgaramekapāṇinā; ","html":"<span class='verse-line'>{}</span>"},"ja536:98.3":{"pli":"Sakena hatthena kareyya ghosaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja536:98.4":{"pli":"Yo sabbabhāvaṁ pamadāsu osaje. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:99.1":{"pli":"Corīnaṁ bahubuddhīnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:99.2":{"pli":"yāsu saccaṁ sudullabhaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja536:99.3":{"pli":"Thīnaṁ bhāvo durājāno, ","html":"<span class='verse-line'>{}</span>"},"ja536:99.4":{"pli":"macchassevodake gataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:100.1":{"pli":"Analā mudusambhāsā, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:100.2":{"pli":"duppūrā tā nadīsamā; ","html":"<span class='verse-line'>{}</span>"},"ja536:100.3":{"pli":"Sīdanti naṁ viditvāna, ","html":"<span class='verse-line'>{}</span>"},"ja536:100.4":{"pli":"ārakā parivajjaye. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:101.1":{"pli":"Āvaṭṭanī mahāmāyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:101.2":{"pli":"brahmacariyavikopanā; ","html":"<span class='verse-line'>{}</span>"},"ja536:101.3":{"pli":"Sīdanti naṁ viditvāna, ","html":"<span class='verse-line'>{}</span>"},"ja536:101.4":{"pli":"ārakā parivajjaye. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:102.1":{"pli":"Yaṁ etā upasevanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:102.2":{"pli":"chandasā vā dhanena vā; ","html":"<span class='verse-line'>{}</span>"},"ja536:102.3":{"pli":"Jātavedova saṇṭhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja536:102.4":{"pli":"khippaṁ anudahanti nan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja536:103.1":{"pli":"Atha khalu, bho, kuṇālo sakuṇo nāradassa devabrāhmaṇassa ādimajjhakathāpariyosānaṁ viditvā tāyaṁ velāyaṁ imā gāthāyo abhāsi—","html":"<p>{}</p>"},"ja536:104.1":{"pli":"“Sallape nisitakhaggapāṇinā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja536:104.2":{"pli":"Paṇḍito api pisācadosinā; ","html":"<span class='verse-line'>{}</span>"},"ja536:104.3":{"pli":"Uggatejamuragampi āside, ","html":"<span class='verse-line'>{}</span>"},"ja536:104.4":{"pli":"Eko ekāya pamadāya nālape. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:105.1":{"pli":"Lokacittamathanā hi nāriyo, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:105.2":{"pli":"Naccagītabhaṇitamhitāvudhā; ","html":"<span class='verse-line'>{}</span>"},"ja536:105.3":{"pli":"Bādhayanti anupaṭṭhitassatiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja536:105.4":{"pli":"Dīpe rakkhasigaṇova vāṇije. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:106.1":{"pli":"Natthi tāsaṁ vinayo na saṁvaro, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:106.2":{"pli":"Majjamaṁsaniratā asaññatā; ","html":"<span class='verse-line'>{}</span>"},"ja536:106.3":{"pli":"Tā gilanti purisassa pābhataṁ, ","html":"<span class='verse-line'>{}</span>"},"ja536:106.4":{"pli":"Sāgareva makaraṁ timiṅgalo. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:107.1":{"pli":"Pañcakāmaguṇasātagocarā, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:107.2":{"pli":"Uddhatā aniyatā asaññatā; ","html":"<span class='verse-line'>{}</span>"},"ja536:107.3":{"pli":"Osaranti pamadā pamādinaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja536:107.4":{"pli":"Loṇatoyavatiyaṁva āpakā. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:108.1":{"pli":"Yaṁ naraṁ upalapenti nāriyo, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:108.2":{"pli":"Chandasā va ratiyā dhanena vā; ","html":"<span class='verse-line'>{}</span>"},"ja536:108.3":{"pli":"Jātavedasadisampi tādisaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja536:108.4":{"pli":"Rāgadosavadhiyo dahanti naṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:109.1":{"pli":"Aḍḍhaṁ ñatvā purisaṁ mahaddhanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:109.2":{"pli":"Osaranti sadhanā sahattanā; ","html":"<span class='verse-line'>{}</span>"},"ja536:109.3":{"pli":"Rattacittamativeṭhayanti naṁ, ","html":"<span class='verse-line'>{}</span>"},"ja536:109.4":{"pli":"Sāla māluvalatāva kānane. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:110.1":{"pli":"Tā upenti vividhena chandasā, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:110.2":{"pli":"Citrabimbamukhiyo alaṅkatā; ","html":"<span class='verse-line'>{}</span>"},"ja536:110.3":{"pli":"Uhasanti pahasanti nāriyo, ","html":"<span class='verse-line'>{}</span>"},"ja536:110.4":{"pli":"Sambarova satamāyakovidā. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:111.1":{"pli":"Jātarūpamaṇimuttabhūsitā, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:111.2":{"pli":"Sakkatā patikulesu nāriyo; ","html":"<span class='verse-line'>{}</span>"},"ja536:111.3":{"pli":"Rakkhitā aticaranti sāmikaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja536:111.4":{"pli":"Dānavaṁva hadayantarassitā. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:112.1":{"pli":"Tejavāpi hi naro vicakkhaṇo, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:112.2":{"pli":"Sakkato bahujanassa pūjito; ","html":"<span class='verse-line'>{}</span>"},"ja536:112.3":{"pli":"Nārinaṁ vasagato na bhāsati, ","html":"<span class='verse-line'>{}</span>"},"ja536:112.4":{"pli":"Rāhunā upahatova candimā. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:113.1":{"pli":"Yaṁ kareyya kupito diso disaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:113.2":{"pli":"Duṭṭhacitto vasamāgataṁ ariṁ; ","html":"<span class='verse-line'>{}</span>"},"ja536:113.3":{"pli":"Tena bhiyyo byasanaṁ nigacchati, ","html":"<span class='verse-line'>{}</span>"},"ja536:113.4":{"pli":"Nārinaṁ vasagato apekkhavā. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:114.1":{"pli":"Kesalūnanakhachinnatajjitā, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:114.2":{"pli":"Pādapāṇikasadaṇḍatāḷitā; ","html":"<span class='verse-line'>{}</span>"},"ja536:114.3":{"pli":"Hīnamevupagatā hi nāriyo, ","html":"<span class='verse-line'>{}</span>"},"ja536:114.4":{"pli":"Tā ramanti kuṇapeva makkhikā. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:115.1":{"pli":"Tā kulesu visikhantaresu vā, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:115.2":{"pli":"Rājadhāninigamesu vā puna; ","html":"<span class='verse-line'>{}</span>"},"ja536:115.3":{"pli":"Oḍḍitaṁ namucipāsavākaraṁ, ","html":"<span class='verse-line'>{}</span>"},"ja536:115.4":{"pli":"Cakkhumā parivajje sukhatthiko. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:116.1":{"pli":"Ossajitva kusalaṁ tapoguṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:116.2":{"pli":"Yo anariyacaritāni mācari; ","html":"<span class='verse-line'>{}</span>"},"ja536:116.3":{"pli":"Devatāhi nirayaṁ nimissati, ","html":"<span class='verse-line'>{}</span>"},"ja536:116.4":{"pli":"Chedagāmimaṇiyaṁva vāṇijo. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:117.1":{"pli":"So idha garahito parattha ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:117.2":{"pli":"Dummatī upahato sakammunā; ","html":"<span class='verse-line'>{}</span>"},"ja536:117.3":{"pli":"Gacchatī aniyato gaḷāgaḷaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja536:117.4":{"pli":"Duṭṭhagadrabharathova uppathe. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:118.1":{"pli":"So upeti nirayaṁ patāpanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:118.2":{"pli":"Sattisimbalivanañca āyasaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja536:118.3":{"pli":"Āvasitvā tiracchānayoniyaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja536:118.4":{"pli":"Petarājavisayaṁ na muñcati. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:119.1":{"pli":"Dibyakhiḍḍaratiyo ca nandane, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:119.2":{"pli":"Cakkavatticaritañca mānuse; ","html":"<span class='verse-line'>{}</span>"},"ja536:119.3":{"pli":"Nāsayanti pamadā pamādinaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja536:119.4":{"pli":"Duggatiñca paṭipādayanti naṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:120.1":{"pli":"Dibyakhiḍḍaratiyo na dullabhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:120.2":{"pli":"Cakkavatticaritañca mānuse; ","html":"<span class='verse-line'>{}</span>"},"ja536:120.3":{"pli":"Soṇṇabyamhanilayā ca accharā, ","html":"<span class='verse-line'>{}</span>"},"ja536:120.4":{"pli":"Ye caranti pamadāhanatthikā. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:121.1":{"pli":"Kāmadhātusamatikkamā gati, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:121.2":{"pli":"Rūpadhātuyā bhāvo na dullabho; ","html":"<span class='verse-line'>{}</span>"},"ja536:121.3":{"pli":"Vītarāgavisayūpapatti yā, ","html":"<span class='verse-line'>{}</span>"},"ja536:121.4":{"pli":"Ye caranti pamadāhanatthikā. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:122.1":{"pli":"Sabbadukkhasamatikkamaṁ sivaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:122.2":{"pli":"Accantamacalitaṁ asaṅkhataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja536:122.3":{"pli":"Nibbutehi sucihī na dullabhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja536:122.4":{"pli":"Ye caranti pamadāhanatthikā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"ja536:123.1":{"pli":"“Kuṇālohaṁ tadā āsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja536:123.2":{"pli":"udāyī phussakokilo; ","html":"<span class='verse-line'>{}</span>"},"ja536:123.3":{"pli":"Ānando gijjharājāsi, ","html":"<span class='verse-line'>{}</span>"},"ja536:123.4":{"pli":"sāriputto ca nārado; ","html":"<span class='verse-line'>{}</span>"},"ja536:123.5":{"pli":"Parisā buddhaparisā, ","html":"<span class='verse-line'>{}</span>"},"ja536:123.6":{"pli":"evaṁ dhāretha jātakan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja536:124.1":{"pli":"Kuṇālajātakaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}