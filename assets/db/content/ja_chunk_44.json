{"ja534":{"ja534:0.1":{"pli":"Jātaka ","html":"<article id='ja534'><header><ul><li class='division'>{}</li>"},"ja534:0.2":{"pli":"Asītinipāta ","html":"<li>{}</li>"},"ja534:0.3":{"pli":"Cūḷahaṁsavagga ","html":"<li>{}</li></ul>"},"ja534:0.4":{"pli":"2. Mahāhaṁsajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja534:1.1":{"pli":"“Ete haṁsā pakkamanti, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja534:1.2":{"pli":"vakkaṅgā bhayameritā; ","html":"<span class='verse-line'>{}</span>"},"ja534:1.3":{"pli":"Harittaca hemavaṇṇa, ","html":"<span class='verse-line'>{}</span>"},"ja534:1.4":{"pli":"kāmaṁ sumukha pakkama. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:2.1":{"pli":"Ohāya maṁ ñātigaṇā, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:2.2":{"pli":"ekaṁ pāsavasaṁ gataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:2.3":{"pli":"Anapekkhamānā gacchanti, ","html":"<span class='verse-line'>{}</span>"},"ja534:2.4":{"pli":"kiṁ eko avahīyasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:3.1":{"pli":"Pateva patataṁ seṭṭha, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:3.2":{"pli":"natthi baddhe sahāyatā; ","html":"<span class='verse-line'>{}</span>"},"ja534:3.3":{"pli":"Mā anīghāya hāpesi, ","html":"<span class='verse-line'>{}</span>"},"ja534:3.4":{"pli":"kāmaṁ sumukha pakkama”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:4.1":{"pli":"“Nāhaṁ dukkhaparetopi, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:4.2":{"pli":"dhataraṭṭha tuvaṁ jahe; ","html":"<span class='verse-line'>{}</span>"},"ja534:4.3":{"pli":"Jīvitaṁ maraṇaṁ vā me, ","html":"<span class='verse-line'>{}</span>"},"ja534:4.4":{"pli":"tayā saddhiṁ bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:5.1":{"pli":"Nāhaṁ dukkhaparetopi, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:5.2":{"pli":"dhataraṭṭha tuvaṁ jahe; ","html":"<span class='verse-line'>{}</span>"},"ja534:5.3":{"pli":"Na maṁ anariyasaṁyutte, ","html":"<span class='verse-line'>{}</span>"},"ja534:5.4":{"pli":"kamme yojetumarahasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:6.1":{"pli":"Sakumāro sakhā tyasmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:6.2":{"pli":"sacitte casmi te ṭhito; ","html":"<span class='verse-line'>{}</span>"},"ja534:6.3":{"pli":"Ñāto senāpati tyāhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja534:6.4":{"pli":"haṁsānaṁ pavaruttama. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:7.1":{"pli":"Kathaṁ ahaṁ vikatthissaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:7.2":{"pli":"ñātimajjhe ito gato; ","html":"<span class='verse-line'>{}</span>"},"ja534:7.3":{"pli":"Taṁ hitvā patataṁ seṭṭha, ","html":"<span class='verse-line'>{}</span>"},"ja534:7.4":{"pli":"kiṁ te vakkhāmito gato; ","html":"<span class='verse-line'>{}</span>"},"ja534:7.5":{"pli":"Idha pāṇaṁ cajissāmi, ","html":"<span class='verse-line'>{}</span>"},"ja534:7.6":{"pli":"nānariyaṁ kattumussahe”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:8.1":{"pli":"“Eso hi dhammo sumukha, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:8.2":{"pli":"yaṁ tvaṁ ariyapathe ṭhito; ","html":"<span class='verse-line'>{}</span>"},"ja534:8.3":{"pli":"Yo bhattāraṁ sakhāraṁ maṁ, ","html":"<span class='verse-line'>{}</span>"},"ja534:8.4":{"pli":"na pariccattumussahe. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:9.1":{"pli":"Tañhi me pekkhamānassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:9.2":{"pli":"bhayaṁ na tveva jāyati; ","html":"<span class='verse-line'>{}</span>"},"ja534:9.3":{"pli":"Adhigacchasi tvaṁ mayhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja534:9.4":{"pli":"evaṁ bhūtassa jīvitaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:10.1":{"pli":"Iccevaṁ mantayantānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:10.2":{"pli":"Ariyānaṁ ariyavuttinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:10.3":{"pli":"Daṇḍamādāya nesādo, ","html":"<span class='verse-line'>{}</span>"},"ja534:10.4":{"pli":"Āpatī turito bhusaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:11.1":{"pli":"Tamāpatantaṁ disvāna, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:11.2":{"pli":"Sumukho atibrūhayi; ","html":"<span class='verse-line'>{}</span>"},"ja534:11.3":{"pli":"Aṭṭhāsi purato rañño, ","html":"<span class='verse-line'>{}</span>"},"ja534:11.4":{"pli":"Haṁso vissāsayaṁ byathaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:12.1":{"pli":"“Mā bhāyi patataṁ seṭṭha, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:12.2":{"pli":"na hi bhāyanti tādisā; ","html":"<span class='verse-line'>{}</span>"},"ja534:12.3":{"pli":"Ahaṁ yogaṁ payuñjissaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja534:12.4":{"pli":"yuttaṁ dhammūpasaṁhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:12.5":{"pli":"Tena pariyāpadānena, ","html":"<span class='verse-line'>{}</span>"},"ja534:12.6":{"pli":"khippaṁ pāsā pamokkhasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:13.1":{"pli":"Tassa taṁ vacanaṁ sutvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:13.2":{"pli":"sumukhassa subhāsitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:13.3":{"pli":"Pahaṭṭhalomo nesādo, ","html":"<span class='verse-line'>{}</span>"},"ja534:13.4":{"pli":"añjalissa paṇāmayi. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:14.1":{"pli":"“Na me sutaṁ vā diṭṭhaṁ vā, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:14.2":{"pli":"bhāsanto mānusiṁ dijo; ","html":"<span class='verse-line'>{}</span>"},"ja534:14.3":{"pli":"Ariyaṁ bruvāno vakkaṅgo, ","html":"<span class='verse-line'>{}</span>"},"ja534:14.4":{"pli":"cajanto mānusiṁ giraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:15.1":{"pli":"Kiṁ nu tāyaṁ dijo hoti, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:15.2":{"pli":"mutto baddhaṁ upāsasi; ","html":"<span class='verse-line'>{}</span>"},"ja534:15.3":{"pli":"Ohāya sakuṇā yanti, ","html":"<span class='verse-line'>{}</span>"},"ja534:15.4":{"pli":"kiṁ eko avahīyasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:16.1":{"pli":"“Rājā me so dijāmitta, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:16.2":{"pli":"senāpaccassa kārayiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:16.3":{"pli":"Tamāpade pariccattuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja534:16.4":{"pli":"nussahe vihagādhipaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:17.1":{"pli":"Mahāgaṇāya bhattā me, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:17.2":{"pli":"mā eko byasanaṁ agā; ","html":"<span class='verse-line'>{}</span>"},"ja534:17.3":{"pli":"Tathā taṁ samma nesāda, ","html":"<span class='verse-line'>{}</span>"},"ja534:17.4":{"pli":"bhattāyaṁ abhito rame”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:18.1":{"pli":"“Ariyavattasi vakkaṅga, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:18.2":{"pli":"yo piṇḍamapacāyasi; ","html":"<span class='verse-line'>{}</span>"},"ja534:18.3":{"pli":"Cajāmi te taṁ bhattāraṁ, ","html":"<span class='verse-line'>{}</span>"},"ja534:18.4":{"pli":"gacchathūbho yathāsukhaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:19.1":{"pli":"“Sace attappayogena, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:19.2":{"pli":"ohito haṁsapakkhinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:19.3":{"pli":"Paṭigaṇhāma te samma, ","html":"<span class='verse-line'>{}</span>"},"ja534:19.4":{"pli":"etaṁ abhayadakkhiṇaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:20.1":{"pli":"No ce attappayogena, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:20.2":{"pli":"ohito haṁsapakkhinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:20.3":{"pli":"Anissaro muñcamamhe, ","html":"<span class='verse-line'>{}</span>"},"ja534:20.4":{"pli":"theyyaṁ kayirāsi luddaka”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:21.1":{"pli":"“Yassa tvaṁ bhatako rañño, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:21.2":{"pli":"kāmaṁ tasseva pāpaya; ","html":"<span class='verse-line'>{}</span>"},"ja534:21.3":{"pli":"Tattha saṁyamano rājā, ","html":"<span class='verse-line'>{}</span>"},"ja534:21.4":{"pli":"yathābhiññaṁ karissati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:22.1":{"pli":"Iccevaṁ vutto nesādo, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:22.2":{"pli":"hemavaṇṇe harittace; ","html":"<span class='verse-line'>{}</span>"},"ja534:22.3":{"pli":"Ubho hatthehi saṅgayha, ","html":"<span class='verse-line'>{}</span>"},"ja534:22.4":{"pli":"pañjare ajjhavodahi. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:23.1":{"pli":"Te pañjaragate pakkhī, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:23.2":{"pli":"ubho bhassaravaṇṇine; ","html":"<span class='verse-line'>{}</span>"},"ja534:23.3":{"pli":"Sumukhaṁ dhataraṭṭhañca, ","html":"<span class='verse-line'>{}</span>"},"ja534:23.4":{"pli":"luddo ādāya pakkami. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:24.1":{"pli":"Harīyamāno dhataraṭṭho, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:24.2":{"pli":"sumukhaṁ etadabravi; ","html":"<span class='verse-line'>{}</span>"},"ja534:24.3":{"pli":"“Bāḷhaṁ bhāyāmi sumukha, ","html":"<span class='verse-line'>{}</span>"},"ja534:24.4":{"pli":"sāmāya lakkhaṇūruyā; ","html":"<span class='verse-line'>{}</span>"},"ja534:24.5":{"pli":"Asmākaṁ vadhamaññāya, ","html":"<span class='verse-line'>{}</span>"},"ja534:24.6":{"pli":"athattānaṁ vadhissati. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:25.1":{"pli":"Pākahaṁsā ca sumukha, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:25.2":{"pli":"suhemā hemasuttacā; ","html":"<span class='verse-line'>{}</span>"},"ja534:25.3":{"pli":"Koñcī samuddatīreva, ","html":"<span class='verse-line'>{}</span>"},"ja534:25.4":{"pli":"kapaṇā nūna rucchati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:26.1":{"pli":"“Evaṁ mahanto lokassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:26.2":{"pli":"appameyyo mahāgaṇī; ","html":"<span class='verse-line'>{}</span>"},"ja534:26.3":{"pli":"Ekitthimanusoceyya, ","html":"<span class='verse-line'>{}</span>"},"ja534:26.4":{"pli":"nayidaṁ paññavatāmiva. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:27.1":{"pli":"Vātova gandhamādeti, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:27.2":{"pli":"ubhayaṁ chekapāpakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:27.3":{"pli":"Bālo āmakapakkaṁva, ","html":"<span class='verse-line'>{}</span>"},"ja534:27.4":{"pli":"lolo andhova āmisaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:28.1":{"pli":"Avinicchayaññu atthesu, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:28.2":{"pli":"mandova paṭibhāsi maṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:28.3":{"pli":"Kiccākiccaṁ na jānāsi, ","html":"<span class='verse-line'>{}</span>"},"ja534:28.4":{"pli":"sampatto kālapariyāyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:29.1":{"pli":"Aḍḍhummatto udīresi, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:29.2":{"pli":"yo seyyā maññasitthiyo; ","html":"<span class='verse-line'>{}</span>"},"ja534:29.3":{"pli":"Bahusādhāraṇā hetā, ","html":"<span class='verse-line'>{}</span>"},"ja534:29.4":{"pli":"soṇḍānaṁva surāgharaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:30.1":{"pli":"Māyā cesā marīcī ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:30.2":{"pli":"soko rogo cupaddavo; ","html":"<span class='verse-line'>{}</span>"},"ja534:30.3":{"pli":"Kharā ca bandhanā cetā, ","html":"<span class='verse-line'>{}</span>"},"ja534:30.4":{"pli":"maccupāsā guhāsayā; ","html":"<span class='verse-line'>{}</span>"},"ja534:30.5":{"pli":"Tāsu yo vissase poso, ","html":"<span class='verse-line'>{}</span>"},"ja534:30.6":{"pli":"so naresu narādhamo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:31.1":{"pli":"“Yaṁ vuddhehi upaññātaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:31.2":{"pli":"ko taṁ ninditumarahati; ","html":"<span class='verse-line'>{}</span>"},"ja534:31.3":{"pli":"Mahābhūtitthiyo nāma, ","html":"<span class='verse-line'>{}</span>"},"ja534:31.4":{"pli":"lokasmiṁ udapajjisuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:32.1":{"pli":"Khiḍḍā paṇihitā tyāsu, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:32.2":{"pli":"rati tyāsu patiṭṭhitā; ","html":"<span class='verse-line'>{}</span>"},"ja534:32.3":{"pli":"Bījāni tyāsu rūhanti, ","html":"<span class='verse-line'>{}</span>"},"ja534:32.4":{"pli":"yadidaṁ sattā pajāyare; ","html":"<span class='verse-line'>{}</span>"},"ja534:32.5":{"pli":"Tāsu ko nibbide poso, ","html":"<span class='verse-line'>{}</span>"},"ja534:32.6":{"pli":"pāṇamāsajja pāṇibhi. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:33.1":{"pli":"Tvameva nañño sumukha, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:33.2":{"pli":"thīnaṁ atthesu yuñjasi; ","html":"<span class='verse-line'>{}</span>"},"ja534:33.3":{"pli":"Tassa tyajja bhaye jāte, ","html":"<span class='verse-line'>{}</span>"},"ja534:33.4":{"pli":"bhītena jāyate mati. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:34.1":{"pli":"Sabbo hi saṁsayaṁ patto, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:34.2":{"pli":"bhayaṁ bhīru titikkhati; ","html":"<span class='verse-line'>{}</span>"},"ja534:34.3":{"pli":"Paṇḍitā ca mahantāno, ","html":"<span class='verse-line'>{}</span>"},"ja534:34.4":{"pli":"atthe yuñjanti duyyuje. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:35.1":{"pli":"Etadatthāya rājāno, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:35.2":{"pli":"sūramicchanti mantinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:35.3":{"pli":"Paṭibāhati yaṁ sūro, ","html":"<span class='verse-line'>{}</span>"},"ja534:35.4":{"pli":"āpadaṁ attapariyāyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:36.1":{"pli":"Mā no ajja vikantiṁsu, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:36.2":{"pli":"rañño sūdā mahānase; ","html":"<span class='verse-line'>{}</span>"},"ja534:36.3":{"pli":"Tathā hi vaṇṇo pattānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja534:36.4":{"pli":"phalaṁ veḷuṁva taṁ vadhi. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:37.1":{"pli":"Muttopi na icchi uḍḍetuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:37.2":{"pli":"Sayaṁ bandhaṁ upāgami; ","html":"<span class='verse-line'>{}</span>"},"ja534:37.3":{"pli":"Sopajja saṁsayaṁ patto, ","html":"<span class='verse-line'>{}</span>"},"ja534:37.4":{"pli":"Atthaṁ gaṇhāhi mā mukhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:38.1":{"pli":"So taṁ yogaṁ payuñjassu, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:38.2":{"pli":"yuttaṁ dhammūpasaṁhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:38.3":{"pli":"Tava pariyāpadānena, ","html":"<span class='verse-line'>{}</span>"},"ja534:38.4":{"pli":"mama pāṇesanaṁ cara”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:39.1":{"pli":"“Mā bhāyi patataṁ seṭṭha, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:39.2":{"pli":"na hi bhāyanti tādisā; ","html":"<span class='verse-line'>{}</span>"},"ja534:39.3":{"pli":"Ahaṁ yogaṁ payuñjissaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja534:39.4":{"pli":"yuttaṁ dhammūpasaṁhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:39.5":{"pli":"Mama pariyāpadānena, ","html":"<span class='verse-line'>{}</span>"},"ja534:39.6":{"pli":"khippaṁ pāsā pamokkhasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:40.1":{"pli":"So luddo haṁsakājena, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:40.2":{"pli":"rājadvāraṁ upāgami; ","html":"<span class='verse-line'>{}</span>"},"ja534:40.3":{"pli":"“Paṭivedetha maṁ rañño, ","html":"<span class='verse-line'>{}</span>"},"ja534:40.4":{"pli":"dhataraṭṭhāyamāgato”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:41.1":{"pli":"Te disvā puññasaṅkāse, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:41.2":{"pli":"ubho lakkhaṇasammate; ","html":"<span class='verse-line'>{}</span>"},"ja534:41.3":{"pli":"Khalu saṁyamano rājā, ","html":"<span class='verse-line'>{}</span>"},"ja534:41.4":{"pli":"amacce ajjhabhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:42.1":{"pli":"“Detha luddassa vatthāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:42.2":{"pli":"annaṁ pānañca bhojanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:42.3":{"pli":"Kāmaṅkaro hiraññassa, ","html":"<span class='verse-line'>{}</span>"},"ja534:42.4":{"pli":"yāvanto esa icchati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:43.1":{"pli":"Disvā luddaṁ pasannattaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:43.2":{"pli":"Kāsirājā tadabravi; ","html":"<span class='verse-line'>{}</span>"},"ja534:43.3":{"pli":"“Yadyāyaṁ samma khemaka, ","html":"<span class='verse-line'>{}</span>"},"ja534:43.4":{"pli":"Puṇṇā haṁsehi tiṭṭhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:44.1":{"pli":"Kathaṁ rucimajjhagataṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:44.2":{"pli":"pāsahattho upāgami; ","html":"<span class='verse-line'>{}</span>"},"ja534:44.3":{"pli":"Okiṇṇaṁ ñātisaṅghehi, ","html":"<span class='verse-line'>{}</span>"},"ja534:44.4":{"pli":"nimmajjhimaṁ kathaṁ gahi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:45.1":{"pli":"“Ajja me sattamā ratti, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:45.2":{"pli":"adanāni upāsato; ","html":"<span class='verse-line'>{}</span>"},"ja534:45.3":{"pli":"Padametassa anvesaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja534:45.4":{"pli":"appamatto ghaṭassito. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:46.1":{"pli":"Athassa padamaddakkhiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:46.2":{"pli":"carato adanesanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:46.3":{"pli":"Tatthāhaṁ odahiṁ pāsaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja534:46.4":{"pli":"evaṁ taṁ dijamaggahiṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:47.1":{"pli":"“Ludda dve ime sakuṇā, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:47.2":{"pli":"atha ekoti bhāsasi; ","html":"<span class='verse-line'>{}</span>"},"ja534:47.3":{"pli":"Cittaṁ nu te vipariyattaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja534:47.4":{"pli":"adu kiṁ nu jigīsasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:48.1":{"pli":"“Yassa lohitakā tālā, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:48.2":{"pli":"tapanīyanibhā subhā; ","html":"<span class='verse-line'>{}</span>"},"ja534:48.3":{"pli":"Uraṁ saṁhacca tiṭṭhanti, ","html":"<span class='verse-line'>{}</span>"},"ja534:48.4":{"pli":"so me bandhaṁ upāgami. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:49.1":{"pli":"Athāyaṁ bhassaro pakkhī, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:49.2":{"pli":"abaddho baddhamāturaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:49.3":{"pli":"Ariyaṁ bruvāno aṭṭhāsi, ","html":"<span class='verse-line'>{}</span>"},"ja534:49.4":{"pli":"cajanto mānusiṁ giraṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:50.1":{"pli":"“Atha kiṁ dāni sumukha, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:50.2":{"pli":"Hanuṁ saṁhacca tiṭṭhasi; ","html":"<span class='verse-line'>{}</span>"},"ja534:50.3":{"pli":"Adu me parisaṁ patto, ","html":"<span class='verse-line'>{}</span>"},"ja534:50.4":{"pli":"Bhayā bhīto na bhāsasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:51.1":{"pli":"“Nāhaṁ kāsipati bhīto, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:51.2":{"pli":"ogayha parisaṁ tava; ","html":"<span class='verse-line'>{}</span>"},"ja534:51.3":{"pli":"Nāhaṁ bhayā na bhāsissaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja534:51.4":{"pli":"vākyaṁ atthamhi tādise”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:52.1":{"pli":"“Na te abhisaraṁ passe, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:52.2":{"pli":"na rathe napi pattike; ","html":"<span class='verse-line'>{}</span>"},"ja534:52.3":{"pli":"Nāssa cammaṁ va kīṭaṁ vā, ","html":"<span class='verse-line'>{}</span>"},"ja534:52.4":{"pli":"vammite ca dhanuggahe. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:53.1":{"pli":"Na hiraññaṁ suvaṇṇaṁ vā, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:53.2":{"pli":"nagaraṁ vā sumāpitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:53.3":{"pli":"Okiṇṇaparikhaṁ duggaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja534:53.4":{"pli":"daḷhamaṭṭālakoṭṭhakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:53.5":{"pli":"Yattha paviṭṭho sumukha, ","html":"<span class='verse-line'>{}</span>"},"ja534:53.6":{"pli":"bhāyitabbaṁ na bhāyasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:54.1":{"pli":"“Na me abhisarenattho, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:54.2":{"pli":"nagarena dhanena vā; ","html":"<span class='verse-line'>{}</span>"},"ja534:54.3":{"pli":"Apathena pathaṁ yāma, ","html":"<span class='verse-line'>{}</span>"},"ja534:54.4":{"pli":"antalikkhecarā mayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:55.1":{"pli":"Sutā ca paṇḍitā tyamhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:55.2":{"pli":"nipuṇā atthacintakā; ","html":"<span class='verse-line'>{}</span>"},"ja534:55.3":{"pli":"Bhāsematthavatiṁ vācaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja534:55.4":{"pli":"sacce cassa patiṭṭhito. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:56.1":{"pli":"Kiñca tuyhaṁ asaccassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:56.2":{"pli":"anariyassa karissati; ","html":"<span class='verse-line'>{}</span>"},"ja534:56.3":{"pli":"Musāvādissa luddassa, ","html":"<span class='verse-line'>{}</span>"},"ja534:56.4":{"pli":"bhaṇitampi subhāsitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:57.1":{"pli":"Taṁ brāhmaṇānaṁ vacanā, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:57.2":{"pli":"imaṁ khemamakārayi; ","html":"<span class='verse-line'>{}</span>"},"ja534:57.3":{"pli":"Abhayañca tayā ghuṭṭhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja534:57.4":{"pli":"imāyo dasadhā disā. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:58.1":{"pli":"Ogayha te pokkharaṇiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:58.2":{"pli":"vippasannodakaṁ suciṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:58.3":{"pli":"Pahūtaṁ cādanaṁ tattha, ","html":"<span class='verse-line'>{}</span>"},"ja534:58.4":{"pli":"ahiṁsā cettha pakkhinaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:59.1":{"pli":"Idaṁ sutvāna nigghosaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:59.2":{"pli":"āgatamha tavantike; ","html":"<span class='verse-line'>{}</span>"},"ja534:59.3":{"pli":"Te te bandhasma pāsena, ","html":"<span class='verse-line'>{}</span>"},"ja534:59.4":{"pli":"etaṁ te bhāsitaṁ musā. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:60.1":{"pli":"Musāvādaṁ purakkhatvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:60.2":{"pli":"icchālobhañca pāpakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:60.3":{"pli":"Ubho sandhimatikkamma, ","html":"<span class='verse-line'>{}</span>"},"ja534:60.4":{"pli":"asātaṁ upapajjati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:61.1":{"pli":"“Nāparajjhāma sumukha, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:61.2":{"pli":"napi lobhāva maggahiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:61.3":{"pli":"Sutā ca paṇḍitātyattha- ","html":"<span class='verse-line'>{}</span>"},"ja534:61.4":{"pli":"nipuṇā atthacintakā. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:62.1":{"pli":"Appevatthavatiṁ vācaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:62.2":{"pli":"byāhareyyuṁ idhāgatā; ","html":"<span class='verse-line'>{}</span>"},"ja534:62.3":{"pli":"Tathā taṁ samma nesādo, ","html":"<span class='verse-line'>{}</span>"},"ja534:62.4":{"pli":"vutto sumukha maggahi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:63.1":{"pli":"“Neva bhītā kāsipati, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:63.2":{"pli":"upanītasmi jīvite; ","html":"<span class='verse-line'>{}</span>"},"ja534:63.3":{"pli":"Bhāsematthavatiṁ vācaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja534:63.4":{"pli":"sampattā kālapariyāyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:64.1":{"pli":"Yo migena migaṁ hanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:64.2":{"pli":"pakkhiṁ vā pana pakkhinā; ","html":"<span class='verse-line'>{}</span>"},"ja534:64.3":{"pli":"Sutena vā sutaṁ kiṇyā, ","html":"<span class='verse-line'>{}</span>"},"ja534:64.4":{"pli":"kiṁ anariyataraṁ tato. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:65.1":{"pli":"Yo cāriyarudaṁ bhāse, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:65.2":{"pli":"anariyadhammavassito; ","html":"<span class='verse-line'>{}</span>"},"ja534:65.3":{"pli":"Ubho so dhaṁsate lokā, ","html":"<span class='verse-line'>{}</span>"},"ja534:65.4":{"pli":"idha ceva parattha ca. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:66.1":{"pli":"Na majjetha yasaṁ patto, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:66.2":{"pli":"na byādhe pattasaṁsayaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:66.3":{"pli":"Vāyametheva kiccesu, ","html":"<span class='verse-line'>{}</span>"},"ja534:66.4":{"pli":"saṁvare vivarāni ca. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:67.1":{"pli":"Ye vuddhā abbhatikkantā, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:67.2":{"pli":"sampattā kālapariyāyaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:67.3":{"pli":"Idha dhammaṁ caritvāna, ","html":"<span class='verse-line'>{}</span>"},"ja534:67.4":{"pli":"evaṁte tidivaṁ gatā. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:68.1":{"pli":"Idaṁ sutvā kāsipati, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:68.2":{"pli":"dhammamattani pālaya; ","html":"<span class='verse-line'>{}</span>"},"ja534:68.3":{"pli":"Dhataraṭṭhañca muñcāhi, ","html":"<span class='verse-line'>{}</span>"},"ja534:68.4":{"pli":"haṁsānaṁ pavaruttamaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:69.1":{"pli":"“Āharantudakaṁ pajjaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:69.2":{"pli":"āsanañca mahārahaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:69.3":{"pli":"Pañjarato pamokkhāmi, ","html":"<span class='verse-line'>{}</span>"},"ja534:69.4":{"pli":"dhataraṭṭhaṁ yasassinaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:70.1":{"pli":"Tañca senāpatiṁ dhīraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:70.2":{"pli":"nipuṇaṁ atthacintakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:70.3":{"pli":"Yo sukhe sukhito rañño, ","html":"<span class='verse-line'>{}</span>"},"ja534:70.4":{"pli":"dukkhite hoti dukkhito. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:71.1":{"pli":"Ediso kho arahati, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:71.2":{"pli":"piṇḍamasnātu bhattuno; ","html":"<span class='verse-line'>{}</span>"},"ja534:71.3":{"pli":"Yathāyaṁ sumukho rañño, ","html":"<span class='verse-line'>{}</span>"},"ja534:71.4":{"pli":"pāṇasādhāraṇo sakhā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:72.1":{"pli":"Pīṭhañca sabbasovaṇṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:72.2":{"pli":"Aṭṭhapādaṁ manoramaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:72.3":{"pli":"Maṭṭhaṁ kāsikamatthannaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja534:72.4":{"pli":"Dhataraṭṭho upāvisi. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:73.1":{"pli":"Kocchañca sabbasovaṇṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:73.2":{"pli":"veyyagghaparisibbitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:73.3":{"pli":"Sumukho ajjhupāvekkhi, ","html":"<span class='verse-line'>{}</span>"},"ja534:73.4":{"pli":"dhataraṭṭhassanantarā. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:74.1":{"pli":"Tesaṁ kañcanapattehi, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:74.2":{"pli":"puthū ādāya kāsiyo; ","html":"<span class='verse-line'>{}</span>"},"ja534:74.3":{"pli":"Haṁsānaṁ abhihāresuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja534:74.4":{"pli":"aggarañño pavāsitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:75.1":{"pli":"Disvā abhihaṭaṁ aggaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:75.2":{"pli":"kāsirājena pesitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:75.3":{"pli":"Kusalo khattadhammānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja534:75.4":{"pli":"tato pucchi anantarā. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:76.1":{"pli":"“Kaccinnu bhoto kusalaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:76.2":{"pli":"kacci bhoto anāmayaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:76.3":{"pli":"Kacci raṭṭhamidaṁ phītaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja534:76.4":{"pli":"dhammena manusāsasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:77.1":{"pli":"“Kusalañceva me haṁsa, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:77.2":{"pli":"atho haṁsa anāmayaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:77.3":{"pli":"Atho raṭṭhamidaṁ phītaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja534:77.4":{"pli":"dhammenaṁ manusāsahaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:78.1":{"pli":"“Kacci bhoto amaccesu, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:78.2":{"pli":"doso koci na vijjati; ","html":"<span class='verse-line'>{}</span>"},"ja534:78.3":{"pli":"Kacci ca te tavatthesu, ","html":"<span class='verse-line'>{}</span>"},"ja534:78.4":{"pli":"nāvakaṅkhanti jīvitaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:79.1":{"pli":"“Athopi me amaccesu, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:79.2":{"pli":"doso koci na vijjati; ","html":"<span class='verse-line'>{}</span>"},"ja534:79.3":{"pli":"Athopi te mamatthesu, ","html":"<span class='verse-line'>{}</span>"},"ja534:79.4":{"pli":"nāvakaṅkhanti jīvitaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:80.1":{"pli":"“Kacci te sādisī bhariyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:80.2":{"pli":"assavā piyabhāṇinī; ","html":"<span class='verse-line'>{}</span>"},"ja534:80.3":{"pli":"Puttarūpayasūpetā, ","html":"<span class='verse-line'>{}</span>"},"ja534:80.4":{"pli":"tava chandavasānugā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:81.1":{"pli":"“Atho me sādisī bhariyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:81.2":{"pli":"assavā piyabhāṇinī; ","html":"<span class='verse-line'>{}</span>"},"ja534:81.3":{"pli":"Puttarūpayasūpetā, ","html":"<span class='verse-line'>{}</span>"},"ja534:81.4":{"pli":"mama chandavasānugā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:82.1":{"pli":"“Kacci raṭṭhaṁ anuppīḷaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:82.2":{"pli":"akutociupaddavaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:82.3":{"pli":"Asāhasena dhammena, ","html":"<span class='verse-line'>{}</span>"},"ja534:82.4":{"pli":"samena manusāsasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:83.1":{"pli":"“Atho raṭṭhaṁ anuppīḷaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:83.2":{"pli":"akutociupaddavaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:83.3":{"pli":"Asāhasena dhammena, ","html":"<span class='verse-line'>{}</span>"},"ja534:83.4":{"pli":"samena manusāsahaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:84.1":{"pli":"“Kacci santo apacitā, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:84.2":{"pli":"Asanto parivajjitā; ","html":"<span class='verse-line'>{}</span>"},"ja534:84.3":{"pli":"No ce dhammaṁ niraṅkatvā, ","html":"<span class='verse-line'>{}</span>"},"ja534:84.4":{"pli":"Adhammamanuvattasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:85.1":{"pli":"“Santo ca me apacitā, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:85.2":{"pli":"asanto parivajjitā; ","html":"<span class='verse-line'>{}</span>"},"ja534:85.3":{"pli":"Dhammamevānuvattāmi, ","html":"<span class='verse-line'>{}</span>"},"ja534:85.4":{"pli":"adhammo me niraṅkato”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:86.1":{"pli":"“Kacci nānāgataṁ dīghaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:86.2":{"pli":"samavekkhasi khattiya; ","html":"<span class='verse-line'>{}</span>"},"ja534:86.3":{"pli":"Kacci matto madanīye, ","html":"<span class='verse-line'>{}</span>"},"ja534:86.4":{"pli":"paralokaṁ na santasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:87.1":{"pli":"“Nāhaṁ anāgataṁ dīghaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:87.2":{"pli":"samavekkhāmi pakkhima; ","html":"<span class='verse-line'>{}</span>"},"ja534:87.3":{"pli":"Ṭhito dasasu dhammesu, ","html":"<span class='verse-line'>{}</span>"},"ja534:87.4":{"pli":"paralokaṁ na santase. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:88.1":{"pli":"Dānaṁ sīlaṁ pariccāgaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:88.2":{"pli":"ajjavaṁ maddavaṁ tapaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:88.3":{"pli":"Akkodhaṁ avihiṁsañca, ","html":"<span class='verse-line'>{}</span>"},"ja534:88.4":{"pli":"khantiñca avirodhanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:89.1":{"pli":"Iccete kusale dhamme, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:89.2":{"pli":"ṭhite passāmi attani; ","html":"<span class='verse-line'>{}</span>"},"ja534:89.3":{"pli":"Tato me jāyate pīti, ","html":"<span class='verse-line'>{}</span>"},"ja534:89.4":{"pli":"somanassañcanappakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:90.1":{"pli":"Sumukho ca acintetvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:90.2":{"pli":"visajji pharusaṁ giraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:90.3":{"pli":"Bhāvadosamanaññāya, ","html":"<span class='verse-line'>{}</span>"},"ja534:90.4":{"pli":"asmākāyaṁ vihaṅgamo. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:91.1":{"pli":"So kuddho pharusaṁ vācaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:91.2":{"pli":"nicchāresi ayoniso; ","html":"<span class='verse-line'>{}</span>"},"ja534:91.3":{"pli":"Yānasmesu na vijjanti, ","html":"<span class='verse-line'>{}</span>"},"ja534:91.4":{"pli":"nayidaṁ paññavatāmiva”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:92.1":{"pli":"“Atthi me taṁ atisāraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:92.2":{"pli":"vegena manujādhipa; ","html":"<span class='verse-line'>{}</span>"},"ja534:92.3":{"pli":"Dhataraṭṭhe ca baddhasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja534:92.4":{"pli":"dukkhaṁ me vipulaṁ ahu. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:93.1":{"pli":"Tvaṁ no pitāva puttānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:93.2":{"pli":"bhūtānaṁ dharaṇīriva; ","html":"<span class='verse-line'>{}</span>"},"ja534:93.3":{"pli":"Asmākaṁ adhipannānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja534:93.4":{"pli":"khamassu rājakuñjara”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:94.1":{"pli":"“Etaṁ te anumodāma, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:94.2":{"pli":"yaṁ bhāvaṁ na nigūhasi; ","html":"<span class='verse-line'>{}</span>"},"ja534:94.3":{"pli":"Khilaṁ pabhindasi pakkhi, ","html":"<span class='verse-line'>{}</span>"},"ja534:94.4":{"pli":"ujukosi vihaṅgama. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:95.1":{"pli":"Yaṁ kiñci ratanaṁ atthi, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:95.2":{"pli":"kāsirājanivesane; ","html":"<span class='verse-line'>{}</span>"},"ja534:95.3":{"pli":"Rajataṁ jātarūpañca, ","html":"<span class='verse-line'>{}</span>"},"ja534:95.4":{"pli":"muttā veḷuriyā bahū. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:96.1":{"pli":"Maṇayo saṅkhamuttā ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:96.2":{"pli":"vatthakaṁ haricandanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:96.3":{"pli":"Ajinaṁ dantabhaṇḍañca, ","html":"<span class='verse-line'>{}</span>"},"ja534:96.4":{"pli":"lohaṁ kāḷāyasaṁ bahuṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:96.5":{"pli":"Etaṁ dadāmi vo vittaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja534:96.6":{"pli":"issaraṁ vissajāmi vo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:97.1":{"pli":"“Addhā apacitā tyamhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:97.2":{"pli":"sakkatā ca rathesabha; ","html":"<span class='verse-line'>{}</span>"},"ja534:97.3":{"pli":"Dhammesu vattamānānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja534:97.4":{"pli":"tvaṁ no ācariyo bhava. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:98.1":{"pli":"Ācariya samanuññātā, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:98.2":{"pli":"Tayā anumatā mayaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:98.3":{"pli":"Taṁ padakkhiṇato katvā, ","html":"<span class='verse-line'>{}</span>"},"ja534:98.4":{"pli":"Ñātiṁ passemurindama”. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:99.1":{"pli":"Sabbarattiṁ cintayitvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:99.2":{"pli":"mantayitvā yathātathaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja534:99.3":{"pli":"Kāsirājā anuññāsi, ","html":"<span class='verse-line'>{}</span>"},"ja534:99.4":{"pli":"haṁsānaṁ pavaruttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:100.1":{"pli":"Tato ratyā vivasāne, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:100.2":{"pli":"sūriyuggamanaṁ pati; ","html":"<span class='verse-line'>{}</span>"},"ja534:100.3":{"pli":"Pekkhato kāsirājassa, ","html":"<span class='verse-line'>{}</span>"},"ja534:100.4":{"pli":"bhavanā te vigāhisuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:101.1":{"pli":"Te aroge anuppatte, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:101.2":{"pli":"disvāna parame dije; ","html":"<span class='verse-line'>{}</span>"},"ja534:101.3":{"pli":"Kekāti makaruṁ haṁsā, ","html":"<span class='verse-line'>{}</span>"},"ja534:101.4":{"pli":"puthusaddo ajāyatha. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:102.1":{"pli":"Te patītā pamuttena, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:102.2":{"pli":"bhattunā bhattugāravā; ","html":"<span class='verse-line'>{}</span>"},"ja534:102.3":{"pli":"Samantā parikiriṁsu, ","html":"<span class='verse-line'>{}</span>"},"ja534:102.4":{"pli":"aṇḍajā laddhapaccayā. ","html":"<span class='verse-line'>{}</span></p>"},"ja534:103.1":{"pli":"Evaṁ mittavataṁ atthā, ","html":"<p><span class='verse-line'>{}</span>"},"ja534:103.2":{"pli":"sabbe honti padakkhiṇā; ","html":"<span class='verse-line'>{}</span>"},"ja534:103.3":{"pli":"Haṁsā yathā dhataraṭṭhā, ","html":"<span class='verse-line'>{}</span>"},"ja534:103.4":{"pli":"ñātisaṅghaṁ upāgamunti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja534:104.1":{"pli":"Mahāhaṁsajātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}