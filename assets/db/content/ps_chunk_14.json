{"ps2.7":{"ps2.7:0.1":{"pli":"Paṭisambhidāmagga ","html":"<article id='ps2.7'><header><ul><li class='division'>{}</li>"},"ps2.7:0.2":{"pli":"2 Yuganaddhavagga ","html":"<li>{}</li></ul>"},"ps2.7:0.3":{"pli":"2.7. Dhammacakkakathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ps2.7:1.0":{"pli":"2.7.1. Saccavāra ","html":"<h2>{}</h2>"},"ps2.7:1.1":{"pli":"Ekaṁ samayaṁ bhagavā bārāṇasiyaṁ viharati …pe… ","html":"<p>{}"},"ps2.7:1.2":{"pli":"iti hidaṁ āyasmato koṇḍaññassa “aññāsikoṇḍañño” tveva nāmaṁ ahosi. ","html":"{}</p>"},"ps2.7:2.1":{"pli":"“Idaṁ dukkhaṁ ariyasaccan”ti pubbe ananussutesu dhammesu cakkhuṁ udapādi, ñāṇaṁ udapādi, paññā udapādi, vijjā udapādi, āloko udapādi. ","html":"<p>{}</p>"},"ps2.7:3.1":{"pli":"Cakkhuṁ udapādīti—","html":"<p>{}"},"ps2.7:3.2":{"pli":"kenaṭṭhena? ","html":"{}"},"ps2.7:3.3":{"pli":"Ñāṇaṁ udapādīti—","html":"{}"},"ps2.7:3.4":{"pli":"kenaṭṭhena? ","html":"{}"},"ps2.7:3.5":{"pli":"Paññā udapādīti—","html":"{}"},"ps2.7:3.6":{"pli":"kenaṭṭhena? ","html":"{}"},"ps2.7:3.7":{"pli":"Vijjā udapādīti—","html":"{}"},"ps2.7:3.8":{"pli":"kenaṭṭhena? ","html":"{}"},"ps2.7:3.9":{"pli":"Āloko udapādīti—","html":"{}"},"ps2.7:3.10":{"pli":"kenaṭṭhena? ","html":"{}"},"ps2.7:3.11":{"pli":"<b>Cakkhuṁ udapādī</b>ti—","html":"{}"},"ps2.7:3.12":{"pli":"dassanaṭṭhena. ","html":"{}"},"ps2.7:3.13":{"pli":"<b>Ñāṇaṁ udapādī</b>ti—","html":"{}"},"ps2.7:3.14":{"pli":"ñātaṭṭhena. ","html":"{}"},"ps2.7:3.15":{"pli":"<b>Paññā udapādī</b>ti—","html":"{}"},"ps2.7:3.16":{"pli":"pajānanaṭṭhena. ","html":"{}"},"ps2.7:3.17":{"pli":"<b>Vijjā udapādī</b>ti—","html":"{}"},"ps2.7:3.18":{"pli":"paṭivedhaṭṭhena. ","html":"{}"},"ps2.7:3.19":{"pli":"<b>Āloko udapādī</b>ti—","html":"{}"},"ps2.7:3.20":{"pli":"obhāsaṭṭhena. ","html":"{}</p>"},"ps2.7:4.1":{"pli":"Cakkhuṁ dhammo, dassanaṭṭho attho. ","html":"<p>{}"},"ps2.7:4.2":{"pli":"Ñāṇaṁ dhammo, ñātaṭṭho attho. ","html":"{}"},"ps2.7:4.3":{"pli":"Paññā dhammo, pajānanaṭṭho attho. ","html":"{}"},"ps2.7:4.4":{"pli":"Vijjā dhammo, paṭivedhaṭṭho attho. ","html":"{}"},"ps2.7:4.5":{"pli":"Āloko dhammo, obhāsaṭṭho attho. ","html":"{}"},"ps2.7:4.6":{"pli":"Ime pañca dhammā pañca atthā dukkhavatthukā saccavatthukā saccārammaṇā saccagocarā saccasaṅgahitā saccapariyāpannā sacce samudāgatā sacce ṭhitā sacce patiṭṭhitā. ","html":"{}</p>"},"ps2.7:5.1":{"pli":"<b>Dhammacakkan</b>ti kenaṭṭhena dhammacakkaṁ? ","html":"<p>{}"},"ps2.7:5.2":{"pli":"Dhammañca pavatteti cakkañcāti—dhammacakkaṁ. ","html":"{}"},"ps2.7:5.3":{"pli":"Cakkañca pavatteti dhammañcāti—dhammacakkaṁ. ","html":"{}"},"ps2.7:5.4":{"pli":"Dhammena pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:5.5":{"pli":"Dhammacariyāya pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:5.6":{"pli":"Dhamme ṭhito pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:5.7":{"pli":"Dhamme patiṭṭhito pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:5.8":{"pli":"Dhamme patiṭṭhāpento pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:5.9":{"pli":"Dhamme vasippatto pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:5.10":{"pli":"Dhamme vasiṁ pāpento pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:5.11":{"pli":"Dhamme pāramippatto pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:5.12":{"pli":"Dhamme pāramiṁ pāpento pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:5.13":{"pli":"Dhamme vesārajjappatto pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:5.14":{"pli":"Dhamme vesārajjaṁ pāpento pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:5.15":{"pli":"Dhammaṁ sakkaronto pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:5.16":{"pli":"Dhammaṁ garuṁ karonto pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:5.17":{"pli":"Dhammaṁ mānento pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:5.18":{"pli":"Dhammaṁ pūjento pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:5.19":{"pli":"Dhammaṁ apacāyamāno pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:5.20":{"pli":"Dhammaddhajo pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:5.21":{"pli":"Dhammaketu pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:5.22":{"pli":"Dhammādhipateyyo pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:5.23":{"pli":"Taṁ kho pana dhammacakkaṁ appaṭivattiyaṁ samaṇena vā brāhmaṇena vā devena vā mārena vā brahmunā vā kenaci vā lokasminti—dhammacakkaṁ. ","html":"{}</p>"},"ps2.7:6.1":{"pli":"Saddhindriyaṁ dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"<p>{}"},"ps2.7:6.2":{"pli":"Vīriyindriyaṁ dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:6.3":{"pli":"Satindriyaṁ dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:6.4":{"pli":"Samādhindriyaṁ dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:6.5":{"pli":"Paññindriyaṁ dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:6.6":{"pli":"Saddhābalaṁ dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:6.7":{"pli":"Vīriyabalaṁ dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:6.8":{"pli":"Satibalaṁ dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:6.9":{"pli":"Samādhibalaṁ dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:6.10":{"pli":"Paññābalaṁ dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:6.11":{"pli":"Satisambojjhaṅgo dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:6.12":{"pli":"Dhammavicayasambojjhaṅgo dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:6.13":{"pli":"Vīriyasambojjhaṅgo dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:6.14":{"pli":"Pītisambojjhaṅgo dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:6.15":{"pli":"Passaddhisambojjhaṅgo dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:6.16":{"pli":"Samādhisambojjhaṅgo dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:6.17":{"pli":"Upekkhāsambojjhaṅgo dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:6.18":{"pli":"Sammādiṭṭhi dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:6.19":{"pli":"Sammāsaṅkappo dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:6.20":{"pli":"Sammāvācā dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:6.21":{"pli":"Sammākammanto dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:6.22":{"pli":"Sammāājīvo dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:6.23":{"pli":"Sammāvāyāmo dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:6.24":{"pli":"Sammāsati dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:6.25":{"pli":"Sammāsamādhi dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}</p>"},"ps2.7:7.1":{"pli":"Ādhipateyyaṭṭhena indriyaṁ dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"<p>{}"},"ps2.7:7.2":{"pli":"Akampiyaṭṭhena balaṁ dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:7.3":{"pli":"Niyyānikaṭṭhena bojjhaṅgo dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:7.4":{"pli":"Hetuṭṭhena maggo dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:7.5":{"pli":"Upaṭṭhānaṭṭhena satipaṭṭhānā dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:7.6":{"pli":"Padahanaṭṭhena sammappadhānā dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:7.7":{"pli":"Ijjhanaṭṭhena iddhipādā dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:7.8":{"pli":"Tathaṭṭhena saccā dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:7.9":{"pli":"Avikkhepaṭṭhena samatho dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:7.10":{"pli":"Anupassanaṭṭhena vipassanā dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:7.11":{"pli":"Ekarasaṭṭhena samathavipassanā dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:7.12":{"pli":"Anativattanaṭṭhena yuganaddhaṁ dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:7.13":{"pli":"Saṁvaraṭṭhena sīlavisuddhi dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:7.14":{"pli":"Avikkhepaṭṭhena cittavisuddhi dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:7.15":{"pli":"Dassanaṭṭhena diṭṭhivisuddhi dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:7.16":{"pli":"Muttaṭṭhena vimokkho dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:7.17":{"pli":"Paṭivedhaṭṭhena vijjā dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:7.18":{"pli":"Pariccāgaṭṭhena vimutti dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:7.19":{"pli":"Samucchedaṭṭhena khaye ñāṇaṁ dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:7.20":{"pli":"Paṭippassaddhaṭṭhena anuppāde ñāṇaṁ dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:7.21":{"pli":"Chando mūlaṭṭhena dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:7.22":{"pli":"Manasikāro samuṭṭhānaṭṭhena dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:7.23":{"pli":"Phasso samodhānaṭṭhena dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:7.24":{"pli":"Vedanā samosaraṇaṭṭhena dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:7.25":{"pli":"Samādhi pamukhaṭṭhena dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:7.26":{"pli":"Sati ādhipateyyaṭṭhena dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:7.27":{"pli":"Paññā taduttaraṭṭhena dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:7.28":{"pli":"Vimutti sāraṭṭhena dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}"},"ps2.7:7.29":{"pli":"Amatogadhaṁ nibbānaṁ pariyosānaṭṭhena dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ. ","html":"{}</p>"},"ps2.7:8.1":{"pli":"“Taṁ kho panidaṁ dukkhaṁ ariyasaccaṁ pariññeyyan”ti …pe… ","html":"<p>{}"},"ps2.7:8.2":{"pli":"pariññātanti pubbe ananussutesu dhammesu cakkhuṁ udapādi …pe… ","html":"{}"},"ps2.7:8.3":{"pli":"āloko udapādi. ","html":"{}</p>"},"ps2.7:9.1":{"pli":"Cakkhuṁ udapādīti—","htm