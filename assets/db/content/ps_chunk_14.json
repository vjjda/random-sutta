ta'>{}</p></article>"}},"ps2.8":{"ps2.8:0.1":{"pli":"Paṭisambhidāmagga ","html":"<article id='ps2.8'><header><ul><li class='division'>{}</li>"},"ps2.8:0.2":{"pli":"2 Yuganaddhavagga ","html":"<li>{}</li></ul>"},"ps2.8:0.3":{"pli":"2.8. Lokuttarakathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ps2.8:1.1":{"pli":"Katame dhammā lokuttarā? ","html":"<p>{}"},"ps2.8:1.2":{"pli":"Cattāro satipaṭṭhānā, cattāro sammappadhānā, cattāro iddhipādā, pañcindriyāni, pañca balāni, satta bojjhaṅgā, ariyo aṭṭhaṅgiko maggo, cattāro ariyamaggā, cattāri ca sāmaññaphalāni, nibbānañca—","html":"{}"},"ps2.8:1.3":{"pli":"ime dhammā lokuttarā. ","html":"{}</p>"},"ps2.8:2.1":{"pli":"<b>Lokuttarā</b>ti kenaṭṭhena lokuttarā? ","html":"<p>{}"},"ps2.8:2.2":{"pli":"Lokaṁ tarantīti—lokuttarā. ","html":"{}"},"ps2.8:2.3":{"pli":"Lokā uttarantīti—lokuttarā. ","html":"{}"},"ps2.8:2.4":{"pli":"Lokato uttarantīti—lokuttarā. ","html":"{}"},"ps2.8:2.5":{"pli":"Lokamhā uttarantīti—lokuttarā. ","html":"{}"},"ps2.8:2.6":{"pli":"Lokaṁ atikkamantīti—lokuttarā. ","html":"{}"},"ps2.8:2.7":{"pli":"Lokaṁ samatikkamantīti—lokuttarā. ","html":"{}"},"ps2.8:2.8":{"pli":"Lokaṁ samatikkantāti—lokuttarā. ","html":"{}"},"ps2.8:2.9":{"pli":"Lokena atirekāti—lokuttarā. ","html":"{}"},"ps2.8:2.10":{"pli":"Lokantaṁ tarantīti—lokuttarā. ","html":"{}"},"ps2.8:2.11":{"pli":"Lokā nissarantīti—lokuttarā. ","html":"{}"},"ps2.8:2.12":{"pli":"Lokato nissarantīti—lokuttarā. ","html":"{}"},"ps2.8:2.13":{"pli":"Lokamhā nissarantīti—lokuttarā. ","html":"{}"},"ps2.8:2.14":{"pli":"Lokā nissaṭāti—lokuttarā. ","html":"{}"},"ps2.8:2.15":{"pli":"Lokena nissaṭāti—lokuttarā. ","html":"{}"},"ps2.8:2.16":{"pli":"Lokamhā nissaṭāti—lokuttarā. ","html":"{}"},"ps2.8:2.17":{"pli":"Loke na tiṭṭhantīti—lokuttarā. ","html":"{}"},"ps2.8:2.18":{"pli":"Lokasmiṁ na tiṭṭhantīti—lokuttarā. ","html":"{}"},"ps2.8:2.19":{"pli":"Loke na limpantīti—lokuttarā. ","html":"{}"},"ps2.8:2.20":{"pli":"Lokena na limpantīti—lokuttarā. ","html":"{}"},"ps2.8:2.21":{"pli":"Loke asaṁlittāti—lokuttarā. ","html":"{}"},"ps2.8:2.22":{"pli":"Lokena asaṁlittāti—lokuttarā. ","html":"{}"},"ps2.8:2.23":{"pli":"Loke anupalittāti—lokuttarā. ","html":"{}"},"ps2.8:2.24":{"pli":"Lokena anupalittāti—lokuttarā. ","html":"{}"},"ps2.8:2.25":{"pli":"Loke vippamuttāti—lokuttarā. ","html":"{}"},"ps2.8:2.26":{"pli":"Lokena vippamuttāti—lokuttarā. ","html":"{}"},"ps2.8:2.27":{"pli":"Lokā vippamuttāti—lokuttarā. ","html":"{}"},"ps2.8:2.28":{"pli":"Lokato vippamuttāti—lokuttarā. ","html":"{}"},"ps2.8:2.29":{"pli":"Lokamhā vippamuttāti—lokuttarā. ","html":"{}"},"ps2.8:2.30":{"pli":"Loke visaññuttāti—lokuttarā. ","html":"{}"},"ps2.8:2.31":{"pli":"Lokena visaññuttāti—lokuttarā. ","html":"{}"},"ps2.8:2.32":{"pli":"Lokā visaññuttāti—lokuttarā. ","html":"{}"},"ps2.8:2.33":{"pli":"Lokasmiṁ visaññuttāti—lokuttarā. ","html":"{}"},"ps2.8:2.34":{"pli":"Lokato visaññuttāti—lokuttarā. ","html":"{}"},"ps2.8:2.35":{"pli":"Lokamhā visaññuttāti—lokuttarā. ","html":"{}"},"ps2.8:2.36":{"pli":"Lokā sujjhantīti—lokuttarā. ","html":"{}"},"ps2.8:2.37":{"pli":"Lokato sujjhantīti—lokuttarā. ","html":"{}"},"ps2.8:2.38":{"pli":"Lokamhā sujjhantīti—lokuttarā. ","html":"{}"},"ps2.8:2.39":{"pli":"Lokā visujjhantīti—lokuttarā. ","html":"{}"},"ps2.8:2.40":{"pli":"Lokato visujjhantīti—lokuttarā. ","html":"{}"},"ps2.8:2.41":{"pli":"Lokamhā visujjhantīti—lokuttarā. ","html":"{}"},"ps2.8:2.42":{"pli":"Lokā vuṭṭhahantīti—lokuttarā. ","html":"{}"},"ps2.8:2.43":{"pli":"Lokato vuṭṭhahantīti—lokuttarā. ","html":"{}"},"ps2.8:2.44":{"pli":"Lokamhā vuṭṭhahantīti—lokuttarā. ","html":"{}"},"ps2.8:2.45":{"pli":"Lokā vivaṭṭantīti—lokuttarā. ","html":"{}"},"ps2.8:2.46":{"pli":"Lokato vivaṭṭantīti—lokuttarā. ","html":"{}"},"ps2.8:2.47":{"pli":"Lokamhā vivaṭṭantīti—lokuttarā. ","html":"{}"},"ps2.8:2.48":{"pli":"Loke na sajjantīti—lokuttarā. ","html":"{}"},"ps2.8:2.49":{"pli":"Loke na gayhantīti—lokuttarā. ","html":"{}"},"ps2.8:2.50":{"pli":"Loke na bajjhantīti—lokuttarā. ","html":"{}"},"ps2.8:2.51":{"pli":"Lokaṁ samucchindantīti—lokuttarā. ","html":"{}"},"ps2.8:2.52":{"pli":"Lokaṁ samucchinnattāti—lokuttarā. ","html":"{}"},"ps2.8:2.53":{"pli":"Lokaṁ paṭippassambhentīti—lokuttarā. ","html":"{}"},"ps2.8:2.54":{"pli":"Lokaṁ paṭippassambhitattāti—lokuttarā. ","html":"{}"},"ps2.8:2.55":{"pli":"Lokassa apathāti—lokuttarā. ","html":"{}"},"ps2.8:2.56":{"pli":"Lokassa agatīti—lokuttarā. ","html":"{}"},"ps2.8:2.57":{"pli":"Lokassa avisayāti—lokuttarā. ","html":"{}"},"ps2.8:2.58":{"pli":"Lokassa asādhāraṇāti—lokuttarā. ","html":"{}"},"ps2.8:2.59":{"pli":"Lokaṁ vamantīti—lokuttarā. ","html":"{}"},"ps2.8:2.60":{"pli":"Lokaṁ na paccāvamantīti—lokuttarā. ","html":"{}"},"ps2.8:2.61":{"pli":"Lokaṁ pajahantīti—lokuttarā. ","html":"{}"},"ps2.8:2.62":{"pli":"Lokaṁ na upādiyantīti—lokuttarā. ","html":"{}"},"ps2.8:2.63":{"pli":"Lokaṁ visinentīti—lokuttarā. ","html":"{}"},"ps2.8:2.64":{"pli":"Lokaṁ na ussinentīti—lokuttarā. ","html":"{}"},"ps2.8:2.65":{"pli":"Lokaṁ vidhūpentīti—lokuttarā. ","html":"{}"},"ps2.8:2.66":{"pli":"Lokaṁ na sandhūpentīti—lokuttarā. ","html":"{}"},"ps2.8:2.67":{"pli":"Lokaṁ samatikkamma abhibhuyya tiṭṭhantīti—lokuttarā. ","html":"{}</p>"},"ps2.8:2.68":{"pli":"Lokuttarakathā niṭṭhitā. ","html":"<p class='endsutta'>{}</p></article>"}}}