{"tha-ap430":{"tha-ap430:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap430'><header><ul><li class='division'>{}</li>"},"tha-ap430:0.2":{"pli":"Sakiṁsammajjakavagga ","html":"<li>{}</li></ul>"},"tha-ap430:0.3":{"pli":"Sucintitattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap430:1.1":{"pli":"“Nagare haṁsavatiyā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap430:1.2":{"pli":"ahosiṁ kassako tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:1.3":{"pli":"Kasikammena jīvāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:1.4":{"pli":"tena posemi dārake. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap430:2.1":{"pli":"Susampannaṁ tadā khettaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap430:2.2":{"pli":"Dhaññaṁ me phalinaṁ ahu; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:2.3":{"pli":"Pākakāle ca sampatte, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:2.4":{"pli":"Evaṁ cintesahaṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap430:3.1":{"pli":"Nacchannaṁ nappatirūpaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap430:3.2":{"pli":"jānantassa guṇāguṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:3.3":{"pli":"Yohaṁ saṅghe adatvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:3.4":{"pli":"aggaṁ bhuñjeyya ce tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap430:4.1":{"pli":"Ayaṁ buddho asamasamo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap430:4.2":{"pli":"dvattiṁsavaralakkhaṇo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:4.3":{"pli":"Tato pabhāvito saṅgho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:4.4":{"pli":"puññakkhetto anuttaro. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap430:5.1":{"pli":"Tattha dassāmahaṁ dānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap430:5.2":{"pli":"navasassaṁ pure pure; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:5.3":{"pli":"Evāhaṁ cintayitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:5.4":{"pli":"haṭṭho pīṇitamānaso. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap430:6.1":{"pli":"Khettato dhaññamāhatvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap430:6.2":{"pli":"sambuddhaṁ upasaṅkamiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:6.3":{"pli":"Upasaṅkamma sambuddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:6.4":{"pli":"lokajeṭṭhaṁ narāsabhaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:6.5":{"pli":"Vanditvā satthuno pāde, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:6.6":{"pli":"idaṁ vacanamabraviṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap430:7.1":{"pli":"‘Navasassañca sampannaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap430:7.2":{"pli":"āyāgosi ca tvaṁ mune; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:7.3":{"pli":"Anukampamupādāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:7.4":{"pli":"adhivāsehi cakkhuma’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap430:8.1":{"pli":"Padumuttaro lokavidū, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap430:8.2":{"pli":"āhutīnaṁ paṭiggaho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:8.3":{"pli":"Mama saṅkappamaññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:8.4":{"pli":"idaṁ vacanamabravi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap430:9.1":{"pli":"‘Cattāro ca paṭipannā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap430:9.2":{"pli":"cattāro ca phale ṭhitā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:9.3":{"pli":"Esa saṅgho ujubhūto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:9.4":{"pli":"paññāsīlasamāhito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:9.5":{"pli":"Yajantānaṁ manussānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:9.6":{"pli":"puññapekkhāna pāṇinaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap430:10.1":{"pli":"Karotopadhikaṁ puññaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap430:10.2":{"pli":"saṅghe dinnaṁ mahapphalaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:10.3":{"pli":"Tasmiṁ saṅgheva dātabbaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:10.4":{"pli":"tava sassaṁ tathetaraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap430:11.1":{"pli":"Saṅghato uddisitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap430:11.2":{"pli":"bhikkhū netvāna saṅgharaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:11.3":{"pli":"Paṭiyattaṁ ghare santaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:11.4":{"pli":"bhikkhusaṅghassa dehi tvaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap430:12.1":{"pli":"Saṅghato uddisitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap430:12.2":{"pli":"bhikkhū netvāna saṅgharaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:12.3":{"pli":"Yaṁ ghare paṭiyattaṁ me, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:12.4":{"pli":"bhikkhusaṅghassadāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap430:13.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap430:13.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:13.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:13.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap430:14.1":{"pli":"Tattha me sukataṁ byamhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap430:14.2":{"pli":"sovaṇṇaṁ sappabhassaraṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:14.3":{"pli":"Saṭṭhiyojanamubbedhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:14.4":{"pli":"tiṁsayojanavitthataṁ. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap430:15.1":{"pli":"Ekūnavīsatimaṁ bhāṇavāraṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap430:16.1":{"pli":"Ākiṇṇaṁ bhavanaṁ mayhaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap430:16.2":{"pli":"nārīgaṇasamākulaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:16.3":{"pli":"Tattha bhutvā pivitvā ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:16.4":{"pli":"vasāmi tidase ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap430:17.1":{"pli":"Satānaṁ tīṇikkhattuñca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap430:17.2":{"pli":"devarajjamakārayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:17.3":{"pli":"Satānaṁ pañcakkhattuñca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:17.4":{"pli":"cakkavattī ahosahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:17.5":{"pli":"Padesarajjaṁ vipulaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:17.6":{"pli":"gaṇanāto asaṅkhiyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap430:18.1":{"pli":"Bhavābhave saṁsaranto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap430:18.2":{"pli":"labhāmi amitaṁ dhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:18.3":{"pli":"Bhoge me ūnatā natthi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:18.4":{"pli":"navasassassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap430:19.1":{"pli":"Hatthiyānaṁ assayānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap430:19.2":{"pli":"sivikaṁ sandamānikaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:19.3":{"pli":"Labhāmi sabbamevetaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:19.4":{"pli":"navasassassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap430:20.1":{"pli":"Navavatthaṁ navaphalaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap430:20.2":{"pli":"navaggarasabhojanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:20.3":{"pli":"Labhāmi sabbamevetaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:20.4":{"pli":"navasassassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap430:21.1":{"pli":"Koseyyakambaliyāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap430:21.2":{"pli":"khomakappāsikāni ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:21.3":{"pli":"Labhāmi sabbamevetaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:21.4":{"pli":"navasassassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap430:22.1":{"pli":"Dāsīgaṇaṁ dāsagaṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap430:22.2":{"pli":"nāriyo ca alaṅkatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:22.3":{"pli":"Labhāmi sabbamevetaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:22.4":{"pli":"navasassassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap430:23.1":{"pli":"Na maṁ sītaṁ vā uṇhaṁ vā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap430:23.2":{"pli":"pariḷāho na vijjati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:23.3":{"pli":"Atho cetasikaṁ dukkhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:23.4":{"pli":"hadaye me na vijjati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap430:24.1":{"pli":"Idaṁ khāda idaṁ bhuñja, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap430:24.2":{"pli":"imamhi sayane saya; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:24.3":{"pli":"Labhāmi sabbamevetaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:24.4":{"pli":"navasassassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap430:25.1":{"pli":"Ayaṁ pacchimako dāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap430:25.2":{"pli":"carimo vattate bhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:25.3":{"pli":"Ajjāpi deyyadhammo me, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:25.4":{"pli":"phalaṁ tosesi sabbadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap430:26.1":{"pli":"Navasassaṁ daditvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap430:26.2":{"pli":"saṅghe gaṇavaruttame; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:26.3":{"pli":"Aṭṭhānisaṁse anubhomi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:26.4":{"pli":"kammānucchavike mama. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap430:27.1":{"pli":"Vaṇṇavā yasavā homi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap430:27.2":{"pli":"mahābhogo anītiko; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:27.3":{"pli":"Mahāpakkho sadā homi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:27.4":{"pli":"abhejjapariso sadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap430:28.1":{"pli":"Sabbe maṁ apacāyanti, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap430:28.2":{"pli":"ye keci pathavissitā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:28.3":{"pli":"Deyyadhammā ca ye keci, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:28.4":{"pli":"pure pure labhāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap430:29.1":{"pli":"Bhikkhusaṅghassa vā majjhe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap430:29.2":{"pli":"buddhaseṭṭhassa sammukhā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:29.3":{"pli":"Sabbepi samatikkamma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:29.4":{"pli":"denti mameva dāyakā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap430:30.1":{"pli":"Paṭhamaṁ navasassañhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap430:30.2":{"pli":"datvā saṅghe gaṇuttame; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:30.3":{"pli":"Imānisaṁse anubhomi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:30.4":{"pli":"navasassassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap430:31.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap430:31.2":{"pli":"yaṁ dānamadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:31.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:31.4":{"pli":"navasassassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap430:32.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap430:32.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:32.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap430:33.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap430:33.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:33.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap430:34.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap430:34.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap430:34.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap430:35.1":{"pli":"Itthaṁ sudaṁ āyasmā sucintito thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap430:36.1":{"pli":"Sucintitattherassāpadānaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap431":{"tha-ap431:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap431'><header><ul><li class='division'>{}</li>"},"tha-ap431:0.2":{"pli":"Sakiṁsammajjakavagga ","html":"<li>{}</li></ul>"},"tha-ap431:0.3":{"pli":"9 Sovaṇṇakiṅkaṇiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap431:1.1":{"pli":"“Saddhāya abhinikkhamma, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap431:1.2":{"pli":"pabbajiṁ anagāriyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap431:1.3":{"pli":"Vākacīradharo āsiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap431:1.4":{"pli":"tapokammamapassito. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap431:2.1":{"pli":"Atthadassī tu bhagavā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap431:2.2":{"pli":"lokajeṭṭho narāsabho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap431:2.3":{"pli":"Uppajji tamhi samaye, ","html":"<span class='verse-line'>{}</span>"},"tha-ap431:2.4":{"pli":"tārayanto mahājanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap431:3.1":{"pli":"Balañca vata me khīṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap431:3.2":{"pli":"byādhinā paramena taṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap431:3.3":{"pli":"Buddhaseṭṭhaṁ saritvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap431:3.4":{"pli":"puline thūpamuttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap431:4.1":{"pli":"Karitvā haṭṭhacittohaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap431:4.2":{"pli":"sahatthena samokiriṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap431:4.3":{"pli":"Soṇṇakiṅkaṇipupphāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap431:4.4":{"pli":"udaggamanaso ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap431:5.1":{"pli":"Sammukhā viya sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap431:5.2":{"pli":"thūpaṁ paricariṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap431:5.3":{"pli":"Tena cetopasādena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap431:5.4":{"pli":"atthadassissa tādino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap431:6.1":{"pli":"Devalokaṁ gato santo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap431:6.2":{"pli":"labhāmi vipulaṁ sukhaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap431:6.3":{"pli":"Suvaṇṇavaṇṇo tatthāsiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap431:6.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap431:7.1":{"pli":"Asītikoṭiyo mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap431:7.2":{"pli":"nāriyo samalaṅkatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap431:7.3":{"pli":"Sadā mayhaṁ upaṭṭhanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap431:7.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap431:8.1":{"pli":"Saṭṭhituriyasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap431:8.2":{"pli":"bheriyo paṇavāni ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap431:8.3":{"pli":"Saṅkhā ca ḍiṇḍimā tattha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap431:8.4":{"pli":"vaggū vajjanti dundubhī. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap431:9.1":{"pli":"Cullāsītisahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap431:9.2":{"pli":"hatthino samalaṅkatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap431:9.3":{"pli":"Tidhāpabhinnamātaṅgā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap431:9.4":{"pli":"kuñjarā saṭṭhihāyanā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap431:10.1":{"pli":"Hemajālābhisañchannā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap431:10.2":{"pli":"upaṭṭhānaṁ karonti me; ","html":"<span class='verse-line'>{}</span>"},"tha-ap431:10.3":{"pli":"Balakāye gaje ceva, ","html":"<span class='verse-line'>{}</span>"},"tha-ap431:10.4":{"pli":"ūnatā me na vijjati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap431:11.1":{"pli":"Soṇṇakiṅkaṇipupphānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap431:11.2":{"pli":"vipākaṁ anubhomahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap431:11.3":{"pli":"Aṭṭhapaññāsakkhattuñca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap431:11.4":{"pli":"devarajjamakārayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap431:12.1":{"pli":"Ekasattatikkhattuñca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap431:12.2":{"pli":"cakkavattī ahosahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap431:12.3":{"pli":"Pathabyā rajjaṁ ekasataṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap431:12.4":{"pli":"mahiyā kārayiṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap431:13.1":{"pli":"So dāni amataṁ patto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap431:13.2":{"pli":"asaṅkhataṁ sududdasaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap431:13.3":{"pli":"Saṁyojanaparikkhīṇo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap431:13.4":{"pli":"natthi dāni punabbhavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap431:14.1":{"pli":"Aṭṭhārase kappasate, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap431:14.2":{"pli":"yaṁ pupphamabhiropayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap431:14.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap431:14.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap431:15.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap431:15.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap431:15.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap431:16.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap431:16.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap431:16.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap431:17.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap431:17.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap431:17.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap431:18.1":{"pli":"Itthaṁ sudaṁ āyasmā sovaṇṇakiṅkaṇiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap431:19.1":{"pli":"Sovaṇṇakiṅkaṇiyattherassāpadānaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap432":{"tha-ap432:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap432'><header><ul><li class='division'>{}</li>"},"tha-ap432:0.2":{"pli":"Sakiṁsammajjakavagga ","html":"<li>{}</li></ul>"},"tha-ap432:0.3":{"pli":"10 Soṇṇakontarikattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap432:1.1":{"pli":"“Manobhāvaniyaṁ buddhaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap432:1.2":{"pli":"attadantaṁ samāhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap432:1.3":{"pli":"Iriyamānaṁ brahmapathe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap432:1.4":{"pli":"cittavūpasame rataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap432:2.1":{"pli":"Nittiṇṇaoghaṁ sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap432:2.2":{"pli":"jhāyiṁ jhānarataṁ muniṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap432:2.3":{"pli":"Upatitthaṁ samāpannaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap432:2.4":{"pli":"indivaradalappabhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap432:3.1":{"pli":"Alābunodakaṁ gayha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap432:3.2":{"pli":"buddhaseṭṭhaṁ upāgamiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap432:3.3":{"pli":"Buddhassa pāde dhovitvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap432:3.4":{"pli":"alābukamadāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap432:4.1":{"pli":"Āṇāpesi ca sambuddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap432:4.2":{"pli":"padumuttaranāmako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap432:4.3":{"pli":"‘Iminā dakamāhatvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap432:4.4":{"pli":"pādamūle ṭhapehi me’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap432:5.1":{"pli":"Sādhūtihaṁ paṭissutvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap432:5.2":{"pli":"satthugāravatāya ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap432:5.3":{"pli":"Dakaṁ alābunāhatvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap432:5.4":{"pli":"buddhaseṭṭhaṁ upāgamiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap432:6.1":{"pli":"Anumodi mahāvīro, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap432:6.2":{"pli":"cittaṁ nibbāpayaṁ mama; ","html":"<span class='verse-line'>{}</span>"},"tha-ap432:6.3":{"pli":"‘Iminālābudānena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap432:6.4":{"pli":"saṅkappo te samijjhatu’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap432:7.1":{"pli":"Pannarasesu kappesu, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap432:7.2":{"pli":"devaloke ramiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap432:7.3":{"pli":"Tiṁsatikkhattuṁ rājā ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap432:7.4":{"pli":"cakkavattī ahosahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap432:8.1":{"pli":"Divā vā yadi vā rattiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap432:8.2":{"pli":"caṅkamantassa tiṭṭhato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap432:8.3":{"pli":"Sovaṇṇaṁ kontaraṁ gayha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap432:8.4":{"pli":"tiṭṭhate purato mama. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap432:9.1":{"pli":"Buddhassa datvānalābuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap432:9.2":{"pli":"labhāmi soṇṇakontaraṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap432:9.3":{"pli":"Appakampi kataṁ kāraṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap432:9.4":{"pli":"vipulaṁ hoti tādisu. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap432:10.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap432:10.2":{"pli":"yaṁlābumadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap432:10.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap432:10.4":{"pli":"alābussa idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap432:11.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap432:11.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap432:11.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap432:12.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap432:12.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap432:12.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap432:13.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap432:13.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap432:13.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap432:14.1":{"pli":"Itthaṁ sudaṁ āyasmā soṇṇakontariko thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap432:15.1":{"pli":"Soṇṇakontarikattherassāpadānaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap432:16.1":{"pli":"Sakiṁsammajjakavaggo tecattālīsamo. ","html":"<p class='endsection'>{}</p>"},"tha-ap432:17.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"tha-ap432:18.1":{"pli":"Sakiṁsammajjako thero, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"tha-ap432:18.2":{"pli":"ekadussī ekāsanī; ","html":"<span class='verse-line'>{}</span>"},"tha-ap432:18.3":{"pli":"Kadambakoraṇḍakado, ","html":"<span class='verse-line'>{}</span>"},"tha-ap432:18.4":{"pli":"ghatassavanikopi ca. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap432:19.1":{"pli":"Sucintiko kiṅkaṇiko, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap432:19.2":{"pli":"soṇṇakontarikopi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap432:19.3":{"pli":"Ekagāthāsatañcettha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap432:19.4":{"pli":"ekasattatimeva ca. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"tha-ap433":{"tha-ap433:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap433'><header><ul><li class='division'>{}</li>"},"tha-ap433:0.2":{"pli":"Ekavihārivagga ","html":"<li>{}</li></ul>"},"tha-ap433:0.3":{"pli":"1 Ekavihārikattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap433:1.1":{"pli":"“Imamhi bhaddake kappe, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap433:1.2":{"pli":"brahmabandhu mahāyaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap433:1.3":{"pli":"Kassapo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap433:1.4":{"pli":"uppajji vadataṁ varo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap433:2.1":{"pli":"Nippapañco nirālambo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap433:2.2":{"pli":"ākāsasamamānaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap433:2.3":{"pli":"Suññatābahulo tādī, ","html":"<span class='verse-line'>{}</span>"},"tha-ap433:2.4":{"pli":"animittarato vasī. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap433:3.1":{"pli":"Asaṅgacitto nikleso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap433:3.2":{"pli":"asaṁsaṭṭho kule gaṇe; ","html":"<span class='verse-line'>{}</span>"},"tha-ap433:3.3":{"pli":"Mahākāruṇiko vīro, ","html":"<span class='verse-line'>{}</span>"},"tha-ap433:3.4":{"pli":"vinayopāyakovido. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap433:4.1":{"pli":"Uyyutto parakiccesu, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap433:4.2":{"pli":"vinayanto sadevake; ","html":"<span class='verse-line'>{}</span>"},"tha-ap433:4.3":{"pli":"Nibbānagamanaṁ maggaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap433:4.4":{"pli":"gatiṁ paṅkavisosanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap433:5.1":{"pli":"Amataṁ paramassādaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap433:5.2":{"pli":"jarāmaccunivāraṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap433:5.3":{"pli":"Mahāparisamajjhe so, ","html":"<span class='verse-line'>{}</span>"},"tha-ap433:5.4":{"pli":"nisinno lokatārako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap433:6.1":{"pli":"Karavīkaruto nātho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap433:6.2":{"pli":"brahmaghoso tathāgato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap433:6.3":{"pli":"Uddharanto mahāduggā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap433:6.4":{"pli":"vippanaṭṭhe anāyake. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap433:7.1":{"pli":"Desento virajaṁ dhammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap433:7.2":{"pli":"diṭṭho me lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap433:7.3":{"pli":"Tassa dhammaṁ suṇitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap433:7.4":{"pli":"pabbajiṁ anagāriyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap433:8.1":{"pli":"Pabbajitvā tadāpāhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap433:8.2":{"pli":"cintento jinasāsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap433:8.3":{"pli":"Ekakova vane ramme, ","html":"<span class='verse-line'>{}</span>"},"tha-ap433:8.4":{"pli":"vasiṁ saṁsaggapīḷito. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap433:9.1":{"pli":"Sakkāyavūpakāso me, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap433:9.2":{"pli":"hetubhūto mamābhavī; ","html":"<span class='verse-line'>{}</span>"},"tha-ap433:9.3":{"pli":"Manaso vūpakāsassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap433:9.4":{"pli":"saṁsaggabhayadassino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap433:10.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap433:10.2":{"pli":"bhavā sabbe samūhatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap433:10.3":{"pli":"Nāgova bandhanaṁ chetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap433:10.4":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap433:11.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap433:11.2":{"pli":"mama buddhassa santike; ","html":"<span class='verse-line'>{}</span>"},"tha-ap433:11.3":{"pli":"Tisso vijjā anuppattā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap433:11.4":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap433:12.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap433:12.2":{"pli":"vimokkhāpi ca aṭṭhime; ","html":"<span class='verse-line'>{}</span>"},"tha-ap433:12.3":{"pli":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap433:12.4":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap433:13.1":{"pli":"Itthaṁ sudaṁ āyasmā ekavihāriko thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap433:14.1":{"pli":"Ekavihārikattherassāpadānaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap434":{"tha-ap434:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap434'><header><ul><li class='division'>{}</li>"},"tha-ap434:0.2":{"pli":"Ekavihārivagga ","html":"<li>{}</li></ul>"},"tha-ap434:0.3":{"pli":"Ekasaṅkhiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap434:1.1":{"pli":"“Vipassino bhagavato, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap434:1.2":{"pli":"mahābodhimaho ahu; ","html":"<span class='verse-line'>{}</span>"},"tha-ap434:1.3":{"pli":"Mahājanā samāgamma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap434:1.4":{"pli":"pūjenti bodhimuttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap434:2.1":{"pli":"Na hi taṁ orakaṁ maññe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap434:2.2":{"pli":"buddhaseṭṭho bhavissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap434:2.3":{"pli":"Yassāyaṁ īdisā bodhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap434:2.4":{"pli":"pūjanīyā ca satthuno. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap434:3.1":{"pli":"Tato saṅkhaṁ gahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap434:3.2":{"pli":"bodhirukkhamupaṭṭhahiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap434:3.3":{"pli":"Dhamanto sabbadivasaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap434:3.4":{"pli":"avandiṁ bodhimuttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap434:4.1":{"pli":"Āsannake kataṁ kammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap434:4.2":{"pli":"devalokaṁ apāpayī; ","html":"<span class='verse-line'>{}</span>"},"tha-ap434:4.3":{"pli":"Kaḷevaraṁ me patitaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap434:4.4":{"pli":"devaloke ramāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap434:5.1":{"pli":"Saṭṭhituriyasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap434:5.2":{"pli":"tuṭṭhahaṭṭhā pamoditā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap434:5.3":{"pli":"Sadā mayhaṁ upaṭṭhanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap434:5.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap434:6.1":{"pli":"Ekasattatime kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap434:6.2":{"pli":"rājā āsiṁ sudassano; ","html":"<span class='verse-line'>{}</span>"},"tha-ap434:6.3":{"pli":"Cāturanto vijitāvī, ","html":"<span class='verse-line'>{}</span>"},"tha-ap434:6.4":{"pli":"jambumaṇḍassa issaro. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap434:7.1":{"pli":"Tato aṅgasatā turiyā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap434:7.2":{"pli":"parivārenti maṁ sadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap434:7.3":{"pli":"Anubhomi sakaṁ kammaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap434:7.4":{"pli":"upaṭṭhānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap434:8.1":{"pli":"Yaṁ yaṁ yonupapajjāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap434:8.2":{"pli":"devattaṁ atha mānusaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap434:8.3":{"pli":"Mātukucchigatassāpi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap434:8.4":{"pli":"vajjare bheriyo sadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap434:9.1":{"pli":"Upaṭṭhitvāna sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap434:9.2":{"pli":"anubhutvāna sampadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap434:9.3":{"pli":"Sivaṁ sukhemaṁ amataṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap434:9.4":{"pli":"pattomhi acalaṁ padaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap434:10.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap434:10.2":{"pli":"yaṁ kammamakariṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap434:10.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap434:10.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap434:11.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap434:11.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap434:11.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap434:12.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap434:12.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap434:12.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap434:13.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap434:13.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap434:13.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap434:14.1":{"pli":"Itthaṁ sudaṁ āyasmā ekasaṅkhiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap434:15.1":{"pli":"Ekasaṅkhiyattherassāpadānaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap435":{"tha-ap435:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap435'><header><ul><li class='division'>{}</li>"},"tha-ap435:0.2":{"pli":"Ekavihārivagga ","html":"<li>{}</li></ul>"},"tha-ap435:0.3":{"pli":"3 Pāṭihīrasaññakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap435:1.1":{"pli":"“Padumuttaro nāma jino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap435:1.2":{"pli":"āhutīnaṁ paṭiggaho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap435:1.3":{"pli":"Vasīsatasahassehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap435:1.4":{"pli":"nagaraṁ pāvisī tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap435:2.1":{"pli":"Nagaraṁ pavisantassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap435:2.2":{"pli":"upasantassa tādino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap435:2.3":{"pli":"Ratanāni pajjotiṁsu, ","html":"<span class='verse-line'>{}</span>"},"tha-ap435:2.4":{"pli":"nigghoso āsi tāvade. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap435:3.1":{"pli":"Buddhassa ānubhāvena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap435:3.2":{"pli":"bherī vajjumaghaṭṭitā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap435:3.3":{"pli":"Sayaṁ vīṇā pavajjanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap435:3.4":{"pli":"buddhassa pavisato puraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap435:4.1":{"pli":"Buddhaseṭṭhaṁ namassāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap435:4.2":{"pli":"padumuttaramahāmuniṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap435:4.3":{"pli":"Pāṭihīrañca passitvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap435:4.4":{"pli":"tattha cittaṁ pasādayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap435:5.1":{"pli":"Aho buddhā aho dhammā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap435:5.2":{"pli":"aho no satthusampadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap435:5.3":{"pli":"Acetanāpi turiyā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap435:5.4":{"pli":"sayameva pavajjare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap435:6.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap435:6.2":{"pli":"yaṁ saññamalabhiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap435:6.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap435:6.4":{"pli":"buddhasaññāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap435:7.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap435:7.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap435:7.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap435:8.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap435:8.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap435:8.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap435:9.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap435:9.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap435:9.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap435:10.1":{"pli":"Itthaṁ sudaṁ āyasmā pāṭihīrasaññako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap435:11.1":{"pli":"Pāṭihīrasaññakattherassāpadānaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap436":{"tha-ap436:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap436'><header><ul><li class='division'>{}</li>"},"tha-ap436:0.2":{"pli":"Ekavihārivagga ","html":"<li>{}</li></ul>"},"tha-ap436:0.3":{"pli":"Ñāṇatthavikattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap436:1.1":{"pli":"“Kaṇikāraṁva jalitaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap436:1.2":{"pli":"dīparukkhaṁva jotitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap436:1.3":{"pli":"Kañcanaṁva virocantaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap436:1.4":{"pli":"addasaṁ dvipaduttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap436:2.1":{"pli":"Kamaṇḍaluṁ ṭhapetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap436:2.2":{"pli":"vākacīrañca kuṇḍikaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap436:2.3":{"pli":"Ekaṁsaṁ ajinaṁ katvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap436:2.4":{"pli":"buddhaseṭṭhaṁ thaviṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap436:3.1":{"pli":"‘Tamandhakāraṁ vidhamaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap436:3.2":{"pli":"mohajālasamākulaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap436:3.3":{"pli":"Ñāṇālokaṁ dassetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap436:3.4":{"pli":"nittiṇṇosi mahāmuni. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap436:4.1":{"pli":"Samuddharasimaṁ lokaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap436:4.2":{"pli":"sabbāvantamanuttaraṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap436:4.3":{"pli":"Ñāṇe te upamā natthi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap436:4.4":{"pli":"yāvatājagatogati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap436:5.1":{"pli":"Tena ñāṇena sabbaññū, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap436:5.2":{"pli":"iti buddho pavuccati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap436:5.3":{"pli":"Vandāmi taṁ mahāvīraṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap436:5.4":{"pli":"sabbaññutamanāvaraṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap436:6.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap436:6.2":{"pli":"buddhaseṭṭhaṁ thaviṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap436:6.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap436:6.4":{"pli":"ñāṇatthavāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap436:7.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap436:7.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap436:7.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap436:8.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap436:8.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap436:8.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap436:9.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap436:9.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap436:9.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap436:10.1":{"pli":"Itthaṁ sudaṁ āyasmā ñāṇatthaviko thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap436:11.1":{"pli":"Ñāṇatthavikattherassāpadānaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}