":{"pli":"vanditvā pupphamokiriṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap178:3.1":{"pli":"Vīsakappasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap178:3.2":{"pli":"ito pañca janā ahuṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap178:3.3":{"pli":"Pupphacchadaniyā nāma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap178:3.4":{"pli":"cakkavattī mahabbalā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap178:4.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap178:4.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap178:4.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap178:5.1":{"pli":"Itthaṁ sudaṁ āyasmā maggadattiko thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap178:6.1":{"pli":"Maggadattikattherassāpadānaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap179":{"tha-ap179:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap179'><header><ul><li class='division'>{}</li>"},"tha-ap179:0.2":{"pli":"Kumudavagga ","html":"<li>{}</li></ul>"},"tha-ap179:0.3":{"pli":"Ekadīpiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap179:1.1":{"pli":"“Padumuttarassa munino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap179:1.2":{"pli":"saḷale bodhimuttame; ","html":"<span class='verse-line'>{}</span>"},"tha-ap179:1.3":{"pli":"Pasannacitto sumano, ","html":"<span class='verse-line'>{}</span>"},"tha-ap179:1.4":{"pli":"ekadīpaṁ adāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap179:2.1":{"pli":"Bhave nibbattamānamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap179:2.2":{"pli":"nibbatte puññasañcaye; ","html":"<span class='verse-line'>{}</span>"},"tha-ap179:2.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap179:2.4":{"pli":"dīpadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap179:3.1":{"pli":"Soḷase kappasahasse, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap179:3.2":{"pli":"ito te caturo janā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap179:3.3":{"pli":"Candābhā nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap179:3.4":{"pli":"cakkavattī mahabbalā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap179:4.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap179:4.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap179:4.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap179:5.1":{"pli":"Itthaṁ sudaṁ āyasmā ekadīpiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap179:6.1":{"pli":"Ekadīpiyattherassāpadānaṁ sattamaṁ. ","html":"<p class='endsutta'>{}<br>"},"tha-ap179:6.2":{"pli":"Navamaṁ bhāṇavāraṁ. ","html":"{}</p></article>"}},"tha-ap18":{"tha-ap18:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap18'><header><ul><li class='division'>{}</li>"},"tha-ap18:0.2":{"pli":"Sīhāsaniyavagga ","html":"<li>{}</li></ul>"},"tha-ap18:0.3":{"pli":"Rāhulattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap18:1.1":{"pli":"“Padumuttarassa bhagavato, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap18:1.2":{"pli":"Lokajeṭṭhassa tādino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:1.3":{"pli":"Sattabhūmamhi pāsāde, ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:1.4":{"pli":"Ādāsaṁ santhariṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap18:2.1":{"pli":"Khīṇāsavasahassehi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap18:2.2":{"pli":"parikiṇṇo mahāmuni; ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:2.3":{"pli":"Upāgami gandhakuṭiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:2.4":{"pli":"dvipadindo narāsabho. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap18:3.1":{"pli":"Virocento gandhakuṭiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap18:3.2":{"pli":"devadevo narāsabho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:3.3":{"pli":"Bhikkhusaṅghe ṭhito satthā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:3.4":{"pli":"imā gāthā abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap18:4.1":{"pli":"‘Yenāyaṁ jotitā seyyā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap18:4.2":{"pli":"ādāsova susanthato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:4.3":{"pli":"Tamahaṁ kittayissāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:4.4":{"pli":"suṇātha mama bhāsato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap18:5.1":{"pli":"Soṇṇamayā rūpimayā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap18:5.2":{"pli":"atho veḷuriyāmayā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:5.3":{"pli":"Nibbattissanti pāsādā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:5.4":{"pli":"ye keci manaso piyā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap18:6.1":{"pli":"Catusaṭṭhikkhattuṁ devindo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap18:6.2":{"pli":"devarajjaṁ karissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:6.3":{"pli":"Sahassakkhattuṁ cakkavattī, ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:6.4":{"pli":"bhavissati anantarā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap18:7.1":{"pli":"Ekavīsatikappamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap18:7.2":{"pli":"vimalo nāma khattiyo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:7.3":{"pli":"Cāturanto vijitāvī, ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:7.4":{"pli":"cakkavattī bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap18:8.1":{"pli":"Nagaraṁ reṇuvatī nāma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap18:8.2":{"pli":"iṭṭhakāhi sumāpitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:8.3":{"pli":"Āyāmato tīṇi sataṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:8.4":{"pli":"caturassasamāyutaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap18:9.1":{"pli":"Sudassano nāma pāsādo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap18:9.2":{"pli":"vissakammena māpito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:9.3":{"pli":"Kūṭāgāravarūpeto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:9.4":{"pli":"sattaratanabhūsito. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap18:10.1":{"pli":"Dasasaddāvivittaṁ taṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap18:10.2":{"pli":"vijjādharasamākulaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:10.3":{"pli":"Sudassanaṁva nagaraṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:10.4":{"pli":"devatānaṁ bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap18:11.1":{"pli":"Pabhā niggacchate tassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap18:11.2":{"pli":"uggacchanteva sūriye; ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:11.3":{"pli":"Virocessati taṁ niccaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:11.4":{"pli":"samantā aṭṭhayojanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap18:12.1":{"pli":"Kappasatasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap18:12.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:12.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:12.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap18:13.1":{"pli":"Tusitā so cavitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap18:13.2":{"pli":"sukkamūlena codito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:13.3":{"pli":"Gotamassa bhagavato, ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:13.4":{"pli":"atrajo so bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap18:14.1":{"pli":"Sacevaseyya agāraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap18:14.2":{"pli":"cakkavattī bhaveyya so; ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:14.3":{"pli":"Aṭṭhānametaṁ yaṁ tādī, ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:14.4":{"pli":"agāre ratimajjhagā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap18:15.1":{"pli":"Nikkhamitvā agāramhā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap18:15.2":{"pli":"pabbajissati subbato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:15.3":{"pli":"Rāhulo nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:15.4":{"pli":"arahā so bhavissati’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap18:16.1":{"pli":"Kikīva aṇḍaṁ rakkheyya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap18:16.2":{"pli":"cāmarī viya vāladhiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:16.3":{"pli":"Nipako sīlasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:16.4":{"pli":"evaṁ rakkhiṁ mahāmuni. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap18:17.1":{"pli":"Tassāhaṁ dhammamaññāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap18:17.2":{"pli":"vihāsiṁ sāsane rato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:17.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:17.4":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap18:18.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap18:18.2":{"pli":"vimokkhāpi ca aṭṭhime; ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:18.3":{"pli":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap18:18.4":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap18:19.1":{"pli":"Itthaṁ sudaṁ āyasmā rāhulo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap18:20.1":{"pli":"Rāhulattherassāpadānaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap180":{"tha-ap180:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap180'><header><ul><li class='division'>{}</li>"},"tha-ap180:0.2":{"pli":"Kumudavagga ","html":"<li>{}</li></ul>"},"tha-ap180:0.3":{"pli":"Maṇipūjakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap180:1.1":{"pli":"“Orena himavantassa, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap180:1.2":{"pli":"nadikā sampavattatha; ","html":"<span class='verse-line'>{}</span>"},"tha-ap180:1.3":{"pli":"Tassā cānupakhettamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap180:1.4":{"pli":"sayambhū vasate tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap180:2.1":{"pli":"Maṇiṁ paggayha pallaṅkaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap180:2.2":{"pli":"sādhucittaṁ manoramaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap180:2.3":{"pli":"Pasannacitto sumano, ","html":"<span class='verse-line'>{}</span>"},"tha-ap180:2.4":{"pli":"buddhassa abhiropayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap180:3.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap180:3.2":{"pli":"yaṁ maṇiṁ abhiropayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap180:3.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap180:3.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap180:4.1":{"pli":"Ito ca dvādase kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap180:4.2":{"pli":"sataraṁsīsanāmakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap180:4.3":{"pli":"Aṭṭha te āsuṁ rājāno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap180:4.4":{"pli":"cakkavattī mahabbalā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap180:5.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap180:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap180:5.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap180:6.1":{"pli":"Itthaṁ sudaṁ āyasmā maṇipūjako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap180:7.1":{"pli":"Maṇipūjakattherassāpadānaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap181":{"tha-ap181:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap181'><header><ul><li class='division'>{}</li>"},"tha-ap181:0.2":{"pli":"Kumudavagga ","html":"<li>{}</li></ul>"},"tha-ap181:0.3":{"pli":"Tikicchakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap181:1.1":{"pli":"“Nagare bandhumatiyā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap181:1.2":{"pli":"vejjo āsiṁ susikkhito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap181:1.3":{"pli":"Āturānaṁ sadukkhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap181:1.4":{"pli":"mahājanasukhāvaho. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap181:2.1":{"pli":"Byādhitaṁ samaṇaṁ disvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap181:2.2":{"pli":"sīlavantaṁ mahājutiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap181:2.3":{"pli":"Pasannacitto sumano, ","html":"<span class='verse-line'>{}</span>"},"tha-ap181:2.4":{"pli":"bhesajjamadadiṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap181:3.1":{"pli":"Arogo āsi teneva, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap181:3.2":{"pli":"samaṇo saṁvutindriyo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap181:3.3":{"pli":"Asoko nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap181:3.4":{"pli":"upaṭṭhāko vipassino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap181:4.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap181:4.2":{"pli":"yaṁ osadhamadāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap181:4.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap181:4.4":{"pli":"bhesajjassa idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap181:5.1":{"pli":"Ito ca aṭṭhame kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap181:5.2":{"pli":"sabbosadhasanāmako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap181:5.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap181:5.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap181:6.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap181:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap181:6.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap181:7.1":{"pli":"Itthaṁ sudaṁ āyasmā tikicchako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap181:8.1":{"pli":"Tikicchakattherassāpadānaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap182":{"tha-ap182:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap182'><header><ul><li class='division'>{}</li>"},"tha-ap182:0.2":{"pli":"Kumudavagga ","html":"<li>{}</li></ul>"},"tha-ap182:0.3":{"pli":"Saṅghupaṭṭhākattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap182:1.1":{"pli":"“Vessabhumhi bhagavati, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap182:1.2":{"pli":"ahosārāmiko ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap182:1.3":{"pli":"Pasannacitto sumano, ","html":"<span class='verse-line'>{}</span>"},"tha-ap182:1.4":{"pli":"upaṭṭhiṁ saṅg