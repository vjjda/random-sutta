{"tha-ap529":{"tha-ap529:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap529'><header><ul><li class='division'>{}</li>"},"tha-ap529:0.2":{"pli":"Tiṇadāyakavagga ","html":"<li>{}</li></ul>"},"tha-ap529:0.3":{"pli":"Girinelapūjakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap529:1.1":{"pli":"“Migaluddo pure āsiṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap529:1.2":{"pli":"vipine vicaraṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap529:1.3":{"pli":"Addasaṁ virajaṁ buddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap529:1.4":{"pli":"sabbadhammāna pāraguṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap529:2.1":{"pli":"Tasmiṁ mahākāruṇike, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap529:2.2":{"pli":"sabbasattahite rate; ","html":"<span class='verse-line'>{}</span>"},"tha-ap529:2.3":{"pli":"Pasannacitto sumano, ","html":"<span class='verse-line'>{}</span>"},"tha-ap529:2.4":{"pli":"nelapupphamapūjayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap529:3.1":{"pli":"Ekatiṁse ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap529:3.2":{"pli":"yaṁ pupphamabhipūjayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap529:3.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap529:3.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap529:4.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap529:4.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap529:4.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap529:5.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap529:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap529:5.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap529:6.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap529:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap529:6.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap529:7.1":{"pli":"Itthaṁ sudaṁ āyasmā girinelapūjako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap529:8.1":{"pli":"Girinelapūjakattherassāpadānaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap53":{"tha-ap53:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap53'><header><ul><li class='division'>{}</li>"},"tha-ap53:0.2":{"pli":"Bījanivagga ","html":"<li>{}</li></ul>"},"tha-ap53:0.3":{"pli":"Vidhūpanadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap53:1.1":{"pli":"“Padumuttarabuddhassa, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap53:1.2":{"pli":"lokajeṭṭhassa tādino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap53:1.3":{"pli":"Bījanikā mayā dinnā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap53:1.4":{"pli":"dvipadindassa tādino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap53:2.1":{"pli":"Sakaṁ cittaṁ pasādetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap53:2.2":{"pli":"paggahetvāna añjaliṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap53:2.3":{"pli":"Sambuddhamabhivādetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap53:2.4":{"pli":"pakkamiṁ uttarāmukho. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap53:3.1":{"pli":"Bījaniṁ paggahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap53:3.2":{"pli":"satthā lokagganāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap53:3.3":{"pli":"Bhikkhusaṅghe ṭhito santo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap53:3.4":{"pli":"imā gāthā abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap53:4.1":{"pli":"‘Iminā bījanidānena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap53:4.2":{"pli":"cittassa paṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap53:4.3":{"pli":"Kappānaṁ satasahassaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap53:4.4":{"pli":"vinipātaṁ na gacchati’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap53:5.1":{"pli":"Āraddhavīriyo pahitatto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap53:5.2":{"pli":"Cetoguṇasamāhito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap53:5.3":{"pli":"Jātiyā sattavassohaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap53:5.4":{"pli":"Arahattaṁ apāpuṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap53:6.1":{"pli":"Saṭṭhikappasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap53:6.2":{"pli":"bījamānasanāmakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap53:6.3":{"pli":"Soḷasāsiṁsu rājāno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap53:6.4":{"pli":"cakkavattī mahabbalā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap53:7.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap53:7.2":{"pli":"vimokkhāpi ca aṭṭhime; ","html":"<span class='verse-line'>{}</span>"},"tha-ap53:7.3":{"pli":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap53:7.4":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap53:8.1":{"pli":"Itthaṁ sudaṁ āyasmā vidhūpanadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap53:9.1":{"pli":"Vidhūpanadāyakattherassāpadānaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap530":{"tha-ap530:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap530'><header><ul><li class='division'>{}</li>"},"tha-ap530:0.2":{"pli":"Tiṇadāyakavagga ","html":"<li>{}</li></ul>"},"tha-ap530:0.3":{"pli":"Bodhisammajjakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap530:1.1":{"pli":"“Ahaṁ pure bodhipattaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap530:1.2":{"pli":"ujjhitaṁ cetiyaṅgaṇe; ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:1.3":{"pli":"Taṁ gahetvāna chaḍḍesiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:1.4":{"pli":"alabhiṁ vīsatīguṇe. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap530:2.1":{"pli":"Tassa kammassa tejena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap530:2.2":{"pli":"saṁsaranto bhavābhave; ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:2.3":{"pli":"Duve bhave saṁsarāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:2.4":{"pli":"devatte cāpi mānuse. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap530:3.1":{"pli":"Devalokā cavitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap530:3.2":{"pli":"āgantvā mānusaṁ bhavaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:3.3":{"pli":"Duve kule pajāyāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:3.4":{"pli":"khattiye cāpi brāhmaṇe. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap530:4.1":{"pli":"Aṅgapaccaṅgasampanno, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap530:4.2":{"pli":"ārohapariṇāhavā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:4.3":{"pli":"Abhirūpo suci homi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:4.4":{"pli":"sampuṇṇaṅgo anūnako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap530:5.1":{"pli":"Devaloke manusse vā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap530:5.2":{"pli":"jāto vā yattha katthaci; ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:5.3":{"pli":"Bhave suvaṇṇavaṇṇo ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:5.4":{"pli":"uttattakanakūpamo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap530:6.1":{"pli":"Mudukā maddavā sniddhā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap530:6.2":{"pli":"sukhumā sukumārikā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:6.3":{"pli":"Chavi me sabbadā hoti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:6.4":{"pli":"bodhipatte suchaḍḍite. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap530:7.1":{"pli":"Yato kutoci gatīsu, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap530:7.2":{"pli":"sarīre samudāgate; ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:7.3":{"pli":"Na limpati rajojallaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:7.4":{"pli":"vipāko pattachaḍḍite. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap530:8.1":{"pli":"Uṇhe vātātape tassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap530:8.2":{"pli":"aggitāpena vā pana; ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:8.3":{"pli":"Gatte sedā na muccanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:8.4":{"pli":"vipāko pattachaḍḍite. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap530:9.1":{"pli":"Kuṭṭhaṁ gaṇḍo kilāso ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap530:9.2":{"pli":"tilakā piḷakā tathā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:9.3":{"pli":"Na honti kāye daddu ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:9.4":{"pli":"vipāko pattachaḍḍite. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap530:10.1":{"pli":"Aparampi guṇaṁ tassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap530:10.2":{"pli":"nibbattati bhavābhave; ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:10.3":{"pli":"Rogā na honti kāyasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:10.4":{"pli":"vipāko pattachaḍḍite. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap530:11.1":{"pli":"Aparampi guṇaṁ tassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap530:11.2":{"pli":"nibbattati bhavābhave; ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:11.3":{"pli":"Na hoti cittajā pīḷā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:11.4":{"pli":"vipāko pattachaḍḍite. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap530:12.1":{"pli":"Aparampi guṇaṁ tassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap530:12.2":{"pli":"nibbattati bhavābhave; ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:12.3":{"pli":"Amittā na bhavantassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:12.4":{"pli":"vipāko pattachaḍḍite. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap530:13.1":{"pli":"Aparampi guṇaṁ tassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap530:13.2":{"pli":"nibbattati bhavābhave; ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:13.3":{"pli":"Anūnabhogo bhavati, ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:13.4":{"pli":"vipāko pattachaḍḍite. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap530:14.1":{"pli":"Aparampi guṇaṁ tassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap530:14.2":{"pli":"nibbattati bhavābhave; ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:14.3":{"pli":"Aggirājūhi corehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:14.4":{"pli":"na hoti udake bhayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap530:15.1":{"pli":"Aparampi guṇaṁ tassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap530:15.2":{"pli":"nibbattati bhavābhave; ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:15.3":{"pli":"Dāsidāsā anucarā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:15.4":{"pli":"honti cittānuvattakā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap530:16.1":{"pli":"Yamhi āyuppamāṇamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap530:16.2":{"pli":"jāyate mānuse bhave; ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:16.3":{"pli":"Tato na hāyate āyu, ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:16.4":{"pli":"tiṭṭhate yāvatāyukaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap530:17.1":{"pli":"Abbhantarā ca bāhirā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap530:17.2":{"pli":"negamā ca saraṭṭhakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:17.3":{"pli":"Nuyuttā honti sabbepi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:17.4":{"pli":"vuddhikāmā sukhicchakā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap530:18.1":{"pli":"Bhogavā yasavā homi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap530:18.2":{"pli":"sirimā ñātipakkhavā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:18.3":{"pli":"Apetabhayasantāso, ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:18.4":{"pli":"bhavehaṁ sabbato bhave. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap530:19.1":{"pli":"Devā manussā asurā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap530:19.2":{"pli":"gandhabbā yakkharakkhasā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:19.3":{"pli":"Sabbe te parirakkhanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:19.4":{"pli":"bhave saṁsarato sadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap530:20.1":{"pli":"Devaloke manusse ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap530:20.2":{"pli":"anubhotvā ubho yase; ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:20.3":{"pli":"Avasāne ca nibbānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:20.4":{"pli":"sivaṁ patto anuttaraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap530:21.1":{"pli":"Sambuddhamuddisitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap530:21.2":{"pli":"bodhiṁ vā tassa satthuno; ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:21.3":{"pli":"Yo puññaṁ pasave poso, ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:21.4":{"pli":"tassa kiṁ nāma dullabhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap530:22.1":{"pli":"Magge phale āgame ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap530:22.2":{"pli":"jhānābhiññāguṇesu ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:22.3":{"pli":"Aññesaṁ adhiko hutvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:22.4":{"pli":"nibbāyāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap530:23.1":{"pli":"Purehaṁ bodhiyā pattaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap530:23.2":{"pli":"chaḍḍetvā haṭṭhamānaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:23.3":{"pli":"Imehi vīsataṅgehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:23.4":{"pli":"samaṅgī homi sabbadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap530:24.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap530:24.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:24.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap530:25.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap530:25.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:25.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap530:26.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap530:26.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap530:26.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap530:27.1":{"pli":"Itthaṁ sudaṁ āyasmā bodhisammajjako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap530:28.1":{"pli":"Bodhisammajjakattherassāpadānaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap531":{"tha-ap531:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap531'><header><ul><li class='division'>{}</li>"},"tha-ap531:0.2":{"pli":"Tiṇadāyakavagga ","html":"<li>{}</li></ul>"},"tha-ap531:0.3":{"pli":"Āmaṇḍaphaladāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap531:1.1":{"pli":"“Padumuttaro nāma jino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap531:1.2":{"pli":"sabbadhammāna pāragū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap531:1.3":{"pli":"Vuṭṭhahitvā samādhimhā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap531:1.4":{"pli":"caṅkamī lokanāyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap531:2.1":{"pli":"Khāribhāraṁ gahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap531:2.2":{"pli":"āharanto phalaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap531:2.3":{"pli":"Addasaṁ virajaṁ buddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap531:2.4":{"pli":"caṅkamantaṁ mahāmuniṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap531:3.1":{"pli":"Pasannacitto sumano, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap531:3.2":{"pli":"sire katvāna añjaliṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap531:3.3":{"pli":"Sambuddhaṁ abhivādetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap531:3.4":{"pli":"āmaṇḍamadadiṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap531:4.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap531:4.2":{"pli":"yaṁ phalaṁ adadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap531:4.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap531:4.4":{"pli":"āmaṇḍassa idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap531:5.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap531:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap531:5.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap531:6.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap531:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap531:6.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap531:7.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap531:7.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap531:7.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap531:8.1":{"pli":"Itthaṁ sudaṁ āyasmā āmaṇḍaphaladāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap531:9.1":{"pli":"Āmaṇḍaphaladāyakattherassāpadānaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap532":{"tha-ap532:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap532'><header><ul><li class='division'>{}</li>"},"tha-ap532:0.2":{"pli":"Tiṇadāyakavagga ","html":"<li>{}</li></ul>"},"tha-ap532:0.3":{"pli":"Sugandhattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap532:1.1":{"pli":"“Imamhi bhaddake kappe, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap532:1.2":{"pli":"brahmabandhu mahāyaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:1.3":{"pli":"Kassapo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:1.4":{"pli":"uppajji vadataṁ varo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:2.1":{"pli":"Anubyañjanasampanno, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:2.2":{"pli":"bāttiṁsavaralakkhaṇo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:2.3":{"pli":"Byāmappabhāparivuto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:2.4":{"pli":"raṁsijālasamotthaṭo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:3.1":{"pli":"Assāsetā yathā cando, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:3.2":{"pli":"sūriyova pabhaṅkaro; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:3.3":{"pli":"Nibbāpetā yathā megho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:3.4":{"pli":"sāgarova guṇākaro. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:4.1":{"pli":"Dharaṇīriva sīlena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:4.2":{"pli":"himavāva samādhinā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:4.3":{"pli":"Ākāso viya paññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:4.4":{"pli":"asaṅgo anilo yathā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:5.1":{"pli":"Sa kadāci mahāvīro, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:5.2":{"pli":"parisāsu visārado; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:5.3":{"pli":"Saccāni sampakāseti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:5.4":{"pli":"uddharanto mahājanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:6.1":{"pli":"Tadā hi bārāṇasiyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:6.2":{"pli":"seṭṭhiputto mahāyaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:6.3":{"pli":"Āsahaṁ dhanadhaññassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:6.4":{"pli":"pahūtassa bahū tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:7.1":{"pli":"Jaṅghāvihāraṁ vicaraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:7.2":{"pli":"migadāyamupeccahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:7.3":{"pli":"Addasaṁ virajaṁ buddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:7.4":{"pli":"desentaṁ amataṁ padaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:8.1":{"pli":"Visaṭṭhakantavacanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:8.2":{"pli":"karavīkasamassaraṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:8.3":{"pli":"Haṁsarutehi nigghosaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:8.4":{"pli":"viññāpentaṁ mahājanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:9.1":{"pli":"Disvā devātidevaṁ taṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:9.2":{"pli":"sutvāva madhuraṁ giraṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:9.3":{"pli":"Pahāyanappake bhoge, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:9.4":{"pli":"pabbajiṁ anagāriyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:10.1":{"pli":"Evaṁ pabbajito cāhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:10.2":{"pli":"na cirena bahussuto; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:10.3":{"pli":"Ahosiṁ dhammakathiko, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:10.4":{"pli":"vicittapaṭibhānavā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:11.1":{"pli":"Mahāparisamajjhehaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:11.2":{"pli":"haṭṭhacitto punappunaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:11.3":{"pli":"Vaṇṇayiṁ hemavaṇṇassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:11.4":{"pli":"vaṇṇaṁ vaṇṇavisārado. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:12.1":{"pli":"‘Esa khīṇāsavo buddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:12.2":{"pli":"anīgho chinnasaṁsayo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:12.3":{"pli":"Sabbakammakkhayaṁ patto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:12.4":{"pli":"vimuttopadhisaṅkhaye. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:13.1":{"pli":"Esa so bhagavā buddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:13.2":{"pli":"esa sīho anuttaro; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:13.3":{"pli":"Sadevakassa lokassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:13.4":{"pli":"brahmacakkappavattako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:14.1":{"pli":"Danto dametā santo ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:14.2":{"pli":"sametā nibbuto isi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:14.3":{"pli":"Nibbāpetā ca assattho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:14.4":{"pli":"assāsetā mahājanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:15.1":{"pli":"Vīro sūro ca vikkanto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:15.2":{"pli":"pañño kāruṇiko vasī; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:15.3":{"pli":"Vijitāvī ca sa jino, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:15.4":{"pli":"appagabbo anālayo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:16.1":{"pli":"Aneñjo acalo dhīmā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:16.2":{"pli":"amoho asamo muni; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:16.3":{"pli":"Dhorayho usabho nāgo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:16.4":{"pli":"sīho sakko garūsupi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:17.1":{"pli":"Virāgo vimalo brahmā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:17.2":{"pli":"vādī sūro raṇañjaho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:17.3":{"pli":"Akhilo ca visallo ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:17.4":{"pli":"asamo saṁyato suci. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:18.1":{"pli":"Brāhmaṇo samaṇo nātho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:18.2":{"pli":"bhisakko sallakattako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:18.3":{"pli":"Yodho buddho sutāsuto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:18.4":{"pli":"acalo mudito sito. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:19.1":{"pli":"Dhātā dhatā ca santi ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:19.2":{"pli":"kattā netā pakāsitā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:19.3":{"pli":"Sampahaṁsitā bhettā ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:19.4":{"pli":"chettā sotā pasaṁsitā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:20.1":{"pli":"Akhilo ca visallo ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:20.2":{"pli":"anīgho akathaṅkathī; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:20.3":{"pli":"Anejo virajo kattā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:20.4":{"pli":"gandhā vattā pasaṁsitā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:21.1":{"pli":"Tāretā atthakāretā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:21.2":{"pli":"kāretā sampadāritā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:21.3":{"pli":"Pāpetā sahitā kantā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:21.4":{"pli":"hantā ātāpī tāpaso. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:22.1":{"pli":"Samacitto samasamo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:22.2":{"pli":"asahāyo dayālayo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:22.3":{"pli":"Accherasatto akuho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:22.4":{"pli":"katāvī isisattamo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:23.1":{"pli":"Nittiṇṇakaṅkho nimmāno, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:23.2":{"pli":"appameyyo anūpamo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:23.3":{"pli":"Sabbavākyapathātīto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:23.4":{"pli":"saccaneyyantagū jino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:24.1":{"pli":"Sattasāravare tasmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:24.2":{"pli":"Pasādo amatāvaho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:24.3":{"pli":"Tasmā buddhe ca dhamme ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:24.4":{"pli":"Saṅghe saddhā mahatthikā’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:25.1":{"pli":"Guṇehi evamādīhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:25.2":{"pli":"tilokasaraṇuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:25.3":{"pli":"Vaṇṇento parisāmajjhe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:25.4":{"pli":"akaṁ dhammakathaṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:26.1":{"pli":"Tato cutāhaṁ tusite, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:26.2":{"pli":"anubhotvā mahāsukhaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:26.3":{"pli":"Tato cuto manussesu, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:26.4":{"pli":"jāto homi sugandhiko. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:27.1":{"pli":"Nissāso mukhagandho ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:27.2":{"pli":"dehagandho tatheva me; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:27.3":{"pli":"Sedagandho ca satataṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:27.4":{"pli":"sabbagandhova hoti me. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:28.1":{"pli":"Mukhagandho sadā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:28.2":{"pli":"padumuppalacampako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:28.3":{"pli":"Parisanto sadā vāti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:28.4":{"pli":"sarīro ca tatheva me. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:29.1":{"pli":"Guṇatthavassa sabbantaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:29.2":{"pli":"Phalaṁ tu paramabbhutaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:29.3":{"pli":"Ekaggamanasā sabbe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:29.4":{"pli":"Vaṇṇayissaṁ suṇātha me. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:30.1":{"pli":"Guṇaṁ buddhassa vatvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:30.2":{"pli":"hitāya ca na sadisaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:30.3":{"pli":"Sukhito homi sabbattha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:30.4":{"pli":"saṅgho vīrasamāyuto. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:31.1":{"pli":"Yasassī sukhito kanto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:31.2":{"pli":"jutimā piyadassano; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:31.3":{"pli":"Vattā aparibhūto ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:31.4":{"pli":"niddoso paññavā tathā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:32.1":{"pli":"Khīṇe āyusi nibbānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:32.2":{"pli":"sulabhaṁ buddhabhattino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:32.3":{"pli":"Tesaṁ hetuṁ pavakkhāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:32.4":{"pli":"taṁ suṇātha yathātathaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:33.1":{"pli":"Santaṁ yasaṁ bhagavato, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:33.2":{"pli":"vidhinā abhivādayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:33.3":{"pli":"Tattha tatthūpapannopi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:33.4":{"pli":"yasassī tena homahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:34.1":{"pli":"Dukkhassantakaraṁ buddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:34.2":{"pli":"dhammaṁ santamasaṅkhataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:34.3":{"pli":"Vaṇṇayaṁ sukhado āsiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:34.4":{"pli":"sattānaṁ sukhito tato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:35.1":{"pli":"Guṇaṁ vadanto buddhassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:35.2":{"pli":"buddhapītisamāyuto; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:35.3":{"pli":"Sakantiṁ parakantiñca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:35.4":{"pli":"janayiṁ tena kantimā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:36.1":{"pli":"Jino te titthikākiṇṇe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:36.2":{"pli":"abhibhuyya kutitthiye; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:36.3":{"pli":"Guṇaṁ vadanto jotesiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:36.4":{"pli":"nāyakaṁ jutimā tato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:37.1":{"pli":"Piyakārī janassāpi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:37.2":{"pli":"sambuddhassa guṇaṁ vadaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:37.3":{"pli":"Saradova sasaṅkohaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:37.4":{"pli":"tenāsiṁ piyadassano. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:38.1":{"pli":"Yathāsattivasenāhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:38.2":{"pli":"sabbavācāhi santhaviṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:38.3":{"pli":"Sugataṁ tena vāgiso, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:38.4":{"pli":"vicittapaṭibhānavā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:39.1":{"pli":"Ye bālā vimatiṁ pattā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:39.2":{"pli":"paribhonti mahāmuniṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:39.3":{"pli":"Niggahiṁ te saddhammena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:39.4":{"pli":"paribhūto na tenahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:40.1":{"pli":"Buddhavaṇṇena sattānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:40.2":{"pli":"kilese apanesahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:40.3":{"pli":"Nikkilesamano homi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:40.4":{"pli":"tassa kammassa vāhasā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:41.1":{"pli":"Sotūnaṁ vuddhimajaniṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:41.2":{"pli":"buddhānussatidesako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:41.3":{"pli":"Tenāhamāsiṁ sappañño, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:41.4":{"pli":"nipuṇatthavipassako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:42.1":{"pli":"Sabbāsavaparikkhīṇo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:42.2":{"pli":"tiṇṇasaṁsārasāgaro; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:42.3":{"pli":"Sikhīva anupādāno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:42.4":{"pli":"pāpuṇissāmi nibbutiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:43.1":{"pli":"Imasmiṁyeva kappasmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:43.2":{"pli":"yamahaṁ santhaviṁ jinaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:43.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:43.4":{"pli":"buddhavaṇṇassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:44.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:44.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:44.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:45.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:45.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:45.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:46.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:46.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:46.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap532:47.1":{"pli":"Itthaṁ sudaṁ āyasmā sugandho thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap532:48.1":{"pli":"Sugandhattherassāpadānaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap532:49.1":{"pli":"Tiṇadāyakavaggo tepaññāsamo. ","html":"<p class='endsection'>{}</p>"},"tha-ap532:50.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"tha-ap532:51.1":{"pli":"Tiṇado mañcado ceva, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"tha-ap532:51.2":{"pli":"saraṇabbhañjanappado; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:51.3":{"pli":"Supaṭo daṇḍadāyī ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:51.4":{"pli":"nelapūjī tatheva ca. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap532:52.1":{"pli":"Bodhisammajjako maṇḍo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap532:52.2":{"pli":"sugandho dasamoti ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:52.3":{"pli":"Gāthāsataṁ satevīsaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap532:52.4":{"pli":"gaṇitañcettha sabbaso. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}}}