{"ja532":{"ja532:0.1":{"pli":"Jātaka ","html":"<article id='ja532'><header><ul><li class='division'>{}</li>"},"ja532:0.2":{"pli":"Sattatinipāta ","html":"<li>{}</li>"},"ja532:0.3":{"pli":"Kusavagga ","html":"<li>{}</li></ul>"},"ja532:0.4":{"pli":"2. Soṇanandajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja532:1.1":{"pli":"“Devatā nusi gandhabbo, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja532:1.2":{"pli":"adu sakko purindado; ","html":"<span class='verse-line'>{}</span>"},"ja532:1.3":{"pli":"Manussabhūto iddhimā, ","html":"<span class='verse-line'>{}</span>"},"ja532:1.4":{"pli":"kathaṁ jānemu taṁ mayaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:2.1":{"pli":"“Nāpi devo na gandhabbo, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:2.2":{"pli":"nāpi sakko purindado; ","html":"<span class='verse-line'>{}</span>"},"ja532:2.3":{"pli":"Manussabhūto iddhimā, ","html":"<span class='verse-line'>{}</span>"},"ja532:2.4":{"pli":"evaṁ jānāhi bhāradha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:3.1":{"pli":"“Katarūpamidaṁ bhoto, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:3.2":{"pli":"veyyāvaccaṁ anappakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja532:3.3":{"pli":"Devamhi vassamānamhi, ","html":"<span class='verse-line'>{}</span>"},"ja532:3.4":{"pli":"anovassaṁ bhavaṁ akā. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:4.1":{"pli":"Tato vātātape ghore, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:4.2":{"pli":"sītacchāyaṁ bhavaṁ akā; ","html":"<span class='verse-line'>{}</span>"},"ja532:4.3":{"pli":"Tato amittamajjhesu, ","html":"<span class='verse-line'>{}</span>"},"ja532:4.4":{"pli":"saratāṇaṁ bhavaṁ akā. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:5.1":{"pli":"Tato phītāni raṭṭhāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:5.2":{"pli":"vasino te bhavaṁ akā; ","html":"<span class='verse-line'>{}</span>"},"ja532:5.3":{"pli":"Tato ekasataṁ khatye, ","html":"<span class='verse-line'>{}</span>"},"ja532:5.4":{"pli":"anuyante bhavaṁ akā. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:6.1":{"pli":"Patītāssu mayaṁ bhoto, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:6.2":{"pli":"Vada taṁ bhañjamicchasi; ","html":"<span class='verse-line'>{}</span>"},"ja532:6.3":{"pli":"Hatthiyānaṁ assarathaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja532:6.4":{"pli":"Nāriyo ca alaṅkatā; ","html":"<span class='verse-line'>{}</span>"},"ja532:6.5":{"pli":"Nivesanāni rammāni, ","html":"<span class='verse-line'>{}</span>"},"ja532:6.6":{"pli":"Mayaṁ bhoto dadāmase. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:7.1":{"pli":"Atha vaṅge vā magadhe, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:7.2":{"pli":"mayaṁ bhoto dadāmase; ","html":"<span class='verse-line'>{}</span>"},"ja532:7.3":{"pli":"Atha vā assakāvantī, ","html":"<span class='verse-line'>{}</span>"},"ja532:7.4":{"pli":"sumanā damma te mayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:8.1":{"pli":"Upaḍḍhaṁ vāpi rajjassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:8.2":{"pli":"mayaṁ bhoto dadāmase; ","html":"<span class='verse-line'>{}</span>"},"ja532:8.3":{"pli":"Sace te attho rajjena, ","html":"<span class='verse-line'>{}</span>"},"ja532:8.4":{"pli":"anusāsa yadicchasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:9.1":{"pli":"“Na me atthopi rajjena, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:9.2":{"pli":"nagarena dhanena vā; ","html":"<span class='verse-line'>{}</span>"},"ja532:9.3":{"pli":"Athopi janapadena, ","html":"<span class='verse-line'>{}</span>"},"ja532:9.4":{"pli":"attho mayhaṁ na vijjati. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:10.1":{"pli":"Bhotova raṭṭhe vijite, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:10.2":{"pli":"araññe atthi assamo; ","html":"<span class='verse-line'>{}</span>"},"ja532:10.3":{"pli":"Pitā mayhaṁ janettī ca, ","html":"<span class='verse-line'>{}</span>"},"ja532:10.4":{"pli":"ubho sammanti assame. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:11.1":{"pli":"Tesāhaṁ pubbācariyesu, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:11.2":{"pli":"Puññaṁ na labhāmi kātave; ","html":"<span class='verse-line'>{}</span>"},"ja532:11.3":{"pli":"Bhavantaṁ ajjhāvaraṁ katvā, ","html":"<span class='verse-line'>{}</span>"},"ja532:11.4":{"pli":"Soṇaṁ yācemu saṁvaraṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:12.1":{"pli":"“Karomi te taṁ vacanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:12.2":{"pli":"yaṁ maṁ bhaṇasi brāhmaṇa; ","html":"<span class='verse-line'>{}</span>"},"ja532:12.3":{"pli":"Etañca kho no akkhāhi, ","html":"<span class='verse-line'>{}</span>"},"ja532:12.4":{"pli":"kīvanto hontu yācakā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:13.1":{"pli":"“Parosataṁ jānapadā, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:13.2":{"pli":"mahāsālā ca brāhmaṇā; ","html":"<span class='verse-line'>{}</span>"},"ja532:13.3":{"pli":"Ime ca khattiyā sabbe, ","html":"<span class='verse-line'>{}</span>"},"ja532:13.4":{"pli":"abhijātā yasassino; ","html":"<span class='verse-line'>{}</span>"},"ja532:13.5":{"pli":"Bhavañca rājā manojo, ","html":"<span class='verse-line'>{}</span>"},"ja532:13.6":{"pli":"alaṁ hessanti yācakā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:14.1":{"pli":"“Hatthī asse ca yojentu, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:14.2":{"pli":"rathaṁ sannayha sārathi; ","html":"<span class='verse-line'>{}</span>"},"ja532:14.3":{"pli":"Ābandhanāni gaṇhātha, ","html":"<span class='verse-line'>{}</span>"},"ja532:14.4":{"pli":"pādāsussārayaddhaje; ","html":"<span class='verse-line'>{}</span>"},"ja532:14.5":{"pli":"Assamaṁ taṁ gamissāmi, ","html":"<span class='verse-line'>{}</span>"},"ja532:14.6":{"pli":"yattha sammati kosiyo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:15.1":{"pli":"Tato ca rājā pāyāsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:15.2":{"pli":"senāya caturaṅginī; ","html":"<span class='verse-line'>{}</span>"},"ja532:15.3":{"pli":"Agamā assamaṁ rammaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja532:15.4":{"pli":"yattha sammati kosiyo. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:16.1":{"pli":"“Kassa kādambayo kājo, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:16.2":{"pli":"vehāsaṁ caturaṅgulaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja532:16.3":{"pli":"Aṁsaṁ asamphusaṁ eti, ","html":"<span class='verse-line'>{}</span>"},"ja532:16.4":{"pli":"udahārāya gacchato”. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:17.1":{"pli":"“Ahaṁ soṇo mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:17.2":{"pli":"tāpaso sahitabbato; ","html":"<span class='verse-line'>{}</span>"},"ja532:17.3":{"pli":"Bharāmi mātāpitaro, ","html":"<span class='verse-line'>{}</span>"},"ja532:17.4":{"pli":"rattindivamatandito. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:18.1":{"pli":"Vane phalañca mūlañca, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:18.2":{"pli":"āharitvā disampati; ","html":"<span class='verse-line'>{}</span>"},"ja532:18.3":{"pli":"Posemi mātāpitaro, ","html":"<span class='verse-line'>{}</span>"},"ja532:18.4":{"pli":"pubbe katamanussaraṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:19.1":{"pli":"“Icchāma assamaṁ gantuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:19.2":{"pli":"yattha sammati kosiyo; ","html":"<span class='verse-line'>{}</span>"},"ja532:19.3":{"pli":"Maggaṁ no soṇa akkhāhi, ","html":"<span class='verse-line'>{}</span>"},"ja532:19.4":{"pli":"yena gacchemu assamaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:20.1":{"pli":"“Ayaṁ ekapadī rāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:20.2":{"pli":"yenetaṁ meghasannibhaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja532:20.3":{"pli":"Koviḷārehi sañchannaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja532:20.4":{"pli":"ettha sammati kosiyo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:21.1":{"pli":"Idaṁ vatvāna pakkāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:21.2":{"pli":"taramāno mahāisi; ","html":"<span class='verse-line'>{}</span>"},"ja532:21.3":{"pli":"Vehāse antalikkhasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja532:21.4":{"pli":"anusāsitvāna khattiye. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:22.1":{"pli":"Assamaṁ parimajjitvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:22.2":{"pli":"paññāpetvāna āsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja532:22.3":{"pli":"Paṇṇasālaṁ pavisitvā, ","html":"<span class='verse-line'>{}</span>"},"ja532:22.4":{"pli":"pitaraṁ paṭibodhayi. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:23.1":{"pli":"“Ime āyanti rājāno, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:23.2":{"pli":"abhijātā yasassino; ","html":"<span class='verse-line'>{}</span>"},"ja532:23.3":{"pli":"Assamā nikkhamitvāna, ","html":"<span class='verse-line'>{}</span>"},"ja532:23.4":{"pli":"nisīda tvaṁ mahāise”. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:24.1":{"pli":"Tassa taṁ vacanaṁ sutvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:24.2":{"pli":"taramāno mahāisi; ","html":"<span class='verse-line'>{}</span>"},"ja532:24.3":{"pli":"Assamā nikkhamitvāna, ","html":"<span class='verse-line'>{}</span>"},"ja532:24.4":{"pli":"sadvāramhi upāvisi. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:25.1":{"pli":"Tañca disvāna āyantaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:25.2":{"pli":"jalantaṁriva tejasā; ","html":"<span class='verse-line'>{}</span>"},"ja532:25.3":{"pli":"Khatyasaṅghaparibyūḷhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja532:25.4":{"pli":"kosiyo etadabravi. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:26.1":{"pli":"Kassa bherī mudiṅgā ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:26.2":{"pli":"saṅkhā paṇavadindimā; ","html":"<span class='verse-line'>{}</span>"},"ja532:26.3":{"pli":"Purato paṭipannāni, ","html":"<span class='verse-line'>{}</span>"},"ja532:26.4":{"pli":"hāsayantā rathesabhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:27.1":{"pli":"Kassa kañcanapaṭṭena, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:27.2":{"pli":"puthunā vijjuvaṇṇinā; ","html":"<span class='verse-line'>{}</span>"},"ja532:27.3":{"pli":"Yuvā kalāpasannaddho, ","html":"<span class='verse-line'>{}</span>"},"ja532:27.4":{"pli":"ko eti siriyā jalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:28.1":{"pli":"Ukkāmukhapahaṭṭhaṁva, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:28.2":{"pli":"khadiraṅgārasannibhaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja532:28.3":{"pli":"Mukhañca rucirā bhāti, ","html":"<span class='verse-line'>{}</span>"},"ja532:28.4":{"pli":"ko eti siriyā jalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:29.1":{"pli":"Kassa paggahitaṁ chattaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:29.2":{"pli":"sasalākaṁ manoramaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja532:29.3":{"pli":"Ādiccaraṁsāvaraṇaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja532:29.4":{"pli":"ko eti siriyā jalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:30.1":{"pli":"Kassa aṅgaṁ pariggayha, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:30.2":{"pli":"vāḷabījanimuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja532:30.3":{"pli":"Caranti varapuññassa, ","html":"<span class='verse-line'>{}</span>"},"ja532:30.4":{"pli":"hatthikkhandhena āyato. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:31.1":{"pli":"Kassa setāni chattāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:31.2":{"pli":"ājānīyā ca vammitā; ","html":"<span class='verse-line'>{}</span>"},"ja532:31.3":{"pli":"Samantā parikīrenti, ","html":"<span class='verse-line'>{}</span>"},"ja532:31.4":{"pli":"ko eti siriyā jalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:32.1":{"pli":"Kassa ekasataṁ khatyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:32.2":{"pli":"anuyantā yasassino; ","html":"<span class='verse-line'>{}</span>"},"ja532:32.3":{"pli":"Samantānupariyanti, ","html":"<span class='verse-line'>{}</span>"},"ja532:32.4":{"pli":"ko eti siriyā jalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:33.1":{"pli":"Hatthi assaratha patti, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:33.2":{"pli":"senā ca caturaṅginī; ","html":"<span class='verse-line'>{}</span>"},"ja532:33.3":{"pli":"Samantānupariyanti, ","html":"<span class='verse-line'>{}</span>"},"ja532:33.4":{"pli":"ko eti siriyā jalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:34.1":{"pli":"Kassesā mahatī senā, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:34.2":{"pli":"piṭṭhito anuvattati; ","html":"<span class='verse-line'>{}</span>"},"ja532:34.3":{"pli":"Akkhobhaṇī apariyantā, ","html":"<span class='verse-line'>{}</span>"},"ja532:34.4":{"pli":"sāgarasseva ūmiyo. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:35.1":{"pli":"Rājābhirājā manojo, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:35.2":{"pli":"indova jayataṁ pati; ","html":"<span class='verse-line'>{}</span>"},"ja532:35.3":{"pli":"Nandassajjhāvaraṁ eti, ","html":"<span class='verse-line'>{}</span>"},"ja532:35.4":{"pli":"assamaṁ brahmacārinaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:36.1":{"pli":"Tassesā mahatī senā, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:36.2":{"pli":"piṭṭhito anuvattati; ","html":"<span class='verse-line'>{}</span>"},"ja532:36.3":{"pli":"Akkhobhaṇī apariyantā, ","html":"<span class='verse-line'>{}</span>"},"ja532:36.4":{"pli":"sāgarasseva ūmiyo. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:37.1":{"pli":"Anulittā candanena, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:37.2":{"pli":"kāsikuttamadhārino; ","html":"<span class='verse-line'>{}</span>"},"ja532:37.3":{"pli":"Sabbe pañjalikā hutvā, ","html":"<span class='verse-line'>{}</span>"},"ja532:37.4":{"pli":"isīnaṁ ajjhupāgamuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:38.1":{"pli":"“Kacci nu bhoto kusalaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:38.2":{"pli":"kacci bhoto anāmayaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja532:38.3":{"pli":"Kacci uñchena yāpetha, ","html":"<span class='verse-line'>{}</span>"},"ja532:38.4":{"pli":"kacci mūlaphalā bahū. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:39.1":{"pli":"Kacci ḍaṁsā makasā ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:39.2":{"pli":"appameva sarīsapā; ","html":"<span class='verse-line'>{}</span>"},"ja532:39.3":{"pli":"Vane vāḷamigākiṇṇe, ","html":"<span class='verse-line'>{}</span>"},"ja532:39.4":{"pli":"kacci hiṁsā na vijjati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:40.1":{"pli":"“Kusalañceva no rāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:40.2":{"pli":"atho rāja anāmayaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja532:40.3":{"pli":"Atho uñchena yāpema, ","html":"<span class='verse-line'>{}</span>"},"ja532:40.4":{"pli":"atho mūlaphalā bahū. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:41.1":{"pli":"Atho ḍaṁsā makasā ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:41.2":{"pli":"appameva sarīsapā; ","html":"<span class='verse-line'>{}</span>"},"ja532:41.3":{"pli":"Vane vāḷamigākiṇṇe, ","html":"<span class='verse-line'>{}</span>"},"ja532:41.4":{"pli":"hiṁsā mayhaṁ na vijjati. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:42.1":{"pli":"Bahūni vassapūgāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:42.2":{"pli":"assame sammataṁ idha; ","html":"<span class='verse-line'>{}</span>"},"ja532:42.3":{"pli":"Nābhijānāmi uppannaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja532:42.4":{"pli":"ābādhaṁ amanoramaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:43.1":{"pli":"Svāgataṁ te mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:43.2":{"pli":"atho te adurāgataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja532:43.3":{"pli":"Issarosi anuppatto, ","html":"<span class='verse-line'>{}</span>"},"ja532:43.4":{"pli":"yaṁ idhatthi pavedaya. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:44.1":{"pli":"Tindukāni piyālāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:44.2":{"pli":"madhuke kāsumāriyo; ","html":"<span class='verse-line'>{}</span>"},"ja532:44.3":{"pli":"Phalāni khuddakappāni, ","html":"<span class='verse-line'>{}</span>"},"ja532:44.4":{"pli":"bhuñja rāja varaṁ varaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:45.1":{"pli":"Idampi pānīyaṁ sītaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:45.2":{"pli":"ābhataṁ girigabbharā; ","html":"<span class='verse-line'>{}</span>"},"ja532:45.3":{"pli":"Tato piva mahārāja, ","html":"<span class='verse-line'>{}</span>"},"ja532:45.4":{"pli":"sace tvaṁ abhikaṅkhasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:46.1":{"pli":"“Paṭiggahitaṁ yaṁ dinnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:46.2":{"pli":"sabbassa agghiyaṁ kataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja532:46.3":{"pli":"Nandassāpi nisāmetha, ","html":"<span class='verse-line'>{}</span>"},"ja532:46.4":{"pli":"vacanaṁ so pavakkhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:47.1":{"pli":"Ajjhāvaramhā nandassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:47.2":{"pli":"bhoto santikamāgatā; ","html":"<span class='verse-line'>{}</span>"},"ja532:47.3":{"pli":"Suṇātu bhavaṁ vacanaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja532:47.4":{"pli":"nandassa parisāya ca”. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:48.1":{"pli":"“Parosataṁ jānapadā, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:48.2":{"pli":"mahāsālā ca brāhmaṇā; ","html":"<span class='verse-line'>{}</span>"},"ja532:48.3":{"pli":"Ime ca khattiyā sabbe, ","html":"<span class='verse-line'>{}</span>"},"ja532:48.4":{"pli":"abhijātā yasassino; ","html":"<span class='verse-line'>{}</span>"},"ja532:48.5":{"pli":"Bhavañca rājā manojo, ","html":"<span class='verse-line'>{}</span>"},"ja532:48.6":{"pli":"anumaññantu me vaco. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:49.1":{"pli":"Ye ca santi samītāro, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:49.2":{"pli":"yakkhāni idha massame; ","html":"<span class='verse-line'>{}</span>"},"ja532:49.3":{"pli":"Araññe bhūtabhabyāni, ","html":"<span class='verse-line'>{}</span>"},"ja532:49.4":{"pli":"suṇantu vacanaṁ mama. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:50.1":{"pli":"Namo katvāna bhūtānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:50.2":{"pli":"isiṁ vakkhāmi subbataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja532:50.3":{"pli":"So tyāhaṁ dakkhiṇā bāhu, ","html":"<span class='verse-line'>{}</span>"},"ja532:50.4":{"pli":"tava kosiya sammato. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:51.1":{"pli":"Pitaraṁ me janettiñca, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:51.2":{"pli":"bhattukāmassa me sato; ","html":"<span class='verse-line'>{}</span>"},"ja532:51.3":{"pli":"Vīra puññamidaṁ ṭhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja532:51.4":{"pli":"mā maṁ kosiya vāraya. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:52.1":{"pli":"Sabbhi hetaṁ upaññātaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:52.2":{"pli":"mametaṁ upanissaja; ","html":"<span class='verse-line'>{}</span>"},"ja532:52.3":{"pli":"Uṭṭhānapāricariyāya, ","html":"<span class='verse-line'>{}</span>"},"ja532:52.4":{"pli":"dīgharattaṁ tayā kataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja532:52.5":{"pli":"Mātāpitūsu puññāni, ","html":"<span class='verse-line'>{}</span>"},"ja532:52.6":{"pli":"mama lokadado bhava. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:53.1":{"pli":"Tatheva santi manujā, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:53.2":{"pli":"dhamme dhammapadaṁ vidū; ","html":"<span class='verse-line'>{}</span>"},"ja532:53.3":{"pli":"Maggo saggassa lokassa, ","html":"<span class='verse-line'>{}</span>"},"ja532:53.4":{"pli":"yathā jānāsi tvaṁ ise. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:54.1":{"pli":"Uṭṭhānapāricariyāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:54.2":{"pli":"mātāpitusukhāvahaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja532:54.3":{"pli":"Taṁ maṁ puññā nivāreti, ","html":"<span class='verse-line'>{}</span>"},"ja532:54.4":{"pli":"ariyamaggāvaro naro”. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:55.1":{"pli":"“Suṇantu bhonto vacanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:55.2":{"pli":"bhāturajjhāvarā mama; ","html":"<span class='verse-line'>{}</span>"},"ja532:55.3":{"pli":"Kulavaṁsaṁ mahārāja, ","html":"<span class='verse-line'>{}</span>"},"ja532:55.4":{"pli":"porāṇaṁ parihāpayaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja532:55.5":{"pli":"Adhammacārī jeṭṭhesu, ","html":"<span class='verse-line'>{}</span>"},"ja532:55.6":{"pli":"nirayaṁ sopapajjati. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:56.1":{"pli":"Ye ca dhammassa kusalā, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:56.2":{"pli":"porāṇassa disampati; ","html":"<span class='verse-line'>{}</span>"},"ja532:56.3":{"pli":"Cārittena ca sampannā, ","html":"<span class='verse-line'>{}</span>"},"ja532:56.4":{"pli":"na te gacchanti duggatiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:57.1":{"pli":"Mātā pitā ca bhātā ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:57.2":{"pli":"bhaginī ñātibandhavā; ","html":"<span class='verse-line'>{}</span>"},"ja532:57.3":{"pli":"Sabbe jeṭṭhassa te bhārā, ","html":"<span class='verse-line'>{}</span>"},"ja532:57.4":{"pli":"evaṁ jānāhi bhāradha. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:58.1":{"pli":"Ādiyitvā garuṁ bhāraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:58.2":{"pli":"nāviko viya ussahe; ","html":"<span class='verse-line'>{}</span>"},"ja532:58.3":{"pli":"Dhammañca nappamajjāmi, ","html":"<span class='verse-line'>{}</span>"},"ja532:58.4":{"pli":"jeṭṭho casmi rathesabha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:59.1":{"pli":"“Adhigamā tame ñāṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:59.2":{"pli":"Jālaṁva jātavedato; ","html":"<span class='verse-line'>{}</span>"},"ja532:59.3":{"pli":"Evameva no bhavaṁ dhammaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja532:59.4":{"pli":"Kosiyo pavidaṁsayi. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:60.1":{"pli":"Yathā udayamādicco, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:60.2":{"pli":"Vāsudevo pabhaṅkaro; ","html":"<span class='verse-line'>{}</span>"},"ja532:60.3":{"pli":"Pāṇīnaṁ pavidaṁseti, ","html":"<span class='verse-line'>{}</span>"},"ja532:60.4":{"pli":"Rūpaṁ kalyāṇapāpakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja532:60.5":{"pli":"Evameva no bhavaṁ dhammaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja532:60.6":{"pli":"Kosiyo pavidaṁsayi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:61.1":{"pli":"“Evaṁ me yācamānassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:61.2":{"pli":"añjaliṁ nāvabujjhatha; ","html":"<span class='verse-line'>{}</span>"},"ja532:61.3":{"pli":"Tava paddhacaro hessaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja532:61.4":{"pli":"vuṭṭhito paricārako”. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:62.1":{"pli":"“Addhā nanda vijānāsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:62.2":{"pli":"Saddhammaṁ sabbhi desitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja532:62.3":{"pli":"Ariyo ariyasamācāro, ","html":"<span class='verse-line'>{}</span>"},"ja532:62.4":{"pli":"Bāḷhaṁ tvaṁ mama ruccasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:63.1":{"pli":"Bhavantaṁ vadāmi bhotiñca, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:63.2":{"pli":"suṇātha vacanaṁ mama; ","html":"<span class='verse-line'>{}</span>"},"ja532:63.3":{"pli":"Nāyaṁ bhāro bhāramato, ","html":"<span class='verse-line'>{}</span>"},"ja532:63.4":{"pli":"ahu mayhaṁ kudācanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:64.1":{"pli":"Taṁ maṁ upaṭṭhitaṁ santaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:64.2":{"pli":"mātāpitusukhāvahaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja532:64.3":{"pli":"Nando ajjhāvaraṁ katvā, ","html":"<span class='verse-line'>{}</span>"},"ja532:64.4":{"pli":"upaṭṭhānāya yācati. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:65.1":{"pli":"Yo ve icchati kāmena, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:65.2":{"pli":"santānaṁ brahmacārinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja532:65.3":{"pli":"Nandaṁ vo varatha eko, ","html":"<span class='verse-line'>{}</span>"},"ja532:65.4":{"pli":"kaṁ nando upatiṭṭhatu”. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:66.1":{"pli":"“Tayā tāta anuññātā, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:66.2":{"pli":"soṇa taṁ nissitā mayaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja532:66.3":{"pli":"Upaghātuṁ labhe nandaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja532:66.4":{"pli":"muddhani brahmacārinaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:67.1":{"pli":"Assatthasseva taruṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:67.2":{"pli":"pavāḷaṁ māluteritaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja532:67.3":{"pli":"Cirassaṁ nandaṁ disvāna, ","html":"<span class='verse-line'>{}</span>"},"ja532:67.4":{"pli":"hadayaṁ me pavedhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:68.1":{"pli":"Yadā suttāpi supine, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:68.2":{"pli":"nandaṁ passāmi āgataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja532:68.3":{"pli":"Udaggā sumanā homi, ","html":"<span class='verse-line'>{}</span>"},"ja532:68.4":{"pli":"nando no āgato ayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:69.1":{"pli":"Yadā ca paṭibujjhitvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:69.2":{"pli":"nandaṁ passāmi nāgataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja532:69.3":{"pli":"Bhiyyo āvisatī soko, ","html":"<span class='verse-line'>{}</span>"},"ja532:69.4":{"pli":"domanassañcanappakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:70.1":{"pli":"Sāhaṁ ajja cirassampi, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:70.2":{"pli":"nandaṁ passāmi āgataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja532:70.3":{"pli":"Bhattucca mayhañca piyo, ","html":"<span class='verse-line'>{}</span>"},"ja532:70.4":{"pli":"nando no pāvisī gharaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:71.1":{"pli":"Pitupi nando suppiyo, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:71.2":{"pli":"Yaṁ nando nappavase gharā; ","html":"<span class='verse-line'>{}</span>"},"ja532:71.3":{"pli":"Labhatū tāta nando taṁ, ","html":"<span class='verse-line'>{}</span>"},"ja532:71.4":{"pli":"Maṁ nando upatiṭṭhatu”. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:72.1":{"pli":"“Anukampikā patiṭṭhā ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:72.2":{"pli":"pubbe rasadadī ca no; ","html":"<span class='verse-line'>{}</span>"},"ja532:72.3":{"pli":"Maggo saggassa lokassa, ","html":"<span class='verse-line'>{}</span>"},"ja532:72.4":{"pli":"mātā taṁ varate ise. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:73.1":{"pli":"Pubbe rasadadī gottī, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:73.2":{"pli":"mātā puññūpasaṁhitā; ","html":"<span class='verse-line'>{}</span>"},"ja532:73.3":{"pli":"Maggo saggassa lokassa, ","html":"<span class='verse-line'>{}</span>"},"ja532:73.4":{"pli":"mātā taṁ varate ise”. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:74.1":{"pli":"“Ākaṅkhamānā puttaphalaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:74.2":{"pli":"devatāya namassati; ","html":"<span class='verse-line'>{}</span>"},"ja532:74.3":{"pli":"Nakkhattāni ca pucchati, ","html":"<span class='verse-line'>{}</span>"},"ja532:74.4":{"pli":"utusaṁvaccharāni ca. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:75.1":{"pli":"Tassā utumhi nhātāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:75.2":{"pli":"hoti gabbhassa vokkamo; ","html":"<span class='verse-line'>{}</span>"},"ja532:75.3":{"pli":"Tena dohaḷinī hoti, ","html":"<span class='verse-line'>{}</span>"},"ja532:75.4":{"pli":"suhadā tena vuccati. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:76.1":{"pli":"Saṁvaccharaṁ vā ūnaṁ vā, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:76.2":{"pli":"pariharitvā vijāyati; ","html":"<span class='verse-line'>{}</span>"},"ja532:76.3":{"pli":"Tena sā janayantīti, ","html":"<span class='verse-line'>{}</span>"},"ja532:76.4":{"pli":"janetti tena vuccati. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:77.1":{"pli":"Thanakhīrena gītena, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:77.2":{"pli":"aṅgapāvuraṇena ca; ","html":"<span class='verse-line'>{}</span>"},"ja532:77.3":{"pli":"Rodantaṁ puttaṁ toseti, ","html":"<span class='verse-line'>{}</span>"},"ja532:77.4":{"pli":"tosentī tena vuccati. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:78.1":{"pli":"Tato vātātape ghore, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:78.2":{"pli":"mamaṁ katvā udikkhati; ","html":"<span class='verse-line'>{}</span>"},"ja532:78.3":{"pli":"Dārakaṁ appajānantaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja532:78.4":{"pli":"posentī tena vuccati. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:79.1":{"pli":"Yañca mātudhanaṁ hoti, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:79.2":{"pli":"yañca hoti pituddhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja532:79.3":{"pli":"Ubhayampetassa gopeti, ","html":"<span class='verse-line'>{}</span>"},"ja532:79.4":{"pli":"api puttassa no siyā. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:80.1":{"pli":"Evaṁ putta aduṁ putta, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:80.2":{"pli":"iti mātā vihaññati; ","html":"<span class='verse-line'>{}</span>"},"ja532:80.3":{"pli":"Pamattaṁ paradāresu, ","html":"<span class='verse-line'>{}</span>"},"ja532:80.4":{"pli":"nisīthe pattayobbane; ","html":"<span class='verse-line'>{}</span>"},"ja532:80.5":{"pli":"Sāyaṁ puttaṁ anāyantaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja532:80.6":{"pli":"iti mātā vihaññati. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:81.1":{"pli":"Evaṁ kicchā bhato poso, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:81.2":{"pli":"mātu aparicārako; ","html":"<span class='verse-line'>{}</span>"},"ja532:81.3":{"pli":"Mātari micchā caritvāna, ","html":"<span class='verse-line'>{}</span>"},"ja532:81.4":{"pli":"nirayaṁ sopapajjati. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:82.1":{"pli":"Evaṁ kicchā bhato poso, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:82.2":{"pli":"pitu aparicārako; ","html":"<span class='verse-line'>{}</span>"},"ja532:82.3":{"pli":"Pitari micchā caritvāna, ","html":"<span class='verse-line'>{}</span>"},"ja532:82.4":{"pli":"nirayaṁ sopapajjati. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:83.1":{"pli":"Dhanāpi dhanakāmānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:83.2":{"pli":"Nassati iti me sutaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja532:83.3":{"pli":"Mātaraṁ aparicaritvāna, ","html":"<span class='verse-line'>{}</span>"},"ja532:83.4":{"pli":"Kicchaṁ vā so nigacchati. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:84.1":{"pli":"Dhanāpi dhanakāmānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:84.2":{"pli":"Nassati iti me sutaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja532:84.3":{"pli":"Pitaraṁ aparicaritvāna, ","html":"<span class='verse-line'>{}</span>"},"ja532:84.4":{"pli":"Kicchaṁ vā so nigacchati. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:85.1":{"pli":"Ānando ca pamodo ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:85.2":{"pli":"sadā hasitakīḷitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja532:85.3":{"pli":"Mātaraṁ paricaritvāna, ","html":"<span class='verse-line'>{}</span>"},"ja532:85.4":{"pli":"labbhametaṁ vijānato. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:86.1":{"pli":"Ānando ca pamodo ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:86.2":{"pli":"sadā hasitakīḷitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja532:86.3":{"pli":"Pitaraṁ paricaritvāna, ","html":"<span class='verse-line'>{}</span>"},"ja532:86.4":{"pli":"labbhametaṁ vijānato. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:87.1":{"pli":"Dānañca piyavācā ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:87.2":{"pli":"atthacariyā ca yā idha; ","html":"<span class='verse-line'>{}</span>"},"ja532:87.3":{"pli":"Samānattatā ca dhammesu, ","html":"<span class='verse-line'>{}</span>"},"ja532:87.4":{"pli":"tattha tattha yathārahaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja532:87.5":{"pli":"Ete kho saṅgahā loke, ","html":"<span class='verse-line'>{}</span>"},"ja532:87.6":{"pli":"rathassāṇīva yāyato. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:88.1":{"pli":"Ete ca saṅgahā nāssu, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:88.2":{"pli":"na mātā puttakāraṇā; ","html":"<span class='verse-line'>{}</span>"},"ja532:88.3":{"pli":"Labhetha mānaṁ pūjaṁ vā, ","html":"<span class='verse-line'>{}</span>"},"ja532:88.4":{"pli":"pitā vā puttakāraṇā. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:89.1":{"pli":"Yasmā ca saṅgahā ete, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:89.2":{"pli":"sammapekkhanti paṇḍitā; ","html":"<span class='verse-line'>{}</span>"},"ja532:89.3":{"pli":"Tasmā mahattaṁ papponti, ","html":"<span class='verse-line'>{}</span>"},"ja532:89.4":{"pli":"pāsaṁsā ca bhavanti te. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:90.1":{"pli":"Brahmāti mātāpitaro, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:90.2":{"pli":"pubbācariyāti vuccare; ","html":"<span class='verse-line'>{}</span>"},"ja532:90.3":{"pli":"Āhuneyyā ca puttānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja532:90.4":{"pli":"pajāya anukampakā. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:91.1":{"pli":"Tasmā hi ne namasseyya, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:91.2":{"pli":"sakkareyya ca paṇḍito; ","html":"<span class='verse-line'>{}</span>"},"ja532:91.3":{"pli":"Annena atho pānena, ","html":"<span class='verse-line'>{}</span>"},"ja532:91.4":{"pli":"vatthena sayanena ca; ","html":"<span class='verse-line'>{}</span>"},"ja532:91.5":{"pli":"Ucchādanena nhāpanena, ","html":"<span class='verse-line'>{}</span>"},"ja532:91.6":{"pli":"pādānaṁ dhovanena ca. ","html":"<span class='verse-line'>{}</span></p>"},"ja532:92.1":{"pli":"Tāya naṁ pāricariyāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja532:92.2":{"pli":"Mātāpitūsu paṇḍitā; ","html":"<span class='verse-line'>{}</span>"},"ja532:92.3":{"pli":"Idheva naṁ pasaṁsanti, ","html":"<span class='verse-line'>{}</span>"},"ja532:92.4":{"pli":"Pecca sagge pamodatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja532:93.1":{"pli":"Soṇanandajātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja532:94.1":{"pli":"Sattatinipātaṁ niṭṭhitaṁ. ","html":"<p class='endsection'>{}</p>"},"ja532:95.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja532:96.1":{"pli":"Atha sattatimamhi nipātavare, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja532:96.2":{"pli":"Sabhāvantu kusāvatirājavaro; ","html":"<span class='verse-line'>{}</span>"},"ja532:96.3":{"pli":"Atha soṇasunandavaro ca puna, ","html":"<span class='verse-line'>{}</span>"},"ja532:96.4":{"pli":"Abhivāsitasattatimamhi suteti. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}}}