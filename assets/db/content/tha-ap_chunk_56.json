{"tha-ap552":{"tha-ap552:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap552'><header><ul><li class='division'>{}</li>"},"tha-ap552:0.2":{"pli":"Bhaddiyavagga ","html":"<li>{}</li></ul>"},"tha-ap552:0.3":{"pli":"Cūḷasugandhattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap552:1.1":{"pli":"“Imamhi bhaddake kappe, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap552:1.2":{"pli":"brahmabandhu mahāyaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:1.3":{"pli":"Kassapo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:1.4":{"pli":"uppajji vadataṁ varo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:2.1":{"pli":"Anubyañjanasampanno, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:2.2":{"pli":"bāttiṁsavaralakkhaṇo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:2.3":{"pli":"Byāmappabhāparivuto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:2.4":{"pli":"raṁsijālasamotthaṭo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:3.1":{"pli":"Assāsetā yathā cando, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:3.2":{"pli":"sūriyova pabhaṅkaro; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:3.3":{"pli":"Nibbāpetā yathā megho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:3.4":{"pli":"sāgarova guṇākaro. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:4.1":{"pli":"Dharaṇīriva sīlena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:4.2":{"pli":"himavāva samādhinā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:4.3":{"pli":"Ākāso viya paññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:4.4":{"pli":"asaṅgo anilo yathā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:5.1":{"pli":"Tadāhaṁ bārāṇasiyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:5.2":{"pli":"upapanno mahākule; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:5.3":{"pli":"Pahūtadhanadhaññasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:5.4":{"pli":"nānāratanasañcaye. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:6.1":{"pli":"Mahatā parivārena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:6.2":{"pli":"nisinnaṁ lokanāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:6.3":{"pli":"Upecca dhammamassosiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:6.4":{"pli":"amataṁva manoharaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:7.1":{"pli":"Dvattiṁsalakkhaṇadharo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:7.2":{"pli":"sanakkhattova candimā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:7.3":{"pli":"Anubyañjanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:7.4":{"pli":"sālarājāva phullito. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:8.1":{"pli":"Raṁsijālaparikkhitto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:8.2":{"pli":"dittova kanakācalo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:8.3":{"pli":"Byāmappabhāparivuto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:8.4":{"pli":"sataraṁsī divākaro. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:9.1":{"pli":"Soṇṇānano jinavaro, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:9.2":{"pli":"samaṇīva siluccayo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:9.3":{"pli":"Karuṇā puṇṇahadayo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:9.4":{"pli":"guṇena viya sāgaro. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:10.1":{"pli":"Lokavissutakitti ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:10.2":{"pli":"sinerūva naguttamo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:10.3":{"pli":"Yasasā vitthato vīro, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:10.4":{"pli":"ākāsasadiso muni. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:11.1":{"pli":"Asaṅgacitto sabbattha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:11.2":{"pli":"anilo viya nāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:11.3":{"pli":"Patiṭṭhā sabbabhūtānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:11.4":{"pli":"mahīva munisattamo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:12.1":{"pli":"Anupalitto lokena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:12.2":{"pli":"toyena padumaṁ yathā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:12.3":{"pli":"Kuvādagacchadahano, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:12.4":{"pli":"aggikhandhova sobhasi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:13.1":{"pli":"Agadho viya sabbattha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:13.2":{"pli":"kilesavisanāsako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:13.3":{"pli":"Gandhamādanaselova, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:13.4":{"pli":"guṇagandhavibhūsito. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:14.1":{"pli":"Guṇānaṁ ākaro vīro, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:14.2":{"pli":"ratanānaṁva sāgaro; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:14.3":{"pli":"Sindhūva vanarājīnaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:14.4":{"pli":"kilesamalahārako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:15.1":{"pli":"Vijayīva mahāyodho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:15.2":{"pli":"mārasenāvamaddano; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:15.3":{"pli":"Cakkavattīva so rājā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:15.4":{"pli":"bojjhaṅgaratanissaro. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:16.1":{"pli":"Mahābhisakkasaṅkāso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:16.2":{"pli":"dosabyādhitikicchako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:16.3":{"pli":"Sallakatto yathā vejjo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:16.4":{"pli":"diṭṭhigaṇḍaviphālako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:17.1":{"pli":"So tadā lokapajjoto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:17.2":{"pli":"sanarāmarasakkato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:17.3":{"pli":"Parisāsu narādicco, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:17.4":{"pli":"dhammaṁ desayate jino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:18.1":{"pli":"‘Dānaṁ datvā mahābhogo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:18.2":{"pli":"sīlena sugatūpago; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:18.3":{"pli":"Bhāvanāya ca nibbāti’, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:18.4":{"pli":"iccevamanusāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:19.1":{"pli":"Desanaṁ taṁ mahassādaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:19.2":{"pli":"ādimajjhantasobhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:19.3":{"pli":"Suṇanti parisā sabbā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:19.4":{"pli":"amataṁva mahārasaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:20.1":{"pli":"Sutvā sumadhuraṁ dhammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:20.2":{"pli":"pasanno jinasāsane; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:20.3":{"pli":"Sugataṁ saraṇaṁ gantvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:20.4":{"pli":"yāvajīvaṁ namassahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:21.1":{"pli":"Munino gandhakuṭiyā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:21.2":{"pli":"opuñjesiṁ tadā mahiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:21.3":{"pli":"Catujjātena gandhena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:21.4":{"pli":"māse aṭṭha dinesvahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:22.1":{"pli":"Paṇidhāya sugandhattaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:22.2":{"pli":"sarīravissagandhino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:22.3":{"pli":"Tadā jino viyākāsi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:22.4":{"pli":"sugandhatanulābhitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:23.1":{"pli":"‘Yo yaṁ gandhakuṭibhūmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:23.2":{"pli":"gandhenopuñjate sakiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:23.3":{"pli":"Tena kammavipākena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:23.4":{"pli":"upapanno tahiṁ tahiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:24.1":{"pli":"Sugandhadeho sabbattha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:24.2":{"pli":"bhavissati ayaṁ naro; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:24.3":{"pli":"Guṇagandhayutto hutvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:24.4":{"pli":"nibbāyissatināsavo’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:25.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:25.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:25.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:25.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:26.1":{"pli":"Pacchime ca bhave dāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:26.2":{"pli":"jāto vippakule ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:26.3":{"pli":"Gabbhaṁ me vasato mātā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:26.4":{"pli":"dehenāsi sugandhitā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:27.1":{"pli":"Yadā ca mātukucchimhā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:27.2":{"pli":"nikkhamāmi tadā purī; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:27.3":{"pli":"Sāvatthisabbagandhehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:27.4":{"pli":"vāsitā viya vāyatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:28.1":{"pli":"Pupphavassañca surabhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:28.2":{"pli":"dibbagandhaṁ manoramaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:28.3":{"pli":"Dhūpāni ca mahagghāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:28.4":{"pli":"upavāyiṁsu tāvade. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:29.1":{"pli":"Devā ca sabbagandhehi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:29.2":{"pli":"dhūpapupphehi taṁ gharaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:29.3":{"pli":"Vāsayiṁsu sugandhena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:29.4":{"pli":"yasmiṁ jāto ahaṁ ghare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:30.1":{"pli":"Yadā ca taruṇo bhaddo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:30.2":{"pli":"paṭhame yobbane ṭhito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:30.3":{"pli":"Tadā selaṁ saparisaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:30.4":{"pli":"vinetvā narasārathi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:31.1":{"pli":"Tehi sabbehi parivuto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:31.2":{"pli":"sāvatthipuramāgato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:31.3":{"pli":"Tadā buddhānubhāvaṁ taṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:31.4":{"pli":"disvā pabbajito ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:32.1":{"pli":"Sīlaṁ samādhipaññañca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:32.2":{"pli":"vimuttiñca anuttaraṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:32.3":{"pli":"Bhāvetvā caturo dhamme, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:32.4":{"pli":"pāpuṇiṁ āsavakkhayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:33.1":{"pli":"Yadā pabbajito cāhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:33.2":{"pli":"yadā ca arahā ahuṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:33.3":{"pli":"Nibbāyissaṁ yadā cāhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:33.4":{"pli":"gandhavasso tadā ahu. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:34.1":{"pli":"Sarīragandho ca sadātiseti me, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:34.2":{"pli":"Mahārahaṁ candanacampakuppalaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:34.3":{"pli":"Tatheva gandhe itare ca sabbaso, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:34.4":{"pli":"Pasayha vāyāmi tato tahiṁ tahiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:35.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:35.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:35.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:36.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:36.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:36.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:37.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:37.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:37.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap552:38.1":{"pli":"Itthaṁ sudaṁ āyasmā cūḷasugandho thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap552:39.1":{"pli":"Cūḷasugandhattherassāpadānaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap552:40.1":{"pli":"Bhaddiyavaggo pañcapaññāsamo. ","html":"<p class='endsection'>{}</p>"},"tha-ap552:41.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"tha-ap552:42.1":{"pli":"Bhaddiyo revato thero, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"tha-ap552:42.2":{"pli":"mahālābhī ca sīvali; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:42.3":{"pli":"Vaṅgīso nandako ceva, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:42.4":{"pli":"kāḷudāyī tathābhayo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:43.1":{"pli":"Lomaso vanavaccho ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:43.2":{"pli":"sugandho ceva dasamo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:43.3":{"pli":"Tīṇi gāthāsatā tattha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:43.4":{"pli":"soḷasā ca taduttari. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap552:44.1":{"pli":"Atha vagguddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"tha-ap552:45.1":{"pli":"Kaṇikāravhayo vaggo, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"tha-ap552:45.2":{"pli":"phalado tiṇadāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:45.3":{"pli":"Kaccāno bhaddiyo vaggo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:45.4":{"pli":"gāthāyo gaṇitā cimā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:46.1":{"pli":"Navagāthāsatānīha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:46.2":{"pli":"caturāsītiyeva ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:46.3":{"pli":"Sapaññāsaṁ pañcasataṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:46.4":{"pli":"apadānā pakāsitā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap552:47.1":{"pli":"Saha udānagāthāhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap552:47.2":{"pli":"chasahassāni hontimā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:47.3":{"pli":"Dvesatāni ca gāthānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap552:47.4":{"pli":"aṭṭhārasa taduttari. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"tha-ap553":{"tha-ap553:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap553'><header><ul><li class='division'>{}</li>"},"tha-ap553:0.2":{"pli":"Yasavagga ","html":"<li>{}</li></ul>"},"tha-ap553:0.3":{"pli":"Yasattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap553:1.1":{"pli":"“Mahāsamuddaṁ oggayha, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap553:1.2":{"pli":"bhavanaṁ me sunimmitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:1.3":{"pli":"Sunimmitā pokkharaṇī, ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:1.4":{"pli":"cakkavākūpakūjitā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap553:2.1":{"pli":"Mandārakehi sañchannā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap553:2.2":{"pli":"padumuppalakehi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:2.3":{"pli":"Nadī ca sandate tattha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:2.4":{"pli":"supatitthā manoramā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap553:3.1":{"pli":"Macchakacchapasañchannā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap553:3.2":{"pli":"nānādijasamotthaṭā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:3.3":{"pli":"Mayūrakoñcābhirudā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:3.4":{"pli":"kokilādīhi vagguhi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap553:4.1":{"pli":"Pārevatā ravihaṁsā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap553:4.2":{"pli":"cakkavākā nadīcarā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:4.3":{"pli":"Tittirā sālikā cettha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:4.4":{"pli":"pāvakā jīvaṁjīvakā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap553:5.1":{"pli":"Haṁsākoñcābhinaditā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap553:5.2":{"pli":"kosiyā piṅgalā bahū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:5.3":{"pli":"Sattaratanasampannā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:5.4":{"pli":"maṇimuttapavāḷikā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap553:6.1":{"pli":"Sabbe soṇṇamayā rukkhā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap553:6.2":{"pli":"nānākhandhasameritā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:6.3":{"pli":"Ujjotenti divārattiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:6.4":{"pli":"bhavanaṁ sabbakālikaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap553:7.1":{"pli":"Saṭṭhituriyasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap553:7.2":{"pli":"sāyaṁ pāto pavajjare; ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:7.3":{"pli":"Soḷasitthisahassāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:7.4":{"pli":"parivārenti maṁ sadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap553:8.1":{"pli":"Abhinikkhamma bhavanā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap553:8.2":{"pli":"sumedhaṁ lokanāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:8.3":{"pli":"Pasannacitto sumano, ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:8.4":{"pli":"vandayiṁ taṁ mahāyasaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap553:9.1":{"pli":"Sambuddhaṁ abhivādetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap553:9.2":{"pli":"sasaṅghaṁ taṁ nimantayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:9.3":{"pli":"Adhivāsesi so dhīro, ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:9.4":{"pli":"sumedho lokanāyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap553:10.1":{"pli":"Mama dhammakathaṁ katvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap553:10.2":{"pli":"uyyojesi mahāmuni; ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:10.3":{"pli":"Sambuddhaṁ abhivādetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:10.4":{"pli":"bhavanaṁ me upāgamiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap553:11.1":{"pli":"Āmantayiṁ parijanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap553:11.2":{"pli":"sabbe sannipatuṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:11.3":{"pli":"‘Pubbaṇhasamayaṁ buddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:11.4":{"pli":"bhavanaṁ āgamissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap553:12.1":{"pli":"Lābhā amhaṁ suladdhā no, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap553:12.2":{"pli":"ye vasāma tavantike; ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:12.3":{"pli":"Mayampi buddhaseṭṭhassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:12.4":{"pli":"pūjayissāma satthuno’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap553:13.1":{"pli":"Annaṁ pānaṁ paṭṭhapetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap553:13.2":{"pli":"kālaṁ ārocayiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:13.3":{"pli":"Vasīsatasahassehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:13.4":{"pli":"upesi lokanāyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap553:14.1":{"pli":"Pañcaṅgikehi turiyehi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap553:14.2":{"pli":"paccuggamamakāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:14.3":{"pli":"Sabbasoṇṇamaye pīṭhe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:14.4":{"pli":"nisīdi purisuttamo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap553:15.1":{"pli":"Uparicchadanaṁ āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap553:15.2":{"pli":"sabbasoṇṇamayaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:15.3":{"pli":"Bījanīyo pavāyanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:15.4":{"pli":"bhikkhusaṅghaṁ anuttaraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap553:16.1":{"pli":"Pahūtenannapānena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap553:16.2":{"pli":"bhikkhusaṅghaṁ atappayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:16.3":{"pli":"Paccekadussayugale, ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:16.4":{"pli":"bhikkhusaṅghassadāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap553:17.1":{"pli":"Yaṁ vadeti sumedho so, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap553:17.2":{"pli":"āhutīnaṁ paṭiggaho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:17.3":{"pli":"Bhikkhusaṅghe nisīditvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:17.4":{"pli":"imā gāthā abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap553:18.1":{"pli":"‘Yo maṁ annena pānena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap553:18.2":{"pli":"sabbe ime ca tappayi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:18.3":{"pli":"Tamahaṁ kittayissāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:18.4":{"pli":"suṇātha mama bhāsato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap553:19.1":{"pli":"Aṭṭhārase kappasate, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap553:19.2":{"pli":"devaloke ramissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:19.3":{"pli":"Sahassakkhattuṁ rājāyaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:19.4":{"pli":"cakkavattī bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap553:20.1":{"pli":"Upagacchati yaṁ yoniṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap553:20.2":{"pli":"devattaṁ atha mānusaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:20.3":{"pli":"Sabbasoṇṇamayaṁ tassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:20.4":{"pli":"chadanaṁ dhārayissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap553:21.1":{"pli":"Tiṁsakappasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap553:21.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:21.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:21.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap553:22.1":{"pli":"Tassa dhammesu dāyādo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap553:22.2":{"pli":"oraso dhammanimmito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:22.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:22.4":{"pli":"nibbāyissatināsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap553:23.1":{"pli":"Bhikkhusaṅghe nisīditvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap553:23.2":{"pli":"sīhanādaṁ nadissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:23.3":{"pli":"Citake chattaṁ dhārenti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:23.4":{"pli":"heṭṭhā chattamhi ḍayhatha’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap553:24.1":{"pli":"Sāmaññaṁ me anuppattaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap553:24.2":{"pli":"kilesā jhāpitā mayā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:24.3":{"pli":"Maṇḍape rukkhamūle vā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:24.4":{"pli":"santāso me na vijjati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap553:25.1":{"pli":"Tiṁsakappasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap553:25.2":{"pli":"yaṁ dānamadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:25.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:25.4":{"pli":"sabbadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap553:26.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap553:26.2":{"pli":"bhavā sabbe samūhatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:26.3":{"pli":"Nāgova bandhanaṁ chetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:26.4":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap553:27.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap553:27.2":{"pli":"mama buddhassa santike; ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:27.3":{"pli":"Tisso vijjā anuppattā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:27.4":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap553:28.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap553:28.2":{"pli":"vimokkhāpi ca aṭṭhime; ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:28.3":{"pli":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap553:28.4":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap553:29.1":{"pli":"Itthaṁ sudaṁ āyasmā yaso thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap553:30.1":{"pli":"Yasattherassāpadānaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap554":{"tha-ap554:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap554'><header><ul><li class='division'>{}</li>"},"tha-ap554:0.2":{"pli":"Yasavagga ","html":"<li>{}</li></ul>"},"tha-ap554:0.3":{"pli":"Nadīkassapattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap554:1.1":{"pli":"“Padumuttarassa bhagavato, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap554:1.2":{"pli":"Lokajeṭṭhassa tādino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap554:1.3":{"pli":"Piṇḍacāraṁ carantassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap554:1.4":{"pli":"Vārato uttamaṁ yasaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap554:1.5":{"pli":"Aggaphalaṁ gahetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap554:1.6":{"pli":"Adāsiṁ satthuno ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap554:2.1":{"pli":"Tena kammena devindo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap554:2.2":{"pli":"lokajeṭṭho narāsabho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap554:2.3":{"pli":"Sampattomhi acalaṁ ṭhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap554:2.4":{"pli":"hitvā jayaparājayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap554:3.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap554:3.2":{"pli":"yaṁ phalaṁ adadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap554:3.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap554:3.4":{"pli":"aggadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap554:4.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap554:4.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap554:4.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap554:5.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap554:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap554:5.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap554:6.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap554:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap554:6.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap554:7.1":{"pli":"Itthaṁ sudaṁ āyasmā nadīkassapo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap554:8.1":{"pli":"Nadīkassapattherassāpadānaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap555":{"tha-ap555:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap555'><header><ul><li class='division'>{}</li>"},"tha-ap555:0.2":{"pli":"Yasavagga ","html":"<li>{}</li></ul>"},"tha-ap555:0.3":{"pli":"Gayākassapattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap555:1.1":{"pli":"“Ajinacammavatthohaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap555:1.2":{"pli":"khāribhāradharo tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap555:1.3":{"pli":"Khārikaṁ hārayitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap555:1.4":{"pli":"kolaṁ ahāsi assamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap555:2.1":{"pli":"Bhagavā tamhi samaye, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap555:2.2":{"pli":"eko adutiyo jino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap555:2.3":{"pli":"Mamassamaṁ upāgacchi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap555:2.4":{"pli":"jotento sabbakālikaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap555:3.1":{"pli":"Sakaṁ cittaṁ pasādetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap555:3.2":{"pli":"abhivādetvāna subbataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap555:3.3":{"pli":"Ubho hatthehi paggayha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap555:3.4":{"pli":"kolaṁ buddhassadāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap555:4.1":{"pli":"Ekatiṁse ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap555:4.2":{"pli":"yaṁ phalaṁ adadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap555:4.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap555:4.4":{"pli":"koladānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap555:5.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap555:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap555:5.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap555:6.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap555:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap555:6.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap555:7.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap555:7.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap555:7.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap555:8.1":{"pli":"Itthaṁ sudaṁ āyasmā gayākassapo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap555:9.1":{"pli":"Gayākassapattherassāpadānaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap556":{"tha-ap556:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap556'><header><ul><li class='division'>{}</li>"},"tha-ap556:0.2":{"pli":"Yasavagga ","html":"<li>{}</li></ul>"},"tha-ap556:0.3":{"pli":"4 Kimilattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap556:1.1":{"pli":"“Nibbute kakusandhamhi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap556:1.2":{"pli":"brāhmaṇamhi vusīmati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap556:1.3":{"pli":"Gahetvā salalaṁ mālaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap556:1.4":{"pli":"maṇḍapaṁ kārayiṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap556:2.1":{"pli":"Tāvatiṁsaṁ gato santo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap556:2.2":{"pli":"labhimha byamhamuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap556:2.3":{"pli":"Aññe devetirocāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap556:2.4":{"pli":"puññakammassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap556:3.1":{"pli":"Divā vā yadi vā rattiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap556:3.2":{"pli":"caṅkamanto ṭhito cahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap556:3.3":{"pli":"Channo salalapupphehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap556:3.4":{"pli":"puññakammassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap556:4.1":{"pli":"Imasmiṁyeva kappamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap556:4.2":{"pli":"yaṁ buddhamabhipūjayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap556:4.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap556:4.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap556:5.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap556:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap556:5.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap556:6.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap556:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap556:6.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap556:7.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap556:7.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap556:7.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap556:8.1":{"pli":"Itthaṁ sudaṁ āyasmā kimilo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap556:9.1":{"pli":"Kimilattherassāpadānaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap557":{"tha-ap557:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap557'><header><ul><li class='division'>{}</li>"},"tha-ap557:0.2":{"pli":"Yasavagga ","html":"<li>{}</li></ul>"},"tha-ap557:0.3":{"pli":"Vajjīputtattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap557:1.1":{"pli":"“Sahassaraṁsī bhagavā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap557:1.2":{"pli":"sayambhū aparājito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap557:1.3":{"pli":"Vivekā vuṭṭhahitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap557:1.4":{"pli":"gocarāyābhinikkhami. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap557:2.1":{"pli":"Phalahattho ahaṁ disvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap557:2.2":{"pli":"upagacchiṁ narāsabhaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap557:2.3":{"pli":"Pasannacitto sumano, ","html":"<span class='verse-line'>{}</span>"},"tha-ap557:2.4":{"pli":"savaṇṭaṁ adadiṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap557:3.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap557:3.2":{"pli":"yaṁ phalaṁ adadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap557:3.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap557:3.4":{"pli":"phaladānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap557:4.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap557:4.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap557:4.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap557:5.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap557:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap557:5.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap557:6.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap557:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap557:6.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap557:7.1":{"pli":"Itthaṁ sudaṁ āyasmā vajjīputto thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap557:8.1":{"pli":"Vajjīputtattherassāpadānaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}