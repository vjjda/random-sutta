{"tha-ap24":{"tha-ap24:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap24'><header><ul><li class='division'>{}</li>"},"tha-ap24:0.2":{"pli":"Subhūtivagga ","html":"<li>{}</li></ul>"},"tha-ap24:0.3":{"pli":"2 Upavānattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap24:1.1":{"pli":"“Padumuttaro nāma jino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap24:1.2":{"pli":"sabbadhammāna pāragū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:1.3":{"pli":"Jalitvā aggikkhandhova, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:1.4":{"pli":"sambuddho parinibbuto. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:2.1":{"pli":"Mahājanā samāgamma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:2.2":{"pli":"pūjayitvā tathāgataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:2.3":{"pli":"Citaṁ katvāna sukataṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:2.4":{"pli":"sarīraṁ abhiropayuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:3.1":{"pli":"Sarīrakiccaṁ katvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:3.2":{"pli":"dhātuṁ tattha samānayuṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:3.3":{"pli":"Sadevamānusā sabbe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:3.4":{"pli":"buddhathūpaṁ akaṁsu te. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:4.1":{"pli":"Paṭhamā kañcanamayā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:4.2":{"pli":"dutiyāsi maṇīmayā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:4.3":{"pli":"Tatiyā rūpiyamayā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:4.4":{"pli":"catutthī phalikāmayā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:5.1":{"pli":"Tathā pañcamiyā bhūmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:5.2":{"pli":"lohitaṅgamayā ahu; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:5.3":{"pli":"Chaṭṭhā masāragallassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:5.4":{"pli":"sabbaratanamayūpari. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:6.1":{"pli":"Jaṅghā maṇimayā āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:6.2":{"pli":"vedikā ratanamayā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:6.3":{"pli":"Sabbasoṇṇamayo thūpo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:6.4":{"pli":"uddhaṁ yojanamuggato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:7.1":{"pli":"Devā tattha samāgantvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:7.2":{"pli":"ekato mantayuṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:7.3":{"pli":"Mayampi thūpaṁ kassāma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:7.4":{"pli":"lokanāthassa tādino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:8.1":{"pli":"Dhātu āveṇikā natthi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:8.2":{"pli":"sarīraṁ ekapiṇḍitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:8.3":{"pli":"Imamhi buddhathūpamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:8.4":{"pli":"kassāma kañcukaṁ mayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:9.1":{"pli":"Devā sattahi ratnehi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:9.2":{"pli":"aññaṁ vaḍḍhesu yojanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:9.3":{"pli":"Thūpo dviyojanubbedho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:9.4":{"pli":"timiraṁ byapahanti so. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:10.1":{"pli":"Nāgā tattha samāgantvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:10.2":{"pli":"ekato mantayuṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:10.3":{"pli":"Manussā ceva devā ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:10.4":{"pli":"buddhathūpaṁ akaṁsu te. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:11.1":{"pli":"Mā no pamattā assumha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:11.2":{"pli":"appamattā sadevakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:11.3":{"pli":"Mayampi thūpaṁ kassāma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:11.4":{"pli":"lokanāthassa tādino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:12.1":{"pli":"Indanīlaṁ mahānīlaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:12.2":{"pli":"atho jotirasaṁ maṇiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:12.3":{"pli":"Ekato sannipātetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:12.4":{"pli":"buddhathūpaṁ achādayuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:13.1":{"pli":"Sabbaṁ maṇimayaṁ āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:13.2":{"pli":"tāvatā buddhacetiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:13.3":{"pli":"Tiyojanasamubbiddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:13.4":{"pli":"ālokakaraṇaṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:14.1":{"pli":"Garuḷā ca samāgantvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:14.2":{"pli":"ekato mantayuṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:14.3":{"pli":"Manussā devā nāgā ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:14.4":{"pli":"buddhathūpaṁ akaṁsu te. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:15.1":{"pli":"‘Mā no pamattā assumha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:15.2":{"pli":"appamattā sadevakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:15.3":{"pli":"Mayampi thūpaṁ kassāma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:15.4":{"pli":"lokanāthassa tādino’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:16.1":{"pli":"Sabbaṁ maṇimayaṁ thūpaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:16.2":{"pli":"akaruṁ te ca kañcukaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:16.3":{"pli":"Yojanaṁ tepi vaḍḍhesuṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:16.4":{"pli":"āyataṁ buddhacetiyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:17.1":{"pli":"Catuyojanamubbiddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:17.2":{"pli":"buddhathūpo virocati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:17.3":{"pli":"Obhāseti disā sabbā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:17.4":{"pli":"sataraṁsīva uggato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:18.1":{"pli":"Kumbhaṇḍā ca samāgantvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:18.2":{"pli":"ekato mantayuṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:18.3":{"pli":"Manussā ceva devā ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:18.4":{"pli":"nāgā ca garuḷā tathā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:18.5":{"pli":"Paccekaṁ buddhaseṭṭhassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:18.6":{"pli":"akaṁsu thūpamuttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:19.1":{"pli":"‘Mā no pamattā assumha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:19.2":{"pli":"appamattā sadevakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:19.3":{"pli":"Mayampi thūpaṁ kassāma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:19.4":{"pli":"lokanāthassa tādino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:19.5":{"pli":"Ratanehi chādessāma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:19.6":{"pli":"āyataṁ buddhacetiyaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:20.1":{"pli":"Yojanaṁ tepi vaḍḍhesuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:20.2":{"pli":"āyataṁ buddhacetiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:20.3":{"pli":"Pañcayojanamubbiddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:20.4":{"pli":"thūpo obhāsate tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:21.1":{"pli":"Yakkhā tattha samāgantvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:21.2":{"pli":"ekato mantayuṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:21.3":{"pli":"Manussā devā nāgā ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:21.4":{"pli":"garuḷā kumbhaaṇḍakā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:22.1":{"pli":"Paccekaṁ buddhaseṭṭhassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:22.2":{"pli":"akaṁsu thūpamuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:22.3":{"pli":"‘Mā no pamattā assumha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:22.4":{"pli":"appamattā sadevakā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:23.1":{"pli":"Mayampi thūpaṁ kassāma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:23.2":{"pli":"lokanāthassa tādino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:23.3":{"pli":"Phalikāhi chādessāma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:23.4":{"pli":"āyataṁ buddhacetiyaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:24.1":{"pli":"Yojanaṁ tepi vaḍḍhesuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:24.2":{"pli":"āyataṁ buddhacetiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:24.3":{"pli":"Cha yojanāni ubbiddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:24.4":{"pli":"thūpo obhāsate tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:25.1":{"pli":"Gandhabbā ca samāgantvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:25.2":{"pli":"ekato mantayuṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:25.3":{"pli":"‘Manujā devatā nāgā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:25.4":{"pli":"garuḷā kumbhayakkhakā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:26.1":{"pli":"Sabbekaṁsu buddhathūpaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:26.2":{"pli":"mayamettha akārakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:26.3":{"pli":"Mayampi thūpaṁ kassāma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:26.4":{"pli":"lokanāthassa tādino’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:27.1":{"pli":"Vediyo satta katvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:27.2":{"pli":"chattamāropayiṁsu te; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:27.3":{"pli":"Sabbasoṇṇamayaṁ thūpaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:27.4":{"pli":"gandhabbā kārayuṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:28.1":{"pli":"Sattayojanamubbiddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:28.2":{"pli":"thūpo obhāsate tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:28.3":{"pli":"Rattindivā na ñāyanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:28.4":{"pli":"āloko hoti sabbadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:29.1":{"pli":"Abhibhonti na tassābhā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:29.2":{"pli":"candasūrā satārakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:29.3":{"pli":"Samantā yojanasate, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:29.4":{"pli":"padīpopi na pajjali. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:30.1":{"pli":"Tena kālena ye keci, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:30.2":{"pli":"thūpaṁ pūjenti mānusā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:30.3":{"pli":"Na te thūpamāruhanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:30.4":{"pli":"ambare ukkhipanti te. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:31.1":{"pli":"Devehi ṭhapito yakkho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:31.2":{"pli":"abhisammatanāmako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:31.3":{"pli":"Dhajaṁ vā pupphadāmaṁ vā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:31.4":{"pli":"abhiropeti uttari. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:32.1":{"pli":"Na te passanti taṁ yakkhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:32.2":{"pli":"dāmaṁ passanti gacchato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:32.3":{"pli":"Evaṁ passitvā gacchantā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:32.4":{"pli":"sabbe gacchanti suggatiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:33.1":{"pli":"Viruddhā ye pāvacane, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:33.2":{"pli":"pasannā ye ca sāsane; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:33.3":{"pli":"Pāṭiheraṁ daṭṭhukāmā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:33.4":{"pli":"thūpaṁ pūjenti mānusā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:34.1":{"pli":"Nagare haṁsavatiyā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:34.2":{"pli":"ahosiṁ bhatako tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:34.3":{"pli":"Āmoditaṁ janaṁ disvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:34.4":{"pli":"evaṁ cintesahaṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:35.1":{"pli":"‘Uḷāro bhagavā heso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:35.2":{"pli":"yassa dhātudharedisaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:35.3":{"pli":"Imā ca janatā tuṭṭhā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:35.4":{"pli":"kāraṁ kubbaṁ na tappare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:36.1":{"pli":"Ahampi kāraṁ kassāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:36.2":{"pli":"lokanāthassa tādino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:36.3":{"pli":"Tassa dhammesu dāyādo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:36.4":{"pli":"bhavissāmi anāgate’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:37.1":{"pli":"Sudhotaṁ rajakenāhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:37.2":{"pli":"uttareyyapaṭaṁ mama; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:37.3":{"pli":"Veḷagge ālaggetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:37.4":{"pli":"dhajaṁ ukkhipimambare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:38.1":{"pli":"Abhisammatako gayha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:38.2":{"pli":"ambarehāsi me dhajaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:38.3":{"pli":"Vāteritaṁ dhajaṁ disvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:38.4":{"pli":"bhiyyo hāsaṁ janesahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:39.1":{"pli":"Tattha cittaṁ pasādetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:39.2":{"pli":"samaṇaṁ upasaṅkamiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:39.3":{"pli":"Taṁ bhikkhuṁ abhivādetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:39.4":{"pli":"vipākaṁ pucchahaṁ dhaje. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:40.1":{"pli":"So me kathesi ānanda, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:40.2":{"pli":"pītisañjananaṁ mama; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:40.3":{"pli":"‘Tassa dhajassa vipākaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:40.4":{"pli":"anubhossasi sabbadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:41.1":{"pli":"Hatthī assā rathā pattī, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:41.2":{"pli":"senā ca caturaṅginī; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:41.3":{"pli":"Parivāressanti taṁ niccaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:41.4":{"pli":"dhajadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:42.1":{"pli":"Saṭṭhitūriyasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:42.2":{"pli":"bheriyo samalaṅkatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:42.3":{"pli":"Parivāressanti taṁ niccaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:42.4":{"pli":"dhajadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:43.1":{"pli":"Chaḷāsītisahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:43.2":{"pli":"nāriyo samalaṅkatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:43.3":{"pli":"Vicittavatthābharaṇā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:43.4":{"pli":"āmuttamaṇikuṇḍalā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:44.1":{"pli":"Aḷārapamhā hasulā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:44.2":{"pli":"susaññā tanumajjhimā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:44.3":{"pli":"Parivāressanti taṁ niccaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:44.4":{"pli":"dhajadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:45.1":{"pli":"Tiṁsakappasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:45.2":{"pli":"devaloke ramissasi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:45.3":{"pli":"Asītikkhattuṁ devindo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:45.4":{"pli":"devarajjaṁ karissasi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:46.1":{"pli":"Sahassakkhattuṁ rājā ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:46.2":{"pli":"cakkavattī bhavissasi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:46.3":{"pli":"Padesarajjaṁ vipulaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:46.4":{"pli":"gaṇanāto asaṅkhiyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:47.1":{"pli":"Kappasatasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:47.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:47.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:47.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:48.1":{"pli":"Devalokā cavitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:48.2":{"pli":"sukkamūlena codito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:48.3":{"pli":"Puññakammena saṁyutto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:48.4":{"pli":"brahmabandhu bhavissasi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:49.1":{"pli":"Asītikoṭiṁ chaḍḍetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:49.2":{"pli":"dāse kammakare bahū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:49.3":{"pli":"Gotamassa bhagavato, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:49.4":{"pli":"sāsane pabbajissasi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:50.1":{"pli":"Ārādhayitvā sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:50.2":{"pli":"gotamaṁ sakyapuṅgavaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:50.3":{"pli":"Upavānoti nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:50.4":{"pli":"hessasi satthu sāvako’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:51.1":{"pli":"Satasahasse kataṁ kammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:51.2":{"pli":"phalaṁ dassesi me idha; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:51.3":{"pli":"Sumutto saravegova, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:51.4":{"pli":"kilese jhāpayī mama. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:52.1":{"pli":"Cakkavattissa santassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:52.2":{"pli":"catudīpissarassa me; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:52.3":{"pli":"Tiyojanāni samantā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:52.4":{"pli":"ussīsanti dhajā sadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:53.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:53.2":{"pli":"yaṁ kammamakariṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:53.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:53.4":{"pli":"dhajadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap24:54.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap24:54.2":{"pli":"vimokkhāpi ca aṭṭhime; ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:54.3":{"pli":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap24:54.4":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap24:55.1":{"pli":"Itthaṁ sudaṁ āyasmā upavāno thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap24:56.1":{"pli":"Upavānattherassāpadānaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap240":{"tha-ap240:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap240'><header><ul><li class='division'>{}</li>"},"tha-ap240:0.2":{"pli":"Udakāsanavagga ","html":"<li>{}</li></ul>"},"tha-ap240:0.3":{"pli":"Ambayāgadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap240:1.1":{"pli":"“Sake sippe apatthaddho, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap240:1.2":{"pli":"agamaṁ kānanaṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap240:1.3":{"pli":"Sambuddhaṁ yantaṁ disvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap240:1.4":{"pli":"ambayāgaṁ adāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap240:2.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap240:2.2":{"pli":"yaṁ dānamadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap240:2.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap240:2.4":{"pli":"ambayāgassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap240:3.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap240:3.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap240:3.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap240:4.1":{"pli":"Itthaṁ sudaṁ āyasmā ambayāgadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap240:5.1":{"pli":"Ambayāgadāyakattherassāpadānaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap241":{"tha-ap241:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap241'><header><ul><li class='division'>{}</li>"},"tha-ap241:0.2":{"pli":"Udakāsanavagga ","html":"<li>{}</li></ul>"},"tha-ap241:0.3":{"pli":"Jagatikārakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap241:1.1":{"pli":"“Nibbute lokanāthamhi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap241:1.2":{"pli":"atthadassi naruttame; ","html":"<span class='verse-line'>{}</span>"},"tha-ap241:1.3":{"pli":"Jagatī kāritā mayhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap241:1.4":{"pli":"buddhassa thūpamuttame. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap241:2.1":{"pli":"Aṭṭhārase kappasate, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap241:2.2":{"pli":"yaṁ kammamakariṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap241:2.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap241:2.4":{"pli":"jagatiyā idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap241:3.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap241:3.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap241:3.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap241:4.1":{"pli":"Itthaṁ sudaṁ āyasmā jagatikārako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap241:5.1":{"pli":"Jagatikārakattherassāpadānaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap242":{"tha-ap242:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap242'><header><ul><li class='division'>{}</li>"},"tha-ap242:0.2":{"pli":"Udakāsanavagga ","html":"<li>{}</li></ul>"},"tha-ap242:0.3":{"pli":"Vāsidāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap242:1.1":{"pli":"“Kammārohaṁ pure āsiṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap242:1.2":{"pli":"tivarāyaṁ puruttame; ","html":"<span class='verse-line'>{}</span>"},"tha-ap242:1.3":{"pli":"Ekā vāsi mayā dinnā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap242:1.4":{"pli":"sayambhuṁ aparājitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap242:2.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap242:2.2":{"pli":"yaṁ vāsimadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap242:2.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap242:2.4":{"pli":"vāsidānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap242:3.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap242:3.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap242:3.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap242:4.1":{"pli":"Itthaṁ sudaṁ āyasmā vāsidāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap242:5.1":{"pli":"Vāsidāyakattherassāpadānaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap242:6.1":{"pli":"Udakāsanavaggo catuvīsatimo. ","html":"<p class='endsection'>{}</p>"},"tha-ap242:7.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"tha-ap242:8.1":{"pli":"Udakāsanabhājanaṁ, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"tha-ap242:8.2":{"pli":"sālapupphī kilañjako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap242:8.3":{"pli":"Vedikā vaṇṇakāro ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap242:8.4":{"pli":"piyālaambayāgado; ","html":"<span class='verse-line'>{}</span>"},"tha-ap242:8.5":{"pli":"Jagatī vāsidātā ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap242:8.6":{"pli":"gāthā tiṁsa ca aṭṭha ca. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"tha-ap243":{"tha-ap243:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap243'><header><ul><li class='division'>{}</li>"},"tha-ap243:0.2":{"pli":"Tuvaradāyakavagga ","html":"<li>{}</li></ul>"},"tha-ap243:0.3":{"pli":"1 Tuvaradāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap243:1.1":{"pli":"“Migaluddo pure āsiṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap243:1.2":{"pli":"araññe kānane ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap243:1.3":{"pli":"Bharitvā tuvaramādāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap243:1.4":{"pli":"saṅghassa adadiṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap243:2.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap243:2.2":{"pli":"yaṁ dānamadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap243:2.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap243:2.4":{"pli":"tuvarassa idaṁ phala