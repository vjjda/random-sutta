 ","html":"<span class='verse-line'>{}</span></p>"},"bv11:23.1":{"pli":"Bhaddasālo jitamitto, ","html":"<p><span class='verse-line'>{}</span>"},"bv11:23.2":{"pli":"ahesuṁ aggasāvakā; ","html":"<span class='verse-line'>{}</span>"},"bv11:23.3":{"pli":"Vāseṭṭho nāmupaṭṭhāko, ","html":"<span class='verse-line'>{}</span>"},"bv11:23.4":{"pli":"nāradassa mahesino. ","html":"<span class='verse-line'>{}</span></p>"},"bv11:24.1":{"pli":"Uttarā phaggunī ceva, ","html":"<p><span class='verse-line'>{}</span>"},"bv11:24.2":{"pli":"ahesuṁ aggasāvikā; ","html":"<span class='verse-line'>{}</span>"},"bv11:24.3":{"pli":"Bodhi tassa bhagavato, ","html":"<span class='verse-line'>{}</span>"},"bv11:24.4":{"pli":"mahāsoṇoti vuccati. ","html":"<span class='verse-line'>{}</span></p>"},"bv11:25.1":{"pli":"Uggarindo vasabho ca, ","html":"<p><span class='verse-line'>{}</span>"},"bv11:25.2":{"pli":"ahesuṁ aggupaṭṭhakā; ","html":"<span class='verse-line'>{}</span>"},"bv11:25.3":{"pli":"Indāvarī ca vaṇḍī ca, ","html":"<span class='verse-line'>{}</span>"},"bv11:25.4":{"pli":"ahesuṁ aggupaṭṭhikā. ","html":"<span class='verse-line'>{}</span></p>"},"bv11:26.1":{"pli":"Aṭṭhāsītiratanāni, ","html":"<p><span class='verse-line'>{}</span>"},"bv11:26.2":{"pli":"accuggato mahāmuni; ","html":"<span class='verse-line'>{}</span>"},"bv11:26.3":{"pli":"Kañcanagghiyasaṅkāso, ","html":"<span class='verse-line'>{}</span>"},"bv11:26.4":{"pli":"dasasahassī virocati. ","html":"<span class='verse-line'>{}</span></p>"},"bv11:27.1":{"pli":"Tassa byāmappabhā kāyā, ","html":"<p><span class='verse-line'>{}</span>"},"bv11:27.2":{"pli":"niddhāvati disodisaṁ; ","html":"<span class='verse-line'>{}</span>"},"bv11:27.3":{"pli":"Nirantaraṁ divārattiṁ, ","html":"<span class='verse-line'>{}</span>"},"bv11:27.4":{"pli":"yojanaṁ pharate sadā. ","html":"<span class='verse-line'>{}</span></p>"},"bv11:28.1":{"pli":"Na keci tena samayena, ","html":"<p><span class='verse-line'>{}</span>"},"bv11:28.2":{"pli":"samantā yojane janā; ","html":"<span class='verse-line'>{}</span>"},"bv11:28.3":{"pli":"Ukkāpadīpe ujjālenti, ","html":"<span class='verse-line'>{}</span>"},"bv11:28.4":{"pli":"buddharaṁsīhi otthaṭā. ","html":"<span class='verse-line'>{}</span></p>"},"bv11:29.1":{"pli":"Navutivassasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"bv11:29.2":{"pli":"āyu vijjati tāvade; ","html":"<span class='verse-line'>{}</span>"},"bv11:29.3":{"pli":"Tāvatā tiṭṭhamāno so, ","html":"<span class='verse-line'>{}</span>"},"bv11:29.4":{"pli":"tāresi janataṁ bahuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"bv11:30.1":{"pli":"Yathā uḷūhi gaganaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"bv11:30.2":{"pli":"vicittaṁ upasobhati; ","html":"<span class='verse-line'>{}</span>"},"bv11:30.3":{"pli":"Tatheva sāsanaṁ tassa, ","html":"<span class='verse-line'>{}</span>"},"bv11:30.4":{"pli":"arahantehi sobhati. ","html":"<span class='verse-line'>{}</span></p>"},"bv11:31.1":{"pli":"Saṁsārasotaṁ taraṇāya, ","html":"<p><span class='verse-line'>{}</span>"},"bv11:31.2":{"pli":"sesake paṭipannake; ","html":"<span class='verse-line'>{}</span>"},"bv11:31.3":{"pli":"Dhammasetuṁ daḷhaṁ katvā, ","html":"<span class='verse-line'>{}</span>"},"bv11:31.4":{"pli":"nibbuto so narāsabho. ","html":"<span class='verse-line'>{}</span></p>"},"bv11:32.1":{"pli":"Sopi buddho asamasamo, ","html":"<p><span class='verse-line'>{}</span>"},"bv11:32.2":{"pli":"Tepi khīṇāsavā atulatejā; ","html":"<span class='verse-line'>{}</span>"},"bv11:32.3":{"pli":"Sabbaṁ tamantarahitaṁ, ","html":"<span class='verse-line'>{}</span>"},"bv11:32.4":{"pli":"Nanu rittā sabbasaṅkhārā. ","html":"<span class='verse-line'>{}</span></p>"},"bv11:33.1":{"pli":"Nārado jinavasabho, ","html":"<p data-counter='5531'><span class='verse-line'>{}</span>"},"bv11:33.2":{"pli":"Nibbuto sudassane pure; ","html":"<span class='verse-line'>{}</span>"},"bv11:33.3":{"pli":"Tatthevassa thūpavaro, ","html":"<span class='verse-line'>{}</span>"},"bv11:33.4":{"pli":"Catuyojanamuggato”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"bv11:34.1":{"pli":"Nāradassa bhagavato vaṁso navamo. ","html":"<p class='endsutta'>{}</p></article>"}},"bv12":{"bv12:0.1":{"pli":"Buddhavaṁsa ","html":"<article id='bv12'><header><ul><li class='division'>{}</li></ul>"},"bv12:0.2":{"pli":"12. Padumuttarabuddhavaṁsa ","html":"<h1 class='sutta-title'>{}</h1></header>"},"bv12:1.1":{"pli":"“Nāradassa aparena, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"bv12:1.2":{"pli":"sambuddho dvipaduttamo; ","html":"<span class='verse-line'>{}</span>"},"bv12:1.3":{"pli":"Padumuttaro nāma jino, ","html":"<span class='verse-line'>{}</span>"},"bv12:1.4":{"pli":"akkhobbho sāgarūpamo. ","html":"<span class='verse-line'>{}</span></p>"},"bv12:2.1":{"pli":"Maṇḍakappova so āsi, ","html":"<p><span class='verse-line'>{}</span>"},"bv12:2.2":{"pli":"yamhi buddho ajāyatha; ","html":"<span class='verse-line'>{}</span>"},"bv12:2.3":{"pli":"Ussannakusalā janatā, ","html":"<span class='verse-line'>{}</span>"},"bv12:2.4":{"pli":"tamhi kappe ajāyatha. ","html":"<span class='verse-line'>{}</span></p>"},"bv12:3.1":{"pli":"Padumuttarassa bhagavato, ","html":"<p><span class='verse-line'>{}</span>"},"bv12:3.2":{"pli":"Paṭhame dhammadesane; ","html":"<span class='verse-line'>{}</span>"},"bv12:3.3":{"pli":"Koṭisatasahassānaṁ, ","html":"<span class='verse-line'>{}</span>"},"bv12:3.4":{"pli":"Dhammābhisamayo ahu. ","html":"<span class='verse-line'>{}</span></p>"},"bv12:4.1":{"pli":"Tato parampi vassante, ","html":"<p><span class='verse-line'>{}</span>"},"bv12:4.2":{"pli":"Tappayante ca pāṇine; ","html":"<span class='verse-line'>{}</span>"},"bv12:4.3":{"pli":"Sattatiṁsasatasahassānaṁ, ","html":"<span class='verse-line'>{}</span>"},"bv12:4.4":{"pli":"Dutiyābhisamayo ahu. ","html":"<span class='verse-line'>{}</span></p>"},"bv12:5.1":{"pli":"Yamhi kāle mahāvīro, ","html":"<p><span class='verse-line'>{}</span>"},"bv12:5.2":{"pli":"ānandaṁ upasaṅkami; ","html"