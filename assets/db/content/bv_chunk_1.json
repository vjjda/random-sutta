i":"sasaṅghe lokanāyake; ","html":"<span class='verse-line'>{}</span>"},"bv13:12.3":{"pli":"Saraṇaṁ tassupagañchiṁ, ","html":"<span class='verse-line'>{}</span>"},"bv13:12.4":{"pli":"pabbajjañcābhirocayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"bv13:13.1":{"pli":"Sopi maṁ buddho byākāsi, ","html":"<p><span class='verse-line'>{}</span>"},"bv13:13.2":{"pli":"karonto anumodanaṁ; ","html":"<span class='verse-line'>{}</span>"},"bv13:13.3":{"pli":"‘Tiṁsakappasahassamhi, ","html":"<span class='verse-line'>{}</span>"},"bv13:13.4":{"pli":"ayaṁ buddho bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"bv13:14.1":{"pli":"Padhānaṁ padahitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"bv13:14.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"bv13:14.3":{"pli":"hessāma sammukhā imaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"bv13:15.1":{"pli":"Tassāpi vacanaṁ sutvā, ","html":"<p><span class='verse-line'>{}</span>"},"bv13:15.2":{"pli":"bhiyyo cittaṁ pasādayiṁ; ","html":"<span class='verse-line'>{}</span>"},"bv13:15.3":{"pli":"Uttariṁ vatamadhiṭṭhāsiṁ, ","html":"<span class='verse-line'>{}</span>"},"bv13:15.4":{"pli":"dasapāramipūriyā. ","html":"<span class='verse-line'>{}</span></p>"},"bv13:16.1":{"pli":"Suttantaṁ vinayañcāpi, ","html":"<p><span class='verse-line'>{}</span>"},"bv13:16.2":{"pli":"navaṅgaṁ satthusāsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"bv13:16.3":{"pli":"Sabbaṁ pariyāpuṇitvāna, ","html":"<span class='verse-line'>{}</span>"},"bv13:16.4":{"pli":"sobhayiṁ jinasāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"bv13:17.1":{"pli":"Tatthappamatto viharanto, ","html":"<p><span class='verse-line'>{}</span>"},"bv13:17.2":{"pli":"Nisajjaṭṭhānacaṅkame; ","html":"<span class='verse-line'>{}</span>"},"bv13:17.3":{"pli":"Abhiññāsu pāramiṁ gantvā, ","html":"<span class='verse-line'>{}</span>"},"bv13:17.4":{"pli":"Brahmalokamagañchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"bv13:18.1":{"pli":"Sudassanaṁ nāma nagaraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"bv13:18.2":{"pli":"sudatto nāma khattiyo; ","html":"<span class='verse-line'>{}</span>"},"bv13:18.3":{"pli":"Sudattā nāma janikā, ","html":"<span class='verse-line'>{}</span>"},"bv13:18.4":{"pli":"sumedhassa mahesino. ","html":"<span class='verse-line'>{}</span></p>"},"bv13:19.1":{"pli":"Navavassasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"bv13:19.2":{"pli":"Agāraṁ ajjha so vasi; ","html":"<span class='verse-line'>{}</span>"},"bv13:19.3":{"pli":"Sucandakañcanasirivaḍḍhā, ","html":"<span class='verse-line'>{}</span>"},"bv13:19.4":{"pli":"Tayo pāsādamuttamā. ","html":"<span class='verse-line'>{}</span></p>"},"bv13:20.1":{"pli":"Tisoḷasasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"bv13:20.2":{"pli":"nāriyo samalaṅkatā; ","html":"<span class='verse-line'>{}</span>"},"bv13:20.3":{"pli":"Sumanā nāma sā nārī, ","html":"<span class='verse-line'>{}</span>"},"bv13:20.4":{"pli":"punabbasu nāma atrajo. ","html":"<span class='verse-line'>{}</span></p>"},"bv13:21.1":{"pli":"Nimitte caturo disvā, ","html":"<p><span class='verse-line'>{}</span>"},"bv13:21.2":{"pli":"hatthiyānena nikkhami; ","html":"<span class='verse-line'>{}</span>"},"bv13:21.3":{"pli":"Anūnakaṁ aḍḍhamāsaṁ, ","html":"<span class='verse-line'>{}</span>"},"bv13:21.4":{"pli":"padhānaṁ padahī jino. ","html":"<span class='verse-line'>{}</span></p>"},"bv13:22.1":{"pli":"Brahmunā yācito santo, ","html":"<p><span class='verse-line'>{}</span>"},"bv13:22.2":{"pli":"sumedho lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"bv13:22.3":{"pli":"Vatti cakkaṁ mahāvīro, ","html":"<span class='verse-line'>{}</span>"},"bv13:22.4":{"pli":"sudassanuyyānamuttame. ","html":"<span class='verse-line'>{}</span></p>"},"bv13:23.1":{"pli":"Saraṇo sabbakāmo ca, ","html":"<p><span class='verse-line'>{}</span>"},"bv13:23.2":{"pli":"ahesuṁ aggasāvakā; ","html":"<span class='verse-line'>{}</span>"},"bv13:23.3":{"pli":"Sāgaro nāmupaṭṭhāko, ","html":"<span class='verse-line'>{}</span>"},"bv13:23.4":{"pli":"sumedhassa mahesino. ","html":"<span class='verse-line'>{}</span></p>"},"bv13:24.1":{"pli":"Rāmā ceva surāmā ca, ","html":"<p><span class='verse-line'>{}</span>"},"bv13:24.2":{"pli":"ahesuṁ aggasāvikā; ","html":"<span class='verse-line'>{}</span>"},"bv13:24.3":{"pli":"Bodhi tassa bhagavato, ","html":"<span class='verse-line'>{}</span>"},"bv13:24.4":{"pli":"mahānīpoti vuccati. ","html":"<span class='verse-line'>{}</span></p>"},"bv13:25.1":{"pli":"Uruvelā yasavā ca, ","html":"<p><span class='verse-line'>{}</span>"},"bv13:25.2":{"pli":"ahesuṁ aggupaṭṭhakā; ","html":"<span class='verse-line'>{}</span>"},"bv13:25.3":{"pli":"Yasodharā sirimā ca, ","html":"<span class='verse-line'>{}</span>"},"bv13:25.4":{"pli":"ahesuṁ aggupaṭṭhikā. ","html":"<span class='verse-line'>{}</span></p>"},"bv13:26.1":{"pli":"Aṭṭhāsītiratanāni, ","html":"<p><span class='verse-line'>{}</span>"},"bv13:26.2":{"pli":"accuggato mahāmuni; ","html":"<span class='verse-line'>{}</span>"},"bv13:26.3":{"pli":"Obhāseti disā sabbā, ","html":"<span class='verse-line'>{}</span>"},"bv13:26.4":{"pli":"cando tāragaṇe yathā. ","html":"<span class='verse-line'>{}</span></p>"},"bv13:27.1":{"pli":"Cakkavattimaṇī nāma, ","html":"<p><span class='verse-line'>{}</span>"},"bv13:27.2":{"pli":"yathā tapati yojanaṁ; ","html":"<span class='verse-line'>{}</span>"},"bv13:27.3":{"pli":"Tatheva tassa ratanaṁ, ","html":"<span class='verse-line'>{}</span>"},"bv13:27.4":{"pli":"samantā pharati yojanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"bv13:28.1":{"pli":"Navutivassasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"bv13:28.2":{"pli":"āyu vijjati tāvade; ","html":"<span class='verse-line'>{}</span>"},"bv13:28.3":{"pli":"Tāvatā tiṭṭhamāno so, ","html":"<span class='verse-line'>{}</span>"},"bv13:28.4":{"pli":"tāresi janataṁ bahuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"bv13:29.1":{"pli":"Tevijjachaḷabhiññehi, ","html":"<p><span class='verse-line'>{}</span>"},"bv13:29.2":{"pli":"balappattehi tādihi; ","html":"<span class='verse-line'>{}</span>"},"bv13:29.3":{"pli":"Samākulamidaṁ āsi, ","html":"<span class='verse-line'>{}</span>"},"bv13:29.4":{"pli":"arahantehi sādhuhi. ","html":"<span class='verse-line'>{}</span></p>"},"bv13:30.1":{"pli":"Tepi sabbe amitayasā, ","html":"<p><span class='verse-line'>{}</span>"},"bv13:30.2":{"pli":"vippamuttā nirūpadhī; ","html":"<span class='verse-line'>{}</span>"},"bv13:30.3":{"pli":"Ñāṇālokaṁ dassayitvā, ","html":"<span class='verse-line'>{}</span>"},"bv13:30.4":{"pli":"nibbutā te mahāyasā. ","html":"<span class='verse-line'>{}</span></p>"},"bv13:31.1":{"pli":"Sumedho jinavaro buddho, ","html":"<p data-counter='6151'><span class='verse-line'>{}</span>"},"bv13:31.2":{"pli":"Medhārāmamhi nibbuto; ","html":"<span class='verse-line'>{}</span>"},"bv13:31.3":{"pli":"Dhātuvitthārikaṁ āsi, ","html":"<span class='verse-line'>{}</span>"},"bv13:31.4":{"pli":"Tesu tesu padesato”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"bv13:32.1":{"pli":"Sumedhassa bhagavato vaṁso ekādasamo. ","html":"<p class='endsutta'>{}</p></article>"}}}