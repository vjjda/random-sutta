{"bv11":{"bv11:0.1":{"pli":"Buddhavaṁsa ","html":"<article id='bv11'><header><ul><li class='division'>{}</li></ul>"},"bv11:0.2":{"pli":"11. Nāradabuddhavaṁsa ","html":"<h1 class='sutta-title'>{}</h1></header>"},"bv11:1.1":{"pli":"“Padumassa aparena, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"bv11:1.2":{"pli":"sambuddho dvipaduttamo; ","html":"<span class='verse-line'>{}</span>"},"bv11:1.3":{"pli":"Nārado nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"bv11:1.4":{"pli":"asamo appaṭipuggalo. ","html":"<span class='verse-line'>{}</span></p>"},"bv11:2.1":{"pli":"So buddho cakkavattissa, ","html":"<p><span class='verse-line'>{}</span>"},"bv11:2.2":{"pli":"jeṭṭho dayitaoraso; ","html":"<span class='verse-line'>{}</span>"},"bv11:2.3":{"pli":"Āmukkamālābharaṇo, ","html":"<span class='verse-line'>{}</span>"},"bv11:2.4":{"pli":"uyyānaṁ upasaṅkami. ","html":"<span class='verse-line'>{}</span></p>"},"bv11:3.1":{"pli":"Tatthāsi rukkho yasavipulo, ","html":"<p><span class='verse-line'>{}</span>"},"bv11:3.2":{"pli":"Abhirūpo brahā suci; ","html":"<span class='verse-line'>{}</span>"},"bv11:3.3":{"pli":"Tamajjhapatvā upanisīdi, ","html":"<span class='verse-line'>{}</span>"},"bv11:3.4":{"pli":"Mahāsoṇassa heṭṭhato. ","html":"<span class='verse-line'>{}</span></p>"},"bv11:4.1":{"pli":"Tattha ñāṇavaruppajji, ","html":"<p><span class='verse-line'>{}</span>"},"bv11:4.2":{"pli":"anantaṁ vajirūpamaṁ; ","html":"<span class='verse-line'>{}</span>"},"bv11:4.3":{"pli":"Tena vicini saṅkhāre, ","html":"<span class='verse-line'>{}</span>"},"bv11:4.4":{"pli":"ukkujjamavakujjakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"bv11:5.1":{"pli":"Tattha sabbakilesāni, ","html":"<p><span class='verse-line'>{}</span>"},"bv11:5.2":{"pli":"asesamabhivāhayi; ","html":"<span class='verse-line'>{}</span>"},"bv11:5.3":{"pli":"Pāpuṇī kevalaṁ bodhiṁ, ","html":"<span class='verse-line'>{}</span>"},"bv11:5.4":{"pli":"buddhañāṇe ca cuddasa. ","html":"<span class='verse-line'>{}</span></p>"},"bv11:6.1":{"pli":"Pāpuṇitvāna sambodhiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"bv11:6.2":{"pli":"dhammacakkaṁ pavattayi; ","html":"<span class='verse-line'>{}</span>"},"bv11:6.3":{"pli":"Koṭisatasahassānaṁ, ","html":"<span class='verse-line'>{}</span>"},"bv11:6.4":{"pli":"paṭhamābhisamayo ahu. ","html":"<span class='verse-line'>{}</span></p>"},"bv11:7.1":{"pli":"Mahādoṇaṁ nāgarājaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"bv11:7.2":{"pli":"vinayanto mahāmuni; ","html":"<span class='verse-line'>{}</span>"},"bv11:7.3":{"pli":"Pāṭiheraṁ tadākāsi, ","html":"<span class='verse-line'>{}</span>"},"bv11:7.4":{"pli":"dassayanto sadevake. ","html":"<span class='verse-line'>{}</span></p>"},"bv11:8.1":{"pli":"Tadā devamanussānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"bv11:8.2":{"pli":"tamhi dhammappakāsane; ","html":"<span class='verse-line'>{}</span>"},"bv11:8.3":{"pli":"Navutikoṭisahassāni, ","html":"<span class='verse-line'>{}</span>"},"bv11:8.4":{"pli":"tariṁsu sabbasaṁsayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"bv11:9.1":{"pli":"Yamhi kāle mahāvīro, ","html":"<p><span class='verse-line'>{}</span>"},"bv11:9.2":{"pli":"ovadī sakamatrajaṁ; ","html":"<span class='verse-line'>{}</span>"},"bv11:9.3":{"pli":"Asītikoṭisahassānaṁ, ","html":"<span class='verse-line'>{}</span>"},"bv11:9.4":{"pli":"tatiyābhisamayo ahu. ","html":"<span class='verse-line'>{}</span></p>"},"bv11:10.1":{"pli":"Sannipātā tayo āsuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"bv11:10.2":{"pli":"nāradassa mahesino; ","html":"<span class='verse-line'>{}</span>"},"bv11:10.3":{"pli":"Koṭisatasahassānaṁ, ","html":"<span class='verse-line'>{}</span>"},"bv11:10.4":{"pli":"paṭhamo āsi samāgamo. ","html":"<span class='verse-line'>{}</span></p>"},"bv11:11.1":{"pli":"Yadā buddho buddhaguṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"bv11:11.2":{"pli":"sanidānaṁ pakāsayi; ","html":"<span class='verse-line'>{}</span>"},"bv11:11.3":{"pli":"Navutikoṭisahassāni, ","html":"<span class='verse-line'>{}</span>"},"bv11:11.4":{"pli":"samiṁsu vimalā tadā. ","html":"<span class='verse-line'>{}</span></p>"},"bv11:12.1":{"pli":"Yadā verocano nāgo, ","html":"<p><span class='verse-line'>{}</span>"},"bv11:12.2":{"pli":"dānaṁ dadāti satthuno; ","html":"<span class='verse-line'>{}</span>"},"bv11:12.3":{"pli":"Tadā samiṁsu jinaputtā, ","html":"<span class='verse-line'>{}</span>"},"bv11:12.4":{"pli":"asītisatasahassiyo. ","html":"<span class='verse-line'>{}</span></p>"},"bv11:13.1":{"pli":"Ahaṁ tena samayena, ","html":"<p><span class='verse-line'>{}</span>"},"bv11:13.2":{"pli":"jaṭilo uggatāpano; ","html":"<span class='verse-line'>{}</span>"},"bv11:13.3":{"pli":"Antalikkhacaro āsiṁ, ","html":"<span class='verse-line'>{}</span>"},"bv11:13.4":{"pli":"pañcābhiññāsu pāragū. ","html":"<span class='verse-line'>{}</span></p>"},"bv11:14.1":{"pli":"Tadāpāhaṁ asamasamaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"bv11:14.2":{"pli":"sasaṅghaṁ saparijjanaṁ; ","html":"<span class='verse-line'>{}</span>"},"bv11:14.3":{"pli":"Annapānena tappetvā, ","html":"<span class='verse-line'>{}</span>"},"bv11:14.4":{"pli":"candanenābhipūjayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"bv11:15.1":{"pli":"Sopi maṁ tadā byākāsi, ","html":"<p><span class='verse-line'>{}</span>"},"bv11:15.2":{"pli":"nārado lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"bv11:15.3":{"pli":"‘Aparimeyyito kappe, ","html":"<span class='verse-line'>{}</span>"},"bv11:15.4":{"pli":"ayaṁ buddho bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"bv11:16.1":{"pli":"Padhānaṁ padahitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"bv11:16.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"bv11:16.3":{"pli":"hessāma sammukhā imaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"bv11:17.1":{"pli":"Tassāpi vacanaṁ sutvā, ","html":"<p><span class='verse-line'>{}</span>"},"bv11:17.2":{"pli":"bhiyyo h