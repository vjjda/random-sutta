":"Kathayanto ca me pañhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap51:17.4":{"pli":"dhammasotaṁ upānayi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap51:18.1":{"pli":"Tassāhaṁ dhammamaññāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap51:18.2":{"pli":"vihāsiṁ sāsane rato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap51:18.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap51:18.4":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap51:19.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap51:19.2":{"pli":"jalajuttamanāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap51:19.3":{"pli":"Nibbāyi anupādāno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap51:19.4":{"pli":"dīpova telasaṅkhayā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap51:20.1":{"pli":"Sattayojanikaṁ āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap51:20.2":{"pli":"thūpañca ratanāmayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap51:20.3":{"pli":"Dhajaṁ tattha apūjesiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap51:20.4":{"pli":"sabbabhaddaṁ manoramaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap51:21.1":{"pli":"Kassapassa ca buddhassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap51:21.2":{"pli":"tisso nāmaggasāvako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap51:21.3":{"pli":"Putto me oraso āsi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap51:21.4":{"pli":"dāyādo jinasāsane. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap51:22.1":{"pli":"Tassa hīnena manasā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap51:22.2":{"pli":"vācaṁ bhāsiṁ abhaddakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap51:22.3":{"pli":"Tena kammavipākena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap51:22.4":{"pli":"pacchā me āsi bhadda