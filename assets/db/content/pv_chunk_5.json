{"pv36":{"pv36:0.1":{"pli":"Petavatthu ","html":"<article id='pv36'><header><ul><li class='division'>{}</li>"},"pv36:0.2":{"pli":"Mahāvagga ","html":"<li>{}</li></ul>"},"pv36:0.3":{"pli":"1. Ambasakkarapetavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv36:1.1":{"pli":"Vesālī nāma nagaratthi vajjīnaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv36:1.2":{"pli":"Tattha ahu licchavi ambasakkaro; ","html":"<span class='verse-line'>{}</span>"},"pv36:1.3":{"pli":"Disvāna petaṁ nagarassa bāhiraṁ, ","html":"<span class='verse-line'>{}</span>"},"pv36:1.4":{"pli":"Tattheva pucchittha taṁ kāraṇatthiko. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:2.1":{"pli":"“Seyyā nisajjā nayimassa atthi, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:2.2":{"pli":"Abhikkamo natthi paṭikkamo ca; ","html":"<span class='verse-line'>{}</span>"},"pv36:2.3":{"pli":"Asitapītakhāyitavatthabhogā, ","html":"<span class='verse-line'>{}</span>"},"pv36:2.4":{"pli":"Paricārikā sāpi imassa natthi. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:3.1":{"pli":"Ye ñātakā diṭṭhasutā suhajjā, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:3.2":{"pli":"Anukampakā yassa ahesuṁ pubbe; ","html":"<span class='verse-line'>{}</span>"},"pv36:3.3":{"pli":"Daṭṭhumpi te dāni na taṁ labhanti, ","html":"<span class='verse-line'>{}</span>"},"pv36:3.4":{"pli":"Virājitatto hi janena tena. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:4.1":{"pli":"Na oggatattassa bhavanti mittā, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:4.2":{"pli":"Jahanti mittā vikalaṁ viditvā; ","html":"<span class='verse-line'>{}</span>"},"pv36:4.3":{"pli":"Atthañca disvā parivārayanti, ","html":"<span class='verse-line'>{}</span>"},"pv36:4.4":{"pli":"Bahū mittā uggatattassa honti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:5.1":{"pli":"Nihīnatto sabbabhogehi kiccho, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:5.2":{"pli":"Sammakkhito samparibhinnagatto; ","html":"<span class='verse-line'>{}</span>"},"pv36:5.3":{"pli":"Ussāvabindūva palimpamāno, ","html":"<span class='verse-line'>{}</span>"},"pv36:5.4":{"pli":"Ajja suve jīvitassūparodho. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:6.1":{"pli":"Etādisaṁ uttamakicchappattaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:6.2":{"pli":"Uttāsitaṁ pucimandassa sūle; ","html":"<span class='verse-line'>{}</span>"},"pv36:6.3":{"pli":"‘Atha tvaṁ kena vaṇṇena vadesi yakkha, ","html":"<span class='verse-line'>{}</span>"},"pv36:6.4":{"pli":"Jīva bho jīvitameva seyyo’”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:7.1":{"pli":"“Sālohito esa ahosi mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:7.2":{"pli":"Ahaṁ sarāmi purimāya jātiyā; ","html":"<span class='verse-line'>{}</span>"},"pv36:7.3":{"pli":"Disvā ca me kāruññamahosi rāja, ","html":"<span class='verse-line'>{}</span>"},"pv36:7.4":{"pli":"Mā pāpadhammo nirayaṁ patāyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:8.1":{"pli":"Ito cuto licchavi esa poso, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:8.2":{"pli":"Sattussadaṁ nirayaṁ ghorarūpaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv36:8.3":{"pli":"Upapajjati dukkaṭakammakārī, ","html":"<span class='verse-line'>{}</span>"},"pv36:8.4":{"pli":"Mahābhitāpaṁ kaṭukaṁ bhayānakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:9.1":{"pli":"Anekabhāgena guṇena seyyo, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:9.2":{"pli":"Ayameva sūlo nirayena tena; ","html":"<span class='verse-line'>{}</span>"},"pv36:9.3":{"pli":"Ekantadukkhaṁ kaṭukaṁ bhayānakaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv36:9.4":{"pli":"Ekantatibbaṁ nirayaṁ patāyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:10.1":{"pli":"Idañca sutvā vacanaṁ mameso, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:10.2":{"pli":"Dukkhūpanīto vijaheyya pāṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv36:10.3":{"pli":"Tasmā ahaṁ santike na bhaṇāmi, ","html":"<span class='verse-line'>{}</span>"},"pv36:10.4":{"pli":"Mā me kato jīvitassūparodho”. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:11.1":{"pli":"“Aññāto eso purisassa attho, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:11.2":{"pli":"Aññampi icchāmase pucchituṁ tuvaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv36:11.3":{"pli":"Okāsakammaṁ sace no karosi, ","html":"<span class='verse-line'>{}</span>"},"pv36:11.4":{"pli":"Pucchāma taṁ no na ca kujjhitabban”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:12.1":{"pli":"“Addhā paṭiññā me tadā ahu, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:12.2":{"pli":"Nācikkhanā appasannassa hoti; ","html":"<span class='verse-line'>{}</span>"},"pv36:12.3":{"pli":"Akāmā saddheyyavacoti katvā, ","html":"<span class='verse-line'>{}</span>"},"pv36:12.4":{"pli":"Pucchassu maṁ kāmaṁ yathā visayhan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:13.1":{"pli":"“Yaṁ kiñcahaṁ cakkhunā passissāmi, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:13.2":{"pli":"Sabbampi tāhaṁ abhisaddaheyyaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv36:13.3":{"pli":"Disvāva taṁ nopi ce saddaheyyaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv36:13.4":{"pli":"Kareyyāsi me yakkha niyassakamman”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:14.1":{"pli":"“Saccappaṭiññā tava mesā hotu, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:14.2":{"pli":"Sutvāna dhammaṁ labha suppasādaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv36:14.3":{"pli":"Aññatthiko no ca paduṭṭhacitto, ","html":"<span class='verse-line'>{}</span>"},"pv36:14.4":{"pli":"Yaṁ te sutaṁ asutañcāpi dhammaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv36:14.5":{"pli":"Sabbampi akkhissaṁ yathā pajānanti”. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:15.1":{"pli":"“Setena assena alaṅkatena, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:15.2":{"pli":"Upayāsi sūlāvutakassa santike; ","html":"<span class='verse-line'>{}</span>"},"pv36:15.3":{"pli":"Yānaṁ idaṁ abbhutaṁ dassaneyyaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv36:15.4":{"pli":"Kissetaṁ kammassa ayaṁ vipāko”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:16.1":{"pli":"“Vesāliyā nagarassa majjhe, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:16.2":{"pli":"Cikkhallamagge narakaṁ ahosi; ","html":"<span class='verse-line'>{}</span>"},"pv36:16.3":{"pli":"Gosīsamekāhaṁ pasannacitto, ","html":"<span class='verse-line'>{}</span>"},"pv36:16.4":{"pli":"Setaṁ gahetvā narakasmiṁ nikkhipiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:17.1":{"pli":"Etasmiṁ pādāni patiṭṭhapetvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:17.2":{"pli":"Mayañca aññe ca atikkamimhā; ","html":"<span class='verse-line'>{}</span>"},"pv36:17.3":{"pli":"Yānaṁ idaṁ abbhutaṁ dassaneyyaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv36:17.4":{"pli":"Tasseva kammassa ayaṁ vipāko”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:18.1":{"pli":"“Vaṇṇo ca te sabbadisā pabhāsati, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:18.2":{"pli":"Gandho ca te sabbadisā pavāyati; ","html":"<span class='verse-line'>{}</span>"},"pv36:18.3":{"pli":"Yakkhiddhipattosi mahānubhāvo, ","html":"<span class='verse-line'>{}</span>"},"pv36:18.4":{"pli":"Naggo cāsi kissa ayaṁ vipāko”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:19.1":{"pli":"“Akkodhano niccapasannacitto, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:19.2":{"pli":"Saṇhāhi vācāhi janaṁ upemi; ","html":"<span class='verse-line'>{}</span>"},"pv36:19.3":{"pli":"Tasseva kammassa ayaṁ vipāko, ","html":"<span class='verse-line'>{}</span>"},"pv36:19.4":{"pli":"Dibbo me vaṇṇo satataṁ pabhāsati. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:20.1":{"pli":"Yasañca kittiñca dhamme ṭhitānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:20.2":{"pli":"Disvāna mantemi pasannacitto; ","html":"<span class='verse-line'>{}</span>"},"pv36:20.3":{"pli":"Tasseva kammassa ayaṁ vipāko, ","html":"<span class='verse-line'>{}</span>"},"pv36:20.4":{"pli":"Dibbo me gandho satataṁ pavāyati. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:21.1":{"pli":"Sahāyānaṁ titthasmiṁ nhāyantānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:21.2":{"pli":"Thale gahetvā nidahissa dussaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv36:21.3":{"pli":"Khiḍḍatthiko no ca paduṭṭhacitto, ","html":"<span class='verse-line'>{}</span>"},"pv36:21.4":{"pli":"Tenamhi naggo kasirā ca vuttī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:22.1":{"pli":"“Yo kīḷamāno pakaroti pāpaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:22.2":{"pli":"Tassedisaṁ kammavipākamāhu; ","html":"<span class='verse-line'>{}</span>"},"pv36:22.3":{"pli":"Akīḷamāno pana yo karoti, ","html":"<span class='verse-line'>{}</span>"},"pv36:22.4":{"pli":"Kiṁ tassa kammassa vipākamāhū”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:23.1":{"pli":"“Ye duṭṭhasaṅkappamanā manussā, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:23.2":{"pli":"Kāyena vācāya ca saṅkiliṭṭhā; ","html":"<span class='verse-line'>{}</span>"},"pv36:23.3":{"pli":"Kāyassa bhedā abhisamparāyaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv36:23.4":{"pli":"Asaṁsayaṁ te nirayaṁ upenti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:24.1":{"pli":"Apare pana sugatimāsamānā, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:24.2":{"pli":"Dāne ratā saṅgahitattabhāvā; ","html":"<span class='verse-line'>{}</span>"},"pv36:24.3":{"pli":"Kāyassa bhedā abhisamparāyaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv36:24.4":{"pli":"Asaṁsayaṁ te sugatiṁ upentī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:25.1":{"pli":"“Taṁ kinti jāneyyamahaṁ avecca, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:25.2":{"pli":"Kalyāṇapāpassa ayaṁ vipāko; ","html":"<span class='verse-line'>{}</span>"},"pv36:25.3":{"pli":"Kiṁ vāhaṁ disvā abhisaddaheyyaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv36:25.4":{"pli":"Ko vāpi maṁ saddahāpeyya etan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:26.1":{"pli":"“Disvā ca sutvā abhisaddahassu, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:26.2":{"pli":"Kalyāṇapāpassa ayaṁ vipāko; ","html":"<span class='verse-line'>{}</span>"},"pv36:26.3":{"pli":"Kalyāṇapāpe ubhaye asante, ","html":"<span class='verse-line'>{}</span>"},"pv36:26.4":{"pli":"Siyā nu sattā sugatā duggatā vā. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:27.1":{"pli":"No cettha kammāni kareyyuṁ maccā, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:27.2":{"pli":"Kalyāṇapāpāni manussaloke; ","html":"<span class='verse-line'>{}</span>"},"pv36:27.3":{"pli":"Nāhesuṁ sattā sugatā duggatā vā, ","html":"<span class='verse-line'>{}</span>"},"pv36:27.4":{"pli":"Hīnā paṇītā ca manussaloke. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:28.1":{"pli":"Yasmā ca kammāni karonti maccā, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:28.2":{"pli":"Kalyāṇapāpāni manussaloke; ","html":"<span class='verse-line'>{}</span>"},"pv36:28.3":{"pli":"Tasmā hi sattā sugatā duggatā vā, ","html":"<span class='verse-line'>{}</span>"},"pv36:28.4":{"pli":"Hīnā paṇītā ca manussaloke. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:29.1":{"pli":"Dvayajja kammānaṁ vipākamāhu, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:29.2":{"pli":"Sukhassa dukkhassa ca vedanīyaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv36:29.3":{"pli":"Tā devatāyo paricārayanti, ","html":"<span class='verse-line'>{}</span>"},"pv36:29.4":{"pli":"Paccanti bālā dvayataṁ apassino. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:30.1":{"pli":"Na matthi kammāni sayaṅkatāni, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:30.2":{"pli":"Datvāpi me natthi yo ādiseyya; ","html":"<span class='verse-line'>{}</span>"},"pv36:30.3":{"pli":"Acchādanaṁ sayanamathannapānaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv36:30.4":{"pli":"Tenamhi naggo kasirā ca vuttī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:31.1":{"pli":"“Siyā nu kho kāraṇaṁ kiñci yakkha, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:31.2":{"pli":"Acchādanaṁ yena tuvaṁ labhetha; ","html":"<span class='verse-line'>{}</span>"},"pv36:31.3":{"pli":"Ācikkha me tvaṁ yadatthi hetu, ","html":"<span class='verse-line'>{}</span>"},"pv36:31.4":{"pli":"Saddhāyikaṁ hetuvaco suṇomā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:32.1":{"pli":"“Kappitako nāma idhatthi bhikkhu, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:32.2":{"pli":"Jhāyī susīlo arahā vimutto; ","html":"<span class='verse-line'>{}</span>"},"pv36:32.3":{"pli":"Guttindriyo saṁvutapātimokkho, ","html":"<span class='verse-line'>{}</span>"},"pv36:32.4":{"pli":"Sītibhūto uttamadiṭṭhipatto. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:33.1":{"pli":"Sakhilo vadaññū suvaco sumukho, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:33.2":{"pli":"Svāgamo suppaṭimuttako ca; ","html":"<span class='verse-line'>{}</span>"},"pv36:33.3":{"pli":"Puññassa khettaṁ araṇavihārī, ","html":"<span class='verse-line'>{}</span>"},"pv36:33.4":{"pli":"Devamanussānañca dakkhiṇeyyo. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:34.1":{"pli":"Santo vidhūmo anīgho nirāso, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:34.2":{"pli":"Mutto visallo amamo avaṅko; ","html":"<span class='verse-line'>{}</span>"},"pv36:34.3":{"pli":"Nirūpadhī sabbapapañcakhīṇo, ","html":"<span class='verse-line'>{}</span>"},"pv36:34.4":{"pli":"Tisso vijjā anuppatto jutimā. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:35.1":{"pli":"Appaññāto disvāpi na ca sujāno, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:35.2":{"pli":"Munīti naṁ vajjisu voharanti; ","html":"<span class='verse-line'>{}</span>"},"pv36:35.3":{"pli":"Jānanti taṁ yakkhabhūtā anejaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv36:35.4":{"pli":"Kalyāṇadhammaṁ vicarantaṁ loke. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:36.1":{"pli":"Tassa tuvaṁ ekayugaṁ duve vā, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:36.2":{"pli":"Mamuddisitvāna sace dadetha; ","html":"<span class='verse-line'>{}</span>"},"pv36:36.3":{"pli":"Paṭiggahītāni ca tāni assu, ","html":"<span class='verse-line'>{}</span>"},"pv36:36.4":{"pli":"Mamañca passetha sannaddhadussan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:37.1":{"pli":"“Kasmiṁ padese samaṇaṁ vasantaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:37.2":{"pli":"Gantvāna passemu mayaṁ idāni; ","html":"<span class='verse-line'>{}</span>"},"pv36:37.3":{"pli":"Yo majja kaṅkhaṁ vicikicchitañca, ","html":"<span class='verse-line'>{}</span>"},"pv36:37.4":{"pli":"Diṭṭhīvisūkāni vinodayeyyā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:38.1":{"pli":"“Eso nisinno kapinaccanāyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:38.2":{"pli":"Parivārito devatāhi bahūhi; ","html":"<span class='verse-line'>{}</span>"},"pv36:38.3":{"pli":"Dhammiṁ kathaṁ bhāsati saccanāmo, ","html":"<span class='verse-line'>{}</span>"},"pv36:38.4":{"pli":"Sakasmimācerake appamatto”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:39.1":{"pli":"“Tathāhaṁ kassāmi gantvā idāni, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:39.2":{"pli":"Acchādayissaṁ samaṇaṁ yugena; ","html":"<span class='verse-line'>{}</span>"},"pv36:39.3":{"pli":"Paṭiggahitāni ca tāni assu, ","html":"<span class='verse-line'>{}</span>"},"pv36:39.4":{"pli":"Tuvañca passemu sannaddhadussan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:40.1":{"pli":"“Mā akkhaṇe pabbajitaṁ upāgami, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:40.2":{"pli":"Sādhu vo licchavi nesa dhammo; ","html":"<span class='verse-line'>{}</span>"},"pv36:40.3":{"pli":"Tato ca kāle upasaṅkamitvā, ","html":"<span class='verse-line'>{}</span>"},"pv36:40.4":{"pli":"Tattheva passāhi raho nisinnan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:41.1":{"pli":"Tathāti vatvā agamāsi tattha, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:41.2":{"pli":"Parivārito dāsagaṇena licchavi; ","html":"<span class='verse-line'>{}</span>"},"pv36:41.3":{"pli":"So taṁ nagaraṁ upasaṅkamitvā, ","html":"<span class='verse-line'>{}</span>"},"pv36:41.4":{"pli":"Vāsūpagacchittha sake nivesane. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:42.1":{"pli":"Tato ca kāle gihikiccāni katvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:42.2":{"pli":"Nhatvā pivitvā ca khaṇaṁ labhitvā; ","html":"<span class='verse-line'>{}</span>"},"pv36:42.3":{"pli":"Viceyya peḷāto ca yugāni aṭṭha, ","html":"<span class='verse-line'>{}</span>"},"pv36:42.4":{"pli":"Gāhāpayī dāsagaṇena licchavi. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:43.1":{"pli":"So taṁ padesaṁ upasaṅkamitvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:43.2":{"pli":"Taṁ addasa samaṇaṁ santacittaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv36:43.3":{"pli":"Paṭikkantaṁ gocarato nivattaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv36:43.4":{"pli":"Sītibhūtaṁ rukkhamūle nisinnaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:44.1":{"pli":"Tamenamavoca upasaṅkamitvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:44.2":{"pli":"Appābādhaṁ phāsuvihārañca pucchi; ","html":"<span class='verse-line'>{}</span>"},"pv36:44.3":{"pli":"“Vesāliyaṁ licchavihaṁ bhadante, ","html":"<span class='verse-line'>{}</span>"},"pv36:44.4":{"pli":"Jānanti maṁ licchavi ambasakkaro. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:45.1":{"pli":"Imāni me aṭṭha yugā subhāni, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:45.2":{"pli":"Paṭigaṇha bhante padadāmi tuyhaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv36:45.3":{"pli":"Teneva atthena idhāgatosmi, ","html":"<span class='verse-line'>{}</span>"},"pv36:45.4":{"pli":"Yathā ahaṁ attamano bhaveyyan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:46.1":{"pli":"“Dūratova samaṇabrāhmaṇā ca, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:46.2":{"pli":"Nivesanaṁ te parivajjayanti; ","html":"<span class='verse-line'>{}</span>"},"pv36:46.3":{"pli":"Pattāni bhijjanti ca te nivesane, ","html":"<span class='verse-line'>{}</span>"},"pv36:46.4":{"pli":"Saṅghāṭiyo cāpi vidālayanti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:47.1":{"pli":"Athāpare pādakuṭhārikāhi, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:47.2":{"pli":"Avaṁsirā samaṇā pātayanti; ","html":"<span class='verse-line'>{}</span>"},"pv36:47.3":{"pli":"Etādisaṁ pabbajitā vihesaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv36:47.4":{"pli":"Tayā kataṁ samaṇā pāpuṇanti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:48.1":{"pli":"Tiṇena telampi na tvaṁ adāsi, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:48.2":{"pli":"Muḷhassa maggampi na pāvadāsi; ","html":"<span class='verse-line'>{}</span>"},"pv36:48.3":{"pli":"Andhassa daṇḍaṁ sayamādiyāsi, ","html":"<span class='verse-line'>{}</span>"},"pv36:48.4":{"pli":"Etādiso kadariyo asaṁvuto tuvaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv36:48.5":{"pli":"Atha tvaṁ kena vaṇṇena kimeva disvā, ","html":"<span class='verse-line'>{}</span>"},"pv36:48.6":{"pli":"Amhehi saha saṁvibhāgaṁ karosī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:49.1":{"pli":"“Paccemi bhante yaṁ tvaṁ vadesi, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:49.2":{"pli":"Vihesayiṁ samaṇe brāhmaṇe ca; ","html":"<span class='verse-line'>{}</span>"},"pv36:49.3":{"pli":"Khiḍḍatthiko no ca paduṭṭhacitto, ","html":"<span class='verse-line'>{}</span>"},"pv36:49.4":{"pli":"Etampi me dukkaṭameva bhante. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:50.1":{"pli":"Khiḍḍāya yakkho pasavitvā pāpaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:50.2":{"pli":"Vedeti dukkhaṁ asamattabhogī; ","html":"<span class='verse-line'>{}</span>"},"pv36:50.3":{"pli":"Daharo yuvā nagganiyassa bhāgī, ","html":"<span class='verse-line'>{}</span>"},"pv36:50.4":{"pli":"Kiṁ su tato dukkhatarassa hoti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:51.1":{"pli":"Taṁ disvā saṁvegamalatthaṁ bhante, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:51.2":{"pli":"Tappaccayā vāpi dadāmi dānaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv36:51.3":{"pli":"Paṭigaṇha bhante vatthayugāni aṭṭha, ","html":"<span class='verse-line'>{}</span>"},"pv36:51.4":{"pli":"Yakkhassimā gacchantu dakkhiṇāyo”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:52.1":{"pli":"“Addhā hi dānaṁ bahudhā pasatthaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:52.2":{"pli":"Dadato ca te akkhayadhammamatthu; ","html":"<span class='verse-line'>{}</span>"},"pv36:52.3":{"pli":"Paṭigaṇhāmi te vatthayugāni aṭṭha, ","html":"<span class='verse-line'>{}</span>"},"pv36:52.4":{"pli":"Yakkhassimā gacchantu dakkhiṇāyo”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:53.1":{"pli":"Tato hi so ācamayitvā licchavi, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:53.2":{"pli":"Therassa datvāna yugāni aṭṭha; ","html":"<span class='verse-line'>{}</span>"},"pv36:53.3":{"pli":"Paṭiggahitāni ca tāni assu, ","html":"<span class='verse-line'>{}</span>"},"pv36:53.4":{"pli":"Yakkhañca passetha sannaddhadussaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:54.1":{"pli":"Tamaddasā candanasāralittaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:54.2":{"pli":"Ājaññamārūḷhamuḷāravaṇṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv36:54.3":{"pli":"Alaṅkataṁ sādhunivatthadussaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv36:54.4":{"pli":"Parivāritaṁ yakkhamahiddhipattaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:55.1":{"pli":"So taṁ disvā attamano udaggo, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:55.2":{"pli":"Pahaṭṭhacitto ca subhaggarūpo; ","html":"<span class='verse-line'>{}</span>"},"pv36:55.3":{"pli":"Kammañca disvāna mahāvipākaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv36:55.4":{"pli":"Sandiṭṭhikaṁ cakkhunā sacchikatvā. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:56.1":{"pli":"Tamenamavoca upasaṅkamitvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:56.2":{"pli":"“Dassāmi dānaṁ samaṇabrāhmaṇānaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv36:56.3":{"pli":"Na cāpi me kiñci adeyyamatthi, ","html":"<span class='verse-line'>{}</span>"},"pv36:56.4":{"pli":"Tuvañca me yakkha bahūpakāro”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:57.1":{"pli":"“Tuvañca me licchavi ekadesaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:57.2":{"pli":"Adāsi dānāni amoghametaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv36:57.3":{"pli":"Svāhaṁ karissāmi tayāva sakkhiṁ, ","html":"<span class='verse-line'>{}</span>"},"pv36:57.4":{"pli":"Amānuso mānusakena saddhin”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:58.1":{"pli":"“Gatī ca bandhū ca parāyaṇañca, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:58.2":{"pli":"Mitto mamāsi atha devatā me; ","html":"<span class='verse-line'>{}</span>"},"pv36:58.3":{"pli":"Yācāmi taṁ pañjaliko bhavitvā, ","html":"<span class='verse-line'>{}</span>"},"pv36:58.4":{"pli":"Icchāmi taṁ yakkha punāpi daṭṭhun”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:59.1":{"pli":"“Sace tuvaṁ assaddho bhavissasi, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:59.2":{"pli":"Kadariyarūpo vippaṭipannacitto; ","html":"<span class='verse-line'>{}</span>"},"pv36:59.3":{"pli":"Tvaṁ neva maṁ lacchasi dassanāya, ","html":"<span class='verse-line'>{}</span>"},"pv36:59.4":{"pli":"Disvā ca taṁ nopi ca ālapissaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:60.1":{"pli":"Sace pana tvaṁ bhavissasi dhammagāravo, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:60.2":{"pli":"Dāne rato saṅgahitattabhāvo; ","html":"<span class='verse-line'>{}</span>"},"pv36:60.3":{"pli":"Opānabhūto samaṇabrāhmaṇānaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv36:60.4":{"pli":"Evaṁ mamaṁ lacchasi dassanāya. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:61.1":{"pli":"Disvā ca taṁ ālapissaṁ bhadante, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:61.2":{"pli":"Imañca sūlato lahuṁ pamuñca; ","html":"<span class='verse-line'>{}</span>"},"pv36:61.3":{"pli":"Yatonidānaṁ akarimha sakkhiṁ, ","html":"<span class='verse-line'>{}</span>"},"pv36:61.4":{"pli":"Maññāmi sūlāvutakassa kāraṇā. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:62.1":{"pli":"Te aññamaññaṁ akarimha sakkhiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:62.2":{"pli":"Ayañca sūlato lahuṁ pamutto; ","html":"<span class='verse-line'>{}</span>"},"pv36:62.3":{"pli":"Sakkacca dhammāni samācaranto, ","html":"<span class='verse-line'>{}</span>"},"pv36:62.4":{"pli":"Mucceyya so nirayā ca tamhā; ","html":"<span class='verse-line'>{}</span>"},"pv36:62.5":{"pli":"Kammaṁ siyā aññatra vedanīyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:63.1":{"pli":"Kappitakañca upasaṅkamitvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:63.2":{"pli":"Teneva saha saṁvibhajitvā kāle; ","html":"<span class='verse-line'>{}</span>"},"pv36:63.3":{"pli":"Sayaṁ mukhenūpanisajja puccha, ","html":"<span class='verse-line'>{}</span>"},"pv36:63.4":{"pli":"So te akkhissati etamatthaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:64.1":{"pli":"Tameva bhikkhuṁ upasaṅkamitvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:64.2":{"pli":"Pucchassu aññatthiko no ca paduṭṭhacitto; ","html":"<span class='verse-line'>{}</span>"},"pv36:64.3":{"pli":"So te sutaṁ asutañcāpi dhammaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv36:64.4":{"pli":"Sabbampi akkhissati yathā pajānan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:65.1":{"pli":"So tattha rahassaṁ samullapitvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:65.2":{"pli":"Sakkhiṁ karitvāna amānusena; ","html":"<span class='verse-line'>{}</span>"},"pv36:65.3":{"pli":"Pakkāmi so licchavīnaṁ sakāsaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv36:65.4":{"pli":"Atha bravi parisaṁ sannisinnaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:66.1":{"pli":"“Suṇantu bhonto mama ekavākyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:66.2":{"pli":"Varaṁ varissaṁ labhissāmi atthaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv36:66.3":{"pli":"Sūlāvuto puriso luddakammo, ","html":"<span class='verse-line'>{}</span>"},"pv36:66.4":{"pli":"Paṇihitadaṇḍo anusattarūpo. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:67.1":{"pli":"Ettāvatā vīsatirattimattā, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:67.2":{"pli":"Yato āvuto neva jīvati na mato; ","html":"<span class='verse-line'>{}</span>"},"pv36:67.3":{"pli":"Tāhaṁ mocayissāmi dāni, ","html":"<span class='verse-line'>{}</span>"},"pv36:67.4":{"pli":"Yathāmatiṁ anujānātu saṅgho”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:68.1":{"pli":"“Etañca aññañca lahuṁ pamuñca, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:68.2":{"pli":"Ko taṁ vadetha tathā karontaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv36:68.3":{"pli":"Yathā pajānāsi tathā karohi, ","html":"<span class='verse-line'>{}</span>"},"pv36:68.4":{"pli":"Yathāmatiṁ anujānāti saṅgho”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:69.1":{"pli":"So taṁ padesaṁ upasaṅkamitvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:69.2":{"pli":"Sūlāvutaṁ mocayi khippameva; ","html":"<span class='verse-line'>{}</span>"},"pv36:69.3":{"pli":"“Mā bhāyi sammā”ti ca taṁ avoca, ","html":"<span class='verse-line'>{}</span>"},"pv36:69.4":{"pli":"Tikicchakānañca upaṭṭhapesi. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:70.1":{"pli":"“Kappitakañca upasaṅkamitvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:70.2":{"pli":"Teneva saha saṁvibhajitvā kāle; ","html":"<span class='verse-line'>{}</span>"},"pv36:70.3":{"pli":"Sayaṁ mukhenūpanisajja licchavi, ","html":"<span class='verse-line'>{}</span>"},"pv36:70.4":{"pli":"Tatheva pucchittha naṁ kāraṇatthiko. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:71.1":{"pli":"Sūlāvuto puriso luddakammo, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:71.2":{"pli":"Paṇihitadaṇḍo anusattarūpo; ","html":"<span class='verse-line'>{}</span>"},"pv36:71.3":{"pli":"Ettāvatā vīsatirattimattā, ","html":"<span class='verse-line'>{}</span>"},"pv36:71.4":{"pli":"Yato āvuto neva jīvati na mato. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:72.1":{"pli":"So mocito gantvā mayā idāni, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:72.2":{"pli":"Etassa yakkhassa vaco hi bhante; ","html":"<span class='verse-line'>{}</span>"},"pv36:72.3":{"pli":"Siyā nu kho kāraṇaṁ kiñcideva, ","html":"<span class='verse-line'>{}</span>"},"pv36:72.4":{"pli":"Yena so nirayaṁ no vajeyya. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:73.1":{"pli":"Ācikkha bhante yadi atthi hetu, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:73.2":{"pli":"Saddhāyikaṁ hetuvaco suṇoma; ","html":"<span class='verse-line'>{}</span>"},"pv36:73.3":{"pli":"Na tesaṁ kammānaṁ vināsamatthi, ","html":"<span class='verse-line'>{}</span>"},"pv36:73.4":{"pli":"Avedayitvā idha byantibhāvo”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:74.1":{"pli":"“Sace sa dhammāni samācareyya, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:74.2":{"pli":"Sakkacca rattindivamappamatto; ","html":"<span class='verse-line'>{}</span>"},"pv36:74.3":{"pli":"Mucceyya so nirayā ca tamhā, ","html":"<span class='verse-line'>{}</span>"},"pv36:74.4":{"pli":"Kammaṁ siyā aññatra vedanīyan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:75.1":{"pli":"“Aññāto eso purisassa attho, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:75.2":{"pli":"Mamampi dāni anukampa bhante; ","html":"<span class='verse-line'>{}</span>"},"pv36:75.3":{"pli":"Anusāsa maṁ ovada bhūripañña, ","html":"<span class='verse-line'>{}</span>"},"pv36:75.4":{"pli":"Yathā ahaṁ no nirayaṁ vajeyyan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:76.1":{"pli":"“Ajjeva buddhaṁ saraṇaṁ upehi, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:76.2":{"pli":"Dhammañca saṅghañca pasannacitto; ","html":"<span class='verse-line'>{}</span>"},"pv36:76.3":{"pli":"Tatheva sikkhāya padāni pañca, ","html":"<span class='verse-line'>{}</span>"},"pv36:76.4":{"pli":"Akhaṇḍaphullāni samādiyassu. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:77.1":{"pli":"Pāṇātipātā viramassu khippaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:77.2":{"pli":"Loke adinnaṁ parivajjayassu; ","html":"<span class='verse-line'>{}</span>"},"pv36:77.3":{"pli":"Amajjapo mā ca musā abhāṇī, ","html":"<span class='verse-line'>{}</span>"},"pv36:77.4":{"pli":"Sakena dārena ca hohi tuṭṭho; ","html":"<span class='verse-line'>{}</span>"},"pv36:77.5":{"pli":"Imañca ariyaṁ aṭṭhaṅgavarenupetaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv36:77.6":{"pli":"Samādiyāhi kusalaṁ sukhudrayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:78.1":{"pli":"Cīvaraṁ piṇḍapātañca, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:78.2":{"pli":"paccayaṁ sayanāsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv36:78.3":{"pli":"Annaṁ pānaṁ khādanīyaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv36:78.4":{"pli":"vatthasenāsanāni ca; ","html":"<span class='verse-line'>{}</span>"},"pv36:78.5":{"pli":"Dadāhi ujubhūtesu, ","html":"<span class='verse-line'>{}</span>"},"pv36:78.6":{"pli":"vippasannena cetasā. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:79.1":{"pli":"Bhikkhūpi sīlasampanne, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:79.2":{"pli":"vītarāge bahussute; ","html":"<span class='verse-line'>{}</span>"},"pv36:79.3":{"pli":"Tappehi annapānena, ","html":"<span class='verse-line'>{}</span>"},"pv36:79.4":{"pli":"sadā puññaṁ pavaḍḍhati. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:80.1":{"pli":"Evañca dhammāni samācaranto, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:80.2":{"pli":"Sakkacca rattindivamappamatto; ","html":"<span class='verse-line'>{}</span>"},"pv36:80.3":{"pli":"Muñca tuvaṁ nirayā ca tamhā, ","html":"<span class='verse-line'>{}</span>"},"pv36:80.4":{"pli":"Kammaṁ siyā aññatra vedanīyan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:81.1":{"pli":"“Ajjeva buddhaṁ saraṇaṁ upemi, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:81.2":{"pli":"Dhammañca saṅghañca pasannacitto; ","html":"<span class='verse-line'>{}</span>"},"pv36:81.3":{"pli":"Tatheva sikkhāya padāni pañca, ","html":"<span class='verse-line'>{}</span>"},"pv36:81.4":{"pli":"Akhaṇḍaphullāni samādiyāmi. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:82.1":{"pli":"Pāṇātipātā viramāmi khippaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:82.2":{"pli":"Loke adinnaṁ parivajjayāmi; ","html":"<span class='verse-line'>{}</span>"},"pv36:82.3":{"pli":"Amajjapo no ca musā bhaṇāmi, ","html":"<span class='verse-line'>{}</span>"},"pv36:82.4":{"pli":"Sakena dārena ca homi tuṭṭho; ","html":"<span class='verse-line'>{}</span>"},"pv36:82.5":{"pli":"Imañca ariyaṁ aṭṭhaṅgavarenupetaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv36:82.6":{"pli":"Samādiyāmi kusalaṁ sukhudrayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:83.1":{"pli":"Cīvaraṁ piṇḍapātañca, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:83.2":{"pli":"paccayaṁ sayanāsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv36:83.3":{"pli":"Annaṁ pānaṁ khādanīyaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv36:83.4":{"pli":"vatthasenāsanāni ca. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:84.1":{"pli":"Bhikkhū ca sīlasampanne, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:84.2":{"pli":"vītarāge bahussute; ","html":"<span class='verse-line'>{}</span>"},"pv36:84.3":{"pli":"Dadāmi na vikampāmi, ","html":"<span class='verse-line'>{}</span>"},"pv36:84.4":{"pli":"buddhānaṁ sāsane rato”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:85.1":{"pli":"Etādiso licchavi ambasakkaro, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:85.2":{"pli":"Vesāliyaṁ aññataro upāsako; ","html":"<span class='verse-line'>{}</span>"},"pv36:85.3":{"pli":"Saddho mudū kārakaro ca bhikkhu, ","html":"<span class='verse-line'>{}</span>"},"pv36:85.4":{"pli":"Saṅghañca sakkacca tadā upaṭṭhahi. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:86.1":{"pli":"Sūlāvuto ca arogo hutvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:86.2":{"pli":"Serī sukhī pabbajjaṁ upāgami; ","html":"<span class='verse-line'>{}</span>"},"pv36:86.3":{"pli":"Bhikkhuñca āgamma kappitakuttamaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv36:86.4":{"pli":"Ubhopi sāmaññaphalāni ajjhaguṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv36:87.1":{"pli":"Etādisā sappurisāna sevanā, ","html":"<p><span class='verse-line'>{}</span>"},"pv36:87.2":{"pli":"Mahapphalā hoti sataṁ vijānataṁ; ","html":"<span class='verse-line'>{}</span>"},"pv36:87.3":{"pli":"Sūlāvuto aggaphalaṁ aphassayi, ","html":"<span class='verse-line'>{}</span>"},"pv36:87.4":{"pli":"Phalaṁ kaniṭṭhaṁ pana ambasakkaroti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv36:88.1":{"pli":"Ambasakkarapetavatthu paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}