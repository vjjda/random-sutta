{"thag18.1":{"thag18.1:0.1":{"pli":"Theragāthā 18.1 ","eng":"Verses of the Senior Monks 18.1 ","html":"<article id='thag18.1'><header><ul><li class='division'>{}</li>"},"thag18.1:0.2":{"pli":"Cattālīsanipāta ","eng":"The Book of the Forties ","html":"<li>{}</li>"},"thag18.1:0.3":{"pli":"Paṭhamavagga ","eng":"Chapter One ","html":"<li>{}</li></ul>"},"thag18.1:0.4":{"pli":"Mahākassapattheragāthā ","eng":"Mahākassapa ","html":"<h1 class='sutta-title'>{}</h1></header>"},"thag18.1:1.1":{"pli":"“Na gaṇena purakkhato care, ","eng":"“You shouldn’t live for the adulation of a following; ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"thag18.1:1.2":{"pli":"Vimano hoti samādhi dullabho; ","eng":"it turns your mind, making it hard to get immersion. ","html":"<span class='verse-line'>{}</span>"},"thag18.1:1.3":{"pli":"Nānājanasaṅgaho dukho, ","eng":"Seeing that popularity is suffering, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:1.4":{"pli":"Iti disvāna gaṇaṁ na rocaye. ","eng":"you shouldn’t consent to a following. ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:2.1":{"pli":"Na kulāni upabbaje muni, ","eng":"A sage should not visit respectable families; ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:2.2":{"pli":"Vimano hoti samādhi dullabho; ","eng":"it turns your mind, making it hard to get immersion. ","html":"<span class='verse-line'>{}</span>"},"thag18.1:2.3":{"pli":"So ussukko rasānugiddho, ","eng":"If you’re eager and greedy for flavors, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:2.4":{"pli":"Atthaṁ riñcati yo sukhāvaho. ","eng":"you’ll miss the goal that brings such happiness. ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:3.1":{"pli":"Paṅkoti hi naṁ avedayuṁ, ","eng":"They know it really is a bog, ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:3.2":{"pli":"Yāyaṁ vandanapūjanā kulesu; ","eng":"this homage and veneration in respectable families. ","html":"<span class='verse-line'>{}</span>"},"thag18.1:3.3":{"pli":"Sukhumaṁ sallaṁ durubbahaṁ, ","eng":"Honor is a subtle dart, hard to extract, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:3.4":{"pli":"Sakkāro kāpurisena dujjaho. ","eng":"and hard for a reprobate to give up.” ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:4.1":{"pli":"Senāsanamhā oruyha, ","eng":"“I came down from my lodging ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:4.2":{"pli":"nagaraṁ piṇḍāya pāvisiṁ; ","eng":"and entered the city for alms. ","html":"<span class='verse-line'>{}</span>"},"thag18.1:4.3":{"pli":"Bhuñjantaṁ purisaṁ kuṭṭhiṁ, ","eng":"I courteously stood by ","html":"<span class='verse-line'>{}</span>"},"thag18.1:4.4":{"pli":"sakkaccaṁ taṁ upaṭṭhahiṁ. ","eng":"while a leper ate. ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:5.1":{"pli":"So me pakkena hatthena, ","eng":"With his putrid hand ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:5.2":{"pli":"ālopaṁ upanāmayi; ","eng":"he offered me a morsel. ","html":"<span class='verse-line'>{}</span>"},"thag18.1:5.3":{"pli":"Ālopaṁ pakkhipantassa, ","eng":"Putting the morsel in my bowl, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:5.4":{"pli":"aṅguli cettha chijjatha. ","eng":"his finger dropped off right there. ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:6.1":{"pli":"Kuṭṭamūlañca nissāya, ","eng":"Sitting by a wall, ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:6.2":{"pli":"ālopaṁ taṁ abhuñjisaṁ; ","eng":"I ate that lump of rice. ","html":"<span class='verse-line'>{}</span>"},"thag18.1:6.3":{"pli":"Bhuñjamāne vā bhutte vā, ","eng":"I did not feel any disgust ","html":"<span class='verse-line'>{}</span>"},"thag18.1:6.4":{"pli":"jegucchaṁ me na vijjati. ","eng":"while eating or afterwards. ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:7.1":{"pli":"Uttiṭṭhapiṇḍo āhāro, ","eng":"Anyone who makes use of ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:7.2":{"pli":"pūtimuttañca osadhaṁ; ","eng":"leftovers for food, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:7.3":{"pli":"Senāsanaṁ rukkhamūlaṁ, ","eng":"rancid urine as medicine, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:7.4":{"pli":"paṁsukūlañca cīvaraṁ; ","eng":"the root of a tree as lodging, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:7.5":{"pli":"Yassete abhisambhutvā, ","eng":"and cast-off rags as robes, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:7.6":{"pli":"sa ve cātuddiso naro. ","eng":"is at ease in any quarter.” ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:8.1":{"pli":"Yattha eke vihaññanti, ","eng":"“Where some have fallen to ruin ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:8.2":{"pli":"āruhantā siluccayaṁ; ","eng":"while climbing the mountain, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:8.3":{"pli":"Tassa buddhassa dāyādo, ","eng":"there Kassapa ascends; ","html":"<span class='verse-line'>{}</span>"},"thag18.1:8.4":{"pli":"sampajāno patissato; ","eng":"an heir of the Buddha, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:8.5":{"pli":"Iddhibalenupatthaddho, ","eng":"aware and mindful, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:8.6":{"pli":"kassapo abhirūhati. ","eng":"owing to his psychic powers. ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:9.1":{"pli":"Piṇḍapātapaṭikkanto, ","eng":"Returning from almsround, ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:9.2":{"pli":"selamāruyha kassapo; ","eng":"Kassapa ascends the mountain, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:9.3":{"pli":"Jhāyati anupādāno, ","eng":"and practices absorption without grasping, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:9.4":{"pli":"pahīnabhayabheravo. ","eng":"with fear and dread given up. ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:10.1":{"pli":"Piṇḍapātapaṭikkanto, ","eng":"Returning from almsround, ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:10.2":{"pli":"selamāruyha kassapo; ","eng":"Kassapa ascends the mountain, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:10.3":{"pli":"Jhāyati anupādāno, ","eng":"and practices absorption without grasping, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:10.4":{"pli":"ḍayhamānesu nibbuto. ","eng":"quenched amongst those who burn. ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:11.1":{"pli":"Piṇḍapātapaṭikkanto, ","eng":"Returning from almsround, ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:11.2":{"pli":"selamāruyha kassapo; ","eng":"Kassapa ascends the mountain, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:11.3":{"pli":"Jhāyati anupādāno, ","eng":"and practices absorption without grasping, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:11.4":{"pli":"katakicco anāsavo. ","eng":"his task completed, free of defilements.” ","html":"<span class='verse-line'>{}</span></p>","comm":"Legend has it that Kassapa meditates there still, rapt in deepest absorption, waiting until the coming of the future Buddha Metteyya, to whom he will present the rag robes of Gotama, which he received at <a href='index.html?q=sn16.11#15.2'>SN 16.11:15.2</a>. This story echoes Taittiriya Āraṇyaka 1.7.1.3, which tells how the sage Kaśyapa, the eighth above the seven Sūryas, dwells constantly on Mount Meru, never leaving, while the other Suns illuminate different regions. Sages have gone as far as the regions around, but none reached the mountain itself. "},"thag18.1:12.1":{"pli":"Karerimālāvitatā, ","eng":"“Strewn with garlands of the musk-rose tree, ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:12.2":{"pli":"bhūmibhāgā manoramā; ","eng":"these regions are so delightful, so lovely, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:12.3":{"pli":"Kuñjarābhirudā rammā, ","eng":"echoing with the trumpeting of elephants: ","html":"<span class='verse-line'>{}</span>"},"thag18.1:12.4":{"pli":"te selā ramayanti maṁ. ","eng":"these rocky crags delight me! ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:13.1":{"pli":"Nīlabbhavaṇṇā rucirā, ","eng":"Glistening, they look like blue stormclouds, ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:13.2":{"pli":"vārisītā sucindharā; ","eng":"with waters cool and streams so clear, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:13.3":{"pli":"Indagopakasañchannā, ","eng":"and covered all in ladybugs: ","html":"<span class='verse-line'>{}</span>"},"thag18.1:13.4":{"pli":"te selā ramayanti maṁ. ","eng":"these rocky crags delight me! ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:14.1":{"pli":"Nīlabbhakūṭasadisā, ","eng":"Like the peak of a blue stormcloud, ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:14.2":{"pli":"kūṭāgāravarūpamā; ","eng":"or like a fine bungalow, lovely, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:14.3":{"pli":"Vāraṇābhirudā rammā, ","eng":"echoing with the trumpeting of elephants: ","html":"<span class='verse-line'>{}</span>"},"thag18.1:14.4":{"pli":"te selā ramayanti maṁ. ","eng":"these rocky crags delight me! ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:15.1":{"pli":"Abhivuṭṭhā rammatalā, ","eng":"The rain comes down on the lovely flats, ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:15.2":{"pli":"nagā isibhi sevitā; ","eng":"in the mountains frequented by seers. ","html":"<span class='verse-line'>{}</span>"},"thag18.1:15.3":{"pli":"Abbhunnaditā sikhīhi, ","eng":"Echoing with the cries of peacocks, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:15.4":{"pli":"te selā ramayanti maṁ. ","eng":"these rocky crags delight me! ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:16.1":{"pli":"Alaṁ jhāyitukāmassa, ","eng":"It’s enough for me, who loves absorption, ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:16.2":{"pli":"pahitattassa me sato; ","eng":"to remain resolute. ","html":"<span class='verse-line'>{}</span>"},"thag18.1:16.3":{"pli":"Alaṁ me atthakāmassa, ","eng":"It’s enough for me, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:16.4":{"pli":"pahitattassa bhikkhuno. ","eng":"a resolute monk who wants what’s best. ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:17.1":{"pli":"Alaṁ me phāsukāmassa, ","eng":"It’s enough for me, ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:17.2":{"pli":"pahitattassa bhikkhuno; ","eng":"a resolute monk who loves comfort. ","html":"<span class='verse-line'>{}</span>"},"thag18.1:17.3":{"pli":"Alaṁ me yogakāmassa, ","eng":"It’s enough for me, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:17.4":{"pli":"pahitattassa tādino. ","eng":"resolute and unaffected, loving meditation. ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:18.1":{"pli":"Umāpupphena samānā, ","eng":"Covered with flowers of flax, ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:18.2":{"pli":"gaganāvabbhachāditā; ","eng":"like the welkin covered with stormclouds, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:18.3":{"pli":"Nānādijagaṇākiṇṇā, ","eng":"full of flocks of many different birds, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:18.4":{"pli":"te selā ramayanti maṁ. ","eng":"these rocky crags delight me! ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:19.1":{"pli":"Anākiṇṇā gahaṭṭhehi, ","eng":"Empty of householders, ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:19.2":{"pli":"migasaṅghanisevitā; ","eng":"frequented by herds of deer, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:19.3":{"pli":"Nānādijagaṇākiṇṇā, ","eng":"full of flocks of many different birds, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:19.4":{"pli":"te selā ramayanti maṁ. ","eng":"these rocky crags delight me! ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:20.1":{"pli":"Acchodikā puthusilā, ","eng":"The water’s clear and the rocks are broad, ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:20.2":{"pli":"gonaṅgulamigāyutā; ","eng":"monkeys and deer are all around; ","html":"<span class='verse-line'>{}</span>"},"thag18.1:20.3":{"pli":"Ambusevālasañchannā, ","eng":"festooned with dewy moss, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:20.4":{"pli":"te selā ramayanti maṁ. ","eng":"these rocky crags delight me!” ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:21.1":{"pli":"Na pañcaṅgikena turiyena, ","eng":"“Even the music of a five-piece band ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:21.2":{"pli":"Rati me hoti tādisī; ","eng":"can never give such pleasure ","html":"<span class='verse-line'>{}</span>"},"thag18.1:21.3":{"pli":"Yathā ekaggacittassa, ","eng":"as when, with unified mind, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:21.4":{"pli":"Sammā dhammaṁ vipassato. ","eng":"you rightly discern the Dhamma.” ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:22.1":{"pli":"Kammaṁ bahukaṁ na kāraye, ","eng":"“Don’t get involved in lots of work, ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:22.2":{"pli":"Parivajjeyya janaṁ na uyyame; ","eng":"avoid people, and don’t try to acquire things. ","html":"<span class='verse-line'>{}</span>"},"thag18.1:22.3":{"pli":"Ussukko so rasānugiddho, ","eng":"If you’re eager and greedy for flavors, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:22.4":{"pli":"Atthaṁ riñcati yo sukhāvaho. ","eng":"you’ll miss the goal that brings such happiness. ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:23.1":{"pli":"Kammaṁ bahukaṁ na kāraye, ","eng":"Don’t get involved in lots of work, ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:23.2":{"pli":"Parivajjeyya anattaneyyametaṁ; ","eng":"avoid what doesn’t lead to the goal. ","html":"<span class='verse-line'>{}</span>"},"thag18.1:23.3":{"pli":"Kicchati kāyo kilamati, ","eng":"The body gets worn out and fatigued, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:23.4":{"pli":"Dukkhito so samathaṁ na vindati. ","eng":"and when you ache, you won’t find serenity.” ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:24.1":{"pli":"Oṭṭhappahatamattena, ","eng":"“You won’t see yourself ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:24.2":{"pli":"attānampi na passati; ","eng":"by merely reciting words, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:24.3":{"pli":"Patthaddhagīvo carati, ","eng":"wandering stiff-necked ","html":"<span class='verse-line'>{}</span>"},"thag18.1:24.4":{"pli":"ahaṁ seyyoti maññati. ","eng":"and thinking, ‘I’m better than them.’ ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:25.1":{"pli":"Aseyyo seyyasamānaṁ, ","eng":"The fool is no better, ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:25.2":{"pli":"bālo maññati attānaṁ; ","eng":"but they think they are. ","html":"<span class='verse-line'>{}</span>"},"thag18.1:25.3":{"pli":"Na taṁ viññū pasaṁsanti, ","eng":"The wise don’t praise ","html":"<span class='verse-line'>{}</span>"},"thag18.1:25.4":{"pli":"patthaddhamānasaṁ naraṁ. ","eng":"pompous people. ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:26.1":{"pli":"Yo ca seyyohamasmīti, ","eng":"Whoever does not waver ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:26.2":{"pli":"nāhaṁ seyyoti vā pana; ","eng":"due to the discriminations—","html":"<span class='verse-line'>{}</span>"},"thag18.1:26.3":{"pli":"Hīno taṁsadiso vāti, ","eng":"‘I am better’, ‘I’m not better’, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:26.4":{"pli":"vidhāsu na vikampati. ","eng":"‘I am worse’, or ‘I am the same’—","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:27.1":{"pli":"Paññavantaṁ tathā tādiṁ, ","eng":"with such understanding, unaffected, ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:27.2":{"pli":"sīlesu susamāhitaṁ; ","eng":"steady in ethics, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:27.3":{"pli":"Cetosamathamanuttaṁ, ","eng":"and devoted to serenity of mind: ","html":"<span class='verse-line'>{}</span>"},"thag18.1:27.4":{"pli":"tañce viññū pasaṁsare. ","eng":"that is who the wise praise.” ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:28.1":{"pli":"Yassa sabrahmacārīsu, ","eng":"“Whoever has no respect ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:28.2":{"pli":"gāravo nūpalabbhati; ","eng":"for their spiritual companions ","html":"<span class='verse-line'>{}</span>"},"thag18.1:28.3":{"pli":"Ārakā hoti saddhammā, ","eng":"is as far from the true teaching ","html":"<span class='verse-line'>{}</span>"},"thag18.1:28.4":{"pli":"nabhato puthavī yathā. ","eng":"as the earth is from the sky. ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:29.1":{"pli":"Yesañca hiriottappaṁ, ","eng":"Those whose conscience and prudence ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:29.2":{"pli":"sadā sammā upaṭṭhitaṁ; ","eng":"are always rightly established, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:29.3":{"pli":"Virūḷhabrahmacariyā te, ","eng":"thrive in the spiritual life; ","html":"<span class='verse-line'>{}</span>"},"thag18.1:29.4":{"pli":"tesaṁ khīṇā punabbhavā. ","eng":"for them, there are no future lives. ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:30.1":{"pli":"Uddhato capalo bhikkhu, ","eng":"When a mendicant who is haughty and fickle ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:30.2":{"pli":"paṁsukūlena pāruto; ","eng":"wears rags from the rubbish-heap, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:30.3":{"pli":"Kapīva sīhacammena, ","eng":"that doesn’t make them shine: ","html":"<span class='verse-line'>{}</span>"},"thag18.1:30.4":{"pli":"na so tenupasobhati. ","eng":"they’re like a monkey in a lion skin. ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:31.1":{"pli":"Anuddhato acapalo, ","eng":"But if they not restless or fickle, ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:31.2":{"pli":"nipako saṁvutindriyo; ","eng":"alert, with senses restrained, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:31.3":{"pli":"Sobhati paṁsukūlena, ","eng":"then, wearing rags from the rubbish-heap, they shine ","html":"<span class='verse-line'>{}</span>"},"thag18.1:31.4":{"pli":"sīhova girigabbhare. ","eng":"like a lion in a mountain cave.” ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:32.1":{"pli":"Ete sambahulā devā, ","eng":"“These many gods ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:32.2":{"pli":"iddhimanto yasassino; ","eng":"powerful and glorious, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:32.3":{"pli":"Dasadevasahassāni, ","eng":"all 10,000 of them, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:32.4":{"pli":"sabbe te brahmakāyikā. ","eng":"belong to the host of the Divinity. ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:33.1":{"pli":"Dhammasenāpatiṁ vīraṁ, ","eng":"They stand with joined palms ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:33.2":{"pli":"mahājhāyiṁ samāhitaṁ; ","eng":"honoring Sāriputta, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:33.3":{"pli":"Sāriputtaṁ namassantā, ","eng":"the general of the Dhamma, the hero, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:33.4":{"pli":"tiṭṭhanti pañjalīkatā. ","eng":"the serene great meditator: ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:34.1":{"pli":"‘Namo te purisājañña, ","eng":"‘Homage to you, O thoroughbred! ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:34.2":{"pli":"namo te purisuttama; ","eng":"Homage to you, supreme among men! ","html":"<span class='verse-line'>{}</span>"},"thag18.1:34.3":{"pli":"Yassa te nābhijānāma, ","eng":"We don’t understand ","html":"<span class='verse-line'>{}</span>"},"thag18.1:34.4":{"pli":"yampi nissāya jhāyati. ","eng":"the basis of your absorption. ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:35.1":{"pli":"Accheraṁ vata buddhānaṁ, ","eng":"The profound domain of the Buddhas ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:35.2":{"pli":"gambhīro gocaro sako; ","eng":"is truly amazing. ","html":"<span class='verse-line'>{}</span>"},"thag18.1:35.3":{"pli":"Ye mayaṁ nābhijānāma, ","eng":"We don’t understand, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:35.4":{"pli":"vālavedhisamāgatā’. ","eng":"though we’ve gathered here to split hairs.’ ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:36.1":{"pli":"Taṁ tathā devakāyehi, ","eng":"When he saw the host of gods ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:36.2":{"pli":"pūjitaṁ pūjanārahaṁ; ","eng":"paying homage to Sāriputta—","html":"<span class='verse-line'>{}</span>"},"thag18.1:36.3":{"pli":"Sāriputtaṁ tadā disvā, ","eng":"who is truly worthy of homage—","html":"<span class='verse-line'>{}</span>"},"thag18.1:36.4":{"pli":"kappinassa sitaṁ ahu. ","eng":"Kappina smiled.” ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:37.1":{"pli":"Yāvatā buddhakhettamhi, ","eng":"“As far as the range of the Buddha extends, ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:37.2":{"pli":"ṭhapayitvā mahāmuniṁ; ","eng":"I am distinguished in austerities. ","html":"<span class='verse-line'>{}</span>"},"thag18.1:37.3":{"pli":"Dhutaguṇe visiṭṭhohaṁ, ","eng":"I have no equal, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:37.4":{"pli":"sadiso me na vijjati. ","eng":"apart from the great sage himself. ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:38.1":{"pli":"Pariciṇṇo mayā satthā, ","eng":"I’ve served the teacher ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:38.2":{"pli":"kataṁ buddhassa sāsanaṁ; ","eng":"and fulfilled the Buddha’s instructions. ","html":"<span class='verse-line'>{}</span>"},"thag18.1:38.3":{"pli":"Ohito garuko bhāro, ","eng":"The heavy burden is laid down, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:38.4":{"pli":"natthi dāni punabbhavo. ","eng":"now there’ll be no more future lives.” ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:39.1":{"pli":"Na cīvare na sayane, ","eng":"“Like a lotus flower ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:39.2":{"pli":"bhojane nupalimpati; ","eng":"to which water will not stick, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:39.3":{"pli":"Gotamo anappameyyo, ","eng":"Gotama the immeasurable is unstained ","html":"<span class='verse-line'>{}</span>"},"thag18.1:39.4":{"pli":"muḷālapupphaṁ vimalaṁva; ","eng":"by robes, lodgings, or food. ","html":"<span class='verse-line'>{}</span>"},"thag18.1:39.5":{"pli":"Ambunā nekkhammaninno, ","eng":"He inclines to renunciation, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:39.6":{"pli":"tibhavābhinissaṭo. ","eng":"and has escaped the three states of existence. ","html":"<span class='verse-line'>{}</span></p>"},"thag18.1:40.1":{"pli":"Satipaṭṭhānagīvo so, ","eng":"The great sage’s neck is mindfulness meditation; ","html":"<p><span class='verse-line'>{}</span>"},"thag18.1:40.2":{"pli":"saddhāhattho mahāmuni; ","eng":"faith is his hands, and wisdom his head. ","html":"<span class='verse-line'>{}</span>"},"thag18.1:40.3":{"pli":"Paññāsīso mahāñāṇī, ","eng":"Having great knowledge, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:40.4":{"pli":"sadā carati nibbuto”ti. ","eng":"he always wanders, quenched.” ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"thag18.1:40.5":{"pli":"… Mahākassapo thero … ","html":"<p class='endsutta'>{}</p>"},"thag18.1:40.6":{"pli":"Cattālīsanipāto niṭṭhito. ","eng":"The Book of the Forties is finished. ","html":"<p class='endbook'>{}</p>"},"thag18.1:41.0":{"pli":"Tatruddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"thag18.1:41.1":{"pli":"Cattālīsanipātamhi, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"thag18.1:41.2":{"pli":"mahākassapasavhayo; ","html":"<span class='verse-line'>{}</span>"},"thag18.1:41.3":{"pli":"Ekova thero gāthāyo, ","html":"<span class='verse-line'>{}</span>"},"thag18.1:41.4":{"pli":"cattālīsa duvepi cāti. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}}}