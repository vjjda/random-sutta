{"kv15.10":{"kv15.10:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv15.10'><header><ul><li class='division'>{}</li>"},"kv15.10:0.2":{"pli":"Mahāpaṇṇāsaka ","html":"<li>{}</li>"},"kv15.10:0.3":{"pli":"Pannarasamavagga ","html":"<li>{}</li></ul>"},"kv15.10:0.4":{"pli":"Asaññasattupikakathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv15.10:1.1":{"pli":"Saññāvedayitanirodhasamāpatti asaññasattupikāti? ","html":"<p data-doxy='orthodox'>{}"},"kv15.10:1.2":{"pli":"Āmantā. ","html":"{}"},"kv15.10:1.3":{"pli":"Atthi saññāvedayitanirodhaṁ samāpannassa alobho kusalamūlaṁ, adoso kusalamūlaṁ, amoho kusalamūlaṁ, saddhā vīriyaṁ sati samādhi paññāti? ","html":"{}"},"kv15.10:1.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv15.10:1.5":{"pli":"natthi saññāvedayitanirodhaṁ samāpannassa alobho kusalamūlaṁ, adoso kusalamūlaṁ …pe… paññāti? ","html":"{}"},"kv15.10:1.6":{"pli":"Āmantā. ","html":"{}"},"kv15.10:1.7":{"pli":"Hañci natthi saññāvedayitanirodhaṁ samāpannassa alobho kusalamūlaṁ, adoso kusalamūlaṁ, amoho kusalamūlaṁ, saddhā vīriyaṁ sati samādhi paññā, no ca vata re vattabbe—","html":"{}"},"kv15.10:1.8":{"pli":"“saññāvedayitanirodhasamāpatti asaññasattupikā”ti. ","html":"{}</p>"},"kv15.10:2.1":{"pli":"Saññāvedayitanirodhasamāpatti asaññasattupikāti? ","html":"<p data-doxy='orthodox'>{}"},"kv15.10:2.2":{"pli":"Āmantā. ","html":"{}"},"kv15.10:2.3":{"pli":"Atthi saññāvedayitanirodhaṁ samāpannassa phasso vedanā saññā cetanā cittanti? ","html":"{}"},"kv15.10:2.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv15.10:2.5":{"pli":"natthi saññāvedayitanirodhaṁ samāpannassa phasso vedanā saññā cetanā cittanti? ","html":"{}"},"kv15.10:2.6":{"pli":"Āmantā. ","html":"{}"},"kv15.10:2.7":{"pli":"Aphassakassa maggabhāvanā …pe… acittakassa maggabhāvanāti? ","html":"{}"},"kv15.10:2.8":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv15.10:2.9":{"pli":"nanu saphassakassa maggabhāvanā …pe… sacittakassa maggabhāvanāti? ","html":"{}"},"kv15.10:2.10":{"pli":"Āmantā. ","html":"{}"},"kv15.10:2.11":{"pli":"Hañci saphassakassa maggabhāvanā …pe… ","html":"{}"},"kv15.10:2.12":{"pli":"sacittakassa maggabhāvanā, no ca vata re vattabbe—","html":"{}"},"kv15.10:2.13":{"pli":"“saññāvedayitanirodhasamāpatti asaññasattupikā”ti. ","html":"{}</p>"},"kv15.10:3.1":{"pli":"Saññāvedayitanirodhasamāpatti asaññasattupikāti? ","html":"<p data-doxy='orthodox'>{}"},"kv15.10:3.2":{"pli":"Āmantā. ","html":"{}"},"kv15.10:3.3":{"pli":"Ye keci saññāvedayitanirodhaṁ samāpajjanti, sabbe te asaññasattupikāti? ","html":"{}"},"kv15.10:3.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv15.10:4.1":{"pli":"Na vattabbaṁ—","html":"<p data-doxy='heterodox'>{}"},"kv15.10:4.2":{"pli":"“saññāvedayitanirodhasamāpatti asaññasattupikā”ti? ","html":"{}"},"kv15.10:4.3":{"pli":"Āmantā. ","html":"{}"},"kv15.10:4.4":{"pli":"Nanu idhāpi asaññī tatrāpi asaññīti? ","html":"{}"},"kv15.10:4.5":{"pli":"Āmantā. ","html":"{}"},"kv15.10:4.6":{"pli":"Hañci idhāpi asaññī tatrāpi asaññī, tena vata re vattabbe—","html":"{}"},"kv15.10:4.7":{"pli":"“saññāvedayitanirodhasamāpatti asaññasattupikā”ti. ","html":"{}</p>"},"kv15.10:4.8":{"pli":"Asaññasattupikakathā niṭṭhitā. ","html":"<p class='endsutta'>{}</p></article>"}},"kv15.11":{"kv15.11:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv15.11'><header><ul><li class='division'>{}</li>"},"kv15.11:0.2":{"pli":"Mahāpaṇṇāsaka ","html":"<li>{}</li>"},"kv15.11:0.3":{"pli":"Pannarasamavagga ","html":"<li>{}</li></ul>"},"kv15.11:0.4":{"pli":"Kammūpacayakathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv15.11:1.1":{"pli":"Aññaṁ kammaṁ añño kammūpacayoti? ","html":"<p data-doxy='orthodox'>{}"},"kv15.11:1.2":{"pli":"Āmantā. ","html":"{}"},"kv15.11:1.3":{"pli":"Añño phasso, añño phassūpacayo; ","html":"{}"},"kv15.11:1.4":{"pli":"aññā vedanā, añño vedanūpacayo; ","html":"{}"},"kv15.11:1.5":{"pli":"aññā saññā, añño saññūpacayo; ","html":"{}"},"kv15.11:1.6":{"pli":"aññā cetanā, añño cetanūpacayo; ","html":"{}"},"kv15.11:1.7":{"pli":"aññaṁ cittaṁ, añño cittūpacayo; ","html":"{}"},"kv15.11:1.8":{"pli":"aññā saddhā, añño saddhūpacayo; ","html":"{}"},"kv15.11:1.9":{"pli":"aññaṁ vīriyaṁ, añño vīriyūpacayo; ","html":"{}"},"kv15.11:1.10":{"pli":"aññā sati, añño satūpacayo; ","html":"{}"},"kv15.11:1.11":{"pli":"añño samādhi, añño samādhūpacayo; ","html":"{}"},"kv15.11:1.12":{"pli":"aññā paññā, añño paññūpacayo; ","html":"{}"},"kv15.11:1.13":{"pli":"añño rāgo, añño rāgūpacayo …pe… ","html":"{}"},"kv15.11:1.14":{"pli":"aññaṁ anottappaṁ, añño anottappūpacayoti? ","html":"{}"},"kv15.11:1.15":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv15.11:2.1":{"pli":"Aññaṁ kammaṁ, añño kammūpacayoti? ","html":"<p data-doxy='orthodox'>{}"},"kv15.11:2.2":{"pli":"Āmantā. ","html":"{}"},"kv15.11:2.3":{"pli":"Kammūpacayo kammena sahajātoti? ","html":"{}"},"kv15.11:2.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv15.11:3.1":{"pli":"Kammūpacayo kammena sahajātoti? ","html":"<p data-doxy='orthodox'>{}"},"kv15.11:3.2":{"pli":"Āmantā. ","html":"{}"},"kv15.11:3.3":{"pli":"Kusalena kammena sahajāto kammūpacayo kusaloti, na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv15.11:4.1":{"pli":"Kusalena kammena sahajāto kammūpacayo kusaloti? ","html":"<p data-doxy='orthodox'>{}"},"kv15.11:4.2":{"pli":"Āmantā. ","html":"{}"},"kv15.11:4.3":{"pli":"Sukhāya vedanāya sampayuttena kammena sahajāto kammūpacayo sukhāya vedanāya sampayuttoti? ","html":"{}"},"kv15.11:4.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv15.11:4.5":{"pli":"dukkhāya vedanāya …pe… ","html":"{}"},"kv15.11:4.6":{"pli":"adukkhamasukhāya vedanāya sampayuttena kammena sahajāto kammūpacayo adukkhamasukhāya vedanāya sampayuttoti? ","html":"{}"},"kv15.11:4.7":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv15.11:5.1":{"pli":"Kammūpacayo kammena sahajātoti? ","html":"<p data-doxy='orthodox'>{}"},"kv15.11:5.2":{"pli":"Āmantā. ","html":"{}"},"kv15.11:5.3":{"pli":"Akusalena kammena sahajāto kammūpacayo akusaloti? ","html":"{}"},"kv15.11:5.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}</p>"},"kv15.11:6.1":{"pli":"Akusalena kammena sahajāto kammūpacayo akusaloti? ","html":"<p data-doxy='orthodox'>{}"},"kv15.11:6.2":{"pli":"Āmantā. ","html":"{}"},"kv15.11:6.3":{"pli":"Sukhāya vedanāya sampayuttena kammena sahajāto kammūpacayo sukhāya vedanāya sampayuttoti? ","html":"{}"},"kv15.11:6.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv15.11:6.5":{"pli":"dukkhāya vedanāya …pe… ","html":"{}"},"kv15.11:6.6":{"pli":"adukkhamasukhāya vedanāya sampayuttena kammena sahajāto kammūpacayo adukkhamasukhāya vedanāya sampayuttoti? ","html":"{}"},"kv15.11:6.7":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv15.11:7.1":{"pli":"Kammaṁ cittena sahajātaṁ, kammaṁ sārammaṇanti? ","html":"<p data-doxy='orthodox'>{}"},"kv15.11:7.2":{"pli":"Āmantā. ","html":"{}"},"kv15.11:7.3":{"pli":"Kammūpacayo cittena sahajāto, kammūpacayo sārammaṇoti? ","html":"{}"},"kv15.11:7.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv15.11:7.5":{"pli":"kammūpacayo cittena sahajāto, kammūpacayo anārammaṇoti? ","html":"{}"},"kv15.11:7.6":{"pli":"Āmantā. ","html":"{}"},"kv15.11:7.7":{"pli":"Kammaṁ cittena sahajātaṁ, kammaṁ anārammaṇanti? ","html":"{}"},"kv15.11:7.8":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv15.11:8.1":{"pli":"Kammaṁ cittena sahajātaṁ, cittaṁ bhijjamānaṁ kammaṁ bhijjatīti? ","html":"<p data-doxy='orthodox'>{}"},"kv15.11:8.2":{"pli":"Āmantā. ","html":"{}"},"kv15.11:8.3":{"pli":"Kammūpacayo cittena sahajāto, cittaṁ bhijjamānaṁ kammūpacayo bhijjatīti? ","html":"{}"},"kv15.11:8.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv15.11:9.1":{"pli":"Kammūpacayo cittena sahajāto, cittaṁ bhijjamānaṁ kammūpacayo na bhijjatīti? ","html":"<p data-doxy='orthodox'>{}"},"kv15.11:9.2":{"pli":"Āmantā. ","html":"{}"},"kv15.11:9.3":{"pli":"Kammaṁ cittena sahajātaṁ, cittaṁ bhijjamānaṁ kammaṁ na bhijjatīti? ","html":"{}"},"kv15.11:9.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv15.11:10.1":{"pli":"Kammamhi kammūpacayoti? ","html":"<p data-doxy='orthodox'>{}"},"kv15.11:10.2":{"pli":"Āmantā. ","html":"{}"},"kv15.11:10.3":{"pli":"Taññeva kammaṁ so kammūpacayoti? ","html":"{}"},"kv15.11:10.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv15.11:11.1":{"pli":"Kammamhi kammūpacayo, kammūpacayato vipāko nibbattatīti? ","html":"<p data-doxy='orthodox'>{}"},"kv15.11:11.2":{"pli":"Āmantā. ","html":"{}"},"kv15.11:11.3":{"pli":"Taññeva kammaṁ, so kammūpacayo, so kammavipākoti? ","html":"{}"},"kv15.11:11.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv15.11:12.1":{"pli":"Kammamhi kammūpacayo, kammūpacayato vipāko nibbattati, vipāko sārammaṇoti? ","html":"<p data-doxy='orthodox'>{}"},"kv15.11:12.2":{"pli":"Āmantā. ","html":"{}"},"kv15.11:12.3":{"pli":"Kammūpacayo sārammaṇoti? ","html":"{}"},"kv15.11:12.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv15.11:12.5":{"pli":"kammūpacayo anārammaṇoti? ","html":"{}"},"kv15.11:12.6":{"pli":"Āmantā. ","html":"{}"},"kv15.11:12.7":{"pli":"Vipāko anārammaṇoti? ","html":"{}"},"kv15.11:12.8":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv15.11:13.1":{"pli":"Aññaṁ kammaṁ añño kammūpacayoti? ","html":"<p data-doxy='orthodox'>{}"},"kv15.11:13.2":{"pli":"Āmantā. ","html":"{}"},"kv15.11:13.3":{"pli":"Nanu vuttaṁ bhagavatā—","html":"{}"},"kv15.11:13.4":{"pli":"“idha, puṇṇa, ekacco sabyābajjhampi abyābajjhampi kāyasaṅkhāraṁ abhisaṅkharoti, sabyābajjhampi abyābajjhampi vacīsaṅkhāraṁ …pe… ","html":"{}"},"kv15.11:13.5":{"pli":"manosaṅkhāraṁ abhisaṅkharoti, so sabyābajjhampi abyābajjhampi kāyasaṅkhāraṁ abhisaṅkharitvā, sabyābajjhampi abyābajjhampi vacīsaṅkhāraṁ …pe… ","html":"{}"},"kv15.11:13.6":{"pli":"manosaṅkhāraṁ abhisaṅkharitvā sabyābajjhampi abyābajjhampi lokaṁ upapajjati. ","html":"{}"},"kv15.11:13.7":{"pli":"Tamenaṁ sabyābajjhampi abyābajjhampi lokaṁ upapannaṁ samānaṁ sabyābajjhāpi abyābajjhāpi phassā phusanti. ","html":"{}"},"kv15.11:13.8":{"pli":"So sabyābajjhehipi abyābajjhehipi phassehi phuṭṭho samāno sabyābajjhampi abyābajjhampi vedanaṁ vedeti vokiṇṇasukhadukkhaṁ, seyyathāpi manussā ekacce ca devā ekacce ca vinipātikā. ","html":"{}"},"kv15.11:13.9":{"pli":"Iti kho, puṇṇa, bhūtā bhūtassa upapatti hoti, yaṁ karoti tena upapajjati, upapannametaṁ phassā phusanti. ","html":"{}"},"kv15.11:13.10":{"pli":"Evampāhaṁ, puṇṇa, ‘kammadāyādā sattā’ti vadāmī”ti. ","html":"{}"},"kv15.11:13.11":{"pli":"Attheva suttantoti? ","html":"{}"},"kv15.11:13.12":{"pli":"Āmantā. ","html":"{}"},"kv15.11:13.13":{"pli":"Tena hi na vattabbaṁ—","html":"{}"},"kv15.11:13.14":{"pli":"“aññaṁ kammaṁ, añño kammūpacayo”ti. ","html":"{}</p>"},"kv15.11:13.15":{"pli":"Kammūpacayakathā niṭṭhitā. ","html":"<p class='endsutta'>{}<br>"},"kv15.11:13.16":{"pli":"Pannarasamo vaggo. ","html":"{}</p>"},"kv15.11:13.17":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"kv15.11:14.1":{"pli":"Paccayatā vavatthitā, ","html":"<p class='uddana'>{}"},"kv15.11:14.2":{"pli":"paṭiccasamuppādo, ","html":"{}"},"kv15.11:14.3":{"pli":"addhā, ","html":"{}"},"kv15.11:14.4":{"pli":"khaṇo layo muhuttaṁ, ","html":"{}"},"kv15.11:14.5":{"pli":"cattāro āsavā anāsavā, ","html":"{}"},"kv15.11:14.6":{"pli":"lokuttarānaṁ dhammānaṁ jarāmaraṇaṁ lokuttarā, ","html":"{}"},"kv15.11:14.7":{"pli":"saññāvedayitanirodhasamāpatti lokuttarā, ","html":"{}"},"kv15.11:14.8":{"pli":"saññāvedayitanirodhasamāpatti lokiyā, ","html":"{}"},"kv15.11:14.9":{"pli":"saññāvedayitanirodhaṁ samāpanno kālaṁ kareyya, ","html":"{}"},"kv15.11:14.10":{"pli":"sveva maggo asaññasattupapattiyā, ","html":"{}"},"kv15.11:14.11":{"pli":"aññaṁ kammaṁ añño kammūpacayoti. ","html":"{}</p>"},"kv15.11:14.12":{"pli":"Tatiyo paṇṇāsako. ","html":"<p class='endsutta'>{}</p>"},"kv15.11:14.13":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"kv15.11:15.1":{"pli":"Anusayā, ","html":"<p class='uddana'>{}"},"kv15.11:15.2":{"pli":"saṁvaro, ","html":"{}"},"kv15.11:15.3":{"pli":"kappo, ","html":"{}"},"kv15.11:15.4":{"pli":"mūlañca vavatthitāti. ","html":"{}</p></article>"}},"kv15.2":{"kv15.2:0.1":{"pli":"Kathāvatthu ","html":"<article id