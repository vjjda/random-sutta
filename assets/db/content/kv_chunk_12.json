li":"Āmantā. ","html":"{}"},"kv15.2:4.4":{"pli":"Tena hi avijjāpaccayāpi saṅkhārā, saṅkhārapaccayāpi avijjā; ","html":"{}"},"kv15.2:4.5":{"pli":"taṇhāpaccayāpi upādānaṁ, upādānapaccayāpi taṇhāti. ","html":"{}</p>"},"kv15.2:4.6":{"pli":"Aññamaññapaccayakathā niṭṭhitā. ","html":"<p class='endsutta'>{}</p></article>"}},"kv15.3":{"kv15.3:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv15.3'><header><ul><li class='division'>{}</li>"},"kv15.3:0.2":{"pli":"Mahāpaṇṇāsaka ","html":"<li>{}</li>"},"kv15.3:0.3":{"pli":"Pannarasamavagga ","html":"<li>{}</li></ul>"},"kv15.3:0.4":{"pli":"Addhākathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv15.3:1.1":{"pli":"Addhā parinipphannoti? ","html":"<p data-doxy='orthodox'>{}"},"kv15.3:1.2":{"pli":"Āmantā. ","html":"{}"},"kv15.3:1.3":{"pli":"Rūpanti? ","html":"{}"},"kv15.3:1.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv15.3:1.5":{"pli":"vedanā …pe… ","html":"{}"},"kv15.3:1.6":{"pli":"saññā …pe… ","html":"{}"},"kv15.3:1.7":{"pli":"saṅkhārā …pe… ","html":"{}"},"kv15.3:1.8":{"pli":"viññāṇanti? ","html":"{}"},"kv15.3:1.9":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv15.3:1.10":{"pli":"atīto addhā parinipphannoti? ","html":"{}"},"kv15.3:1.11":{"pli":"Āmantā. ","html":"{}"},"kv15.3:1.12":{"pli":"Rūpanti? ","html":"{}"},"kv15.3:1.13":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv15.3:1.14":{"pli":"vedanā …pe… ","html":"{}"},"kv15.3:1.15":{"pli":"saññā …pe… ","html":"{}"},"kv15.3:1.16":{"pli":"saṅkhārā …pe… ","html":"{}"},"kv15.3:1.17":{"pli":"viññāṇanti? ","html":"{}"},"kv15.3:1.18":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv15.3:1.19":{"pli":"anāgato addhā parinipphannoti? ","html":"{}"},"kv15.3:1.20":{"pli":"Āmantā. ","html":"{}"},"kv15.3:1.21":{"pli":"Rūpanti? ","html":"{}"},"kv15.3:1.22":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv15.3:1.23":{"pli":"vedanā …pe… ","html":"{}"},"kv15.3:1.24":{"pli":"saññā …pe… ","html":"{}"},"kv15.3:1.25":{"pli":"saṅkhārā …pe… ","html":"{}"},"kv15.3:1.26":{"pli":"viññāṇan