{"pv39":{"pv39:0.1":{"pli":"Petavatthu ","html":"<article id='pv39'><header><ul><li class='division'>{}</li>"},"pv39:0.2":{"pli":"Mahāvagga ","html":"<li>{}</li></ul>"},"pv39:0.3":{"pli":"4. Revatīpetavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv39:1.1":{"pli":"“Uṭṭhehi revate supāpadhamme, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv39:1.2":{"pli":"Apārutadvāre adānasīle; ","html":"<span class='verse-line'>{}</span>"},"pv39:1.3":{"pli":"Nessāma taṁ yattha thunanti duggatā, ","html":"<span class='verse-line'>{}</span>"},"pv39:1.4":{"pli":"Samappitā nerayikā dukhenā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv39:2.1":{"pli":"Icceva vatvāna yamassa dūtā, ","html":"<p><span class='verse-line'>{}</span>"},"pv39:2.2":{"pli":"Te dve yakkhā lohitakkhā brahantā; ","html":"<span class='verse-line'>{}</span>"},"pv39:2.3":{"pli":"Paccekabāhāsu gahetvā revataṁ, ","html":"<span class='verse-line'>{}</span>"},"pv39:2.4":{"pli":"Pakkāmayuṁ devagaṇassa santike. ","html":"<span class='verse-line'>{}</span></p>"},"pv39:3.1":{"pli":"“Ādiccavaṇṇaṁ ruciraṁ pabhassaraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv39:3.2":{"pli":"Byamhaṁ subhaṁ kañcanajālachannaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv39:3.3":{"pli":"Kassetamākiṇṇajanaṁ vimānaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv39:3.4":{"pli":"Suriyassa raṁsīriva jotamānaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv39:4.1":{"pli":"Nārīgaṇā candanasāralittā, ","html":"<p><span class='verse-line'>{}</span>"},"pv39:4.2":{"pli":"Ubhato vimānaṁ upasobhayanti; ","html":"<span class='verse-line'>{}</span>"},"pv39:4.3":{"pli":"Taṁ dissati suriyasamānavaṇṇaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv39:4.4":{"pli":"Ko modati saggapatto vimāne”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv39:5.1":{"pli":"“Bārāṇasiyaṁ nandiyo nāmāsi, ","html":"<p><span class='verse-line'>{}</span>"},"pv39:5.2":{"pli":"Upāsako amaccharī dānapati vadaññū; ","html":"<span class='verse-line'>{}</span>"},"pv39:5.3":{"pli":"Tassetamākiṇṇajanaṁ vimānaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv39:5.4":{"pli":"Suriyassa raṁsīriva jotamānaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv39:6.1":{"pli":"Nārīgaṇā candanasāralittā, ","html":"<p><span class='verse-line'>{}</span>"},"pv39:6.2":{"pli":"Ubhato vimānaṁ upasobhayanti; ","html":"<span class='verse-line'>{}</span>"},"pv39:6.3":{"pli":"Taṁ dissati suriyasamānavaṇṇaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv39:6.4":{"pli":"So modati saggapatto vimāne”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv39:7.1":{"pli":"“Nandiyassāhaṁ bhariyā, ","html":"<p><span class='verse-line'>{}</span>"},"pv39:7.2":{"pli":"Agārinī sabbakulassa issarā; ","html":"<span class='verse-line'>{}</span>"},"pv39:7.3":{"pli":"Bhattu vimāne ramissāmi dānahaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv39:7.4":{"pli":"Na patthaye nirayadassanāyā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv39:8.1":{"pli":"“Eso te nirayo supāpadhamme, ","html":"<p><span class='verse-line'>{}</span>"},"pv39:8.2":{"pli":"Puññaṁ tayā akataṁ jīvaloke; ","html":"<span class='verse-line'>{}</span>"},"pv39:8.3":{"pli":"Na hi maccharī rosako pāpadhammo, ","html":"<span class='verse-line'>{}</span>"},"pv39:8.4":{"pli":"Saggūpagānaṁ labhati sahabyatan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv39:9.1":{"pli":"“Kiṁ nu gūthañca muttañca, ","html":"<p><span class='verse-line'>{}</span>"},"pv39:9.2":{"pli":"asucī paṭidissati; ","html":"<span class='verse-line'>{}</span>"},"pv39:9.3":{"pli":"Duggandhaṁ kimidaṁ mīḷhaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv39:9.4":{"pli":"kimetaṁ upavāyatī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv39:10.1":{"pli":"“Esa saṁsavako nāma, ","html":"<p><span class='verse-line'>{}</span>"},"pv39:10.2":{"pli":"gambhīro sataporiso; ","html":"<span class='verse-line'>{}</span>"},"pv39:10.3":{"pli":"Yattha vassasahassāni, ","html":"<span class='verse-line'>{}</span>"},"pv39:10.4":{"pli":"tuvaṁ paccasi revate”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv39:11.1":{"pli":"“Kiṁ nu kāyena vācāya, ","html":"<p><span class='verse-line'>{}</span>"},"pv39:11.2":{"pli":"manasā dukkaṭaṁ kataṁ; ","html":"<span class='verse-line'>{}</span>"},"pv39:11.3":{"pli":"Kena saṁsavako laddho, ","html":"<span class='verse-line'>{}</span>"},"pv39:11.4":{"pli":"gambhīro sataporiso”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv39:12.1":{"pli":"“Samaṇe brāhmaṇe cāpi, ","html":"<p><span class='verse-line'>{}</span>"},"pv39:12.2":{"pli":"aññe vāpi vanibbake; ","html":"<span class='verse-line'>{}</span>"},"pv39:12.3":{"pli":"Musāvādena vañcesi, ","html":"<span class='verse-line'>{}</span>"},"pv39:12.4":{"pli":"taṁ pāpaṁ pakataṁ tayā. ","html":"<span class='verse-line'>{}</span></p>"},"pv39:13.1":{"pli":"Tena saṁsavako laddho, ","html":"<p><span class='verse-line'>{}</span>"},"pv39:13.2":{"pli":"gambhīro sataporiso; ","html":"<span class='verse-line'>{}</span>"},"pv39:13.3":{"pli":"Tattha vassasahassāni, ","html":"<span class='verse-line'>{}</span>"},"pv39:13.4":{"pli":"tuvaṁ paccasi revate. ","html":"<span class='verse-line'>{}</span></p>"},"pv39:14.1":{"pli":"Hatthepi chindanti athopi pāde, ","html":"<p><span class='verse-line'>{}</span>"},"pv39:14.2":{"pli":"Kaṇṇepi chindanti athopi nāsaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv39:14.3":{"pli":"Athopi kākoḷagaṇā samecca, ","html":"<span class='verse-line'>{}</span>"},"pv39:14.4":{"pli":"Saṅgamma khādanti viphandamānan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv39:15.1":{"pli":"“Sādhu kho maṁ paṭinetha, ","html":"<p><span class='verse-line'>{}</span>"},"pv39:15.2":{"pli":"kāhāmi kusalaṁ bahuṁ; ","html":"<span class='verse-line'>{}</span>"},"pv39:15.3":{"pli":"Dānena samacariyāya, ","html":"<span class='verse-line'>{}</span>"},"pv39:15.4":{"pli":"saṁyamena damena ca; ","html":"<span class='verse-line'>{}</span>"},"pv39:15.5":{"pli":"Yaṁ katvā sukhitā honti, ","html":"<span class='verse-line'>{}</span>"},"pv39:15.6":{"pli":"na ca pacchānutappare”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv39:16.1":{"pli":"“Pure tuvaṁ pamajjitvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv39:16.2":{"pli":"idāni paridevasi; ","html":"<span class='verse-line'>{}</span>"},"pv39:16.3":{"pli":"Sayaṁ katānaṁ kammānaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv39:16.4":{"pli":"vipākaṁ anubhossasī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv39:17.1":{"pli":"“Ko devalokato manussalokaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv39:17.2":{"pli":"Gantvāna puṭṭho me evaṁ vadeyya; ","html":"<span class='verse-line'>{}</span>"},"pv39:17.3":{"pli":"‘Nikkhittadaṇḍesu dadātha dānaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv39:17.4":{"pli":"Acchādanaṁ seyya mathannapānaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv39:17.5":{"pli":"Na hi maccharī rosako pāpadhammo, ","html":"<span class='verse-line'>{}</span>"},"pv39:17.6":{"pli":"Saggūpagānaṁ labhati sahabyataṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"pv39:18.1":{"pli":"Sāhaṁ nūna ito gantvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv39:18.2":{"pli":"yoniṁ laddhāna mānusiṁ; ","html":"<span class='verse-line'>{}</span>"},"pv39:18.3":{"pli":"Vadaññū sīlasampannā, ","html":"<span class='verse-line'>{}</span>"},"pv39:18.4":{"pli":"kāhāmi kusalaṁ bahuṁ; ","html":"<span class='verse-line'>{}</span>"},"pv39:18.5":{"pli":"Dānena samacariyāya, ","html":"<span class='verse-line'>{}</span>"},"pv39:18.6":{"pli":"saṁyamena damena ca. ","html":"<span class='verse-line'>{}</span></p>"},"pv39:19.1":{"pli":"Ārāmāni ca ropissaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv39:19.2":{"pli":"dugge saṅkamanāni ca; ","html":"<span class='verse-line'>{}</span>"},"pv39:19.3":{"pli":"Papañca udapānañca, ","html":"<span class='verse-line'>{}</span>"},"pv39:19.4":{"pli":"vippasannena cetasā. ","html":"<span class='verse-line'>{}</span></p>"},"pv39:20.1":{"pli":"Cātuddasiṁ pañcadasiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv39:20.2":{"pli":"yā ca pakkhassa aṭṭhamī; ","html":"<span class='verse-line'>{}</span>"},"pv39:20.3":{"pli":"Pāṭihāriyapakkhañca, ","html":"<span class='verse-line'>{}</span>"},"pv39:20.4":{"pli":"aṭṭhaṅgasusamāgataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv39:21.1":{"pli":"Uposathaṁ upavasissaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv39:21.2":{"pli":"sadā sīlesu saṁvutā; ","html":"<span class='verse-line'>{}</span>"},"pv39:21.3":{"pli":"Na ca dāne pamajjissaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv39:21.4":{"pli":"sāmaṁ diṭṭhamidaṁ mayā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv39:22.1":{"pli":"Iccevaṁ vippalapantiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv39:22.2":{"pli":"phandamānaṁ tato tato; ","html":"<span class='verse-line'>{}</span>"},"pv39:22.3":{"pli":"Khipiṁsu niraye ghore, ","html":"<span class='verse-line'>{}</span>"},"pv39:22.4":{"pli":"uddhampādaṁ avaṁsiraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv39:23.1":{"pli":"“Ahaṁ pure maccharinī ahosiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv39:23.2":{"pli":"Paribhāsikā samaṇabrāhmaṇānaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv39:23.3":{"pli":"Vitathena ca sāmikaṁ vañcayitvā, ","html":"<span class='verse-line'>{}</span>"},"pv39:23.4":{"pli":"Paccāmahaṁ niraye ghorarūpe”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv39:24.1":{"pli":"Revatīpetavatthu catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"pv4":{"pv4:0.1":{"pli":"Petavatthu ","html":"<article id='pv4'><header><ul><li class='division'>{}</li>"},"pv4:0.2":{"pli":"Uragavagga ","html":"<li>{}</li></ul>"},"pv4:0.3":{"pli":"4. Piṭṭhadhītalikapetavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv4:1.1":{"pli":"“Yaṁ kiñcārammaṇaṁ katvā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv4:1.2":{"pli":"dajjā dānaṁ amaccharī; ","html":"<span class='verse-line'>{}</span>"},"pv4:1.3":{"pli":"Pubbapete ca ārabbha, ","html":"<span class='verse-line'>{}</span>"},"pv4:1.4":{"pli":"atha vā vatthudevatā. ","html":"<span class='verse-line'>{}</span></p>"},"pv4:2.1":{"pli":"Cattāro ca mahārāje, ","html":"<p><span class='verse-line'>{}</span>"},"pv4:2.2":{"pli":"lokapāle yasassine; ","html":"<span class='verse-line'>{}</span>"},"pv4:2.3":{"pli":"Kuveraṁ dhataraṭṭhañca, ","html":"<span class='verse-line'>{}</span>"},"pv4:2.4":{"pli":"virūpakkhaṁ virūḷhakaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv4:2.5":{"pli":"Te ceva pūjitā honti, ","html":"<span class='verse-line'>{}</span>"},"pv4:2.6":{"pli":"dāyakā ca anipphalā. ","html":"<span class='verse-line'>{}</span></p>"},"pv4:3.1":{"pli":"Na hi ruṇṇaṁ vā soko vā, ","html":"<p><span class='verse-line'>{}</span>"},"pv4:3.2":{"pli":"yā caññā paridevanā; ","html":"<span class='verse-line'>{}</span>"},"pv4:3.3":{"pli":"Na taṁ petassa atthāya, ","html":"<span class='verse-line'>{}</span>"},"pv4:3.4":{"pli":"evaṁ tiṭṭhanti ñātayo. ","html":"<span class='verse-line'>{}</span></p>"},"pv4:4.1":{"pli":"Ayañca kho dakkhiṇā dinnā, ","html":"<p><span class='verse-line'>{}</span>"},"pv4:4.2":{"pli":"saṅghamhi suppatiṭṭhitā; ","html":"<span class='verse-line'>{}</span>"},"pv4:4.3":{"pli":"Dīgharattaṁ hitāyassa, ","html":"<span class='verse-line'>{}</span>"},"pv4:4.4":{"pli":"ṭhānaso upakappatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv4:5.1":{"pli":"Piṭṭhadhītalikapetavatthu catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"pv40":{"pv40:0.1":{"pli":"Petavatthu ","html":"<article id='pv40'><header><ul><li class='division'>{}</li>"},"pv40:0.2":{"pli":"Mahāvagga ","html":"<li>{}</li></ul>"},"pv40:0.3":{"pli":"5. Ucchupetavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv40:1.1":{"pli":"“Idaṁ mama ucchuvanaṁ mahantaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv40:1.2":{"pli":"Nibbattati puññaphalaṁ anappakaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv40:1.3":{"pli":"Taṁ dāni me na paribhogameti, ","html":"<span class='verse-line'>{}</span>"},"pv40:1.4":{"pli":"Ācikkha bhante kissa ayaṁ vipāko. ","html":"<span class='verse-line'>{}</span></p>"},"pv40:2.1":{"pli":"Haññāmi khajjāmi ca vāyamāmi, ","html":"<p><span class='verse-line'>{}</span>"},"pv40:2.2":{"pli":"Parisakkāmi paribhuñjituṁ kiñci; ","html":"<span class='verse-line'>{}</span>"},"pv40:2.3":{"pli":"Svāhaṁ chinnathāmo kapaṇo lālapāmi, ","html":"<span class='verse-line'>{}</span>"},"pv40:2.4":{"pli":"Kissa kammassa ayaṁ vipāko. ","html":"<span class='verse-line'>{}</span></p>"},"pv40:3.1":{"pli":"Vighāto cāhaṁ paripatāmi chamāyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv40:3.2":{"pli":"Parivattāmi vāricarova ghamme; ","html":"<span class='verse-line'>{}</span>"},"pv40:3.3":{"pli":"Rudato ca me assukā niggalanti, ","html":"<span class='verse-line'>{}</span>"},"pv40:3.4":{"pli":"Ācikkha bhante kissa ayaṁ vipāko. ","html":"<span class='verse-line'>{}</span></p>"},"pv40:4.1":{"pli":"Chāto kilanto ca pipāsito ca, ","html":"<p><span class='verse-line'>{}</span>"},"pv40:4.2":{"pli":"Santassito sātasukhaṁ na vinde; ","html":"<span class='verse-line'>{}</span>"},"pv40:4.3":{"pli":"Pucchāmi taṁ etamatthaṁ bhadante, ","html":"<span class='verse-line'>{}</span>"},"pv40:4.4":{"pli":"Kathaṁ nu ucchuparibhogaṁ labheyyan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv40:5.1":{"pli":"“Pure tuvaṁ kammamakāsi attanā, ","html":"<p><span class='verse-line'>{}</span>"},"pv40:5.2":{"pli":"Manussabhūto purimāya jātiyā; ","html":"<span class='verse-line'>{}</span>"},"pv40:5.3":{"pli":"Ahañca taṁ etamatthaṁ vadāmi, ","html":"<span class='verse-line'>{}</span>"},"pv40:5.4":{"pli":"Sutvāna tvaṁ etamatthaṁ vijāna. ","html":"<span class='verse-line'>{}</span></p>"},"pv40:6.1":{"pli":"Ucchuṁ tuvaṁ khādamāno payāto, ","html":"<p><span class='verse-line'>{}</span>"},"pv40:6.2":{"pli":"Puriso ca te piṭṭhito anvagacchi; ","html":"<span class='verse-line'>{}</span>"},"pv40:6.3":{"pli":"So ca taṁ paccāsanto kathesi, ","html":"<span class='verse-line'>{}</span>"},"pv40:6.4":{"pli":"Tassa tuvaṁ na kiñci ālapittha. ","html":"<span class='verse-line'>{}</span></p>"},"pv40:7.1":{"pli":"So ca taṁ abhaṇantaṁ ayāci, ","html":"<p><span class='verse-line'>{}</span>"},"pv40:7.2":{"pli":"‘Dehayya ucchun’ti ca taṁ avoca; ","html":"<span class='verse-line'>{}</span>"},"pv40:7.3":{"pli":"Tassa tuvaṁ piṭṭhito ucchuṁ adāsi, ","html":"<span class='verse-line'>{}</span>"},"pv40:7.4":{"pli":"Tassetaṁ kammassa ayaṁ vipāko. ","html":"<span class='verse-line'>{}</span></p>"},"pv40:8.1":{"pli":"Iṅgha tvaṁ gantvāna piṭṭhito gaṇheyyāsi, ","html":"<p><span class='verse-line'>{}</span>"},"pv40:8.2":{"pli":"Gahetvāna taṁ khādassu yāvadatthaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv40:8.3":{"pli":"Teneva tvaṁ attamano bhavissasi, ","html":"<span class='verse-line'>{}</span>"},"pv40:8.4":{"pli":"Haṭṭho cudaggo ca pamodito cā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv40:9.1":{"pli":"Gantvāna so piṭṭhito aggahesi, ","html":"<p><span class='verse-line'>{}</span>"},"pv40:9.2":{"pli":"Gahetvāna taṁ khādi yāvadatthaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv40:9.3":{"pli":"Teneva so attamano ahosi, ","html":"<span class='verse-line'>{}</span>"},"pv40:9.4":{"pli":"Haṭṭho cudaggo ca pamodito cāti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv40:10.1":{"pli":"Ucchupetavatthu pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"pv41":{"pv41:0.1":{"pli":"Petavatthu ","html":"<article id='pv41'><header><ul><li class='division'>{}</li>"},"pv41:0.2":{"pli":"Mahāvagga ","html":"<li>{}</li></ul>"},"pv41:0.3":{"pli":"6. Kumārapetavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv41:1.1":{"pli":"“Sāvatthi nāma nagaraṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv41:1.2":{"pli":"himavantassa passato; ","html":"<span class='verse-line'>{}</span>"},"pv41:1.3":{"pli":"Tattha āsuṁ dve kumārā, ","html":"<span class='verse-line'>{}</span>"},"pv41:1.4":{"pli":"rājaputtāti me sutaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv41:2.1":{"pli":"Sammattā rajanīyesu, ","html":"<p><span class='verse-line'>{}</span>"},"pv41:2.2":{"pli":"kāmassādābhinandino; ","html":"<span class='verse-line'>{}</span>"},"pv41:2.3":{"pli":"Paccuppannasukhe giddhā, ","html":"<span class='verse-line'>{}</span>"},"pv41:2.4":{"pli":"na te passiṁsunāgataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv41:3.1":{"pli":"Te cutā ca manussattā, ","html":"<p><span class='verse-line'>{}</span>"},"pv41:3.2":{"pli":"paralokaṁ ito gatā; ","html":"<span class='verse-line'>{}</span>"},"pv41:3.3":{"pli":"Tedha ghosentyadissantā, ","html":"<span class='verse-line'>{}</span>"},"pv41:3.4":{"pli":"pubbe dukkaṭamattano. ","html":"<span class='verse-line'>{}</span></p>"},"pv41:4.1":{"pli":"Bahūsu vata santesu, ","html":"<p><span class='verse-line'>{}</span>"},"pv41:4.2":{"pli":"deyyadhamme upaṭṭhite; ","html":"<span class='verse-line'>{}</span>"},"pv41:4.3":{"pli":"Nāsakkhimhā ca attānaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv41:4.4":{"pli":"parittaṁ kātuṁ sukhāvahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv41:5.1":{"pli":"Kiṁ tato pāpakaṁ assa, ","html":"<p><span class='verse-line'>{}</span>"},"pv41:5.2":{"pli":"yaṁ no rājakulā cutā; ","html":"<span class='verse-line'>{}</span>"},"pv41:5.3":{"pli":"Upapannā pettivisayaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv41:5.4":{"pli":"khuppipāsasamappitā. ","html":"<span class='verse-line'>{}</span></p>"},"pv41:6.1":{"pli":"Sāmino idha hutvāna, ","html":"<p><span class='verse-line'>{}</span>"},"pv41:6.2":{"pli":"honti asāmino tahiṁ; ","html":"<span class='verse-line'>{}</span>"},"pv41:6.3":{"pli":"Bhamanti khuppipāsāya, ","html":"<span class='verse-line'>{}</span>"},"pv41:6.4":{"pli":"manussā unnatonatā. ","html":"<span class='verse-line'>{}</span></p>"},"pv41:7.1":{"pli":"Etamādīnavaṁ ñatvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv41:7.2":{"pli":"issaramadasambhavaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv41:7.3":{"pli":"Pahāya issaramadaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv41:7.4":{"pli":"bhave saggagato naro; ","html":"<span class='verse-line'>{}</span>"},"pv41:7.5":{"pli":"Kāyassa bhedā sappañño, ","html":"<span class='verse-line'>{}</span>"},"pv41:7.6":{"pli":"saggaṁ so upapajjatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv41:8.1":{"pli":"Kumārapetavatthu chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"pv42":{"pv42:0.1":{"pli":"Petavatthu ","html":"<article id='pv42'><header><ul><li class='division'>{}</li>"},"pv42:0.2":{"pli":"Mahāvagga ","html":"<li>{}</li></ul>"},"pv42:0.3":{"pli":"7. Rājaputtapetavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv42:1.1":{"pli":"Pubbe katānaṁ kammānaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv42:1.2":{"pli":"vipāko mathaye manaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv42:1.3":{"pli":"Rūpe sadde rase gandhe, ","html":"<span class='verse-line'>{}</span>"},"pv42:1.4":{"pli":"phoṭṭhabbe ca manorame. ","html":"<span class='verse-line'>{}</span></p>"},"pv42:2.1":{"pli":"Naccaṁ gītaṁ ratiṁ khiḍḍaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv42:2.2":{"pli":"anubhutvā anappakaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv42:2.3":{"pli":"Uyyāne paricaritvā, ","html":"<span class='verse-line'>{}</span>"},"pv42:2.4":{"pli":"pavisanto giribbajaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv42:3.1":{"pli":"Isiṁ sunetta maddakkhi, ","html":"<p><span class='verse-line'>{}</span>"},"pv42:3.2":{"pli":"attadantaṁ samāhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv42:3.3":{"pli":"Appicchaṁ hirisampannaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv42:3.4":{"pli":"uñche pattagate rataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv42:4.1":{"pli":"Hatthikkhandhato oruyha, ","html":"<p><span class='verse-line'>{}</span>"},"pv42:4.2":{"pli":"laddhā bhanteti cābravi; ","html":"<span class='verse-line'>{}</span>"},"pv42:4.3":{"pli":"Tassa pattaṁ gahetvāna, ","html":"<span class='verse-line'>{}</span>"},"pv42:4.4":{"pli":"uccaṁ paggayha khattiyo. ","html":"<span class='verse-line'>{}</span></p>"},"pv42:5.1":{"pli":"Thaṇḍile pattaṁ bhinditvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv42:5.2":{"pli":"hasamāno apakkami; ","html":"<span class='verse-line'>{}</span>"},"pv42:5.3":{"pli":"“Rañño kitavassāhaṁ putto, ","html":"<span class='verse-line'>{}</span>"},"pv42:5.4":{"pli":"kiṁ maṁ bhikkhu karissasi”. ","html":"<span class='verse-line'>{}</span></p>"},"pv42:6.1":{"pli":"Tassa kammassa pharusassa, ","html":"<p><span class='verse-line'>{}</span>"},"pv42:6.2":{"pli":"vipāko kaṭuko ahu; ","html":"<span class='verse-line'>{}</span>"},"pv42:6.3":{"pli":"Yaṁ rājaputto vedesi, ","html":"<span class='verse-line'>{}</span>"},"pv42:6.4":{"pli":"nirayamhi samappito. ","html":"<span class='verse-line'>{}</span></p>"},"pv42:7.1":{"pli":"Chaḷeva caturāsīti, ","html":"<p><span class='verse-line'>{}</span>"},"pv42:7.2":{"pli":"vassāni navutāni ca; ","html":"<span class='verse-line'>{}</span>"},"pv42:7.3":{"pli":"Bhusaṁ dukkhaṁ nigacchittho, ","html":"<span class='verse-line'>{}</span>"},"pv42:7.4":{"pli":"niraye katakibbiso. ","html":"<span class='verse-line'>{}</span></p>"},"pv42:8.1":{"pli":"Uttānopi ca paccittha, ","html":"<p><span class='verse-line'>{}</span>"},"pv42:8.2":{"pli":"nikujjo vāmadakkhiṇo; ","html":"<span class='verse-line'>{}</span>"},"pv42:8.3":{"pli":"Uddhampādo ṭhito ceva, ","html":"<span class='verse-line'>{}</span>"},"pv42:8.4":{"pli":"ciraṁ bālo apaccatha. ","html":"<span class='verse-line'>{}</span></p>"},"pv42:9.1":{"pli":"Bahūni vassasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"pv42:9.2":{"pli":"pūgāni nahutāni ca; ","html":"<span class='verse-line'>{}</span>"},"pv42:9.3":{"pli":"Bhusaṁ dukkhaṁ nigacchittho, ","html":"<span class='verse-line'>{}</span>"},"pv42:9.4":{"pli":"niraye katakibbiso. ","html":"<span class='verse-line'>{}</span></p>"},"pv42:10.1":{"pli":"Etādisaṁ kho kaṭukaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv42:10.2":{"pli":"appaduṭṭhappadosinaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv42:10.3":{"pli":"Paccanti pāpakammantā, ","html":"<span class='verse-line'>{}</span>"},"pv42:10.4":{"pli":"isimāsajja subbataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv42:11.1":{"pli":"So tattha bahuvassāni, ","html":"<p><span class='verse-line'>{}</span>"},"pv42:11.2":{"pli":"vedayitvā bahuṁ dukhaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv42:11.3":{"pli":"Khuppipāsahato nāma, ","html":"<span class='verse-line'>{}</span>"},"pv42:11.4":{"pli":"peto āsi tato cuto. ","html":"<span class='verse-line'>{}</span></p>"},"pv42:12.1":{"pli":"Etamādīnavaṁ ñatvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv42:12.2":{"pli":"issaramadasambhavaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv42:12.3":{"pli":"Pahāya issaramadaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv42:12.4":{"pli":"nivātamanuvattaye. ","html":"<span class='verse-line'>{}</span></p>"},"pv42:13.1":{"pli":"Diṭṭheva dhamme pāsaṁso, ","html":"<p><span class='verse-line'>{}</span>"},"pv42:13.2":{"pli":"yo buddhesu sagāravo; ","html":"<span class='verse-line'>{}</span>"},"pv42:13.3":{"pli":"Kāyassa bhedā sappañño, ","html":"<span class='verse-line'>{}</span>"},"pv42:13.4":{"pli":"saggaṁ so upapajjatīti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv42:14.1":{"pli":"Rājaputtapetavatthu sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"pv43":{"pv43:0.1":{"pli":"Petavatthu ","html":"<article id='pv43'><header><ul><li class='division'>{}</li>"},"pv43:0.2":{"pli":"Mahāvagga ","html":"<li>{}</li></ul>"},"pv43:0.3":{"pli":"8. Gūthakhādakapetavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv43:1.1":{"pli":"“Gūthakūpato uggantvā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv43:1.2":{"pli":"ko nu dīno patiṭṭhasi; ","html":"<span class='verse-line'>{}</span>"},"pv43:1.3":{"pli":"Nissaṁsayaṁ pāpakammanto, ","html":"<span class='verse-line'>{}</span>"},"pv43:1.4":{"pli":"kiṁ nu saddahase tuvan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv43:2.1":{"pli":"“Ahaṁ bhadante petomhi, ","html":"<p><span class='verse-line'>{}</span>"},"pv43:2.2":{"pli":"duggato yamalokiko; ","html":"<span class='verse-line'>{}</span>"},"pv43:2.3":{"pli":"Pāpakammaṁ karitvāna, ","html":"<span class='verse-line'>{}</span>"},"pv43:2.4":{"pli":"petalokaṁ ito gato”. ","html":"<span class='verse-line'>{}</span></p>"},"pv43:3.1":{"pli":"“Kiṁ nu kāyena vācāya, ","html":"<p><span class='verse-line'>{}</span>"},"pv43:3.2":{"pli":"manasā dukkaṭaṁ kataṁ; ","html":"<span class='verse-line'>{}</span>"},"pv43:3.3":{"pli":"Kissa kammavipākena, ","html":"<span class='verse-line'>{}</span>"},"pv43:3.4":{"pli":"idaṁ dukkhaṁ nigacchasī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv43:4.1":{"pli":"“Ahu āvāsiko mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv43:4.2":{"pli":"issukī kulamaccharī; ","html":"<span class='verse-line'>{}</span>"},"pv43:4.3":{"pli":"Ajjhāsito mayhaṁ ghare, ","html":"<span class='verse-line'>{}</span>"},"pv43:4.4":{"pli":"kadariyo paribhāsako. ","html":"<span class='verse-line'>{}</span></p>"},"pv43:5.1":{"pli":"Tassāhaṁ vacanaṁ sutvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv43:5.2":{"pli":"bhikkhavo paribhāsisaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv43:5.3":{"pli":"Tassa kammavipākena, ","html":"<span class='verse-line'>{}</span>"},"pv43:5.4":{"pli":"petalokaṁ ito gato”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv43:6.1":{"pli":"“Amitto mittavaṇṇena, ","html":"<p><span class='verse-line'>{}</span>"},"pv43:6.2":{"pli":"yo te āsi kulūpako; ","html":"<span class='verse-line'>{}</span>"},"pv43:6.3":{"pli":"Kāyassa bhedā duppañño, ","html":"<span class='verse-line'>{}</span>"},"pv43:6.4":{"pli":"kiṁ nu pecca gatiṁ gato”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv43:7.1":{"pli":"“Tassevāhaṁ pāpakammassa, ","html":"<p><span class='verse-line'>{}</span>"},"pv43:7.2":{"pli":"sīse tiṭṭhāmi matthake; ","html":"<span class='verse-line'>{}</span>"},"pv43:7.3":{"pli":"So ca paravisayaṁ patto, ","html":"<span class='verse-line'>{}</span>"},"pv43:7.4":{"pli":"mameva paricārako. ","html":"<span class='verse-line'>{}</span></p>"},"pv43:8.1":{"pli":"Yaṁ bhadante hadantaññe, ","html":"<p><span class='verse-line'>{}</span>"},"pv43:8.2":{"pli":"etaṁ me hoti bhojanaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv43:8.3":{"pli":"Ahañca kho yaṁ hadāmi, ","html":"<span class='verse-line'>{}</span>"},"pv43:8.4":{"pli":"etaṁ so upajīvatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv43:9.1":{"pli":"Gūthakhādakapetavatthu aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"pv44":{"pv44:0.1":{"pli":"Petavatthu ","html":"<article id='pv44'><header><ul><li class='division'>{}</li>"},"pv44:0.2":{"pli":"Mahāvagga ","html":"<li>{}</li></ul>"},"pv44:0.3":{"pli":"9. Gūthakhādakapetivatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv44:1.1":{"pli":"“Gūthakūpato uggantvā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv44:1.2":{"pli":"kā nu dīnā patiṭṭhasi; ","html":"<span class='verse-line'>{}</span>"},"pv44:1.3":{"pli":"Nissaṁsayaṁ pāpakammantā, ","html":"<span class='verse-line'>{}</span>"},"pv44:1.4":{"pli":"kiṁ nu saddahase tuvan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv44:2.1":{"pli":"“Ahaṁ bhadante petīmhi, ","html":"<p><span class='verse-line'>{}</span>"},"pv44:2.2":{"pli":"duggatā yamalokikā; ","html":"<span class='verse-line'>{}</span>"},"pv44:2.3":{"pli":"Pāpakammaṁ karitvāna, ","html":"<span class='verse-line'>{}</span>"},"pv44:2.4":{"pli":"petalokaṁ ito gatā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv44:3.1":{"pli":"“Kiṁ nu kāyena vācāya, ","html":"<p><span class='verse-line'>{}</span>"},"pv44:3.2":{"pli":"manasā dukkaṭaṁ kataṁ; ","html":"<span class='verse-line'>{}</span>"},"pv44:3.3":{"pli":"Kissa kammavipākena, ","html":"<span class='verse-line'>{}</span>"},"pv44:3.4":{"pli":"idaṁ dukkhaṁ nigacchasī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv44:4.1":{"pli":"“Ahu āvāsiko mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv44:4.2":{"pli":"issukī kulamaccharī; ","html":"<span class='verse-line'>{}</span>"},"pv44:4.3":{"pli":"Ajjhāsito mayhaṁ ghare, ","html":"<span class='verse-line'>{}</span>"},"pv44:4.4":{"pli":"kadariyo paribhāsako. ","html":"<span class='verse-line'>{}</span></p>"},"pv44:5.1":{"pli":"Tassāhaṁ vacanaṁ sutvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv44:5.2":{"pli":"bhikkhavo paribhāsisaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv44:5.3":{"pli":"Tassa kammavipākena, ","html":"<span class='verse-line'>{}</span>"},"pv44:5.4":{"pli":"petalokaṁ ito gatā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv44:6.1":{"pli":"“Amitto mittavaṇṇena, ","html":"<p><span class='verse-line'>{}</span>"},"pv44:6.2":{"pli":"yo te āsi kulūpako; ","html":"<span class='verse-line'>{}</span>"},"pv44:6.3":{"pli":"Kāyassa bhedā duppañño, ","html":"<span class='verse-line'>{}</span>"},"pv44:6.4":{"pli":"kiṁ nu pecca gatiṁ gato”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv44:7.1":{"pli":"“Tassevāhaṁ pāpakammassa, ","html":"<p><span class='verse-line'>{}</span>"},"pv44:7.2":{"pli":"sīse tiṭṭhāmi matthake; ","html":"<span class='verse-line'>{}</span>"},"pv44:7.3":{"pli":"So ca paravisayaṁ patto, ","html":"<span class='verse-line'>{}</span>"},"pv44:7.4":{"pli":"mameva paricārako. ","html":"<span class='verse-line'>{}</span></p>"},"pv44:8.1":{"pli":"Yaṁ bhadante hadantaññe, ","html":"<p><span class='verse-line'>{}</span>"},"pv44:8.2":{"pli":"etaṁ me hoti bhojanaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv44:8.3":{"pli":"Ahañca kho yaṁ hadāmi, ","html":"<span class='verse-line'>{}</span>"},"pv44:8.4":{"pli":"etaṁ so upajīvatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv44:9.1":{"pli":"Gūthakhādakapetivatthu navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"pv45":{"pv45:0.1":{"pli":"Petavatthu ","html":"<article id='pv45'><header><ul><li class='division'>{}</li>"},"pv45:0.2":{"pli":"Mahāvagga ","html":"<li>{}</li></ul>"},"pv45:0.3":{"pli":"10. Gaṇapetavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv45:1.1":{"pli":"“Naggā dubbaṇṇarūpāttha, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv45:1.2":{"pli":"kisā dhamanisanthatā; ","html":"<span class='verse-line'>{}</span>"},"pv45:1.3":{"pli":"Upphāsulikā kisikā, ","html":"<span class='verse-line'>{}</span>"},"pv45:1.4":{"pli":"ke nu tumhettha mārisā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv45:2.1":{"pli":"“Mayaṁ bhadante petāmhā, ","html":"<p><span class='verse-line'>{}</span>"},"pv45:2.2":{"pli":"duggatā yamalokikā; ","html":"<span class='verse-line'>{}</span>"},"pv45:2.3":{"pli":"Pāpakammaṁ karitvāna, ","html":"<span class='verse-line'>{}</span>"},"pv45:2.4":{"pli":"petalokaṁ ito gatā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv45:3.1":{"pli":"“Kiṁ nu kāyena vācāya, ","html":"<p><span class='verse-line'>{}</span>"},"pv45:3.2":{"pli":"manasā dukkaṭaṁ kataṁ; ","html":"<span class='verse-line'>{}</span>"},"pv45:3.3":{"pli":"Kissa kammavipākena, ","html":"<span class='verse-line'>{}</span>"},"pv45:3.4":{"pli":"petalokaṁ ito gatā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv45:4.1":{"pli":"“Anāvaṭesu titthesu, ","html":"<p><span class='verse-line'>{}</span>"},"pv45:4.2":{"pli":"vicinimhaddhamāsakaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv45:4.3":{"pli":"Santesu deyyadhammesu, ","html":"<span class='verse-line'>{}</span>"},"pv45:4.4":{"pli":"dīpaṁ nākamha attano. ","html":"<span class='verse-line'>{}</span></p>"},"pv45:5.1":{"pli":"Nadiṁ upema tasitā, ","html":"<p><span class='verse-line'>{}</span>"},"pv45:5.2":{"pli":"rittakā parivattati; ","html":"<span class='verse-line'>{}</span>"},"pv45:5.3":{"pli":"Chāyaṁ upema uṇhesu, ","html":"<span class='verse-line'>{}</span>"},"pv45:5.4":{"pli":"ātapo parivattati. ","html":"<span class='verse-line'>{}</span></p>"},"pv45:6.1":{"pli":"Aggivaṇṇo ca no vāto, ","html":"<p><span class='verse-line'>{}</span>"},"pv45:6.2":{"pli":"ḍahanto upavāyati; ","html":"<span class='verse-line'>{}</span>"},"pv45:6.3":{"pli":"Etañca bhante arahāma, ","html":"<span class='verse-line'>{}</span>"},"pv45:6.4":{"pli":"aññañca pāpakaṁ tato. ","html":"<span class='verse-line'>{}</span></p>"},"pv45:7.1":{"pli":"Api yojanāni gacchāma, ","html":"<p><span class='verse-line'>{}</span>"},"pv45:7.2":{"pli":"chātā āhāragedhino; ","html":"<span class='verse-line'>{}</span>"},"pv45:7.3":{"pli":"Aladdhāva nivattāma, ","html":"<span class='verse-line'>{}</span>"},"pv45:7.4":{"pli":"aho no appapuññatā. ","html":"<span class='verse-line'>{}</span></p>"},"pv45:8.1":{"pli":"Chātā pamucchitā bhantā, ","html":"<p><span class='verse-line'>{}</span>"},"pv45:8.2":{"pli":"bhūmiyaṁ paṭisumbhitā; ","html":"<span class='verse-line'>{}</span>"},"pv45:8.3":{"pli":"Uttānā paṭikirāma, ","html":"<span class='verse-line'>{}</span>"},"pv45:8.4":{"pli":"avakujjā patāmase. ","html":"<span class='verse-line'>{}</span></p>"},"pv45:9.1":{"pli":"Te ca tattheva patitā, ","html":"<p><span class='verse-line'>{}</span>"},"pv45:9.2":{"pli":"bhūmiyaṁ paṭisumbhitā; ","html":"<span class='verse-line'>{}</span>"},"pv45:9.3":{"pli":"Uraṁ sīsañca ghaṭṭema, ","html":"<span class='verse-line'>{}</span>"},"pv45:9.4":{"pli":"aho no appapuññatā. ","html":"<span class='verse-line'>{}</span></p>"},"pv45:10.1":{"pli":"Etañca bhante arahāma, ","html":"<p><span class='verse-line'>{}</span>"},"pv45:10.2":{"pli":"aññañca pāpakaṁ tato; ","html":"<span class='verse-line'>{}</span>"},"pv45:10.3":{"pli":"Santesu deyyadhammesu, ","html":"<span class='verse-line'>{}</span>"},"pv45:10.4":{"pli":"dīpaṁ nākamha attano. ","html":"<span class='verse-line'>{}</span></p>"},"pv45:11.1":{"pli":"Te hi nūna ito gantvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv45:11.2":{"pli":"yoniṁ laddhāna mānusiṁ; ","html":"<span class='verse-line'>{}</span>"},"pv45:11.3":{"pli":"Vadaññū sīlasampannā, ","html":"<span class='verse-line'>{}</span>"},"pv45:11.4":{"pli":"kāhāma kusalaṁ bahun”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv45:12.1":{"pli":"Gaṇapetavatthu dasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"pv46":{"pv46:0.1":{"pli":"Petavatthu ","html":"<article id='pv46'><header><ul><li class='division'>{}</li>"},"pv46:0.2":{"pli":"Mahāvagga ","html":"<li>{}</li></ul>"},"pv46:0.3":{"pli":"11. Pāṭaliputtapetavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv46:1.1":{"pli":"“Diṭṭhā tayā nirayā tiracchānayoni, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv46:1.2":{"pli":"Petā asurā athavāpi mānusā devā; ","html":"<span class='verse-line'>{}</span>"},"pv46:1.3":{"pli":"Sayamaddasa kammavipākamattano, ","html":"<span class='verse-line'>{}</span>"},"pv46:1.4":{"pli":"Nessāmi taṁ pāṭaliputtamakkhataṁ; ","html":"<span class='verse-line'>{}</span>"},"pv46:1.5":{"pli":"Tattha gantvā kusalaṁ karohi kammaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"pv46:2.1":{"pli":"“Atthakāmosi me yakkha, ","html":"<p><span class='verse-line'>{}</span>"},"pv46:2.2":{"pli":"hitakāmosi devate; ","html":"<span class='verse-line'>{}</span>"},"pv46:2.3":{"pli":"Karomi tuyhaṁ vacanaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv46:2.4":{"pli":"tvaṁsi ācariyo mama. ","html":"<span class='verse-line'>{}</span></p>"},"pv46:3.1":{"pli":"Diṭṭhā mayā nirayā tiracchānayoni, ","html":"<p><span class='verse-line'>{}</span>"},"pv46:3.2":{"pli":"Petā asurā athavāpi mānusā devā; ","html":"<span class='verse-line'>{}</span>"},"pv46:3.3":{"pli":"Sayamaddasaṁ kammavipākamattano, ","html":"<span class='verse-line'>{}</span>"},"pv46:3.4":{"pli":"Kāhāmi puññāni anappakānī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv46:4.1":{"pli":"Pāṭaliputtapetavatthu ekādasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"pv47":{"pv47:0.1":{"pli":"Petavatthu ","html":"<article id='pv47'><header><ul><li class='division'>{}</li>"},"pv47:0.2":{"pli":"Mahāvagga ","html":"<li>{}</li></ul>"},"pv47:0.3":{"pli":"12. Ambavanapetavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv47:1.1":{"pli":"“Ayañca te pokkharaṇī surammā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv47:1.2":{"pli":"Samā sutitthā ca mahodakā ca; ","html":"<span class='verse-line'>{}</span>"},"pv47:1.3":{"pli":"Supupphitā bhamaragaṇānukiṇṇā, ","html":"<span class='verse-line'>{}</span>"},"pv47:1.4":{"pli":"Kathaṁ tayā laddhā ayaṁ manuññā. ","html":"<span class='verse-line'>{}</span></p>"},"pv47:2.1":{"pli":"Idañca te ambavanaṁ surammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv47:2.2":{"pli":"Sabbotukaṁ dhārayate phalāni; ","html":"<span class='verse-line'>{}</span>"},"pv47:2.3":{"pli":"Supupphitaṁ bhamaragaṇānukiṇṇaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv47:2.4":{"pli":"Kathaṁ tayā laddhamidaṁ vimānaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"pv47:3.1":{"pli":"“Ambapakkaṁ dakaṁ yāgu, ","html":"<p><span class='verse-line'>{}</span>"},"pv47:3.2":{"pli":"sītacchāyā manoramā; ","html":"<span class='verse-line'>{}</span>"},"pv47:3.3":{"pli":"Dhītāya dinnadānena, ","html":"<span class='verse-line'>{}</span>"},"pv47:3.4":{"pli":"tena me idha labbhati”. ","html":"<span class='verse-line'>{}</span></p>"},"pv47:4.1":{"pli":"“Sandiṭṭhikaṁ kammaṁ evaṁ passatha, ","html":"<p><span class='verse-line'>{}</span>"},"pv47:4.2":{"pli":"Dānassa damassa saṁyamassa vipākaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv47:4.3":{"pli":"Dāsī ahaṁ ayyakulesu hutvā, ","html":"<span class='verse-line'>{}</span>"},"pv47:4.4":{"pli":"Suṇisā homi agārassa issarā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv47:5.1":{"pli":"Ambavanapetavatthu dvādasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"pv48":{"pv48:0.1":{"pli":"Petavatthu ","html":"<article id='pv48'><header><ul><li class='division'>{}</li>"},"pv48:0.2":{"pli":"Mahāvagga ","html":"<li>{}</li></ul>"},"pv48:0.3":{"pli":"13. Akkharukkhapetavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv48:1.1":{"pli":"“Yaṁ dadāti na taṁ hoti, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv48:1.2":{"pli":"Detheva dānaṁ datvā ubhayaṁ tarati; ","html":"<span class='verse-line'>{}</span>"},"pv48:1.3":{"pli":"Ubhayaṁ tena dānena gacchati, ","html":"<span class='verse-line'>{}</span>"},"pv48:1.4":{"pli":"Jāgaratha māpamajjathā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv48:2.1":{"pli":"Akkharukkhapetavatthu terasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"pv49":{"pv49:0.1":{"pli":"Petavatthu ","html":"<article id='pv49'><header><ul><li class='division'>{}</li>"},"pv49:0.2":{"pli":"Mahāvagga ","html":"<li>{}</li></ul>"},"pv49:0.3":{"pli":"14. Bhogasaṁharaṇapetavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv49:1.1":{"pli":"“Mayaṁ bhoge saṁharimhā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv49:1.2":{"pli":"samena visamena ca; ","html":"<span class='verse-line'>{}</span>"},"pv49:1.3":{"pli":"Te aññe paribhuñjanti, ","html":"<span class='verse-line'>{}</span>"},"pv49:1.4":{"pli":"mayaṁ dukkhassa bhāginī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv49:2.1":{"pli":"Bhogasaṁharaṇapetavatthu cuddasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"pv5":{"pv5:0.1":{"pli":"Petavatthu ","html":"<article id='pv5'><header><ul><li class='division'>{}</li>"},"pv5:0.2":{"pli":"Uragavagga ","html":"<li>{}</li></ul>"},"pv5:0.3":{"pli":"5. Tirokuṭṭapetavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv5:1.1":{"pli":"“Tirokuṭṭesu tiṭṭhanti, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv5:1.2":{"pli":"sandhisiṅghāṭakesu ca; ","html":"<span class='verse-line'>{}</span>"},"pv5:1.3":{"pli":"Dvārabāhāsu tiṭṭhanti, ","html":"<span class='verse-line'>{}</span>"},"pv5:1.4":{"pli":"āgantvāna sakaṁ gharaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv5:2.1":{"pli":"Pahūte annapānamhi, ","html":"<p><span class='verse-line'>{}</span>"},"pv5:2.2":{"pli":"khajjabhojje upaṭṭhite; ","html":"<span class='verse-line'>{}</span>"},"pv5:2.3":{"pli":"Na tesaṁ koci sarati, ","html":"<span class='verse-line'>{}</span>"},"pv5:2.4":{"pli":"sattānaṁ kammapaccayā. ","html":"<span class='verse-line'>{}</span></p>"},"pv5:3.1":{"pli":"Evaṁ dadanti ñātīnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv5:3.2":{"pli":"ye honti anukampakā; ","html":"<span class='verse-line'>{}</span>"},"pv5:3.3":{"pli":"Suciṁ paṇītaṁ kālena, ","html":"<span class='verse-line'>{}</span>"},"pv5:3.4":{"pli":"kappiyaṁ pānabhojanaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv5:3.5":{"pli":"‘Idaṁ vo ñātīnaṁ hotu, ","html":"<span class='verse-line'>{}</span>"},"pv5:3.6":{"pli":"sukhitā hontu ñātayo’. ","html":"<span class='verse-line'>{}</span></p>"},"pv5:4.1":{"pli":"Te ca tattha samāgantvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv5:4.2":{"pli":"ñātipetā samāgatā; ","html":"<span class='verse-line'>{}</span>"},"pv5:4.3":{"pli":"Pahūte annapānamhi, ","html":"<span class='verse-line'>{}</span>"},"pv5:4.4":{"pli":"sakkaccaṁ anumodare. ","html":"<span class='verse-line'>{}</span></p>"},"pv5:5.1":{"pli":"‘Ciraṁ jīvantu no ñātī, ","html":"<p><span class='verse-line'>{}</span>"},"pv5:5.2":{"pli":"yesaṁ hetu labhāmase; ","html":"<span class='verse-line'>{}</span>"},"pv5:5.3":{"pli":"Amhākañca katā pūjā, ","html":"<span class='verse-line'>{}</span>"},"pv5:5.4":{"pli":"dāyakā ca anipphalā’. ","html":"<span class='verse-line'>{}</span></p>"},"pv5:6.1":{"pli":"Na hi tattha kasī atthi, ","html":"<p><span class='verse-line'>{}</span>"},"pv5:6.2":{"pli":"gorakkhettha na vijjati; ","html":"<span class='verse-line'>{}</span>"},"pv5:6.3":{"pli":"Vaṇijjā tādisī natthi, ","html":"<span class='verse-line'>{}</span>"},"pv5:6.4":{"pli":"hiraññena kayākayaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv5:6.5":{"pli":"Ito dinnena yāpenti, ","html":"<span class='verse-line'>{}</span>"},"pv5:6.6":{"pli":"petā kālagatā tahiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv5:7.1":{"pli":"Unname udakaṁ vuṭṭhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv5:7.2":{"pli":"yathā ninnaṁ pavattati; ","html":"<span class='verse-line'>{}</span>"},"pv5:7.3":{"pli":"Evamevaṁ ito dinnaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv5:7.4":{"pli":"petānaṁ upakappati. ","html":"<span class='verse-line'>{}</span></p>"},"pv5:8.1":{"pli":"Yathā vārivahā pūrā, ","html":"<p><span class='verse-line'>{}</span>"},"pv5:8.2":{"pli":"paripūrenti sāgaraṁ; ","html":"<span class='verse-line'>{}</span>"},"pv5:8.3":{"pli":"Evamevaṁ ito dinnaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv5:8.4":{"pli":"petānaṁ upakappati. ","html":"<span class='verse-line'>{}</span></p>"},"pv5:9.1":{"pli":"‘Adāsi me akāsi me, ","html":"<p><span class='verse-line'>{}</span>"},"pv5:9.2":{"pli":"ñāti mittā sakhā ca me’; ","html":"<span class='verse-line'>{}</span>"},"pv5:9.3":{"pli":"Petānaṁ dakkhiṇaṁ dajjā, ","html":"<span class='verse-line'>{}</span>"},"pv5:9.4":{"pli":"pubbe katamanussaraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv5:10.1":{"pli":"Na hi ruṇṇaṁ vā soko vā, ","html":"<p><span class='verse-line'>{}</span>"},"pv5:10.2":{"pli":"yā caññā paridevanā; ","html":"<span class='verse-line'>{}</span>"},"pv5:10.3":{"pli":"Na taṁ petānamatthāya, ","html":"<span class='verse-line'>{}</span>"},"pv5:10.4":{"pli":"evaṁ tiṭṭhanti ñātayo. ","html":"<span class='verse-line'>{}</span></p>"},"pv5:11.1":{"pli":"Ayañca kho dakkhiṇā dinnā, ","html":"<p><span class='verse-line'>{}</span>"},"pv5:11.2":{"pli":"saṅghamhi suppatiṭṭhitā; ","html":"<span class='verse-line'>{}</span>"},"pv5:11.3":{"pli":"Dīgharattaṁ hitāyassa, ","html":"<span class='verse-line'>{}</span>"},"pv5:11.4":{"pli":"ṭhānaso upakappati. ","html":"<span class='verse-line'>{}</span></p>"},"pv5:12.1":{"pli":"So ñātidhammo ca ayaṁ nidassito, ","html":"<p><span class='verse-line'>{}</span>"},"pv5:12.2":{"pli":"Petāna pūjā ca katā uḷārā; ","html":"<span class='verse-line'>{}</span>"},"pv5:12.3":{"pli":"Balañca bhikkhūnamanuppadinnaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv5:12.4":{"pli":"Tumhehi puññaṁ pasutaṁ anappakan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv5:13.1":{"pli":"Tirokuṭṭapetavatthu pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}