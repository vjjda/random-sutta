{"ja477":{"ja477:0.1":{"pli":"Jātaka ","html":"<article id='ja477'><header><ul><li class='division'>{}</li>"},"ja477:0.2":{"pli":"Terasakanipāta ","html":"<li>{}</li>"},"ja477:0.3":{"pli":"Ambavagga ","html":"<li>{}</li></ul>"},"ja477:0.4":{"pli":"4. Cūḷanāradajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja477:1.1":{"pli":"“Na te kaṭṭhāni bhinnāni, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja477:1.2":{"pli":"na te udakamābhataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja477:1.3":{"pli":"Aggīpi te na hāpito, ","html":"<span class='verse-line'>{}</span>"},"ja477:1.4":{"pli":"kiṁ nu mandova jhāyasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja477:2.1":{"pli":"“Na ussahe vane vatthuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja477:2.2":{"pli":"kassapāmantayāmi taṁ; ","html":"<span class='verse-line'>{}</span>"},"ja477:2.3":{"pli":"Dukkho vāso araññasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja477:2.4":{"pli":"raṭṭhaṁ icchāmi gantave. ","html":"<span class='verse-line'>{}</span></p>"},"ja477:3.1":{"pli":"Yathā ahaṁ ito gantvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja477:3.2":{"pli":"Yasmiṁ janapade vasaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja477:3.3":{"pli":"Ācāraṁ brahme sikkheyyaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja477:3.4":{"pli":"Taṁ dhammaṁ anusāsa maṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja477:4.1":{"pli":"“Sace araññaṁ hitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"ja477:4.2":{"pli":"vanamūlaphalāni ca; ","html":"<span class='verse-line'>{}</span>"},"ja477:4.3":{"pli":"Raṭṭhe rocayase vāsaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja477:4.4":{"pli":"taṁ dhammaṁ nisāmehi me. ","html":"<span class='verse-line'>{}</span></p>"},"ja477:5.1":{"pli":"Visaṁ mā paṭisevittho, ","html":"<p><span class='verse-line'>{}</span>"},"ja477:5.2":{"pli":"papātaṁ parivajjaya; ","html":"<span class='verse-line'>{}</span>"},"ja477:5.3":{"pli":"Paṅke ca mā visīdittho, ","html":"<span class='verse-line'>{}</span>"},"ja477:5.4":{"pli":"yatto cāsīvise care”. ","html":"<span class='verse-line'>{}</span></p>"},"ja477:6.1":{"pli":"“Kiṁ nu visaṁ papāto vā, ","html":"<p><span class='verse-line'>{}</span>"},"ja477:6.2":{"pli":"paṅko vā brahmacārinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja477:6.3":{"pli":"Kaṁ tvaṁ āsīvisaṁ brūsi, ","html":"<span class='verse-line'>{}</span>"},"ja477:6.4":{"pli":"taṁ me akkhāhi pucchito”. ","html":"<span class='verse-line'>{}</span></p>"},"ja477:7.1":{"pli":"“Āsavo tāta lokasmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja477:7.2":{"pli":"surā nāma pavuccati; ","html":"<span class='verse-line'>{}</span>"},"ja477:7.3":{"pli":"Manuñño surabhī vaggu, ","html":"<span class='verse-line'>{}</span>"},"ja477:7.4":{"pli":"sādu khuddarasūpamo; ","html":"<span class='verse-line'>{}</span>"},"ja477:7.5":{"pli":"Visaṁ tadāhu ariyā se, ","html":"<span class='verse-line'>{}</span>"},"ja477:7.6":{"pli":"brahmacariyassa nārada. ","html":"<span class='verse-line'>{}</span></p>"},"ja477:8.1":{"pli":"Itthiyo tāta lokasmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja477:8.2":{"pli":"pamattaṁ pamathenti tā; ","html":"<span class='verse-line'>{}</span>"},"ja477:8.3":{"pli":"Haranti yuvino cittaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja477:8.4":{"pli":"tūlaṁ bhaṭṭhaṁva māluto; ","html":"<span class='verse-line'>{}</span>"},"ja477:8.5":{"pli":"Papāto eso akkhāto, ","html":"<span class='verse-line'>{}</span>"},"ja477:8.6":{"pli":"brahmacariyassa nārada. ","html":"<span class='verse-line'>{}</span></p>"},"ja477:9.1":{"pli":"Lābho siloko sakkāro, ","html":"<p><span class='verse-line'>{}</span>"},"ja477:9.2":{"pli":"pūjā parakulesu ca; ","html":"<span class='verse-line'>{}</span>"},"ja477:9.3":{"pli":"Paṅko eso ca akkhāto, ","html":"<span class='verse-line'>{}</span>"},"ja477:9.4":{"pli":"brahmacariyassa nārada. ","html":"<span class='verse-line'>{}</span></p>"},"ja477:10.1":{"pli":"Sasatthā tāta rājāno, ","html":"<p><span class='verse-line'>{}</span>"},"ja477:10.2":{"pli":"āvasanti mahiṁ imaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja477:10.3":{"pli":"Te tādise manussinde, ","html":"<span class='verse-line'>{}</span>"},"ja477:10.4":{"pli":"mahante tāta nārada. ","html":"<span class='verse-line'>{}</span></p>"},"ja477:11.1":{"pli":"Issarānaṁ adhipatīnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja477:11.2":{"pli":"na tesaṁ pādato care; ","html":"<span class='verse-line'>{}</span>"},"ja477:11.3":{"pli":"Āsīvisoti akkhāto, ","html":"<span class='verse-line'>{}</span>"},"ja477:11.4":{"pli":"brahmacariyassa nārada. ","html":"<span class='verse-line'>{}</span></p>"},"ja477:12.1":{"pli":"Bhattattho bhattakāle ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja477:12.2":{"pli":"yaṁ gehamupasaṅkame; ","html":"<span class='verse-line'>{}</span>"},"ja477:12.3":{"pli":"Yadettha kusalaṁ jaññā, ","html":"<span class='verse-line'>{}</span>"},"ja477:12.4":{"pli":"tattha ghāsesanaṁ care. ","html":"<span class='verse-line'>{}</span></p>"},"ja477:13.1":{"pli":"Pavisitvā parakulaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja477:13.2":{"pli":"pānatthaṁ bhojanāya vā; ","html":"<span class='verse-line'>{}</span>"},"ja477:13.3":{"pli":"Mitaṁ khāde mitaṁ bhuñje, ","html":"<span class='verse-line'>{}</span>"},"ja477:13.4":{"pli":"na ca rūpe manaṁ kare. ","html":"<span class='verse-line'>{}</span></p>"},"ja477:14.1":{"pli":"Goṭṭhaṁ majjaṁ kirāṭañca, ","html":"<p><span class='verse-line'>{}</span>"},"ja477:14.2":{"pli":"sabhā nikiraṇāni ca; ","html":"<span class='verse-line'>{}</span>"},"ja477:14.3":{"pli":"Ārakā parivajjehi, ","html":"<span class='verse-line'>{}</span>"},"ja477:14.4":{"pli":"yānīva visamaṁ pathan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja477:15.1":{"pli":"Cūḷanāradajātakaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja478":{"ja478:0.1":{"pli":"Jātaka ","html":"<article id='ja478'><header><ul><li class='division'>{}</li>"},"ja478:0.2":{"pli":"Terasakanipāta ","html":"<li>{}</li>"},"ja478:0.3":{"pli":"Ambavagga ","html":"<li>{}</li></ul>"},"ja478:0.4":{"pli":"5. Dūtajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja478:1.1":{"pli":"“Dūte te brahme pāhesiṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja478:1.2":{"pli":"Gaṅgātīrasmi jhāyato; ","html":"<span class='verse-line'>{}</span>"},"ja478:1.3":{"pli":"Tesaṁ puṭṭho na byākāsi, ","html":"<span class='verse-line'>{}</span>"},"ja478:1.4":{"pli":"Dukkhaṁ guyhamataṁ nu te”. ","html":"<span class='verse-line'>{}</span></p>"},"ja478:2.1":{"pli":"“Sace te dukkhamuppajje, ","html":"<p><span class='verse-line'>{}</span>"},"ja478:2.2":{"pli":"kāsīnaṁ raṭṭhavaḍḍhana; ","html":"<span class='verse-line'>{}</span>"},"ja478:2.3":{"pli":"Mā kho naṁ tassa akkhāhi, ","html":"<span class='verse-line'>{}</span>"},"ja478:2.4":{"pli":"yo taṁ dukkhā na mocaye. ","html":"<span class='verse-line'>{}</span></p>"},"ja478:3.1":{"pli":"Yo tassa dukkhajātassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja478:3.2":{"pli":"ekaṅgamapi bhāgaso; ","html":"<span class='verse-line'>{}</span>"},"ja478:3.3":{"pli":"Vippamoceyya dhammena, ","html":"<span class='verse-line'>{}</span>"},"ja478:3.4":{"pli":"kāmaṁ tassa pavedaya. ","html":"<span class='verse-line'>{}</span></p>"},"ja478:4.1":{"pli":"Suvijānaṁ siṅgālānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja478:4.2":{"pli":"sakuṇānañca vassitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja478:4.3":{"pli":"Manussavassitaṁ rāja, ","html":"<span class='verse-line'>{}</span>"},"ja478:4.4":{"pli":"dubbijānataraṁ tato. ","html":"<span class='verse-line'>{}</span></p>"},"ja478:5.1":{"pli":"Api ce maññatī poso, ","html":"<p><span class='verse-line'>{}</span>"},"ja478:5.2":{"pli":"ñāti mitto sakhāti vā; ","html":"<span class='verse-line'>{}</span>"},"ja478:5.3":{"pli":"Yo pubbe sumano hutvā, ","html":"<span class='verse-line'>{}</span>"},"ja478:5.4":{"pli":"pacchā sampajjate diso. ","html":"<span class='verse-line'>{}</span></p>"},"ja478:6.1":{"pli":"Yo attano dukkhamanānupuṭṭho, ","html":"<p><span class='verse-line'>{}</span>"},"ja478:6.2":{"pli":"Pavedaye jantu akālarūpe; ","html":"<span class='verse-line'>{}</span>"},"ja478:6.3":{"pli":"Ānandino tassa bhavantimittā, ","html":"<span class='verse-line'>{}</span>"},"ja478:6.4":{"pli":"Hitesino tassa dukhī bhavanti. ","html":"<span class='verse-line'>{}</span></p>"},"ja478:7.1":{"pli":"Kālañca ñatvāna tathāvidhassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja478:7.2":{"pli":"Medhāvīnaṁ ekamanaṁ viditvā; ","html":"<span class='verse-line'>{}</span>"},"ja478:7.3":{"pli":"Akkheyya tibbāni parassa dhīro, ","html":"<span class='verse-line'>{}</span>"},"ja478:7.4":{"pli":"Saṇhaṁ giraṁ atthavatiṁ pamuñce. ","html":"<span class='verse-line'>{}</span></p>"},"ja478:8.1":{"pli":"Sace ca jaññā avisayhamattano, ","html":"<p><span class='verse-line'>{}</span>"},"ja478:8.2":{"pli":"Na te hi mayhaṁ sukhāgamāya; ","html":"<span class='verse-line'>{}</span>"},"ja478:8.3":{"pli":"Ekova tibbāni saheyya dhīro, ","html":"<span class='verse-line'>{}</span>"},"ja478:8.4":{"pli":"Saccaṁ hirottappamapekkhamāno. ","html":"<span class='verse-line'>{}</span></p>"},"ja478:9.1":{"pli":"Ahaṁ raṭṭhe vicaranto, ","html":"<p><span class='verse-line'>{}</span>"},"ja478:9.2":{"pli":"nigame rājadhāniyo; ","html":"<span class='verse-line'>{}</span>"},"ja478:9.3":{"pli":"Bhikkhamāno mahārāja, ","html":"<span class='verse-line'>{}</span>"},"ja478:9.4":{"pli":"ācariyassa dhanatthiko. ","html":"<span class='verse-line'>{}</span></p>"},"ja478:10.1":{"pli":"Gahapatī rājapurise, ","html":"<p><span class='verse-line'>{}</span>"},"ja478:10.2":{"pli":"mahāsāle ca brāhmaṇe; ","html":"<span class='verse-line'>{}</span>"},"ja478:10.3":{"pli":"Alatthaṁ satta nikkhāni, ","html":"<span class='verse-line'>{}</span>"},"ja478:10.4":{"pli":"suvaṇṇassa janādhipa; ","html":"<span class='verse-line'>{}</span>"},"ja478:10.5":{"pli":"Te me naṭṭhā mahārāja, ","html":"<span class='verse-line'>{}</span>"},"ja478:10.6":{"pli":"tasmā socāmahaṁ bhusaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja478:11.1":{"pli":"Purisā te mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja478:11.2":{"pli":"manasānuvicintitā; ","html":"<span class='verse-line'>{}</span>"},"ja478:11.3":{"pli":"Nālaṁ dukkhā pamocetuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja478:11.4":{"pli":"tasmā tesaṁ na byāhariṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja478:12.1":{"pli":"Tvañca kho me mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja478:12.2":{"pli":"manasānuvicintito; ","html":"<span class='verse-line'>{}</span>"},"ja478:12.3":{"pli":"Alaṁ dukkhā pamocetuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja478:12.4":{"pli":"tasmā tuyhaṁ pavedayiṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja478:13.1":{"pli":"“Tassādāsi pasannatto, ","html":"<p><span class='verse-line'>{}</span>"},"ja478:13.2":{"pli":"kāsīnaṁ raṭṭhavaḍḍhano; ","html":"<span class='verse-line'>{}</span>"},"ja478:13.3":{"pli":"Jātarūpamaye nikkhe, ","html":"<span class='verse-line'>{}</span>"},"ja478:13.4":{"pli":"suvaṇṇassa catuddasā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja478:14.1":{"pli":"Dūtajātakaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja479":{"ja479:0.1":{"pli":"Jātaka ","html":"<article id='ja479'><header><ul><li class='division'>{}</li>"},"ja479:0.2":{"pli":"Terasakanipāta ","html":"<li>{}</li>"},"ja479:0.3":{"pli":"Ambavagga ","html":"<li>{}</li></ul>"},"ja479:0.4":{"pli":"6. Kāliṅgabodhijātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja479:1.1":{"pli":"Rājā kāliṅgo cakkavatti, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja479:1.2":{"pli":"Dhammena pathavimanusāsaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja479:1.3":{"pli":"Agamā bodhisamīpaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja479:1.4":{"pli":"Nāgena mahānubhāvena. ","html":"<span class='verse-line'>{}</span></p>"},"ja479:2.1":{"pli":"Kāliṅgo bhāradvājo ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja479:2.2":{"pli":"Rājānaṁ kāliṅgaṁ samaṇakolaññaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja479:2.3":{"pli":"Cakkaṁ vattayato pariggahetvā, ","html":"<span class='verse-line'>{}</span>"},"ja479:2.4":{"pli":"Pañjalī idamavoca. ","html":"<span class='verse-line'>{}</span></p>"},"ja479:3.1":{"pli":"“Paccoroha mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja479:3.2":{"pli":"Bhūmibhāgo yathā samaṇuggato; ","html":"<span class='verse-line'>{}</span>"},"ja479:3.3":{"pli":"Idha anadhivarā buddhā, ","html":"<span class='verse-line'>{}</span>"},"ja479:3.4":{"pli":"Abhisambuddhā virocanti. ","html":"<span class='verse-line'>{}</span></p>"},"ja479:4.1":{"pli":"Padakkhiṇato āvaṭṭā, ","html":"<p><span class='verse-line'>{}</span>"},"ja479:4.2":{"pli":"Tiṇalatā asmiṁ bhūmibhāgasmiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja479:4.3":{"pli":"Pathaviyā nābhiyaṁ maṇḍo, ","html":"<span class='verse-line'>{}</span>"},"ja479:4.4":{"pli":"Iti no sutaṁ mante mahārāja. ","html":"<span class='verse-line'>{}</span></p>"},"ja479:5.1":{"pli":"Sāgarapariyantāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja479:5.2":{"pli":"Mediniyā sabbabhūtadharaṇiyā; ","html":"<span class='verse-line'>{}</span>"},"ja479:5.3":{"pli":"Pathaviyā ayaṁ maṇḍo, ","html":"<span class='verse-line'>{}</span>"},"ja479:5.4":{"pli":"Orohitvā namo karohi. ","html":"<span class='verse-line'>{}</span></p>"},"ja479:6.1":{"pli":"Ye te bhavanti nāgā ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja479:6.2":{"pli":"abhijātā ca kuñjarā; ","html":"<span class='verse-line'>{}</span>"},"ja479:6.3":{"pli":"Ettāvatā padesaṁ te, ","html":"<span class='verse-line'>{}</span>"},"ja479:6.4":{"pli":"nāgā neva mupayanti. ","html":"<span class='verse-line'>{}</span></p>"},"ja479:7.1":{"pli":"Abhijāto nāgo kāmaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja479:7.2":{"pli":"Pesehi kuñjaraṁ dantiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja479:7.3":{"pli":"Ettāvatā padeso, ","html":"<span class='verse-line'>{}</span>"},"ja479:7.4":{"pli":"Sakkā nāgena mupagantuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja479:8.1":{"pli":"Taṁ sutvā rājā kāliṅgo, ","html":"<p><span class='verse-line'>{}</span>"},"ja479:8.2":{"pli":"Veyyañjanikavaco nisāmetvā; ","html":"<span class='verse-line'>{}</span>"},"ja479:8.3":{"pli":"Sampesesi nāgaṁ ñassāma, ","html":"<span class='verse-line'>{}</span>"},"ja479:8.4":{"pli":"Mayaṁ yathimassidaṁ vacanaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja479:9.1":{"pli":"Sampesito ca raññā, ","html":"<p><span class='verse-line'>{}</span>"},"ja479:9.2":{"pli":"Nāgo koñcova abhinaditvāna; ","html":"<span class='verse-line'>{}</span>"},"ja479:9.3":{"pli":"Paṭisakkitvā nisīdi, ","html":"<span class='verse-line'>{}</span>"},"ja479:9.4":{"pli":"Garuṁva bhāraṁ asahamāno. ","html":"<span class='verse-line'>{}</span></p>"},"ja479:10.1":{"pli":"Kāliṅgabhāradvājo, ","html":"<p><span class='verse-line'>{}</span>"},"ja479:10.2":{"pli":"Nāgaṁ khīṇāyukaṁ viditvāna; ","html":"<span class='verse-line'>{}</span>"},"ja479:10.3":{"pli":"Rājānaṁ kāliṅgaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja479:10.4":{"pli":"Taramāno ajjhabhāsittha; ","html":"<span class='verse-line'>{}</span>"},"ja479:10.5":{"pli":"“Aññaṁ saṅkama nāgaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja479:10.6":{"pli":"Nāgo khīṇāyuko mahārāja”. ","html":"<span class='verse-line'>{}</span></p>"},"ja479:11.1":{"pli":"Taṁ sutvā kāliṅgo, ","html":"<p><span class='verse-line'>{}</span>"},"ja479:11.2":{"pli":"taramāno saṅkamī nāgaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja479:11.3":{"pli":"Saṅkanteva raññe, ","html":"<span class='verse-line'>{}</span>"},"ja479:11.4":{"pli":"nāgo tattheva pati bhumyā; ","html":"<span class='verse-line'>{}</span>"},"ja479:11.5":{"pli":"Veyyañjanikavaco, ","html":"<span class='verse-line'>{}</span>"},"ja479:11.6":{"pli":"yathā tathā ahu nāgo. ","html":"<span class='verse-line'>{}</span></p>"},"ja479:12.1":{"pli":"Kāliṅgo rājā kāliṅgaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja479:12.2":{"pli":"brāhmaṇaṁ etadavoca; ","html":"<span class='verse-line'>{}</span>"},"ja479:12.3":{"pli":"“Tvameva asi sambuddho, ","html":"<span class='verse-line'>{}</span>"},"ja479:12.4":{"pli":"sabbaññū sabbadassāvī”. ","html":"<span class='verse-line'>{}</span></p>"},"ja479:13.1":{"pli":"Taṁ anadhivāsento kāliṅgaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja479:13.2":{"pli":"Brāhmaṇo idamavoca; ","html":"<span class='verse-line'>{}</span>"},"ja479:13.3":{"pli":"“Veyyañjanikā hi mayaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja479:13.4":{"pli":"Buddhā sabbaññuno mahārāja. ","html":"<span class='verse-line'>{}</span></p>"},"ja479:14.1":{"pli":"Sabbaññū sabbavidū ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja479:14.2":{"pli":"Buddhā na lakkhaṇena jānanti; ","html":"<span class='verse-line'>{}</span>"},"ja479:14.3":{"pli":"Āgamabalasā hi mayaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja479:14.4":{"pli":"Buddhā sabbaṁ pajānanti”. ","html":"<span class='verse-line'>{}</span></p>"},"ja479:15.1":{"pli":"Mahayitvā sambodhiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja479:15.2":{"pli":"Nānāturiyehi vajjamānehi; ","html":"<span class='verse-line'>{}</span>"},"ja479:15.3":{"pli":"Mālāvilepanaṁ abhiharitvā, ","html":"<span class='verse-line'>{}</span>"},"ja479:15.4":{"pli":"Atha rājā manupāyāsi. ","html":"<span class='verse-line'>{}</span></p>"},"ja479:16.1":{"pli":"Saṭṭhi vāhasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja479:16.2":{"pli":"pupphānaṁ sannipātayi; ","html":"<span class='verse-line'>{}</span>"},"ja479:16.3":{"pli":"Pūjesi rājā kāliṅgo, ","html":"<span class='verse-line'>{}</span>"},"ja479:16.4":{"pli":"bodhimaṇḍamanuttaranti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja479:17.1":{"pli":"Kāliṅgabodhijātakaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja48":{"ja48:0.1":{"pli":"Jātaka ","eng":"Stories of Past Lives 48 ","html":"<article id='ja48'><header><ul><li class='division'>{}</li>"},"ja48:0.2":{"pli":"Ekakanipāta ","eng":"The Book of the Ones ","html":"<li>{}</li>"},"ja48:0.3":{"pli":"Atthakāmavagga ","eng":"Wanting to Help ","html":"<li>{}</li></ul>"},"ja48:0.4":{"pli":"8. Vedabbajātaka ","eng":"About Vedabbha: a past life story ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja48:1.1":{"pli":"“Anupāyena yo atthaṁ, ","eng":"Who wishes to profit by inappropriate means ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>","comm":"The commentary says that a brahmin named Vedabbha, being captured by bandits from Cetī, paid his ransom through a wealth-granting spell also named Vedabbha. But that only inflames the bandits’ desires, and they end up killing him and each other. Despite the commentary, however, the verse does not mention bandits, spells, or brahmins. "},"ja48:1.2":{"pli":"Icchati so vihaññati; ","eng":"is tormented. ","html":"<span class='verse-line'>{}</span>"},"ja48:1.3":{"pli":"Cetā haniṁsu vedabbaṁ, ","eng":"The Cetans who killed Vedabbha ","html":"<span class='verse-line'>{}</span>","comm":"Vedabbha (Sanskrit <i lang='pi' translate='no'>vaidarbha</i>) is a name for the king of Vidarbha, a country to the south of Cetī. It seems the original story concerned a raid by the Cetans that resulted in the death of the king of Vidarbha, a framework that could well convey the same moral. "},"ja48:1.4":{"pli":"Sabbe te byasanamajjhagūti. ","eng":"all fell into ruin. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja48:2.1":{"pli":"Vedabbajātakaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja480":{"ja480:0.1":{"pli":"Jātaka ","html":"<article id='ja480'><header><ul><li class='division'>{}</li>"},"ja480:0.2":{"pli":"Terasakanipāta ","html":"<li>{}</li>"},"ja480:0.3":{"pli":"Ambavagga ","html":"<li>{}</li></ul>"},"ja480:0.4":{"pli":"7. Akittijātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja480:1.1":{"pli":"“Akittiṁ disvā sammantaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja480:1.2":{"pli":"sakko bhūtapatī bravi; ","html":"<span class='verse-line'>{}</span>"},"ja480:1.3":{"pli":"Kiṁ patthayaṁ mahābrahme, ","html":"<span class='verse-line'>{}</span>"},"ja480:1.4":{"pli":"eko sammasi ghammani”. ","html":"<span class='verse-line'>{}</span></p>"},"ja480:2.1":{"pli":"“Dukkho punabbhavo sakka, ","html":"<p><span class='verse-line'>{}</span>"},"ja480:2.2":{"pli":"sarīrassa ca bhedanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja480:2.3":{"pli":"Sammohamaraṇaṁ dukkhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja480:2.4":{"pli":"tasmā sammāmi vāsava”. ","html":"<span class='verse-line'>{}</span></p>"},"ja480:3.1":{"pli":"“Etasmiṁ te sulapite, ","html":"<p><span class='verse-line'>{}</span>"},"ja480:3.2":{"pli":"patirūpe subhāsite; ","html":"<span class='verse-line'>{}</span>"},"ja480:3.3":{"pli":"Varaṁ kassapa te dammi, ","html":"<span class='verse-line'>{}</span>"},"ja480:3.4":{"pli":"yaṁ kiñci manasicchasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja480:4.1":{"pli":"“Varañce me ado sakka, ","html":"<p><span class='verse-line'>{}</span>"},"ja480:4.2":{"pli":"sabbabhūtānamissara; ","html":"<span class='verse-line'>{}</span>"},"ja480:4.3":{"pli":"Yena putte ca dāre ca, ","html":"<span class='verse-line'>{}</span>"},"ja480:4.4":{"pli":"dhanadhaññaṁ piyāni ca; ","html":"<span class='verse-line'>{}</span>"},"ja480:4.5":{"pli":"Laddhā narā na tappanti, ","html":"<span class='verse-line'>{}</span>"},"ja480:4.6":{"pli":"so lobho na mayī vase”. ","html":"<span class='verse-line'>{}</span></p>"},"ja480:5.1":{"pli":"“Etasmiṁ te sulapite, ","html":"<p><span class='verse-line'>{}</span>"},"ja480:5.2":{"pli":"patirūpe subhāsite; ","html":"<span class='verse-line'>{}</span>"},"ja480:5.3":{"pli":"Varaṁ kassapa te dammi, ","html":"<span class='verse-line'>{}</span>"},"ja480:5.4":{"pli":"yaṁ kiñci manasicchasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja480:6.1":{"pli":"“Varañce me ado sakka, ","html":"<p><span class='verse-line'>{}</span>"},"ja480:6.2":{"pli":"sabbabhūtānamissara; ","html":"<span class='verse-line'>{}</span>"},"ja480:6.3":{"pli":"Khettaṁ vatthuṁ hiraññañca, ","html":"<span class='verse-line'>{}</span>"},"ja480:6.4":{"pli":"gavāssaṁ dāsaporisaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja480:6.5":{"pli":"Yena jātena jīyanti, ","html":"<span class='verse-line'>{}</span>"},"ja480:6.6":{"pli":"so doso na mayī vase”. ","html":"<span class='verse-line'>{}</span></p>"},"ja480:7.1":{"pli":"“Etasmiṁ te sulapite, ","html":"<p><span class='verse-line'>{}</span>"},"ja480:7.2":{"pli":"patirūpe subhāsite; ","html":"<span class='verse-line'>{}</span>"},"ja480:7.3":{"pli":"Varaṁ kassapa te dammi, ","html":"<span class='verse-line'>{}</span>"},"ja480:7.4":{"pli":"yaṁ kiñci manasicchasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja480:8.1":{"pli":"“Varañce me ado sakka, ","html":"<p><span class='verse-line'>{}</span>"},"ja480:8.2":{"pli":"sabbabhūtānamissara; ","html":"<span class='verse-line'>{}</span>"},"ja480:8.3":{"pli":"Bālaṁ na passe na suṇe, ","html":"<span class='verse-line'>{}</span>"},"ja480:8.4":{"pli":"na ca bālena saṁvase; ","html":"<span class='verse-line'>{}</span>"},"ja480:8.5":{"pli":"Bālenallāpasallāpaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja480:8.6":{"pli":"na kare na ca rocaye”. ","html":"<span class='verse-line'>{}</span></p>"},"ja480:9.1":{"pli":"“Kiṁ nu te akaraṁ bālo, ","html":"<p><span class='verse-line'>{}</span>"},"ja480:9.2":{"pli":"vada kassapa kāraṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja480:9.3":{"pli":"Kena kassapa bālassa, ","html":"<span class='verse-line'>{}</span>"},"ja480:9.4":{"pli":"dassanaṁ nābhikaṅkhasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja480:10.1":{"pli":"“Anayaṁ nayati dummedho, ","html":"<p><span class='verse-line'>{}</span>"},"ja480:10.2":{"pli":"adhurāyaṁ niyuñjati; ","html":"<span class='verse-line'>{}</span>"},"ja480:10.3":{"pli":"Dunnayo seyyaso hoti, ","html":"<span class='verse-line'>{}</span>"},"ja480:10.4":{"pli":"sammā vutto pakuppati; ","html":"<span class='verse-line'>{}</span>"},"ja480:10.5":{"pli":"Vinayaṁ so na jānāti, ","html":"<span class='verse-line'>{}</span>"},"ja480:10.6":{"pli":"sādhu tassa adassanaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja480:11.1":{"pli":"“Etasmiṁ te sulapite, ","html":"<p><span class='verse-line'>{}</span>"},"ja480:11.2":{"pli":"patirūpe subhāsite; ","html":"<span class='verse-line'>{}</span>"},"ja480:11.3":{"pli":"Varaṁ kassapa te dammi, ","html":"<span class='verse-line'>{}</span>"},"ja480:11.4":{"pli":"yaṁ kiñci manasicchasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja480:12.1":{"pli":"“Varañce me ado sakka, ","html":"<p><span class='verse-line'>{}</span>"},"ja480:12.2":{"pli":"sabbabhūtānamissara; ","html":"<span class='verse-line'>{}</span>"},"ja480:12.3":{"pli":"Dhīraṁ passe suṇe dhīraṁ, ","html":"<span class='verse-line'>{}</span>"},"ja480:12.4":{"pli":"dhīrena saha saṁvase; ","html":"<span class='verse-line'>{}</span>"},"ja480:12.5":{"pli":"Dhīrenallāpasallāpaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja480:12.6":{"pli":"taṁ kare tañca rocaye”. ","html":"<span class='verse-line'>{}</span></p>"},"ja480:13.1":{"pli":"“Kiṁ nu te akaraṁ dhīro, ","html":"<p><span class='verse-line'>{}</span>"},"ja480:13.2":{"pli":"vada kassapa kāraṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja480:13.3":{"pli":"Kena kassapa dhīrassa, ","html":"<span class='verse-line'>{}</span>"},"ja480:13.4":{"pli":"dassanaṁ abhikaṅkhasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja480:14.1":{"pli":"“Nayaṁ nayati medhāvī, ","html":"<p><span class='verse-line'>{}</span>"},"ja480:14.2":{"pli":"adhurāyaṁ na yuñjati; ","html":"<span class='verse-line'>{}</span>"},"ja480:14.3":{"pli":"Sunayo seyyaso hoti, ","html":"<span class='verse-line'>{}</span>"},"ja480:14.4":{"pli":"sammā vutto na kuppati; ","html":"<span class='verse-line'>{}</span>"},"ja480:14.5":{"pli":"Vinayaṁ so pajānāti, ","html":"<span class='verse-line'>{}</span>"},"ja480:14.6":{"pli":"sādhu tena samāgamo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja480:15.1":{"pli":"“Etasmiṁ te sulapite, ","html":"<p><span class='verse-line'>{}</span>"},"ja480:15.2":{"pli":"patirūpe subhāsite; ","html":"<span class='verse-line'>{}</span>"},"ja480:15.3":{"pli":"Varaṁ kassapa te dammi, ","html":"<span class='verse-line'>{}</span>"},"ja480:15.4":{"pli":"yaṁ kiñci manasicchasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja480:16.1":{"pli":"“Varañce me ado sakka, ","html":"<p><span class='verse-line'>{}</span>"},"ja480:16.2":{"pli":"sabbabhūtānamissara; ","html":"<span class='verse-line'>{}</span>"},"ja480:16.3":{"pli":"Tato ratyā vivasāne, ","html":"<span class='verse-line'>{}</span>"},"ja480:16.4":{"pli":"sūriyuggamanaṁ pati; ","html":"<span class='verse-line'>{}</span>"},"ja480:16.5":{"pli":"Dibbā bhakkhā pātubhaveyyuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja480:16.6":{"pli":"sīlavanto ca yācakā. ","html":"<span class='verse-line'>{}</span></p>"},"ja480:17.1":{"pli":"Dadato me na khīyetha, ","html":"<p><span class='verse-line'>{}</span>"},"ja480:17.2":{"pli":"datvā nānutapeyyahaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja480:17.3":{"pli":"Dadaṁ cittaṁ pasādeyyaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja480:17.4":{"pli":"etaṁ sakka varaṁ vare”. ","html":"<span class='verse-line'>{}</span></p>"},"ja480:18.1":{"pli":"“Etasmiṁ te sulapite, ","html":"<p><span class='verse-line'>{}</span>"},"ja480:18.2":{"pli":"patirūpe subhāsite; ","html":"<span class='verse-line'>{}</span>"},"ja480:18.3":{"pli":"Varaṁ kassapa te dammi, ","html":"<span class='verse-line'>{}</span>"},"ja480:18.4":{"pli":"yaṁ kiñci manasicchasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja480:19.1":{"pli":"“Varañce me ado sakka, ","html":"<p><span class='verse-line'>{}</span>"},"ja480:19.2":{"pli":"sabbabhūtānamissara; ","html":"<span class='verse-line'>{}</span>"},"ja480:19.3":{"pli":"Na maṁ puna upeyyāsi, ","html":"<span class='verse-line'>{}</span>"},"ja480:19.4":{"pli":"etaṁ sakka varaṁ vare”. ","html":"<span class='verse-line'>{}</span></p>"},"ja480:20.1":{"pli":"“Bahūhi vatacariyāhi, ","html":"<p><span class='verse-line'>{}</span>"},"ja480:20.2":{"pli":"narā ca atha nāriyo; ","html":"<span class='verse-line'>{}</span>"},"ja480:20.3":{"pli":"Dassanaṁ abhikaṅkhanti, ","html":"<span class='verse-line'>{}</span>"},"ja480:20.4":{"pli":"kiṁ nu me dassane bhayaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja480:21.1":{"pli":"“Taṁ tādisaṁ devavaṇṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja480:21.2":{"pli":"sabbakāmasamiddhinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja480:21.3":{"pli":"Disvā tapo pamajjeyyaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja480:21.4":{"pli":"etaṁ te dassane bhayan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja480:22.1":{"pli":"Akittijātakaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja481":{"ja481:0.1":{"pli":"Jātaka ","html":"<article id='ja481'><header><ul><li class='division'>{}</li>"},"ja481:0.2":{"pli":"Terasakanipāta ","html":"<li>{}</li>"},"ja481:0.3":{"pli":"Ambavagga ","html":"<li>{}</li></ul>"},"ja481:0.4":{"pli":"8. Takkāriyajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja481:1.1":{"pli":"“Ahameva dubbhāsitaṁ bhāsi bālo, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja481:1.2":{"pli":"Bhekovaraññe ahimavhāyamāno; ","html":"<span class='verse-line'>{}</span>"},"ja481:1.3":{"pli":"Takkāriye sobbhamimaṁ patāmi, ","html":"<span class='verse-line'>{}</span>"},"ja481:1.4":{"pli":"Na kireva sādhu ativelabhāṇī”. ","html":"<span class='verse-line'>{}</span></p>"},"ja481:2.1":{"pli":"“Pappoti macco ativelabhāṇī, ","html":"<p><span class='verse-line'>{}</span>"},"ja481:2.2":{"pli":"Bandhaṁ vadhaṁ sokapariddavañca; ","html":"<span class='verse-line'>{}</span>"},"ja481:2.3":{"pli":"Attānameva garahāsi ettha, ","html":"<span class='verse-line'>{}</span>"},"ja481:2.4":{"pli":"Ācera yaṁ taṁ nikhaṇanti sobbhe”. ","html":"<span class='verse-line'>{}</span></p>"},"ja481:3.1":{"pli":"“Kimevahaṁ tuṇḍilamanupucchiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja481:3.2":{"pli":"Kareyya saṁ bhātaraṁ kāḷikāyaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja481:3.3":{"pli":"Naggovahaṁ vatthayugañca jīno, ","html":"<span class='verse-line'>{}</span>"},"ja481:3.4":{"pli":"Ayampi attho bahutādisova”. ","html":"<span class='verse-line'>{}</span></p>"},"ja481:4.1":{"pli":"“Yo yujjhamānānamayujjhamāno, ","html":"<p><span class='verse-line'>{}</span>"},"ja481:4.2":{"pli":"Meṇḍantaraṁ accupatī kuliṅgo; ","html":"<span class='verse-line'>{}</span>"},"ja481:4.3":{"pli":"So piṁsito meṇḍasirehi tattha, ","html":"<span class='verse-line'>{}</span>"},"ja481:4.4":{"pli":"Ayampi attho bahutādisova. ","html":"<span class='verse-line'>{}</span></p>"},"ja481:5.1":{"pli":"Caturo janā potthakamaggahesuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja481:5.2":{"pli":"Ekañca posaṁ anurakkhamānā; ","html":"<span class='verse-line'>{}</span>"},"ja481:5.3":{"pli":"Sabbeva te bhinnasirā sayiṁsu, ","html":"<span class='verse-line'>{}</span>"},"ja481:5.4":{"pli":"Ayampi attho bahutādisova. ","html":"<span class='verse-line'>{}</span></p>"},"ja481:6.1":{"pli":"Ajā yathā veḷugumbasmiṁ baddhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja481:6.2":{"pli":"Avakkhipantī asimajjhagacchi; ","html":"<span class='verse-line'>{}</span>"},"ja481:6.3":{"pli":"Teneva tassā galakāvakantaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja481:6.4":{"pli":"Ayampi attho bahutādisova”. ","html":"<span class='verse-line'>{}</span></p>"},"ja481:7.1":{"pli":"“Ime na devā na gandhabbaputtā, ","html":"<p><span class='verse-line'>{}</span>"},"ja481:7.2":{"pli":"Migā ime atthavasaṁ gatā me; ","html":"<span class='verse-line'>{}</span>"},"ja481:7.3":{"pli":"Ekañca naṁ sāyamāse pacantu, ","html":"<span class='verse-line'>{}</span>"},"ja481:7.4":{"pli":"Ekaṁ punappātarāse pacantu”. ","html":"<span class='verse-line'>{}</span></p>"},"ja481:8.1":{"pli":"“Sataṁ sahassāni dubhāsitāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja481:8.2":{"pli":"Kalampi nāgghanti subhāsitassa; ","html":"<span class='verse-line'>{}</span>"},"ja481:8.3":{"pli":"Dubbhāsitaṁ saṅkamāno kileso, ","html":"<span class='verse-line'>{}</span>"},"ja481:8.4":{"pli":"Tasmā tuṇhī kimpurisā na bālyā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja481:9.1":{"pli":"“Yā mesā byāhāsi pamuñcathetaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja481:9.2":{"pli":"Giriñca naṁ himavantaṁ nayantu; ","html":"<span class='verse-line'>{}</span>"},"ja481:9.3":{"pli":"Imañca kho dentu mahānasāya, ","html":"<span class='verse-line'>{}</span>"},"ja481:9.4":{"pli":"Pātova naṁ pātarāse pacantu”. ","html":"<span class='verse-line'>{}</span></p>"},"ja481:10.1":{"pli":"“Pajjunnanāthā pasavo, ","html":"<p><span class='verse-line'>{}</span>"},"ja481:10.2":{"pli":"pasunāthā ayaṁ pajā; ","html":"<span class='verse-line'>{}</span>"},"ja481:10.3":{"pli":"Tvaṁ nāthosi mahārāja, ","html":"<span class='verse-line'>{}</span>"},"ja481:10.4":{"pli":"nāthohaṁ bhariyāya me; ","html":"<span class='verse-line'>{}</span>"},"ja481:10.5":{"pli":"Dvinnamaññataraṁ ñatvā, ","html":"<span class='verse-line'>{}</span>"},"ja481:10.6":{"pli":"mutto gaccheyya pabbataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja481:11.1":{"pli":"Na ve nindā suparivajjayetha, ","html":"<p><span class='verse-line'>{}</span>"},"ja481:11.2":{"pli":"Nānā janā sevitabbā janinda; ","html":"<span class='verse-line'>{}</span>"},"ja481:11.3":{"pli":"Yeneva eko labhate pasaṁsaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja481:11.4":{"pli":"Teneva añño labhate ninditāraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja481:12.1":{"pli":"Sabbo loko paricitto aticitto, ","html":"<p><span class='verse-line'>{}</span>"},"ja481:12.2":{"pli":"Sabbo loko cittavā samhi citte; ","html":"<span class='verse-line'>{}</span>"},"ja481:12.3":{"pli":"Paccekacittā puthu sabbasattā, ","html":"<span class='verse-line'>{}</span>"},"ja481:12.4":{"pli":"Kassīdha cittassa vasena vatte”. ","html":"<span class='verse-line'>{}</span></p>"},"ja481:13.1":{"pli":"“Tuṇhī ahū kimpuriso sabhariyo, ","html":"<p><span class='verse-line'>{}</span>"},"ja481:13.2":{"pli":"Yo dāni byāhāsi bhayassa bhīto; ","html":"<span class='verse-line'>{}</span>"},"ja481:13.3":{"pli":"So dāni mutto sukhito arogo, ","html":"<span class='verse-line'>{}</span>"},"ja481:13.4":{"pli":"Vācākirevatthavatī narānan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja481:14.1":{"pli":"Takkāriyajātakaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja482":{"ja482:0.1":{"pli":"Jātaka ","html":"<article id='ja482'><header><ul><li class='division'>{}</li>"},"ja482:0.2":{"pli":"Terasakanipāta ","html":"<li>{}</li>"},"ja482:0.3":{"pli":"Ambavagga ","html":"<li>{}</li></ul>"},"ja482:0.4":{"pli":"9. Rurumigarājajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja482:1.1":{"pli":"“Tassa gāmavaraṁ dammi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja482:1.2":{"pli":"Nāriyo ca alaṅkatā; ","html":"<span class='verse-line'>{}</span>"},"ja482:1.3":{"pli":"Yo metaṁ migamakkhāti, ","html":"<span class='verse-line'>{}</span>"},"ja482:1.4":{"pli":"Migānaṁ migamuttamaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja482:2.1":{"pli":"“Mayhaṁ gāmavaraṁ dehi, ","html":"<p><span class='verse-line'>{}</span>"},"ja482:2.2":{"pli":"nāriyo ca alaṅkatā; ","html":"<span class='verse-line'>{}</span>"},"ja482:2.3":{"pli":"Ahaṁ te migamakkhissaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja482:2.4":{"pli":"migānaṁ migamuttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja482:3.1":{"pli":"Etasmiṁ vanasaṇḍasmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja482:3.2":{"pli":"ambā sālā ca pupphitā; ","html":"<span class='verse-line'>{}</span>"},"ja482:3.3":{"pli":"Indagopakasañchannā, ","html":"<span class='verse-line'>{}</span>"},"ja482:3.4":{"pli":"ettheso tiṭṭhate migo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja482:4.1":{"pli":"“Dhanuṁ advejjhaṁ katvāna, ","html":"<p><span class='verse-line'>{}</span>"},"ja482:4.2":{"pli":"usuṁ sannayhupāgami; ","html":"<span class='verse-line'>{}</span>"},"ja482:4.3":{"pli":"Migo ca disvā rājānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja482:4.4":{"pli":"dūrato ajjhabhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"ja482:5.1":{"pli":"Āgamehi mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja482:5.2":{"pli":"mā maṁ vijjhi rathesabha; ","html":"<span class='verse-line'>{}</span>"},"ja482:5.3":{"pli":"Ko nu te idamakkhāsi, ","html":"<span class='verse-line'>{}</span>"},"ja482:5.4":{"pli":"ettheso tiṭṭhate migo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja482:6.1":{"pli":"“Esa pāpacaro poso, ","html":"<p><span class='verse-line'>{}</span>"},"ja482:6.2":{"pli":"samma tiṭṭhati ārakā; ","html":"<span class='verse-line'>{}</span>"},"ja482:6.3":{"pli":"Soyaṁ me idamakkhāsi, ","html":"<span class='verse-line'>{}</span>"},"ja482:6.4":{"pli":"ettheso tiṭṭhate migo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja482:7.1":{"pli":"“Saccaṁ kireva māhaṁsu, ","html":"<p><span class='verse-line'>{}</span>"},"ja482:7.2":{"pli":"narā ekacciyā idha; ","html":"<span class='verse-line'>{}</span>"},"ja482:7.3":{"pli":"Kaṭṭhaṁ niplavitaṁ seyyo, ","html":"<span class='verse-line'>{}</span>"},"ja482:7.4":{"pli":"na tvevekacciyo naro”. ","html":"<span class='verse-line'>{}</span></p>"},"ja482:8.1":{"pli":"“Kiṁ nu ruru garahasi migānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja482:8.2":{"pli":"Kiṁ pakkhīnaṁ kiṁ pana mānusānaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja482:8.3":{"pli":"Bhayañhi maṁ vindatinapparūpaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja482:8.4":{"pli":"Sutvāna taṁ mānusiṁ bhāsamānaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja482:9.1":{"pli":"“Yamuddhariṁ vāhane vuyhamānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja482:9.2":{"pli":"Mahodake salile sīghasote; ","html":"<span class='verse-line'>{}</span>"},"ja482:9.3":{"pli":"Tatonidānaṁ bhayamāgataṁ mama, ","html":"<span class='verse-line'>{}</span>"},"ja482:9.4":{"pli":"Dukkho have rāja asabbhi saṅgamo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja482:10.1":{"pli":"“Sohaṁ catuppattamimaṁ vihaṅgamaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja482:10.2":{"pli":"Tanucchidaṁ hadaye ossajāmi; ","html":"<span class='verse-line'>{}</span>"},"ja482:10.3":{"pli":"Hanāmi taṁ mittadubbhiṁ akiccakāriṁ, ","html":"<span class='verse-line'>{}</span>"},"ja482:10.4":{"pli":"Yo tādisaṁ kammakataṁ na jāne”. ","html":"<span class='verse-line'>{}</span></p>"},"ja482:11.1":{"pli":"“Dhīrassa bālassa have janinda, ","html":"<p><span class='verse-line'>{}</span>"},"ja482:11.2":{"pli":"Santo vadhaṁ nappasaṁsanti jātu; ","html":"<span class='verse-line'>{}</span>"},"ja482:11.3":{"pli":"Kāmaṁ gharaṁ gacchatu pāpadhammo, ","html":"<span class='verse-line'>{}</span>"},"ja482:11.4":{"pli":"Yañcassa bhaṭṭhaṁ tadetassa dehi; ","html":"<span class='verse-line'>{}</span>"},"ja482:11.5":{"pli":"Ahañca te kāmakaro bhavāmi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja482:12.1":{"pli":"“Addhā rurū aññataro sataṁ so, ","html":"<p><span class='verse-line'>{}</span>"},"ja482:12.2":{"pli":"Yo dubbhato mānusassa na dubbhi; ","html":"<span class='verse-line'>{}</span>"},"ja482:12.3":{"pli":"Kāmaṁ gharaṁ gacchatu pāpadhammo, ","html":"<span class='verse-line'>{}</span>"},"ja482:12.4":{"pli":"Yañcassa bhaṭṭhaṁ tadetassa dammi; ","html":"<span class='verse-line'>{}</span>"},"ja482:12.5":{"pli":"Ahañca te kāmacāraṁ dadāmi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja482:13.1":{"pli":"“Suvijānaṁ siṅgālānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja482:13.2":{"pli":"sakuṇānañca vassitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja482:13.3":{"pli":"Manussavassitaṁ rāja, ","html":"<span class='verse-line'>{}</span>"},"ja482:13.4":{"pli":"dubbijānataraṁ tato. ","html":"<span class='verse-line'>{}</span></p>"},"ja482:14.1":{"pli":"Api ce maññatī poso, ","html":"<p><span class='verse-line'>{}</span>"},"ja482:14.2":{"pli":"ñāti mitto sakhāti vā; ","html":"<span class='verse-line'>{}</span>"},"ja482:14.3":{"pli":"Yo pubbe sumano hutvā, ","html":"<span class='verse-line'>{}</span>"},"ja482:14.4":{"pli":"pacchā sampajjate diso”. ","html":"<span class='verse-line'>{}</span></p>"},"ja482:15.1":{"pli":"“Samāgatā jānapadā, ","html":"<p><span class='verse-line'>{}</span>"},"ja482:15.2":{"pli":"negamā ca samāgatā; ","html":"<span class='verse-line'>{}</span>"},"ja482:15.3":{"pli":"Migā sassāni khādanti, ","html":"<span class='verse-line'>{}</span>"},"ja482:15.4":{"pli":"taṁ devo paṭisedhatu”. ","html":"<span class='verse-line'>{}</span></p>"},"ja482:16.1":{"pli":"“Kāmaṁ janapado māsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja482:16.2":{"pli":"raṭṭhañcāpi vinassatu; ","html":"<span class='verse-line'>{}</span>"},"ja482:16.3":{"pli":"Na tvevāhaṁ ruruṁ dubbhe, ","html":"<span class='verse-line'>{}</span>"},"ja482:16.4":{"pli":"datvā abhayadakkhiṇaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja482:17.1":{"pli":"Mā me janapado āsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja482:17.2":{"pli":"raṭṭhañcāpi vinassatu; ","html":"<span class='verse-line'>{}</span>"},"ja482:17.3":{"pli":"Na tvevāhaṁ migarājassa, ","html":"<span class='verse-line'>{}</span>"},"ja482:17.4":{"pli":"varaṁ datvā musā bhaṇe”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja482:18.1":{"pli":"Rurumigarājajātakaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}