{"ps1.0":{"ps1.0:0.1":{"pli":"Paṭisambhidāmagga ","html":"<article id='ps1.0'><header><ul><li class='division'>{}</li>"},"ps1.0:0.2":{"pli":"1 Mahāvagga ","html":"<li>{}</li></ul>"},"ps1.0:0.3":{"pli":"1.0 Mātikā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ps1.0:0.4":{"pli":"Namo tassa Bhagavato Arahato Sammāsambuddhassa. ","html":"<p class='namo'>{}</p>"},"ps1.0:1.1":{"pli":"Sotāvadhāne paññā sutamaye ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:2.1":{"pli":"Sutvāna saṁvare paññā sīlamaye ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:3.1":{"pli":"Saṁvaritvā samādahane paññā samādhibhāvanāmaye ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:4.1":{"pli":"Paccayapariggahe paññā dhammaṭṭhitiñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:5.1":{"pli":"Atītānāgatapaccuppannānaṁ dhammānaṁ saṅkhipitvā vavatthāne paññā sammasane ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:6.1":{"pli":"Paccuppannānaṁ dhammānaṁ vipariṇāmānupassane paññā udayabbayānupassane ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:7.1":{"pli":"Ārammaṇaṁ paṭisaṅkhā bhaṅgānupassane paññā vipassane ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:8.1":{"pli":"Bhayatupaṭṭhāne paññā ādīnave ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:9.1":{"pli":"Muñcitukamyatāpaṭisaṅkhāsantiṭṭhanā paññā saṅkhārupekkhāsu ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:10.1":{"pli":"Bahiddhā vuṭṭhānavivaṭṭane paññā gotrabhuñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:11.1":{"pli":"Dubhato vuṭṭhānavivaṭṭane paññā magge ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:12.1":{"pli":"Payogappaṭippassaddhi paññā phale ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:13.1":{"pli":"Chinnavaṭumānupassane paññā vimuttiñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:14.1":{"pli":"Tadā samudāgate dhamme passane paññā paccavekkhaṇe ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:15.1":{"pli":"Ajjhattavavatthāne paññā vatthunānatte ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:16.1":{"pli":"Bahiddhāvavatthāne paññā gocaranānatte ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:17.1":{"pli":"Cariyāvavatthāne paññā cariyānānatte ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:18.1":{"pli":"Catudhammavavatthāne paññā bhūminānatte ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:19.1":{"pli":"Navadhammavavatthāne paññā dhammanānatte ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:20.1":{"pli":"Abhiññāpaññā ñātaṭṭhe ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:21.1":{"pli":"Pariññāpaññā tīraṇaṭṭhe ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:22.1":{"pli":"Pahāne paññā pariccāgaṭṭhe ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:23.1":{"pli":"Bhāvanāpaññā ekarasaṭṭhe ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:24.1":{"pli":"Sacchikiriyāpaññā phassanaṭṭhe ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:25.1":{"pli":"Atthanānatte paññā atthapaṭisambhide ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:26.1":{"pli":"Dhammanānatte paññā dhammapaṭisambhide ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:27.1":{"pli":"Niruttinānatte paññā niruttipaṭisambhide ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:28.1":{"pli":"Paṭibhānanānatte paññā paṭibhānapaṭisambhide ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:29.1":{"pli":"Vihāranānatte paññā vihāraṭṭhe ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:30.1":{"pli":"Samāpattinānatte paññā samāpattaṭṭhe ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:31.1":{"pli":"Vihārasamāpattinānatte paññā vihārasamāpattaṭṭhe ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:32.1":{"pli":"Avikkhepaparisuddhattā āsavasamucchede paññā ānantarikasamādhimhi ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:33.1":{"pli":"Dassanādhipateyyaṁ santo ca vihārādhigamo paṇītādhimuttatā paññā araṇavihāre ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:34.1":{"pli":"Dvīhi balehi samannāgatattā tayo ca saṅkhārānaṁ paṭippassaddhiyā soḷasahi ñāṇacariyāhi navahi samādhicariyāhi vasibhāvatā paññā nirodhasamāpattiyā ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:35.1":{"pli":"Sampajānassa pavattapariyādāne paññā parinibbāne ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:36.1":{"pli":"Sabbadhammānaṁ sammā samucchede nirodhe ca anupaṭṭhānatā paññā samasīsaṭṭhe ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:37.1":{"pli":"Puthunānattatejapariyādāne paññā sallekhaṭṭhe ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:38.1":{"pli":"Asallīnattapahitattapaggahaṭṭhe paññā vīriyārambhe ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:39.1":{"pli":"Nānādhammappakāsanatā paññā atthasandassane ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:40.1":{"pli":"Sabbadhammānaṁ ekasaṅgahatānānattekattapaṭivedhe paññā dassanavisuddhiñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:41.1":{"pli":"Viditattā paññā khantiñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:42.1":{"pli":"Phuṭṭhattā paññā pariyogāhaṇe ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:43.1":{"pli":"Samodahane paññā padesavihāre ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:44.1":{"pli":"Adhipatattā paññā saññāvivaṭṭe ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:45.1":{"pli":"Nānatte paññā cetovivaṭṭe ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:46.1":{"pli":"Adhiṭṭhāne paññā cittavivaṭṭe ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:47.1":{"pli":"Suññate paññā ñāṇavivaṭṭe ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:48.1":{"pli":"Vosagge paññā vimokkhavivaṭṭe ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:49.1":{"pli":"Tathaṭṭhe paññā saccavivaṭṭe ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:50.1":{"pli":"Kāyampi cittampi ekavavatthānatā sukhasaññañca lahusaññañca adhiṭṭhānavasena ijjhanaṭṭhe paññā iddhividhe ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:51.1":{"pli":"Vitakkavipphāravasena nānattekattasaddanimittānaṁ pariyogāhaṇe paññā sotadhātuvisuddhiñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:52.1":{"pli":"Tiṇṇannaṁ cittānaṁ vipphārattā indriyānaṁ pasādavasena nānattekattaviññāṇacariyā pariyogāhaṇe paññā cetopariyañāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:53.1":{"pli":"Paccayappavattānaṁ dhammānaṁ nānattekattakammavipphāravasena pariyogāhaṇe paññā pubbenivāsānussatiñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:54.1":{"pli":"Obhāsavasena nānattekattarūpanimittānaṁ dassanaṭṭhe paññā dibbacakkhuñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:55.1":{"pli":"Catusaṭṭhiyā ākārehi tiṇṇannaṁ indriyānaṁ vasibhāvatā paññā āsavānaṁ khaye ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:56.1":{"pli":"Pariññaṭṭhe paññā dukkhe ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:57.1":{"pli":"Pahānaṭṭhe paññā samudaye ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:58.1":{"pli":"Sacchikiriyaṭṭhe paññā nirodhe ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:59.1":{"pli":"Bhāvanaṭṭhe paññā magge ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:60.1":{"pli":"Dukkhe ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:61.1":{"pli":"Dukkhasamudaye ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:62.1":{"pli":"Dukkhanirodhe ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:63.1":{"pli":"Dukkhanirodhagāminiyā paṭipadāya ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:64.1":{"pli":"Atthapaṭisambhide ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:65.1":{"pli":"Dhammapaṭisambhide ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:66.1":{"pli":"Niruttipaṭisambhide ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:67.1":{"pli":"Paṭibhānapaṭisambhide ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:68.1":{"pli":"Indriyaparopariyattañāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:69.1":{"pli":"Sattānaṁ āsayānusaye ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:70.1":{"pli":"Yamakapāṭihīre ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:71.1":{"pli":"Mahākaruṇāsamāpattiyā ñāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:72.1":{"pli":"Sabbaññutaññāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:73.1":{"pli":"Anāvaraṇañāṇaṁ. ","html":"<p>{}</p>"},"ps1.0:74.1":{"pli":"Imāni tesattati ñāṇāni. ","html":"<p>{}"},"ps1.0:74.2":{"pli":"Imesaṁ tesattatiyā ñāṇānaṁ sattasaṭṭhi ñāṇāni sāvakasādhāraṇāni; ","html":"{}"},"ps1.0:74.3":{"pli":"cha ñāṇāni asādhāraṇāni sāvakehi. ","html":"{}</p>"},"ps1.0:74.4":{"pli":"Mātikā niṭṭhitā. ","html":"<p class='endsutta'>{}</p></article>"}}}