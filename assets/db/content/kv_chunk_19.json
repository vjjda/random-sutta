{"kv2.4":{"kv2.4:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv2.4'><header><ul><li class='division'>{}</li>"},"kv2.4:0.2":{"pli":"Mahāpaṇṇāsaka ","html":"<li>{}</li>"},"kv2.4:0.3":{"pli":"Dutiyavagga ","html":"<li>{}</li></ul>"},"kv2.4:0.4":{"pli":"Paravitāraṇakathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv2.4:1.1":{"pli":"Atthi arahato paravitāraṇāti? ","html":"<p data-doxy='orthodox'>{}"},"kv2.4:1.2":{"pli":"Āmantā. ","html":"{}"},"kv2.4:1.3":{"pli":"Arahā paraneyyo parapattiyo parapaccayo parapaṭibaddhabhū, na jānāti na passati sammūḷho asampajānoti? ","html":"{}"},"kv2.4:1.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv2.4:2.1":{"pli":"Nanu arahā na paraneyyo na parapattiyo na parapaccayo na parapaṭibaddhabhū jānāti passati asammūḷho sampajānoti? ","html":"<p data-doxy='orthodox'>{}"},"kv2.4:2.2":{"pli":"Āmantā. ","html":"{}"},"kv2.4:2.3":{"pli":"Hañci arahā na paraneyyo na parapattiyo na parapaccayo na parapaṭibaddhabhū, jānāti passati asammūḷho sampajāno, no ca vata re vattabbe—","html":"{}"},"kv2.4:2.4":{"pli":"“atthi arahato paravitāraṇā”ti. ","html":"{}</p>"},"kv2.4:3.1":{"pli":"Atthi puthujjanassa paravitāraṇā, so ca paraneyyo parapattiyo parapaccayo parapaṭibaddhabhū, na jānāti na passati sammūḷho asampajānoti? ","html":"<p data-doxy='orthodox'>{}"},"kv2.4:3.2":{"pli":"Āmantā. ","html":"{}"},"kv2.4:3.3":{"pli":"Atthi arahato paravitāraṇā, so ca paraneyyo parapattiyo parapaccayo parapaṭibaddhabhū, na jānāti na passati sammūḷho asampajānoti? ","html":"{}"},"kv2.4:3.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv2.4:4.1":{"pli":"Atthi arahato paravitāraṇā, so ca na paraneyyo na parapattiyo na parapaccayo na parapaṭibaddhabhū, jānāti passati asammūḷho sampajānoti? ","html":"<p data-doxy='orthodox'>{}"},"kv2.4:4.2":{"pli":"Āmantā. ","html":"{}"},"kv2.4:4.3":{"pli":"Atthi puthujjanassa paravitāraṇā, so ca na paraneyyo na parapattiyo na parapaccayo na parapaṭibaddhabhū, jānāti passati asammūḷho sampajānoti? ","html":"{}"},"kv2.4:4.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv2.4:5.1":{"pli":"Atthi arahato paravitāraṇāti? ","html":"<p data-doxy='orthodox'>{}"},"kv2.4:5.2":{"pli":"Āmantā. ","html":"{}"},"kv2.4:5.3":{"pli":"Atthi arahato satthari paravitāraṇā, dhamme paravitāraṇā, saṅghe paravitāraṇā, sikkhāya paravitāraṇā, pubbante paravitāraṇā, aparante paravitāraṇā, pubbantāparante paravitāraṇā, idappaccayatāpaṭiccasamuppannesu dhammesu paravitāraṇāti? ","html":"{}"},"kv2.4:5.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv2.4:6.1":{"pli":"Natthi arahato satthari paravitāraṇā, dhamme paravitāraṇā …pe… idappaccayatāpaṭiccasamuppannesu dhammesu paravitāraṇāti? ","html":"<p data-doxy='orthodox'>{}"},"kv2.4:6.2":{"pli":"Āmantā. ","html":"{}"},"kv2.4:6.3":{"pli":"Hañci natthi arahato satthari paravitāraṇā, dhamme paravitāraṇā …pe… idappaccayatāpaṭiccasamuppannesu dhammesu paravitāraṇā, no ca vata re vattabbe—","html":"{}"},"kv2.4:6.4":{"pli":"“atthi arahato paravitāraṇā”ti. ","html":"{}</p>"},"kv2.4:7.1":{"pli":"Atthi puthujjanassa paravitāraṇā, atthi tassa satthari paravitāraṇā, dhamme paravitāraṇā …pe… idappaccayatāpaṭiccasamuppannesu dhammesu paravitāraṇāti? ","html":"<p data-doxy='orthodox'>{}"},"kv2.4:7.2":{"pli":"Āmantā. ","html":"{}"},"kv2.4:7.3":{"pli":"Atthi arahato paravitāraṇā, atthi tassa satthari paravitāraṇā, dhamme paravitāraṇā …pe… idappaccayatāpaṭiccasamuppannesu dhammesu paravitāraṇāti? ","html":"{}"},"kv2.4:7.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv2.4:8.1":{"pli":"Atthi arahato paravitāraṇā, natthi tassa satthari paravitāraṇā, dhamme paravitāraṇā …pe… idappaccayatāpaṭiccasamuppannesu dhammesu paravitāraṇāti? ","html":"<p data-doxy='orthodox'>{}"},"kv2.4:8.2":{"pli":"Āmantā. ","html":"{}"},"kv2.4:8.3":{"pli":"Atthi puthujjanassa paravitāraṇā, natthi tassa satthari paravitāraṇā, dhamme paravitāraṇā …pe… idappaccayatāpaṭiccasamuppannesu dhammesu paravitāraṇāti? ","html":"{}"},"kv2.4:8.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p