{"bv7":{"bv7:0.1":{"pli":"Buddhavaṁsa ","html":"<article id='bv7'><header><ul><li class='division'>{}</li></ul>"},"bv7:0.2":{"pli":"7. Revatabuddhavaṁsa ","html":"<h1 class='sutta-title'>{}</h1></header>"},"bv7:1.1":{"pli":"Sumanassa aparena, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"bv7:1.2":{"pli":"revato nāma nāyako; ","html":"<span class='verse-line'>{}</span>"},"bv7:1.3":{"pli":"Anūpamo asadiso, ","html":"<span class='verse-line'>{}</span>"},"bv7:1.4":{"pli":"atulo uttamo jino. ","html":"<span class='verse-line'>{}</span></p>"},"bv7:2.1":{"pli":"Sopi dhammaṁ pakāsesi, ","html":"<p><span class='verse-line'>{}</span>"},"bv7:2.2":{"pli":"brahmunā abhiyācito; ","html":"<span class='verse-line'>{}</span>"},"bv7:2.3":{"pli":"Khandhadhātuvavatthānaṁ, ","html":"<span class='verse-line'>{}</span>"},"bv7:2.4":{"pli":"appavattaṁ bhavābhave. ","html":"<span class='verse-line'>{}</span></p>"},"bv7:3.1":{"pli":"Tassābhisamayā tīṇi, ","html":"<p><span class='verse-line'>{}</span>"},"bv7:3.2":{"pli":"ahesuṁ dhammadesane; ","html":"<span class='verse-line'>{}</span>"},"bv7:3.3":{"pli":"Gaṇanāya na vattabbo, ","html":"<span class='verse-line'>{}</span>"},"bv7:3.4":{"pli":"paṭhamābhisamayo ahu. ","html":"<span class='verse-line'>{}</span></p>"},"bv7:4.1":{"pli":"Yadā arindamaṁ rājaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"bv7:4.2":{"pli":"vinesi revato muni; ","html":"<span class='verse-line'>{}</span>"},"bv7:4.3":{"pli":"Tadā koṭisahassānaṁ, ","html":"<span class='verse-line'>{}</span>"},"bv7:4.4":{"pli":"dutiyābhisamayo ahu. ","html":"<span class='verse-line'>{}</span></p>"},"bv7:5.1":{"pli":"Sattāhaṁ paṭisallānā, ","html":"<p><span class='verse-line'>{}</span>"},"bv7:5.2":{"pli":"vuṭṭhahitvā narāsabho; ","html":"<span class='verse-line'>{}</span>"},"bv7:5.3":{"pli":"Koṭisataṁ naramarūnaṁ, ","html":"<span class='verse-line'>{}</span>"},"bv7:5.4":{"pli":"vinesi uttame phale. ","html":"<span class='verse-line'>{}</span></p>"},"bv7:6.