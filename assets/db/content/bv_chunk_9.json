tml":"<span class='verse-line'>{}</span>"},"bv7:11.4":{"pli":"uttarīyamadāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"bv7:12.1":{"pli":"Sopi maṁ buddho byākāsi, ","html":"<p><span class='verse-line'>{}</span>"},"bv7:12.2":{"pli":"revato lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"bv7:12.3":{"pli":"“Aparimeyyito kappe, ","html":"<span class='verse-line'>{}</span>"},"bv7:12.4":{"pli":"ayaṁ buddho bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"bv7:13.1":{"pli":"‘Padhānaṁ padahitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"bv7:13.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"bv7:13.3":{"pli":"hessāma sammukhā imaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"bv7:14.1":{"pli":"Tassāpi vacanaṁ sutvā, ","html":"<p><span class='verse-line'>{}</span>"},"bv7:14.2":{"pli":"bhiyyo cittaṁ pasādayiṁ; ","html":"<span class='verse-line'>{}</span>"},"bv7:14.3":{"pli":"Uttariṁ vatamadhiṭṭhāsiṁ, ","html":"<span class='verse-line'>{}</span>"},"bv7:14.4":{"pli":"dasapāramipūriyā. ","html":"<span class='verse-line'>{}</span></p>"},"bv7:15.1":{"pli":"Tadāpi taṁ buddhadhammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"bv7:15.2":{"pli":"saritvā anubrūhayiṁ; ","html":"<span class='verse-line'>{}</span>"},"bv7:15.3":{"pli":"Āharissāmi taṁ dhammaṁ, ","html":"<span class='verse-line'>{}</span>"},"bv7:15.4":{"pli":"yaṁ mayhaṁ abhipatthitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"bv7:16.1":{"pli":"Nagaraṁ sudhaññavatī nāma, ","html":"<p><span class='verse-line'>{}</span>"},"bv7:16.2":{"pli":"Vipulo nāma khattiyo; ","html":"<span class='verse-line'>{}</span>"},"bv7:16.3":{"pli":"Vipulā nāma janikā, ","html":"<span class='verse-line'>{}</span>"},"bv7:16.4":{"pli":"Revatassa mahesino. ","html":"<span class='verse-line'>{}</span></p>"},"bv7:17.1":{"pli":"Cha ca vassasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"bv7:17.2":{"pli":"agāraṁ ajjha so vasi; ","html":"<span class='verse-line'>{}</span>"},"bv7:17.3":{"pli":"Sudassano ratanagghi, ","html":"<span class='verse-line'>{}</span>"},"bv7:17.4":{"pli":"āveḷo ca vibhūsito; ","html":"<span class='verse-line'>{}</span>"},"bv7:17.5":{"pli":"Puññakammābhinibbattā, ","html":"<span class='verse-line'>{}</span>"},"bv7:17.6":{"pli":"tayo pāsādamuttamā. ","html":"<span class='verse-line'>{}</span></p>"},"bv7:18.1":{"pli":"Tettiṁsa ca sahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"bv7:18.2":{"pli":"nāriyo samalaṅkatā; ","html":"<span class='verse-line'>{}</span>"},"bv7:18.3":{"pli":"Sudassanā nāma nārī, ","html":"<span class='verse-line'>{}</span>"},"bv7:18.4":{"pli":"varuṇo nāma atrajo. ","html":"<span class='verse-line'>{}</span></p>"},"bv7:19.1":{"pli":"Nimitte caturo disvā, ","html":"<p><span class='verse-line'>{}</span>"},"bv7:19.2":{"pli":"rathayānena nikkhami; ","html":"<span class='verse-line'>{}</span>"},"bv7:19.3":{"pli":"Anūnasattamāsāni, ","html":"<span class='verse-line'>{}</span>"},"bv7:19.4":{"pli":"padhānaṁ padahī jino. ","html":"<span class='verse-line'>{}</span></p>"},"bv7:20.1":{"pli":"Brahmunā yācito santo, ","html":"<p><span class='verse-line'>{}</span>"},"bv7:20.2":{"pli":"revato lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"bv7:20.3":{"pli":"Vatti cakkaṁ mahāvīro, ","html":"<span class='verse-line'>{}</span>"},"bv7:20.4":{"pli":"varuṇārāme sirīghare. ","html":"<span class='verse-line'>{}</span></p>"},"bv7:21.1":{"pli":"Varuṇo brahmadevo ca, ","html":"<p><span class='verse-line'>{}</span>"},"bv7:21.2":{"pli":"ahesuṁ aggasāvakā; ","html":"<span class='verse-line'>{}</span>"},"bv7:21.3":{"pli":"Sambhavo nāmupaṭṭhāko, ","html":"<span class='verse-line'>{}</span>"},"bv7:21.4":{"pli":"revatassa mahesino. ","html":"<span class='verse-line'>{}</span></p>"},"bv7:22.1":{"pli":"Bhaddā ceva subhaddā ca, ","html":"<p><span class='verse-line'>{}</span>"},"bv7:22.2":{"pli":"ahesuṁ aggasāvikā; ","html":"<span class='verse-line'>{}</span>"},"bv7:22.3":{"pli":"Sopi b