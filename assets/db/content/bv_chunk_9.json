p><span class='verse-line'>{}</span>"},"bv7:28.2":{"pli":"so ca dhammo asādiso; ","html":"<span class='verse-line'>{}</span>"},"bv7:28.3":{"pli":"Sabbaṁ tamantarahitaṁ, ","html":"<span class='verse-line'>{}</span>"},"bv7:28.4":{"pli":"nanu rittā sabbasaṅkhārā. ","html":"<span class='verse-line'>{}</span></p>"},"bv7:29.1":{"pli":"Revato yasadharo buddho, ","html":"<p data-counter='4321'><span class='verse-line'>{}</span>"},"bv7:29.2":{"pli":"Nibbuto so mahāpure; ","html":"<span class='verse-line'>{}</span>"},"bv7:29.3":{"pli":"Dhātuvitthārikaṁ āsi, ","html":"<span class='verse-line'>{}</span>"},"bv7:29.4":{"pli":"Tesu tesu padesato”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"bv7:30.1":{"pli":"Revatassa bhagavato vaṁso pañcamo. ","html":"<p class='endsutta'>{}</p></article>"}},"bv8":{"bv8:0.1":{"pli":"Buddhavaṁsa ","html":"<article id='bv8'><header><ul><li class='division'>{}</li></ul>"},"bv8:0.2":{"pli":"8. Sobhitabuddhavaṁsa ","html":"<h1 class='sutta-title'>{}</h1></header>"},"bv8:1.1":{"pli":"“Revatassa aparena, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"bv8:1.2":{"pli":"sobhito nāma nāyako; ","html":"<span class='verse-line'>{}</span>"},"bv8:1.3":{"pli":"Samāhito santacitto, ","html":"<span class='verse-line'>{}</span>"},"bv8:1.4":{"pli":"asamo appaṭipuggalo. ","html":"<span class='verse-line'>{}</span></p>"},"bv8:2.1":{"pli":"So jino sakagehamhi, ","html":"<p><span class='verse-line'>{}</span>"},"bv8:2.2":{"pli":"mānasaṁ vinivattayi; ","html":"<span class='verse-line'>{}</span>"},"bv8:2.3":{"pli":"Patvāna kevalaṁ bodhiṁ, ","html":"<span class='verse-line'>{}</span>"},"bv8:2.4":{"pli":"dhammacakkaṁ pavattayi. ","html":"<span class='verse-line'>{}</span></p>"},"bv8:3.1":{"pli":"Yāva heṭṭhā avīcito, ","html":"<p><span class='verse-line'>{}</span>"},"bv8:3.2":{"pli":"bhavaggā cāpi uddhato; ","html":"<span class='verse-line'>{}</span>"},"bv8:3.3":{"pli":"Etthantare ekaparisā, ","html":"<span class='verse-line'>{}</span>"},"bv8:3.4":{"pli":"ahosi dhammadesane. ","html":"<span class='verse-line'>{}</span></p>"},"bv8:4.1":{"pli":"Tāya parisāya sambuddho, ","html":"<p><span class='verse-line'>{}</span>"},"bv8:4.2":{"pli":"dhammacakkaṁ pavattayi; ","html":"<span class='verse-line'>{}</span>"},"bv8:4.3":{"pli":"Gaṇanāya na vattabbo, ","html":"<span class='verse-line'>{}</span>"},"bv8:4.4":{"pli":"paṭhamābhisamayo ahu. ","html":"<span class='verse-line'>{}</span></p>"},"bv8:5.1":{"pli":"Tato parampi desente, ","html":"<p><span class='verse-line'>{}</span>"},"bv8:5.2":{"pli":"marūnañca samāgame; ","html":"<span class='verse-line'>{}</span>"},"bv8:5.3":{"pli":"Navutikoṭisahassānaṁ, ","html":"<span class='verse-line'>{}</span>"},"bv8:5.4":{"pli":"dutiyābhisamayo ahu. ","html":"<span class='verse-line'>{}</span></p>"},"bv8:6.1":{"pli":"Punāparaṁ rājaputto, ","html":"<p><span class='verse-line'>{}</span>"},"bv8:6.2":{"pli":"jayaseno nāma khattiyo; ","html":"<span class='verse-line'>{}</span>"},"bv8:6.3":{"pli":"Ārāmaṁ ropayitvāna, ","html":"<span class='verse-line'>{}</span>"},"bv8:6.4":{"pli":"buddhe niyyādayī tadā. ","html":"<span class='verse-line'>{}</span></p>"},"bv8:7.1":{"pli":"Tassa yāgaṁ pakittento, ","html":"<p><span class='verse-line'>{}</span>"},"bv8:7.2":{"pli":"dhammaṁ desesi cakkhumā; ","html":"<span class='verse-line'>{}</span>"},"bv8:7.3":{"pli":"Tadā koṭisahassānaṁ, ","html":"<span class='verse-line'>{}</span>"},"bv8:7.4":{"pli":"tatiyābhisamayo ahu. ","html":"<span class='verse-line'>{}</span></p>"},"bv8:8.1":{"pli":"Sannipātā tayo āsuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"bv8:8.2":{"pli":"sobhitassa mahesino; ","html":"<span class='verse-line'>{}</span>"},"bv8:8.3":{"pli":"Khīṇāsavānaṁ vimalānaṁ, ","html":"<span class='verse-line'>{}</span>"},"bv8:8.4":{"pli":"santacittāna tādinaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"bv8:9.1":{"pli":"Uggato nāma so rājā, ","html":"<p><span class='verse-line'>{}</span>"},"bv8:9.2":{"pli":"dānaṁ deti