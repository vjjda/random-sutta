9:18.1":{"pli":"Dasavassasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"bv9:18.2":{"pli":"agāraṁ ajjha so vasi; ","html":"<span class='verse-line'>{}</span>"},"bv9:18.3":{"pli":"Sirī upasirī vaḍḍho, ","html":"<span class='verse-line'>{}</span>"},"bv9:18.4":{"pli":"tayo pāsādamuttamā. ","html":"<span class='verse-line'>{}</span></p>"},"bv9:19.1":{"pli":"Tevīsatisahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"bv9:19.2":{"pli":"nāriyo samalaṅkatā; ","html":"<span class='verse-line'>{}</span>"},"bv9:19.3":{"pli":"Sirimā nāma sā nārī, ","html":"<span class='verse-line'>{}</span>"},"bv9:19.4":{"pli":"upavāṇo nāma atrajo. ","html":"<span class='verse-line'>{}</span></p>"},"bv9:20.1":{"pli":"Nimitte caturo disvā, ","html":"<p><span class='verse-line'>{}</span>"},"bv9:20.2":{"pli":"sivikāyābhinikkhami; ","html":"<span class='verse-line'>{}</span>"},"bv9:20.3":{"pli":"Anūnadasamāsāni, ","html":"<span class='verse-line'>{}</span>"},"bv9:20.4":{"pli":"padhānaṁ padahī jino. ","html":"<span class='verse-line'>{}</span></p>"},"bv9:21.1":{"pli":"Brahmunā yācito santo, ","html":"<p><span class='verse-line'>{}</span>"},"bv9:21.2":{"pli":"anomadassī mahāmuni; ","html":"<span class='verse-line'>{}</span>"},"bv9:21.3":{"pli":"Vatti cakkaṁ mahāvīro, ","html":"<span class='verse-line'>{}</span>"},"bv9:21.4":{"pli":"uyyāne so sudassane. ","html":"<span class='verse-line'>{}</span></p>"},"bv9:22.1":{"pli":"Nisabho ca anomo ca, ","html":"<p><span class='verse-line'>{}</span>"},"bv9:22.2":{"pli":"ahesuṁ aggasāvakā; ","html":"<span class='verse-line'>{}</span>"},"bv9:22.3":{"pli":"Varuṇo nāmupaṭṭhāko, ","html":"<span class='verse-line'>{}</span>"},"bv9:22.4":{"pli":"anomadassissa satthuno. ","html":"<span class='verse-line'>{}</span></p>"},"bv9:23.1":{"pli":"Sundarī ca sumanā ca, ","html":"<p><span class='verse-line'>{}</span>"},"bv9:23.2":{"pli":"ahesuṁ aggasāvikā; ","html":"<span class='verse-line'>{}</span>"},"bv9:23.3":{"pli":"Bodhi tassa bhagavato, ","html":"<span class='verse-line'>{}</span>"},"bv9:23.4":{"pli":"ajjunoti pavuccati. ","html":"<span class='verse-line'>{}</span></p>"},"bv9:24.1":{"pli":"Nandivaḍḍho sirivaḍḍho, ","html":"<p><span class='verse-line'>{}</span>"},"bv9:24.2":{"pli":"ahesuṁ aggupaṭṭhakā; ","html":"<span class='verse-line'>{}</span>"},"bv9:24.3":{"pli":"Uppalā ceva padumā ca, ","html":"<span class='verse-line'>{}</span>"},"bv9:24.4":{"pli":"ahesuṁ aggupaṭṭhikā. ","html":"<span class='verse-line'>{}</span></p>"},"bv9:25.1":{"pli":"Aṭṭhapaṇṇāsaratanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"bv9:25.2":{"pli":"accuggato mahāmuni; ","html":"<span class='verse-line'>{}</span>"},"bv9:25.3":{"pli":"Pabhā niddhāvatī tassa, ","html":"<span class='verse-line'>{}</span>"},"bv9:25.4":{"pli":"sataraṁsīva uggato. ","html":"<span class='verse-line'>{}</span></p>"},"bv9:26.1":{"pli":"Vassasatasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"bv9:26.2":{"pli":"āyu vijjati tāvade; ","html":"<span class='verse-line'>{}</span>"},"bv9:26.3":{"pli":"Tāvatā tiṭṭhamāno so, ","html":"<span class='verse-line'>{}</span>"},"bv9:26.4":{"pli":"tāresi janataṁ bahuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"bv9:27.1":{"pli":"Supupphitaṁ pāvacanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"bv9:27.2":{"pli":"arahantehi tādihi; ","html":"<span class='verse-line'>{}</span>"},"bv9:27.3":{"pli":"Vītarāgehi vimalehi, ","html":"<span class='verse-line'>{}</span>"},"bv9:27.4":{"pli":"sobhittha jinasāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"bv9:28.1":{"pli":"So ca satthā amitayaso, ","html":"<p><span class='verse-line'>{}</span>"},"bv9:28.2":{"pli":"Yugāni tāni atuliyāni; ","html":"<span class='verse-line'>{}</span>"},"bv9:28.3":{"pli":"Sabbaṁ tamantarahitaṁ, ","html":"<span class='verse-line'>{}</span>"},"bv9:28.4":{"pli":"Nanu rittā sabbasaṅkhārā. ","html":"<span class='verse-line'>{}</span></p>"},"bv9:29.1":{"pli":"Anomadassī jino satthā, ","html":"<p data-counter='4911'><span class='verse-line'>{}</span>"},"bv9:29.2":{"pli":"Dhammārāmamhi nibbuto; ","html":"<span class='verse-line'>{}</span>"},"bv9:29.3":{"pli":"Tatthevassa jinathūpo, ","html":"<span class='verse-line'>{}</span>"},"bv9:29.4":{"pli":"Ubbedho pañcavīsatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"bv9:30.1":{"pli":"Anomadassissa bhagavato vaṁso sattamo. ","html":"<p class='endsutta'>{}</p></article>"}}}