erse-line'>{}</span>"},"tha-ap64:4.2":{"pli":"yaṁ pupphamabhiropayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap64:4.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap64:4.4":{"pli":"pupphapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap64:5.1":{"pli":"Ito vīsatikappamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap64:5.2":{"pli":"sumedho nāma khattiyo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap64:5.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap64:5.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap64:6.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap64:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap64:6.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap64:7.1":{"pli":"Itthaṁ sudaṁ āyasmā avopupphiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap64:8.1":{"pli":"Avopupphiyattherassāpadānaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap65":{"tha-ap65:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap65'><header><ul><li class='division'>{}</li>"},"tha-ap65:0.2":{"pli":"Sakacintaniyavagga ","html":"<li>{}</li></ul>"},"tha-ap65:0.3":{"pli":"Paccāgamaniyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap65:1.1":{"pli":"“Sindhuyā nadiyā tīre, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap65:1.2":{"pli":"cakkavāko ahaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap65:1.3":{"pli":"Suddhasevālabhakkhohaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap65:1.4":{"pli":"pāpesu ca susaññato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap65:2.1":{"pli":"Addasaṁ virajaṁ buddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap65:2.2":{"pli":"gacchantaṁ anilañjase; ","html":"<span class='verse-line'>{}</span>"},"tha-ap65:2.3":{"pli":"Tuṇḍena sālaṁ paggayha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap65:2.4":{"pli":"vipassissābhiropayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap65:3.1":{"pli":"Yassa saddhā tathāgate, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap65:3.2":{"pli":"acalā supatiṭṭhitā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap65:3.3":{"pli":"Tena cittappasādena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap65:3.4":{"pli":"duggatiṁ so na gacchati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap65:4.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap65:4.2":{"pli":"buddhaseṭṭhassa santike; ","html":"<span class='verse-line'>{}</span>"},"tha-ap65:4.3":{"pli":"Vihaṅgamena santena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap65:4.4":{"pli":"subījaṁ ropitaṁ mayā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap65:5.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap65:5.2":{"pli":"yaṁ pupphamabhiropayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap65:5.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap65:5.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap65:6.1":{"pli":"Sucārudassanā nāma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap65:6.2":{"pli":"aṭṭhete ekanāmakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap65:6.3":{"pli":"Kappe sattarase āsuṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap65:6.4":{"pli":"cakkavattī mahabbalā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap65:7.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap65:7.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap65:7.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap65:8.1":{"pli":"Itthaṁ sudaṁ āyasmā paccāgamaniyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap65:9.1":{"pli":"Paccāgamaniyattherassāpadānaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap66":{"tha-ap66:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap66'><header><ul><li class='division'>{}</li>"},"tha-ap66:0.2":{"pli":"Sakacintaniyavagga ","html":"<li>{}</li></ul>"},"tha-ap66:0.3":{"pli":"Parappasādakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap66:1.1":{"pli":"“Usabhaṁ pavaraṁ vīraṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap66:1.2":{"pli":"Mahesiṁ vijitāvinaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap66:1.3":{"pli":"Suvaṇṇavaṇṇaṁ sambuddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap66:1.4":{"pli":"Ko disvā nappasīdati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap66:2.1":{"pli":"Himavāvāparimeyyo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap66:2.2":{"pli":"sāgarova duruttaro; ","html":"<span class='verse-line'>{}</span>"},"tha-ap66:2.3":{"pli":"Tatheva jhānaṁ buddhassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap66:2.4":{"pli":"ko disvā nappasīdati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap66:3.1":{"pli":"Vasudhā yathāppameyyā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap66:3.2":{"pli":"cittā vanavaṭaṁsakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap66:3.3":{"pli":"Tatheva sīlaṁ buddhassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap66:3.4":{"pli":"ko disvā nappasīdati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap66:4.1":{"pli":"Anilañjasāsaṅkhubbho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap66:4.2":{"pli":"yathākāso asaṅkhiyo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap66:4.3":{"pli":"Tatheva ñāṇaṁ buddhassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap66:4.4":{"pli":"ko disvā nappasīdati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap66:5.1":{"pli":"Imāhi catugāthāhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap66:5.2":{"pli":"brāhmaṇo senasavhayo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap66:5.3":{"pli":"Buddhaseṭṭhaṁ thavitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap66:5.4":{"pli":"siddhatthaṁ aparājitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap66:6.1":{"pli":"Catunnavutikappāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap66:6.2":{"pli":"duggatiṁ nupapajjatha; ","html":"<span class='verse-line'>{}</span>"},"tha-ap66:6.3":{"pli":"Sugatiṁ sukhasampattiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap66:6.4":{"pli":"anubhosimanappakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap66:7.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap66:7.2":{"pli":"thavitvā lokanāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap66:7.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap66:7.4":{"pli":"thomanāya idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap66:8.1":{"pli":"Cātuddasamhi kappamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap66:8.2":{"pli":"caturo āsumuggatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap66:8.3":{"pli":"Sattaratanasampannā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap66:8.4":{"pli":"cakkavattī mahabbalā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap66:9.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap66:9.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap66:9.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap66:10.1":{"pli":"Itthaṁ sudaṁ āyasmā parappasādako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap66:11.1":{"pli":"Parappasādakattherassāpadānaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap67":{"tha-ap67:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap67'><header><ul><li class='division'>{}</li>"},"tha-ap67:0.2":{"pli":"Sakacintaniyavagga ","html":"<li>{}</li></ul>"},"tha-ap67:0.3":{"pli":"Bhisadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap67:1.1":{"pli":"“Vessabhū nāma nāmena, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap67:1.2":{"pli":"isīnaṁ tatiyo ahu; ","html":"<span class='verse-line'>{}</span>"},"tha-ap67:1.3":{"pli":"Kānanaṁ vanamogayha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap67:1.4":{"pli":"vihāsi purisuttamo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap67:2.1":{"pli":"Bhisamuḷālaṁ gaṇhitvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap67:2.2":{"pli":"agamaṁ buddhasantikaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap67:2.3":{"pli":"Tañca buddhassa pādāsiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap67:2.4":{"pli":"pasanno sehi pāṇibhi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap67:3.1":{"pli":"Karena ca parāmaṭṭho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap67:3.2":{"pli":"vessabhūvarabuddhinā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap67:3.3":{"pli":"Sukhāhaṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap67:3.4":{"pli":"samaṁ tena kutottariṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap67:4.1":{"pli":"Carimo vattate mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap67:4.2":{"pli":"bhavā sabbe samūhatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap67:4.3":{"pli":"Hatthināgena santena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap67:4.4":{"pli":"kusalaṁ ropitaṁ mayā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap67:5.1":{"pli":"Ekattiṁse ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap67:5.2":{"pli":"yaṁ kammamakariṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap67:5.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap67:5.4":{"pli":"bhisadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap67:6.1":{"pli":"Samodhānā ca rājāno, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap67:6.2":{"pli":"soḷasa manujādhipā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap67:6.3":{"pli":"Kappamhi cuddase āsuṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap67:6.4":{"pli":"cakkavattī mahabbalā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap67:7.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap67:7.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap67:7.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap67:8.1":{"pli":"Itthaṁ sudaṁ āyasmā bhisadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap67:9.1":{"pli":"Bhisadāyakattherassāpadānaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap68":{"tha-ap68:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap68'><header><ul><li class='division'>{}</li>"},"tha-ap68:0.2":{"pli":"Sakacintaniyavagga ","html":"<li>{}</li></ul>"},"tha-ap68:0.3":{"pli":"Sucintitattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap68:1.1":{"pli":"“Giriduggacaro āsiṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap68:1.2":{"pli":"abhijātova kesarī; ","html":"<span class='verse-line'>{}</span>"},"tha-ap68:1.3":{"pli":"Migasaṅghaṁ vadhitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap68:1.4":{"pli":"jīvāmi pabbatantare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap68:2.1":{"pli":"Atthadassī tu bhagavā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap68:2.2":{"pli":"sabbaññū vadataṁ varo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap68:2.3":{"pli":"Mamuddharitukāmo so, ","html":"<span class='verse-line'>{}</span>"},"tha-ap68:2.4":{"pli":"āgacchi pabbatuttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap68:3.1":{"pli":"Pasadañca migaṁ hantvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap68:3.2":{"pli":"bhakkhituṁ samupāgamiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap68:3.3":{"pli":"Bhagavā tamhi samaye, ","html":"<span class='verse-line'>{}</span>"},"tha-ap68:3.4":{"pli":"bhikkhamāno upāgami. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap68:4.1":{"pli":"Varamaṁsāni paggayha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap68:4.2":{"pli":"adāsiṁ tassa satthuno; ","html":"<span class='verse-line'>{}</span>"},"tha-ap68:4.3":{"pli":"Anumodi mahāvīro, ","html":"<span class='verse-line'>{}</span>"},"tha-ap68:4.4":{"pli":"nibbāpento mamaṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap68:5.1":{"pli":"Tena cittappasādena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap68:5.2":{"pli":"giriduggaṁ pavisiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap68:5.3":{"pli":"Pītiṁ uppādayitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap68:5.4":{"pli":"tattha kālaṅkato ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap68:6.1":{"pli":"Etena maṁsadānena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap68:6.2":{"pli":"cittassa paṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap68:6.3":{"pli":"Pannarase kappasate, ","html":"<span class='verse-line'>{}</span>"},"tha-ap68:6.4":{"pli":"devaloke ramiṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap68:7.1":{"pli":"Avasesesu kappesu, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap68:7.2":{"pli":"kusalaṁ cintitaṁ mayā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap68:7.3":{"pli":"Teneva maṁsadānena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap68:7.4":{"pli":"buddhānussaraṇena ca. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap68:8.1":{"pli":"Aṭṭhattiṁsamhi kappamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap68:8.2":{"pli":"aṭṭha dīghāyunāmakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap68:8.3":{"pli":"Saṭṭhimhito kappasate, ","html":"<span class='verse-line'>{}</span>"},"tha-ap68:8.4":{"pli":"duve varuṇanāmakā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap68:9.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap68:9.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap68:9.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap68:10.1":{"pli":"Itthaṁ sudaṁ āyasmā sucintito thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap68:11.1":{"pli":"Sucintitattherassāpadānaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap69":{"tha-ap69:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap69'><header><ul><li class='division'>{}</li>"},"tha-ap69:0.2":{"pli":"Sakacintaniyavagga ","html":"<li>{}</li></ul>"},"tha-ap69:0.3":{"pli":"Vatthadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap69:1.1":{"pli":"“Pakkhijāto tadā āsiṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap69:1.2":{"pli":"supaṇṇo garuḷādhipo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap69:1.3":{"pli":"Addasaṁ virajaṁ buddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap69:1.4":{"pli":"gacchantaṁ gandhamādanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap69:2.1":{"pli":"Jahitvā garuḷavaṇṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap69:2.2":{"pli":"māṇavakaṁ adhārayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap69:2.3":{"pli":"Ekaṁ vatthaṁ mayā dinnaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap69:2.4":{"pli":"dvipadindassa tādino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap69:3.1":{"pli":"Tañca dussaṁ paṭiggayha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap69:3.2":{"pli":"buddho lokagganāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap69:3.3":{"pli":"Antalikkhe ṭhito satthā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap69:3.4":{"pli":"imā gāthā abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap69:4.1":{"pli":"‘Iminā vatthadānena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap69:4.2":{"pli":"cittassa paṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap69:4.3":{"pli":"Pahāya garuḷaṁ yoniṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap69:4.4":{"pli":"devaloke ramissati’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap69:5.1":{"pli":"Atthadassī tu bhagavā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap69:5.2":{"pli":"lokajeṭṭho narāsabho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap69:5.3":{"pli":"Vatthadānaṁ pasaṁsitvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap69:5.4":{"pli":"pakkāmi uttarāmukho. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap69:6.1":{"pli":"Bhave nibbattamānamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap69:6.2":{"pli":"honti me vatthasampadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap69:6.3":{"pli":"Ākāse chadanaṁ hoti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap69:6.4":{"pli":"vatthadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap69:7.1":{"pli":"Aruṇavā satta janā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap69:7.2":{"pli":"cakkavattī mahabbalā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap69:7.3":{"pli":"Chattiṁsatimhi āsiṁsu, ","html":"<span class='verse-line'>{}</span>"},"tha-ap69:7.4":{"pli":"kappamhi manujādhipā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap69:8.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap69:8.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap69:8.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap69:9.1":{"pli":"Itthaṁ sudaṁ āyasmā vatthadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap69:10.1":{"pli":"Vatthadāyakattherassāpadānaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap7":{"tha-ap7:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap7'><header><ul><li class='division'>{}</li>"},"tha-ap7:0.2":{"pli":"Buddhavagga ","html":"<li>{}</li></ul>"},"tha-ap7:0.3":{"pli":"7 Puṇṇamantāṇiputtattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap7:1.1":{"pli":"“Ajjhāyako mantadharo, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap7:1.2":{"pli":"tiṇṇaṁ vedāna pāragū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap7:1.3":{"pli":"Purakkhatomhi sissehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap7:1.4":{"pli":"upagacchiṁ naruttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap7:2.1":{"pli":"Padumuttaro lokavidū, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap7:2.2":{"pli":"āhutīnaṁ paṭiggaho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap7:2.3":{"pli":"Mama kammaṁ pakittesi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap7:2.4":{"pli":"saṅkhittena mahāmuni. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap7:3.1":{"pli":"Tāhaṁ dhammaṁ suṇitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap7:3.2":{"pli":"Abhivādetvāna satthuno; ","html":"<span class='verse-line'>{}</span>"},"tha-ap7:3.3":{"pli":"Añjaliṁ paggahetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap7:3.4":{"pli":"Pakkamiṁ dakkhiṇāmukho. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap7:4.1":{"pli":"Saṅkhittena suṇitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap7:4.2":{"pli":"vitthārena abhāsayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap7:4.3":{"pli":"Sabbe sissā attamanā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap7:4.4":{"pli":"sutvāna mama bhāsato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap7:4.5":{"pli":"Sakaṁ diṭṭhiṁ vinodetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap7:4.6":{"pli":"buddhe cittaṁ pasādayuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap7:5.1":{"pli":"Saṅkhittenapi desemi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap7:5.2":{"pli":"vitthārena tathevahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap7:5.3":{"pli":"Abhidhammanayaññūhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap7:5.4":{"pli":"kathāvatthuvisuddhiyā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap7:5.5":{"pli":"Sabbesaṁ viññāpetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap7:5.6":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap7:6.1":{"pli":"Ito pañcasate kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap7:6.2":{"pli":"caturo suppakāsakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap7:6.3":{"pli":"Sattaratanasampannā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap7:6.4":{"pli":"catudīpamhi issarā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap7:7.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap7:7.2":{"pli":"vimokkhāpi ca aṭṭhime; ","html":"<span class='verse-line'>{}</span>"},"tha-ap7:7.3":{"pli":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap7:7.4":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap7:8.1":{"pli":"Itthaṁ sudaṁ āyasmā puṇṇo mantāṇiputto thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap7:9.1":{"pli":"Puṇṇamantāṇiputtattherassāpadānaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap70":{"tha-ap70:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap70'><header><ul><li class='division'>{}</li>"},"tha-ap70:0.2":{"pli":"Sakacintaniyavagga ","html":"<li>{}</li></ul>"},"tha-ap70:0.3":{"pli":"Ambadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap70:1.1":{"pli":"“Anomadassī bhagavā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap70:1.2":{"pli":"nisinno pabbatantare; ","html":"<span class='verse-line'>{}</span>"},"tha-ap70:1.3":{"pli":"Mettāya aphari loke, ","html":"<span class='verse-line'>{}</span>"},"tha-ap70:1.4":{"pli":"appamāṇe nirūpadhi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap70:2.1":{"pli":"Kapi ahaṁ tadā āsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap70:2.2":{"pli":"himavante naguttame; ","html":"<span class='verse-line'>{}</span>"},"tha-ap70:2.3":{"pli":"Disvā anomadassiṁ taṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap70:2.4":{"pli":"buddhe cittaṁ pasādayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap70:3.1":{"pli":"Avidūre himavantassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap70:3.2":{"pli":"ambāsuṁ phalino tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap70:3.3":{"pli":"Tato pakkaṁ gahetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap70:3.4":{"pli":"ambaṁ samadhukaṁ adaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap70:4.1":{"pli":"Taṁ me buddho viyākāsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap70:4.2":{"pli":"anomadassī mahāmuni; ","html":"<span class='verse-line'>{}</span>"},"tha-ap70:4.3":{"pli":"Iminā madhudānena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap70:4.4":{"pli":"ambadānena cūbhayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap70:5.1":{"pli":"Sattapaññāsakappamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap70:5.2":{"pli":"devaloke ramissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap70:5.3":{"pli":"Avasesesu kappesu, ","html":"<span class='verse-line'>{}</span>"},"tha-ap70:5.4":{"pli":"vokiṇṇaṁ saṁsarissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap70:6.1":{"pli":"Khepetvā pāpakaṁ kammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap70:6.2":{"pli":"paripakkāya buddhiyā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap70:6.3":{"pli":"Vinipātamagantvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap70:6.4":{"pli":"kilese jhāpayissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap70:7.1":{"pli":"Damena uttamenāhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap70:7.2":{"pli":"damitomhi mahesinā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap70:7.3":{"pli":"Pattomhi acalaṁ ṭhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap70:7.4":{"pli":"hitvā jayaparājayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap70:8.1":{"pli":"Sattasattatikappasate, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap70:8.2":{"pli":"ambaṭṭhajasanāmakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap70:8.3":{"pli":"Catuddasa te rājāno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap70:8.4":{"pli":"cakkavattī mahabbalā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap70:9.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap70:9.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap70:9.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap70:10.1":{"pli":"Itthaṁ sudaṁ āyasmā ambadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap70:11.1":{"pli":"Ambadāyakattherassāpadānaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}