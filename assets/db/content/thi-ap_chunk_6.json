{"thi-ap22":{"thi-ap22:0.1":{"pli":"Therīapadāna ","html":"<article id='thi-ap22'><header><ul><li class='division'>{}</li>"},"thi-ap22:0.2":{"pli":"Kuṇḍalakesīvagga ","html":"<li>{}</li></ul>"},"thi-ap22:0.3":{"pli":"Kisāgotamītherīapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"thi-ap22:1.1":{"pli":"“Padumuttaro nāma jino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"thi-ap22:1.2":{"pli":"sabbadhammāna pāragū; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:1.3":{"pli":"Ito satasahassamhi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:1.4":{"pli":"kappe uppajji nāyako. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:2.1":{"pli":"Tadāhaṁ haṁsavatiyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:2.2":{"pli":"jātā aññatare kule; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:2.3":{"pli":"Upetvā taṁ naravaraṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:2.4":{"pli":"saraṇaṁ samupāgamiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:3.1":{"pli":"Dhammañca tassa assosiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:3.2":{"pli":"catusaccūpasañhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:3.3":{"pli":"Madhuraṁ paramassādaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:3.4":{"pli":"vaṭṭasantisukhāvahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:4.1":{"pli":"Tadā ca bhikkhuniṁ vīro, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:4.2":{"pli":"lūkhacīvaradhāriniṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:4.3":{"pli":"Ṭhapento etadaggamhi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:4.4":{"pli":"vaṇṇayī purisuttamo. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:5.1":{"pli":"Janetvānappakaṁ pītiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:5.2":{"pli":"sutvā bhikkhuniyā guṇe; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:5.3":{"pli":"Kāraṁ katvāna buddhassa, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:5.4":{"pli":"yathāsatti yathābalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:6.1":{"pli":"Nipacca munivaraṁ taṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:6.2":{"pli":"taṁ ṭhānamabhipatthayiṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:6.3":{"pli":"Tadānumodi sambuddho, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:6.4":{"pli":"ṭhānalābhāya nāyako. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:7.1":{"pli":"‘Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:7.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:7.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:7.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:8.1":{"pli":"Tassa dhammesu dāyādā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:8.2":{"pli":"orasā dhammanimmitā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:8.3":{"pli":"Kisāgotamī nāmena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:8.4":{"pli":"hessati satthu sāvikā’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:9.1":{"pli":"Taṁ sutvā muditā hutvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:9.2":{"pli":"yāvajīvaṁ tadā jinaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:9.3":{"pli":"Mettacittā paricariṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:9.4":{"pli":"paccayehi vināyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:10.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:10.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:10.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:10.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:11.1":{"pli":"Imamhi bhaddake kappe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:11.2":{"pli":"brahmabandhu mahāyaso; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:11.3":{"pli":"Kassapo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:11.4":{"pli":"uppajji vadataṁ varo. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:12.1":{"pli":"Upaṭṭhāko mahesissa, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:12.2":{"pli":"tadā āsi narissaro; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:12.3":{"pli":"Kāsirājā kikī nāma, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:12.4":{"pli":"bārāṇasipuruttame. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:13.1":{"pli":"Pañcamī tassa dhītāsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:13.2":{"pli":"dhammā nāmena vissutā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:13.3":{"pli":"Dhammaṁ sutvā jinaggassa, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:13.4":{"pli":"pabbajjaṁ samarocayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:14.1":{"pli":"Anujāni na no tāto, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:14.2":{"pli":"agāreva tadā mayaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:14.3":{"pli":"Vīsavassasahassāni, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:14.4":{"pli":"vicarimha atanditā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:15.1":{"pli":"Komāribrahmacariyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:15.2":{"pli":"rājakaññā sukhedhitā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:15.3":{"pli":"Buddhopaṭṭhānaniratā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:15.4":{"pli":"muditā satta dhītaro. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:16.1":{"pli":"Samaṇī samaṇaguttā ca, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:16.2":{"pli":"bhikkhunī bhikkhudāyikā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:16.3":{"pli":"Dhammā ceva sudhammā ca, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:16.4":{"pli":"sattamī saṅghadāyikā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:17.1":{"pli":"Khemā uppalavaṇṇā ca, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:17.2":{"pli":"paṭācārā ca kuṇḍalā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:17.3":{"pli":"Ahañca dhammadinnā ca, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:17.4":{"pli":"visākhā hoti sattamī. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:18.1":{"pli":"Tehi kammehi sukatehi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:18.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:18.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:18.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:19.1":{"pli":"Pacchime ca bhave dāni, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:19.2":{"pli":"jātā seṭṭhikule ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:19.3":{"pli":"Duggate adhane naṭṭhe, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:19.4":{"pli":"gatā ca sadhanaṁ kulaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:20.1":{"pli":"Patiṁ ṭhapetvā sesā me, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:20.2":{"pli":"dessanti adhanā iti; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:20.3":{"pli":"Yadā ca pasūtā āsiṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:20.4":{"pli":"sabbesaṁ dayitā tadā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:21.1":{"pli":"Yadā so taruṇo bhaddo, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:21.2":{"pli":"komalako sukhedhito; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:21.3":{"pli":"Sapāṇamiva kanto me, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:21.4":{"pli":"tadā yamavasaṁ gato. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:22.1":{"pli":"Sokaṭṭādīnavadanā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:22.2":{"pli":"assunettā rudammukhā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:22.3":{"pli":"Mataṁ kuṇapamādāya, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:22.4":{"pli":"vilapantī gamāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:23.1":{"pli":"Tadā ekena sandiṭṭhā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:23.2":{"pli":"upetvābhisakkuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:23.3":{"pli":"Avocaṁ ‘dehi bhesajjaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:23.4":{"pli":"puttasañjīvananti bho’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:24.1":{"pli":"‘Na vijjante matā yasmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:24.2":{"pli":"gehe siddhatthakaṁ tato; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:24.3":{"pli":"Āharā’ti jino āha, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:24.4":{"pli":"vinayopāyakovido. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:25.1":{"pli":"Tadā gamitvā sāvatthiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:25.2":{"pli":"na labhiṁ tādisaṁ gharaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:25.3":{"pli":"Kuto siddhatthakaṁ tasmā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:25.4":{"pli":"tato laddhā satiṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:26.1":{"pli":"Kuṇapaṁ chaḍḍayitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:26.2":{"pli":"upesiṁ lokanāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:26.3":{"pli":"Dūratova mamaṁ disvā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:26.4":{"pli":"avoca madhurassaro. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:27.1":{"pli":"‘Yo ca vassasataṁ jīve, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:27.2":{"pli":"apassaṁ udayabbayaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:27.3":{"pli":"Ekāhaṁ jīvitaṁ seyyo, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:27.4":{"pli":"passato udayabbayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:28.1":{"pli":"Na gāmadhammo nigamassa dhammo, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:28.2":{"pli":"Na cāpiyaṁ ekakulassa dhammo; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:28.3":{"pli":"Sabbassa lokassa sadevakassa, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:28.4":{"pli":"Eseva dhammo yadidaṁ aniccatā’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:29.1":{"pli":"Sāhaṁ sutvānimā gāthā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:29.2":{"pli":"dhammacakkhuṁ visodhayiṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:29.3":{"pli":"Tato viññātasaddhammā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:29.4":{"pli":"pabbajiṁ anagāriyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:30.1":{"pli":"Tathā pabbajitā santī, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:30.2":{"pli":"yuñjantī jinasāsane; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:30.3":{"pli":"Na cireneva kālena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:30.4":{"pli":"arahattamapāpuṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:31.1":{"pli":"Iddhīsu ca vasī homi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:31.2":{"pli":"dibbāya sotadhātuyā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:31.3":{"pli":"Paracittāni jānāmi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:31.4":{"pli":"satthusāsanakārikā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:32.1":{"pli":"Pubbenivāsaṁ jānāmi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:32.2":{"pli":"dibbacakkhu visodhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:32.3":{"pli":"Khepetvā āsave sabbe, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:32.4":{"pli":"visuddhāsiṁ sunimmalā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:33.1":{"pli":"Pariciṇṇo mayā satthā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:33.2":{"pli":"kataṁ buddhassa sāsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:33.3":{"pli":"Ohito garuko bhāro, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:33.4":{"pli":"bhavanetti samūhatā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:34.1":{"pli":"Yassatthāya pabbajitā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:34.2":{"pli":"agārasmānagāriyaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:34.3":{"pli":"So me attho anuppatto, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:34.4":{"pli":"sabbasaṁyojanakkhayo. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:35.1":{"pli":"Atthadhammaniruttīsu, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:35.2":{"pli":"paṭibhāne tatheva ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:35.3":{"pli":"Ñāṇaṁ me vimalaṁ suddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:35.4":{"pli":"buddhaseṭṭhassa vāhasā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:36.1":{"pli":"Saṅkārakūṭā āhitvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:36.2":{"pli":"susānā rathiyāpi ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:36.3":{"pli":"Tato saṅghāṭikaṁ katvā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:36.4":{"pli":"lūkhaṁ dhāremi cīvaraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:37.1":{"pli":"Jino tasmiṁ guṇe tuṭṭho, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:37.2":{"pli":"lūkhacīvaradhāraṇe; ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:37.3":{"pli":"Ṭhapesi etadaggamhi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:37.4":{"pli":"parisāsu vināyako. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:38.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:38.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:38.3":{"pli":"viharāmi anāsavā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:39.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:39.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:39.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap22:40.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap22:40.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap22:40.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"thi-ap22:41.1":{"pli":"Itthaṁ sudaṁ kisāgotamī bhikkhunī imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"thi-ap22:42.1":{"pli":"Kisāgotamītheriyāpadānaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"thi-ap23":{"thi-ap23:0.1":{"pli":"Therīapadāna ","html":"<article id='thi-ap23'><header><ul><li class='division'>{}</li>"},"thi-ap23:0.2":{"pli":"Kuṇḍalakesīvagga ","html":"<li>{}</li></ul>"},"thi-ap23:0.3":{"pli":"Dhammadinnātherīapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"thi-ap23:1.1":{"pli":"“Padumuttaro nāma jino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"thi-ap23:1.2":{"pli":"sabbadhammāna pāragū; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:1.3":{"pli":"Ito satasahassamhi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:1.4":{"pli":"kappe uppajji nāyako. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:2.1":{"pli":"Tadāhaṁ haṁsavatiyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:2.2":{"pli":"kule aññatare ahuṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:2.3":{"pli":"Parakammakārī āsiṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:2.4":{"pli":"nipakā sīlasaṁvutā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:3.1":{"pli":"Padumuttarabuddhassa, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:3.2":{"pli":"sujāto aggasāvako; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:3.3":{"pli":"Vihārā abhinikkhamma, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:3.4":{"pli":"piṇḍapātāya gacchati. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:4.1":{"pli":"Ghaṭaṁ gahetvā gacchantī, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:4.2":{"pli":"tadā udakahārikā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:4.3":{"pli":"Taṁ disvā adadaṁ pūpaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:4.4":{"pli":"pasannā sehi pāṇibhi. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:5.1":{"pli":"Paṭiggahetvā tattheva, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:5.2":{"pli":"nisinno paribhuñji so; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:5.3":{"pli":"Tato netvāna taṁ gehaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:5.4":{"pli":"adāsiṁ tassa bhojanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:6.1":{"pli":"Tato me ayyako tuṭṭho, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:6.2":{"pli":"akarī suṇisaṁ sakaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:6.3":{"pli":"Sassuyā saha gantvāna, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:6.4":{"pli":"sambuddhaṁ abhivādayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:7.1":{"pli":"Tadā so dhammakathikaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:7.2":{"pli":"bhikkhuniṁ parikittayaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:7.3":{"pli":"Ṭhapesi etadaggamhi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:7.4":{"pli":"taṁ sutvā muditā ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:8.1":{"pli":"Nimantayitvā sugataṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:8.2":{"pli":"sasaṅghaṁ lokanāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:8.3":{"pli":"Mahādānaṁ daditvāna, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:8.4":{"pli":"taṁ ṭhānamabhipatthayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:9.1":{"pli":"Tato maṁ sugato āha, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:9.2":{"pli":"ghananinnādasussaro; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:9.3":{"pli":"‘Mamupaṭṭhānanirate, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:9.4":{"pli":"sasaṅghaparivesike. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:10.1":{"pli":"Saddhammassavane yutte, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:10.2":{"pli":"guṇavaddhitamānase; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:10.3":{"pli":"Bhadde bhavassu muditā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:10.4":{"pli":"lacchase paṇidhīphalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:11.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:11.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:11.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:11.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:12.1":{"pli":"Tassa dhammesu dāyādā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:12.2":{"pli":"orasā dhammanimmitā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:12.3":{"pli":"Dhammadinnāti nāmena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:12.4":{"pli":"hessati satthu sāvikā’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:13.1":{"pli":"Taṁ sutvā muditā hutvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:13.2":{"pli":"yāvajīvaṁ mahāmuniṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:13.3":{"pli":"Mettacittā paricariṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:13.4":{"pli":"paccayehi vināyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:14.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:14.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:14.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:14.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:15.1":{"pli":"Imamhi bhaddake kappe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:15.2":{"pli":"brahmabandhu mahāyaso; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:15.3":{"pli":"Kassapo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:15.4":{"pli":"uppajji vadataṁ varo. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:16.1":{"pli":"Upaṭṭhāko mahesissa, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:16.2":{"pli":"tadā āsi narissaro; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:16.3":{"pli":"Kāsirājā kikī nāma, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:16.4":{"pli":"bārāṇasipuruttame. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:17.1":{"pli":"Chaṭṭhā tassāsahaṁ dhītā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:17.2":{"pli":"sudhammā iti vissutā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:17.3":{"pli":"Dhammaṁ sutvā jinaggassa, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:17.4":{"pli":"pabbajjaṁ samarocayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:18.1":{"pli":"Anujāni na no tāto, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:18.2":{"pli":"agāreva tadā mayaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:18.3":{"pli":"Vīsavassasahassāni, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:18.4":{"pli":"vicarimha atanditā. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"thi-ap23:19.1":{"pli":"Tatiyaṁ bhāṇavāraṁ. ","html":"<p class='endsutta'>{}</p>"},"thi-ap23:20.1":{"pli":"Komāribrahmacariyaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"thi-ap23:20.2":{"pli":"rājakaññā sukhedhitā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:20.3":{"pli":"Buddhopaṭṭhānaniratā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:20.4":{"pli":"muditā satta dhītaro. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:21.1":{"pli":"Samaṇī samaṇaguttā ca, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:21.2":{"pli":"bhikkhunī bhikkhudāyikā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:21.3":{"pli":"Dhammā ceva sudhammā ca, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:21.4":{"pli":"sattamī saṅghadāyikā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:22.1":{"pli":"Khemā uppalavaṇṇā ca, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:22.2":{"pli":"paṭācārā ca kuṇḍalā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:22.3":{"pli":"Gotamī ca ahañceva, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:22.4":{"pli":"visākhā hoti sattamī. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:23.1":{"pli":"Tehi kammehi sukatehi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:23.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:23.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:23.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:24.1":{"pli":"Pacchime ca bhave dāni, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:24.2":{"pli":"giribbajapuruttame; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:24.3":{"pli":"Jātā seṭṭhikule phīte, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:24.4":{"pli":"sabbakāmasamiddhine. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:25.1":{"pli":"Yadā rūpaguṇūpetā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:25.2":{"pli":"paṭhame yobbane ṭhitā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:25.3":{"pli":"Tadā parakulaṁ gantvā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:25.4":{"pli":"vasiṁ sukhasamappitā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:26.1":{"pli":"Upetvā lokasaraṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:26.2":{"pli":"suṇitvā dhammadesanaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:26.3":{"pli":"Anāgāmiphalaṁ patto, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:26.4":{"pli":"sāmiko me subuddhimā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:27.1":{"pli":"Tadāhaṁ anujānetvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:27.2":{"pli":"pabbajiṁ anagāriyaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:27.3":{"pli":"Na cireneva kālena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:27.4":{"pli":"arahattamapāpuṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:28.1":{"pli":"Tadā upāsako so maṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:28.2":{"pli":"upagantvā apucchatha; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:28.3":{"pli":"Gambhīre nipuṇe pañhe, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:28.4":{"pli":"te sabbe byākariṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:29.1":{"pli":"Jino tasmiṁ guṇe tuṭṭho, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:29.2":{"pli":"etadagge ṭhapesi maṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:29.3":{"pli":"‘Bhikkhuniṁ dhammakathikaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:29.4":{"pli":"nāññaṁ passāmi edisiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:30.1":{"pli":"Dhammadinnā yathā dhīrā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:30.2":{"pli":"evaṁ dhāretha bhikkhavo’; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:30.3":{"pli":"Evāhaṁ paṇḍitā homi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:30.4":{"pli":"nāyakenānukampitā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:31.1":{"pli":"Pariciṇṇo mayā satthā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:31.2":{"pli":"kataṁ buddhassa sāsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:31.3":{"pli":"Ohito garuko bhāro, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:31.4":{"pli":"bhavanetti samūhatā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:32.1":{"pli":"Yassatthāya pabbajitā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:32.2":{"pli":"agārasmānagāriyaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:32.3":{"pli":"So me attho anuppatto, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:32.4":{"pli":"sabbasaṁyojanakkhayo. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:33.1":{"pli":"Iddhīsu ca vasī homi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:33.2":{"pli":"dibbāya sotadhātuyā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:33.3":{"pli":"Paracittāni jānāmi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:33.4":{"pli":"satthusāsanakārikā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:34.1":{"pli":"Pubbenivāsaṁ jānāmi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:34.2":{"pli":"dibbacakkhu visodhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:34.3":{"pli":"Khepetvā āsave sabbe, ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:34.4":{"pli":"visuddhāsiṁ sunimmalā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:35.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:35.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:35.3":{"pli":"viharāmi anāsavā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:36.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:36.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:36.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap23:37.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap23:37.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap23:37.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"thi-ap23:38.1":{"pli":"Itthaṁ sudaṁ dhammadinnā bhikkhunī imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"thi-ap23:39.1":{"pli":"Dhammadinnātheriyāpadānaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"thi-ap24":{"thi-ap24:0.1":{"pli":"Therīapadāna ","html":"<article id='thi-ap24'><header><ul><li class='division'>{}</li>"},"thi-ap24:0.2":{"pli":"Kuṇḍalakesīvagga ","html":"<li>{}</li></ul>"},"thi-ap24:0.3":{"pli":"Sakulātherīapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"thi-ap24:1.1":{"pli":"“Padumuttaro nāma jino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"thi-ap24:1.2":{"pli":"sabbadhammāna pāragū; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:1.3":{"pli":"Ito satasahassamhi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:1.4":{"pli":"kappe uppajji nāyako. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:2.1":{"pli":"Hitāya sabbasattānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:2.2":{"pli":"sukhāya vadataṁ varo; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:2.3":{"pli":"Atthāya purisājañño, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:2.4":{"pli":"paṭipanno sadevake. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:3.1":{"pli":"Yasaggapatto sirimā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:3.2":{"pli":"kittivaṇṇagato jino; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:3.3":{"pli":"Pūjito sabbalokassa, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:3.4":{"pli":"disāsabbāsu vissuto. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:4.1":{"pli":"Uttiṇṇavicikiccho so, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:4.2":{"pli":"vītivattakathaṅkatho; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:4.3":{"pli":"Sampuṇṇamanasaṅkappo, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:4.4":{"pli":"patto sambodhimuttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:5.1":{"pli":"Anuppannassa maggassa, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:5.2":{"pli":"uppādetā naruttamo; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:5.3":{"pli":"Anakkhātañca akkhāsi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:5.4":{"pli":"asañjātañca sañjanī. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:6.1":{"pli":"Maggaññū ca maggavidū, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:6.2":{"pli":"maggakkhāyī narāsabho; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:6.3":{"pli":"Maggassa kusalo satthā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:6.4":{"pli":"sārathīnaṁ varuttamo. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:7.1":{"pli":"Mahākāruṇiko satthā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:7.2":{"pli":"dhammaṁ desesi nāyako; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:7.3":{"pli":"Nimugge kāmapaṅkamhi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:7.4":{"pli":"samuddharati pāṇine. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:8.1":{"pli":"Tadāhaṁ haṁsavatiyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:8.2":{"pli":"jātā khattiyanandanā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:8.3":{"pli":"Surūpā sadhanā cāpi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:8.4":{"pli":"dayitā ca sirīmatī. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:9.1":{"pli":"Ānandassa mahārañño, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:9.2":{"pli":"dhītā paramasobhaṇā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:9.3":{"pli":"Vemātā bhaginī cāpi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:9.4":{"pli":"padumuttaranāmino. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:10.1":{"pli":"Rājakaññāhi sahitā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:10.2":{"pli":"sabbābharaṇabhūsitā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:10.3":{"pli":"Upāgamma mahāvīraṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:10.4":{"pli":"assosiṁ dhammadesanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:11.1":{"pli":"Tadā hi so lokagaru, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:11.2":{"pli":"bhikkhuniṁ dibbacakkhukaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:11.3":{"pli":"Kittayaṁ parisāmajjhe, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:11.4":{"pli":"aggaṭṭhāne ṭhapesi taṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:12.1":{"pli":"Suṇitvā tamahaṁ haṭṭhā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:12.2":{"pli":"dānaṁ datvāna satthuno; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:12.3":{"pli":"Pūjitvāna ca sambuddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:12.4":{"pli":"dibbacakkhuṁ apatthayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:13.1":{"pli":"Tato avoca maṁ satthā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:13.2":{"pli":"‘nande lacchasi patthitaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:13.3":{"pli":"Padīpadhammadānānaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:13.4":{"pli":"phalametaṁ sunicchitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:14.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:14.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:14.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:14.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:15.1":{"pli":"Tassa dhammesu dāyādā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:15.2":{"pli":"orasā dhammanimmitā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:15.3":{"pli":"Sakulā nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:15.4":{"pli":"hessati satthu sāvikā’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:16.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:16.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:16.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:16.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:17.1":{"pli":"Imamhi bhaddake kappe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:17.2":{"pli":"brahmabandhu mahāyaso; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:17.3":{"pli":"Kassapo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:17.4":{"pli":"uppajji vadataṁ varo. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:18.1":{"pli":"Paribbājakinī āsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:18.2":{"pli":"tadāhaṁ ekacārinī; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:18.3":{"pli":"Bhikkhāya vicaritvāna, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:18.4":{"pli":"alabhiṁ telamattakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:19.1":{"pli":"Tena dīpaṁ padīpetvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:19.2":{"pli":"upaṭṭhiṁ sabbasaṁvariṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:19.3":{"pli":"Cetiyaṁ dvipadaggassa, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:19.4":{"pli":"vippasannena cetasā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:20.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:20.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:20.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:20.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:21.1":{"pli":"Yattha yatthūpapajjāmi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:21.2":{"pli":"tassa kammassa vāhasā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:21.3":{"pli":"Pajjalanti mahādīpā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:21.4":{"pli":"tattha tattha gatāya me. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:22.1":{"pli":"Tirokuṭṭaṁ tiroselaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:22.2":{"pli":"samatiggayha pabbataṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:22.3":{"pli":"Passāmahaṁ yadicchāmi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:22.4":{"pli":"dīpadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:23.1":{"pli":"Visuddhanayanā homi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:23.2":{"pli":"yasasā ca jalāmahaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:23.3":{"pli":"Saddhāpaññāvatī ceva, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:23.4":{"pli":"dīpadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:24.1":{"pli":"Pacchime ca bhave dāni, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:24.2":{"pli":"jātā vippakule ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:24.3":{"pli":"Pahūtadhanadhaññamhi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:24.4":{"pli":"mudite rājapūjite. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:25.1":{"pli":"Ahaṁ sabbaṅgasampannā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:25.2":{"pli":"sabbābharaṇabhūsitā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:25.3":{"pli":"Purappavese sugataṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:25.4":{"pli":"vātapāne ṭhitā ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:26.1":{"pli":"Disvā jalantaṁ yasasā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:26.2":{"pli":"devamanussasakkataṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:26.3":{"pli":"Anubyañjanasampannaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:26.4":{"pli":"lakkhaṇehi vibhūsitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:27.1":{"pli":"Udaggacittā sumanā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:27.2":{"pli":"pabbajjaṁ samarocayiṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:27.3":{"pli":"Na cireneva kālena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:27.4":{"pli":"arahattamapāpuṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:28.1":{"pli":"Iddhīsu ca vasī homi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:28.2":{"pli":"dibbāya sotadhātuyā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:28.3":{"pli":"Paracittāni jānāmi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:28.4":{"pli":"satthusāsanakārikā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:29.1":{"pli":"Pubbenivāsaṁ jānāmi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:29.2":{"pli":"dibbacakkhu visodhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:29.3":{"pli":"Khepetvā āsave sabbe, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:29.4":{"pli":"visuddhāsiṁ sunimmalā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:30.1":{"pli":"Pariciṇṇo mayā satthā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:30.2":{"pli":"kataṁ buddhassa sāsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:30.3":{"pli":"Ohito garuko bhāro, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:30.4":{"pli":"bhavanetti samūhatā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:31.1":{"pli":"Yassatthāya pabbajitā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:31.2":{"pli":"agārasmānagāriyaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:31.3":{"pli":"So me attho anuppatto, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:31.4":{"pli":"sabbasaṁyojanakkhayo. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:32.1":{"pli":"Tato mahākāruṇiko, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:32.2":{"pli":"etadagge ṭhapesi maṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:32.3":{"pli":"Dibbacakkhukānaṁ aggā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:32.4":{"pli":"sakulāti naruttamo. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:33.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:33.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:33.3":{"pli":"viharāmi anāsavā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:34.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:34.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:34.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap24:35.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap24:35.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap24:35.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"thi-ap24:36.1":{"pli":"Itthaṁ sudaṁ sakulā bhikkhunī imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"thi-ap24:37.1":{"pli":"Sakulātheriyāpadānaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}