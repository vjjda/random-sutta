{"ja406":{"ja406:0.1":{"pli":"Jātaka ","html":"<article id='ja406'><header><ul><li class='division'>{}</li>"},"ja406:0.2":{"pli":"Sattakanipāta ","html":"<li>{}</li>"},"ja406:0.3":{"pli":"Gandhāravagga ","html":"<li>{}</li></ul>"},"ja406:0.4":{"pli":"1. Gandhārajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja406:1.1":{"pli":"“Hitvā gāmasahassāni, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja406:1.2":{"pli":"paripuṇṇāni soḷasa; ","html":"<span class='verse-line'>{}</span>"},"ja406:1.3":{"pli":"Koṭṭhāgārāni phītāni, ","html":"<span class='verse-line'>{}</span>"},"ja406:1.4":{"pli":"sannidhiṁ dāni kubbasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja406:2.1":{"pli":"“Hitvā gandhāravisayaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja406:2.2":{"pli":"pahūtadhanadhāriyaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja406:2.3":{"pli":"Pasāsanato nikkhanto, ","html":"<span class='verse-line'>{}</span>"},"ja406:2.4":{"pli":"idha dāni pasāsasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja406:3.1":{"pli":"“Dhammaṁ bhaṇāmi vedeha, ","html":"<p><span class='verse-line'>{}</span>"},"ja406:3.2":{"pli":"adhammo me na ruccati; ","html":"<span class='verse-line'>{}</span>"},"ja406:3.3":{"pli":"Dhammaṁ me bhaṇamānassa, ","html":"<span class='verse-line'>{}</span>"},"ja406:3.4":{"pli":"na pāpamupalimpati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja406:4.1":{"pli":"“Yena kenaci vaṇṇena, ","html":"<p><span class='verse-line'>{}</span>"},"ja406:4.2":{"pli":"paro labhati ruppanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja406:4.3":{"pli":"Mahatthiyampi ce vācaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja406:4.4":{"pli":"na taṁ bhāseyya paṇḍito”. ","html":"<span class='verse-line'>{}</span></p>"},"ja406:5.1":{"pli":"“Kāmaṁ ruppatu vā mā vā, ","html":"<p><span class='verse-line'>{}</span>"},"ja406:5.2":{"pli":"bhusaṁva vikirīyatu; ","html":"<span class='verse-line'>{}</span>"},"ja406:5.3":{"pli":"Dhammaṁ me bhaṇamānassa, ","html":"<span class='verse-line'>{}</span>"},"ja406:5.4":{"pli":"na pāpamupalimpati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja406:6.1":{"pli":"“No ce assa sakā buddhi, ","html":"<p><span class='verse-line'>{}</span>"},"ja406:6.2":{"pli":"vinayo vā susikkhito; ","html":"<span class='verse-line'>{}</span>"},"ja406:6.3":{"pli":"Vane andhamahiṁsova, ","html":"<span class='verse-line'>{}</span>"},"ja406:6.4":{"pli":"careyya bahuko jano. ","html":"<span class='verse-line'>{}</span></p>"},"ja406:7.1":{"pli":"Yasmā ca panidhekacce, ","html":"<p><span class='verse-line'>{}</span>"},"ja406:7.2":{"pli":"āceramhi susikkhitā; ","html":"<span class='verse-line'>{}</span>"},"ja406:7.3":{"pli":"Tasmā vinītavinayā, ","html":"<span class='verse-line'>{}</span>"},"ja406:7.4":{"pli":"caranti susamāhitā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja406:8.1":{"pli":"Gandhārajātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja407":{"ja407:0.1":{"pli":"Jātaka ","html":"<article id='ja407'><header><ul><li class='division'>{}</li>"},"ja407:0.2":{"pli":"Sattakanipāta ","html":"<li>{}</li>"},"ja407:0.3":{"pli":"Gandhāravagga ","html":"<li>{}</li></ul>"},"ja407:0.4":{"pli":"2. Mahākapijātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja407:1.1":{"pli":"“Attānaṁ saṅkamaṁ katvā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja407:1.2":{"pli":"Yo sotthiṁ samatārayi; ","html":"<span class='verse-line'>{}</span>"},"ja407:1.3":{"pli":"Kiṁ tvaṁ tesaṁ kime tuyhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja407:1.4":{"pli":"Honti ete mahākapi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja407:2.1":{"pli":"“Rājāhaṁ issaro tesaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja407:2.2":{"pli":"yūthassa parihārako; ","html":"<span class='verse-line'>{}</span>"},"ja407:2.3":{"pli":"Tesaṁ sokaparetānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja407:2.4":{"pli":"bhītānaṁ te arindama. ","html":"<span class='verse-line'>{}</span></p>"},"ja407:3.1":{"pli":"Ullaṅghayitvā attānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja407:3.2":{"pli":"vissaṭṭhadhanuno sataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja407:3.3":{"pli":"Tato aparapādesu, ","html":"<span class='verse-line'>{}</span>"},"ja407:3.4":{"pli":"daḷhaṁ bandhaṁ latāguṇaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja407:4.1":{"pli":"Chinnabbhamiva vātena, ","html":"<p><span class='verse-line'>{}</span>"},"ja407:4.2":{"pli":"Nuṇṇo rukkhaṁ upāgamiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja407:4.3":{"pli":"Sohaṁ appabhavaṁ tattha, ","html":"<span class='verse-line'>{}</span>"},"ja407:4.4":{"pli":"Sākhaṁ hatthehi aggahiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja407:5.1":{"pli":"Taṁ maṁ viyāyataṁ santaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja407:5.2":{"pli":"sākhāya ca latāya ca; ","html":"<span class='verse-line'>{}</span>"},"ja407:5.3":{"pli":"Samanukkamantā pādehi, ","html":"<span class='verse-line'>{}</span>"},"ja407:5.4":{"pli":"sotthiṁ sākhāmigā gatā. ","html":"<span class='verse-line'>{}</span></p>"},"ja407:6.1":{"pli":"Taṁ maṁ na tapate bandho, ","html":"<p><span class='verse-line'>{}</span>"},"ja407:6.2":{"pli":"mato me na tapessati; ","html":"<span class='verse-line'>{}</span>"},"ja407:6.3":{"pli":"Sukhamāharitaṁ tesaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja407:6.4":{"pli":"yesaṁ rajjamakārayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja407:7.1":{"pli":"Esā te upamā rāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja407:7.2":{"pli":"taṁ suṇohi arindama; ","html":"<span class='verse-line'>{}</span>"},"ja407:7.3":{"pli":"Raññā raṭṭhassa yoggassa, ","html":"<span class='verse-line'>{}</span>"},"ja407:7.4":{"pli":"balassa nigamassa ca; ","html":"<span class='verse-line'>{}</span>"},"ja407:7.5":{"pli":"Sabbesaṁ sukhameṭṭhabbaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja407:7.6":{"pli":"khattiyena pajānatā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja407:8.1":{"pli":"Mahākapijātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja408":{"ja408:0.1":{"pli":"Jātaka ","html":"<article id='ja408'><header><ul><li class='division'>{}</li>"},"ja408:0.2":{"pli":"Sattakanipāta ","html":"<li>{}</li>"},"ja408:0.3":{"pli":"Gandhāravagga ","html":"<li>{}</li></ul>"},"ja408:0.4":{"pli":"3. Kumbhakārajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja408:1.1":{"pli":"“Ambāhamaddaṁ vanamantarasmiṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja408:1.2":{"pli":"Nīlobhāsaṁ phalitaṁ saṁvirūḷhaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja408:1.3":{"pli":"Tamaddasaṁ phalahetu vibhaggaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja408:1.4":{"pli":"Taṁ disvā bhikkhācariyaṁ carāmi. ","html":"<span class='verse-line'>{}</span></p>"},"ja408:2.1":{"pli":"Selaṁ sumaṭṭhaṁ naravīraniṭṭhitaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja408:2.2":{"pli":"Nārī yugaṁ dhārayi appasaddaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja408:2.3":{"pli":"Dutiyañca āgamma ahosi saddo, ","html":"<span class='verse-line'>{}</span>"},"ja408:2.4":{"pli":"Taṁ disvā bhikkhācariyaṁ carāmi. ","html":"<span class='verse-line'>{}</span></p>"},"ja408:3.1":{"pli":"Dijā dijaṁ kuṇapamāharantaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja408:3.2":{"pli":"Ekaṁ samānaṁ bahukā samecca; ","html":"<span class='verse-line'>{}</span>"},"ja408:3.3":{"pli":"Āhārahetū paripātayiṁsu, ","html":"<span class='verse-line'>{}</span>"},"ja408:3.4":{"pli":"Taṁ disvā bhikkhācariyaṁ carāmi. ","html":"<span class='verse-line'>{}</span></p>"},"ja408:4.1":{"pli":"Usabhāhamaddaṁ yūthassa majjhe, ","html":"<p><span class='verse-line'>{}</span>"},"ja408:4.2":{"pli":"Calakkakuṁ vaṇṇabalūpapannaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja408:4.3":{"pli":"Tamaddasaṁ kāmahetu vitunnaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja408:4.4":{"pli":"Taṁ disvā bhikkhācariyaṁ carāmi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja408:5.1":{"pli":"“Karaṇḍako kaliṅgānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja408:5.2":{"pli":"gandhārānañca naggaji; ","html":"<span class='verse-line'>{}</span>"},"ja408:5.3":{"pli":"Nimirājā videhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja408:5.4":{"pli":"pañcālānañca dummukho; ","html":"<span class='verse-line'>{}</span>"},"ja408:5.5":{"pli":"Ete raṭṭhāni hitvāna, ","html":"<span class='verse-line'>{}</span>"},"ja408:5.6":{"pli":"pabbajiṁsu akiñcanā. ","html":"<span class='verse-line'>{}</span></p>"},"ja408:6.1":{"pli":"Sabbepime devasamā samāgatā, ","html":"<p><span class='verse-line'>{}</span>"},"ja408:6.2":{"pli":"Aggī yathā pajjalito tathevime; ","html":"<span class='verse-line'>{}</span>"},"ja408:6.3":{"pli":"Ahampi eko carissāmi bhaggavi, ","html":"<span class='verse-line'>{}</span>"},"ja408:6.4":{"pli":"Hitvāna kāmāni yathodhikāni”. ","html":"<span class='verse-line'>{}</span></p>"},"ja408:7.1":{"pli":"“Ayameva kālo na hi añño atthi, ","html":"<p><span class='verse-line'>{}</span>"},"ja408:7.2":{"pli":"Anusāsitā me na bhaveyya pacchā; ","html":"<span class='verse-line'>{}</span>"},"ja408:7.3":{"pli":"Ahampi ekā carissāmi bhaggava, ","html":"<span class='verse-line'>{}</span>"},"ja408:7.4":{"pli":"Sakuṇīva muttā purisassa hatthā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja408:8.1":{"pli":"“Āmaṁ pakkañca jānanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja408:8.2":{"pli":"atho loṇaṁ aloṇakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja408:8.3":{"pli":"Tamahaṁ disvāna pabbajiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja408:8.4":{"pli":"careva tvaṁ carāmahan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja408:9.1":{"pli":"Kumbhakārajātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja409":{"ja409:0.1":{"pli":"Jātaka ","html":"<article id='ja409'><header><ul><li class='division'>{}</li>"},"ja409:0.2":{"pli":"Sattakanipāta ","html":"<li>{}</li>"},"ja409:0.3":{"pli":"Gandhāravagga ","html":"<li>{}</li></ul>"},"ja409:0.4":{"pli":"4. Daḷhadhammajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja409:1.1":{"pli":"“Ahañce daḷhadhammassa, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja409:1.2":{"pli":"vahantī nābhirādhayiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja409:1.3":{"pli":"Dharantī urasi sallaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja409:1.4":{"pli":"yuddhe vikkantacārinī. ","html":"<span class='verse-line'>{}</span></p>"},"ja409:2.1":{"pli":"Nūna rājā na jānāti, ","html":"<p><span class='verse-line'>{}</span>"},"ja409:2.2":{"pli":"mama vikkamaporisaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja409:2.3":{"pli":"Saṅgāme sukatantāni, ","html":"<span class='verse-line'>{}</span>"},"ja409:2.4":{"pli":"dūtavippahitāni ca. ","html":"<span class='verse-line'>{}</span></p>"},"ja409:3.1":{"pli":"Sā nūnāhaṁ marissāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja409:3.2":{"pli":"abandhu aparāyinī; ","html":"<span class='verse-line'>{}</span>"},"ja409:3.3":{"pli":"Tadā hi kumbhakārassa, ","html":"<span class='verse-line'>{}</span>"},"ja409:3.4":{"pli":"dinnā chakaṇahārikā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja409:4.1":{"pli":"“Yāvatāsīsatī poso, ","html":"<p><span class='verse-line'>{}</span>"},"ja409:4.2":{"pli":"tāvadeva pavīṇati; ","html":"<span class='verse-line'>{}</span>"},"ja409:4.3":{"pli":"Atthāpāye jahanti naṁ, ","html":"<span class='verse-line'>{}</span>"},"ja409:4.4":{"pli":"oṭṭhibyādhiṁva khattiyo. ","html":"<span class='verse-line'>{}</span></p>"},"ja409:5.1":{"pli":"Yo pubbe katakalyāṇo, ","html":"<p><span class='verse-line'>{}</span>"},"ja409:5.2":{"pli":"katattho nāvabujjhati; ","html":"<span class='verse-line'>{}</span>"},"ja409:5.3":{"pli":"Atthā tassa palujjanti, ","html":"<span class='verse-line'>{}</span>"},"ja409:5.4":{"pli":"ye honti abhipatthitā. ","html":"<span class='verse-line'>{}</span></p>"},"ja409:6.1":{"pli":"Yo pubbe katakalyāṇo, ","html":"<p><span class='verse-line'>{}</span>"},"ja409:6.2":{"pli":"katattho manubujjhati; ","html":"<span class='verse-line'>{}</span>"},"ja409:6.3":{"pli":"Atthā tassa pavaḍḍhanti, ","html":"<span class='verse-line'>{}</span>"},"ja409:6.4":{"pli":"ye honti abhipatthitā. ","html":"<span class='verse-line'>{}</span></p>"},"ja409:7.1":{"pli":"Taṁ vo vadāmi bhaddante, ","html":"<p><span class='verse-line'>{}</span>"},"ja409:7.2":{"pli":"yāvantettha samāgatā; ","html":"<span class='verse-line'>{}</span>"},"ja409:7.3":{"pli":"Sabbe kataññuno hotha, ","html":"<span class='verse-line'>{}</span>"},"ja409:7.4":{"pli":"ciraṁ saggamhi ṭhassathā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja409:8.1":{"pli":"Daḷhadhammajātakaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja41":{"ja41:0.1":{"pli":"Jātaka ","eng":"Stories of Past Lives 41 ","html":"<article id='ja41'><header><ul><li class='division'>{}</li>"},"ja41:0.2":{"pli":"Ekakanipāta ","eng":"The Book of the Ones ","html":"<li>{}</li>"},"ja41:0.3":{"pli":"Atthakāmavagga ","eng":"Wanting to Help ","html":"<li>{}</li></ul>"},"ja41:0.4":{"pli":"1. Losakajātaka ","eng":"About Losaka: a past life story ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja41:1.1":{"pli":"“Yo atthakāmassa hitānukampino, ","eng":"One who does not follow advice when instructed ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>","comm":"After an act of jealousy towards an arahant in a distant past life, so the story goes, Mittaka’s bad character, as much as his bad kamma, resulted in a series of extravagant tragedies over many lives. "},"ja41:1.2":{"pli":"Ovajjamāno na karoti sāsanaṁ; ","eng":"by an ally who desires their good, ","html":"<span class='verse-line'>{}</span>"},"ja41:1.3":{"pli":"Ajiyā pādamolamba, ","eng":"grieves like Mittaka ","html":"<span class='verse-line'>{}</span>","comm":"Mittaka is called Mittavindaka in the past life story and Losaka Tissa in the story of the present. The name Losaka, otherwise unattested in Pali, is a patronymic stemming from Luśa Dhānāka of Rig Veda 10.35 and 10.36. "},"ja41:1.4":{"pli":"Mittako viya socatī”ti. ","eng":"hanging off a goat’s foot. ","html":"<span class='verse-line'>{}</span></p></blockquote>","comm":"The details of how he came to be hanging off a goat’s foot are absurd and too complex to relate here. The events collate several stories of the archetypal scapegoat type, subsuming this ancient mythic and ritual idea under the doctrine of kamma. In such cases, absurdity is used for humorous effect, but it also draws on the surreal and fantastical narratives that swirl around the Vedic ritual. The story likely began as an explanation for a detail of Vedic sacrifice. "},"ja41:2.1":{"pli":"Losakajātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja410":{"ja410:0.1":{"pli":"Jātaka ","html":"<article id='ja410'><header><ul><li class='division'>{}</li>"},"ja410:0.2":{"pli":"Sattakanipāta ","html":"<li>{}</li>"},"ja410:0.3":{"pli":"Gandhāravagga ","html":"<li>{}</li></ul>"},"ja410:0.4":{"pli":"5. Somadattajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja410:1.1":{"pli":"“Yo maṁ pure paccuḍḍeti, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja410:1.2":{"pli":"araññe dūramāyato; ","html":"<span class='verse-line'>{}</span>"},"ja410:1.3":{"pli":"So na dissati mātaṅgo, ","html":"<span class='verse-line'>{}</span>"},"ja410:1.4":{"pli":"somadatto kuhiṁ gato. ","html":"<span class='verse-line'>{}</span></p>"},"ja410:2.1":{"pli":"Ayaṁ vā so mato seti, ","html":"<p><span class='verse-line'>{}</span>"},"ja410:2.2":{"pli":"allasiṅgaṁva vacchito; ","html":"<span class='verse-line'>{}</span>"},"ja410:2.3":{"pli":"Bhumyā nipatito seti, ","html":"<span class='verse-line'>{}</span>"},"ja410:2.4":{"pli":"amarā vata kuñjaro”. ","html":"<span class='verse-line'>{}</span></p>"},"ja410:3.1":{"pli":"“Anagāriyupetassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja410:3.2":{"pli":"vippamuttassa te sato; ","html":"<span class='verse-line'>{}</span>"},"ja410:3.3":{"pli":"Samaṇassa na taṁ sādhu, ","html":"<span class='verse-line'>{}</span>"},"ja410:3.4":{"pli":"yaṁ petamanusocasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja410:4.1":{"pli":"“Saṁvāsena have sakka, ","html":"<p><span class='verse-line'>{}</span>"},"ja410:4.2":{"pli":"manussassa migassa vā; ","html":"<span class='verse-line'>{}</span>"},"ja410:4.3":{"pli":"Hadaye jāyate pemaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja410:4.4":{"pli":"taṁ na sakkā asocituṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja410:5.1":{"pli":"“Mataṁ marissaṁ rodanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja410:5.2":{"pli":"ye rudanti lapanti ca; ","html":"<span class='verse-line'>{}</span>"},"ja410:5.3":{"pli":"Tasmā tvaṁ isi mā rodi, ","html":"<span class='verse-line'>{}</span>"},"ja410:5.4":{"pli":"roditaṁ moghamāhu santo. ","html":"<span class='verse-line'>{}</span></p>"},"ja410:6.1":{"pli":"Kanditena have brahme, ","html":"<p><span class='verse-line'>{}</span>"},"ja410:6.2":{"pli":"mato peto samuṭṭhahe; ","html":"<span class='verse-line'>{}</span>"},"ja410:6.3":{"pli":"Sabbe saṅgamma rodāma, ","html":"<span class='verse-line'>{}</span>"},"ja410:6.4":{"pli":"aññamaññassa ñātake”. ","html":"<span class='verse-line'>{}</span></p>"},"ja410:7.1":{"pli":"“Ādittaṁ vata maṁ santaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja410:7.2":{"pli":"ghatasittaṁva pāvakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja410:7.3":{"pli":"Vārinā viya osiñcaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja410:7.4":{"pli":"sabbaṁ nibbāpaye daraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja410:8.1":{"pli":"Abbahī vata me sallaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja410:8.2":{"pli":"yamāsi hadayassitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja410:8.3":{"pli":"Yo me sokaparetassa, ","html":"<span class='verse-line'>{}</span>"},"ja410:8.4":{"pli":"puttasokaṁ apānudi. ","html":"<span class='verse-line'>{}</span></p>"},"ja410:9.1":{"pli":"Sohaṁ abbūḷhasallosmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja410:9.2":{"pli":"vītasoko anāvilo; ","html":"<span class='verse-line'>{}</span>"},"ja410:9.3":{"pli":"Na socāmi na rodāmi, ","html":"<span class='verse-line'>{}</span>"},"ja410:9.4":{"pli":"tava sutvāna vāsavā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja410:10.1":{"pli":"Somadattajātakaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja411":{"ja411:0.1":{"pli":"Jātaka ","html":"<article id='ja411'><header><ul><li class='division'>{}</li>"},"ja411:0.2":{"pli":"Sattakanipāta ","html":"<li>{}</li>"},"ja411:0.3":{"pli":"Gandhāravagga ","html":"<li>{}</li></ul>"},"ja411:0.4":{"pli":"6. Susīmajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja411:1.1":{"pli":"“Kāḷāni kesāni pure ahesuṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja411:1.2":{"pli":"Jātāni sīsamhi yathāpadese; ","html":"<span class='verse-line'>{}</span>"},"ja411:1.3":{"pli":"Tānajja setāni susīma disvā, ","html":"<span class='verse-line'>{}</span>"},"ja411:1.4":{"pli":"Dhammaṁ cara brahmacariyassa kālo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja411:2.1":{"pli":"“Mameva deva palitaṁ na tuyhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja411:2.2":{"pli":"Mameva sīsaṁ mama uttamaṅgaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja411:2.3":{"pli":"‘Atthaṁ karissan’ti musā abhāṇiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja411:2.4":{"pli":"Ekāparādhaṁ khama rājaseṭṭha. ","html":"<span class='verse-line'>{}</span></p>"},"ja411:3.1":{"pli":"Daharo tuvaṁ dassaniyosi rāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja411:3.2":{"pli":"Paṭhamuggato hosi yathā kaḷīro; ","html":"<span class='verse-line'>{}</span>"},"ja411:3.3":{"pli":"Rajjañca kārehi mamañca passa, ","html":"<span class='verse-line'>{}</span>"},"ja411:3.4":{"pli":"Mā kālikaṁ anudhāvī janinda”. ","html":"<span class='verse-line'>{}</span></p>"},"ja411:4.1":{"pli":"“Passāmi vohaṁ dahariṁ kumāriṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja411:4.2":{"pli":"Sāmaṭṭhapassaṁ sutanuṁ sumajjhaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja411:4.3":{"pli":"Kāḷappavāḷāva pavellamānā, ","html":"<span class='verse-line'>{}</span>"},"ja411:4.4":{"pli":"Palobhayantīva naresu gacchati. ","html":"<span class='verse-line'>{}</span></p>"},"ja411:5.1":{"pli":"Tamena passāmiparena nāriṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja411:5.2":{"pli":"Āsītikaṁ nāvutikaṁ va jaccā; ","html":"<span class='verse-line'>{}</span>"},"ja411:5.3":{"pli":"Daṇḍaṁ gahetvāna pavedhamānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja411:5.4":{"pli":"Gopānasībhoggasamaṁ carantiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja411:6.1":{"pli":"Sohaṁ tamevānuvicintayanto, ","html":"<p><span class='verse-line'>{}</span>"},"ja411:6.2":{"pli":"Eko sayāmi sayanassa majjhe; ","html":"<span class='verse-line'>{}</span>"},"ja411:6.3":{"pli":"‘Ahampi evaṁ’ iti pekkhamāno, ","html":"<span class='verse-line'>{}</span>"},"ja411:6.4":{"pli":"Na gahe rame brahmacariyassa kālo. ","html":"<span class='verse-line'>{}</span></p>"},"ja411:7.1":{"pli":"Rajjuvālambanī cesā, ","html":"<p><span class='verse-line'>{}</span>"},"ja411:7.2":{"pli":"Yā gehe vasato rati; ","html":"<span class='verse-line'>{}</span>"},"ja411:7.3":{"pli":"Evampi chetvāna vajanti dhīrā, ","html":"<span class='verse-line'>{}</span>"},"ja411:7.4":{"pli":"Anapekkhino kāmasukhaṁ pahāyā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja411:8.1":{"pli":"Susīmajātakaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja412":{"ja412:0.1":{"pli":"Jātaka ","html":"<article id='ja412'><header><ul><li class='division'>{}</li>"},"ja412:0.2":{"pli":"Sattakanipāta ","html":"<li>{}</li>"},"ja412:0.3":{"pli":"Gandhāravagga ","html":"<li>{}</li></ul>"},"ja412:0.4":{"pli":"7. Koṭasimbalijātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja412:1.1":{"pli":"“Ahaṁ dasasataṁbyāmaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja412:1.2":{"pli":"uragamādāya āgato; ","html":"<span class='verse-line'>{}</span>"},"ja412:1.3":{"pli":"Tañca mañca mahākāyaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja412:1.4":{"pli":"dhārayaṁ nappavedhasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja412:2.1":{"pli":"Athimaṁ khuddakaṁ pakkhiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja412:2.2":{"pli":"Appamaṁsataraṁ mayā; ","html":"<span class='verse-line'>{}</span>"},"ja412:2.3":{"pli":"Dhārayaṁ byathasi bhītā, ","html":"<span class='verse-line'>{}</span>"},"ja412:2.4":{"pli":"Kamatthaṁ koṭasimbali”. ","html":"<span class='verse-line'>{}</span></p>"},"ja412:3.1":{"pli":"“Maṁsabhakkho tuvaṁ rāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja412:3.2":{"pli":"phalabhakkho ayaṁ dijo; ","html":"<span class='verse-line'>{}</span>"},"ja412:3.3":{"pli":"Ayaṁ nigrodhabījāni, ","html":"<span class='verse-line'>{}</span>"},"ja412:3.4":{"pli":"pilakkhudumbarāni ca; ","html":"<span class='verse-line'>{}</span>"},"ja412:3.5":{"pli":"Assatthāni ca bhakkhitvā, ","html":"<span class='verse-line'>{}</span>"},"ja412:3.6":{"pli":"khandhe me ohadissati. ","html":"<span class='verse-line'>{}</span></p>"},"ja412:4.1":{"pli":"Te rukkhā saṁvirūhanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja412:4.2":{"pli":"mama passe nivātajā; ","html":"<span class='verse-line'>{}</span>"},"ja412:4.3":{"pli":"Te maṁ pariyonandhissanti, ","html":"<span class='verse-line'>{}</span>"},"ja412:4.4":{"pli":"arukkhaṁ maṁ karissare. ","html":"<span class='verse-line'>{}</span></p>"},"ja412:5.1":{"pli":"Santi aññepi rukkhā se, ","html":"<p><span class='verse-line'>{}</span>"},"ja412:5.2":{"pli":"mūlino khandhino dumā; ","html":"<span class='verse-line'>{}</span>"},"ja412:5.3":{"pli":"Iminā sakuṇajātena, ","html":"<span class='verse-line'>{}</span>"},"ja412:5.4":{"pli":"bījamāharitā hatā. ","html":"<span class='verse-line'>{}</span></p>"},"ja412:6.1":{"pli":"Ajjhārūhābhivaḍḍhanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja412:6.2":{"pli":"brahantampi vanappatiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja412:6.3":{"pli":"Tasmā rāja pavedhāmi, ","html":"<span class='verse-line'>{}</span>"},"ja412:6.4":{"pli":"sampassaṁnāgataṁ bhayaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja412:7.1":{"pli":"“Saṅkeyya saṅkitabbāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja412:7.2":{"pli":"rakkheyyānāgataṁ bhayaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja412:7.3":{"pli":"Anāgatabhayā dhīro, ","html":"<span class='verse-line'>{}</span>"},"ja412:7.4":{"pli":"ubho loke avekkhatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja412:8.1":{"pli":"Koṭasimbalijātakaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja413":{"ja413:0.1":{"pli":"Jātaka ","html":"<article id='ja413'><header><ul><li class='division'>{}</li>"},"ja413:0.2":{"pli":"Sattakanipāta ","html":"<li>{}</li>"},"ja413:0.3":{"pli":"Gandhāravagga ","html":"<li>{}</li></ul>"},"ja413:0.4":{"pli":"8. Dhūmakārijātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja413:1.1":{"pli":"“Rājā apucchi vidhuraṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja413:1.2":{"pli":"dhammakāmo yudhiṭṭhilo; ","html":"<span class='verse-line'>{}</span>"},"ja413:1.3":{"pli":"Api brāhmaṇa jānāsi, ","html":"<span class='verse-line'>{}</span>"},"ja413:1.4":{"pli":"ko eko bahu socati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja413:2.1":{"pli":"“Brāhmaṇo ajayūthena, ","html":"<p><span class='verse-line'>{}</span>"},"ja413:2.2":{"pli":"pahūtedho vane vasaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja413:2.3":{"pli":"Dhūmaṁ akāsi vāseṭṭho, ","html":"<span class='verse-line'>{}</span>"},"ja413:2.4":{"pli":"rattindivamatandito. ","html":"<span class='verse-line'>{}</span></p>"},"ja413:3.1":{"pli":"Tassa taṁ dhūmagandhena, ","html":"<p><span class='verse-line'>{}</span>"},"ja413:3.2":{"pli":"sarabhā makasaḍḍitā; ","html":"<span class='verse-line'>{}</span>"},"ja413:3.3":{"pli":"Vassāvāsaṁ upāgacchuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja413:3.4":{"pli":"dhūmakārissa santike. ","html":"<span class='verse-line'>{}</span></p>"},"ja413:4.1":{"pli":"Sarabhesu manaṁ katvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja413:4.2":{"pli":"ajā so nāvabujjhatha; ","html":"<span class='verse-line'>{}</span>"},"ja413:4.3":{"pli":"Āgacchantī vajantī vā, ","html":"<span class='verse-line'>{}</span>"},"ja413:4.4":{"pli":"tassa tā vinasuṁ ajā. ","html":"<span class='verse-line'>{}</span></p>"},"ja413:5.1":{"pli":"Sarabhā sarade kāle, ","html":"<p><span class='verse-line'>{}</span>"},"ja413:5.2":{"pli":"pahīnamakase vane; ","html":"<span class='verse-line'>{}</span>"},"ja413:5.3":{"pli":"Pāvisuṁ giriduggāni, ","html":"<span class='verse-line'>{}</span>"},"ja413:5.4":{"pli":"nadīnaṁ pabhavāni ca. ","html":"<span class='verse-line'>{}</span></p>"},"ja413:6.1":{"pli":"Sarabhe ca gate disvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja413:6.2":{"pli":"ajā ca vibhavaṁ gatā; ","html":"<span class='verse-line'>{}</span>"},"ja413:6.3":{"pli":"Kiso ca vivaṇṇo cāsi, ","html":"<span class='verse-line'>{}</span>"},"ja413:6.4":{"pli":"paṇḍurogī ca brāhmaṇo. ","html":"<span class='verse-line'>{}</span></p>"},"ja413:7.1":{"pli":"Evaṁ yo saṁ niraṅkatvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja413:7.2":{"pli":"āgantuṁ kurute piyaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja413:7.3":{"pli":"So eko bahu socati, ","html":"<span class='verse-line'>{}</span>"},"ja413:7.4":{"pli":"dhūmakārīva brāhmaṇo”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja413:8.1":{"pli":"Dhūmakārijātakaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja414":{"ja414:0.1":{"pli":"Jātaka ","html":"<article id='ja414'><header><ul><li class='division'>{}</li>"},"ja414:0.2":{"pli":"Sattakanipāta ","html":"<li>{}</li>"},"ja414:0.3":{"pli":"Gandhāravagga ","html":"<li>{}</li></ul>"},"ja414:0.4":{"pli":"9. Jāgarajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja414:1.1":{"pli":"“Kodha jāgarataṁ sutto, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja414:1.2":{"pli":"kodha suttesu jāgaro; ","html":"<span class='verse-line'>{}</span>"},"ja414:1.3":{"pli":"Ko mametaṁ vijānāti, ","html":"<span class='verse-line'>{}</span>"},"ja414:1.4":{"pli":"ko taṁ paṭibhaṇāti me”. ","html":"<span class='verse-line'>{}</span></p>"},"ja414:2.1":{"pli":"“Ahaṁ jāgarataṁ sutto, ","html":"<p><span class='verse-line'>{}</span>"},"ja414:2.2":{"pli":"ahaṁ suttesu jāgaro; ","html":"<span class='verse-line'>{}</span>"},"ja414:2.3":{"pli":"Ahametaṁ vijānāmi, ","html":"<span class='verse-line'>{}</span>"},"ja414:2.4":{"pli":"ahaṁ paṭibhaṇāmi te”. ","html":"<span class='verse-line'>{}</span></p>"},"ja414:3.1":{"pli":"“Kathaṁ jāgarataṁ sutto, ","html":"<p><span class='verse-line'>{}</span>"},"ja414:3.2":{"pli":"kathaṁ suttesu jāgaro; ","html":"<span class='verse-line'>{}</span>"},"ja414:3.3":{"pli":"Kathaṁ etaṁ vijānāsi, ","html":"<span class='verse-line'>{}</span>"},"ja414:3.4":{"pli":"kathaṁ paṭibhaṇāsi me”. ","html":"<span class='verse-line'>{}</span></p>"},"ja414:4.1":{"pli":"“Ye dhammaṁ nappajānanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja414:4.2":{"pli":"saṁyamoti damoti ca; ","html":"<span class='verse-line'>{}</span>"},"ja414:4.3":{"pli":"Tesu suppamānesu, ","html":"<span class='verse-line'>{}</span>"},"ja414:4.4":{"pli":"ahaṁ jaggāmi devate. ","html":"<span class='verse-line'>{}</span></p>"},"ja414:5.1":{"pli":"Yesaṁ rāgo ca doso ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja414:5.2":{"pli":"avijjā ca virājitā; ","html":"<span class='verse-line'>{}</span>"},"ja414:5.3":{"pli":"Tesu jāgaramānesu, ","html":"<span class='verse-line'>{}</span>"},"ja414:5.4":{"pli":"ahaṁ suttosmi devate. ","html":"<span class='verse-line'>{}</span></p>"},"ja414:6.1":{"pli":"Evaṁ jāgarataṁ sutto, ","html":"<p><span class='verse-line'>{}</span>"},"ja414:6.2":{"pli":"evaṁ suttesu jāgaro; ","html":"<span class='verse-line'>{}</span>"},"ja414:6.3":{"pli":"Evametaṁ vijānāmi, ","html":"<span class='verse-line'>{}</span>"},"ja414:6.4":{"pli":"evaṁ paṭibhaṇāmi te”. ","html":"<span class='verse-line'>{}</span></p>"},"ja414:7.1":{"pli":"“Sādhu jāgarataṁ sutto, ","html":"<p><span class='verse-line'>{}</span>"},"ja414:7.2":{"pli":"sādhu suttesu jāgaro; ","html":"<span class='verse-line'>{}</span>"},"ja414:7.3":{"pli":"Sādhumetaṁ vijānāsi, ","html":"<span class='verse-line'>{}</span>"},"ja414:7.4":{"pli":"sādhu paṭibhaṇāsi me”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja414:8.1":{"pli":"Jāgarajātakaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja415":{"ja415:0.1":{"pli":"Jātaka ","html":"<article id='ja415'><header><ul><li class='division'>{}</li>"},"ja415:0.2":{"pli":"Sattakanipāta ","html":"<li>{}</li>"},"ja415:0.3":{"pli":"Gandhāravagga ","html":"<li>{}</li></ul>"},"ja415:0.4":{"pli":"10. Kummāsapiṇḍijātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja415:1.1":{"pli":"“Na kiratthi anomadassisu, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja415:1.2":{"pli":"Pāricariyā buddhesu appikā; ","html":"<span class='verse-line'>{}</span>"},"ja415:1.3":{"pli":"Sukkhāya aloṇikāya ca, ","html":"<span class='verse-line'>{}</span>"},"ja415:1.4":{"pli":"Passaphalaṁ kummāsapiṇḍiyā. ","html":"<span class='verse-line'>{}</span></p>"},"ja415:2.1":{"pli":"Hatthigavassā cime bahū, ","html":"<p><span class='verse-line'>{}</span>"},"ja415:2.2":{"pli":"Dhanadhaññaṁ pathavī ca kevalā; ","html":"<span class='verse-line'>{}</span>"},"ja415:2.3":{"pli":"Nāriyo cimā accharūpamā, ","html":"<span class='verse-line'>{}</span>"},"ja415:2.4":{"pli":"Passa phalaṁ kummāsapiṇḍiyā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja415:3.1":{"pli":"“Abhikkhaṇaṁ rājakuñjara, ","html":"<p><span class='verse-line'>{}</span>"},"ja415:3.2":{"pli":"Gāthā bhāsasi kosalādhipa; ","html":"<span class='verse-line'>{}</span>"},"ja415:3.3":{"pli":"Pucchāmi taṁ raṭṭhavaḍḍhana, ","html":"<span class='verse-line'>{}</span>"},"ja415:3.4":{"pli":"Bāḷhaṁ pītimano pabhāsasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja415:4.1":{"pli":"“Imasmiññeva nagare, ","html":"<p><span class='verse-line'>{}</span>"},"ja415:4.2":{"pli":"kule aññatare ahuṁ; ","html":"<span class='verse-line'>{}</span>"},"ja415:4.3":{"pli":"Parakammakaro āsiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja415:4.4":{"pli":"bhatako sīlasaṁvuto. ","html":"<span class='verse-line'>{}</span></p>"},"ja415:5.1":{"pli":"Kammāya nikkhamantohaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja415:5.2":{"pli":"caturo samaṇeddasaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja415:5.3":{"pli":"Ācārasīlasampanne, ","html":"<span class='verse-line'>{}</span>"},"ja415:5.4":{"pli":"sītibhūte anāsave. ","html":"<span class='verse-line'>{}</span></p>"},"ja415:6.1":{"pli":"Tesu cittaṁ pasādetvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja415:6.2":{"pli":"nisīdetvā paṇṇasanthate; ","html":"<span class='verse-line'>{}</span>"},"ja415:6.3":{"pli":"Adaṁ buddhāna kummāsaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja415:6.4":{"pli":"pasanno sehi pāṇibhi. ","html":"<span class='verse-line'>{}</span></p>"},"ja415:7.1":{"pli":"Tassa kammassa kusalassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja415:7.2":{"pli":"idaṁ me edisaṁ phalaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja415:7.3":{"pli":"Anubhomi idaṁ rajjaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja415:7.4":{"pli":"phītaṁ dharaṇimuttamaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja415:8.1":{"pli":"“Dadaṁ bhuñja mā ca pamādo, ","html":"<p><span class='verse-line'>{}</span>"},"ja415:8.2":{"pli":"Cakkaṁ vattaya kosalādhipa; ","html":"<span class='verse-line'>{}</span>"},"ja415:8.3":{"pli":"Mā rāja adhammiko ahu, ","html":"<span class='verse-line'>{}</span>"},"ja415:8.4":{"pli":"Dhammaṁ pālaya kosalādhipa”. ","html":"<span class='verse-line'>{}</span></p>"},"ja415:9.1":{"pli":"“Sohaṁ tadeva punappunaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja415:9.2":{"pli":"Vaṭumaṁ ācarissāmi sobhane; ","html":"<span class='verse-line'>{}</span>"},"ja415:9.3":{"pli":"Ariyācaritaṁ sukosale, ","html":"<span class='verse-line'>{}</span>"},"ja415:9.4":{"pli":"Arahanto me manāpāva passituṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja415:10.1":{"pli":"Devī viya accharūpamā, ","html":"<p><span class='verse-line'>{}</span>"},"ja415:10.2":{"pli":"Majjhe nārigaṇassa sobhasi; ","html":"<span class='verse-line'>{}</span>"},"ja415:10.3":{"pli":"Kiṁ kammamakāsi bhaddakaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja415:10.4":{"pli":"Kenāsi vaṇṇavatī sukosale”. ","html":"<span class='verse-line'>{}</span></p>"},"ja415:11.1":{"pli":"“Ambaṭṭhakulassa khattiya, ","html":"<p><span class='verse-line'>{}</span>"},"ja415:11.2":{"pli":"Dāsyāhaṁ parapesiyā ahuṁ; ","html":"<span class='verse-line'>{}</span>"},"ja415:11.3":{"pli":"Saññatā ca dhammajīvinī, ","html":"<span class='verse-line'>{}</span>"},"ja415:11.4":{"pli":"Sīlavatī ca apāpadassanā. ","html":"<span class='verse-line'>{}</span></p>"},"ja415:12.1":{"pli":"Uddhaṭabhattaṁ ahaṁ tadā, ","html":"<p><span class='verse-line'>{}</span>"},"ja415:12.2":{"pli":"Caramānassa adāsi bhikkhuno; ","html":"<span class='verse-line'>{}</span>"},"ja415:12.3":{"pli":"Vittā sumanā sayaṁ ahaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja415:12.4":{"pli":"Tassa kammassa phalaṁ mamedisan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja415:13.1":{"pli":"Kummāsapiṇḍijātakaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja416":{"ja416:0.1":{"pli":"Jātaka ","html":"<article id='ja416'><header><ul><li class='division'>{}</li>"},"ja416:0.2":{"pli":"Sattakanipāta ","html":"<li>{}</li>"},"ja416:0.3":{"pli":"Gandhāravagga ","html":"<li>{}</li></ul>"},"ja416:0.4":{"pli":"11. Parantapajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja416:1.1":{"pli":"“Āgamissati me pāpaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja416:1.2":{"pli":"āgamissati me bhayaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja416:1.3":{"pli":"Tadā hi calitā sākhā, ","html":"<span class='verse-line'>{}</span>"},"ja416:1.4":{"pli":"manussena migena vā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja416:2.1":{"pli":"“Bhīruyā nūna me kāmo, ","html":"<p><span class='verse-line'>{}</span>"},"ja416:2.2":{"pli":"avidūre vasantiyā; ","html":"<span class='verse-line'>{}</span>"},"ja416:2.3":{"pli":"Karissati kisaṁ paṇḍuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja416:2.4":{"pli":"sāva sākhā parantapaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja416:3.1":{"pli":"Socayissati maṁ kantā, ","html":"<p><span class='verse-line'>{}</span>"},"ja416:3.2":{"pli":"gāme vasamaninditā; ","html":"<span class='verse-line'>{}</span>"},"ja416:3.3":{"pli":"Karissati kisaṁ paṇḍuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja416:3.4":{"pli":"sāva sākhā parantapaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja416:4.1":{"pli":"Tayā maṁ asitāpaṅgi, ","html":"<p><span class='verse-line'>{}</span>"},"ja416:4.2":{"pli":"sitāni bhaṇitāni ca; ","html":"<span class='verse-line'>{}</span>"},"ja416:4.3":{"pli":"Kisaṁ paṇḍuṁ karissanti, ","html":"<span class='verse-line'>{}</span>"},"ja416:4.4":{"pli":"sāva sākhā parantapaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja416:5.1":{"pli":"“Agamā nūna so saddo, ","html":"<p><span class='verse-line'>{}</span>"},"ja416:5.2":{"pli":"asaṁsi nūna so tava; ","html":"<span class='verse-line'>{}</span>"},"ja416:5.3":{"pli":"Akkhātaṁ nūna taṁ tena, ","html":"<span class='verse-line'>{}</span>"},"ja416:5.4":{"pli":"yo taṁ sākhamakampayi. ","html":"<span class='verse-line'>{}</span></p>"},"ja416:6.1":{"pli":"Idaṁ kho taṁ samāgamma, ","html":"<p><span class='verse-line'>{}</span>"},"ja416:6.2":{"pli":"mama bālassa cintitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja416:6.3":{"pli":"Tadā hi calitā sākhā, ","html":"<span class='verse-line'>{}</span>"},"ja416:6.4":{"pli":"manussena migena vā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja416:7.1":{"pli":"“Tatheva tvaṁ avedesi, ","html":"<p><span class='verse-line'>{}</span>"},"ja416:7.2":{"pli":"Avañci pitaraṁ mama; ","html":"<span class='verse-line'>{}</span>"},"ja416:7.3":{"pli":"Hantvā sākhāhi chādento, ","html":"<span class='verse-line'>{}</span>"},"ja416:7.4":{"pli":"Āgamissati me bhayan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja416:8.1":{"pli":"Parantapajātakaṁ ekādasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja416:8.2":{"pli":"Gandhāravaggo dutiyo. ","html":"<p class='endvagga'>{}</p>"},"ja416:9.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja416:10.1":{"pli":"Varagāma mahākapi bhaggava ca, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja416:10.2":{"pli":"Daḷhadhamma sakuñjara kesavaro; ","html":"<span class='verse-line'>{}</span>"},"ja416:10.3":{"pli":"Urago vidhuro puna jāgarataṁ, ","html":"<span class='verse-line'>{}</span>"},"ja416:10.4":{"pli":"Atha kosalādhipa parantapa cāti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja416:11.1":{"pli":"Atha vagguddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja416:12.1":{"pli":"Atha sattanipātamhi, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja416:12.2":{"pli":"vaggaṁ me bhaṇato suṇa; ","html":"<span class='verse-line'>{}</span>"},"ja416:12.3":{"pli":"Kukku ca puna gandhāro, ","html":"<span class='verse-line'>{}</span>"},"ja416:12.4":{"pli":"dveva vuttā mahesināti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja416:13.1":{"pli":"Sattakanipātaṁ niṭṭhitaṁ. ","html":"<p class='endsection'>{}</p></article>"}},"ja417":{"ja417:0.1":{"pli":"Jātaka ","html":"<article id='ja417'><header><ul><li class='division'>{}</li>"},"ja417:0.2":{"pli":"Aṭṭhakanipāta ","html":"<li>{}</li>"},"ja417:0.3":{"pli":"Kaccānivagga ","html":"<li>{}</li></ul>"},"ja417:0.4":{"pli":"1. Kaccānijātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja417:1.1":{"pli":"“Odātavatthā suci allakesā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja417:1.2":{"pli":"Kaccāni kiṁ kumbhimadhissayitvā; ","html":"<span class='verse-line'>{}</span>"},"ja417:1.3":{"pli":"Piṭṭhā tilā dhovasi taṇḍulāni, ","html":"<span class='verse-line'>{}</span>"},"ja417:1.4":{"pli":"Tilodano hehiti kissahetu”. ","html":"<span class='verse-line'>{}</span></p>"},"ja417:2.1":{"pli":"“Na kho ayaṁ brāhmaṇa bhojanatthā, ","html":"<p><span class='verse-line'>{}</span>"},"ja417:2.2":{"pli":"Tilodano hehiti sādhupakko; ","html":"<span class='verse-line'>{}</span>"},"ja417:2.3":{"pli":"Dhammo mato tassa pahuttamajja, ","html":"<span class='verse-line'>{}</span>"},"ja417:2.4":{"pli":"Ahaṁ karissāmi susānamajjhe”. ","html":"<span class='verse-line'>{}</span></p>"},"ja417:3.1":{"pli":"“Anuvicca kaccāni karohi kiccaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja417:3.2":{"pli":"Dhammo mato ko nu taveva saṁsi; ","html":"<span class='verse-line'>{}</span>"},"ja417:3.3":{"pli":"Sahassanetto atulānubhāvo, ","html":"<span class='verse-line'>{}</span>"},"ja417:3.4":{"pli":"Na miyyatī dhammavaro kadāci”. ","html":"<span class='verse-line'>{}</span></p>"},"ja417:4.1":{"pli":"“Daḷhappamāṇaṁ mama ettha brahme, ","html":"<p><span class='verse-line'>{}</span>"},"ja417:4.2":{"pli":"Dhammo mato natthi mamettha kaṅkhā; ","html":"<span class='verse-line'>{}</span>"},"ja417:4.3":{"pli":"Yeyeva dāni pāpā bhavanti, ","html":"<span class='verse-line'>{}</span>"},"ja417:4.4":{"pli":"Te teva dāni sukhitā bhavanti. ","html":"<span class='verse-line'>{}</span></p>"},"ja417:5.1":{"pli":"Suṇisā hi mayhaṁ vañjhā ahosi, ","html":"<p><span class='verse-line'>{}</span>"},"ja417:5.2":{"pli":"Sā maṁ vadhitvāna vijāyi puttaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja417:5.3":{"pli":"Sā dāni sabbassa kulassa issarā, ","html":"<span class='verse-line'>{}</span>"},"ja417:5.4":{"pli":"Ahaṁ panamhi apaviddhā ekikā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja417:6.1":{"pli":"“Jīvāmi vohaṁ na matohamasmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja417:6.2":{"pli":"Taveva atthāya idhāgatosmi; ","html":"<span class='verse-line'>{}</span>"},"ja417:6.3":{"pli":"Yā taṁ vadhitvāna vijāyi puttaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja417:6.4":{"pli":"Sahāva puttena karomi bhasmaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja417:7.1":{"pli":"“Evañca te ruccati devarāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja417:7.2":{"pli":"Mameva atthāya idhāgatosi; ","html":"<span class='verse-line'>{}</span>"},"ja417:7.3":{"pli":"Ahañca putto suṇisā ca nattā, ","html":"<span class='verse-line'>{}</span>"},"ja417:7.4":{"pli":"Sammodamānā gharamāvasema”. ","html":"<span class='verse-line'>{}</span></p>"},"ja417:8.1":{"pli":"“Evañca te ruccati kātiyāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja417:8.2":{"pli":"Hatāpi santā na jahāsi dhammaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja417:8.3":{"pli":"Tuvañca putto suṇisā ca nattā, ","html":"<span class='verse-line'>{}</span>"},"ja417:8.4":{"pli":"Sammodamānā gharamāvasetha. ","html":"<span class='verse-line'>{}</span></p>"},"ja417:9.1":{"pli":"Sā kātiyānī suṇisāya saddhiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja417:9.2":{"pli":"Sammodamānā gharamāvasittha; ","html":"<span class='verse-line'>{}</span>"},"ja417:9.3":{"pli":"Putto ca nattā ca upaṭṭhahiṁsu, ","html":"<span class='verse-line'>{}</span>"},"ja417:9.4":{"pli":"Devānamindena adhiggahītā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja417:10.1":{"pli":"Kaccānijātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}