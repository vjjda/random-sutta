{"vv34":{"vv34:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv34'><header><ul><li class='division'>{}</li>"},"vv34:0.2":{"pli":"Itthivimāna ","html":"<li>{}</li>"},"vv34:0.3":{"pli":"Pāricchattakavagga ","html":"<li>{}</li></ul>"},"vv34:0.4":{"pli":"6. Daddallavimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv34:1.1":{"pli":"“Daddallamānā vaṇṇena, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv34:1.2":{"pli":"yasasā ca yasassinī; ","html":"<span class='verse-line'>{}</span>"},"vv34:1.3":{"pli":"Sabbe deve tāvatiṁse, ","html":"<span class='verse-line'>{}</span>"},"vv34:1.4":{"pli":"vaṇṇena atirocasi. ","html":"<span class='verse-line'>{}</span></p>"},"vv34:2.1":{"pli":"Dassanaṁ nābhijānāmi, ","html":"<p><span class='verse-line'>{}</span>"},"vv34:2.2":{"pli":"idaṁ paṭhamadassanaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv34:2.3":{"pli":"Kasmā kāyā nu āgamma, ","html":"<span class='verse-line'>{}</span>"},"vv34:2.4":{"pli":"nāmena bhāsase maman”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv34:3.1":{"pli":"“Ahaṁ bhadde subhaddāsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv34:3.2":{"pli":"pubbe mānusake bhave; ","html":"<span class='verse-line'>{}</span>"},"vv34:3.3":{"pli":"Sahabhariyā ca te āsiṁ, ","html":"<span class='verse-line'>{}</span>"},"vv34:3.4":{"pli":"bhaginī ca kaniṭṭhikā. ","html":"<span class='verse-line'>{}</span></p>"},"vv34:4.1":{"pli":"Sā ahaṁ kāyassa bhedā, ","html":"<p><span class='verse-line'>{}</span>"},"vv34:4.2":{"pli":"vippamuttā tato cutā; ","html":"<span class='verse-line'>{}</span>"},"vv34:4.3":{"pli":"Nimmānaratīnaṁ devānaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv34:4.4":{"pli":"upapannā sahabyatan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv34:5.1":{"pli":"“Pahūtakatakalyāṇā, ","html":"<p><span class='verse-line'>{}</span>"},"vv34:5.2":{"pli":"te deve yanti pāṇino; ","html":"<span class='verse-line'>{}</span>"},"vv34:5.3":{"pli":"Yesaṁ tvaṁ kittayissasi, ","html":"<span class='verse-line'>{}</span>"},"vv34:5.4":{"pli":"subhadde jātimattano. ","html":"<span class='verse-line'>{}</span></p>"},"vv34:6.1":{"pli":"Atha tvaṁ kena vaṇṇena, ","html":"<p><span class='verse-line'>{}</span>"},"vv34:6.2":{"pli":"kena vā anusāsitā; ","html":"<span class='verse-line'>{}</span>"},"vv34:6.3":{"pli":"Kīdiseneva dānena, ","html":"<span class='verse-line'>{}</span>"},"vv34:6.4":{"pli":"subbatena yasassinī. ","html":"<span class='verse-line'>{}</span></p>"},"vv34:7.1":{"pli":"Yasaṁ etādisaṁ pattā, ","html":"<p><span class='verse-line'>{}</span>"},"vv34:7.2":{"pli":"visesaṁ vipulamajjhagā; ","html":"<span class='verse-line'>{}</span>"},"vv34:7.3":{"pli":"Devate pucchitācikkha, ","html":"<span class='verse-line'>{}</span>"},"vv34:7.4":{"pli":"kissa kammassidaṁ phalan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv34:8.1":{"pli":"“Aṭṭheva piṇḍapātāni, ","html":"<p><span class='verse-line'>{}</span>"},"vv34:8.2":{"pli":"yaṁ dānaṁ adadaṁ pure; ","html":"<span class='verse-line'>{}</span>"},"vv34:8.3":{"pli":"Dakkhiṇeyyassa saṅghassa, ","html":"<span class='verse-line'>{}</span>"},"vv34:8.4":{"pli":"pasannā sehi pāṇibhi. ","html":"<span class='verse-line'>{}</span></p>"},"vv34:9.1":{"pli":"Tena metādiso vaṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"vv34:9.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"vv34:9.3":{"pli":"vaṇṇo ca me sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv34:10.1":{"pli":"“Ahaṁ tayā bahutare bhikkhū, ","html":"<p><span class='verse-line'>{}</span>"},"vv34:10.2":{"pli":"Saññate brahmacārayo; ","html":"<span class='verse-line'>{}</span>"},"vv34:10.3":{"pli":"Tappesiṁ annapānena, ","html":"<span class='verse-line'>{}</span>"},"vv34:10.4":{"pli":"Pasannā sehi pāṇibhi. ","html":"<span class='verse-line'>{}</span></p>"},"vv34:11.1":{"pli":"Tayā bahutaraṁ datvā, ","html":"<p><span class='verse-line'>{}</span>"},"vv34:11.2":{"pli":"hīnakāyūpagā ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv34:11.3":{"pli":"Kathaṁ tvaṁ appataraṁ datvā, ","html":"<span class='verse-line'>{}</span>"},"vv34:11.4":{"pli":"visesaṁ vipulamajjhagā; ","html":"<span class='verse-line'>{}</span>"},"vv34:11.5":{"pli":"Devate pucchitācikkha, ","html":"<span class='verse-line'>{}</span>"},"vv34:11.6":{"pli":"kissa kammassidaṁ phalan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv34:12.1":{"pli":"“Manobhāvanīyo bhikkhu, ","html":"<p><span class='verse-line'>{}</span>"},"vv34:12.2":{"pli":"sandiṭṭho me pure ahu; ","html":"<span class='verse-line'>{}</span>"},"vv34:12.3":{"pli":"Tāhaṁ bhattena nimantesiṁ, ","html":"<span class='verse-line'>{}</span>"},"vv34:12.4":{"pli":"revataṁ attanaṭṭhamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv34:13.1":{"pli":"So me atthapurekkhāro, ","html":"<p><span class='verse-line'>{}</span>"},"vv34:13.2":{"pli":"anukampāya revato; ","html":"<span class='verse-line'>{}</span>"},"vv34:13.3":{"pli":"Saṅghe dehīti maṁvoca, ","html":"<span class='verse-line'>{}</span>"},"vv34:13.4":{"pli":"tassāhaṁ vacanaṁ kariṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv34:14.1":{"pli":"Sā dakkhiṇā saṅghagatā, ","html":"<p><span class='verse-line'>{}</span>"},"vv34:14.2":{"pli":"appameyye patiṭṭhitā; ","html":"<span class='verse-line'>{}</span>"},"vv34:14.3":{"pli":"Puggalesu tayā dinnaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv34:14.4":{"pli":"na taṁ tava mahapphalan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv34:15.1":{"pli":"“Idānevāhaṁ jānāmi, ","html":"<p><span class='verse-line'>{}</span>"},"vv34:15.2":{"pli":"saṅghe dinnaṁ mahapphalaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv34:15.3":{"pli":"Sāhaṁ gantvā manussattaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv34:15.4":{"pli":"vadaññū vītamaccharā; ","html":"<span class='verse-line'>{}</span>"},"vv34:15.5":{"pli":"Saṅghe dānāni dassāmi, ","html":"<span class='verse-line'>{}</span>"},"vv34:15.6":{"pli":"appamattā punappunan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv34:16.1":{"pli":"“Kā esā devatā bhadde, ","html":"<p><span class='verse-line'>{}</span>"},"vv34:16.2":{"pli":"tayā mantayate saha; ","html":"<span class='verse-line'>{}</span>"},"vv34:16.3":{"pli":"Sabbe deve tāvatiṁse, ","html":"<span class='verse-line'>{}</span>"},"vv34:16.4":{"pli":"vaṇṇena atirocatī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv34:17.1":{"pli":"“Manussabhūtā devinda, ","html":"<p><span class='verse-line'>{}</span>"},"vv34:17.2":{"pli":"pubbe mānusake bhave; ","html":"<span class='verse-line'>{}</span>"},"vv34:17.3":{"pli":"Sahabhariyā ca me āsi, ","html":"<span class='verse-line'>{}</span>"},"vv34:17.4":{"pli":"bhaginī ca kaniṭṭhikā; ","html":"<span class='verse-line'>{}</span>"},"vv34:17.5":{"pli":"Saṅghe dānāni datvāna, ","html":"<span class='verse-line'>{}</span>"},"vv34:17.6":{"pli":"katapuññā virocatī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv34:18.1":{"pli":"“Dhammena pubbe bhaginī, ","html":"<p><span class='verse-line'>{}</span>"},"vv34:18.2":{"pli":"tayā bhadde virocati; ","html":"<span class='verse-line'>{}</span>"},"vv34:18.3":{"pli":"Yaṁ saṅghamhi appameyye, ","html":"<span class='verse-line'>{}</span>"},"vv34:18.4":{"pli":"patiṭṭhāpesi dakkhiṇaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"vv34:19.1":{"pli":"“Pucchito hi mayā buddho, ","html":"<p><span class='verse-line'>{}</span>"},"vv34:19.2":{"pli":"gijjhakūṭamhi pabbate; ","html":"<span class='verse-line'>{}</span>"},"vv34:19.3":{"pli":"Vipākaṁ saṁvibhāgassa, ","html":"<span class='verse-line'>{}</span>"},"vv34:19.4":{"pli":"yattha dinnaṁ mahapphalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv34:20.1":{"pli":"Yajamānānaṁ manussānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv34:20.2":{"pli":"puññapekkhāna pāṇinaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv34:20.3":{"pli":"Karotaṁ opadhikaṁ puññaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv34:20.4":{"pli":"yattha dinnaṁ mahapphalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv34:21.1":{"pli":"Taṁ me buddho viyākāsi, ","html":"<p><span class='verse-line'>{}</span>"},"vv34:21.2":{"pli":"jānaṁ kammaphalaṁ sakaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv34:21.3":{"pli":"Vipākaṁ saṁvibhāgassa, ","html":"<span class='verse-line'>{}</span>"},"vv34:21.4":{"pli":"yattha dinnaṁ mahapphalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv34:22.1":{"pli":"Cattāro ca paṭipannā, ","html":"<p><span class='verse-line'>{}</span>"},"vv34:22.2":{"pli":"cattāro ca phale ṭhitā; ","html":"<span class='verse-line'>{}</span>"},"vv34:22.3":{"pli":"Esa saṅgho ujubhūto, ","html":"<span class='verse-line'>{}</span>"},"vv34:22.4":{"pli":"paññāsīlasamāhito. ","html":"<span class='verse-line'>{}</span></p>"},"vv34:23.1":{"pli":"Yajamānānaṁ manussānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv34:23.2":{"pli":"puññapekkhāna pāṇinaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv34:23.3":{"pli":"Karotaṁ opadhikaṁ puññaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv34:23.4":{"pli":"saṅghe dinnaṁ mahapphalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv34:24.1":{"pli":"Eso hi saṅgho vipulo mahaggato, ","html":"<p><span class='verse-line'>{}</span>"},"vv34:24.2":{"pli":"Esappameyyo udadhīva sāgaro; ","html":"<span class='verse-line'>{}</span>"},"vv34:24.3":{"pli":"Ete hi seṭṭhā naravīrasāvakā, ","html":"<span class='verse-line'>{}</span>"},"vv34:24.4":{"pli":"Pabhaṅkarā dhammamudīrayanti. ","html":"<span class='verse-line'>{}</span></p>"},"vv34:25.1":{"pli":"Tesaṁ sudinnaṁ suhutaṁ suyiṭṭhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv34:25.2":{"pli":"Ye saṅghamuddissa dadanti dānaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv34:25.3":{"pli":"Sā dakkhiṇā saṅghagatā patiṭṭhitā, ","html":"<span class='verse-line'>{}</span>"},"vv34:25.4":{"pli":"Mahapphalā lokavidūna vaṇṇitā. ","html":"<span class='verse-line'>{}</span></p>"},"vv34:26.1":{"pli":"Etādisaṁ yaññamanussarantā, ","html":"<p><span class='verse-line'>{}</span>"},"vv34:26.2":{"pli":"Ye vedajātā vicaranti loke; ","html":"<span class='verse-line'>{}</span>"},"vv34:26.3":{"pli":"Vineyya maccheramalaṁ samūlaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv34:26.4":{"pli":"Aninditā saggamupenti ṭhānan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv34:27.1":{"pli":"Daddallavimānaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"vv35":{"vv35:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv35'><header><ul><li class='division'>{}</li>"},"vv35:0.2":{"pli":"Itthivimāna ","html":"<li>{}</li>"},"vv35:0.3":{"pli":"Pāricchattakavagga ","html":"<li>{}</li></ul>"},"vv35:0.4":{"pli":"7. Pesavatīvimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv35:1.1":{"pli":"“Phalikarajatahemajālachannaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv35:1.2":{"pli":"Vividhacitratalamaddasaṁ surammaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv35:1.3":{"pli":"Byamhaṁ sunimmitaṁ toraṇūpapannaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv35:1.4":{"pli":"Rucakupakiṇṇamidaṁ subhaṁ vimānaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv35:2.1":{"pli":"Bhāti ca dasa disā nabheva suriyo, ","html":"<p><span class='verse-line'>{}</span>"},"vv35:2.2":{"pli":"Sarade tamonudo sahassaraṁsī; ","html":"<span class='verse-line'>{}</span>"},"vv35:2.3":{"pli":"Tathā tapati midaṁ tava vimānaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv35:2.4":{"pli":"Jalamiva dhūmasikho nise nabhagge. ","html":"<span class='verse-line'>{}</span></p>"},"vv35:3.1":{"pli":"Musatīva nayanaṁ sateratāva, ","html":"<p><span class='verse-line'>{}</span>"},"vv35:3.2":{"pli":"Ākāse ṭhapitamidaṁ manuññaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv35:3.3":{"pli":"Vīṇāmurajasammatāḷaghuṭṭhaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv35:3.4":{"pli":"Iddhaṁ indapuraṁ yathā tavedaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv35:4.1":{"pli":"Padumakumuduppalakuvalayaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv35:4.2":{"pli":"Yodhika bandhukanojakā ca santi; ","html":"<span class='verse-line'>{}</span>"},"vv35:4.3":{"pli":"Sālakusumitapupphitā asokā, ","html":"<span class='verse-line'>{}</span>"},"vv35:4.4":{"pli":"Vividhadumaggasugandhasevitamidaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv35:5.1":{"pli":"Saḷalalabujabhujaka saṁyuttā, ","html":"<p><span class='verse-line'>{}</span>"},"vv35:5.2":{"pli":"Kusakasuphullitalatāvalambinīhi; ","html":"<span class='verse-line'>{}</span>"},"vv35:5.3":{"pli":"Maṇijālasadisā yasassinī, ","html":"<span class='verse-line'>{}</span>"},"vv35:5.4":{"pli":"Rammā pokkharaṇī upaṭṭhitā te. ","html":"<span class='verse-line'>{}</span></p>"},"vv35:6.1":{"pli":"Udakaruhā ca yetthi pupphajātā, ","html":"<p><span class='verse-line'>{}</span>"},"vv35:6.2":{"pli":"Thalajā ye ca santi rukkhajātā; ","html":"<span class='verse-line'>{}</span>"},"vv35:6.3":{"pli":"Mānusakāmānussakā ca dibbā, ","html":"<span class='verse-line'>{}</span>"},"vv35:6.4":{"pli":"Sabbe tuyhaṁ nivesanamhi jātā. ","html":"<span class='verse-line'>{}</span></p>"},"vv35:7.1":{"pli":"Kissa saṁyamadamassayaṁ vipāko, ","html":"<p><span class='verse-line'>{}</span>"},"vv35:7.2":{"pli":"Kenāsi kammaphalenidhūpapannā; ","html":"<span class='verse-line'>{}</span>"},"vv35:7.3":{"pli":"Yathā ca te adhigatamidaṁ vimānaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv35:7.4":{"pli":"Tadanupadaṁ avacāsiḷārapamhe”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv35:8.1":{"pli":"“Yathā ca me adhigatamidaṁ vimānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv35:8.2":{"pli":"Koñcamayūracakorasaṅghacaritaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv35:8.3":{"pli":"Dibyapilavahaṁsarājaciṇṇaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv35:8.4":{"pli":"Dijakāraṇḍavakokilābhinaditaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv35:9.1":{"pli":"Nānāsantānakapuppharukkhavividhā, ","html":"<p><span class='verse-line'>{}</span>"},"vv35:9.2":{"pli":"Pāṭalijambuasokarukkhavantaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv35:9.3":{"pli":"Yathā ca me adhigatamidaṁ vimānaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv35:9.4":{"pli":"Taṁ te pavedayāmi suṇohi bhante. ","html":"<span class='verse-line'>{}</span></p>"},"vv35:10.1":{"pli":"Magadhavarapuratthimena, ","html":"<p><span class='verse-line'>{}</span>"},"vv35:10.2":{"pli":"Nāḷakagāmo nāma atthi bhante; ","html":"<span class='verse-line'>{}</span>"},"vv35:10.3":{"pli":"Tattha ahosiṁ pure suṇisā, ","html":"<span class='verse-line'>{}</span>"},"vv35:10.4":{"pli":"Pesavatīti tattha jāniṁsu mamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv35:11.1":{"pli":"Sāhamapacitatthadhammakusalaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv35:11.2":{"pli":"Devamanussapūjitaṁ mahantaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv35:11.3":{"pli":"Upatissaṁ nibbutamappameyyaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv35:11.4":{"pli":"Muditamanā kusumehi abbhukiriṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv35:12.1":{"pli":"Paramagatigatañca pūjayitvā, ","html":"<p><span class='verse-line'>{}</span>"},"vv35:12.2":{"pli":"Antimadehadharaṁ isiṁ uḷāraṁ; ","html":"<span class='verse-line'>{}</span>"},"vv35:12.3":{"pli":"Pahāya mānusakaṁ samussayaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv35:12.4":{"pli":"Tidasagatā idha māvasāmi ṭhānan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv35:13.1":{"pli":"Pesavatīvimānaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"vv36":{"vv36:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv36'><header><ul><li class='division'>{}</li>"},"vv36:0.2":{"pli":"Itthivimāna ","html":"<li>{}</li>"},"vv36:0.3":{"pli":"Pāricchattakavagga ","html":"<li>{}</li></ul>"},"vv36:0.4":{"pli":"8. Mallikāvimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv36:1.1":{"pli":"“Pītavatthe pītadhaje, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv36:1.2":{"pli":"pītālaṅkārabhūsite; ","html":"<span class='verse-line'>{}</span>"},"vv36:1.3":{"pli":"Pītantarāhi vaggūhi, ","html":"<span class='verse-line'>{}</span>"},"vv36:1.4":{"pli":"apiḷandhāva sobhasi. ","html":"<span class='verse-line'>{}</span></p>"},"vv36:2.1":{"pli":"Kā kambukāyūradhare, ","html":"<p><span class='verse-line'>{}</span>"},"vv36:2.2":{"pli":"kañcanāveḷabhūsite; ","html":"<span class='verse-line'>{}</span>"},"vv36:2.3":{"pli":"Hemajālakasañchanne, ","html":"<span class='verse-line'>{}</span>"},"vv36:2.4":{"pli":"nānāratanamālinī. ","html":"<span class='verse-line'>{}</span></p>"},"vv36:3.1":{"pli":"Sovaṇṇamayā lohitaṅgamayā ca, ","html":"<p><span class='verse-line'>{}</span>"},"vv36:3.2":{"pli":"Muttāmayā veḷuriyamayā ca; ","html":"<span class='verse-line'>{}</span>"},"vv36:3.3":{"pli":"Masāragallā sahalohitaṅgā, ","html":"<span class='verse-line'>{}</span>"},"vv36:3.4":{"pli":"Pārevatakkhīhi maṇīhi cittatā. ","html":"<span class='verse-line'>{}</span></p>"},"vv36:4.1":{"pli":"Koci koci ettha mayūrasussaro, ","html":"<p><span class='verse-line'>{}</span>"},"vv36:4.2":{"pli":"Haṁsassa rañño karavīkasussaro; ","html":"<span class='verse-line'>{}</span>"},"vv36:4.3":{"pli":"Tesaṁ saro suyyati vaggurūpo, ","html":"<span class='verse-line'>{}</span>"},"vv36:4.4":{"pli":"Pañcaṅgikaṁ tūriyamivappavāditaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv36:5.1":{"pli":"Ratho ca te subho vaggu, ","html":"<p><span class='verse-line'>{}</span>"},"vv36:5.2":{"pli":"nānāratanacittito; ","html":"<span class='verse-line'>{}</span>"},"vv36:5.3":{"pli":"Nānāvaṇṇāhi dhātūhi, ","html":"<span class='verse-line'>{}</span>"},"vv36:5.4":{"pli":"suvibhattova sobhati. ","html":"<span class='verse-line'>{}</span></p>"},"vv36:6.1":{"pli":"Tasmiṁ rathe kañcanabimbavaṇṇe, ","html":"<p><span class='verse-line'>{}</span>"},"vv36:6.2":{"pli":"Yā tvaṁ ṭhitā bhāsasimaṁ padesaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv36:6.3":{"pli":"Devate pucchitācikkha, ","html":"<span class='verse-line'>{}</span>"},"vv36:6.4":{"pli":"Kissa kammassidaṁ phalan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv36:7.1":{"pli":"“Sovaṇṇajālaṁ maṇisoṇṇacittitaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv36:7.2":{"pli":"Muttācitaṁ hemajālena channaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv36:7.3":{"pli":"Parinibbute gotame appameyye, ","html":"<span class='verse-line'>{}</span>"},"vv36:7.4":{"pli":"Pasannacittā ahamābhiropayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv36:8.1":{"pli":"Tāhaṁ kammaṁ karitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"vv36:8.2":{"pli":"kusalaṁ buddhavaṇṇitaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv36:8.3":{"pli":"Apetasokā sukhitā, ","html":"<span class='verse-line'>{}</span>"},"vv36:8.4":{"pli":"sampamodāmanāmayā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv36:9.1":{"pli":"Mallikāvimānaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"vv37":{"vv37:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv37'><header><ul><li class='division'>{}</li>"},"vv37:0.2":{"pli":"Itthivimāna ","html":"<li>{}</li>"},"vv37:0.3":{"pli":"Pāricchattakavagga ","html":"<li>{}</li></ul>"},"vv37:0.4":{"pli":"9. Visālakkhivimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv37:1.1":{"pli":"“Kā nāma tvaṁ visālakkhi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv37:1.2":{"pli":"ramme cittalatāvane; ","html":"<span class='verse-line'>{}</span>"},"vv37:1.3":{"pli":"Samantā anupariyāsi, ","html":"<span class='verse-line'>{}</span>"},"vv37:1.4":{"pli":"nārīgaṇapurakkhatā. ","html":"<span class='verse-line'>{}</span></p>"},"vv37:2.1":{"pli":"Yadā devā tāvatiṁsā, ","html":"<p><span class='verse-line'>{}</span>"},"vv37:2.2":{"pli":"pavisanti imaṁ vanaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv37:2.3":{"pli":"Sayoggā sarathā sabbe, ","html":"<span class='verse-line'>{}</span>"},"vv37:2.4":{"pli":"citrā honti idhāgatā. ","html":"<span class='verse-line'>{}</span></p>"},"vv37:3.1":{"pli":"Tuyhañca idha pattāya, ","html":"<p><span class='verse-line'>{}</span>"},"vv37:3.2":{"pli":"uyyāne vicarantiyā; ","html":"<span class='verse-line'>{}</span>"},"vv37:3.3":{"pli":"Kāye na dissatī cittaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv37:3.4":{"pli":"kena rūpaṁ tavedisaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv37:3.5":{"pli":"Devate pucchitācikkha, ","html":"<span class='verse-line'>{}</span>"},"vv37:3.6":{"pli":"kissa kammassidaṁ phalan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv37:4.1":{"pli":"“Yena kammena devinda, ","html":"<p><span class='verse-line'>{}</span>"},"vv37:4.2":{"pli":"rūpaṁ mayhaṁ gatī ca me; ","html":"<span class='verse-line'>{}</span>"},"vv37:4.3":{"pli":"Iddhi ca ānubhāvo ca, ","html":"<span class='verse-line'>{}</span>"},"vv37:4.4":{"pli":"taṁ suṇohi purindada. ","html":"<span class='verse-line'>{}</span></p>"},"vv37:5.1":{"pli":"Ahaṁ rājagahe ramme, ","html":"<p><span class='verse-line'>{}</span>"},"vv37:5.2":{"pli":"sunandā nāmupāsikā; ","html":"<span class='verse-line'>{}</span>"},"vv37:5.3":{"pli":"Saddhā sīlena sampannā, ","html":"<span class='verse-line'>{}</span>"},"vv37:5.4":{"pli":"saṁvibhāgaratā sadā. ","html":"<span class='verse-line'>{}</span></p>"},"vv37:6.1":{"pli":"Acchādanañca bhattañca, ","html":"<p><span class='verse-line'>{}</span>"},"vv37:6.2":{"pli":"senāsanaṁ padīpiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv37:6.3":{"pli":"Adāsiṁ ujubhūtesu, ","html":"<span class='verse-line'>{}</span>"},"vv37:6.4":{"pli":"vippasannena cetasā. ","html":"<span class='verse-line'>{}</span></p>"},"vv37:7.1":{"pli":"Cātuddasiṁ pañcadasiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv37:7.2":{"pli":"yā ca pakkhassa aṭṭhamī; ","html":"<span class='verse-line'>{}</span>"},"vv37:7.3":{"pli":"Pāṭihāriyapakkhañca, ","html":"<span class='verse-line'>{}</span>"},"vv37:7.4":{"pli":"aṭṭhaṅgasusamāgataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv37:8.1":{"pli":"Uposathaṁ upavasissaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv37:8.2":{"pli":"sadā sīlesu saṁvutā; ","html":"<span class='verse-line'>{}</span>"},"vv37:8.3":{"pli":"Saññamā saṁvibhāgā ca, ","html":"<span class='verse-line'>{}</span>"},"vv37:8.4":{"pli":"vimānaṁ āvasāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv37:9.1":{"pli":"Pāṇātipātā viratā, ","html":"<p><span class='verse-line'>{}</span>"},"vv37:9.2":{"pli":"musāvādā ca saññatā; ","html":"<span class='verse-line'>{}</span>"},"vv37:9.3":{"pli":"Theyyā ca aticārā ca, ","html":"<span class='verse-line'>{}</span>"},"vv37:9.4":{"pli":"majjapānā ca ārakā. ","html":"<span class='verse-line'>{}</span></p>"},"vv37:10.1":{"pli":"Pañcasikkhāpade ratā, ","html":"<p><span class='verse-line'>{}</span>"},"vv37:10.2":{"pli":"ariyasaccāna kovidā; ","html":"<span class='verse-line'>{}</span>"},"vv37:10.3":{"pli":"Upāsikā cakkhumato, ","html":"<span class='verse-line'>{}</span>"},"vv37:10.4":{"pli":"gotamassa yasassino. ","html":"<span class='verse-line'>{}</span></p>"},"vv37:11.1":{"pli":"Tassā me ñātikulā dāsī, ","html":"<p><span class='verse-line'>{}</span>"},"vv37:11.2":{"pli":"sadā mālābhihārati; ","html":"<span class='verse-line'>{}</span>"},"vv37:11.3":{"pli":"Tāhaṁ bhagavato thūpe, ","html":"<span class='verse-line'>{}</span>"},"vv37:11.4":{"pli":"sabbamevābhiropayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv37:12.1":{"pli":"Uposathe cahaṁ gantvā, ","html":"<p><span class='verse-line'>{}</span>"},"vv37:12.2":{"pli":"mālāgandhavilepanaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv37:12.3":{"pli":"Thūpasmiṁ abhiropesiṁ, ","html":"<span class='verse-line'>{}</span>"},"vv37:12.4":{"pli":"pasannā sehi pāṇibhi. ","html":"<span class='verse-line'>{}</span></p>"},"vv37:13.1":{"pli":"Tena kammena devinda, ","html":"<p><span class='verse-line'>{}</span>"},"vv37:13.2":{"pli":"rūpaṁ mayhaṁ gatī ca me; ","html":"<span class='verse-line'>{}</span>"},"vv37:13.3":{"pli":"Iddhī ca ānubhāvo ca, ","html":"<span class='verse-line'>{}</span>"},"vv37:13.4":{"pli":"yaṁ mālaṁ abhiropayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv37:14.1":{"pli":"Yañca sīlavatī āsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv37:14.2":{"pli":"na taṁ tāva vipaccati; ","html":"<span class='verse-line'>{}</span>"},"vv37:14.3":{"pli":"Āsā ca pana me devinda, ","html":"<span class='verse-line'>{}</span>"},"vv37:14.4":{"pli":"sakadāgāminī siyan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv37:15.1":{"pli":"Visālakkhivimānaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"vv38":{"vv38:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv38'><header><ul><li class='division'>{}</li>"},"vv38:0.2":{"pli":"Itthivimāna ","html":"<li>{}</li>"},"vv38:0.3":{"pli":"Pāricchattakavagga ","html":"<li>{}</li></ul>"},"vv38:0.4":{"pli":"10. Pāricchattakavimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv38:1.1":{"pli":"“Pāricchattake koviḷāre, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv38:1.2":{"pli":"ramaṇīye manorame; ","html":"<span class='verse-line'>{}</span>"},"vv38:1.3":{"pli":"Dibbamālaṁ ganthamānā, ","html":"<span class='verse-line'>{}</span>"},"vv38:1.4":{"pli":"gāyantī sampamodasi. ","html":"<span class='verse-line'>{}</span></p>"},"vv38:2.1":{"pli":"Tassā te naccamānāya, ","html":"<p><span class='verse-line'>{}</span>"},"vv38:2.2":{"pli":"aṅgamaṅgehi sabbaso; ","html":"<span class='verse-line'>{}</span>"},"vv38:2.3":{"pli":"Dibbā saddā niccharanti, ","html":"<span class='verse-line'>{}</span>"},"vv38:2.4":{"pli":"savanīyā manoramā. ","html":"<span class='verse-line'>{}</span></p>"},"vv38:3.1":{"pli":"Tassā te naccamānāya, ","html":"<p><span class='verse-line'>{}</span>"},"vv38:3.2":{"pli":"aṅgamaṅgehi sabbaso; ","html":"<span class='verse-line'>{}</span>"},"vv38:3.3":{"pli":"Dibbā gandhā pavāyanti, ","html":"<span class='verse-line'>{}</span>"},"vv38:3.4":{"pli":"sucigandhā manoramā. ","html":"<span class='verse-line'>{}</span></p>"},"vv38:4.1":{"pli":"Vivattamānā kāyena, ","html":"<p><span class='verse-line'>{}</span>"},"vv38:4.2":{"pli":"yā veṇīsu piḷandhanā; ","html":"<span class='verse-line'>{}</span>"},"vv38:4.3":{"pli":"Tesaṁ suyyati nigghoso, ","html":"<span class='verse-line'>{}</span>"},"vv38:4.4":{"pli":"tūriye pañcaṅgike yathā. ","html":"<span class='verse-line'>{}</span></p>"},"vv38:5.1":{"pli":"Vaṭaṁsakā vātadhutā, ","html":"<p><span class='verse-line'>{}</span>"},"vv38:5.2":{"pli":"vātena sampakampitā; ","html":"<span class='verse-line'>{}</span>"},"vv38:5.3":{"pli":"Tesaṁ suyyati nigghoso, ","html":"<span class='verse-line'>{}</span>"},"vv38:5.4":{"pli":"tūriye pañcaṅgike yathā. ","html":"<span class='verse-line'>{}</span></p>"},"vv38:6.1":{"pli":"Yāpi te sirasmiṁ mālā, ","html":"<p><span class='verse-line'>{}</span>"},"vv38:6.2":{"pli":"sucigandhā manoramā; ","html":"<span class='verse-line'>{}</span>"},"vv38:6.3":{"pli":"Vāti gandho disā sabbā, ","html":"<span class='verse-line'>{}</span>"},"vv38:6.4":{"pli":"rukkho mañjūsako yathā. ","html":"<span class='verse-line'>{}</span></p>"},"vv38:7.1":{"pli":"Ghāyase taṁ sucigandhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv38:7.2":{"pli":"rūpaṁ passasi amānusaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv38:7.3":{"pli":"Devate pucchitācikkha, ","html":"<span class='verse-line'>{}</span>"},"vv38:7.4":{"pli":"kissa kammassidaṁ phalan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv38:8.1":{"pli":"“Pabhassaraṁ accimantaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv38:8.2":{"pli":"vaṇṇagandhena saṁyutaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv38:8.3":{"pli":"Asokapupphamālāhaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv38:8.4":{"pli":"buddhassa upanāmayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv38:9.1":{"pli":"Tāhaṁ kammaṁ karitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"vv38:9.2":{"pli":"kusalaṁ buddhavaṇṇitaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv38:9.3":{"pli":"Apetasokā sukhitā, ","html":"<span class='verse-line'>{}</span>"},"vv38:9.4":{"pli":"sampamodāmanāmayā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv38:10.1":{"pli":"Pāricchattakavimānaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"vv38:11.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"vv38:12.1":{"pli":"Uḷāro ucchu pallaṅko, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"vv38:12.2":{"pli":"latā ca guttilena ca; ","html":"<span class='verse-line'>{}</span>"},"vv38:12.3":{"pli":"Daddallapesamallikā, ","html":"<span class='verse-line'>{}</span>"},"vv38:12.4":{"pli":"visālakkhi pāricchattako; ","html":"<span class='verse-line'>{}</span>"},"vv38:12.5":{"pli":"Vaggo tena pavuccatīti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv38:13.1":{"pli":"Pāricchattakavaggo tatiyo. ","html":"<p class='endsutta'>{}</p></article>"}},"vv39":{"vv39:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv39'><header><ul><li class='division'>{}</li>"},"vv39:0.2":{"pli":"Itthivimāna ","html":"<li>{}</li>"},"vv39:0.3":{"pli":"Mañjiṭṭhakavagga ","html":"<li>{}</li></ul>"},"vv39:0.4":{"pli":"1. Mañjiṭṭhakavimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv39:1.1":{"pli":"“Mañjiṭṭhake vimānasmiṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv39:1.2":{"pli":"soṇṇavālukasanthate; ","html":"<span class='verse-line'>{}</span>"},"vv39:1.3":{"pli":"Pañcaṅgikena tūriyena, ","html":"<span class='verse-line'>{}</span>"},"vv39:1.4":{"pli":"ramasi suppavādite. ","html":"<span class='verse-line'>{}</span></p>"},"vv39:2.1":{"pli":"Tamhā vimānā oruyha, ","html":"<p><span class='verse-line'>{}</span>"},"vv39:2.2":{"pli":"nimmitā ratanāmayā; ","html":"<span class='verse-line'>{}</span>"},"vv39:2.3":{"pli":"Ogāhasi sālavanaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv39:2.4":{"pli":"pupphitaṁ sabbakālikaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv39:3.1":{"pli":"Yassa yasseva sālassa, ","html":"<p><span class='verse-line'>{}</span>"},"vv39:3.2":{"pli":"mūle tiṭṭhasi devate; ","html":"<span class='verse-line'>{}</span>"},"vv39:3.3":{"pli":"So so muñcati pupphāni, ","html":"<span class='verse-line'>{}</span>"},"vv39:3.4":{"pli":"onamitvā dumuttamo. ","html":"<span class='verse-line'>{}</span></p>"},"vv39:4.1":{"pli":"Vāteritaṁ sālavanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv39:4.2":{"pli":"ādhutaṁ dijasevitaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv39:4.3":{"pli":"Vāti gandho disā sabbā, ","html":"<span class='verse-line'>{}</span>"},"vv39:4.4":{"pli":"rukkho mañjūsako yathā. ","html":"<span class='verse-line'>{}</span></p>"},"vv39:5.1":{"pli":"Ghāyase taṁ sucigandhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv39:5.2":{"pli":"rūpaṁ passasi amānusaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv39:5.3":{"pli":"Devate pucchitācikkha, ","html":"<span class='verse-line'>{}</span>"},"vv39:5.4":{"pli":"kissa kammassidaṁ phalan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv39:6.1":{"pli":"“Ahaṁ manussesu manussabhūtā, ","html":"<p><span class='verse-line'>{}</span>"},"vv39:6.2":{"pli":"Dāsī ayirakule ahuṁ; ","html":"<span class='verse-line'>{}</span>"},"vv39:6.3":{"pli":"Buddhaṁ nisinnaṁ disvāna, ","html":"<span class='verse-line'>{}</span>"},"vv39:6.4":{"pli":"Sālapupphehi okiriṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv39:7.1":{"pli":"Vaṭaṁsakañca sukataṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv39:7.2":{"pli":"sālapupphamayaṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv39:7.3":{"pli":"Buddhassa upanāmesiṁ, ","html":"<span class='verse-line'>{}</span>"},"vv39:7.4":{"pli":"pasannā sehi pāṇibhi. ","html":"<span class='verse-line'>{}</span></p>"},"vv39:8.1":{"pli":"Tāhaṁ kammaṁ karitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"vv39:8.2":{"pli":"kusalaṁ buddhavaṇṇitaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv39:8.3":{"pli":"Apetasokā sukhitā, ","html":"<span class='verse-line'>{}</span>"},"vv39:8.4":{"pli":"sampamodāmanāmayā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv39:9.1":{"pli":"Mañjiṭṭhakavimānaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"vv4":{"vv4:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv4'><header><ul><li class='division'>{}</li>"},"vv4:0.2":{"pli":"Itthivimāna ","html":"<li>{}</li>"},"vv4:0.3":{"pli":"Pīṭhavagga ","html":"<li>{}</li></ul>"},"vv4:0.4":{"pli":"4. Catutthapīṭhavimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv4:1.1":{"pli":"“Pīṭhaṁ te veḷuriyamayaṁ uḷāraṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv4:1.2":{"pli":"Manojavaṁ gacchati yenakāmaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv4:1.3":{"pli":"Alaṅkate malyadhare suvatthe, ","html":"<span class='verse-line'>{}</span>"},"vv4:1.4":{"pli":"Obhāsasi vijjurivabbhakūṭaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv4:2.1":{"pli":"Kena tetādiso vaṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"vv4:2.2":{"pli":"kena te idha mijjhati; ","html":"<span class='verse-line'>{}</span>"},"vv4:2.3":{"pli":"Uppajjanti ca te bhogā, ","html":"<span class='verse-line'>{}</span>"},"vv4:2.4":{"pli":"ye keci manaso piyā. ","html":"<span class='verse-line'>{}</span></p>"},"vv4:3.1":{"pli":"Pucchāmi taṁ devi mahānubhāve, ","html":"<p><span class='verse-line'>{}</span>"},"vv4:3.2":{"pli":"Manussabhūtā kimakāsi puññaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv4:3.3":{"pli":"Kenāsi evaṁ jalitānubhāvā, ","html":"<span class='verse-line'>{}</span>"},"vv4:3.4":{"pli":"Vaṇṇo ca te sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv4:4.1":{"pli":"Sā devatā attamanā, ","html":"<p><span class='verse-line'>{}</span>"},"vv4:4.2":{"pli":"moggallānena pucchitā; ","html":"<span class='verse-line'>{}</span>"},"vv4:4.3":{"pli":"Pañhaṁ puṭṭhā viyākāsi, ","html":"<span class='verse-line'>{}</span>"},"vv4:4.4":{"pli":"yassa kammassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv4:5.1":{"pli":"“Appassa kammassa phalaṁ mamedaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv4:5.2":{"pli":"Yenamhi evaṁ jalitānubhāvā; ","html":"<span class='verse-line'>{}</span>"},"vv4:5.3":{"pli":"Ahaṁ manussesu manussabhūtā, ","html":"<span class='verse-line'>{}</span>"},"vv4:5.4":{"pli":"Purimāya jātiyā manussaloke. ","html":"<span class='verse-line'>{}</span></p>"},"vv4:6.1":{"pli":"Addasaṁ virajaṁ bhikkhuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv4:6.2":{"pli":"vippasannamanāvilaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv4:6.3":{"pli":"Tassa adāsahaṁ pīṭhaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv4:6.4":{"pli":"pasannā sehi pāṇibhi. ","html":"<span class='verse-line'>{}</span></p>"},"vv4:7.1":{"pli":"Tena metādiso vaṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"vv4:7.2":{"pli":"tena me idha mijjhati; ","html":"<span class='verse-line'>{}</span>"},"vv4:7.3":{"pli":"Uppajjanti ca me bhogā, ","html":"<span class='verse-line'>{}</span>"},"vv4:7.4":{"pli":"ye keci manaso piyā. ","html":"<span class='verse-line'>{}</span></p>"},"vv4:8.1":{"pli":"Akkhāmi te bhikkhu mahānubhāva, ","html":"<p><span class='verse-line'>{}</span>"},"vv4:8.2":{"pli":"Manussabhūtā yamakāsi puññaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv4:8.3":{"pli":"Tenamhi evaṁ jalitānubhāvā, ","html":"<span class='verse-line'>{}</span>"},"vv4:8.4":{"pli":"Vaṇṇo ca me sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv4:9.1":{"pli":"Catutthapīṭhavimānaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"vv40":{"vv40:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv40'><header><ul><li class='division'>{}</li>"},"vv40:0.2":{"pli":"Itthivimāna ","html":"<li>{}</li>"},"vv40:0.3":{"pli":"Mañjiṭṭhakavagga ","html":"<li>{}</li></ul>"},"vv40:0.4":{"pli":"2. Pabhassaravimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv40:1.1":{"pli":"“Pabhassaravaravaṇṇanibhe, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv40:1.2":{"pli":"Surattavatthavasane; ","html":"<span class='verse-line'>{}</span>"},"vv40:1.3":{"pli":"Mahiddhike candanaruciragatte, ","html":"<span class='verse-line'>{}</span>"},"vv40:1.4":{"pli":"Kā tvaṁ subhe devate vandase mamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv40:2.1":{"pli":"Pallaṅko ca te mahaggho, ","html":"<p><span class='verse-line'>{}</span>"},"vv40:2.2":{"pli":"Nānāratanacittito ruciro; ","html":"<span class='verse-line'>{}</span>"},"vv40:2.3":{"pli":"Yattha tvaṁ nisinnā virocasi, ","html":"<span class='verse-line'>{}</span>"},"vv40:2.4":{"pli":"Devarājāriva nandane vane. ","html":"<span class='verse-line'>{}</span></p>"},"vv40:3.1":{"pli":"Kiṁ tvaṁ pure sucaritamācarī bhadde, ","html":"<p><span class='verse-line'>{}</span>"},"vv40:3.2":{"pli":"Kissa kammassa vipākaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv40:3.3":{"pli":"Anubhosi devalokasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"vv40:3.4":{"pli":"Devate pucchitācikkha; ","html":"<span class='verse-line'>{}</span>"},"vv40:3.5":{"pli":"Kissa kammassidaṁ phalan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv40:4.1":{"pli":"“Piṇḍāya te carantassa, ","html":"<p><span class='verse-line'>{}</span>"},"vv40:4.2":{"pli":"Mālaṁ phāṇitañca adadaṁ bhante; ","html":"<span class='verse-line'>{}</span>"},"vv40:4.3":{"pli":"Tassa kammassidaṁ vipākaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv40:4.4":{"pli":"Anubhomi devalokasmiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv40:5.1":{"pli":"Hoti ca me anutāpo, ","html":"<p><span class='verse-line'>{}</span>"},"vv40:5.2":{"pli":"Aparaddhaṁ dukkhitañca me bhante; ","html":"<span class='verse-line'>{}</span>"},"vv40:5.3":{"pli":"Sāhaṁ dhammaṁ nāssosiṁ, ","html":"<span class='verse-line'>{}</span>"},"vv40:5.4":{"pli":"Sudesitaṁ dhammarājena. ","html":"<span class='verse-line'>{}</span></p>"},"vv40:6.1":{"pli":"Taṁ taṁ vadāmi bhaddante, ","html":"<p><span class='verse-line'>{}</span>"},"vv40:6.2":{"pli":"‘Yassa me anukampiyo koci; ","html":"<span class='verse-line'>{}</span>"},"vv40:6.3":{"pli":"Dhammesu taṁ samādapetha’, ","html":"<span class='verse-line'>{}</span>"},"vv40:6.4":{"pli":"Sudesitaṁ dhammarājena. ","html":"<span class='verse-line'>{}</span></p>"},"vv40:7.1":{"pli":"Yesaṁ atthi saddhā buddhe, ","html":"<p><span class='verse-line'>{}</span>"},"vv40:7.2":{"pli":"dhamme ca saṅgharatane; ","html":"<span class='verse-line'>{}</span>"},"vv40:7.3":{"pli":"Te maṁ ativirocanti, ","html":"<span class='verse-line'>{}</span>"},"vv40:7.4":{"pli":"āyunā yasasā siriyā. ","html":"<span class='verse-line'>{}</span></p>"},"vv40:8.1":{"pli":"Patāpena vaṇṇena uttaritarā, ","html":"<p><span class='verse-line'>{}</span>"},"vv40:8.2":{"pli":"Aññe mahiddhikatarā mayā devā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv40:9.1":{"pli":"Pabhassaravimānaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"vv41":{"vv41:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv41'><header><ul><li class='division'>{}</li>"},"vv41:0.2":{"pli":"Itthivimāna ","html":"<li>{}</li>"},"vv41:0.3":{"pli":"Mañjiṭṭhakavagga ","html":"<li>{}</li></ul>"},"vv41:0.4":{"pli":"3. Nāgavimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv41:1.1":{"pli":"“Alaṅkatā maṇikañcanācitaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv41:1.2":{"pli":"Sovaṇṇajālacitaṁ mahantaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv41:1.3":{"pli":"Abhiruyha gajavaraṁ sukappitaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv41:1.4":{"pli":"Idhāgamā vehāyasaṁ antalikkhe. ","html":"<span class='verse-line'>{}</span></p>"},"vv41:2.1":{"pli":"Nāgassa dantesu duvesu nimmitā, ","html":"<p><span class='verse-line'>{}</span>"},"vv41:2.2":{"pli":"Acchodakā paduminiyo suphullā; ","html":"<span class='verse-line'>{}</span>"},"vv41:2.3":{"pli":"Padumesu ca tūriyagaṇā pabhijjare, ","html":"<span class='verse-line'>{}</span>"},"vv41:2.4":{"pli":"Imā ca naccanti manoharāyo. ","html":"<span class='verse-line'>{}</span></p>"},"vv41:3.1":{"pli":"Deviddhipattāsi mahānubhāve, ","html":"<p><span class='verse-line'>{}</span>"},"vv41:3.2":{"pli":"Manussabhūtā kimakāsi puññaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv41:3.3":{"pli":"Kenāsi evaṁ jalitānubhāvā, ","html":"<span class='verse-line'>{}</span>"},"vv41:3.4":{"pli":"Vaṇṇo ca te sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv41:4.1":{"pli":"“Bārāṇasiyaṁ upasaṅkamitvā, ","html":"<p><span class='verse-line'>{}</span>"},"vv41:4.2":{"pli":"Buddhassahaṁ vatthayugaṁ adāsiṁ; ","html":"<span class='verse-line'>{}</span>"},"vv41:4.3":{"pli":"Pādāni vanditvā chamā nisīdiṁ, ","html":"<span class='verse-line'>{}</span>"},"vv41:4.4":{"pli":"Vittā cahaṁ añjalikaṁ akāsiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv41:5.1":{"pli":"Buddho ca me kañcanasannibhattaco, ","html":"<p><span class='verse-line'>{}</span>"},"vv41:5.2":{"pli":"Adesayi samudayadukkhaniccataṁ; ","html":"<span class='verse-line'>{}</span>"},"vv41:5.3":{"pli":"Asaṅkhataṁ dukkhanirodhasassataṁ, ","html":"<span class='verse-line'>{}</span>"},"vv41:5.4":{"pli":"Maggaṁ adesayi yato vijānisaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv41:6.1":{"pli":"Appāyukī kālakatā tato cutā, ","html":"<p><span class='verse-line'>{}</span>"},"vv41:6.2":{"pli":"Upapannā tidasagaṇaṁ yasassinī; ","html":"<span class='verse-line'>{}</span>"},"vv41:6.3":{"pli":"Sakkassahaṁ aññatarā pajāpati, ","html":"<span class='verse-line'>{}</span>"},"vv41:6.4":{"pli":"Yasuttarā nāma disāsu vissutā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv41:7.1":{"pli":"Nāgavimānaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"vv42":{"vv42:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv42'><header><ul><li class='division'>{}</li>"},"vv42:0.2":{"pli":"Itthivimāna ","html":"<li>{}</li>"},"vv42:0.3":{"pli":"Mañjiṭṭhakavagga ","html":"<li>{}</li></ul>"},"vv42:0.4":{"pli":"4. Alomavimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv42:1.1":{"pli":"“Abhikkantena vaṇṇena, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv42:1.2":{"pli":"yā tvaṁ tiṭṭhasi devate; ","html":"<span class='verse-line'>{}</span>"},"vv42:1.3":{"pli":"Obhāsentī disā sabbā, ","html":"<span class='verse-line'>{}</span>"},"vv42:1.4":{"pli":"osadhī viya tārakā. ","html":"<span class='verse-line'>{}</span></p>"},"vv42:2.1":{"pli":"Kena tetādiso vaṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"vv42:2.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"vv42:2.3":{"pli":"Vaṇṇo ca te sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv42:3.1":{"pli":"Sā devatā attamanā, ","html":"<p><span class='verse-line'>{}</span>"},"vv42:3.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"vv42:3.3":{"pli":"yassa kammassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv42:4.1":{"pli":"“Ahañca bārāṇasiyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv42:4.2":{"pli":"buddhassādiccabandhuno; ","html":"<span class='verse-line'>{}</span>"},"vv42:4.3":{"pli":"Adāsiṁ sukkhakummāsaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv42:4.4":{"pli":"pasannā sehi pāṇibhi. ","html":"<span class='verse-line'>{}</span></p>"},"vv42:5.1":{"pli":"Sukkhāya aloṇikāya ca, ","html":"<p><span class='verse-line'>{}</span>"},"vv42:5.2":{"pli":"Passa phalaṁ kummāsapiṇḍiyā; ","html":"<span class='verse-line'>{}</span>"},"vv42:5.3":{"pli":"Alomaṁ sukhitaṁ disvā, ","html":"<span class='verse-line'>{}</span>"},"vv42:5.4":{"pli":"Ko puññaṁ na karissati. ","html":"<span class='verse-line'>{}</span></p>"},"vv42:6.1":{"pli":"Tena metādiso vaṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"vv42:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"vv42:6.3":{"pli":"Vaṇṇo ca me sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv42:7.1":{"pli":"Alomavimānaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}