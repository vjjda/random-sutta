{"ja366":{"ja366:0.1":{"pli":"Jātaka ","html":"<article id='ja366'><header><ul><li class='division'>{}</li>"},"ja366:0.2":{"pli":"Pañcakanipāta ","html":"<li>{}</li>"},"ja366:0.3":{"pli":"Vaṇṇārohavagga ","html":"<li>{}</li></ul>"},"ja366:0.4":{"pli":"6. Gumbiyajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja366:1.1":{"pli":"“Madhuvaṇṇaṁ madhurasaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja366:1.2":{"pli":"madhugandhaṁ visaṁ ahu; ","html":"<span class='verse-line'>{}</span>"},"ja366:1.3":{"pli":"Gumbiyo ghāsamesāno, ","html":"<span class='verse-line'>{}</span>"},"ja366:1.4":{"pli":"araññe odahī visaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja366:2.1":{"pli":"Madhu iti maññamānā, ","html":"<p><span class='verse-line'>{}</span>"},"ja366:2.2":{"pli":"ye taṁ visamakhādisuṁ; ","html":"<span class='verse-line'>{}</span>"},"ja366:2.3":{"pli":"Tesaṁ taṁ kaṭukaṁ āsi, ","html":"<span class='verse-line'>{}</span>"},"ja366:2.4":{"pli":"maraṇaṁ tenupāgamuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja366:3.1":{"pli":"Ye ca kho paṭisaṅkhāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja366:3.2":{"pli":"visaṁ taṁ parivajjayuṁ; ","html":"<span class='verse-line'>{}</span>"},"ja366:3.3":{"pli":"Te āturesu sukhitā, ","html":"<span class='verse-line'>{}</span>"},"ja366:3.4":{"pli":"ḍayhamānesu nibbutā. ","html":"<span class='verse-line'>{}</span></p>"},"ja366:4.1":{"pli":"Evameva manussesu, ","html":"<p><span class='verse-line'>{}</span>"},"ja366:4.2":{"pli":"visaṁ kāmā samohitā; ","html":"<span class='verse-line'>{}</span>"},"ja366:4.3":{"pli":"Āmisaṁ bandhanañcetaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja366:4.4":{"pli":"maccuveso guhāsayo. ","html":"<span class='verse-line'>{}</span></p>"},"ja366:5.1":{"pli":"Evameva ime kāme, ","html":"<p><span class='verse-line'>{}</span>"},"ja366:5.2":{"pli":"āturā paricārike; ","html":"<span class='verse-line'>{}</span>"},"ja366:5.3":{"pli":"Ye sadā parivajjenti, ","html":"<span class='verse-line'>{}</span>"},"ja366:5.4":{"pli":"saṅgaṁ loke upaccagun”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja366:6.1":{"pli":"Gumbiyajātakaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja367":{"ja367:0.1":{"pli":"Jātaka ","html":"<article id='ja367'><header><ul><li class='division'>{}</li>"},"ja367:0.2":{"pli":"Pañcakanipāta ","html":"<li>{}</li>"},"ja367:0.3":{"pli":"Vaṇṇārohavagga ","html":"<li>{}</li></ul>"},"ja367:0.4":{"pli":"7. Sāḷiyajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja367:1.1":{"pli":"“Yvāyaṁ sāḷiyachāpoti, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja367:1.2":{"pli":"kaṇhasappaṁ agāhayi; ","html":"<span class='verse-line'>{}</span>"},"ja367:1.3":{"pli":"Tena sappenayaṁ daṭṭho, ","html":"<span class='verse-line'>{}</span>"},"ja367:1.4":{"pli":"hato pāpānusāsako. ","html":"<span class='verse-line'>{}</span></p>"},"ja367:2.1":{"pli":"Ahantāra mahantāraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja367:2.2":{"pli":"yo naro hantumicchati; ","html":"<span class='verse-line'>{}</span>"},"ja367:2.3":{"pli":"Evaṁ so nihato seti, ","html":"<span class='verse-line'>{}</span>"},"ja367:2.4":{"pli":"yathāyaṁ puriso hato. ","html":"<span class='verse-line'>{}</span></p>"},"ja367:3.1":{"pli":"Ahantāra maghātentaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja367:3.2":{"pli":"yo naro hantumicchati; ","html":"<span class='verse-line'>{}</span>"},"ja367:3.3":{"pli":"Evaṁ so nihato seti, ","html":"<span class='verse-line'>{}</span>"},"ja367:3.4":{"pli":"yathāyaṁ puriso hato. ","html":"<span class='verse-line'>{}</span></p>"},"ja367:4.1":{"pli":"Yathā paṁsumuṭṭhiṁ puriso, ","html":"<p><span class='verse-line'>{}</span>"},"ja367:4.2":{"pli":"paṭivātaṁ paṭikkhipe; ","html":"<span class='verse-line'>{}</span>"},"ja367:4.3":{"pli":"Tameva so rajo hanti, ","html":"<span class='verse-line'>{}</span>"},"ja367:4.4":{"pli":"tathāyaṁ puriso hato. ","html":"<span class='verse-line'>{}</span></p>"},"ja367:5.1":{"pli":"Yo appaduṭṭhassa narassa dussati, ","html":"<p><span class='verse-line'>{}</span>"},"ja367:5.2":{"pli":"Suddhassa posassa anaṅgaṇassa; ","html":"<span class='verse-line'>{}</span>"},"ja367:5.3":{"pli":"Tameva bālaṁ pacceti pāpaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja367:5.4":{"pli":"Sukhumo rajo paṭivātaṁva khitto”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja367:6.1":{"pli":"Sāḷiyajātakaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja368":{"ja368:0.1":{"pli":"Jātaka ","html":"<article id='ja368'><header><ul><li class='division'>{}</li>"},"ja368:0.2":{"pli":"Pañcakanipāta ","html":"<li>{}</li>"},"ja368:0.3":{"pli":"Vaṇṇārohavagga ","html":"<li>{}</li></ul>"},"ja368:0.4":{"pli":"8. Tacasārajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja368:1.1":{"pli":"“Amittahatthatthagatā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja368:1.2":{"pli":"tacasārasamappitā; ","html":"<span class='verse-line'>{}</span>"},"ja368:1.3":{"pli":"Pasannamukhavaṇṇāttha, ","html":"<span class='verse-line'>{}</span>"},"ja368:1.4":{"pli":"kasmā tumhe na socatha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja368:2.1":{"pli":"“Na socanāya paridevanāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja368:2.2":{"pli":"Atthova labbho api appakopi; ","html":"<span class='verse-line'>{}</span>"},"ja368:2.3":{"pli":"Socantamenaṁ dukhitaṁ viditvā, ","html":"<span class='verse-line'>{}</span>"},"ja368:2.4":{"pli":"Paccatthikā attamanā bhavanti. ","html":"<span class='verse-line'>{}</span></p>"},"ja368:3.1":{"pli":"Yato ca kho paṇḍito āpadāsu, ","html":"<p><span class='verse-line'>{}</span>"},"ja368:3.2":{"pli":"Na vedhatī atthavinicchayaññū; ","html":"<span class='verse-line'>{}</span>"},"ja368:3.3":{"pli":"Paccatthikāssa dukhitā bhavanti, ","html":"<span class='verse-line'>{}</span>"},"ja368:3.4":{"pli":"Disvā mukhaṁ avikāraṁ purāṇaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja368:4.1":{"pli":"Jappena mantena subhāsitena, ","html":"<p><span class='verse-line'>{}</span>"},"ja368:4.2":{"pli":"Anuppadānena paveṇiyā vā; ","html":"<span class='verse-line'>{}</span>"},"ja368:4.3":{"pli":"Yathā yathā yattha labhetha atthaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja368:4.4":{"pli":"Tathā tathā tattha parakkameyya. ","html":"<span class='verse-line'>{}</span></p>"},"ja368:5.1":{"pli":"Yato ca jāneyya alabbhaneyyo, ","html":"<p><span class='verse-line'>{}</span>"},"ja368:5.2":{"pli":"Mayā va aññena vā esa attho; ","html":"<span class='verse-line'>{}</span>"},"ja368:5.3":{"pli":"Asocamāno adhivāsayeyya, ","html":"<span class='verse-line'>{}</span>"},"ja368:5.4":{"pli":"Kammaṁ daḷhaṁ kinti karomi dānī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja368:6.1":{"pli":"Tacasārajātakaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja369":{"ja369:0.1":{"pli":"Jātaka ","html":"<article id='ja369'><header><ul><li class='division'>{}</li>"},"ja369:0.2":{"pli":"Pañcakanipāta ","html":"<li>{}</li>"},"ja369:0.3":{"pli":"Vaṇṇārohavagga ","html":"<li>{}</li></ul>"},"ja369:0.4":{"pli":"9. Mittavindakajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja369:1.1":{"pli":"“Kyāhaṁ devānamakaraṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja369:1.2":{"pli":"kiṁ pāpaṁ pakataṁ mayā; ","html":"<span class='verse-line'>{}</span>"},"ja369:1.3":{"pli":"Yaṁ me sirasmiṁ ohacca, ","html":"<span class='verse-line'>{}</span>"},"ja369:1.4":{"pli":"cakkaṁ bhamati matthake”. ","html":"<span class='verse-line'>{}</span></p>"},"ja369:2.1":{"pli":"“Atikkamma ramaṇakaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja369:2.2":{"pli":"sadāmattañca dūbhakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja369:2.3":{"pli":"Brahmattarañca pāsādaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja369:2.4":{"pli":"kenatthena idhāgato”. ","html":"<span class='verse-line'>{}</span></p>"},"ja369:3.1":{"pli":"“Ito bahutarā bhogā, ","html":"<p><span class='verse-line'>{}</span>"},"ja369:3.2":{"pli":"atra maññe bhavissare; ","html":"<span class='verse-line'>{}</span>"},"ja369:3.3":{"pli":"Iti etāya saññāya, ","html":"<span class='verse-line'>{}</span>"},"ja369:3.4":{"pli":"passa maṁ byasanaṁ gataṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja369:4.1":{"pli":"“Catubbhi aṭṭhajjhagamā, ","html":"<p><span class='verse-line'>{}</span>"},"ja369:4.2":{"pli":"aṭṭhāhipi ca soḷasa; ","html":"<span class='verse-line'>{}</span>"},"ja369:4.3":{"pli":"Soḷasāhi ca bāttiṁsa, ","html":"<span class='verse-line'>{}</span>"},"ja369:4.4":{"pli":"atricchaṁ cakkamāsado; ","html":"<span class='verse-line'>{}</span>"},"ja369:4.5":{"pli":"Icchāhatassa posassa, ","html":"<span class='verse-line'>{}</span>"},"ja369:4.6":{"pli":"cakkaṁ bhamati matthake. ","html":"<span class='verse-line'>{}</span></p>"},"ja369:5.1":{"pli":"Uparivisālā duppūrā, ","html":"<p><span class='verse-line'>{}</span>"},"ja369:5.2":{"pli":"icchā visaṭagāminī; ","html":"<span class='verse-line'>{}</span>"},"ja369:5.3":{"pli":"Ye ca taṁ anugijjhanti, ","html":"<span class='verse-line'>{}</span>"},"ja369:5.4":{"pli":"te honti cakkadhārino”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja369:6.1":{"pli":"Mittavindakajātakaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja37":{"ja37:0.1":{"pli":"Jātaka ","eng":"Stories of Past Lives 37 ","html":"<article id='ja37'><header><ul><li class='division'>{}</li>"},"ja37:0.2":{"pli":"Ekakanipāta ","eng":"The Book of the Ones ","html":"<li>{}</li>"},"ja37:0.3":{"pli":"Kulāvakavagga ","eng":"Nests ","html":"<li>{}</li></ul>"},"ja37:0.4":{"pli":"7. Tittirajātaka ","eng":"The Partridge: a past life story ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja37:1.1":{"pli":"“Ye vuḍḍhamapacāyanti, ","eng":"Those people who honor the elder ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>","comm":"A partridge, a monkey, and an elephant were friends who lived happily because they honored the eldest among them. "},"ja37:1.2":{"pli":"narā dhammassa kovidā; ","eng":"are experts in the teaching; ","html":"<span class='verse-line'>{}</span>"},"ja37:1.3":{"pli":"Diṭṭheva dhamme pāsaṁsā, ","eng":"praised in this life, ","html":"<span class='verse-line'>{}</span>"},"ja37:1.4":{"pli":"samparāye ca suggatī”ti. ","eng":"they’re destined for happiness in the next. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja37:2.1":{"pli":"Tittirajātakaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja370":{"ja370:0.1":{"pli":"Jātaka ","html":"<article id='ja370'><header><ul><li class='division'>{}</li>"},"ja370:0.2":{"pli":"Pañcakanipāta ","html":"<li>{}</li>"},"ja370:0.3":{"pli":"Vaṇṇārohavagga ","html":"<li>{}</li></ul>"},"ja370:0.4":{"pli":"10. Palāsajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja370:1.1":{"pli":"“Haṁso palāsamavaca, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja370:1.2":{"pli":"nigrodho samma jāyati; ","html":"<span class='verse-line'>{}</span>"},"ja370:1.3":{"pli":"Aṅkasmiṁ te nisinnova, ","html":"<span class='verse-line'>{}</span>"},"ja370:1.4":{"pli":"so te mammāni checchati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja370:2.1":{"pli":"“Vaḍḍhatāmeva nigrodho, ","html":"<p><span class='verse-line'>{}</span>"},"ja370:2.2":{"pli":"patiṭṭhassa bhavāmahaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja370:2.3":{"pli":"Yathā pitā ca mātā ca, ","html":"<span class='verse-line'>{}</span>"},"ja370:2.4":{"pli":"evaṁ me so bhavissati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja370:3.1":{"pli":"“Yaṁ tvaṁ aṅkasmiṁ vaḍḍhesi, ","html":"<p><span class='verse-line'>{}</span>"},"ja370:3.2":{"pli":"khīrarukkhaṁ bhayānakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja370:3.3":{"pli":"Āmanta kho taṁ gacchāma, ","html":"<span class='verse-line'>{}</span>"},"ja370:3.4":{"pli":"vuḍḍhi massa na ruccati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja370:4.1":{"pli":"“Idāni kho maṁ bhāyeti, ","html":"<p><span class='verse-line'>{}</span>"},"ja370:4.2":{"pli":"mahānerunidassanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja370:4.3":{"pli":"Haṁsassa anabhiññāya, ","html":"<span class='verse-line'>{}</span>"},"ja370:4.4":{"pli":"mahā me bhayamāgataṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja370:5.1":{"pli":"“Na tassa vuḍḍhi kusalappasatthā, ","html":"<p><span class='verse-line'>{}</span>"},"ja370:5.2":{"pli":"Yo vaḍḍhamāno ghasate patiṭṭhaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja370:5.3":{"pli":"Tassūparodhaṁ parisaṅkamāno, ","html":"<span class='verse-line'>{}</span>"},"ja370:5.4":{"pli":"Patārayī mūlavadhāya dhīro”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja370:6.1":{"pli":"Palāsajātakaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja370:6.2":{"pli":"Vaṇṇārohavaggo dutiyo. ","html":"<p class='endvagga'>{}</p></article>"}},"ja371":{"ja371:0.1":{"pli":"Jātaka ","html":"<article id='ja371'><header><ul><li class='division'>{}</li>"},"ja371:0.2":{"pli":"Pañcakanipāta ","html":"<li>{}</li>"},"ja371:0.3":{"pli":"Aḍḍhavagga ","html":"<li>{}</li></ul>"},"ja371:0.4":{"pli":"1. Dīghītikosalajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja371:1.1":{"pli":"“Evaṁbhūtassa te rāja, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja371:1.2":{"pli":"āgatassa vase mama; ","html":"<span class='verse-line'>{}</span>"},"ja371:1.3":{"pli":"Atthi nu koci pariyāyo, ","html":"<span class='verse-line'>{}</span>"},"ja371:1.4":{"pli":"yo taṁ dukkhā pamocaye”. ","html":"<span class='verse-line'>{}</span></p>"},"ja371:2.1":{"pli":"“Evaṁbhūtassa me tāta, ","html":"<p><span class='verse-line'>{}</span>"},"ja371:2.2":{"pli":"āgatassa vase tava; ","html":"<span class='verse-line'>{}</span>"},"ja371:2.3":{"pli":"Natthi no koci pariyāyo, ","html":"<span class='verse-line'>{}</span>"},"ja371:2.4":{"pli":"yo maṁ dukkhā pamocaye”. ","html":"<span class='verse-line'>{}</span></p>"},"ja371:3.1":{"pli":"“Nāññaṁ sucaritaṁ rāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja371:3.2":{"pli":"nāññaṁ rāja subhāsitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja371:3.3":{"pli":"Tāyate maraṇakāle, ","html":"<span class='verse-line'>{}</span>"},"ja371:3.4":{"pli":"evamevitaraṁ dhanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja371:4.1":{"pli":"Akkocchi maṁ avadhi maṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja371:4.2":{"pli":"ajini maṁ ahāsi me; ","html":"<span class='verse-line'>{}</span>"},"ja371:4.3":{"pli":"Ye ca taṁ upanayhanti, ","html":"<span class='verse-line'>{}</span>"},"ja371:4.4":{"pli":"veraṁ tesaṁ na sammati. ","html":"<span class='verse-line'>{}</span></p>"},"ja371:5.1":{"pli":"Akkocchi maṁ avadhi maṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja371:5.2":{"pli":"ajini maṁ ahāsi me; ","html":"<span class='verse-line'>{}</span>"},"ja371:5.3":{"pli":"Ye ca taṁ nupanayhanti, ","html":"<span class='verse-line'>{}</span>"},"ja371:5.4":{"pli":"veraṁ tesūpasammati. ","html":"<span class='verse-line'>{}</span></p>"},"ja371:6.1":{"pli":"Na hi verena verāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja371:6.2":{"pli":"sammantīdha kudācanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja371:6.3":{"pli":"Averena ca sammanti, ","html":"<span class='verse-line'>{}</span>"},"ja371:6.4":{"pli":"esa dhammo sanantano”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja371:7.1":{"pli":"Dīghītikosalajātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja372":{"ja372:0.1":{"pli":"Jātaka ","html":"<article id='ja372'><header><ul><li class='division'>{}</li>"},"ja372:0.2":{"pli":"Pañcakanipāta ","html":"<li>{}</li>"},"ja372:0.3":{"pli":"Aḍḍhavagga ","html":"<li>{}</li></ul>"},"ja372:0.4":{"pli":"2. Migapotakajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja372:1.1":{"pli":"“Agārā paccupetassa, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja372:1.2":{"pli":"anagārassa te sato; ","html":"<span class='verse-line'>{}</span>"},"ja372:1.3":{"pli":"Samaṇassa na taṁ sādhu, ","html":"<span class='verse-line'>{}</span>"},"ja372:1.4":{"pli":"yaṁ petamanusocasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja372:2.1":{"pli":"“Saṁvāsena have sakka, ","html":"<p><span class='verse-line'>{}</span>"},"ja372:2.2":{"pli":"manussassa migassa vā; ","html":"<span class='verse-line'>{}</span>"},"ja372:2.3":{"pli":"Hadaye jāyate pemaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja372:2.4":{"pli":"na taṁ sakkā asocituṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja372:3.1":{"pli":"“Mataṁ marissaṁ rodanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja372:3.2":{"pli":"ye rudanti lapanti ca; ","html":"<span class='verse-line'>{}</span>"},"ja372:3.3":{"pli":"Tasmā tvaṁ isi mā rodi, ","html":"<span class='verse-line'>{}</span>"},"ja372:3.4":{"pli":"roditaṁ moghamāhu santo. ","html":"<span class='verse-line'>{}</span></p>"},"ja372:4.1":{"pli":"Roditena have brahme, ","html":"<p><span class='verse-line'>{}</span>"},"ja372:4.2":{"pli":"mato peto samuṭṭhahe; ","html":"<span class='verse-line'>{}</span>"},"ja372:4.3":{"pli":"Sabbe saṅgamma rodāma, ","html":"<span class='verse-line'>{}</span>"},"ja372:4.4":{"pli":"aññamaññassa ñātake”. ","html":"<span class='verse-line'>{}</span></p>"},"ja372:5.1":{"pli":"“Ādittaṁ vata maṁ santaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja372:5.2":{"pli":"ghatasittaṁva pāvakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja372:5.3":{"pli":"Vārinā viya osiñcaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja372:5.4":{"pli":"sabbaṁ nibbāpaye daraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja372:6.1":{"pli":"Abbahi vata me sallaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja372:6.2":{"pli":"yamāsi hadayassitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja372:6.3":{"pli":"Yo me sokaparetassa, ","html":"<span class='verse-line'>{}</span>"},"ja372:6.4":{"pli":"puttasokaṁ apānudi. ","html":"<span class='verse-line'>{}</span></p>"},"ja372:7.1":{"pli":"Sohaṁ abbūḷhasallosmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja372:7.2":{"pli":"vītasoko anāvilo; ","html":"<span class='verse-line'>{}</span>"},"ja372:7.3":{"pli":"Na socāmi na rodāmi, ","html":"<span class='verse-line'>{}</span>"},"ja372:7.4":{"pli":"tava sutvāna vāsavā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja372:8.1":{"pli":"Migapotakajātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja373":{"ja373:0.1":{"pli":"Jātaka ","html":"<article id='ja373'><header><ul><li class='division'>{}</li>"},"ja373:0.2":{"pli":"Pañcakanipāta ","html":"<li>{}</li>"},"ja373:0.3":{"pli":"Aḍḍhavagga ","html":"<li>{}</li></ul>"},"ja373:0.4":{"pli":"3. Mūsikajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja373:1.1":{"pli":"“Kuhiṁ gatā kattha gatā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja373:1.2":{"pli":"iti lālappatī jano; ","html":"<span class='verse-line'>{}</span>"},"ja373:1.3":{"pli":"Ahameveko jānāmi, ","html":"<span class='verse-line'>{}</span>"},"ja373:1.4":{"pli":"udapāne mūsikā hatā. ","html":"<span class='verse-line'>{}</span></p>"},"ja373:2.1":{"pli":"Yañcetaṁ iti cīti ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja373:2.2":{"pli":"gadrabhova nivattasi; ","html":"<span class='verse-line'>{}</span>"},"ja373:2.3":{"pli":"Udapāne mūsikaṁ hantvā, ","html":"<span class='verse-line'>{}</span>"},"ja373:2.4":{"pli":"yavaṁ bhakkhetumicchasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja373:3.1":{"pli":"Daharo cāsi dummedha, ","html":"<p><span class='verse-line'>{}</span>"},"ja373:3.2":{"pli":"paṭhamuppattiko susu; ","html":"<span class='verse-line'>{}</span>"},"ja373:3.3":{"pli":"Dīghañcetaṁ samāsajja, ","html":"<span class='verse-line'>{}</span>"},"ja373:3.4":{"pli":"na te dassāmi jīvitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja373:4.1":{"pli":"Nāntalikkhabhavanena, ","html":"<p><span class='verse-line'>{}</span>"},"ja373:4.2":{"pli":"nāṅgaputtapinena vā; ","html":"<span class='verse-line'>{}</span>"},"ja373:4.3":{"pli":"Puttena hi patthayito, ","html":"<span class='verse-line'>{}</span>"},"ja373:4.4":{"pli":"silokehi pamocito. ","html":"<span class='verse-line'>{}</span></p>"},"ja373:5.1":{"pli":"Sabbaṁ sutamadhīyetha, ","html":"<p><span class='verse-line'>{}</span>"},"ja373:5.2":{"pli":"hīnamukkaṭṭhamajjhimaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja373:5.3":{"pli":"Sabbassa atthaṁ jāneyya, ","html":"<span class='verse-line'>{}</span>"},"ja373:5.4":{"pli":"na ca sabbaṁ payojaye; ","html":"<span class='verse-line'>{}</span>"},"ja373:5.5":{"pli":"Hoti tādisako kālo, ","html":"<span class='verse-line'>{}</span>"},"ja373:5.6":{"pli":"yattha atthāvahaṁ sutan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja373:6.1":{"pli":"Mūsikajātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja374":{"ja374:0.1":{"pli":"Jātaka ","html":"<article id='ja374'><header><ul><li class='division'>{}</li>"},"ja374:0.2":{"pli":"Pañcakanipāta ","html":"<li>{}</li>"},"ja374:0.3":{"pli":"Aḍḍhavagga ","html":"<li>{}</li></ul>"},"ja374:0.4":{"pli":"4. Cūḷadhanuggahajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja374:1.1":{"pli":"“Sabbaṁ bhaṇḍaṁ samādāya, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja374:1.2":{"pli":"pāraṁ tiṇṇosi brāhmaṇa; ","html":"<span class='verse-line'>{}</span>"},"ja374:1.3":{"pli":"Paccāgaccha lahuṁ khippaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja374:1.4":{"pli":"mampi tārehi dānito”. ","html":"<span class='verse-line'>{}</span></p>"},"ja374:2.1":{"pli":"“Asanthutaṁ maṁ cirasanthutena, ","html":"<p><span class='verse-line'>{}</span>"},"ja374:2.2":{"pli":"Nimīni bhotī addhuvaṁ dhuvena; ","html":"<span class='verse-line'>{}</span>"},"ja374:2.3":{"pli":"Mayāpi bhotī nimineyya aññaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja374:2.4":{"pli":"Ito ahaṁ dūrataraṁ gamissaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja374:3.1":{"pli":"“Kāyaṁ eḷagalāgumbe, ","html":"<p><span class='verse-line'>{}</span>"},"ja374:3.2":{"pli":"karoti ahuhāsiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja374:3.3":{"pli":"Nayīdha naccagītaṁ vā, ","html":"<span class='verse-line'>{}</span>"},"ja374:3.4":{"pli":"tāḷaṁ vā susamāhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja374:3.5":{"pli":"Anamhikāle susoṇi, ","html":"<span class='verse-line'>{}</span>"},"ja374:3.6":{"pli":"kiṁ nu jagghasi sobhane”. ","html":"<span class='verse-line'>{}</span></p>"},"ja374:4.1":{"pli":"“Siṅgāla bāla dummedha, ","html":"<p><span class='verse-line'>{}</span>"},"ja374:4.2":{"pli":"appapaññosi jambuka; ","html":"<span class='verse-line'>{}</span>"},"ja374:4.3":{"pli":"Jīno macchañca pesiñca, ","html":"<span class='verse-line'>{}</span>"},"ja374:4.4":{"pli":"kapaṇo viya jhāyasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja374:5.1":{"pli":"“Sudassaṁ vajjamaññesaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja374:5.2":{"pli":"attano pana duddasaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja374:5.3":{"pli":"Jīnā patiñca jārañca, ","html":"<span class='verse-line'>{}</span>"},"ja374:5.4":{"pli":"maññe tvaññeva jhāyasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja374:6.1":{"pli":"“Evametaṁ migarāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja374:6.2":{"pli":"yathā bhāsasi jambuka; ","html":"<span class='verse-line'>{}</span>"},"ja374:6.3":{"pli":"Sā nūnāhaṁ ito gantvā, ","html":"<span class='verse-line'>{}</span>"},"ja374:6.4":{"pli":"bhattu hessaṁ vasānugā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja374:7.1":{"pli":"“Yo hare mattikaṁ thālaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja374:7.2":{"pli":"kaṁsathālampi so hare; ","html":"<span class='verse-line'>{}</span>"},"ja374:7.3":{"pli":"Katañceva tayā pāpaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja374:7.4":{"pli":"punapevaṁ karissasī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja374:8.1":{"pli":"Cūḷadhanuggahajātakaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja375":{"ja375:0.1":{"pli":"Jātaka ","html":"<article id='ja375'><header><ul><li class='division'>{}</li>"},"ja375:0.2":{"pli":"Pañcakanipāta ","html":"<li>{}</li>"},"ja375:0.3":{"pli":"Aḍḍhavagga ","html":"<li>{}</li></ul>"},"ja375:0.4":{"pli":"5. Kapotajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja375:1.1":{"pli":"“Idāni khomhi sukhito arogo, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja375:1.2":{"pli":"Nikkaṇṭako nippatito kapoto; ","html":"<span class='verse-line'>{}</span>"},"ja375:1.3":{"pli":"Kāhāmi dānī hadayassa tuṭṭhiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja375:1.4":{"pli":"Tathāhimaṁ maṁsasākaṁ baleti”. ","html":"<span class='verse-line'>{}</span></p>"},"ja375:2.1":{"pli":"“Kāyaṁ balākā sikhinī, ","html":"<p><span class='verse-line'>{}</span>"},"ja375:2.2":{"pli":"corī laṅghipitāmahā; ","html":"<span class='verse-line'>{}</span>"},"ja375:2.3":{"pli":"Oraṁ balāke āgaccha, ","html":"<span class='verse-line'>{}</span>"},"ja375:2.4":{"pli":"caṇḍo me vāyaso sakhā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja375:3.1":{"pli":"“Alañhi te jagghitāye, ","html":"<p><span class='verse-line'>{}</span>"},"ja375:3.2":{"pli":"Mamaṁ disvāna edisaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja375:3.3":{"pli":"Vilūnaṁ sūdaputtena, ","html":"<span class='verse-line'>{}</span>"},"ja375:3.4":{"pli":"Piṭṭhamaṇḍena makkhitaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja375:4.1":{"pli":"“Sunhāto suvilittosi, ","html":"<p><span class='verse-line'>{}</span>"},"ja375:4.2":{"pli":"annapānena tappito; ","html":"<span class='verse-line'>{}</span>"},"ja375:4.3":{"pli":"Kaṇṭhe ca te veḷuriyo, ","html":"<span class='verse-line'>{}</span>"},"ja375:4.4":{"pli":"agamā nu kajaṅgalaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja375:5.1":{"pli":"“Mā te mitto amitto vā, ","html":"<p><span class='verse-line'>{}</span>"},"ja375:5.2":{"pli":"agamāsi kajaṅgalaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja375:5.3":{"pli":"Piñchāni tattha lāyitvā, ","html":"<span class='verse-line'>{}</span>"},"ja375:5.4":{"pli":"kaṇṭhe bandhanti vaṭṭanaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja375:6.1":{"pli":"“Punapāpajjasī samma, ","html":"<p><span class='verse-line'>{}</span>"},"ja375:6.2":{"pli":"Sīlañhi tava tādisaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja375:6.3":{"pli":"Na hi mānusakā bhogā, ","html":"<span class='verse-line'>{}</span>"},"ja375:6.4":{"pli":"Subhuñjā honti pakkhinā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja375:7.1":{"pli":"Kapotajātakaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja375:7.2":{"pli":"Aḍḍhavaggo tatiyo. ","html":"<p class='endvagga'>{}</p>"},"ja375:8.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja375:9.1":{"pli":"Atha vaṇṇa sasīla hiri labhate, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja375:9.2":{"pli":"Sumukhā visa sāḷiyamittavaro; ","html":"<span class='verse-line'>{}</span>"},"ja375:9.3":{"pli":"Atha cakka palāsa sarāja sato, ","html":"<span class='verse-line'>{}</span>"},"ja375:9.4":{"pli":"Yava bāla kapotaka pannarasāti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja375:10.1":{"pli":"Atha vagguddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja375:11.1":{"pli":"Jīnañca vaṇṇaṁ asamaṁvaguppari, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja375:11.2":{"pli":"Sudesitā jātakanti santi vīsati; ","html":"<span class='verse-line'>{}</span>"},"ja375:11.3":{"pli":"Mahesino brahmacarittamutta- ","html":"<span class='verse-line'>{}</span>"},"ja375:11.4":{"pli":"Mavoca gāthā atthavatī subyañjanāti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja375:12.1":{"pli":"Pañcakanipātaṁ niṭṭhitaṁ. ","html":"<p class='endsection'>{}</p></article>"}},"ja376":{"ja376:0.1":{"pli":"Jātaka ","html":"<article id='ja376'><header><ul><li class='division'>{}</li>"},"ja376:0.2":{"pli":"Chakkanipāta ","html":"<li>{}</li>"},"ja376:0.3":{"pli":"Avāriyavagga ","html":"<li>{}</li></ul>"},"ja376:0.4":{"pli":"1. Avāriyajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja376:1.1":{"pli":"“Māsu kujjha bhūmipati, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja376:1.2":{"pli":"māsu kujjha rathesabha; ","html":"<span class='verse-line'>{}</span>"},"ja376:1.3":{"pli":"Kuddhaṁ appaṭikujjhanto, ","html":"<span class='verse-line'>{}</span>"},"ja376:1.4":{"pli":"rājā raṭṭhassa pūjito. ","html":"<span class='verse-line'>{}</span></p>"},"ja376:2.1":{"pli":"Gāme vā yadi vāraññe, ","html":"<p><span class='verse-line'>{}</span>"},"ja376:2.2":{"pli":"ninne vā yadi vā thale; ","html":"<span class='verse-line'>{}</span>"},"ja376:2.3":{"pli":"Sabbattha anusāsāmi, ","html":"<span class='verse-line'>{}</span>"},"ja376:2.4":{"pli":"māsu kujjha rathesabha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja376:3.1":{"pli":"“Avāriyapitā nāma, ","html":"<p><span class='verse-line'>{}</span>"},"ja376:3.2":{"pli":"ahu gaṅgāya nāviko; ","html":"<span class='verse-line'>{}</span>"},"ja376:3.3":{"pli":"Pubbe janaṁ tāretvāna, ","html":"<span class='verse-line'>{}</span>"},"ja376:3.4":{"pli":"pacchā yācati vetanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja376:3.5":{"pli":"Tenassa bhaṇḍanaṁ hoti, ","html":"<span class='verse-line'>{}</span>"},"ja376:3.6":{"pli":"na ca bhogehi vaḍḍhati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja376:4.1":{"pli":"“Atiṇṇaṁyeva yācassu, ","html":"<p><span class='verse-line'>{}</span>"},"ja376:4.2":{"pli":"apāraṁ tāta nāvika; ","html":"<span class='verse-line'>{}</span>"},"ja376:4.3":{"pli":"Añño hi tiṇṇassa mano, ","html":"<span class='verse-line'>{}</span>"},"ja376:4.4":{"pli":"añño hoti pāresino. ","html":"<span class='verse-line'>{}</span></p>"},"ja376:5.1":{"pli":"Gāme vā yadi vāraññe, ","html":"<p><span class='verse-line'>{}</span>"},"ja376:5.2":{"pli":"ninne vā yadi vā thale; ","html":"<span class='verse-line'>{}</span>"},"ja376:5.3":{"pli":"Sabbattha anusāsāmi, ","html":"<span class='verse-line'>{}</span>"},"ja376:5.4":{"pli":"māsu kujjhittha nāvika”. ","html":"<span class='verse-line'>{}</span></p>"},"ja376:6.1":{"pli":"“Yāyevānusāsaniyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja376:6.2":{"pli":"rājā gāmavaraṁ adā; ","html":"<span class='verse-line'>{}</span>"},"ja376:6.3":{"pli":"Tāyevānusāsaniyā, ","html":"<span class='verse-line'>{}</span>"},"ja376:6.4":{"pli":"nāviko paharī mukhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja376:7.1":{"pli":"Bhattaṁ bhinnaṁ hatā bhariyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja376:7.2":{"pli":"Gabbho ca patito chamā; ","html":"<span class='verse-line'>{}</span>"},"ja376:7.3":{"pli":"Migova jātarūpena, ","html":"<span class='verse-line'>{}</span>"},"ja376:7.4":{"pli":"Na tenatthaṁ abandhi sū”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja376:8.1":{"pli":"Avāriyajātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja377":{"ja377:0.1":{"pli":"Jātaka ","html":"<article id='ja377'><header><ul><li class='division'>{}</li>"},"ja377:0.2":{"pli":"Chakkanipāta ","html":"<li>{}</li>"},"ja377:0.3":{"pli":"Avāriyavagga ","html":"<li>{}</li></ul>"},"ja377:0.4":{"pli":"2. Setaketujātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja377:1.1":{"pli":"“Mā tāta kujjhi na hi sādhu kodho, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja377:1.2":{"pli":"Bahumpi te adiṭṭhamassutañca; ","html":"<span class='verse-line'>{}</span>"},"ja377:1.3":{"pli":"Mātā pitā disatā setaketu, ","html":"<span class='verse-line'>{}</span>"},"ja377:1.4":{"pli":"Ācariyamāhu disataṁ pasatthā. ","html":"<span class='verse-line'>{}</span></p>"},"ja377:2.1":{"pli":"Agārino annadapānavatthadā, ","html":"<p><span class='verse-line'>{}</span>"},"ja377:2.2":{"pli":"Avhāyikā tampi disaṁ vadanti; ","html":"<span class='verse-line'>{}</span>"},"ja377:2.3":{"pli":"Esā disā paramā setaketu, ","html":"<span class='verse-line'>{}</span>"},"ja377:2.4":{"pli":"Yaṁ patvā dukkhī sukhino bhavanti”. ","html":"<span class='verse-line'>{}</span></p>"},"ja377:3.1":{"pli":"“Kharājinā jaṭilā paṅkadantā, ","html":"<p><span class='verse-line'>{}</span>"},"ja377:3.2":{"pli":"Dummakkharūpā yeme jappanti mante; ","html":"<span class='verse-line'>{}</span>"},"ja377:3.3":{"pli":"Kacci nu te mānusake payoge, ","html":"<span class='verse-line'>{}</span>"},"ja377:3.4":{"pli":"Idaṁ vidū parimuttā apāyā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja377:4.1":{"pli":"“Pāpāni kammāni katvāna rāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja377:4.2":{"pli":"Bahussuto ce na careyya dhammaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja377:4.3":{"pli":"Sahassavedopi na taṁ paṭicca, ","html":"<span class='verse-line'>{}</span>"},"ja377:4.4":{"pli":"Dukkhā pamucce caraṇaṁ apatvā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja377:5.1":{"pli":"“Sahassavedopi na taṁ paṭicca, ","html":"<p><span class='verse-line'>{}</span>"},"ja377:5.2":{"pli":"Dukkhā pamucce caraṇaṁ apatvā; ","html":"<span class='verse-line'>{}</span>"},"ja377:5.3":{"pli":"Maññāmi vedā aphalā bhavanti, ","html":"<span class='verse-line'>{}</span>"},"ja377:5.4":{"pli":"Sasaṁyamaṁ caraṇameva saccaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja377:6.1":{"pli":"“Na heva vedā aphalā bhavanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja377:6.2":{"pli":"Sasaṁyamaṁ caraṇameva saccaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja377:6.3":{"pli":"Kittiñhi pappoti adhicca vede, ","html":"<span class='verse-line'>{}</span>"},"ja377:6.4":{"pli":"Santiṁ puṇeti caraṇena danto”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja377:7.1":{"pli":"Setaketujātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja378":{"ja378:0.1":{"pli":"Jātaka ","html":"<article id='ja378'><header><ul><li class='division'>{}</li>"},"ja378:0.2":{"pli":"Chakkanipāta ","html":"<li>{}</li>"},"ja378:0.3":{"pli":"Avāriyavagga ","html":"<li>{}</li></ul>"},"ja378:0.4":{"pli":"3. Darīmukhajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja378:1.1":{"pli":"“Paṅko ca kāmā palipo ca kāmā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja378:1.2":{"pli":"Bhayañca metaṁ timūlaṁ pavuttaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja378:1.3":{"pli":"Rajo ca dhūmo ca mayā pakāsitā, ","html":"<span class='verse-line'>{}</span>"},"ja378:1.4":{"pli":"Hitvā tuvaṁ pabbaja brahmadatta”. ","html":"<span class='verse-line'>{}</span></p>"},"ja378:2.1":{"pli":"“Gadhito ca ratto ca adhimucchito ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja378:2.2":{"pli":"Kāmesvahaṁ brāhmaṇa bhiṁsarūpaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja378:2.3":{"pli":"Taṁ nussahe jīvikattho pahātuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja378:2.4":{"pli":"Kāhāmi puññāni anappakāni”. ","html":"<span class='verse-line'>{}</span></p>"},"ja378:3.1":{"pli":"“Yo atthakāmassa hitānukampino, ","html":"<p><span class='verse-line'>{}</span>"},"ja378:3.2":{"pli":"Ovajjamāno na karoti sāsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja378:3.3":{"pli":"Idameva seyyo iti maññamāno, ","html":"<span class='verse-line'>{}</span>"},"ja378:3.4":{"pli":"Punappunaṁ gabbhamupeti mando. ","html":"<span class='verse-line'>{}</span></p>"},"ja378:4.1":{"pli":"So ghorarūpaṁ nirayaṁ upeti, ","html":"<p><span class='verse-line'>{}</span>"},"ja378:4.2":{"pli":"Subhāsubhaṁ muttakarīsapūraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja378:4.3":{"pli":"Sattā sakāye na jahanti giddhā, ","html":"<span class='verse-line'>{}</span>"},"ja378:4.4":{"pli":"Ye honti kāmesu avītarāgā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja378:5.1":{"pli":"“Mīḷhena littā ruhirena makkhitā, ","html":"<p><span class='verse-line'>{}</span>"},"ja378:5.2":{"pli":"Semhena littā upanikkhamanti; ","html":"<span class='verse-line'>{}</span>"},"ja378:5.3":{"pli":"Yaṁ yañhi kāyena phusanti tāvade, ","html":"<span class='verse-line'>{}</span>"},"ja378:5.4":{"pli":"Sabbaṁ asātaṁ dukhameva kevalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja378:6.1":{"pli":"Disvā vadāmi na hi aññato savaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja378:6.2":{"pli":"Pubbenivāsaṁ bahukaṁ sarāmi; ","html":"<span class='verse-line'>{}</span>"},"ja378:6.3":{"pli":"Citrāhi gāthāhi subhāsitāhi, ","html":"<span class='verse-line'>{}</span>"},"ja378:6.4":{"pli":"Darīmukho nijjhāpayi sumedhan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja378:7.1":{"pli":"Darīmukhajātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja379":{"ja379:0.1":{"pli":"Jātaka ","html":"<article id='ja379'><header><ul><li class='division'>{}</li>"},"ja379:0.2":{"pli":"Chakkanipāta ","html":"<li>{}</li>"},"ja379:0.3":{"pli":"Avāriyavagga ","html":"<li>{}</li></ul>"},"ja379:0.4":{"pli":"4. Nerujātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja379:1.1":{"pli":"“Kākolā kākasaṅghā ca, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja379:1.2":{"pli":"mayañca patataṁ varā; ","html":"<span class='verse-line'>{}</span>"},"ja379:1.3":{"pli":"Sabbeva sadisā homa, ","html":"<span class='verse-line'>{}</span>"},"ja379:1.4":{"pli":"imaṁ āgamma pabbataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja379:2.1":{"pli":"Idha sīhā ca byagghā ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja379:2.2":{"pli":"siṅgālā ca migādhamā; ","html":"<span class='verse-line'>{}</span>"},"ja379:2.3":{"pli":"Sabbeva sadisā honti, ","html":"<span class='verse-line'>{}</span>"},"ja379:2.4":{"pli":"ayaṁ ko nāma pabbato”. ","html":"<span class='verse-line'>{}</span></p>"},"ja379:3.1":{"pli":"“Imaṁ nerūti jānanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja379:3.2":{"pli":"manussā pabbatuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja379:3.3":{"pli":"Idha vaṇṇena sampannā, ","html":"<span class='verse-line'>{}</span>"},"ja379:3.4":{"pli":"vasanti sabbapāṇino”. ","html":"<span class='verse-line'>{}</span></p>"},"ja379:4.1":{"pli":"“Amānanā yattha siyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja379:4.2":{"pli":"santānaṁ vā vimānanā; ","html":"<span class='verse-line'>{}</span>"},"ja379:4.3":{"pli":"Hīnasammānanā vāpi, ","html":"<span class='verse-line'>{}</span>"},"ja379:4.4":{"pli":"na tattha vasatiṁ vase. ","html":"<span class='verse-line'>{}</span></p>"},"ja379:5.1":{"pli":"Yatthālaso ca dakkho ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja379:5.2":{"pli":"sūro bhīru ca pūjiyā; ","html":"<span class='verse-line'>{}</span>"},"ja379:5.3":{"pli":"Na tattha santo vasanti, ","html":"<span class='verse-line'>{}</span>"},"ja379:5.4":{"pli":"avisesakare nare. ","html":"<span class='verse-line'>{}</span></p>"},"ja379:6.1":{"pli":"Nāyaṁ neru vibhajati, ","html":"<p><span class='verse-line'>{}</span>"},"ja379:6.2":{"pli":"hīnaukkaṭṭhamajjhime; ","html":"<span class='verse-line'>{}</span>"},"ja379:6.3":{"pli":"Avisesakaro neru, ","html":"<span class='verse-line'>{}</span>"},"ja379:6.4":{"pli":"handa neruṁ jahāmase”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja379:7.1":{"pli":"Nerujātakaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja38":{"ja38:0.1":{"pli":"Jātaka ","eng":"Stories of Past Lives 38 ","html":"<article id='ja38'><header><ul><li class='division'>{}</li>"},"ja38:0.2":{"pli":"Ekakanipāta ","eng":"The Book of the Ones ","html":"<li>{}</li>"},"ja38:0.3":{"pli":"Kulāvakavagga ","eng":"Nests ","html":"<li>{}</li></ul>"},"ja38:0.4":{"pli":"8. Bakajātaka ","eng":"The Crane: a past life story ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja38:1.1":{"pli":"“Nāccantaṁ nikatippañño, ","eng":"The clever cheat cannot achieve ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>","comm":"The crane, appearing to contemplate deeply as it waits beside the pond, catches the fish by means of fraud, but is outplayed by the canny crab. "},"ja38:1.2":{"pli":"nikatyā sukhamedhati; ","eng":"ultimate happiness by cheating. ","html":"<span class='verse-line'>{}</span>"},"ja38:1.3":{"pli":"Ārādheti nikatippañño, ","eng":"The clever cheat succeeds only ","html":"<span class='verse-line'>{}</span>"},"ja38:1.4":{"pli":"bako kakkaṭakāmivā”ti. ","eng":"in getting what the crane did from the crab. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja38:2.1":{"pli":"Bakajātakaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja380":{"ja380:0.1":{"pli":"Jātaka ","html":"<article id='ja380'><header><ul><li class='division'>{}</li>"},"ja380:0.2":{"pli":"Chakkanipāta ","html":"<li>{}</li>"},"ja380:0.3":{"pli":"Avāriyavagga ","html":"<li>{}</li></ul>"},"ja380:0.4":{"pli":"5. Āsaṅkajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja380:1.1":{"pli":"“Āsāvatī nāma latā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja380:1.2":{"pli":"jātā cittalatāvane; ","html":"<span class='verse-line'>{}</span>"},"ja380:1.3":{"pli":"Tassā vassasahassena, ","html":"<span class='verse-line'>{}</span>"},"ja380:1.4":{"pli":"ekaṁ nibbattate phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja380:2.1":{"pli":"Taṁ devā payirupāsanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja380:2.2":{"pli":"tāva dūraphalaṁ satiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja380:2.3":{"pli":"Āsīseva tuvaṁ rāja, ","html":"<span class='verse-line'>{}</span>"},"ja380:2.4":{"pli":"āsā phalavatī sukhā. ","html":"<span class='verse-line'>{}</span></p>"},"ja380:3.1":{"pli":"Āsīsateva so pakkhī, ","html":"<p><span class='verse-line'>{}</span>"},"ja380:3.2":{"pli":"āsīsateva so dijo; ","html":"<span class='verse-line'>{}</span>"},"ja380:3.3":{"pli":"Tassa cāsā samijjhati, ","html":"<span class='verse-line'>{}</span>"},"ja380:3.4":{"pli":"tāva dūragatā satī; ","html":"<span class='verse-line'>{}</span>"},"ja380:3.5":{"pli":"Āsīseva tuvaṁ rāja, ","html":"<span class='verse-line'>{}</span>"},"ja380:3.6":{"pli":"āsā phalavatī sukhā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja380:4.1":{"pli":"“Sampesi kho maṁ vācāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja380:4.2":{"pli":"na ca sampesi kammunā; ","html":"<span class='verse-line'>{}</span>"},"ja380:4.3":{"pli":"Mālā sereyyakasseva, ","html":"<span class='verse-line'>{}</span>"},"ja380:4.4":{"pli":"vaṇṇavantā agandhikā. ","html":"<span class='verse-line'>{}</span></p>"},"ja380:5.1":{"pli":"Aphalaṁ madhuraṁ vācaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja380:5.2":{"pli":"yo mittesu pakubbati; ","html":"<span class='verse-line'>{}</span>"},"ja380:5.3":{"pli":"Adadaṁ avissajaṁ bhogaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja380:5.4":{"pli":"sandhi tenassa jīrati. ","html":"<span class='verse-line'>{}</span></p>"},"ja380:6.1":{"pli":"Yañhi kayirā tañhi vade, ","html":"<p><span class='verse-line'>{}</span>"},"ja380:6.2":{"pli":"yaṁ na kayirā na taṁ vade; ","html":"<span class='verse-line'>{}</span>"},"ja380:6.3":{"pli":"Akarontaṁ bhāsamānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja380:6.4":{"pli":"parijānanti paṇḍitā. ","html":"<span class='verse-line'>{}</span></p>"},"ja380:7.1":{"pli":"Balañca vata me khīṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja380:7.2":{"pli":"pātheyyañca na vijjati; ","html":"<span class='verse-line'>{}</span>"},"ja380:7.3":{"pli":"Saṅke pāṇūparodhāya, ","html":"<span class='verse-line'>{}</span>"},"ja380:7.4":{"pli":"handa dāni vajāmahaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja380:8.1":{"pli":"“Etadeva hi me nāmaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja380:8.2":{"pli":"Yaṁ nāmasmi rathesabha; ","html":"<span class='verse-line'>{}</span>"},"ja380:8.3":{"pli":"Āgamehi mahārāja, ","html":"<span class='verse-line'>{}</span>"},"ja380:8.4":{"pli":"Pitaraṁ āmantayāmahan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja380:9.1":{"pli":"Āsaṅkajātakaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}