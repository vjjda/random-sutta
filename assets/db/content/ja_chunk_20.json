{"ja470":{"ja470:0.1":{"pli":"Jātaka ","html":"<article id='ja470'><header><ul><li class='division'>{}</li>"},"ja470:0.2":{"pli":"Dvādasakanipāta ","html":"<li>{}</li>"},"ja470:0.3":{"pli":"Cūḷakuṇālavagga ","html":"<li>{}</li></ul>"},"ja470:0.4":{"pli":"7. Kosiyajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja470:1.1":{"pli":"“Neva kiṇāmi napi vikkiṇāmi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja470:1.2":{"pli":"Na cāpi me sannicayo ca atthi; ","html":"<span class='verse-line'>{}</span>"},"ja470:1.3":{"pli":"Sukiccharūpaṁ vatidaṁ parittaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja470:1.4":{"pli":"Patthodano nālamayaṁ duvinnaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja470:2.1":{"pli":"“Appamhā appakaṁ dajjā, ","html":"<p><span class='verse-line'>{}</span>"},"ja470:2.2":{"pli":"anumajjhato majjhakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja470:2.3":{"pli":"Bahumhā bahukaṁ dajjā, ","html":"<span class='verse-line'>{}</span>"},"ja470:2.4":{"pli":"adānaṁ nupapajjati. ","html":"<span class='verse-line'>{}</span></p>"},"ja470:3.1":{"pli":"Taṁ taṁ vadāmi kosiya, ","html":"<p><span class='verse-line'>{}</span>"},"ja470:3.2":{"pli":"dehi dānāni bhuñja ca”. ","html":"<span class='verse-line'>{}</span>"},"ja470:3.3":{"pli":"Ariyamaggaṁ samārūha, ","html":"<span class='verse-line'>{}</span>"},"ja470:3.4":{"pli":"nekāsī labhate sukhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja470:4.1":{"pli":"“Moghañcassa hutaṁ hoti, ","html":"<p><span class='verse-line'>{}</span>"},"ja470:4.2":{"pli":"moghañcāpi samīhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja470:4.3":{"pli":"Atithismiṁ yo nisinnasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja470:4.4":{"pli":"eko bhuñjati bhojanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja470:5.1":{"pli":"Taṁ taṁ vadāmi kosiya, ","html":"<p><span class='verse-line'>{}</span>"},"ja470:5.2":{"pli":"dehi dānāni bhuñja ca; ","html":"<span class='verse-line'>{}</span>"},"ja470:5.3":{"pli":"Ariyamaggaṁ samārūha, ","html":"<span class='verse-line'>{}</span>"},"ja470:5.4":{"pli":"nekāsī labhate sukhaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja470:6.1":{"pli":"“Saccañcassa hutaṁ hoti, ","html":"<p><span class='verse-line'>{}</span>"},"ja470:6.2":{"pli":"saccañcāpi samīhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja470:6.3":{"pli":"Atithismiṁ yo nisinnasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja470:6.4":{"pli":"neko bhuñjati bhojanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja470:7.1":{"pli":"Taṁ taṁ vadāmi kosiya, ","html":"<p><span class='verse-line'>{}</span>"},"ja470:7.2":{"pli":"dehi dānāni bhuñja ca; ","html":"<span class='verse-line'>{}</span>"},"ja470:7.3":{"pli":"Ariyamaggaṁ samārūha, ","html":"<span class='verse-line'>{}</span>"},"ja470:7.4":{"pli":"nekāsī labhate sukhaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja470:8.1":{"pli":"“Sarañca juhati poso, ","html":"<p><span class='verse-line'>{}</span>"},"ja470:8.2":{"pli":"bahukāya gayāya ca; ","html":"<span class='verse-line'>{}</span>"},"ja470:8.3":{"pli":"Doṇe timbarutitthasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja470:8.4":{"pli":"sīghasote mahāvahe. ","html":"<span class='verse-line'>{}</span></p>"},"ja470:9.1":{"pli":"Atra cassa hutaṁ hoti, ","html":"<p><span class='verse-line'>{}</span>"},"ja470:9.2":{"pli":"atra cassa samīhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja470:9.3":{"pli":"Atithismiṁ yo nisinnasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja470:9.4":{"pli":"neko bhuñjati bhojanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja470:10.1":{"pli":"Taṁ taṁ vadāmi kosiya, ","html":"<p><span class='verse-line'>{}</span>"},"ja470:10.2":{"pli":"dehi dānāni bhuñja ca; ","html":"<span class='verse-line'>{}</span>"},"ja470:10.3":{"pli":"Ariyamaggaṁ samārūha, ","html":"<span class='verse-line'>{}</span>"},"ja470:10.4":{"pli":"nekāsī labhate sukhaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja470:11.1":{"pli":"“Baḷisañhi so nigilati, ","html":"<p><span class='verse-line'>{}</span>"},"ja470:11.2":{"pli":"dīghasuttaṁ sabandhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja470:11.3":{"pli":"Atithismiṁ yo nisinnasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja470:11.4":{"pli":"eko bhuñjati bhojanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja470:12.1":{"pli":"Taṁ taṁ vadāmi kosiya, ","html":"<p><span class='verse-line'>{}</span>"},"ja470:12.2":{"pli":"dehi dānāni bhuñja ca; ","html":"<span class='verse-line'>{}</span>"},"ja470:12.3":{"pli":"Ariyamaggaṁ samārūha, ","html":"<span class='verse-line'>{}</span>"},"ja470:12.4":{"pli":"nekāsī labhate sukhaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja470:13.1":{"pli":"“Uḷāravaṇṇā vata brāhmaṇā ime, ","html":"<p><span class='verse-line'>{}</span>"},"ja470:13.2":{"pli":"Ayañca vo sunakho kissa hetu; ","html":"<span class='verse-line'>{}</span>"},"ja470:13.3":{"pli":"Uccāvacaṁ vaṇṇanibhaṁ vikubbati, ","html":"<span class='verse-line'>{}</span>"},"ja470:13.4":{"pli":"Akkhātha no brāhmaṇā ke nu tumhe”. ","html":"<span class='verse-line'>{}</span></p>"},"ja470:14.1":{"pli":"“Cando ca suriyo ca ubho idhāgatā, ","html":"<p><span class='verse-line'>{}</span>"},"ja470:14.2":{"pli":"Ayaṁ pana mātali devasārathi; ","html":"<span class='verse-line'>{}</span>"},"ja470:14.3":{"pli":"Sakkohamasmi tidasānamindo, ","html":"<span class='verse-line'>{}</span>"},"ja470:14.4":{"pli":"Eso ca kho pañcasikhoti vuccati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja470:15.1":{"pli":"“Pāṇissarā mudiṅgā ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja470:15.2":{"pli":"murajālambarāni ca; ","html":"<span class='verse-line'>{}</span>"},"ja470:15.3":{"pli":"Suttamenaṁ pabodhenti, ","html":"<span class='verse-line'>{}</span>"},"ja470:15.4":{"pli":"paṭibuddho ca nandati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja470:16.1":{"pli":"“Ye kecime maccharino kadariyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja470:16.2":{"pli":"Paribhāsakā samaṇabrāhmaṇānaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja470:16.3":{"pli":"Idheva nikkhippa sarīradehaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja470:16.4":{"pli":"Kāyassa bhedā nirayaṁ vajanti”. ","html":"<span class='verse-line'>{}</span></p>"},"ja470:17.1":{"pli":"“Ye kecime suggatimāsamānā, ","html":"<p><span class='verse-line'>{}</span>"},"ja470:17.2":{"pli":"Dhamme ṭhitā saṁyame saṁvibhāge; ","html":"<span class='verse-line'>{}</span>"},"ja470:17.3":{"pli":"Idheva nikkhippa sarīradehaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja470:17.4":{"pli":"Kāyassa bhedā sugatiṁ vajanti. ","html":"<span class='verse-line'>{}</span></p>"},"ja470:18.1":{"pli":"Tvaṁ nosi ñāti purimāsu jātisu, ","html":"<p><span class='verse-line'>{}</span>"},"ja470:18.2":{"pli":"So maccharī rosako pāpadhammo; ","html":"<span class='verse-line'>{}</span>"},"ja470:18.3":{"pli":"Taveva atthāya idhāgatamhā, ","html":"<span class='verse-line'>{}</span>"},"ja470:18.4":{"pli":"Mā pāpadhammo nirayaṁ gamittha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja470:19.1":{"pli":"“Addhā hi maṁ vo hitakāmā, ","html":"<p><span class='verse-line'>{}</span>"},"ja470:19.2":{"pli":"yaṁ maṁ samanusāsatha; ","html":"<span class='verse-line'>{}</span>"},"ja470:19.3":{"pli":"Sohaṁ tathā karissāmi, ","html":"<span class='verse-line'>{}</span>"},"ja470:19.4":{"pli":"sabbaṁ vuttaṁ hitesibhi. ","html":"<span class='verse-line'>{}</span></p>"},"ja470:20.1":{"pli":"Esāhamajjeva upāramāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja470:20.2":{"pli":"Na cāpihaṁ kiñci kareyya pāpaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja470:20.3":{"pli":"Na cāpi me kiñci adeyyamatthi, ","html":"<span class='verse-line'>{}</span>"},"ja470:20.4":{"pli":"Na cāpidatvā udakaṁ pivāmi. ","html":"<span class='verse-line'>{}</span></p>"},"ja470:21.1":{"pli":"Evañca me dadato sabbakālaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja470:21.2":{"pli":"Bhogā ime vāsava khīyissanti; ","html":"<span class='verse-line'>{}</span>"},"ja470:21.3":{"pli":"Tato ahaṁ pabbajissāmi sakka, ","html":"<span class='verse-line'>{}</span>"},"ja470:21.4":{"pli":"Hitvāna kāmāni yathodhikānī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja470:22.1":{"pli":"Kosiyajātakaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja471":{"ja471:0.1":{"pli":"Jātaka ","html":"<article id='ja471'><header><ul><li class='division'>{}</li>"},"ja471:0.2":{"pli":"Dvādasakanipāta ","html":"<li>{}</li>"},"ja471:0.3":{"pli":"Cūḷakuṇālavagga ","html":"<li>{}</li></ul>"},"ja471:0.4":{"pli":"8. Meṇḍakapañhajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja471:1.1":{"pli":"“Yesaṁ na kadāci bhūtapubbaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja471:1.2":{"pli":"Sakhyaṁ sattapadampimasmi loke; ","html":"<span class='verse-line'>{}</span>"},"ja471:1.3":{"pli":"Jātā amittā duve sahāyā, ","html":"<span class='verse-line'>{}</span>"},"ja471:1.4":{"pli":"Paṭisandhāya caranti kissa hetu”. ","html":"<span class='verse-line'>{}</span></p>"},"ja471:2.1":{"pli":"“Yadi me ajja pātarāsakāle, ","html":"<p><span class='verse-line'>{}</span>"},"ja471:2.2":{"pli":"Pañhaṁ na sakkuṇeyyātha vattumetaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja471:2.3":{"pli":"Raṭṭhā pabbājayissāmi vo sabbe, ","html":"<span class='verse-line'>{}</span>"},"ja471:2.4":{"pli":"Na hi mattho duppaññajātikehi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja471:3.1":{"pli":"“Mahājanasamāgamamhi ghore, ","html":"<p><span class='verse-line'>{}</span>"},"ja471:3.2":{"pli":"Janakolāhalasaṅgamamhi jāte; ","html":"<span class='verse-line'>{}</span>"},"ja471:3.3":{"pli":"Vikkhittamanā anekacittā, ","html":"<span class='verse-line'>{}</span>"},"ja471:3.4":{"pli":"Pañhaṁ na sakkuṇoma vattumetaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja471:4.1":{"pli":"Ekaggacittāva ekamekā, ","html":"<p><span class='verse-line'>{}</span>"},"ja471:4.2":{"pli":"Rahasi gatā atthaṁ nicintayitvā; ","html":"<span class='verse-line'>{}</span>"},"ja471:4.3":{"pli":"Paviveke sammasitvāna dhīrā, ","html":"<span class='verse-line'>{}</span>"},"ja471:4.4":{"pli":"Atha vakkhanti janinda etamatthaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja471:5.1":{"pli":"“Uggaputtarājaputtiyānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja471:5.2":{"pli":"Urabbhassa maṁsaṁ piyaṁ manāpaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja471:5.3":{"pli":"Na sunakhassa te adenti maṁsaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja471:5.4":{"pli":"Atha meṇḍassa suṇena sakhyamassa”. ","html":"<span class='verse-line'>{}</span></p>"},"ja471:6.1":{"pli":"“Cammaṁ vihananti eḷakassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja471:6.2":{"pli":"Assapiṭṭhattharassukhassa hetu; ","html":"<span class='verse-line'>{}</span>"},"ja471:6.3":{"pli":"Na ca te sunakhassa attharanti, ","html":"<span class='verse-line'>{}</span>"},"ja471:6.4":{"pli":"Atha meṇḍassa suṇena sakhyamassa”. ","html":"<span class='verse-line'>{}</span></p>"},"ja471:7.1":{"pli":"“Āvellitasiṅgiko hi meṇḍo, ","html":"<p><span class='verse-line'>{}</span>"},"ja471:7.2":{"pli":"Na ca sunakhassa visāṇakāni atthi; ","html":"<span class='verse-line'>{}</span>"},"ja471:7.3":{"pli":"Tiṇabhakkho maṁsabhojano ca, ","html":"<span class='verse-line'>{}</span>"},"ja471:7.4":{"pli":"Atha meṇḍassa suṇena sakhyamassa”. ","html":"<span class='verse-line'>{}</span></p>"},"ja471:8.1":{"pli":"“Tiṇamāsi palāsamāsi meṇḍo, ","html":"<p><span class='verse-line'>{}</span>"},"ja471:8.2":{"pli":"Na ca sunakho tiṇamāsi no palāsaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja471:8.3":{"pli":"Gaṇheyya suṇo sasaṁ biḷāraṁ, ","html":"<span class='verse-line'>{}</span>"},"ja471:8.4":{"pli":"Atha meṇḍassa suṇena sakhyamassa”. ","html":"<span class='verse-line'>{}</span></p>"},"ja471:9.1":{"pli":"“Aṭṭhaḍḍhapado catuppadassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja471:9.2":{"pli":"Meṇḍo aṭṭhanakho adissamāno; ","html":"<span class='verse-line'>{}</span>"},"ja471:9.3":{"pli":"Chādiyamāharatī ayaṁ imassa, ","html":"<span class='verse-line'>{}</span>"},"ja471:9.4":{"pli":"Maṁsaṁ āharatī ayaṁ amussa. ","html":"<span class='verse-line'>{}</span></p>"},"ja471:10.1":{"pli":"Pāsādavaragato videhaseṭṭho, ","html":"<p><span class='verse-line'>{}</span>"},"ja471:10.2":{"pli":"Vitihāraṁ aññamaññabhojanānaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja471:10.3":{"pli":"Addakkhi kira sakkhikaṁ janindo, ","html":"<span class='verse-line'>{}</span>"},"ja471:10.4":{"pli":"Bubhukkassa puṇṇaṁmukhassa cetaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja471:11.1":{"pli":"“Lābhā vata me anapparūpā, ","html":"<p><span class='verse-line'>{}</span>"},"ja471:11.2":{"pli":"Yassa medisā paṇḍitā kulamhi; ","html":"<span class='verse-line'>{}</span>"},"ja471:11.3":{"pli":"Pañhassa gambhīragataṁ nipuṇamatthaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja471:11.4":{"pli":"Paṭivijjhanti subhāsitena dhīrā. ","html":"<span class='verse-line'>{}</span></p>"},"ja471:12.1":{"pli":"Assatarirathañca ekamekaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja471:12.2":{"pli":"Phītaṁ gāmavarañca ekamekaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja471:12.3":{"pli":"Sabbesaṁ vo dammi paṇḍitānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja471:12.4":{"pli":"Paramappatītamano subhāsitenā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja471:13.1":{"pli":"Meṇḍakapañhajātakaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja472":{"ja472:0.1":{"pli":"Jātaka ","html":"<article id='ja472'><header><ul><li class='division'>{}</li>"},"ja472:0.2":{"pli":"Dvādasakanipāta ","html":"<li>{}</li>"},"ja472:0.3":{"pli":"Cūḷakuṇālavagga ","html":"<li>{}</li></ul>"},"ja472:0.4":{"pli":"9. Mahāpadumajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja472:1.1":{"pli":"“Nādaṭṭhā parato dosaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja472:1.2":{"pli":"aṇuṁthūlāni sabbaso; ","html":"<span class='verse-line'>{}</span>"},"ja472:1.3":{"pli":"Issaro paṇaye daṇḍaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja472:1.4":{"pli":"sāmaṁ appaṭivekkhiya. ","html":"<span class='verse-line'>{}</span></p>"},"ja472:2.1":{"pli":"Yo ca appaṭivekkhitvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja472:2.2":{"pli":"daṇḍaṁ kubbati khattiyo; ","html":"<span class='verse-line'>{}</span>"},"ja472:2.3":{"pli":"Sakaṇṭakaṁ so gilati, ","html":"<span class='verse-line'>{}</span>"},"ja472:2.4":{"pli":"jaccandhova samakkhikaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja472:3.1":{"pli":"Adaṇḍiyaṁ daṇḍayati, ","html":"<p><span class='verse-line'>{}</span>"},"ja472:3.2":{"pli":"daṇḍiyañca adaṇḍiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja472:3.3":{"pli":"Andhova visamaṁ maggaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja472:3.4":{"pli":"na jānāti samāsamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja472:4.1":{"pli":"Yo ca etāni ṭhānāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja472:4.2":{"pli":"Aṇuṁthūlāni sabbaso; ","html":"<span class='verse-line'>{}</span>"},"ja472:4.3":{"pli":"Sudiṭṭhamanusāseyya, ","html":"<span class='verse-line'>{}</span>"},"ja472:4.4":{"pli":"Sa ve voharitumarahati. ","html":"<span class='verse-line'>{}</span></p>"},"ja472:5.1":{"pli":"Nekantamudunā sakkā, ","html":"<p><span class='verse-line'>{}</span>"},"ja472:5.2":{"pli":"Ekantatikhiṇena vā; ","html":"<span class='verse-line'>{}</span>"},"ja472:5.3":{"pli":"Attaṁ mahante ṭhapetuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja472:5.4":{"pli":"Tasmā ubhayamācare. ","html":"<span class='verse-line'>{}</span></p>"},"ja472:6.1":{"pli":"Paribhūto mudu hoti, ","html":"<p><span class='verse-line'>{}</span>"},"ja472:6.2":{"pli":"atitikkho ca veravā; ","html":"<span class='verse-line'>{}</span>"},"ja472:6.3":{"pli":"Etañca ubhayaṁ ñatvā, ","html":"<span class='verse-line'>{}</span>"},"ja472:6.4":{"pli":"anumajjhaṁ samācare. ","html":"<span class='verse-line'>{}</span></p>"},"ja472:7.1":{"pli":"Bahumpi ratto bhāseyya, ","html":"<p><span class='verse-line'>{}</span>"},"ja472:7.2":{"pli":"duṭṭhopi bahu bhāsati; ","html":"<span class='verse-line'>{}</span>"},"ja472:7.3":{"pli":"Na itthikāraṇā rāja, ","html":"<span class='verse-line'>{}</span>"},"ja472:7.4":{"pli":"puttaṁ ghātetumarahasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja472:8.1":{"pli":"“Sabbova loko ekato, ","html":"<p><span class='verse-line'>{}</span>"},"ja472:8.2":{"pli":"Itthī ca ayamekikā; ","html":"<span class='verse-line'>{}</span>"},"ja472:8.3":{"pli":"Tenāhaṁ paṭipajjissaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja472:8.4":{"pli":"Gacchatha pakkhipatheva taṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja472:9.1":{"pli":"“Anekatāle narake, ","html":"<p><span class='verse-line'>{}</span>"},"ja472:9.2":{"pli":"gambhīre ca suduttare; ","html":"<span class='verse-line'>{}</span>"},"ja472:9.3":{"pli":"Pātito giriduggasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja472:9.4":{"pli":"kena tvaṁ tattha nāmari”. ","html":"<span class='verse-line'>{}</span></p>"},"ja472:10.1":{"pli":"“Nāgo jātaphaṇo tattha, ","html":"<p><span class='verse-line'>{}</span>"},"ja472:10.2":{"pli":"thāmavā girisānujo; ","html":"<span class='verse-line'>{}</span>"},"ja472:10.3":{"pli":"Paccaggahi maṁ bhogehi, ","html":"<span class='verse-line'>{}</span>"},"ja472:10.4":{"pli":"tenāhaṁ tattha nāmariṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja472:11.1":{"pli":"“Ehi taṁ paṭinessāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja472:11.2":{"pli":"rājaputta sakaṁ gharaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja472:11.3":{"pli":"Rajjaṁ kārehi bhaddante, ","html":"<span class='verse-line'>{}</span>"},"ja472:11.4":{"pli":"kiṁ araññe karissasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja472:12.1":{"pli":"“Yathā gilitvā baḷisaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja472:12.2":{"pli":"Uddhareyya salohitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja472:12.3":{"pli":"Uddharitvā sukhī assa, ","html":"<span class='verse-line'>{}</span>"},"ja472:12.4":{"pli":"Evaṁ passāmi attanaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja472:13.1":{"pli":"“Kiṁ nu tvaṁ baḷisaṁ brūsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja472:13.2":{"pli":"kiṁ tvaṁ brūsi salohitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja472:13.3":{"pli":"Kiṁ nu tvaṁ ubbhataṁ brūsi, ","html":"<span class='verse-line'>{}</span>"},"ja472:13.4":{"pli":"taṁ me akkhāhi pucchito”. ","html":"<span class='verse-line'>{}</span></p>"},"ja472:14.1":{"pli":"“Kāmāhaṁ baḷisaṁ brūmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja472:14.2":{"pli":"hatthiassaṁ salohitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja472:14.3":{"pli":"Cattāhaṁ ubbhataṁ brūmi, ","html":"<span class='verse-line'>{}</span>"},"ja472:14.4":{"pli":"evaṁ jānāhi khattiya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja472:15.1":{"pli":"“Ciñcamāṇavikā mātā, ","html":"<p><span class='verse-line'>{}</span>"},"ja472:15.2":{"pli":"devadatto ca me pitā; ","html":"<span class='verse-line'>{}</span>"},"ja472:15.3":{"pli":"Ānando paṇḍito nāgo, ","html":"<span class='verse-line'>{}</span>"},"ja472:15.4":{"pli":"sāriputto ca devatā; ","html":"<span class='verse-line'>{}</span>"},"ja472:15.5":{"pli":"Rājaputto ahaṁ āsiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja472:15.6":{"pli":"evaṁ dhāretha jātakan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja472:16.1":{"pli":"Mahāpadumajātakaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja473":{"ja473:0.1":{"pli":"Jātaka ","html":"<article id='ja473'><header><ul><li class='division'>{}</li>"},"ja473:0.2":{"pli":"Dvādasakanipāta ","html":"<li>{}</li>"},"ja473:0.3":{"pli":"Cūḷakuṇālavagga ","html":"<li>{}</li></ul>"},"ja473:0.4":{"pli":"10. Mittāmittajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja473:1.1":{"pli":"“Kāni kammāni kubbānaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja473:1.2":{"pli":"kathaṁ viññū parakkame; ","html":"<span class='verse-line'>{}</span>"},"ja473:1.3":{"pli":"Amittaṁ jāneyya medhāvī, ","html":"<span class='verse-line'>{}</span>"},"ja473:1.4":{"pli":"disvā sutvā ca paṇḍito”. ","html":"<span class='verse-line'>{}</span></p>"},"ja473:2.1":{"pli":"“Na naṁ umhayate disvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja473:2.2":{"pli":"na ca naṁ paṭinandati; ","html":"<span class='verse-line'>{}</span>"},"ja473:2.3":{"pli":"Cakkhūni cassa na dadāti, ","html":"<span class='verse-line'>{}</span>"},"ja473:2.4":{"pli":"paṭilomañca vattati. ","html":"<span class='verse-line'>{}</span></p>"},"ja473:3.1":{"pli":"Amitte tassa bhajati, ","html":"<p><span class='verse-line'>{}</span>"},"ja473:3.2":{"pli":"mitte tassa na sevati; ","html":"<span class='verse-line'>{}</span>"},"ja473:3.3":{"pli":"Vaṇṇakāme nivāreti, ","html":"<span class='verse-line'>{}</span>"},"ja473:3.4":{"pli":"akkosante pasaṁsati. ","html":"<span class='verse-line'>{}</span></p>"},"ja473:4.1":{"pli":"Guyhañca tassa nakkhāti, ","html":"<p><span class='verse-line'>{}</span>"},"ja473:4.2":{"pli":"tassa guyhaṁ na gūhati; ","html":"<span class='verse-line'>{}</span>"},"ja473:4.3":{"pli":"Kammaṁ tassa na vaṇṇeti, ","html":"<span class='verse-line'>{}</span>"},"ja473:4.4":{"pli":"paññassa nappasaṁsati. ","html":"<span class='verse-line'>{}</span></p>"},"ja473:5.1":{"pli":"Abhave nandati tassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja473:5.2":{"pli":"bhave tassa na nandati; ","html":"<span class='verse-line'>{}</span>"},"ja473:5.3":{"pli":"Accheraṁ bhojanaṁ laddhā, ","html":"<span class='verse-line'>{}</span>"},"ja473:5.4":{"pli":"tassa nuppajjate sati; ","html":"<span class='verse-line'>{}</span>"},"ja473:5.5":{"pli":"Tato naṁ nānukampati, ","html":"<span class='verse-line'>{}</span>"},"ja473:5.6":{"pli":"aho sopi labheyyito. ","html":"<span class='verse-line'>{}</span></p>"},"ja473:6.1":{"pli":"Iccete soḷasākārā, ","html":"<p><span class='verse-line'>{}</span>"},"ja473:6.2":{"pli":"amittasmiṁ patiṭṭhitā; ","html":"<span class='verse-line'>{}</span>"},"ja473:6.3":{"pli":"Yehi amittaṁ jāneyya, ","html":"<span class='verse-line'>{}</span>"},"ja473:6.4":{"pli":"disvā sutvā ca paṇḍito”. ","html":"<span class='verse-line'>{}</span></p>"},"ja473:7.1":{"pli":"“Kāni kammāni kubbānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja473:7.2":{"pli":"kathaṁ viññū parakkame; ","html":"<span class='verse-line'>{}</span>"},"ja473:7.3":{"pli":"Mittaṁ jāneyya medhāvī, ","html":"<span class='verse-line'>{}</span>"},"ja473:7.4":{"pli":"disvā sutvā ca paṇḍito. ","html":"<span class='verse-line'>{}</span></p>"},"ja473:8.1":{"pli":"Pavutthaṁ tassa sarati, ","html":"<p><span class='verse-line'>{}</span>"},"ja473:8.2":{"pli":"āgataṁ abhinandati; ","html":"<span class='verse-line'>{}</span>"},"ja473:8.3":{"pli":"Tato kelāyito hoti, ","html":"<span class='verse-line'>{}</span>"},"ja473:8.4":{"pli":"vācāya paṭinandati. ","html":"<span class='verse-line'>{}</span></p>"},"ja473:9.1":{"pli":"Mitte tasseva bhajati, ","html":"<p><span class='verse-line'>{}</span>"},"ja473:9.2":{"pli":"amitte tassa na sevati; ","html":"<span class='verse-line'>{}</span>"},"ja473:9.3":{"pli":"Akkosante nivāreti, ","html":"<span class='verse-line'>{}</span>"},"ja473:9.4":{"pli":"vaṇṇakāme pasaṁsati. ","html":"<span class='verse-line'>{}</span></p>"},"ja473:10.1":{"pli":"Guyhañca tassa akkhāti, ","html":"<p><span class='verse-line'>{}</span>"},"ja473:10.2":{"pli":"tassa guyhañca gūhati; ","html":"<span class='verse-line'>{}</span>"},"ja473:10.3":{"pli":"Kammañca tassa vaṇṇeti, ","html":"<span class='verse-line'>{}</span>"},"ja473:10.4":{"pli":"paññaṁ tassa pasaṁsati. ","html":"<span class='verse-line'>{}</span></p>"},"ja473:11.1":{"pli":"Bhave ca nandati tassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja473:11.2":{"pli":"abhave tassa na nandati; ","html":"<span class='verse-line'>{}</span>"},"ja473:11.3":{"pli":"Accheraṁ bhojanaṁ laddhā, ","html":"<span class='verse-line'>{}</span>"},"ja473:11.4":{"pli":"tassa uppajjate sati; ","html":"<span class='verse-line'>{}</span>"},"ja473:11.5":{"pli":"Tato naṁ anukampati, ","html":"<span class='verse-line'>{}</span>"},"ja473:11.6":{"pli":"aho sopi labheyyito. ","html":"<span class='verse-line'>{}</span></p>"},"ja473:12.1":{"pli":"Iccete soḷasākārā, ","html":"<p><span class='verse-line'>{}</span>"},"ja473:12.2":{"pli":"Mittasmiṁ suppatiṭṭhitā; ","html":"<span class='verse-line'>{}</span>"},"ja473:12.3":{"pli":"Yehi mittañca jāneyya, ","html":"<span class='verse-line'>{}</span>"},"ja473:12.4":{"pli":"Disvā sutvā ca paṇḍito”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja473:13.1":{"pli":"Mittāmittajātakaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja473:14.1":{"pli":"Dvādasakanipātaṁ niṭṭhitaṁ. ","html":"<p class='endsection'>{}</p>"},"ja473:15.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja473:16.1":{"pli":"Lahucitta sasāla kasanti puna, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja473:16.2":{"pli":"Atha kāma dasakhaluṭṭhānavaro; ","html":"<span class='verse-line'>{}</span>"},"ja473:16.3":{"pli":"Atha kaṇha sukosiya meṇḍavaro, ","html":"<span class='verse-line'>{}</span>"},"ja473:16.4":{"pli":"Padumo puna mittavarena dasāti. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"ja474":{"ja474:0.1":{"pli":"Jātaka ","html":"<article id='ja474'><header><ul><li class='division'>{}</li>"},"ja474:0.2":{"pli":"Terasakanipāta ","html":"<li>{}</li>"},"ja474:0.3":{"pli":"Ambavagga ","html":"<li>{}</li></ul>"},"ja474:0.4":{"pli":"1. Ambajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja474:1.1":{"pli":"“Ahāsi me ambaphalāni pubbe, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja474:1.2":{"pli":"Aṇūni thūlāni ca brahmacāri; ","html":"<span class='verse-line'>{}</span>"},"ja474:1.3":{"pli":"Teheva mantehi na dāni tuyhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja474:1.4":{"pli":"Dumapphalā pātubhavanti brahme”. ","html":"<span class='verse-line'>{}</span></p>"},"ja474:2.1":{"pli":"“Nakkhattayogaṁ paṭimānayāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja474:2.2":{"pli":"Khaṇaṁ muhuttañca mante na passaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja474:2.3":{"pli":"Nakkhattayogañca khaṇañca laddhā, ","html":"<span class='verse-line'>{}</span>"},"ja474:2.4":{"pli":"Addhāharissambaphalaṁ pahūtaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja474:3.1":{"pli":"“Nakkhattayogaṁ na pure abhāṇi, ","html":"<p><span class='verse-line'>{}</span>"},"ja474:3.2":{"pli":"Khaṇaṁ muhuttaṁ na pure asaṁsi; ","html":"<span class='verse-line'>{}</span>"},"ja474:3.3":{"pli":"Sayaṁ harī ambaphalaṁ pahūtaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja474:3.4":{"pli":"Vaṇṇena gandhena rasenupetaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja474:4.1":{"pli":"Mantābhijappena pure hi tuyhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja474:4.2":{"pli":"Dumapphalā pātubhavanti brahme; ","html":"<span class='verse-line'>{}</span>"},"ja474:4.3":{"pli":"Svājja na pāresi jappampi mantaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja474:4.4":{"pli":"Ayaṁ so ko nāma tavajja dhammo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja474:5.1":{"pli":"“Caṇḍālaputto mama sampadāsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja474:5.2":{"pli":"Dhammena mante pakatiñca saṁsi; ","html":"<span class='verse-line'>{}</span>"},"ja474:5.3":{"pli":"Mā cassu me pucchito nāmagottaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja474:5.4":{"pli":"Guyhittho atthaṁ vijaheyya manto. ","html":"<span class='verse-line'>{}</span></p>"},"ja474:6.1":{"pli":"Sohaṁ janindena janamhi puṭṭho, ","html":"<p><span class='verse-line'>{}</span>"},"ja474:6.2":{"pli":"Makkhābhibhūto alikaṁ abhāṇiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja474:6.3":{"pli":"‘Mantā ime brāhmaṇassā’ti micchā, ","html":"<span class='verse-line'>{}</span>"},"ja474:6.4":{"pli":"Pahīnamanto kapaṇo rudāmi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja474:7.1":{"pli":"“Eraṇḍā pucimandā vā, ","html":"<p><span class='verse-line'>{}</span>"},"ja474:7.2":{"pli":"atha vā pālibhaddakā; ","html":"<span class='verse-line'>{}</span>"},"ja474:7.3":{"pli":"Madhuṁ madhutthiko vinde, ","html":"<span class='verse-line'>{}</span>"},"ja474:7.4":{"pli":"so hi tassa dumuttamo. ","html":"<span class='verse-line'>{}</span></p>"},"ja474:8.1":{"pli":"Khattiyā brāhmaṇā vessā, ","html":"<p><span class='verse-line'>{}</span>"},"ja474:8.2":{"pli":"suddā caṇḍālapukkusā; ","html":"<span class='verse-line'>{}</span>"},"ja474:8.3":{"pli":"Yamhā dhammaṁ vijāneyya, ","html":"<span class='verse-line'>{}</span>"},"ja474:8.4":{"pli":"so hi tassa naruttamo. ","html":"<span class='verse-line'>{}</span></p>"},"ja474:9.1":{"pli":"Imassa daṇḍañca vadhañca datvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja474:9.2":{"pli":"Gale gahetvā khalayātha jammaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja474:9.3":{"pli":"Yo uttamatthaṁ kasirena laddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja474:9.4":{"pli":"Mānātimānena vināsayittha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja474:10.1":{"pli":"“Yathā samaṁ maññamāno pateyya, ","html":"<p><span class='verse-line'>{}</span>"},"ja474:10.2":{"pli":"Sobbhaṁ guhaṁ narakaṁ pūtipādaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja474:10.3":{"pli":"Rajjūti vā akkame kaṇhasappaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja474:10.4":{"pli":"Andho yathā jotimadhiṭṭhaheyya; ","html":"<span class='verse-line'>{}</span>"},"ja474:10.5":{"pli":"Evampi maṁ tvaṁ khalitaṁ sapañña, ","html":"<span class='verse-line'>{}</span>"},"ja474:10.6":{"pli":"Pahīnamantassa punappadāhi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja474:11.1":{"pli":"“Dhammena mantaṁ tava sampadāsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja474:11.2":{"pli":"Tuvampi dhammena pariggahesi; ","html":"<span class='verse-line'>{}</span>"},"ja474:11.3":{"pli":"Pakatimpi te attamano asaṁsiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja474:11.4":{"pli":"Dhamme ṭhitaṁ taṁ na jaheyya manto. ","html":"<span class='verse-line'>{}</span></p>"},"ja474:12.1":{"pli":"Yo bāla mantaṁ kasirena laddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja474:12.2":{"pli":"Yaṁ dullabhaṁ ajja manussaloke; ","html":"<span class='verse-line'>{}</span>"},"ja474:12.3":{"pli":"Kiñcāpi laddhā jīvituṁ appapañño, ","html":"<span class='verse-line'>{}</span>"},"ja474:12.4":{"pli":"Vināsayī alikaṁ bhāsamāno. ","html":"<span class='verse-line'>{}</span></p>"},"ja474:13.1":{"pli":"Bālassa mūḷhassa akataññuno ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja474:13.2":{"pli":"Musā bhaṇantassa asaññatassa; ","html":"<span class='verse-line'>{}</span>"},"ja474:13.3":{"pli":"Mante mayaṁ tādisake na dema, ","html":"<span class='verse-line'>{}</span>"},"ja474:13.4":{"pli":"Kuto mantā gaccha na mayha ruccasī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja474:14.1":{"pli":"Ambajātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja475":{"ja475:0.1":{"pli":"Jātaka ","html":"<article id='ja475'><header><ul><li class='division'>{}</li>"},"ja475:0.2":{"pli":"Terasakanipāta ","html":"<li>{}</li>"},"ja475:0.3":{"pli":"Ambavagga ","html":"<li>{}</li></ul>"},"ja475:0.4":{"pli":"2. Phandanajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja475:1.1":{"pli":"“Kuṭhārihattho puriso, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja475:1.2":{"pli":"vanamogayha tiṭṭhasi; ","html":"<span class='verse-line'>{}</span>"},"ja475:1.3":{"pli":"Puṭṭho me samma akkhāhi, ","html":"<span class='verse-line'>{}</span>"},"ja475:1.4":{"pli":"kiṁ dāruṁ chetumicchasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja475:2.1":{"pli":"“Isso vanāni carasi, ","html":"<p><span class='verse-line'>{}</span>"},"ja475:2.2":{"pli":"samāni visamāni ca; ","html":"<span class='verse-line'>{}</span>"},"ja475:2.3":{"pli":"Puṭṭho me samma akkhāhi, ","html":"<span class='verse-line'>{}</span>"},"ja475:2.4":{"pli":"kiṁ dāruṁ nemiyā daḷhaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja475:3.1":{"pli":"“Neva sālo na khadiro, ","html":"<p><span class='verse-line'>{}</span>"},"ja475:3.2":{"pli":"nāssakaṇṇo kuto dhavo; ","html":"<span class='verse-line'>{}</span>"},"ja475:3.3":{"pli":"Rukkho ca phandano nāma, ","html":"<span class='verse-line'>{}</span>"},"ja475:3.4":{"pli":"taṁ dāruṁ nemiyā daḷhaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja475:4.1":{"pli":"“Kīdisānissa pattāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja475:4.2":{"pli":"khandho vā pana kīdiso; ","html":"<span class='verse-line'>{}</span>"},"ja475:4.3":{"pli":"Puṭṭho me samma akkhāhi, ","html":"<span class='verse-line'>{}</span>"},"ja475:4.4":{"pli":"yathā jānemu phandanaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja475:5.1":{"pli":"“Yassa sākhā palambanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja475:5.2":{"pli":"namanti na ca bhañjare; ","html":"<span class='verse-line'>{}</span>"},"ja475:5.3":{"pli":"So rukkho phandano nāma, ","html":"<span class='verse-line'>{}</span>"},"ja475:5.4":{"pli":"yassa mūle ahaṁ ṭhito. ","html":"<span class='verse-line'>{}</span></p>"},"ja475:6.1":{"pli":"Arānaṁ cakkanābhīnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja475:6.2":{"pli":"īsānemirathassa ca; ","html":"<span class='verse-line'>{}</span>"},"ja475:6.3":{"pli":"Sabbassa te kammaniyo, ","html":"<span class='verse-line'>{}</span>"},"ja475:6.4":{"pli":"ayaṁ hessati phandano”. ","html":"<span class='verse-line'>{}</span></p>"},"ja475:7.1":{"pli":"“Iti phandanarukkhopi, ","html":"<p><span class='verse-line'>{}</span>"},"ja475:7.2":{"pli":"tāvade ajjhabhāsatha; ","html":"<span class='verse-line'>{}</span>"},"ja475:7.3":{"pli":"Mayhampi vacanaṁ atthi, ","html":"<span class='verse-line'>{}</span>"},"ja475:7.4":{"pli":"bhāradvāja suṇohi me. ","html":"<span class='verse-line'>{}</span></p>"},"ja475:8.1":{"pli":"Issassa upakkhandhamhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja475:8.2":{"pli":"Ukkacca caturaṅgulaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja475:8.3":{"pli":"Tena nemiṁ pasāresi, ","html":"<span class='verse-line'>{}</span>"},"ja475:8.4":{"pli":"Evaṁ daḷhataraṁ siyā. ","html":"<span class='verse-line'>{}</span></p>"},"ja475:9.1":{"pli":"Iti phandanarukkhopi, ","html":"<p><span class='verse-line'>{}</span>"},"ja475:9.2":{"pli":"veraṁ appesi tāvade; ","html":"<span class='verse-line'>{}</span>"},"ja475:9.3":{"pli":"Jātānañca ajātānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja475:9.4":{"pli":"issānaṁ dukkhamāvahi. ","html":"<span class='verse-line'>{}</span></p>"},"ja475:10.1":{"pli":"Iccevaṁ phandano issaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja475:10.2":{"pli":"isso ca pana phandanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja475:10.3":{"pli":"Aññamaññaṁ vivādena, ","html":"<span class='verse-line'>{}</span>"},"ja475:10.4":{"pli":"aññamaññamaghātayuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja475:11.1":{"pli":"Evameva manussānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja475:11.2":{"pli":"vivādo yattha jāyati; ","html":"<span class='verse-line'>{}</span>"},"ja475:11.3":{"pli":"Mayūranaccaṁ naccanti, ","html":"<span class='verse-line'>{}</span>"},"ja475:11.4":{"pli":"yathā te issaphandanā. ","html":"<span class='verse-line'>{}</span></p>"},"ja475:12.1":{"pli":"Taṁ vo vadāmi bhaddaṁ vo, ","html":"<p><span class='verse-line'>{}</span>"},"ja475:12.2":{"pli":"yāvantettha samāgatā; ","html":"<span class='verse-line'>{}</span>"},"ja475:12.3":{"pli":"Sammodatha mā vivadatha, ","html":"<span class='verse-line'>{}</span>"},"ja475:12.4":{"pli":"mā hotha issaphandanā. ","html":"<span class='verse-line'>{}</span></p>"},"ja475:13.1":{"pli":"Sāmaggimeva sikkhetha, ","html":"<p><span class='verse-line'>{}</span>"},"ja475:13.2":{"pli":"buddhehetaṁ pasaṁsitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja475:13.3":{"pli":"Sāmaggirato dhammaṭṭho, ","html":"<span class='verse-line'>{}</span>"},"ja475:13.4":{"pli":"yogakkhemā na dhaṁsatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja475:14.1":{"pli":"Phandanajātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja476":{"ja476:0.1":{"pli":"Jātaka ","html":"<article id='ja476'><header><ul><li class='division'>{}</li>"},"ja476:0.2":{"pli":"Terasakanipāta ","html":"<li>{}</li>"},"ja476:0.3":{"pli":"Ambavagga ","html":"<li>{}</li></ul>"},"ja476:0.4":{"pli":"3. Javanahaṁsajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja476:1.1":{"pli":"“Idheva haṁsa nipata, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja476:1.2":{"pli":"piyaṁ me tava dassanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja476:1.3":{"pli":"Issarosi anuppatto, ","html":"<span class='verse-line'>{}</span>"},"ja476:1.4":{"pli":"yamidhatthi pavedaya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja476:2.1":{"pli":"“Savanena ekassa piyā bhavanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja476:2.2":{"pli":"Disvā panekassa viyeti chando; ","html":"<span class='verse-line'>{}</span>"},"ja476:2.3":{"pli":"Disvā ca sutvā ca piyā bhavanti, ","html":"<span class='verse-line'>{}</span>"},"ja476:2.4":{"pli":"Kaccinnu me pīyasi dassanena. ","html":"<span class='verse-line'>{}</span></p>"},"ja476:3.1":{"pli":"Savanena piyo mesi, ","html":"<p><span class='verse-line'>{}</span>"},"ja476:3.2":{"pli":"bhiyyo cāgamma dassanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja476:3.3":{"pli":"Evaṁ piyadassano me, ","html":"<span class='verse-line'>{}</span>"},"ja476:3.4":{"pli":"vasa haṁsa mamantike”. ","html":"<span class='verse-line'>{}</span></p>"},"ja476:4.1":{"pli":"“Vaseyyāma tavāgāre, ","html":"<p><span class='verse-line'>{}</span>"},"ja476:4.2":{"pli":"niccaṁ sakkatapūjitā; ","html":"<span class='verse-line'>{}</span>"},"ja476:4.3":{"pli":"Matto ca ekadā vajje, ","html":"<span class='verse-line'>{}</span>"},"ja476:4.4":{"pli":"‘haṁsarājaṁ pacantu me’”. ","html":"<span class='verse-line'>{}</span></p>"},"ja476:5.1":{"pli":"“Dhiratthu taṁ majjapānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja476:5.2":{"pli":"yaṁ me piyataraṁ tayā; ","html":"<span class='verse-line'>{}</span>"},"ja476:5.3":{"pli":"Na cāpi majjaṁ pissāmi, ","html":"<span class='verse-line'>{}</span>"},"ja476:5.4":{"pli":"yāva me vacchasī ghare”. ","html":"<span class='verse-line'>{}</span></p>"},"ja476:6.1":{"pli":"“Suvijānaṁ siṅgālānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja476:6.2":{"pli":"sakuṇānañca vassitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja476:6.3":{"pli":"Manussavassitaṁ rāja, ","html":"<span class='verse-line'>{}</span>"},"ja476:6.4":{"pli":"dubbijānataraṁ tato. ","html":"<span class='verse-line'>{}</span></p>"},"ja476:7.1":{"pli":"Api ce maññatī poso, ","html":"<p><span class='verse-line'>{}</span>"},"ja476:7.2":{"pli":"ñāti mitto sakhāti vā; ","html":"<span class='verse-line'>{}</span>"},"ja476:7.3":{"pli":"Yo pubbe sumano hutvā, ","html":"<span class='verse-line'>{}</span>"},"ja476:7.4":{"pli":"pacchā sampajjate diso. ","html":"<span class='verse-line'>{}</span></p>"},"ja476:8.1":{"pli":"Yasmiṁ mano nivisati, ","html":"<p><span class='verse-line'>{}</span>"},"ja476:8.2":{"pli":"avidūre sahāpi so; ","html":"<span class='verse-line'>{}</span>"},"ja476:8.3":{"pli":"Santikepi hi so dūre, ","html":"<span class='verse-line'>{}</span>"},"ja476:8.4":{"pli":"yasmiṁ nāvisate mano. ","html":"<span class='verse-line'>{}</span></p>"},"ja476:9.1":{"pli":"Antopi so hoti pasannacitto, ","html":"<p><span class='verse-line'>{}</span>"},"ja476:9.2":{"pli":"Pāraṁ samuddassa pasannacitto; ","html":"<span class='verse-line'>{}</span>"},"ja476:9.3":{"pli":"Antopi so hoti paduṭṭhacitto, ","html":"<span class='verse-line'>{}</span>"},"ja476:9.4":{"pli":"Pāraṁ samuddassa paduṭṭhacitto. ","html":"<span class='verse-line'>{}</span></p>"},"ja476:10.1":{"pli":"Saṁvasantā vivasanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja476:10.2":{"pli":"ye disā te rathesabha; ","html":"<span class='verse-line'>{}</span>"},"ja476:10.3":{"pli":"Ārā santo saṁvasanti, ","html":"<span class='verse-line'>{}</span>"},"ja476:10.4":{"pli":"manasā raṭṭhavaḍḍhana. ","html":"<span class='verse-line'>{}</span></p>"},"ja476:11.1":{"pli":"Aticiraṁ nivāsena, ","html":"<p><span class='verse-line'>{}</span>"},"ja476:11.2":{"pli":"piyo bhavati appiyo; ","html":"<span class='verse-line'>{}</span>"},"ja476:11.3":{"pli":"Āmanta kho taṁ gacchāma, ","html":"<span class='verse-line'>{}</span>"},"ja476:11.4":{"pli":"purā te homa appiyā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja476:12.1":{"pli":"“Evañce yācamānānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja476:12.2":{"pli":"Añjaliṁ nāvabujjhasi; ","html":"<span class='verse-line'>{}</span>"},"ja476:12.3":{"pli":"Paricārakānaṁ sataṁ, ","html":"<span class='verse-line'>{}</span>"},"ja476:12.4":{"pli":"Vacanaṁ na karosi no; ","html":"<span class='verse-line'>{}</span>"},"ja476:12.5":{"pli":"Evaṁ taṁ abhiyācāma, ","html":"<span class='verse-line'>{}</span>"},"ja476:12.6":{"pli":"Puna kayirāsi pariyāyaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja476:13.1":{"pli":"“Evañce no viharataṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja476:13.2":{"pli":"antarāyo na hessati; ","html":"<span class='verse-line'>{}</span>"},"ja476:13.3":{"pli":"Tuyhañcāpi mahārāja, ","html":"<span class='verse-line'>{}</span>"},"ja476:13.4":{"pli":"mayhañca raṭṭhavaḍḍhana; ","html":"<span class='verse-line'>{}</span>"},"ja476:13.5":{"pli":"Appeva nāma passemu, ","html":"<span class='verse-line'>{}</span>"},"ja476:13.6":{"pli":"ahorattānamaccaye”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja476:14.1":{"pli":"Javanahaṁsajātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}