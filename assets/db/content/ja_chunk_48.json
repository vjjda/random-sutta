{"ja538":{"ja538:0.1":{"pli":"Jātaka ","html":"<article id='ja538'><header><ul><li class='division'>{}</li>"},"ja538:0.2":{"pli":"Mahānipāta ","html":"<li>{}</li>"},"ja538:0.3":{"pli":"Mūgapakkhavagga ","html":"<li>{}</li></ul>"},"ja538:0.4":{"pli":"1 Mūgapakkhajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja538:1.1":{"pli":"“Mā paṇḍiccayaṁ vibhāvaya, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja538:1.2":{"pli":"Bālamato bhava sabbapāṇinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:1.3":{"pli":"Sabbo taṁ jano ocināyatu, ","html":"<span class='verse-line'>{}</span>"},"ja538:1.4":{"pli":"Evaṁ tava attho bhavissati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:2.1":{"pli":"“Karomi te taṁ vacanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:2.2":{"pli":"yaṁ maṁ bhaṇasi devate; ","html":"<span class='verse-line'>{}</span>"},"ja538:2.3":{"pli":"Atthakāmāsi me amma, ","html":"<span class='verse-line'>{}</span>"},"ja538:2.4":{"pli":"hitakāmāsi devate”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:3.1":{"pli":"“Kiṁ nu santaramānova, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:3.2":{"pli":"kāsuṁ khaṇasi sārathi; ","html":"<span class='verse-line'>{}</span>"},"ja538:3.3":{"pli":"Puṭṭho me samma akkhāhi, ","html":"<span class='verse-line'>{}</span>"},"ja538:3.4":{"pli":"kiṁ kāsuyā karissasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:4.1":{"pli":"“Rañño mūgo ca pakkho ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:4.2":{"pli":"putto jāto acetaso; ","html":"<span class='verse-line'>{}</span>"},"ja538:4.3":{"pli":"Somhi raññā samajjhiṭṭho, ","html":"<span class='verse-line'>{}</span>"},"ja538:4.4":{"pli":"puttaṁ me nikhaṇaṁ vane”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:5.1":{"pli":"“Na badhiro na mūgosmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:5.2":{"pli":"na pakkho na ca vīkalo; ","html":"<span class='verse-line'>{}</span>"},"ja538:5.3":{"pli":"Adhammaṁ sārathi kayirā, ","html":"<span class='verse-line'>{}</span>"},"ja538:5.4":{"pli":"mañce tvaṁ nikhaṇaṁ vane. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:6.1":{"pli":"Ūrū bāhuñca me passa, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:6.2":{"pli":"bhāsitañca suṇohi me; ","html":"<span class='verse-line'>{}</span>"},"ja538:6.3":{"pli":"Adhammaṁ sārathi kayirā, ","html":"<span class='verse-line'>{}</span>"},"ja538:6.4":{"pli":"mañce tvaṁ nikhaṇaṁ vane”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:7.1":{"pli":"“Devatā nusi gandhabbo, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:7.2":{"pli":"adu sakko purindado; ","html":"<span class='verse-line'>{}</span>"},"ja538:7.3":{"pli":"Ko vā tvaṁ kassa vā putto, ","html":"<span class='verse-line'>{}</span>"},"ja538:7.4":{"pli":"kathaṁ jānemu taṁ mayaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:8.1":{"pli":"“Namhi devo na gandhabbo, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:8.2":{"pli":"nāpi sakko purindado; ","html":"<span class='verse-line'>{}</span>"},"ja538:8.3":{"pli":"Kāsirañño ahaṁ putto, ","html":"<span class='verse-line'>{}</span>"},"ja538:8.4":{"pli":"yaṁ kāsuyā nikhaññasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:9.1":{"pli":"Tassa rañño ahaṁ putto, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:9.2":{"pli":"yaṁ tvaṁ sammūpajīvasi; ","html":"<span class='verse-line'>{}</span>"},"ja538:9.3":{"pli":"Adhammaṁ sārathi kayirā, ","html":"<span class='verse-line'>{}</span>"},"ja538:9.4":{"pli":"mañce tvaṁ nikhaṇaṁ vane. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:10.1":{"pli":"Yassa rukkhassa chāyāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:10.2":{"pli":"nisīdeyya sayeyya vā; ","html":"<span class='verse-line'>{}</span>"},"ja538:10.3":{"pli":"Na tassa sākhaṁ bhañjeyya, ","html":"<span class='verse-line'>{}</span>"},"ja538:10.4":{"pli":"mittadubbho hi pāpako. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:11.1":{"pli":"Yathā rukkho tathā rājā, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:11.2":{"pli":"yathā sākhā tathā ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:11.3":{"pli":"Yathā chāyūpago poso, ","html":"<span class='verse-line'>{}</span>"},"ja538:11.4":{"pli":"evaṁ tvamasi sārathi; ","html":"<span class='verse-line'>{}</span>"},"ja538:11.5":{"pli":"Adhammaṁ sārathi kayirā, ","html":"<span class='verse-line'>{}</span>"},"ja538:11.6":{"pli":"mañce tvaṁ nikhaṇaṁ vane. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:12.1":{"pli":"Pahūtabhakkho bhavati, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:12.2":{"pli":"vippavuttho sakaṁ gharā; ","html":"<span class='verse-line'>{}</span>"},"ja538:12.3":{"pli":"Bahū naṁ upajīvanti, ","html":"<span class='verse-line'>{}</span>"},"ja538:12.4":{"pli":"yo mittānaṁ na dubbhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:13.1":{"pli":"Yaṁ yaṁ janapadaṁ yāti, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:13.2":{"pli":"nigame rājadhāniyo; ","html":"<span class='verse-line'>{}</span>"},"ja538:13.3":{"pli":"Sabbattha pūjito hoti, ","html":"<span class='verse-line'>{}</span>"},"ja538:13.4":{"pli":"yo mittānaṁ na dubbhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:14.1":{"pli":"Nāssa corā pasāhanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:14.2":{"pli":"nātimaññanti khattiyā; ","html":"<span class='verse-line'>{}</span>"},"ja538:14.3":{"pli":"Sabbe amitte tarati, ","html":"<span class='verse-line'>{}</span>"},"ja538:14.4":{"pli":"yo mittānaṁ na dubbhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:15.1":{"pli":"Akkuddho sagharaṁ eti, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:15.2":{"pli":"sabhāyaṁ paṭinandito; ","html":"<span class='verse-line'>{}</span>"},"ja538:15.3":{"pli":"Ñātīnaṁ uttamo hoti, ","html":"<span class='verse-line'>{}</span>"},"ja538:15.4":{"pli":"yo mittānaṁ na dubbhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:16.1":{"pli":"Sakkatvā sakkato hoti, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:16.2":{"pli":"garu hoti sagāravo; ","html":"<span class='verse-line'>{}</span>"},"ja538:16.3":{"pli":"Vaṇṇakittibhato hoti, ","html":"<span class='verse-line'>{}</span>"},"ja538:16.4":{"pli":"yo mittānaṁ na dubbhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:17.1":{"pli":"Pūjako labhate pūjaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:17.2":{"pli":"vandako paṭivandanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:17.3":{"pli":"Yaso kittiñca pappoti, ","html":"<span class='verse-line'>{}</span>"},"ja538:17.4":{"pli":"yo mittānaṁ na dubbhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:18.1":{"pli":"Aggi yathā pajjalati, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:18.2":{"pli":"devatāva virocati; ","html":"<span class='verse-line'>{}</span>"},"ja538:18.3":{"pli":"Siriyā ajahito hoti, ","html":"<span class='verse-line'>{}</span>"},"ja538:18.4":{"pli":"yo mittānaṁ na dubbhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:19.1":{"pli":"Gāvo tassa pajāyanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:19.2":{"pli":"khette vuttaṁ virūhati; ","html":"<span class='verse-line'>{}</span>"},"ja538:19.3":{"pli":"Vuttānaṁ phalamasnāti, ","html":"<span class='verse-line'>{}</span>"},"ja538:19.4":{"pli":"yo mittānaṁ na dubbhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:20.1":{"pli":"Darito pabbatāto vā, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:20.2":{"pli":"rukkhato patito naro; ","html":"<span class='verse-line'>{}</span>"},"ja538:20.3":{"pli":"Cuto patiṭṭhaṁ labhati, ","html":"<span class='verse-line'>{}</span>"},"ja538:20.4":{"pli":"yo mittānaṁ na dubbhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:21.1":{"pli":"Virūḷhamūlasantānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:21.2":{"pli":"nigrodhamiva māluto; ","html":"<span class='verse-line'>{}</span>"},"ja538:21.3":{"pli":"Amittā nappasāhanti, ","html":"<span class='verse-line'>{}</span>"},"ja538:21.4":{"pli":"yo mittānaṁ na dubbhati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:22.1":{"pli":"“Ehi taṁ paṭinessāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:22.2":{"pli":"rājaputta sakaṁ gharaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:22.3":{"pli":"Rajjaṁ kārehi bhaddante, ","html":"<span class='verse-line'>{}</span>"},"ja538:22.4":{"pli":"kiṁ araññe karissasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:23.1":{"pli":"“Alaṁ me tena rajjena, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:23.2":{"pli":"ñātakehi dhanena vā; ","html":"<span class='verse-line'>{}</span>"},"ja538:23.3":{"pli":"Yaṁ me adhammacariyāya, ","html":"<span class='verse-line'>{}</span>"},"ja538:23.4":{"pli":"rajjaṁ labbhetha sārathi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:24.1":{"pli":"“Puṇṇapattaṁ maṁ lābhehi, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:24.2":{"pli":"rājaputta ito gato; ","html":"<span class='verse-line'>{}</span>"},"ja538:24.3":{"pli":"Pitā mātā ca me dajjuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja538:24.4":{"pli":"rājaputta tayī gate. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:25.1":{"pli":"Orodhā ca kumārā ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:25.2":{"pli":"vesiyānā ca brāhmaṇā; ","html":"<span class='verse-line'>{}</span>"},"ja538:25.3":{"pli":"Tepi attamanā dajjuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja538:25.4":{"pli":"rājaputta tayī gate. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:26.1":{"pli":"Hatthārohā anīkaṭṭhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:26.2":{"pli":"rathikā pattikārakā; ","html":"<span class='verse-line'>{}</span>"},"ja538:26.3":{"pli":"Tepi attamanā dajjuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja538:26.4":{"pli":"rājaputta tayī gate. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:27.1":{"pli":"Bahudhaññā jānapadā, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:27.2":{"pli":"negamā ca samāgatā; ","html":"<span class='verse-line'>{}</span>"},"ja538:27.3":{"pli":"Upāyanāni me dajjuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja538:27.4":{"pli":"rājaputta tayī gate”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:28.1":{"pli":"“Pitu mātu cahaṁ catto, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:28.2":{"pli":"raṭṭhassa nigamassa ca; ","html":"<span class='verse-line'>{}</span>"},"ja538:28.3":{"pli":"Atho sabbakumārānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja538:28.4":{"pli":"natthi mayhaṁ sakaṁ gharaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:29.1":{"pli":"Anuññāto ahaṁ matyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:29.2":{"pli":"sañcatto pitarā mahaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:29.3":{"pli":"Ekoraññe pabbajito, ","html":"<span class='verse-line'>{}</span>"},"ja538:29.4":{"pli":"na kāme abhipatthaye. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:30.1":{"pli":"Api ataramānānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:30.2":{"pli":"phalāsāva samijjhati; ","html":"<span class='verse-line'>{}</span>"},"ja538:30.3":{"pli":"Vipakkabrahmacariyosmi, ","html":"<span class='verse-line'>{}</span>"},"ja538:30.4":{"pli":"evaṁ jānāhi sārathi. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:31.1":{"pli":"Api ataramānānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:31.2":{"pli":"sammadattho vipaccati; ","html":"<span class='verse-line'>{}</span>"},"ja538:31.3":{"pli":"Vipakkabrahmacariyosmi, ","html":"<span class='verse-line'>{}</span>"},"ja538:31.4":{"pli":"nikkhanto akutobhayo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:32.1":{"pli":"“Evaṁ vaggukatho santo, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:32.2":{"pli":"visaṭṭhavacano casi; ","html":"<span class='verse-line'>{}</span>"},"ja538:32.3":{"pli":"Kasmā pitu ca mātucca, ","html":"<span class='verse-line'>{}</span>"},"ja538:32.4":{"pli":"santike na bhaṇī tadā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:33.1":{"pli":"“Nāhaṁ asandhitā pakkho, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:33.2":{"pli":"na badhiro asotatā; ","html":"<span class='verse-line'>{}</span>"},"ja538:33.3":{"pli":"Nāhaṁ ajivhatā mūgo, ","html":"<span class='verse-line'>{}</span>"},"ja538:33.4":{"pli":"mā maṁ mūgamadhārayi. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:34.1":{"pli":"Purimaṁ sarāmahaṁ jātiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:34.2":{"pli":"yattha rajjamakārayiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:34.3":{"pli":"Kārayitvā tahiṁ rajjaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja538:34.4":{"pli":"pāpatthaṁ nirayaṁ bhusaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:35.1":{"pli":"Vīsatiñceva vassāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:35.2":{"pli":"tahiṁ rajjamakārayiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:35.3":{"pli":"Asītivassasahassāni, ","html":"<span class='verse-line'>{}</span>"},"ja538:35.4":{"pli":"nirayamhi apaccisaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:36.1":{"pli":"Tassa rajjassahaṁ bhīto, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:36.2":{"pli":"mā maṁ rajjābhisecayuṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:36.3":{"pli":"Tasmā pitu ca mātucca, ","html":"<span class='verse-line'>{}</span>"},"ja538:36.4":{"pli":"santike na bhaṇiṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:37.1":{"pli":"Ucchaṅge maṁ nisādetvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:37.2":{"pli":"pitā atthānusāsati; ","html":"<span class='verse-line'>{}</span>"},"ja538:37.3":{"pli":"Ekaṁ hanatha bandhatha, ","html":"<span class='verse-line'>{}</span>"},"ja538:37.4":{"pli":"ekaṁ khārāpatacchikaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:37.5":{"pli":"Ekaṁ sūlasmiṁ uppetha, ","html":"<span class='verse-line'>{}</span>"},"ja538:37.6":{"pli":"iccassa manusāsati. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:38.1":{"pli":"Tāyāhaṁ pharusaṁ sutvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:38.2":{"pli":"vācāyo samudīritā; ","html":"<span class='verse-line'>{}</span>"},"ja538:38.3":{"pli":"Amūgo mūgavaṇṇena, ","html":"<span class='verse-line'>{}</span>"},"ja538:38.4":{"pli":"apakkho pakkhasammato; ","html":"<span class='verse-line'>{}</span>"},"ja538:38.5":{"pli":"Sake muttakarīsasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja538:38.6":{"pli":"acchāhaṁ samparipluto. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:39.1":{"pli":"Kasirañca parittañca, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:39.2":{"pli":"tañca dukkhena saṁyutaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:39.3":{"pli":"Komaṁ jīvitamāgamma, ","html":"<span class='verse-line'>{}</span>"},"ja538:39.4":{"pli":"veraṁ kayirātha kenaci. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:40.1":{"pli":"Paññāya ca alābhena, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:40.2":{"pli":"dhammassa ca adassanā; ","html":"<span class='verse-line'>{}</span>"},"ja538:40.3":{"pli":"Komaṁ jīvitamāgamma, ","html":"<span class='verse-line'>{}</span>"},"ja538:40.4":{"pli":"veraṁ kayirātha kenaci. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:41.1":{"pli":"Api ataramānānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:41.2":{"pli":"phalāsāva samijjhati; ","html":"<span class='verse-line'>{}</span>"},"ja538:41.3":{"pli":"Vipakkabrahmacariyosmi, ","html":"<span class='verse-line'>{}</span>"},"ja538:41.4":{"pli":"evaṁ jānāhi sārathi. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:42.1":{"pli":"Api ataramānānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:42.2":{"pli":"sammadattho vipaccati; ","html":"<span class='verse-line'>{}</span>"},"ja538:42.3":{"pli":"Vipakkabrahmacariyosmi, ","html":"<span class='verse-line'>{}</span>"},"ja538:42.4":{"pli":"nikkhanto akutobhayo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:43.1":{"pli":"“Ahampi pabbajissāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:43.2":{"pli":"rājaputta tavantike; ","html":"<span class='verse-line'>{}</span>"},"ja538:43.3":{"pli":"Avhāyassu maṁ bhaddante, ","html":"<span class='verse-line'>{}</span>"},"ja538:43.4":{"pli":"pabbajjā mama ruccati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:44.1":{"pli":"“Rathaṁ niyyādayitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:44.2":{"pli":"anaṇo ehi sārathi; ","html":"<span class='verse-line'>{}</span>"},"ja538:44.3":{"pli":"Anaṇassa hi pabbajjā, ","html":"<span class='verse-line'>{}</span>"},"ja538:44.4":{"pli":"etaṁ isīhi vaṇṇitaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:45.1":{"pli":"“Yadeva tyāhaṁ vacanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:45.2":{"pli":"akaraṁ bhaddamatthu te; ","html":"<span class='verse-line'>{}</span>"},"ja538:45.3":{"pli":"Tadeva me tvaṁ vacanaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja538:45.4":{"pli":"yācito kattumarahasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:46.1":{"pli":"Idheva tāva acchassu, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:46.2":{"pli":"yāva rājānamānaye; ","html":"<span class='verse-line'>{}</span>"},"ja538:46.3":{"pli":"Appeva te pitā disvā, ","html":"<span class='verse-line'>{}</span>"},"ja538:46.4":{"pli":"patīto sumano siyā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:47.1":{"pli":"“Karomi tetaṁ vacanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:47.2":{"pli":"yaṁ maṁ bhaṇasi sārathi; ","html":"<span class='verse-line'>{}</span>"},"ja538:47.3":{"pli":"Ahampi daṭṭhukāmosmi, ","html":"<span class='verse-line'>{}</span>"},"ja538:47.4":{"pli":"pitaraṁ me idhāgataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:48.1":{"pli":"Ehi samma nivattassu, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:48.2":{"pli":"kusalaṁ vajjāsi ñātinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:48.3":{"pli":"Mātaraṁ pitaraṁ mayhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja538:48.4":{"pli":"vutto vajjāsi vandanaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:49.1":{"pli":"Tassa pāde gahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:49.2":{"pli":"katvā ca naṁ padakkhiṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:49.3":{"pli":"Sārathi rathamāruyha, ","html":"<span class='verse-line'>{}</span>"},"ja538:49.4":{"pli":"rājadvāraṁ upāgami. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:50.1":{"pli":"Suññaṁ mātā rathaṁ disvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:50.2":{"pli":"ekaṁ sārathimāgataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:50.3":{"pli":"Assupuṇṇehi nettehi, ","html":"<span class='verse-line'>{}</span>"},"ja538:50.4":{"pli":"rodantī naṁ udikkhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:51.1":{"pli":"“Ayaṁ so sārathi eti, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:51.2":{"pli":"nihantvā mama atrajaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:51.3":{"pli":"Nihato nūna me putto, ","html":"<span class='verse-line'>{}</span>"},"ja538:51.4":{"pli":"pathabyā bhūmivaḍḍhano. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:52.1":{"pli":"Amittā nūna nandanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:52.2":{"pli":"patītā nūna verino; ","html":"<span class='verse-line'>{}</span>"},"ja538:52.3":{"pli":"Āgataṁ sārathiṁ disvā, ","html":"<span class='verse-line'>{}</span>"},"ja538:52.4":{"pli":"nihantvā mama atrajaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:53.1":{"pli":"Suññaṁ mātā rathaṁ disvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:53.2":{"pli":"ekaṁ sārathimāgataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:53.3":{"pli":"Assupuṇṇehi nettehi, ","html":"<span class='verse-line'>{}</span>"},"ja538:53.4":{"pli":"rodantī paripucchi naṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:54.1":{"pli":"“Kiṁ nu mūgo kiṁ nu pakkho, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:54.2":{"pli":"kiṁ nu so vilapī tadā; ","html":"<span class='verse-line'>{}</span>"},"ja538:54.3":{"pli":"Nihaññamāno bhūmiyā, ","html":"<span class='verse-line'>{}</span>"},"ja538:54.4":{"pli":"taṁ me akkhāhi sārathi. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:55.1":{"pli":"Kathaṁ hatthehi pādehi, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:55.2":{"pli":"mūgapakkho vivajjayi; ","html":"<span class='verse-line'>{}</span>"},"ja538:55.3":{"pli":"Nihaññamāno bhūmiyā, ","html":"<span class='verse-line'>{}</span>"},"ja538:55.4":{"pli":"taṁ me akkhāhi pucchito”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:56.1":{"pli":"“Akkheyyaṁ te ahaṁ ayye, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:56.2":{"pli":"dajjāsi abhayaṁ mama; ","html":"<span class='verse-line'>{}</span>"},"ja538:56.3":{"pli":"Yaṁ me sutaṁ vā diṭṭhaṁ vā, ","html":"<span class='verse-line'>{}</span>"},"ja538:56.4":{"pli":"rājaputtassa santike”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:57.1":{"pli":"“Abhayaṁ samma te dammi, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:57.2":{"pli":"abhīto bhaṇa sārathi; ","html":"<span class='verse-line'>{}</span>"},"ja538:57.3":{"pli":"Yaṁ te sutaṁ vā diṭṭhaṁ vā, ","html":"<span class='verse-line'>{}</span>"},"ja538:57.4":{"pli":"rājaputtassa santike”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:58.1":{"pli":"“Na so mūgo na so pakkho, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:58.2":{"pli":"visaṭṭhavacano ca so; ","html":"<span class='verse-line'>{}</span>"},"ja538:58.3":{"pli":"Rajjassa kira so bhīto, ","html":"<span class='verse-line'>{}</span>"},"ja538:58.4":{"pli":"akarā ālaye bahū. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:59.1":{"pli":"Purimaṁ sarati so jātiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:59.2":{"pli":"yattha rajjamakārayi; ","html":"<span class='verse-line'>{}</span>"},"ja538:59.3":{"pli":"Kārayitvā tahiṁ rajjaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja538:59.4":{"pli":"pāpattha nirayaṁ bhusaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:60.1":{"pli":"Vīsatiñceva vassāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:60.2":{"pli":"tahiṁ rajjamakārayi; ","html":"<span class='verse-line'>{}</span>"},"ja538:60.3":{"pli":"Asītivassasahassāni, ","html":"<span class='verse-line'>{}</span>"},"ja538:60.4":{"pli":"nirayamhi apacci so. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:61.1":{"pli":"Tassa rajjassa so bhīto, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:61.2":{"pli":"mā maṁ rajjābhisecayuṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:61.3":{"pli":"Tasmā pitu ca mātucca, ","html":"<span class='verse-line'>{}</span>"},"ja538:61.4":{"pli":"santike na bhaṇī tadā. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:62.1":{"pli":"Aṅgapaccaṅgasampanno, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:62.2":{"pli":"ārohapariṇāhavā; ","html":"<span class='verse-line'>{}</span>"},"ja538:62.3":{"pli":"Visaṭṭhavacano pañño, ","html":"<span class='verse-line'>{}</span>"},"ja538:62.4":{"pli":"magge saggassa tiṭṭhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:63.1":{"pli":"Sace tvaṁ daṭṭhukāmāsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:63.2":{"pli":"rājaputtaṁ tavatrajaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:63.3":{"pli":"Ehi taṁ pāpayissāmi, ","html":"<span class='verse-line'>{}</span>"},"ja538:63.4":{"pli":"yattha sammati temiyo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:64.1":{"pli":"“Yojayantu rathe asse, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:64.2":{"pli":"Kacchaṁ nāgāna bandhatha; ","html":"<span class='verse-line'>{}</span>"},"ja538:64.3":{"pli":"Udīrayantu saṅkhapaṇavā, ","html":"<span class='verse-line'>{}</span>"},"ja538:64.4":{"pli":"Vādantu ekapokkharā. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:65.1":{"pli":"Vādantu bherī sannaddhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:65.2":{"pli":"vaggū vādantu dundubhī; ","html":"<span class='verse-line'>{}</span>"},"ja538:65.3":{"pli":"Negamā ca maṁ anventu, ","html":"<span class='verse-line'>{}</span>"},"ja538:65.4":{"pli":"gacchaṁ puttanivedako. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:66.1":{"pli":"Orodhā ca kumārā ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:66.2":{"pli":"vesiyānā ca brāhmaṇā; ","html":"<span class='verse-line'>{}</span>"},"ja538:66.3":{"pli":"Khippaṁ yānāni yojentu, ","html":"<span class='verse-line'>{}</span>"},"ja538:66.4":{"pli":"gacchaṁ puttanivedako. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:67.1":{"pli":"Hatthārohā anīkaṭṭhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:67.2":{"pli":"rathikā pattikārakā; ","html":"<span class='verse-line'>{}</span>"},"ja538:67.3":{"pli":"Khippaṁ yānāni yojentu, ","html":"<span class='verse-line'>{}</span>"},"ja538:67.4":{"pli":"gacchaṁ puttanivedako. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:68.1":{"pli":"Samāgatā jānapadā, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:68.2":{"pli":"negamā ca samāgatā; ","html":"<span class='verse-line'>{}</span>"},"ja538:68.3":{"pli":"Khippaṁ yānāni yojentu, ","html":"<span class='verse-line'>{}</span>"},"ja538:68.4":{"pli":"gacchaṁ puttanivedako”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:69.1":{"pli":"Asse ca sārathī yutte, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:69.2":{"pli":"sindhave sīghavāhane; ","html":"<span class='verse-line'>{}</span>"},"ja538:69.3":{"pli":"Rājadvāraṁ upāgacchuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja538:69.4":{"pli":"“yuttā deva ime hayā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:70.1":{"pli":"“Thūlā javena hāyanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:70.2":{"pli":"kisā hāyanti thāmunā; ","html":"<span class='verse-line'>{}</span>"},"ja538:70.3":{"pli":"Kise thūle vivajjetvā, ","html":"<span class='verse-line'>{}</span>"},"ja538:70.4":{"pli":"saṁsaṭṭhā yojitā hayā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:71.1":{"pli":"Tato rājā taramāno, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:71.2":{"pli":"yuttamāruyha sandanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:71.3":{"pli":"Itthāgāraṁ ajjhabhāsi, ","html":"<span class='verse-line'>{}</span>"},"ja538:71.4":{"pli":"“sabbāva anuyātha maṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:72.1":{"pli":"Vālabījanimuṇhīsaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:72.2":{"pli":"khaggaṁ chattañca paṇḍaraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:72.3":{"pli":"Upādhī rathamāruyha, ","html":"<span class='verse-line'>{}</span>"},"ja538:72.4":{"pli":"suvaṇṇehi alaṅkatā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:73.1":{"pli":"Tato sa rājā pāyāsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:73.2":{"pli":"purakkhatvāna sārathiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:73.3":{"pli":"Khippameva upāgacchi, ","html":"<span class='verse-line'>{}</span>"},"ja538:73.4":{"pli":"yattha sammati temiyo. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:74.1":{"pli":"Tañca disvāna āyantaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:74.2":{"pli":"jalantamiva tejasā; ","html":"<span class='verse-line'>{}</span>"},"ja538:74.3":{"pli":"Khattasaṅghaparibyūḷhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja538:74.4":{"pli":"temiyo etadabravi. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:75.1":{"pli":"“Kacci nu tāta kusalaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:75.2":{"pli":"kacci tāta anāmayaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:75.3":{"pli":"Sabbā ca rājakaññāyo, ","html":"<span class='verse-line'>{}</span>"},"ja538:75.4":{"pli":"arogā mayha mātaro”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:76.1":{"pli":"“Kusalañceva me putta, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:76.2":{"pli":"atho putta anāmayaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:76.3":{"pli":"Sabbā ca rājakaññāyo, ","html":"<span class='verse-line'>{}</span>"},"ja538:76.4":{"pli":"arogā tuyha mātaro”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:77.1":{"pli":"“Kacci amajjapo tāta, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:77.2":{"pli":"kacci te suramappiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:77.3":{"pli":"Kacci sacce ca dhamme ca, ","html":"<span class='verse-line'>{}</span>"},"ja538:77.4":{"pli":"dāne te ramate mano”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:78.1":{"pli":"“Amajjapo ahaṁ putta, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:78.2":{"pli":"atho me suramappiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:78.3":{"pli":"Atho sacce ca dhamme ca, ","html":"<span class='verse-line'>{}</span>"},"ja538:78.4":{"pli":"dāne me ramate mano”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:79.1":{"pli":"“Kacci arogaṁ yoggaṁ te, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:79.2":{"pli":"kacci vahati vāhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:79.3":{"pli":"Kacci te byādhayo natthi, ","html":"<span class='verse-line'>{}</span>"},"ja538:79.4":{"pli":"sarīrassupatāpanā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:80.1":{"pli":"“Atho arogaṁ yoggaṁ me, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:80.2":{"pli":"atho vahati vāhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:80.3":{"pli":"Atho me byādhayo natthi, ","html":"<span class='verse-line'>{}</span>"},"ja538:80.4":{"pli":"sarīrassupatāpanā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:81.1":{"pli":"“Kacci antā ca te phītā, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:81.2":{"pli":"majjhe ca bahalā tava; ","html":"<span class='verse-line'>{}</span>"},"ja538:81.3":{"pli":"Koṭṭhāgārañca kosañca, ","html":"<span class='verse-line'>{}</span>"},"ja538:81.4":{"pli":"kacci te paṭisanthataṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:82.1":{"pli":"“Atho antā ca me phītā, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:82.2":{"pli":"majjhe ca bahalā mama; ","html":"<span class='verse-line'>{}</span>"},"ja538:82.3":{"pli":"Koṭṭhāgārañca kosañca, ","html":"<span class='verse-line'>{}</span>"},"ja538:82.4":{"pli":"sabbaṁ me paṭisanthataṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:83.1":{"pli":"“Svāgataṁ te mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:83.2":{"pli":"atho te adurāgataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:83.3":{"pli":"Patiṭṭhapentu pallaṅkaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja538:83.4":{"pli":"yattha rājā nisakkati. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:84.1":{"pli":"Idheva te nisīdassu, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:84.2":{"pli":"niyate paṇṇasanthare; ","html":"<span class='verse-line'>{}</span>"},"ja538:84.3":{"pli":"Etto udakamādāya, ","html":"<span class='verse-line'>{}</span>"},"ja538:84.4":{"pli":"pāde pakkhālayassu te. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:85.1":{"pli":"Idampi paṇṇakaṁ mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:85.2":{"pli":"randhaṁ rāja aloṇakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:85.3":{"pli":"Paribhuñja mahārāja, ","html":"<span class='verse-line'>{}</span>"},"ja538:85.4":{"pli":"pāhuno mesidhāgato”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:86.1":{"pli":"“Na cāhaṁ paṇṇaṁ bhuñjāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:86.2":{"pli":"Na hetaṁ mayha bhojanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:86.3":{"pli":"Sālīnaṁ odanaṁ bhuñje, ","html":"<span class='verse-line'>{}</span>"},"ja538:86.4":{"pli":"Suciṁ maṁsūpasecanaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:87.1":{"pli":"“Accherakaṁ maṁ paṭibhāti, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:87.2":{"pli":"ekakampi rahogataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:87.3":{"pli":"Edisaṁ bhuñjamānānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja538:87.4":{"pli":"kena vaṇṇo pasīdati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:88.1":{"pli":"“Eko rāja nipajjāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:88.2":{"pli":"niyate paṇṇasanthare; ","html":"<span class='verse-line'>{}</span>"},"ja538:88.3":{"pli":"Tāya me ekaseyyāya, ","html":"<span class='verse-line'>{}</span>"},"ja538:88.4":{"pli":"rāja vaṇṇo pasīdati. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:89.1":{"pli":"Na ca nettiṁsabandhā me, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:89.2":{"pli":"rājarakkhā upaṭṭhitā; ","html":"<span class='verse-line'>{}</span>"},"ja538:89.3":{"pli":"Tāya me sukhaseyyāya, ","html":"<span class='verse-line'>{}</span>"},"ja538:89.4":{"pli":"rāja vaṇṇo pasīdati. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:90.1":{"pli":"Atītaṁ nānusocāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:90.2":{"pli":"nappajappāmināgataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:90.3":{"pli":"Paccuppannena yāpemi, ","html":"<span class='verse-line'>{}</span>"},"ja538:90.4":{"pli":"tena vaṇṇo pasīdati. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:91.1":{"pli":"Anāgatappajappāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:91.2":{"pli":"atītassānusocanā; ","html":"<span class='verse-line'>{}</span>"},"ja538:91.3":{"pli":"Etena bālā sussanti, ","html":"<span class='verse-line'>{}</span>"},"ja538:91.4":{"pli":"naḷova harito luto”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:92.1":{"pli":"“Hatthānīkaṁ rathānīkaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:92.2":{"pli":"asse pattī ca vammino; ","html":"<span class='verse-line'>{}</span>"},"ja538:92.3":{"pli":"Nivesanāni rammāni, ","html":"<span class='verse-line'>{}</span>"},"ja538:92.4":{"pli":"ahaṁ putta dadāmi te. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:93.1":{"pli":"Itthāgārampi te dammi, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:93.2":{"pli":"sabbālaṅkārabhūsitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:93.3":{"pli":"Tā putta paṭipajjassu, ","html":"<span class='verse-line'>{}</span>"},"ja538:93.4":{"pli":"tvaṁ no rājā bhavissasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:94.1":{"pli":"Kusalā naccagītassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:94.2":{"pli":"sikkhitā cāturitthiyo; ","html":"<span class='verse-line'>{}</span>"},"ja538:94.3":{"pli":"Kāme taṁ ramayissanti, ","html":"<span class='verse-line'>{}</span>"},"ja538:94.4":{"pli":"kiṁ araññe karissasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:95.1":{"pli":"Paṭirājūhi te kaññā, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:95.2":{"pli":"ānayissaṁ alaṅkatā; ","html":"<span class='verse-line'>{}</span>"},"ja538:95.3":{"pli":"Tāsu putte janetvāna, ","html":"<span class='verse-line'>{}</span>"},"ja538:95.4":{"pli":"atha pacchā pabbajissasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:96.1":{"pli":"Yuvā ca daharo cāsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:96.2":{"pli":"paṭhamuppattiko susu; ","html":"<span class='verse-line'>{}</span>"},"ja538:96.3":{"pli":"Rajjaṁ kārehi bhaddante, ","html":"<span class='verse-line'>{}</span>"},"ja538:96.4":{"pli":"kiṁ araññe karissasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:97.1":{"pli":"“Yuvā care brahmacariyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:97.2":{"pli":"brahmacārī yuvā siyā; ","html":"<span class='verse-line'>{}</span>"},"ja538:97.3":{"pli":"Daharassa hi pabbajjā, ","html":"<span class='verse-line'>{}</span>"},"ja538:97.4":{"pli":"etaṁ isīhi vaṇṇitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:98.1":{"pli":"Yuvā care brahmacariyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:98.2":{"pli":"brahmacārī yuvā siyā; ","html":"<span class='verse-line'>{}</span>"},"ja538:98.3":{"pli":"Brahmacariyaṁ carissāmi, ","html":"<span class='verse-line'>{}</span>"},"ja538:98.4":{"pli":"nāhaṁ rajjena matthiko. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:99.1":{"pli":"Passāmi vohaṁ daharaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:99.2":{"pli":"amma tāta vadantaraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:99.3":{"pli":"Kicchāladdhaṁ piyaṁ puttaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja538:99.4":{"pli":"appatvāva jaraṁ mataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:100.1":{"pli":"Passāmi vohaṁ dahariṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:100.2":{"pli":"kumāriṁ cārudassaniṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:100.3":{"pli":"Navavaṁsakaḷīraṁva, ","html":"<span class='verse-line'>{}</span>"},"ja538:100.4":{"pli":"paluggaṁ jīvitakkhayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:101.1":{"pli":"Daharāpi hi miyyanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:101.2":{"pli":"narā ca atha nāriyo; ","html":"<span class='verse-line'>{}</span>"},"ja538:101.3":{"pli":"Tattha ko vissase poso, ","html":"<span class='verse-line'>{}</span>"},"ja538:101.4":{"pli":"daharomhīti jīvite. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:102.1":{"pli":"Yassa ratyā vivasāne, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:102.2":{"pli":"āyu appataraṁ siyā; ","html":"<span class='verse-line'>{}</span>"},"ja538:102.3":{"pli":"Appodakeva macchānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja538:102.4":{"pli":"kiṁ nu komārakaṁ tahiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:103.1":{"pli":"Niccamabbhāhato loko, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:103.2":{"pli":"niccañca parivārito; ","html":"<span class='verse-line'>{}</span>"},"ja538:103.3":{"pli":"Amoghāsu vajantīsu, ","html":"<span class='verse-line'>{}</span>"},"ja538:103.4":{"pli":"kiṁ maṁ rajjebhisiñcasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:104.1":{"pli":"“Kena mabbhāhato loko, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:104.2":{"pli":"kena ca parivārito; ","html":"<span class='verse-line'>{}</span>"},"ja538:104.3":{"pli":"Kāyo amoghā gacchanti, ","html":"<span class='verse-line'>{}</span>"},"ja538:104.4":{"pli":"taṁ me akkhāhi pucchito”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:105.1":{"pli":"“Maccunābbhāhato loko, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:105.2":{"pli":"jarāya parivārito; ","html":"<span class='verse-line'>{}</span>"},"ja538:105.3":{"pli":"Ratyo amoghā gacchanti, ","html":"<span class='verse-line'>{}</span>"},"ja538:105.4":{"pli":"evaṁ jānāhi khattiya. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:106.1":{"pli":"Yathāpi tante vitate, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:106.2":{"pli":"yaṁ yadevūpaviyyati; ","html":"<span class='verse-line'>{}</span>"},"ja538:106.3":{"pli":"Appakaṁ hoti vetabbaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja538:106.4":{"pli":"evaṁ maccāna jīvitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:107.1":{"pli":"Yathā vārivaho pūro, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:107.2":{"pli":"gacchannupanivattati; ","html":"<span class='verse-line'>{}</span>"},"ja538:107.3":{"pli":"Evamāyu manussānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja538:107.4":{"pli":"gacchannupanivattati. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:108.1":{"pli":"Yathā vārivaho pūro, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:108.2":{"pli":"vahe rukkhepakūlaje; ","html":"<span class='verse-line'>{}</span>"},"ja538:108.3":{"pli":"Evaṁ jarāmaraṇena, ","html":"<span class='verse-line'>{}</span>"},"ja538:108.4":{"pli":"vuyhante sabbapāṇino”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:109.1":{"pli":"“Hatthānīkaṁ rathānīkaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:109.2":{"pli":"asse pattī ca vammino; ","html":"<span class='verse-line'>{}</span>"},"ja538:109.3":{"pli":"Nivesanāni rammāni, ","html":"<span class='verse-line'>{}</span>"},"ja538:109.4":{"pli":"ahaṁ putta dadāmi te. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:110.1":{"pli":"Itthāgārampi te dammi, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:110.2":{"pli":"sabbālaṅkārabhūsitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:110.3":{"pli":"Tā putta paṭipajjassu, ","html":"<span class='verse-line'>{}</span>"},"ja538:110.4":{"pli":"tvaṁ no rājā bhavissasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:111.1":{"pli":"Kusalā naccagītassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:111.2":{"pli":"sikkhitā cāturitthiyo; ","html":"<span class='verse-line'>{}</span>"},"ja538:111.3":{"pli":"Kāme taṁ ramayissanti, ","html":"<span class='verse-line'>{}</span>"},"ja538:111.4":{"pli":"kiṁ araññe karissasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:112.1":{"pli":"Paṭirājūhi te kaññā, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:112.2":{"pli":"ānayissaṁ alaṅkatā; ","html":"<span class='verse-line'>{}</span>"},"ja538:112.3":{"pli":"Tāsu putte janetvāna, ","html":"<span class='verse-line'>{}</span>"},"ja538:112.4":{"pli":"atha pacchā pabbajissasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:113.1":{"pli":"Yuvā ca daharo cāsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:113.2":{"pli":"paṭhamuppattiko susu; ","html":"<span class='verse-line'>{}</span>"},"ja538:113.3":{"pli":"Rajjaṁ kārehi bhaddante, ","html":"<span class='verse-line'>{}</span>"},"ja538:113.4":{"pli":"kiṁ araññe karissasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:114.1":{"pli":"Koṭṭhāgārañca kosañca, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:114.2":{"pli":"vāhanāni balāni ca; ","html":"<span class='verse-line'>{}</span>"},"ja538:114.3":{"pli":"Nivesanāni rammāni, ","html":"<span class='verse-line'>{}</span>"},"ja538:114.4":{"pli":"ahaṁ putta dadāmi te. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:115.1":{"pli":"Gomaṇḍalaparibyūḷho, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:115.2":{"pli":"dāsisaṅghapurakkhato; ","html":"<span class='verse-line'>{}</span>"},"ja538:115.3":{"pli":"Rajjaṁ kārehi bhaddante, ","html":"<span class='verse-line'>{}</span>"},"ja538:115.4":{"pli":"kiṁ araññe karissasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:116.1":{"pli":"“Kiṁ dhanena yaṁ khīyetha, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:116.2":{"pli":"Kiṁ bhariyāya marissati; ","html":"<span class='verse-line'>{}</span>"},"ja538:116.3":{"pli":"Kiṁ yobbanena jiṇṇena, ","html":"<span class='verse-line'>{}</span>"},"ja538:116.4":{"pli":"Yaṁ jarāyābhibhuyyati. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:117.1":{"pli":"Tattha kā nandi kā khiḍḍā, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:117.2":{"pli":"kā rati kā dhanesanā; ","html":"<span class='verse-line'>{}</span>"},"ja538:117.3":{"pli":"Kiṁ me puttehi dārehi, ","html":"<span class='verse-line'>{}</span>"},"ja538:117.4":{"pli":"rāja muttosmi bandhanā. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:118.1":{"pli":"Yohaṁ evaṁ pajānāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:118.2":{"pli":"maccu me nappamajjati; ","html":"<span class='verse-line'>{}</span>"},"ja538:118.3":{"pli":"Antakenādhipannassa, ","html":"<span class='verse-line'>{}</span>"},"ja538:118.4":{"pli":"kā ratī kā dhanesanā. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:119.1":{"pli":"Phalānamiva pakkānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:119.2":{"pli":"niccaṁ patanato bhayaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja538:119.3":{"pli":"Evaṁ jātāna maccānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja538:119.4":{"pli":"niccaṁ maraṇato bhayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:120.1":{"pli":"Sāyameke na dissanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:120.2":{"pli":"pāto diṭṭhā bahū janā; ","html":"<span class='verse-line'>{}</span>"},"ja538:120.3":{"pli":"Pāto eke na dissanti, ","html":"<span class='verse-line'>{}</span>"},"ja538:120.4":{"pli":"sāyaṁ diṭṭhā bahū janā. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:121.1":{"pli":"Ajjeva kiccaṁ ātapaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:121.2":{"pli":"ko jaññā maraṇaṁ suve; ","html":"<span class='verse-line'>{}</span>"},"ja538:121.3":{"pli":"Na hi no saṅgaraṁ tena, ","html":"<span class='verse-line'>{}</span>"},"ja538:121.4":{"pli":"mahāsenena maccunā. ","html":"<span class='verse-line'>{}</span></p>"},"ja538:122.1":{"pli":"Corā dhanassa patthenti, ","html":"<p><span class='verse-line'>{}</span>"},"ja538:122.2":{"pli":"rāja muttosmi bandhanā; ","html":"<span class='verse-line'>{}</span>"},"ja538:122.3":{"pli":"Ehi rāja nivattassu, ","html":"<span class='verse-line'>{}</span>"},"ja538:122.4":{"pli":"nāhaṁ rajjena matthiko”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja538:123.1":{"pli":"Mūgapakkhajātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}