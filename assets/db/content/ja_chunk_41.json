{"ja531":{"ja531:0.1":{"pli":"Jātaka ","html":"<article id='ja531'><header><ul><li class='division'>{}</li>"},"ja531:0.2":{"pli":"Sattatinipāta ","html":"<li>{}</li>"},"ja531:0.3":{"pli":"Kusavagga ","html":"<li>{}</li></ul>"},"ja531:0.4":{"pli":"1. Kusajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja531:1.1":{"pli":"“Idaṁ te raṭṭhaṁ sadhanaṁ sayoggaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja531:1.2":{"pli":"Sakāyuraṁ sabbakāmūpapannaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja531:1.3":{"pli":"Idaṁ te rajjaṁ anusāsa amma, ","html":"<span class='verse-line'>{}</span>"},"ja531:1.4":{"pli":"Gacchāmahaṁ yattha piyā pabhāvatī”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:2.1":{"pli":"“Anujjubhūtena haraṁ mahantaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:2.2":{"pli":"Divā ca ratto ca nisīthakāle; ","html":"<span class='verse-line'>{}</span>"},"ja531:2.3":{"pli":"Paṭigaccha tvaṁ khippaṁ kusāvatiṁ kusa, ","html":"<span class='verse-line'>{}</span>"},"ja531:2.4":{"pli":"Nicchāmi dubbaṇṇamahaṁ vasantaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:3.1":{"pli":"“Nāhaṁ gamissāmi ito kusāvatiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:3.2":{"pli":"Pabhāvatī vaṇṇapalobhito tava; ","html":"<span class='verse-line'>{}</span>"},"ja531:3.3":{"pli":"Ramāmi maddassa niketaramme, ","html":"<span class='verse-line'>{}</span>"},"ja531:3.4":{"pli":"Hitvāna raṭṭhaṁ tava dassane rato. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:4.1":{"pli":"Pabhāvatī vaṇṇapalobhito tava, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:4.2":{"pli":"Sammūḷharūpo vicarāmi mediniṁ; ","html":"<span class='verse-line'>{}</span>"},"ja531:4.3":{"pli":"Disaṁ na jānāmi kutomhi āgato, ","html":"<span class='verse-line'>{}</span>"},"ja531:4.4":{"pli":"Tayamhi matto migamandalocane. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:5.1":{"pli":"Suvaṇṇacīravasane, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:5.2":{"pli":"jātarūpasumekhale; ","html":"<span class='verse-line'>{}</span>"},"ja531:5.3":{"pli":"Sussoṇi tava kāmā hi, ","html":"<span class='verse-line'>{}</span>"},"ja531:5.4":{"pli":"nāhaṁ rajjena matthiko”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:6.1":{"pli":"“Abbhūti tassa bho hoti, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:6.2":{"pli":"yo anicchantamicchati; ","html":"<span class='verse-line'>{}</span>"},"ja531:6.3":{"pli":"Akāmaṁ rāja kāmesi, ","html":"<span class='verse-line'>{}</span>"},"ja531:6.4":{"pli":"akantaṁ kantumicchasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:7.1":{"pli":"“Akāmaṁ vā sakāmaṁ vā, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:7.2":{"pli":"yo naro labhate piyaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja531:7.3":{"pli":"Lābhamettha pasaṁsāma, ","html":"<span class='verse-line'>{}</span>"},"ja531:7.4":{"pli":"alābho tattha pāpako”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:8.1":{"pli":"“Pāsāṇasāraṁ khaṇasi, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:8.2":{"pli":"kaṇikārassa dārunā; ","html":"<span class='verse-line'>{}</span>"},"ja531:8.3":{"pli":"Vātaṁ jālena bādhesi, ","html":"<span class='verse-line'>{}</span>"},"ja531:8.4":{"pli":"yo anicchantamicchasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:9.1":{"pli":"“Pāsāṇo nūna te hadaye, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:9.2":{"pli":"ohito mudulakkhaṇe; ","html":"<span class='verse-line'>{}</span>"},"ja531:9.3":{"pli":"Yo te sātaṁ na vindāmi, ","html":"<span class='verse-line'>{}</span>"},"ja531:9.4":{"pli":"tirojanapadāgato. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:10.1":{"pli":"Yadā maṁ bhakuṭiṁ katvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:10.2":{"pli":"rājaputtī udikkhati; ","html":"<span class='verse-line'>{}</span>"},"ja531:10.3":{"pli":"Āḷāriko tadā homi, ","html":"<span class='verse-line'>{}</span>"},"ja531:10.4":{"pli":"rañño maddassantepure. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:11.1":{"pli":"Yadā umhayamānā maṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:11.2":{"pli":"rājaputtī udikkhati; ","html":"<span class='verse-line'>{}</span>"},"ja531:11.3":{"pli":"Nāḷāriko tadā homi, ","html":"<span class='verse-line'>{}</span>"},"ja531:11.4":{"pli":"rājā homi tadā kuso”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:12.1":{"pli":"“Sace hi vacanaṁ saccaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:12.2":{"pli":"nemittānaṁ bhavissati; ","html":"<span class='verse-line'>{}</span>"},"ja531:12.3":{"pli":"Neva me tvaṁ patī assa, ","html":"<span class='verse-line'>{}</span>"},"ja531:12.4":{"pli":"kāmaṁ chindantu sattadhā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:13.1":{"pli":"“Sace hi vacanaṁ saccaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:13.2":{"pli":"aññesaṁ yadi vā mamaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja531:13.3":{"pli":"Neva tuyhaṁ patī atthi, ","html":"<span class='verse-line'>{}</span>"},"ja531:13.4":{"pli":"añño sīhassarā kusā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:14.1":{"pli":"“Nekkhaṁ gīvaṁ te kāressaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:14.2":{"pli":"patvā khujje kusāvatiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja531:14.3":{"pli":"Sace maṁ nāganāsūrū, ","html":"<span class='verse-line'>{}</span>"},"ja531:14.4":{"pli":"olokeyya pabhāvatī. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:15.1":{"pli":"Nekkhaṁ gīvaṁ te kāressaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:15.2":{"pli":"patvā khujje kusāvatiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja531:15.3":{"pli":"Sace maṁ nāganāsūrū, ","html":"<span class='verse-line'>{}</span>"},"ja531:15.4":{"pli":"ālapeyya pabhāvatī. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:16.1":{"pli":"Nekkhaṁ gīvaṁ te kāressaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:16.2":{"pli":"patvā khujje kusāvatiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja531:16.3":{"pli":"Sace maṁ nāganāsūrū, ","html":"<span class='verse-line'>{}</span>"},"ja531:16.4":{"pli":"umhāyeyya pabhāvatī. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:17.1":{"pli":"Nekkhaṁ gīvaṁ te kāressaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:17.2":{"pli":"patvā khujje kusāvatiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja531:17.3":{"pli":"Sace maṁ nāganāsūrū, ","html":"<span class='verse-line'>{}</span>"},"ja531:17.4":{"pli":"pamhāyeyya pabhāvatī. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:18.1":{"pli":"Nekkhaṁ gīvaṁ te kāressaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:18.2":{"pli":"patvā khujje kusāvatiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja531:18.3":{"pli":"Sace maṁ nāganāsūrū, ","html":"<span class='verse-line'>{}</span>"},"ja531:18.4":{"pli":"pāṇīhi upasamphuse”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:19.1":{"pli":"“Na hi nūnāyaṁ rājaputtī, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:19.2":{"pli":"kuse sātampi vindati; ","html":"<span class='verse-line'>{}</span>"},"ja531:19.3":{"pli":"Āḷārike bhate pose, ","html":"<span class='verse-line'>{}</span>"},"ja531:19.4":{"pli":"vetanena anatthike”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:20.1":{"pli":"“Na hi nūnāyaṁ sā khujjā, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:20.2":{"pli":"labhati jivhāya chedanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja531:20.3":{"pli":"Sunisitena satthena, ","html":"<span class='verse-line'>{}</span>"},"ja531:20.4":{"pli":"evaṁ dubbhāsitaṁ bhaṇaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:21.1":{"pli":"“Mā naṁ rūpena pāmesi, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:21.2":{"pli":"ārohena pabhāvati; ","html":"<span class='verse-line'>{}</span>"},"ja531:21.3":{"pli":"Mahāyasoti katvāna, ","html":"<span class='verse-line'>{}</span>"},"ja531:21.4":{"pli":"karassu rucire piyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:22.1":{"pli":"Mā naṁ rūpena pāmesi, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:22.2":{"pli":"ārohena pabhāvati; ","html":"<span class='verse-line'>{}</span>"},"ja531:22.3":{"pli":"Mahaddhanoti katvāna, ","html":"<span class='verse-line'>{}</span>"},"ja531:22.4":{"pli":"karassu rucire piyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:23.1":{"pli":"Mā naṁ rūpena pāmesi, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:23.2":{"pli":"ārohena pabhāvati; ","html":"<span class='verse-line'>{}</span>"},"ja531:23.3":{"pli":"Mahabbaloti katvāna, ","html":"<span class='verse-line'>{}</span>"},"ja531:23.4":{"pli":"karassu rucire piyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:24.1":{"pli":"Mā naṁ rūpena pāmesi, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:24.2":{"pli":"ārohena pabhāvati; ","html":"<span class='verse-line'>{}</span>"},"ja531:24.3":{"pli":"Mahāraṭṭhoti katvāna, ","html":"<span class='verse-line'>{}</span>"},"ja531:24.4":{"pli":"karassu rucire piyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:25.1":{"pli":"Mā naṁ rūpena pāmesi, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:25.2":{"pli":"ārohena pabhāvati; ","html":"<span class='verse-line'>{}</span>"},"ja531:25.3":{"pli":"Mahārājāti katvāna, ","html":"<span class='verse-line'>{}</span>"},"ja531:25.4":{"pli":"karassu rucire piyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:26.1":{"pli":"Mā naṁ rūpena pāmesi, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:26.2":{"pli":"ārohena pabhāvati; ","html":"<span class='verse-line'>{}</span>"},"ja531:26.3":{"pli":"Sīhassaroti katvāna, ","html":"<span class='verse-line'>{}</span>"},"ja531:26.4":{"pli":"karassu rucire piyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:27.1":{"pli":"Mā naṁ rūpena pāmesi, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:27.2":{"pli":"ārohena pabhāvati; ","html":"<span class='verse-line'>{}</span>"},"ja531:27.3":{"pli":"Vaggussaroti katvāna, ","html":"<span class='verse-line'>{}</span>"},"ja531:27.4":{"pli":"karassu rucire piyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:28.1":{"pli":"Mā naṁ rūpena pāmesi, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:28.2":{"pli":"ārohena pabhāvati; ","html":"<span class='verse-line'>{}</span>"},"ja531:28.3":{"pli":"Bindussaroti katvāna, ","html":"<span class='verse-line'>{}</span>"},"ja531:28.4":{"pli":"karassu rucire piyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:29.1":{"pli":"Mā naṁ rūpena pāmesi, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:29.2":{"pli":"ārohena pabhāvati; ","html":"<span class='verse-line'>{}</span>"},"ja531:29.3":{"pli":"Mañjussaroti katvāna, ","html":"<span class='verse-line'>{}</span>"},"ja531:29.4":{"pli":"karassu rucire piyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:30.1":{"pli":"Mā naṁ rūpena pāmesi, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:30.2":{"pli":"ārohena pabhāvati; ","html":"<span class='verse-line'>{}</span>"},"ja531:30.3":{"pli":"Madhussaroti katvāna, ","html":"<span class='verse-line'>{}</span>"},"ja531:30.4":{"pli":"karassu rucire piyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:31.1":{"pli":"Mā naṁ rūpena pāmesi, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:31.2":{"pli":"ārohena pabhāvati; ","html":"<span class='verse-line'>{}</span>"},"ja531:31.3":{"pli":"Satasippoti katvāna, ","html":"<span class='verse-line'>{}</span>"},"ja531:31.4":{"pli":"karassu rucire piyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:32.1":{"pli":"Mā naṁ rūpena pāmesi, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:32.2":{"pli":"ārohena pabhāvati; ","html":"<span class='verse-line'>{}</span>"},"ja531:32.3":{"pli":"Khattiyotipi katvāna, ","html":"<span class='verse-line'>{}</span>"},"ja531:32.4":{"pli":"karassu rucire piyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:33.1":{"pli":"Mā naṁ rūpena pāmesi, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:33.2":{"pli":"ārohena pabhāvati; ","html":"<span class='verse-line'>{}</span>"},"ja531:33.3":{"pli":"Kusarājāti katvāna, ","html":"<span class='verse-line'>{}</span>"},"ja531:33.4":{"pli":"karassu rucire piyaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:34.1":{"pli":"“Ete nāgā upatthaddhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:34.2":{"pli":"sabbe tiṭṭhanti vammitā; ","html":"<span class='verse-line'>{}</span>"},"ja531:34.3":{"pli":"Purā maddanti pākāraṁ, ","html":"<span class='verse-line'>{}</span>"},"ja531:34.4":{"pli":"ānentetaṁ pabhāvatiṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:35.1":{"pli":"“Satta bile karitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:35.2":{"pli":"ahametaṁ pabhāvatiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja531:35.3":{"pli":"Khattiyānaṁ padassāmi, ","html":"<span class='verse-line'>{}</span>"},"ja531:35.4":{"pli":"ye maṁ hantuṁ idhāgatā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:36.1":{"pli":"“Avuṭṭhahi rājaputtī, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:36.2":{"pli":"sāmā koseyyavāsinī; ","html":"<span class='verse-line'>{}</span>"},"ja531:36.3":{"pli":"Assupuṇṇehi nettehi, ","html":"<span class='verse-line'>{}</span>"},"ja531:36.4":{"pli":"dāsīgaṇapurakkhatā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:37.1":{"pli":"“Taṁ nūna kakkūpanisevitaṁ mukhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:37.2":{"pli":"Ādāsadantātharupaccavekkhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja531:37.3":{"pli":"Subhaṁ sunettaṁ virajaṁ anaṅgaṇaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja531:37.4":{"pli":"Chuddhaṁ vane ṭhassati khattiyehi. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:38.1":{"pli":"Te nūna me asite vellitagge, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:38.2":{"pli":"Kese mudū candanasāralitte; ","html":"<span class='verse-line'>{}</span>"},"ja531:38.3":{"pli":"Samākule sīvathikāya majjhe, ","html":"<span class='verse-line'>{}</span>"},"ja531:38.4":{"pli":"Pādehi gijjhā parikaḍḍhissanti. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:39.1":{"pli":"Tā nūna me tambanakhā sulomā, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:39.2":{"pli":"Bāhā mudū candanasāralittā; ","html":"<span class='verse-line'>{}</span>"},"ja531:39.3":{"pli":"Chinnā vane ujjhitā khattiyehi, ","html":"<span class='verse-line'>{}</span>"},"ja531:39.4":{"pli":"Gayha dhaṅko gacchati yenakāmaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:40.1":{"pli":"Te nūna tālūpanibhe alambe, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:40.2":{"pli":"Nisevite kāsikacandanena; ","html":"<span class='verse-line'>{}</span>"},"ja531:40.3":{"pli":"Thanesu me lambissati siṅgālo, ","html":"<span class='verse-line'>{}</span>"},"ja531:40.4":{"pli":"Mātūva putto taruṇo tanūjo. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:41.1":{"pli":"Taṁ nūna soṇiṁ puthulaṁ sukoṭṭitaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:41.2":{"pli":"Nisevitaṁ kañcanamekhalāhi; ","html":"<span class='verse-line'>{}</span>"},"ja531:41.3":{"pli":"Chinnaṁ vane khattiyehī avatthaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja531:41.4":{"pli":"Siṅgālasaṅghā parikaḍḍhissanti. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:42.1":{"pli":"Soṇā dhaṅkā siṅgālā ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:42.2":{"pli":"ye caññe santi dāṭhino; ","html":"<span class='verse-line'>{}</span>"},"ja531:42.3":{"pli":"Ajarā nūna hessanti, ","html":"<span class='verse-line'>{}</span>"},"ja531:42.4":{"pli":"bhakkhayitvā pabhāvatiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:43.1":{"pli":"Sace maṁsāni hariṁsu, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:43.2":{"pli":"khattiyā dūragāmino; ","html":"<span class='verse-line'>{}</span>"},"ja531:43.3":{"pli":"Aṭṭhīni amma yācitvā, ","html":"<span class='verse-line'>{}</span>"},"ja531:43.4":{"pli":"anupathe dahātha naṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:44.1":{"pli":"Khettāni amma kāretvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:44.2":{"pli":"kaṇikārettha ropaya; ","html":"<span class='verse-line'>{}</span>"},"ja531:44.3":{"pli":"Yadā te pupphitā assu, ","html":"<span class='verse-line'>{}</span>"},"ja531:44.4":{"pli":"hemantānaṁ himaccaye; ","html":"<span class='verse-line'>{}</span>"},"ja531:44.5":{"pli":"Sareyyātha mamaṁ amma, ","html":"<span class='verse-line'>{}</span>"},"ja531:44.6":{"pli":"evaṁvaṇṇā pabhāvatī”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:45.1":{"pli":"“Tassā mātā udaṭṭhāsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:45.2":{"pli":"khattiyā devavaṇṇinī; ","html":"<span class='verse-line'>{}</span>"},"ja531:45.3":{"pli":"Disvā asiñca sūnañca, ","html":"<span class='verse-line'>{}</span>"},"ja531:45.4":{"pli":"rañño maddassantepure”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:46.1":{"pli":"“Iminā nūna asinā, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:46.2":{"pli":"susaññaṁ tanumajjhimaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja531:46.3":{"pli":"Dhītaraṁ madda hantvāna, ","html":"<span class='verse-line'>{}</span>"},"ja531:46.4":{"pli":"khattiyānaṁ padassasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:47.1":{"pli":"Na me akāsi vacanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:47.2":{"pli":"atthakāmāya puttike; ","html":"<span class='verse-line'>{}</span>"},"ja531:47.3":{"pli":"Sājja lohitasañchannā, ","html":"<span class='verse-line'>{}</span>"},"ja531:47.4":{"pli":"gacchasi yamasādhanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:48.1":{"pli":"Evamāpajjatī poso, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:48.2":{"pli":"pāpiyañca nigacchati; ","html":"<span class='verse-line'>{}</span>"},"ja531:48.3":{"pli":"Yo ve hitānaṁ vacanaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja531:48.4":{"pli":"na karoti atthadassinaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:49.1":{"pli":"Sace ca ajja dhāresi, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:49.2":{"pli":"kumāraṁ cārudassanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja531:49.3":{"pli":"Kusena jātaṁ khattiyaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja531:49.4":{"pli":"suvaṇṇamaṇimekhalaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja531:49.5":{"pli":"Pūjitaṁ ñātisaṅghehi, ","html":"<span class='verse-line'>{}</span>"},"ja531:49.6":{"pli":"na gacchasi yamakkhayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:50.1":{"pli":"Yatthassu bherī nadati, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:50.2":{"pli":"kuñjaro ca nikūjati; ","html":"<span class='verse-line'>{}</span>"},"ja531:50.3":{"pli":"Khattiyānaṁ kule bhadde, ","html":"<span class='verse-line'>{}</span>"},"ja531:50.4":{"pli":"kiṁ nu sukhataraṁ tato. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:51.1":{"pli":"Asso ca sisati dvāre, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:51.2":{"pli":"kumāro uparodati; ","html":"<span class='verse-line'>{}</span>"},"ja531:51.3":{"pli":"Khattiyānaṁ kule bhadde, ","html":"<span class='verse-line'>{}</span>"},"ja531:51.4":{"pli":"kiṁ nu sukhataraṁ tato. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:52.1":{"pli":"Mayūrakoñcābhirude, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:52.2":{"pli":"kokilābhinikūjite; ","html":"<span class='verse-line'>{}</span>"},"ja531:52.3":{"pli":"Khattiyānaṁ kule bhadde, ","html":"<span class='verse-line'>{}</span>"},"ja531:52.4":{"pli":"kiṁ nu sukhataraṁ tato”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:53.1":{"pli":"“Kahaṁ nu so sattumaddano, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:53.2":{"pli":"pararaṭṭhappamaddano; ","html":"<span class='verse-line'>{}</span>"},"ja531:53.3":{"pli":"Kuso soḷārapaññāṇo, ","html":"<span class='verse-line'>{}</span>"},"ja531:53.4":{"pli":"yo no dukkhā pamocaye”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:54.1":{"pli":"“Idheva so sattumaddano, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:54.2":{"pli":"pararaṭṭhappamaddano; ","html":"<span class='verse-line'>{}</span>"},"ja531:54.3":{"pli":"Kuso soḷārapaññāṇo, ","html":"<span class='verse-line'>{}</span>"},"ja531:54.4":{"pli":"yo te sabbe vadhissati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:55.1":{"pli":"“Ummattikā nu bhaṇasi, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:55.2":{"pli":"Andhabālā pabhāsasi; ","html":"<span class='verse-line'>{}</span>"},"ja531:55.3":{"pli":"Kuso ce āgato assa, ","html":"<span class='verse-line'>{}</span>"},"ja531:55.4":{"pli":"Kiṁ na jānemu taṁ mayaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:56.1":{"pli":"“Eso āḷāriko poso, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:56.2":{"pli":"kumārīpuramantare; ","html":"<span class='verse-line'>{}</span>"},"ja531:56.3":{"pli":"Daḷhaṁ katvāna saṁvelliṁ, ","html":"<span class='verse-line'>{}</span>"},"ja531:56.4":{"pli":"kumbhiṁ dhovati oṇato”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:57.1":{"pli":"“Veṇī tvamasi caṇḍālī, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:57.2":{"pli":"adūsi kulagandhinī; ","html":"<span class='verse-line'>{}</span>"},"ja531:57.3":{"pli":"Kathaṁ maddakule jātā, ","html":"<span class='verse-line'>{}</span>"},"ja531:57.4":{"pli":"dāsaṁ kayirāsi kāmukaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:58.1":{"pli":"“Namhi veṇī na caṇḍālī, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:58.2":{"pli":"na camhi kulagandhinī; ","html":"<span class='verse-line'>{}</span>"},"ja531:58.3":{"pli":"Okkākaputto bhaddante, ","html":"<span class='verse-line'>{}</span>"},"ja531:58.4":{"pli":"tvaṁ nu dāsoti maññasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:59.1":{"pli":"“Yo brāhmaṇasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:59.2":{"pli":"sadā bhojeti vīsatiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja531:59.3":{"pli":"Okkākaputto bhaddante, ","html":"<span class='verse-line'>{}</span>"},"ja531:59.4":{"pli":"tvaṁ nu dāsoti maññasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:60.1":{"pli":"Yassa nāgasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:60.2":{"pli":"sadā yojenti vīsatiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja531:60.3":{"pli":"Okkākaputto bhaddante, ","html":"<span class='verse-line'>{}</span>"},"ja531:60.4":{"pli":"tvaṁ nu dāsoti maññasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:61.1":{"pli":"Yassa assasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:61.2":{"pli":"sadā yojenti vīsatiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja531:61.3":{"pli":"Okkākaputto bhaddante, ","html":"<span class='verse-line'>{}</span>"},"ja531:61.4":{"pli":"tvaṁ nu dāsoti maññasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:62.1":{"pli":"Yassa rathasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:62.2":{"pli":"sadā yojenti vīsatiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja531:62.3":{"pli":"Okkākaputto bhaddante, ","html":"<span class='verse-line'>{}</span>"},"ja531:62.4":{"pli":"tvaṁ nu dāsoti maññasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:63.1":{"pli":"Yassa usabhasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:63.2":{"pli":"sadā yojenti vīsatiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja531:63.3":{"pli":"Okkākaputto bhaddante, ","html":"<span class='verse-line'>{}</span>"},"ja531:63.4":{"pli":"tvaṁ nu dāsoti maññasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:64.1":{"pli":"Yassa dhenusahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:64.2":{"pli":"sadā duhanti vīsatiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja531:64.3":{"pli":"Okkākaputto bhaddante, ","html":"<span class='verse-line'>{}</span>"},"ja531:64.4":{"pli":"tvaṁ nu dāsoti maññasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:65.1":{"pli":"“Taggha te dukkaṭaṁ bāle, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:65.2":{"pli":"yaṁ khattiyaṁ mahabbalaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja531:65.3":{"pli":"Nāgaṁ maṇḍūkavaṇṇena, ","html":"<span class='verse-line'>{}</span>"},"ja531:65.4":{"pli":"na naṁ akkhāsidhāgataṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:66.1":{"pli":"“Aparādhaṁ mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:66.2":{"pli":"tvaṁ no khama rathesabha; ","html":"<span class='verse-line'>{}</span>"},"ja531:66.3":{"pli":"Yaṁ taṁ aññātavesena, ","html":"<span class='verse-line'>{}</span>"},"ja531:66.4":{"pli":"nāññāsimhā idhāgataṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:67.1":{"pli":"“Mādisassa na taṁ channaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:67.2":{"pli":"yohaṁ āḷāriko bhave; ","html":"<span class='verse-line'>{}</span>"},"ja531:67.3":{"pli":"Tvaññeva me pasīdassu, ","html":"<span class='verse-line'>{}</span>"},"ja531:67.4":{"pli":"natthi te deva dukkaṭaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:68.1":{"pli":"“Gaccha bāle khamāpehi, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:68.2":{"pli":"kusarājaṁ mahabbalaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja531:68.3":{"pli":"Khamāpito kuso rājā, ","html":"<span class='verse-line'>{}</span>"},"ja531:68.4":{"pli":"so te dassati jīvitaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:69.1":{"pli":"“Pitussa vacanaṁ sutvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:69.2":{"pli":"devavaṇṇī pabhāvatī; ","html":"<span class='verse-line'>{}</span>"},"ja531:69.3":{"pli":"Sirasā aggahī pāde, ","html":"<span class='verse-line'>{}</span>"},"ja531:69.4":{"pli":"kusarājaṁ mahabbalaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:70.1":{"pli":"“Yāmā ratyo atikkantā, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:70.2":{"pli":"tāmā deva tayā vinā; ","html":"<span class='verse-line'>{}</span>"},"ja531:70.3":{"pli":"Vande te sirasā pāde, ","html":"<span class='verse-line'>{}</span>"},"ja531:70.4":{"pli":"mā me kujjha rathesabha. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:71.1":{"pli":"Sabbaṁ te paṭijānāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:71.2":{"pli":"mahārāja suṇohi me; ","html":"<span class='verse-line'>{}</span>"},"ja531:71.3":{"pli":"Na cāpi appiyaṁ tuyhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja531:71.4":{"pli":"kareyyāmi ahaṁ puna. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:72.1":{"pli":"Evañce yācamānāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:72.2":{"pli":"vacanaṁ me na kāhasi; ","html":"<span class='verse-line'>{}</span>"},"ja531:72.3":{"pli":"Idāni maṁ tāto hantvā, ","html":"<span class='verse-line'>{}</span>"},"ja531:72.4":{"pli":"khattiyānaṁ padassati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:73.1":{"pli":"“Evaṁ te yācamānāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:73.2":{"pli":"kiṁ na kāhāmi te vaco; ","html":"<span class='verse-line'>{}</span>"},"ja531:73.3":{"pli":"Vikuddho tyasmi kalyāṇi, ","html":"<span class='verse-line'>{}</span>"},"ja531:73.4":{"pli":"mā tvaṁ bhāyi pabhāvati. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:74.1":{"pli":"Sabbaṁ te paṭijānāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:74.2":{"pli":"rājaputti suṇohi me; ","html":"<span class='verse-line'>{}</span>"},"ja531:74.3":{"pli":"Na cāpi appiyaṁ tuyhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja531:74.4":{"pli":"kareyyāmi ahaṁ puna. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:75.1":{"pli":"Tava kāmā hi sussoṇi, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:75.2":{"pli":"pahu dukkhaṁ titikkhisaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja531:75.3":{"pli":"Bahuṁ maddakulaṁ hantvā, ","html":"<span class='verse-line'>{}</span>"},"ja531:75.4":{"pli":"nayituṁ taṁ pabhāvati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:76.1":{"pli":"“Yojayantu rathe asse, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:76.2":{"pli":"nānācitte samāhite; ","html":"<span class='verse-line'>{}</span>"},"ja531:76.3":{"pli":"Atha dakkhatha me vegaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja531:76.4":{"pli":"vidhamantassa sattavo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:77.1":{"pli":"“Tañca tattha udikkhiṁsu, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:77.2":{"pli":"rañño maddassantepure; ","html":"<span class='verse-line'>{}</span>"},"ja531:77.3":{"pli":"Vijambhamānaṁ sīhaṁva, ","html":"<span class='verse-line'>{}</span>"},"ja531:77.4":{"pli":"phoṭentaṁ diguṇaṁ bhujaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:78.1":{"pli":"Hatthikkhandhañca āruyha, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:78.2":{"pli":"āropetvā pabhāvatiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja531:78.3":{"pli":"Saṅgāmaṁ otaritvāna, ","html":"<span class='verse-line'>{}</span>"},"ja531:78.4":{"pli":"sīhanādaṁ nadī kuso. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:79.1":{"pli":"Tassa taṁ nadato sutvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:79.2":{"pli":"sīhassevitare migā; ","html":"<span class='verse-line'>{}</span>"},"ja531:79.3":{"pli":"Khattiyā vipalāyiṁsu, ","html":"<span class='verse-line'>{}</span>"},"ja531:79.4":{"pli":"kusasaddabhayaṭṭitā. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:80.1":{"pli":"Hatthārohā anīkaṭṭhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:80.2":{"pli":"rathikā pattikārakā; ","html":"<span class='verse-line'>{}</span>"},"ja531:80.3":{"pli":"Aññamaññassa chindanti, ","html":"<span class='verse-line'>{}</span>"},"ja531:80.4":{"pli":"kusasaddabhayaṭṭitā. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:81.1":{"pli":"Tasmiṁ saṅgāmasīsasmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:81.2":{"pli":"passitvā haṭṭhamānaso; ","html":"<span class='verse-line'>{}</span>"},"ja531:81.3":{"pli":"Kusassa rañño devindo, ","html":"<span class='verse-line'>{}</span>"},"ja531:81.4":{"pli":"adā verocanaṁ maṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:82.1":{"pli":"So taṁ vijitvā saṅgāmaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:82.2":{"pli":"laddhā verocanaṁ maṇiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja531:82.3":{"pli":"Hatthikkhandhagato rājā, ","html":"<span class='verse-line'>{}</span>"},"ja531:82.4":{"pli":"pāvekkhi nagaraṁ puraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:83.1":{"pli":"Jīvaggāhaṁ gahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:83.2":{"pli":"bandhitvā satta khattiye; ","html":"<span class='verse-line'>{}</span>"},"ja531:83.3":{"pli":"Sasurassupanāmesi, ","html":"<span class='verse-line'>{}</span>"},"ja531:83.4":{"pli":"ime te deva sattavo. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:84.1":{"pli":"Sabbeva te vasaṁ gatā, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:84.2":{"pli":"amittā vihatā tava; ","html":"<span class='verse-line'>{}</span>"},"ja531:84.3":{"pli":"Kāmaṁ karohi te tayā, ","html":"<span class='verse-line'>{}</span>"},"ja531:84.4":{"pli":"muñca vā te hanassu vā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:85.1":{"pli":"“Tuyheva sattavo ete, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:85.2":{"pli":"na hi te mayha sattavo; ","html":"<span class='verse-line'>{}</span>"},"ja531:85.3":{"pli":"Tvaññeva no mahārāja, ","html":"<span class='verse-line'>{}</span>"},"ja531:85.4":{"pli":"muñca vā te hanassu vā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:86.1":{"pli":"“Imā te dhītaro satta, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:86.2":{"pli":"devakaññūpamā subhā; ","html":"<span class='verse-line'>{}</span>"},"ja531:86.3":{"pli":"Dadāhi nesaṁ ekekaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja531:86.4":{"pli":"hontu jāmātaro tava”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:87.1":{"pli":"“Amhākañceva tāsañca, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:87.2":{"pli":"tvaṁ no sabbesamissaro; ","html":"<span class='verse-line'>{}</span>"},"ja531:87.3":{"pli":"Tvaññeva no mahārāja, ","html":"<span class='verse-line'>{}</span>"},"ja531:87.4":{"pli":"dehi nesaṁ yadicchasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:88.1":{"pli":"Ekamekassa ekekaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:88.2":{"pli":"adā sīhassaro kuso; ","html":"<span class='verse-line'>{}</span>"},"ja531:88.3":{"pli":"Khattiyānaṁ tadā tesaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja531:88.4":{"pli":"rañño maddassa dhītaro. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:89.1":{"pli":"Pīṇitā tena lābhena, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:89.2":{"pli":"tuṭṭhā sīhassare kuse; ","html":"<span class='verse-line'>{}</span>"},"ja531:89.3":{"pli":"Sakaraṭṭhāni pāyiṁsu, ","html":"<span class='verse-line'>{}</span>"},"ja531:89.4":{"pli":"khattiyā satta tāvade. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:90.1":{"pli":"Pabhāvatiñca ādāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:90.2":{"pli":"maṇiṁ verocanaṁ subhaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja531:90.3":{"pli":"Kusāvatiṁ kuso rājā, ","html":"<span class='verse-line'>{}</span>"},"ja531:90.4":{"pli":"agamāsi mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:91.1":{"pli":"Tyassu ekarathe yantā, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:91.2":{"pli":"pavisantā kusāvatiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja531:91.3":{"pli":"Samānā vaṇṇarūpena, ","html":"<span class='verse-line'>{}</span>"},"ja531:91.4":{"pli":"nāññamaññātirocisuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja531:92.1":{"pli":"Mātā puttena saṅgacchi, ","html":"<p><span class='verse-line'>{}</span>"},"ja531:92.2":{"pli":"ubhayo ca jayampatī; ","html":"<span class='verse-line'>{}</span>"},"ja531:92.3":{"pli":"Samaggā te tadā āsuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja531:92.4":{"pli":"phītaṁ dharaṇimāvasunti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja531:93.1":{"pli":"Kusajātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}