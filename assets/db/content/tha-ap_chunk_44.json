{"tha-ap489":{"tha-ap489:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap489'><header><ul><li class='division'>{}</li>"},"tha-ap489:0.2":{"pli":"Paṁsukūlavagga ","html":"<li>{}</li></ul>"},"tha-ap489:0.3":{"pli":"7 Pulinuppādakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap489:1.1":{"pli":"“Pabbate himavantamhi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap489:1.2":{"pli":"devalo nāma tāpaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:1.3":{"pli":"Tattha me caṅkamo āsi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:1.4":{"pli":"amanussehi māpito. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:2.1":{"pli":"Jaṭābhārena bharito, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:2.2":{"pli":"kamaṇḍaludharo sadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:2.3":{"pli":"Uttamatthaṁ gavesanto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:2.4":{"pli":"vipinā nikkhamiṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:3.1":{"pli":"Cullāsītisahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:3.2":{"pli":"sissā mayhaṁ upaṭṭhahuṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:3.3":{"pli":"Sakakammābhipasutā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:3.4":{"pli":"vasanti vipine tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:4.1":{"pli":"Assamā abhinikkhamma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:4.2":{"pli":"akaṁ pulinacetiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:4.3":{"pli":"Nānāpupphaṁ samānetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:4.4":{"pli":"taṁ cetiyamapūjayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:5.1":{"pli":"Tattha cittaṁ pasādetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:5.2":{"pli":"assamaṁ pavisāmahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:5.3":{"pli":"Sabbe sissā samāgantvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:5.4":{"pli":"etamatthaṁ pucchiṁsu maṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:6.1":{"pli":"‘Pulinena kato thūpo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:6.2":{"pli":"yaṁ tvaṁ deva namassasi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:6.3":{"pli":"Mayampi ñātumicchāma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:6.4":{"pli":"puṭṭho ācikkha no tuvaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:7.1":{"pli":"‘Niddiṭṭhā nu mantapade, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:7.2":{"pli":"cakkhumanto mahāyasā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:7.3":{"pli":"Te kho ahaṁ namassāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:7.4":{"pli":"buddhaseṭṭhe mahāyase. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:8.1":{"pli":"Kīdisā te mahāvīrā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:8.2":{"pli":"sabbaññū lokanāyakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:8.3":{"pli":"Kathaṁvaṇṇā kathaṁsīlā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:8.4":{"pli":"kīdisā te mahāyasā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:9.1":{"pli":"Bāttiṁsalakkhaṇā buddhā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:9.2":{"pli":"cattālīsadijāpi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:9.3":{"pli":"Nettā gopakhumā tesaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:9.4":{"pli":"jiñjukā phalasannibhā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:10.1":{"pli":"Gacchamānā ca te buddhā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:10.2":{"pli":"yugamattañca pekkhare; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:10.3":{"pli":"Na tesaṁ jāṇu nadati, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:10.4":{"pli":"sandhisaddo na suyyati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:11.1":{"pli":"Gacchamānā ca sugatā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:11.2":{"pli":"uddharantāva gacchare; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:11.3":{"pli":"Paṭhamaṁ dakkhiṇaṁ pādaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:11.4":{"pli":"buddhānaṁ esa dhammatā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:12.1":{"pli":"Asambhītā ca te buddhā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:12.2":{"pli":"migarājāva kesarī; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:12.3":{"pli":"Nevukkaṁsenti attānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:12.4":{"pli":"no ca vambhenti pāṇinaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:13.1":{"pli":"Mānāvamānato muttā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:13.2":{"pli":"samā sabbesu pāṇisu; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:13.3":{"pli":"Anattukkaṁsakā buddhā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:13.4":{"pli":"buddhānaṁ esa dhammatā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:14.1":{"pli":"Uppajjantā ca sambuddhā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:14.2":{"pli":"ālokaṁ dassayanti te; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:14.3":{"pli":"Chappakāraṁ pakampenti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:14.4":{"pli":"kevalaṁ vasudhaṁ imaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:15.1":{"pli":"Passanti nirayañcete, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:15.2":{"pli":"nibbāti nirayo tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:15.3":{"pli":"Pavassati mahāmegho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:15.4":{"pli":"buddhānaṁ esa dhammatā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:16.1":{"pli":"Īdisā te mahānāgā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:16.2":{"pli":"atulā ca mahāyasā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:16.3":{"pli":"Vaṇṇato anatikkantā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:16.4":{"pli":"appameyyā tathāgatā’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:17.1":{"pli":"Anumodiṁsu me vākyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:17.2":{"pli":"sabbe sissā sagāravā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:17.3":{"pli":"Tathā ca paṭipajjiṁsu, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:17.4":{"pli":"yathāsatti yathābalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:18.1":{"pli":"Paṭipūjenti pulinaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:18.2":{"pli":"sakakammābhilāsino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:18.3":{"pli":"Saddahantā mama vākyaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:18.4":{"pli":"buddhasakkatamānasā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:19.1":{"pli":"Tadā cavitvā tusitā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:19.2":{"pli":"devaputto mahāyaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:19.3":{"pli":"Uppajji mātukucchimhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:19.4":{"pli":"dasasahassi kampatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:20.1":{"pli":"Assamassāvidūramhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:20.2":{"pli":"caṅkamamhi ṭhito ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:20.3":{"pli":"Sabbe sissā samāgantvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:20.4":{"pli":"āgacchuṁ mama santike. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:21.1":{"pli":"‘Usabhova mahī nadati, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:21.2":{"pli":"migarājāva kūjati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:21.3":{"pli":"Susumārova saḷati, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:21.4":{"pli":"kiṁ vipāko bhavissati’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:22.1":{"pli":"‘Yaṁ pakittemi sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:22.2":{"pli":"sikatāthūpasantike; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:22.3":{"pli":"So dāni bhagavā satthā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:22.4":{"pli":"mātukucchimupāgami’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:23.1":{"pli":"Tesaṁ dhammakathaṁ vatvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:23.2":{"pli":"kittayitvā mahāmuniṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:23.3":{"pli":"Uyyojetvā sake sisse, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:23.4":{"pli":"pallaṅkamābhujiṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:24.1":{"pli":"Balañca vata me khīṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:24.2":{"pli":"byādhinā paramena taṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:24.3":{"pli":"Buddhaseṭṭhaṁ saritvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:24.4":{"pli":"tattha kālaṅkato ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:25.1":{"pli":"Sabbe sissā samāgantvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:25.2":{"pli":"akaṁsu citakaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:25.3":{"pli":"Kaḷevarañca me gayha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:25.4":{"pli":"citakaṁ abhiropayuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:26.1":{"pli":"Citakaṁ parivāretvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:26.2":{"pli":"sīse katvāna añjaliṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:26.3":{"pli":"Sokasallaparetā te, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:26.4":{"pli":"vikkandiṁsu samāgatā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:27.1":{"pli":"Tesaṁ lālappamānānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:27.2":{"pli":"agamaṁ citakaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:27.3":{"pli":"‘Ahaṁ ācariyo tumhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:27.4":{"pli":"mā socittha sumedhasā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:28.1":{"pli":"Sadatthe vāyameyyātha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:28.2":{"pli":"rattindivamatanditā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:28.3":{"pli":"Mā vo pamattā ahuttha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:28.4":{"pli":"khaṇo vo paṭipādito’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:29.1":{"pli":"Sake sissenusāsitvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:29.2":{"pli":"devalokaṁ punāgamiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:29.3":{"pli":"Aṭṭhārasa ca kappāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:29.4":{"pli":"devaloke ramāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:30.1":{"pli":"Satānaṁ pañcakkhattuñca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:30.2":{"pli":"cakkavattī ahosahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:30.3":{"pli":"Anekasatakkhattuñca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:30.4":{"pli":"devarajjamakārayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:31.1":{"pli":"Avasesesu kappesu, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:31.2":{"pli":"vokiṇṇo saṁsariṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:31.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:31.4":{"pli":"uppādassa idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:32.1":{"pli":"Yathā komudike māse, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:32.2":{"pli":"bahū pupphanti pādapā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:32.3":{"pli":"Tathevāhampi samaye, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:32.4":{"pli":"pupphitomhi mahesinā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:33.1":{"pli":"Vīriyaṁ me dhuradhorayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:33.2":{"pli":"yogakkhemādhivāhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:33.3":{"pli":"Nāgova bandhanaṁ chetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:33.4":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:34.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:34.2":{"pli":"yaṁ buddhamabhikittayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:34.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:34.4":{"pli":"kittanāya idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:35.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:35.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:35.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:36.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:36.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:36.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap489:37.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap489:37.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap489:37.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap489:38.1":{"pli":"Itthaṁ sudaṁ āyasmā pulinuppādako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap489:39.1":{"pli":"Pulinuppādakattherassāpadānaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap49":{"tha-ap49:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap49'><header><ul><li class='division'>{}</li>"},"tha-ap49:0.2":{"pli":"Upālivagga ","html":"<li>{}</li></ul>"},"tha-ap49:0.3":{"pli":"Sayanadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap49:1.1":{"pli":"“Siddhatthassa bhagavato, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap49:1.2":{"pli":"mettacittassa tādino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap49:1.3":{"pli":"Sayanaggaṁ mayā dinnaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap49:1.4":{"pli":"dussabhaṇḍehi atthataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap49:2.1":{"pli":"Paṭiggahesi bhagavā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap49:2.2":{"pli":"kappiyaṁ sayanāsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap49:2.3":{"pli":"Uṭṭhāya sayanā tamhā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap49:2.4":{"pli":"vehāsaṁ uggamī jino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap49:3.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap49:3.2":{"pli":"yaṁ sayanamadāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap49:3.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap49:3.4":{"pli":"sayanassa idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap49:4.1":{"pli":"Ekapaññāsito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap49:4.2":{"pli":"varako devasavhayo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap49:4.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap49:4.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap49:5.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap49:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap49:5.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap49:6.1":{"pli":"Itthaṁ sudaṁ āyasmā sayanadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap49:7.1":{"pli":"Sayanadāyakattherassāpadānaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap490":{"tha-ap490:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap490'><header><ul><li class='division'>{}</li>"},"tha-ap490:0.2":{"pli":"Paṁsukūlavagga ","html":"<li>{}</li></ul>"},"tha-ap490:0.3":{"pli":"Taraṇiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap490:1.1":{"pli":"“Atthadassī tu bhagavā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap490:1.2":{"pli":"sayambhū lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap490:1.3":{"pli":"Vinatā nadiyā tīraṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap490:1.4":{"pli":"upāgacchi tathāgato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap490:2.1":{"pli":"Udakā abhinikkhamma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap490:2.2":{"pli":"kacchapo vārigocaro; ","html":"<span class='verse-line'>{}</span>"},"tha-ap490:2.3":{"pli":"Buddhaṁ tāretukāmohaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap490:2.4":{"pli":"upesiṁ lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap490:3.1":{"pli":"‘Abhirūhatu maṁ buddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap490:3.2":{"pli":"atthadassī mahāmuni; ","html":"<span class='verse-line'>{}</span>"},"tha-ap490:3.3":{"pli":"Ahaṁ taṁ tārayissāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap490:3.4":{"pli":"dukkhassantakaro tuvaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap490:4.1":{"pli":"Mama saṅkappamaññāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap490:4.2":{"pli":"atthadassī mahāyaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap490:4.3":{"pli":"Abhirūhitvā me piṭṭhiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap490:4.4":{"pli":"aṭṭhāsi lokanāyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap490:5.1":{"pli":"Yato sarāmi attānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap490:5.2":{"pli":"yato pattosmi viññutaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap490:5.3":{"pli":"Sukhaṁ me tādisaṁ natthi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap490:5.4":{"pli":"phuṭṭhe pādatale yathā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap490:6.1":{"pli":"Uttaritvāna sambuddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap490:6.2":{"pli":"atthadassī mahāyaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap490:6.3":{"pli":"Naditīramhi ṭhatvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap490:6.4":{"pli":"imā gāthā abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap490:7.1":{"pli":"‘Yāvatā vattate cittaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap490:7.2":{"pli":"gaṅgāsotaṁ tarāmahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap490:7.3":{"pli":"Ayañca kacchapo rājā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap490:7.4":{"pli":"tāresi mama paññavā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap490:8.1":{"pli":"Iminā buddhataraṇena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap490:8.2":{"pli":"mettacittavatāya ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap490:8.3":{"pli":"Aṭṭhārase kappasate, ","html":"<span class='verse-line'>{}</span>"},"tha-ap490:8.4":{"pli":"devaloke ramissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap490:9.1":{"pli":"Devalokā idhāgantvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap490:9.2":{"pli":"sukkamūlena codito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap490:9.3":{"pli":"Ekāsane nisīditvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap490:9.4":{"pli":"kaṅkhāsotaṁ tarissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap490:10.1":{"pli":"Yathāpi bhaddake khette, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap490:10.2":{"pli":"bījaṁ appampi ropitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap490:10.3":{"pli":"Sammādhāre pavecchante, ","html":"<span class='verse-line'>{}</span>"},"tha-ap490:10.4":{"pli":"phalaṁ toseti kassakaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap490:11.1":{"pli":"Tathevidaṁ buddhakhettaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap490:11.2":{"pli":"sammāsambuddhadesitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap490:11.3":{"pli":"Sammādhāre pavecchante, ","html":"<span class='verse-line'>{}</span>"},"tha-ap490:11.4":{"pli":"phalaṁ maṁ tosayissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap490:12.1":{"pli":"Padhānapahitattomhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap490:12.2":{"pli":"upasanto nirūpadhi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap490:12.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap490:12.4":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap490:13.1":{"pli":"Aṭṭhārase kappasate, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap490:13.2":{"pli":"yaṁ kammamakariṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap490:13.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap490:13.4":{"pli":"taraṇāya idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap490:14.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap490:14.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap490:14.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap490:15.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap490:15.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap490:15.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap490:16.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap490:16.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap490:16.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap490:17.1":{"pli":"Itthaṁ sudaṁ āyasmā taraṇiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap490:18.1":{"pli":"Taraṇiyattherassāpadānaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap491":{"tha-ap491:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap491'><header><ul><li class='division'>{}</li>"},"tha-ap491:0.2":{"pli":"Paṁsukūlavagga ","html":"<li>{}</li></ul>"},"tha-ap491:0.3":{"pli":"9 Dhammaruciyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap491:1.1":{"pli":"“Yadā dīpaṅkaro buddho, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap491:1.2":{"pli":"sumedhaṁ byākarī jino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:1.3":{"pli":"‘Aparimeyye ito kappe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:1.4":{"pli":"ayaṁ buddho bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap491:2.1":{"pli":"Imassa janikā mātā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap491:2.2":{"pli":"māyā nāma bhavissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:2.3":{"pli":"Pitā suddhodano nāma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:2.4":{"pli":"ayaṁ hessati gotamo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap491:3.1":{"pli":"Padhānaṁ padahitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap491:3.2":{"pli":"katvā dukkarakārikaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:3.3":{"pli":"Assatthamūle sambuddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:3.4":{"pli":"bujjhissati mahāyaso. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap491:4.1":{"pli":"Upatisso kolito ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap491:4.2":{"pli":"aggā hessanti sāvakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:4.3":{"pli":"Ānando nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:4.4":{"pli":"upaṭṭhissatimaṁ jinaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap491:5.1":{"pli":"Khemā uppalavaṇṇā ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap491:5.2":{"pli":"aggā hessanti sāvikā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:5.3":{"pli":"Citto āḷavako ceva, ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:5.4":{"pli":"aggā hessantupāsakā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap491:6.1":{"pli":"Khujjuttarā nandamātā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap491:6.2":{"pli":"aggā hessantupāsikā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:6.3":{"pli":"Bodhi imassa vīrassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:6.4":{"pli":"assatthoti pavuccati’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap491:7.1":{"pli":"Idaṁ sutvāna vacanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap491:7.2":{"pli":"asamassa mahesino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:7.3":{"pli":"Āmoditā naramarū, ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:7.4":{"pli":"namassanti katañjalī. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap491:8.1":{"pli":"Tadāhaṁ māṇavo āsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap491:8.2":{"pli":"megho nāma susikkhito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:8.3":{"pli":"Sutvā byākaraṇaṁ seṭṭhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:8.4":{"pli":"sumedhassa mahāmune. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap491:9.1":{"pli":"Saṁvisaṭṭho bhavitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap491:9.2":{"pli":"sumedhe karuṇāsaye; ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:9.3":{"pli":"Pabbajantañca taṁ vīraṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:9.4":{"pli":"sahāva anupabbajiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap491:10.1":{"pli":"Saṁvuto pātimokkhasmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap491:10.2":{"pli":"indriyesu ca pañcasu; ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:10.3":{"pli":"Suddhājīvo sato vīro, ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:10.4":{"pli":"jinasāsanakārako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap491:11.1":{"pli":"Evaṁ viharamānohaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap491:11.2":{"pli":"pāpamittena kenaci; ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:11.3":{"pli":"Niyojito anācāre, ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:11.4":{"pli":"sumaggā paridhaṁsito. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap491:12.1":{"pli":"Vitakkavasiko hutvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap491:12.2":{"pli":"sāsanato apakkamiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:12.3":{"pli":"Pacchā tena kumittena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:12.4":{"pli":"payutto mātughātanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap491:13.1":{"pli":"Akariṁ ānantariyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap491:13.2":{"pli":"ghātayiṁ duṭṭhamānaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:13.3":{"pli":"Tato cuto mahāvīciṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:13.4":{"pli":"upapanno sudāruṇaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap491:14.1":{"pli":"Vinipātagato santo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap491:14.2":{"pli":"saṁsariṁ dukkhito ciraṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:14.3":{"pli":"Na puno addasaṁ vīraṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:14.4":{"pli":"sumedhaṁ narapuṅgavaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap491:15.1":{"pli":"Asmiṁ kappe samuddamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap491:15.2":{"pli":"maccho āsiṁ timiṅgalo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:15.3":{"pli":"Disvāhaṁ sāgare nāvaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:15.4":{"pli":"gocaratthamupāgamiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap491:16.1":{"pli":"Disvā maṁ vāṇijā bhītā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap491:16.2":{"pli":"buddhaseṭṭhamanussaruṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:16.3":{"pli":"Gotamoti mahāghosaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:16.4":{"pli":"sutvā tehi udīritaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap491:17.1":{"pli":"Pubbasaññaṁ saritvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap491:17.2":{"pli":"tato kālaṅkato ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:17.3":{"pli":"Sāvatthiyaṁ kule iddhe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:17.4":{"pli":"jāto brāhmaṇajātiyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap491:18.1":{"pli":"Āsiṁ dhammaruci nāma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap491:18.2":{"pli":"sabbapāpajigucchako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:18.3":{"pli":"Disvāhaṁ lokapajjotaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:18.4":{"pli":"jātiyā sattavassiko. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap491:19.1":{"pli":"Mahājetavanaṁ gantvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap491:19.2":{"pli":"pabbajiṁ anagāriyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:19.3":{"pli":"Upemi buddhaṁ tikkhattuṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:19.4":{"pli":"rattiyā divasassa ca. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap491:20.1":{"pli":"Tadā disvā muni āha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap491:20.2":{"pli":"ciraṁ dhammarucīti maṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:20.3":{"pli":"Tatohaṁ avacaṁ buddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:20.4":{"pli":"pubbakammapabhāvitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap491:21.1":{"pli":"Suciraṁ satapuññalakkhaṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap491:21.2":{"pli":"Patipubbena visuddhapaccayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:21.3":{"pli":"Ahamajjasupekkhanaṁ vata, ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:21.4":{"pli":"Tava passāmi nirupamaṁ viggahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap491:22.1":{"pli":"Suciraṁ vihatattamo mayā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap491:22.2":{"pli":"Sucirakkhena nadī visositā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:22.3":{"pli":"Suciraṁ amalaṁ visodhitaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:22.4":{"pli":"Nayanaṁ ñāṇamayaṁ mahāmune. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap491:23.1":{"pli":"Cirakālasamaṅgito tayā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap491:23.2":{"pli":"Avinaṭṭho punarantaraṁ ciraṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:23.3":{"pli":"Punarajjasamāgato tayā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:23.4":{"pli":"Na hi nassanti katāni gotama. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap491:24.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap491:24.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:24.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap491:25.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap491:25.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:25.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap491:26.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap491:26.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap491:26.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap491:27.1":{"pli":"Itthaṁ sudaṁ āyasmā dhammaruciyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap491:28.1":{"pli":"Dhammaruciyattherassāpadānaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap492":{"tha-ap492:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap492'><header><ul><li class='division'>{}</li>"},"tha-ap492:0.2":{"pli":"Paṁsukūlavagga ","html":"<li>{}</li></ul>"},"tha-ap492:0.3":{"pli":"Sālamaṇḍapiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap492:1.1":{"pli":"“Ajjhogāhetvā sālavanaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap492:1.2":{"pli":"sukato assamo mama; ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:1.3":{"pli":"Sālapupphehi sañchanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:1.4":{"pli":"vasāmi vipine tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap492:2.1":{"pli":"Piyadassī ca bhagavā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap492:2.2":{"pli":"sayambhū aggapuggalo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:2.3":{"pli":"Vivekakāmo sambuddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:2.4":{"pli":"sālavanamupāgami. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap492:3.1":{"pli":"Assamā abhinikkhamma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap492:3.2":{"pli":"pavanaṁ agamāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:3.3":{"pli":"Mūlaphalaṁ gavesanto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:3.4":{"pli":"āhiṇḍāmi vane tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap492:4.1":{"pli":"Tatthaddasāsiṁ sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap492:4.2":{"pli":"piyadassiṁ mahāyasaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:4.3":{"pli":"Sunisinnaṁ samāpannaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:4.4":{"pli":"virocantaṁ mahāvane. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap492:5.1":{"pli":"Catudaṇḍe ṭhapetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap492:5.2":{"pli":"buddhassa uparī ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:5.3":{"pli":"Maṇḍapaṁ sukataṁ katvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:5.4":{"pli":"sālapupphehi chādayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap492:6.1":{"pli":"Sattāhaṁ dhārayitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap492:6.2":{"pli":"maṇḍapaṁ sālachāditaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:6.3":{"pli":"Tattha cittaṁ pasādetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:6.4":{"pli":"buddhaseṭṭhamavandahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap492:7.1":{"pli":"Bhagavā tamhi samaye, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap492:7.2":{"pli":"vuṭṭhahitvā samādhito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:7.3":{"pli":"Yugamattaṁ pekkhamāno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:7.4":{"pli":"nisīdi purisuttamo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap492:8.1":{"pli":"Sāvako varuṇo nāma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap492:8.2":{"pli":"piyadassissa satthuno; ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:8.3":{"pli":"Vasīsatasahassehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:8.4":{"pli":"upagacchi vināyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap492:9.1":{"pli":"Piyadassī ca bhagavā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap492:9.2":{"pli":"lokajeṭṭho narāsabho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:9.3":{"pli":"Bhikkhusaṅghe nisīditvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:9.4":{"pli":"sitaṁ pātukarī jino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap492:10.1":{"pli":"Anuruddho upaṭṭhāko, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap492:10.2":{"pli":"piyadassissa satthuno; ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:10.3":{"pli":"Ekaṁsaṁ cīvaraṁ katvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:10.4":{"pli":"apucchittha mahāmuniṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap492:11.1":{"pli":"‘Ko nu kho bhagavā hetu, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap492:11.2":{"pli":"sitakammassa satthuno; ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:11.3":{"pli":"Kāraṇe vijjamānamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:11.4":{"pli":"satthā pātukare sitaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap492:12.1":{"pli":"‘Sattāhaṁ sālacchadanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap492:12.2":{"pli":"yo me dhāresi māṇavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:12.3":{"pli":"Tassa kammaṁ saritvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:12.4":{"pli":"sitaṁ pātukariṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap492:13.1":{"pli":"Anokāsaṁ na passāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap492:13.2":{"pli":"yattha puññaṁ vipaccati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:13.3":{"pli":"Devaloke manusse vā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:13.4":{"pli":"okāsova na sammati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap492:14.1":{"pli":"Devaloke vasantassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap492:14.2":{"pli":"puññakammasamaṅgino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:14.3":{"pli":"Yāvatā parisā tassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:14.4":{"pli":"sālacchannā bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap492:15.1":{"pli":"Tattha dibbehi naccehi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap492:15.2":{"pli":"gītehi vāditehi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:15.3":{"pli":"Ramissati sadā santo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:15.4":{"pli":"puññakammasamāhito. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap492:16.1":{"pli":"Yāvatā parisā tassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap492:16.2":{"pli":"gandhagandhī bhavissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:16.3":{"pli":"Sālassa pupphavasso ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:16.4":{"pli":"pavassissati tāvade. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap492:17.1":{"pli":"Tato cutoyaṁ manujo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap492:17.2":{"pli":"mānusaṁ āgamissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:17.3":{"pli":"Idhāpi sālacchadanaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:17.4":{"pli":"sabbakālaṁ dharissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap492:18.1":{"pli":"Idha naccañca gītañca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap492:18.2":{"pli":"sammatāḷasamāhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:18.3":{"pli":"Parivāressanti maṁ niccaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:18.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap492:19.1":{"pli":"Uggacchante ca sūriye, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap492:19.2":{"pli":"sālavassaṁ pavassati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:19.3":{"pli":"Puññakammena saṁyuttaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:19.4":{"pli":"vassate sabbakālikaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap492:20.1":{"pli":"Aṭṭhārase kappasate, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap492:20.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:20.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:20.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap492:21.1":{"pli":"Tassa dhammesu dāyādo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap492:21.2":{"pli":"oraso dhammanimmito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:21.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:21.4":{"pli":"nibbāyissatināsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap492:22.1":{"pli":"Dhammaṁ abhisamentassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap492:22.2":{"pli":"sālacchannaṁ bhavissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:22.3":{"pli":"Citake jhāyamānassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:22.4":{"pli":"chadanaṁ tattha hessati’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap492:23.1":{"pli":"Vipākaṁ kittayitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap492:23.2":{"pli":"piyadassī mahāmuni; ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:23.3":{"pli":"Parisāya dhammaṁ desesi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:23.4":{"pli":"tappento dhammavuṭṭhiyā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap492:24.1":{"pli":"Tiṁsakappāni devesu, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap492:24.2":{"pli":"devarajjamakārayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:24.3":{"pli":"Saṭṭhi ca sattakkhattuñca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:24.4":{"pli":"cakkavattī ahosahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap492:25.1":{"pli":"Devalokā idhāgantvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap492:25.2":{"pli":"labhāmi vipulaṁ sukhaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:25.3":{"pli":"Idhāpi sālacchadanaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:25.4":{"pli":"maṇḍapassa idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap492:26.1":{"pli":"Ayaṁ pacchimako mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap492:26.2":{"pli":"carimo vattate bhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:26.3":{"pli":"Idhāpi sālacchadanaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:26.4":{"pli":"hessati sabbakālikaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap492:27.1":{"pli":"Mahāmuniṁ tosayitvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap492:27.2":{"pli":"gotamaṁ sakyapuṅgavaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:27.3":{"pli":"Pattomhi acalaṁ ṭhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:27.4":{"pli":"hitvā jayaparājayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap492:28.1":{"pli":"Aṭṭhārase kappasate, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap492:28.2":{"pli":"yaṁ buddhamabhipūjayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:28.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:28.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap492:29.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap492:29.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:29.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap492:30.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap492:30.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:30.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap492:31.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap492:31.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:31.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap492:32.1":{"pli":"Itthaṁ sudaṁ āyasmā sālamaṇḍapiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap492:33.1":{"pli":"Sālamaṇḍapiyattherassāpadānaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap492:34.1":{"pli":"Paṁsukūlavaggo ekūnapaññāsamo. ","html":"<p class='endsection'>{}</p>"},"tha-ap492:35.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"tha-ap492:36.1":{"pli":"Paṁsukūlaṁ buddhasaññī, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"tha-ap492:36.2":{"pli":"bhisado ñāṇakittako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:36.3":{"pli":"Candanī dhātupūjī ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:36.4":{"pli":"pulinuppādakopi ca. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap492:37.1":{"pli":"Taraṇo dhammaruciko, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap492:37.2":{"pli":"sālamaṇḍapiyo tathā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:37.3":{"pli":"Satāni dve honti gāthā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap492:37.4":{"pli":"ūnavīsatimeva ca. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}}}