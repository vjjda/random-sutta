{"vv64":{"vv64:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv64'><header><ul><li class='division'>{}</li>"},"vv64:0.2":{"pli":"Purisavimāna ","html":"<li>{}</li>"},"vv64:0.3":{"pli":"Mahārathavagga ","html":"<li>{}</li></ul>"},"vv64:0.4":{"pli":"14. Mahārathavimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv64:1.1":{"pli":"“Sahassayuttaṁ hayavāhanaṁ subhaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv64:1.2":{"pli":"Āruyhimaṁ sandanaṁ nekacittaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv64:1.3":{"pli":"Uyyānabhūmiṁ abhito anukkamaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv64:1.4":{"pli":"Purindado bhūtapatīva vāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:2.1":{"pli":"Sovaṇṇamayā te rathakubbarā ubho, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:2.2":{"pli":"Phalehi aṁsehi atīva saṅgatā; ","html":"<span class='verse-line'>{}</span>"},"vv64:2.3":{"pli":"Sujātagumbā naravīraniṭṭhitā, ","html":"<span class='verse-line'>{}</span>"},"vv64:2.4":{"pli":"Virocatī pannaraseva cando. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:3.1":{"pli":"Suvaṇṇajālāvatato ratho ayaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:3.2":{"pli":"Bahūhi nānāratanehi cittito; ","html":"<span class='verse-line'>{}</span>"},"vv64:3.3":{"pli":"Sunandighoso ca subhassaro ca, ","html":"<span class='verse-line'>{}</span>"},"vv64:3.4":{"pli":"Virocatī cāmarahatthabāhubhi. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:4.1":{"pli":"Imā ca nābhyo manasābhinimmitā, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:4.2":{"pli":"Rathassa pādantaramajjhabhūsitā; ","html":"<span class='verse-line'>{}</span>"},"vv64:4.3":{"pli":"Imā ca nābhyo satarājicittitā, ","html":"<span class='verse-line'>{}</span>"},"vv64:4.4":{"pli":"Sateratā vijjurivappabhāsare. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:5.1":{"pli":"Anekacittāvatato ratho ayaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:5.2":{"pli":"Puthū ca nemī ca sahassaraṁsiko; ","html":"<span class='verse-line'>{}</span>"},"vv64:5.3":{"pli":"Tesaṁ saro suyyati vaggurūpo, ","html":"<span class='verse-line'>{}</span>"},"vv64:5.4":{"pli":"Pañcaṅgikaṁ tūriyamivappavāditaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:6.1":{"pli":"Sirasmiṁ cittaṁ maṇicandakappitaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:6.2":{"pli":"Sadā visuddhaṁ ruciraṁ pabhassaraṁ; ","html":"<span class='verse-line'>{}</span>"},"vv64:6.3":{"pli":"Suvaṇṇarājīhi atīva saṅgataṁ, ","html":"<span class='verse-line'>{}</span>"},"vv64:6.4":{"pli":"Veḷuriyarājīva atīva sobhati. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:7.1":{"pli":"Ime ca vāḷī maṇicandakappitā, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:7.2":{"pli":"Ārohakambū sujavā brahūpamā; ","html":"<span class='verse-line'>{}</span>"},"vv64:7.3":{"pli":"Brahā mahantā balino mahājavā, ","html":"<span class='verse-line'>{}</span>"},"vv64:7.4":{"pli":"Mano tavaññāya tatheva siṁsare. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:8.1":{"pli":"Ime ca sabbe sahitā catukkamā, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:8.2":{"pli":"Mano tavaññāya tatheva siṁsare; ","html":"<span class='verse-line'>{}</span>"},"vv64:8.3":{"pli":"Samaṁ vahantī mudukā anuddhatā, ","html":"<span class='verse-line'>{}</span>"},"vv64:8.4":{"pli":"Āmodamānā turagānamuttama. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:9.1":{"pli":"Dhunanti vagganti patanti cambare, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:9.2":{"pli":"Abbhuddhunantā sukate piḷandhane; ","html":"<span class='verse-line'>{}</span>"},"vv64:9.3":{"pli":"Tesaṁ saro suyyati vaggurūpo, ","html":"<span class='verse-line'>{}</span>"},"vv64:9.4":{"pli":"Pañcaṅgikaṁ tūriyamivappavāditaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:10.1":{"pli":"Rathassa ghoso apiḷandhanāna ca, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:10.2":{"pli":"Khurassa nādo abhihiṁsanāya ca; ","html":"<span class='verse-line'>{}</span>"},"vv64:10.3":{"pli":"Ghoso suvaggū samitassa suyyati, ","html":"<span class='verse-line'>{}</span>"},"vv64:10.4":{"pli":"Gandhabbatūriyāni vicitrasaṁvane. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:11.1":{"pli":"Rathe ṭhitā tā migamandalocanā, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:11.2":{"pli":"Āḷārapamhā hasitā piyaṁvadā; ","html":"<span class='verse-line'>{}</span>"},"vv64:11.3":{"pli":"Veḷuriyajālāvatatā tanucchavā, ","html":"<span class='verse-line'>{}</span>"},"vv64:11.4":{"pli":"Sadeva gandhabbasūraggapūjitā. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:12.1":{"pli":"Tā rattarattambarapītavāsasā, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:12.2":{"pli":"Visālanettā abhirattalocanā; ","html":"<span class='verse-line'>{}</span>"},"vv64:12.3":{"pli":"Kule sujātā sutanū sucimhitā, ","html":"<span class='verse-line'>{}</span>"},"vv64:12.4":{"pli":"Rathe ṭhitā pañjalikā upaṭṭhitā. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:13.1":{"pli":"Tā kambukeyūradharā suvāsasā, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:13.2":{"pli":"Sumajjhimā ūruthanūpapannā; ","html":"<span class='verse-line'>{}</span>"},"vv64:13.3":{"pli":"Vaṭṭaṅguliyo sumukhā sudassanā, ","html":"<span class='verse-line'>{}</span>"},"vv64:13.4":{"pli":"Rathe ṭhitā pañjalikā upaṭṭhitā. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:14.1":{"pli":"Aññā suveṇī susu missakesiyo, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:14.2":{"pli":"Samaṁ vibhattāhi pabhassarāhi ca; ","html":"<span class='verse-line'>{}</span>"},"vv64:14.3":{"pli":"Anubbatā tā tava mānase ratā, ","html":"<span class='verse-line'>{}</span>"},"vv64:14.4":{"pli":"Rathe ṭhitā pañjalikā upaṭṭhitā. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:15.1":{"pli":"Āveḷiniyo padumuppalacchadā, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:15.2":{"pli":"Alaṅkatā candanasāravāsitā; ","html":"<span class='verse-line'>{}</span>"},"vv64:15.3":{"pli":"Anubbatā tā tava mānase ratā, ","html":"<span class='verse-line'>{}</span>"},"vv64:15.4":{"pli":"Rathe ṭhitā pañjalikā upaṭṭhitā. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:16.1":{"pli":"Tā māliniyo padumuppalacchadā, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:16.2":{"pli":"Alaṅkatā candanasāravāsitā; ","html":"<span class='verse-line'>{}</span>"},"vv64:16.3":{"pli":"Anubbatā tā tava mānase ratā, ","html":"<span class='verse-line'>{}</span>"},"vv64:16.4":{"pli":"Rathe ṭhitā pañjalikā upaṭṭhitā. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:17.1":{"pli":"Kaṇṭhesu te yāni piḷandhanāni, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:17.2":{"pli":"Hatthesu pādesu tatheva sīse; ","html":"<span class='verse-line'>{}</span>"},"vv64:17.3":{"pli":"Obhāsayantī dasa sabbaso disā, ","html":"<span class='verse-line'>{}</span>"},"vv64:17.4":{"pli":"Abbhuddayaṁ sāradikova bhāṇumā. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:18.1":{"pli":"Vātassa vegena ca sampakampitā, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:18.2":{"pli":"Bhujesu mālā apiḷandhanāni ca; ","html":"<span class='verse-line'>{}</span>"},"vv64:18.3":{"pli":"Muñcanti ghosaṁ ruciraṁ suciṁ subhaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv64:18.4":{"pli":"Sabbehi viññūhi sutabbarūpaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:19.1":{"pli":"Uyyānabhūmyā ca duvaddhato ṭhitā, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:19.2":{"pli":"Rathā ca nāgā tūriyāni ca saro; ","html":"<span class='verse-line'>{}</span>"},"vv64:19.3":{"pli":"Tameva devinda pamodayanti, ","html":"<span class='verse-line'>{}</span>"},"vv64:19.4":{"pli":"Vīṇā yathā pokkharapattabāhubhi. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:20.1":{"pli":"Imāsu vīṇāsu bahūsu vaggūsu, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:20.2":{"pli":"Manuññarūpāsu hadayeritaṁ pītiṁ; ","html":"<span class='verse-line'>{}</span>"},"vv64:20.3":{"pli":"Pavajjamānāsu atīva accharā, ","html":"<span class='verse-line'>{}</span>"},"vv64:20.4":{"pli":"Bhamanti kaññā padumesu sikkhitā. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:21.1":{"pli":"Yadā ca gītāni ca vāditāni ca, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:21.2":{"pli":"Naccāni cimāni samenti ekato; ","html":"<span class='verse-line'>{}</span>"},"vv64:21.3":{"pli":"Athettha naccanti athettha accharā, ","html":"<span class='verse-line'>{}</span>"},"vv64:21.4":{"pli":"Obhāsayantī ubhato varitthiyo. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:22.1":{"pli":"So modasi tūriyagaṇappabodhano, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:22.2":{"pli":"Mahīyamāno vajirāvudhoriva; ","html":"<span class='verse-line'>{}</span>"},"vv64:22.3":{"pli":"Imāsu vīṇāsu bahūsu vaggūsu, ","html":"<span class='verse-line'>{}</span>"},"vv64:22.4":{"pli":"Manuññarūpāsu hadayeritaṁ pītiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:23.1":{"pli":"Kiṁ tvaṁ pure kammamakāsi attanā, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:23.2":{"pli":"Manussabhūto purimāya jātiyā; ","html":"<span class='verse-line'>{}</span>"},"vv64:23.3":{"pli":"Uposathaṁ kaṁ vā tuvaṁ upāvasi, ","html":"<span class='verse-line'>{}</span>"},"vv64:23.4":{"pli":"Kaṁ dhammacariyaṁ vatamābhirocayi. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:24.1":{"pli":"Nayīdamappassa katassa kammuno, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:24.2":{"pli":"Pubbe suciṇṇassa uposathassa vā; ","html":"<span class='verse-line'>{}</span>"},"vv64:24.3":{"pli":"Iddhānubhāvo vipulo ayaṁ tava, ","html":"<span class='verse-line'>{}</span>"},"vv64:24.4":{"pli":"Yaṁ devasaṅghaṁ abhirocase bhusaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:25.1":{"pli":"Dānassa te idaṁ phalaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:25.2":{"pli":"atho sīlassa vā pana; ","html":"<span class='verse-line'>{}</span>"},"vv64:25.3":{"pli":"Atho añjalikammassa, ","html":"<span class='verse-line'>{}</span>"},"vv64:25.4":{"pli":"taṁ me akkhāhi pucchito”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:26.1":{"pli":"So devaputto attamano, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:26.2":{"pli":"moggallānena pucchito; ","html":"<span class='verse-line'>{}</span>"},"vv64:26.3":{"pli":"Pañhaṁ puṭṭho viyākāsi, ","html":"<span class='verse-line'>{}</span>"},"vv64:26.4":{"pli":"yassa kammassidaṁ phalanti. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:27.1":{"pli":"“Jitindriyaṁ buddhamanomanikkamaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:27.2":{"pli":"Naruttamaṁ kassapamaggapuggalaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv64:27.3":{"pli":"Avāpurantaṁ amatassa dvāraṁ, ","html":"<span class='verse-line'>{}</span>"},"vv64:27.4":{"pli":"Devātidevaṁ satapuññalakkhaṇaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:28.1":{"pli":"Tamaddasaṁ kuñjaramoghatiṇṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:28.2":{"pli":"Suvaṇṇasiṅgīnadabimbasādisaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv64:28.3":{"pli":"Disvāna taṁ khippamahuṁ sucīmano, ","html":"<span class='verse-line'>{}</span>"},"vv64:28.4":{"pli":"Tameva disvāna subhāsitaddhajaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:29.1":{"pli":"Tamannapānaṁ athavāpi cīvaraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:29.2":{"pli":"Suciṁ paṇītaṁ rasasā upetaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv64:29.3":{"pli":"Pupphābhikkiṇamhi sake nivesane, ","html":"<span class='verse-line'>{}</span>"},"vv64:29.4":{"pli":"Patiṭṭhapesiṁ sa asaṅgamānaso. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:30.1":{"pli":"Tamannapānena ca cīvarena ca, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:30.2":{"pli":"Khajjena bhojjena ca sāyanena ca; ","html":"<span class='verse-line'>{}</span>"},"vv64:30.3":{"pli":"Santappayitvā dvipadānamuttamaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv64:30.4":{"pli":"So saggaso devapure ramāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:31.1":{"pli":"Etenupāyena imaṁ niraggaḷaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:31.2":{"pli":"Yaññaṁ yajitvā tividhaṁ visuddhaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv64:31.3":{"pli":"Pahāyahaṁ mānusakaṁ samussayaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv64:31.4":{"pli":"Indūpamo devapure ramāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:32.1":{"pli":"Āyuñca vaṇṇañca sukhaṁ balañca, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:32.2":{"pli":"Paṇītarūpaṁ abhikaṅkhatā muni; ","html":"<span class='verse-line'>{}</span>"},"vv64:32.3":{"pli":"Annañca pānañca bahuṁ susaṅkhataṁ, ","html":"<span class='verse-line'>{}</span>"},"vv64:32.4":{"pli":"Patiṭṭhapetabbamasaṅgamānase. ","html":"<span class='verse-line'>{}</span></p>"},"vv64:33.1":{"pli":"Nayimasmiṁ loke parasmiṁ vā pana, ","html":"<p><span class='verse-line'>{}</span>"},"vv64:33.2":{"pli":"Buddhena seṭṭho va samo va vijjati; ","html":"<span class='verse-line'>{}</span>"},"vv64:33.3":{"pli":"Āhuneyyānaṁ paramāhutiṁ gato, ","html":"<span class='verse-line'>{}</span>"},"vv64:33.4":{"pli":"Puññatthikānaṁ vipulapphalesinan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv64:34.1":{"pli":"Mahārathavimānaṁ cuddasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"vv64:34.2":{"pli":"Mahārathavaggo pañcamo. ","html":"<p class='endvagga'>{}</p>"},"vv64:35.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"vv64:36.1":{"pli":"Maṇḍūko revatī chatto, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"vv64:36.2":{"pli":"Kakkaṭo dvārapālako; ","html":"<span class='verse-line'>{}</span>"},"vv64:36.3":{"pli":"Dve karaṇīyā dve sūci, ","html":"<span class='verse-line'>{}</span>"},"vv64:36.4":{"pli":"Tayo nāgā ca dve rathā; ","html":"<span class='verse-line'>{}</span>"},"vv64:36.5":{"pli":"Purisānaṁ paṭhamo vaggo pavuccatīti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv64:37.1":{"pli":"Bhāṇavāraṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"vv65":{"vv65:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv65'><header><ul><li class='division'>{}</li>"},"vv65:0.2":{"pli":"Purisavimāna ","html":"<li>{}</li>"},"vv65:0.3":{"pli":"Pāyāsivagga ","html":"<li>{}</li></ul>"},"vv65:0.4":{"pli":"1. Paṭhamaagāriyavimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv65:1.1":{"pli":"“Yathā vanaṁ cittalataṁ pabhāsati, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv65:1.2":{"pli":"Uyyānaseṭṭhaṁ tidasānamuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv65:1.3":{"pli":"Tathūpamaṁ tuyhamidaṁ vimānaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv65:1.4":{"pli":"Obhāsayaṁ tiṭṭhati antalikkhe. ","html":"<span class='verse-line'>{}</span></p>"},"vv65:2.1":{"pli":"Deviddhipattosi mahānubhāvo, ","html":"<p><span class='verse-line'>{}</span>"},"vv65:2.2":{"pli":"Manussabhūto kimakāsi puññaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv65:2.3":{"pli":"Kenāsi evaṁ jalitānubhāvo, ","html":"<span class='verse-line'>{}</span>"},"vv65:2.4":{"pli":"Vaṇṇo ca te sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv65:3.1":{"pli":"So devaputto attamano, ","html":"<p><span class='verse-line'>{}</span>"},"vv65:3.2":{"pli":"moggallānena pucchito; ","html":"<span class='verse-line'>{}</span>"},"vv65:3.3":{"pli":"Pañhaṁ puṭṭho viyākāsi, ","html":"<span class='verse-line'>{}</span>"},"vv65:3.4":{"pli":"yassa kammassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv65:4.1":{"pli":"“Ahañca bhariyā ca manussaloke, ","html":"<p><span class='verse-line'>{}</span>"},"vv65:4.2":{"pli":"Opānabhūtā gharamāvasimha; ","html":"<span class='verse-line'>{}</span>"},"vv65:4.3":{"pli":"Annañca pānañca pasannacittā, ","html":"<span class='verse-line'>{}</span>"},"vv65:4.4":{"pli":"Sakkacca dānaṁ vipulaṁ adamha. ","html":"<span class='verse-line'>{}</span></p>"},"vv65:5.1":{"pli":"Tena metādiso vaṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"vv65:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"vv65:5.3":{"pli":"Vaṇṇo ca me sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv65:6.1":{"pli":"Paṭhamaagāriyavimānaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"vv66":{"vv66:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv66'><header><ul><li class='division'>{}</li>"},"vv66:0.2":{"pli":"Purisavimāna ","html":"<li>{}</li>"},"vv66:0.3":{"pli":"Pāyāsivagga ","html":"<li>{}</li></ul>"},"vv66:0.4":{"pli":"2. Dutiyaagāriyavimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv66:1.1":{"pli":"“Yathā vanaṁ cittalataṁ pabhāsati, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv66:1.2":{"pli":"Uyyānaseṭṭhaṁ tidasānamuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv66:1.3":{"pli":"Tathūpamaṁ tuyhamidaṁ vimānaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv66:1.4":{"pli":"Obhāsayaṁ tiṭṭhati antalikkhe. ","html":"<span class='verse-line'>{}</span></p>"},"vv66:2.1":{"pli":"Deviddhipattosi mahānubhāvo, ","html":"<p><span class='verse-line'>{}</span>"},"vv66:2.2":{"pli":"Manussabhūto kimakāsi puññaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv66:2.3":{"pli":"Kenāsi evaṁ jalitānubhāvo, ","html":"<span class='verse-line'>{}</span>"},"vv66:2.4":{"pli":"Vaṇṇo ca te sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv66:3.1":{"pli":"So devaputto attamano, ","html":"<p><span class='verse-line'>{}</span>"},"vv66:3.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"vv66:3.3":{"pli":"yassa kammassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv66:4.1":{"pli":"“Ahañca bhariyā ca manussaloke, ","html":"<p><span class='verse-line'>{}</span>"},"vv66:4.2":{"pli":"Opānabhūtā gharamāvasimha; ","html":"<span class='verse-line'>{}</span>"},"vv66:4.3":{"pli":"Annañca pānañca pasannacittā, ","html":"<span class='verse-line'>{}</span>"},"vv66:4.4":{"pli":"Sakkacca dānaṁ vipulaṁ adamha. ","html":"<span class='verse-line'>{}</span></p>"},"vv66:5.1":{"pli":"Tena metādiso vaṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"vv66:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"vv66:5.3":{"pli":"Vaṇṇo ca me sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv66:6.1":{"pli":"Dutiyaagāriyavimānaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"vv67":{"vv67:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv67'><header><ul><li class='division'>{}</li>"},"vv67:0.2":{"pli":"Purisavimāna ","html":"<li>{}</li>"},"vv67:0.3":{"pli":"Pāyāsivagga ","html":"<li>{}</li></ul>"},"vv67:0.4":{"pli":"3. Phaladāyakavimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv67:1.1":{"pli":"“Uccamidaṁ maṇithūṇaṁ vimānaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv67:1.2":{"pli":"Samantato soḷasa yojanāni; ","html":"<span class='verse-line'>{}</span>"},"vv67:1.3":{"pli":"Kūṭāgārā sattasatā uḷārā, ","html":"<span class='verse-line'>{}</span>"},"vv67:1.4":{"pli":"Veḷuriyathambhā rucakatthatā subhā. ","html":"<span class='verse-line'>{}</span></p>"},"vv67:2.1":{"pli":"Tatthacchasi pivasi khādasi ca, ","html":"<p><span class='verse-line'>{}</span>"},"vv67:2.2":{"pli":"Dibbā ca vīṇā pavadanti vagguṁ; ","html":"<span class='verse-line'>{}</span>"},"vv67:2.3":{"pli":"Aṭṭhaṭṭhakā sikkhitā sādhurūpā, ","html":"<span class='verse-line'>{}</span>"},"vv67:2.4":{"pli":"Dibbā ca kaññā tidasacarā uḷārā; ","html":"<span class='verse-line'>{}</span>"},"vv67:2.5":{"pli":"Naccanti gāyanti pamodayanti. ","html":"<span class='verse-line'>{}</span></p>"},"vv67:3.1":{"pli":"Deviddhipattosi mahānubhāvo, ","html":"<p><span class='verse-line'>{}</span>"},"vv67:3.2":{"pli":"Manussabhūto kimakāsi puññaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv67:3.3":{"pli":"Kenāsi evaṁ jalitānubhāvo, ","html":"<span class='verse-line'>{}</span>"},"vv67:3.4":{"pli":"Vaṇṇo ca te sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv67:4.1":{"pli":"So devaputto attamano, ","html":"<p><span class='verse-line'>{}</span>"},"vv67:4.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"vv67:4.3":{"pli":"Yassa kammassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv67:5.1":{"pli":"“Phaladāyī phalaṁ vipulaṁ labhati, ","html":"<p><span class='verse-line'>{}</span>"},"vv67:5.2":{"pli":"Dadamujugatesu pasannamānaso; ","html":"<span class='verse-line'>{}</span>"},"vv67:5.3":{"pli":"So hi pamodati saggagato tidive, ","html":"<span class='verse-line'>{}</span>"},"vv67:5.4":{"pli":"Anubhoti ca puññaphalaṁ vipulaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv67:6.1":{"pli":"Tavevāhaṁ mahāmuni, ","html":"<p><span class='verse-line'>{}</span>"},"vv67:6.2":{"pli":"Adāsiṁ caturo phale. ","html":"<span class='verse-line'>{}</span></p>"},"vv67:7.1":{"pli":"Tasmā hi phalaṁ alameva dātuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv67:7.2":{"pli":"Niccaṁ manussena sukhatthikena; ","html":"<span class='verse-line'>{}</span>"},"vv67:7.3":{"pli":"Dibbāni vā patthayatā sukhāni, ","html":"<span class='verse-line'>{}</span>"},"vv67:7.4":{"pli":"Manussasobhaggatamicchatā vā. ","html":"<span class='verse-line'>{}</span></p>"},"vv67:8.1":{"pli":"Tena metādiso vaṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"vv67:8.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"vv67:8.3":{"pli":"Vaṇṇo ca me sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv67:9.1":{"pli":"Phaladāyakavimānaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"vv68":{"vv68:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv68'><header><ul><li class='division'>{}</li>"},"vv68:0.2":{"pli":"Purisavimāna ","html":"<li>{}</li>"},"vv68:0.3":{"pli":"Pāyāsivagga ","html":"<li>{}</li></ul>"},"vv68:0.4":{"pli":"4. Paṭhamaupassayadāyakavimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv68:1.1":{"pli":"“Cando yathā vigatavalāhake nabhe, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv68:1.2":{"pli":"Obhāsayaṁ gacchati antalikkhe; ","html":"<span class='verse-line'>{}</span>"},"vv68:1.3":{"pli":"Tathūpamaṁ tuyhamidaṁ vimānaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv68:1.4":{"pli":"Obhāsayaṁ tiṭṭhati antalikkhe. ","html":"<span class='verse-line'>{}</span></p>"},"vv68:2.1":{"pli":"Deviddhipattosi mahānubhāvo, ","html":"<p><span class='verse-line'>{}</span>"},"vv68:2.2":{"pli":"Manussabhūto kimakāsi puññaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv68:2.3":{"pli":"Kenāsi evaṁ jalitānubhāvo, ","html":"<span class='verse-line'>{}</span>"},"vv68:2.4":{"pli":"Vaṇṇo ca te sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv68:3.1":{"pli":"So devaputto attamano, ","html":"<p><span class='verse-line'>{}</span>"},"vv68:3.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"vv68:3.3":{"pli":"yassa kammassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv68:4.1":{"pli":"“Ahañca bhariyā ca manussaloke, ","html":"<p><span class='verse-line'>{}</span>"},"vv68:4.2":{"pli":"Upassayaṁ arahato adamha; ","html":"<span class='verse-line'>{}</span>"},"vv68:4.3":{"pli":"Annañca pānañca pasannacittā, ","html":"<span class='verse-line'>{}</span>"},"vv68:4.4":{"pli":"Sakkacca dānaṁ vipulaṁ adamha. ","html":"<span class='verse-line'>{}</span></p>"},"vv68:5.1":{"pli":"Tena metādiso vaṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"vv68:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"vv68:5.3":{"pli":"Vaṇṇo ca me sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv68:6.1":{"pli":"Paṭhamaupassayadāyakavimānaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"vv69":{"vv69:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv69'><header><ul><li class='division'>{}</li>"},"vv69:0.2":{"pli":"Purisavimāna ","html":"<li>{}</li>"},"vv69:0.3":{"pli":"Pāyāsivagga ","html":"<li>{}</li></ul>"},"vv69:0.4":{"pli":"5. Dutiyaupassayadāyakavimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv69:1.1":{"pli":"Suriyo yathā vigatavalāhake nabhe, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv69:1.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv69:2.1":{"pli":"(Yathā purimavimānaṁ tathā vitthāretabbaṁ.) ","html":"<p class='endsutta'>{}</p>"},"vv69:3.1":{"pli":"“Tena metādiso vaṇṇo, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"vv69:3.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"vv69:3.3":{"pli":"Vaṇṇo ca me sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv69:4.1":{"pli":"Dutiyaupassayadāyakavimānaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"vv7":{"vv7:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv7'><header><ul><li class='division'>{}</li>"},"vv7:0.2":{"pli":"Itthivimāna ","html":"<li>{}</li>"},"vv7:0.3":{"pli":"Pīṭhavagga ","html":"<li>{}</li></ul>"},"vv7:0.4":{"pli":"7. Dutiyanāvāvimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv7:1.1":{"pli":"“Suvaṇṇacchadanaṁ nāvaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv7:1.2":{"pli":"Nāri āruyha tiṭṭhasi; ","html":"<span class='verse-line'>{}</span>"},"vv7:1.3":{"pli":"Ogāhasi pokkharaṇiṁ, ","html":"<span class='verse-line'>{}</span>"},"vv7:1.4":{"pli":"Padmaṁ chindasi pāṇinā. ","html":"<span class='verse-line'>{}</span></p>"},"vv7:2.1":{"pli":"Kena tetādiso vaṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"vv7:2.2":{"pli":"kena te idha mijjhati; ","html":"<span class='verse-line'>{}</span>"},"vv7:2.3":{"pli":"Uppajjanti ca te bhogā, ","html":"<span class='verse-line'>{}</span>"},"vv7:2.4":{"pli":"ye keci manaso piyā. ","html":"<span class='verse-line'>{}</span></p>"},"vv7:3.1":{"pli":"Pucchāmi taṁ devi mahānubhāve, ","html":"<p><span class='verse-line'>{}</span>"},"vv7:3.2":{"pli":"Manussabhūtā kimakāsi puññaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv7:3.3":{"pli":"Kenāsi evaṁ jalitānubhāvā, ","html":"<span class='verse-line'>{}</span>"},"vv7:3.4":{"pli":"Vaṇṇo ca te sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv7:4.1":{"pli":"Sā devatā attamanā, ","html":"<p><span class='verse-line'>{}</span>"},"vv7:4.2":{"pli":"moggallānena pucchitā; ","html":"<span class='verse-line'>{}</span>"},"vv7:4.3":{"pli":"Pañhaṁ puṭṭhā viyākāsi, ","html":"<span class='verse-line'>{}</span>"},"vv7:4.4":{"pli":"yassa kammassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv7:5.1":{"pli":"“Ahaṁ manussesu manussabhūtā, ","html":"<p><span class='verse-line'>{}</span>"},"vv7:5.2":{"pli":"Purimāya jātiyā manussaloke; ","html":"<span class='verse-line'>{}</span>"},"vv7:5.3":{"pli":"Disvāna bhikkhuṁ tasitaṁ kilantaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv7:5.4":{"pli":"Uṭṭhāya pātuṁ udakaṁ adāsiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv7:6.1":{"pli":"Yo ve kilantassa pipāsitassa, ","html":"<p><span class='verse-line'>{}</span>"},"vv7:6.2":{"pli":"Uṭṭhāya pātuṁ udakaṁ dadāti; ","html":"<span class='verse-line'>{}</span>"},"vv7:6.3":{"pli":"Sītodakā tassa bhavanti najjo, ","html":"<span class='verse-line'>{}</span>"},"vv7:6.4":{"pli":"Pahūtamalyā bahupuṇḍarīkā. ","html":"<span class='verse-line'>{}</span></p>"},"vv7:7.1":{"pli":"Taṁ āpagā anupariyanti sabbadā, ","html":"<p><span class='verse-line'>{}</span>"},"vv7:7.2":{"pli":"Sītodakā vālukasanthatā nadī; ","html":"<span class='verse-line'>{}</span>"},"vv7:7.3":{"pli":"Ambā ca sālā tilakā ca jambuyo, ","html":"<span class='verse-line'>{}</span>"},"vv7:7.4":{"pli":"Uddālakā pāṭaliyo ca phullā. ","html":"<span class='verse-line'>{}</span></p>"},"vv7:8.1":{"pli":"Taṁ bhūmibhāgehi upetarūpaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv7:8.2":{"pli":"Vimānaseṭṭhaṁ bhusa sobhamānaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv7:8.3":{"pli":"Tassīdha kammassa ayaṁ vipāko, ","html":"<span class='verse-line'>{}</span>"},"vv7:8.4":{"pli":"Etādisaṁ puññakatā labhanti. ","html":"<span class='verse-line'>{}</span></p>"},"vv7:9.1":{"pli":"Tena metādiso vaṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"vv7:9.2":{"pli":"tena me idha mijjhati; ","html":"<span class='verse-line'>{}</span>"},"vv7:9.3":{"pli":"Uppajjanti ca me bhogā, ","html":"<span class='verse-line'>{}</span>"},"vv7:9.4":{"pli":"ye keci manaso piyā. ","html":"<span class='verse-line'>{}</span></p>"},"vv7:10.1":{"pli":"Akkhāmi te bhikkhu mahānubhāva, ","html":"<p><span class='verse-line'>{}</span>"},"vv7:10.2":{"pli":"Manussabhūtā yamakāsi puññaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv7:10.3":{"pli":"Tenamhi evaṁ jalitānubhāvā, ","html":"<span class='verse-line'>{}</span>"},"vv7:10.4":{"pli":"Vaṇṇo ca me sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv7:11.1":{"pli":"Dutiyanāvāvimānaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"vv70":{"vv70:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv70'><header><ul><li class='division'>{}</li>"},"vv70:0.2":{"pli":"Purisavimāna ","html":"<li>{}</li>"},"vv70:0.3":{"pli":"Pāyāsivagga ","html":"<li>{}</li></ul>"},"vv70:0.4":{"pli":"6. Bhikkhādāyakavimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv70:1.1":{"pli":"“Uccamidaṁ maṇithūṇaṁ vimānaṁ, ","html":"<blockquote class='gatha'><p><span cla