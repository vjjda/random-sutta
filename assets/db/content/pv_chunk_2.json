{"pv20":{"pv20:0.1":{"pli":"Petavatthu ","html":"<article id='pv20'><header><ul><li class='division'>{}</li>"},"pv20:0.2":{"pli":"Ubbarivagga ","html":"<li>{}</li></ul>"},"pv20:0.3":{"pli":"8. Cūḷaseṭṭhipetavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv20:1.1":{"pli":"“Naggo kiso pabbajitosi bhante, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv20:1.2":{"pli":"Rattiṁ kuhiṁ gacchasi kissa hetu; ","html":"<span class='verse-line'>{}</span>"},"pv20:1.3":{"pli":"Ācikkha me taṁ api sakkuṇemu, ","html":"<span class='verse-line'>{}</span>"},"pv20:1.4":{"pli":"Sabbena vittaṁ paṭipādaye tuvan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv20:2.1":{"pli":"“Bārāṇasī nagaraṁ dūraghuṭṭhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv20:2.2":{"pli":"Tatthāhaṁ gahapati aḍḍhako ahu dīno; ","html":"<span class='verse-line'>{}</span>"},"pv20:2.3":{"pli":"Adātā gedhitamano āmisasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"pv20:2.4":{"pli":"Dussīlyena yamavisayamhi patto. ","html":"<span class='verse-line'>{}</span></p>"},"pv20:3.1":{"pli":"So sūcikāya kilamito tehi, ","html":"<p><span class='verse-line'>{}</span>"},"pv20:3.2":{"pli":"Teneva ñātīsu yāmi āmisakiñcikkhahetu; ","html":"<span class='verse-line'>{}</span>"},"pv20:3.3":{"pli":"Adānasīlā na ca saddahanti, ","html":"<span class='verse-line'>{}</span>"},"pv20:3.4":{"pli":"Dānaphalaṁ hoti paramhi loke. ","html":"<span class='verse-line'>{}</span></p>"},"pv20:4.1":{"pli":"Dhītā ca mayhaṁ lapate abhikkhaṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv20:4.2":{"pli":"‘Dassāmi dānaṁ pitūnaṁ pitāmahānaṁ’; ","html":"<span class='verse-line'>{}</span>"},"pv20:4.3":{"pli":"Tamupakkhaṭaṁ parivisayanti brāhmaṇā, ","html":"<span class='verse-line'>{}</span>"},"pv20:4.4":{"pli":"‘Yāmi ahaṁ andhakavindaṁ bhottun’”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv20:5.1":{"pli":"Tamavoca rājā “anubhaviyāna tampi, ","html":"<p><span class='verse-line'>{}</span>"},"pv20:5.2":{"pli":"Eyyāsi khippaṁ ahamapi kassaṁ pūjaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv20:5.3":{"pli":"Ācikkha me taṁ yadi atthi hetu, ","html":"<span class='verse-line'>{}</span>"},"pv20:5.4":{"pli":"Saddhāyitaṁ hetuvaco suṇomā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv20:6.1":{"pli":"“Tathā”ti vatvā agamāsi tattha, ","html":"<p><span class='verse-line'>{}</span>"},"pv20:6.2":{"pli":"Bhuñjiṁsu bhattaṁ na ca dakkhiṇārahā; ","html":"<span class='verse-line'>{}</span>"},"pv20:6.3":{"pli":"Paccāgami rājagahaṁ punāparaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv20:6.4":{"pli":"Pāturahosi purato janādhipassa. ","html":"<span class='verse-line'>{}</span></p>"},"pv20:7.1":{"pli":"Disvāna petaṁ punadeva āgataṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv20:7.2":{"pli":"Rājā avoca “ahamapi kiṁ dadāmi; ","html":"<span class='verse-line'>{}</span>"},"pv20:7.3":{"pli":"Ācikkha me taṁ yadi atthi hetu, ","html":"<span class='verse-line'>{}</span>"},"pv20:7.4":{"pli":"Yena tuvaṁ cirataraṁ pīṇito siyā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv20:8.1":{"pli":"“Buddhañca saṅghaṁ parivisiyāna rāja, ","html":"<p><span class='verse-line'>{}</span>"},"pv20:8.2":{"pli":"Annena pānena ca cīvarena; ","html":"<span class='verse-line'>{}</span>"},"pv20:8.3":{"pli":"Taṁ dakkhiṇaṁ ādisa me hitāya, ","html":"<span class='verse-line'>{}</span>"},"pv20:8.4":{"pli":"Evaṁ ahaṁ cirataraṁ pīṇito siyā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv20:9.1":{"pli":"Tato ca rājā nipatitvā tāvade, ","html":"<p><span class='verse-line'>{}</span>"},"pv20:9.2":{"pli":"Dānaṁ sahatthā atulaṁ daditvā saṅghe; ","html":"<span class='verse-line'>{}</span>"},"pv20:9.3":{"pli":"Ārocesi pakataṁ tathāgatassa, ","html":"<span class='verse-line'>{}</span>"},"pv20:9.4":{"pli":"Tassa ca petassa dakkhiṇaṁ ādisittha. ","html":"<span class='verse-line'>{}</span></p>"},"pv20:10.1":{"pli":"So pūjito ativiya sobhamāno, ","html":"<p><span class='verse-line'>{}</span>"},"pv20:10.2":{"pli":"Pāturahosi purato janādhipassa; ","html":"<span class='verse-line'>{}</span>"},"pv20:10.3":{"pli":"“Yakkhohamasmi paramiddhipatto, ","html":"<span class='verse-line'>{}</span>"},"pv20:10.4":{"pli":"Na mayhamatthi samā sadisā mānusā. ","html":"<span class='verse-line'>{}</span></p>"},"pv20:11.1":{"pli":"Passānubhāvaṁ aparimitaṁ mamayidaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv20:11.2":{"pli":"Tayānudiṭṭhaṁ atulaṁ datvā saṅghe; ","html":"<span class='verse-line'>{}</span>"},"pv20:11.3":{"pli":"Santappito satataṁ sadā bahūhi, ","html":"<span class='verse-line'>{}</span>"},"pv20:11.4":{"pli":"Yāmi ahaṁ sukhito manussadevā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv20:12.1":{"pli":"Cūḷaseṭṭhipetavatthu aṭṭhamaṁ. ","html":"<p class='endsutta'>{}<br>"},"pv20:12.2":{"pli":"Bhāṇavāraṁ paṭhamaṁ. ","html":"{}</p></article>"}},"pv21":{"pv21:0.1":{"pli":"Petavatthu ","html":"<article id='pv21'><header><ul><li class='division'>{}</li>"},"pv21:0.2":{"pli":"Ubbarivagga ","html":"<li>{}</li></ul>"},"pv21:0.3":{"pli":"9. Aṅkurapetavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv21:1.1":{"pli":"“Yassa atthāya gacchāma, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv21:1.2":{"pli":"kambojaṁ dhanahārakā; ","html":"<span class='verse-line'>{}</span>"},"pv21:1.3":{"pli":"Ayaṁ kāmadado yakkho, ","html":"<span class='verse-line'>{}</span>"},"pv21:1.4":{"pli":"imaṁ yakkhaṁ nayāmase. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:2.1":{"pli":"Imaṁ yakkhaṁ gahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:2.2":{"pli":"Sādhukena pasayha vā; ","html":"<span class='verse-line'>{}</span>"},"pv21:2.3":{"pli":"Yānaṁ āropayitvāna, ","html":"<span class='verse-line'>{}</span>"},"pv21:2.4":{"pli":"Khippaṁ gacchāma dvārakan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:3.1":{"pli":"“Yassa rukkhassa chāyāya, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:3.2":{"pli":"nisīdeyya sayeyya vā; ","html":"<span class='verse-line'>{}</span>"},"pv21:3.3":{"pli":"Na tassa sākhaṁ bhañjeyya, ","html":"<span class='verse-line'>{}</span>"},"pv21:3.4":{"pli":"mittadubbho hi pāpako”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:4.1":{"pli":"“Yassa rukkhassa chāyāya, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:4.2":{"pli":"nisīdeyya sayeyya vā; ","html":"<span class='verse-line'>{}</span>"},"pv21:4.3":{"pli":"Khandhampi tassa chindeyya, ","html":"<span class='verse-line'>{}</span>"},"pv21:4.4":{"pli":"attho ce tādiso siyā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:5.1":{"pli":"“Yassa rukkhassa chāyāya, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:5.2":{"pli":"nisīdeyya sayeyya vā; ","html":"<span class='verse-line'>{}</span>"},"pv21:5.3":{"pli":"Na tassa pattaṁ bhindeyya, ","html":"<span class='verse-line'>{}</span>"},"pv21:5.4":{"pli":"mittadubbho hi pāpako”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:6.1":{"pli":"“Yassa rukkhassa chāyāya, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:6.2":{"pli":"nisīdeyya sayeyya vā; ","html":"<span class='verse-line'>{}</span>"},"pv21:6.3":{"pli":"Samūlampi taṁ abbuhe, ","html":"<span class='verse-line'>{}</span>"},"pv21:6.4":{"pli":"attho ce tādiso siyā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:7.1":{"pli":"“Yassekarattimpi ghare vaseyya, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:7.2":{"pli":"Yatthannapānaṁ puriso labhetha; ","html":"<span class='verse-line'>{}</span>"},"pv21:7.3":{"pli":"Na tassa pāpaṁ manasāpi cintaye, ","html":"<span class='verse-line'>{}</span>"},"pv21:7.4":{"pli":"Kataññutā sappurisehi vaṇṇitā. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:8.1":{"pli":"Yassekarattimpi ghare vaseyya, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:8.2":{"pli":"Annena pānena upaṭṭhito siyā; ","html":"<span class='verse-line'>{}</span>"},"pv21:8.3":{"pli":"Na tassa pāpaṁ manasāpi cintaye, ","html":"<span class='verse-line'>{}</span>"},"pv21:8.4":{"pli":"Adubbhapāṇī dahate mittadubbhiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:9.1":{"pli":"Yo pubbe katakalyāṇo, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:9.2":{"pli":"pacchā pāpena hiṁsati; ","html":"<span class='verse-line'>{}</span>"},"pv21:9.3":{"pli":"Allapāṇihato poso, ","html":"<span class='verse-line'>{}</span>"},"pv21:9.4":{"pli":"na so bhadrāni passatī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:10.1":{"pli":"“Nāhaṁ devena vā manussena vā, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:10.2":{"pli":"Issariyena vāhaṁ suppasayho; ","html":"<span class='verse-line'>{}</span>"},"pv21:10.3":{"pli":"Yakkhohamasmi paramiddhipatto, ","html":"<span class='verse-line'>{}</span>"},"pv21:10.4":{"pli":"Dūraṅgamo vaṇṇabalūpapanno”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:11.1":{"pli":"“Pāṇi te sabbaso vaṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:11.2":{"pli":"pañcadhāro madhussavo; ","html":"<span class='verse-line'>{}</span>"},"pv21:11.3":{"pli":"Nānārasā paggharanti, ","html":"<span class='verse-line'>{}</span>"},"pv21:11.4":{"pli":"maññehaṁ taṁ purindadan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:12.1":{"pli":"“Nāmhi devo na gandhabbo, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:12.2":{"pli":"nāpi sakko purindado; ","html":"<span class='verse-line'>{}</span>"},"pv21:12.3":{"pli":"Petaṁ maṁ aṅkura jānāhi, ","html":"<span class='verse-line'>{}</span>"},"pv21:12.4":{"pli":"roruvamhā idhāgatan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:13.1":{"pli":"“Kiṁsīlo kiṁsamācāro, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:13.2":{"pli":"roruvasmiṁ pure tuvaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv21:13.3":{"pli":"Kena te brahmacariyena, ","html":"<span class='verse-line'>{}</span>"},"pv21:13.4":{"pli":"puññaṁ pāṇimhi ijjhatī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:14.1":{"pli":"“Tunnavāyo pure āsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:14.2":{"pli":"roruvasmiṁ tadā ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv21:14.3":{"pli":"Sukicchavutti kapaṇo, ","html":"<span class='verse-line'>{}</span>"},"pv21:14.4":{"pli":"na me vijjati dātave. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:15.1":{"pli":"Nivesanañca me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:15.2":{"pli":"asayhassa upantike; ","html":"<span class='verse-line'>{}</span>"},"pv21:15.3":{"pli":"Saddhassa dānapatino, ","html":"<span class='verse-line'>{}</span>"},"pv21:15.4":{"pli":"katapuññassa lajjino. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:16.1":{"pli":"Tattha yācanakāyanti, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:16.2":{"pli":"nānāgottā vanibbakā; ","html":"<span class='verse-line'>{}</span>"},"pv21:16.3":{"pli":"Te ca maṁ tattha pucchanti, ","html":"<span class='verse-line'>{}</span>"},"pv21:16.4":{"pli":"asayhassa nivesanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:17.1":{"pli":"Kattha gacchāma bhaddaṁ vo, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:17.2":{"pli":"kattha dānaṁ padīyati; ","html":"<span class='verse-line'>{}</span>"},"pv21:17.3":{"pli":"Tesāhaṁ puṭṭho akkhāmi, ","html":"<span class='verse-line'>{}</span>"},"pv21:17.4":{"pli":"asayhassa nivesanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:18.1":{"pli":"Paggayha dakkhiṇaṁ bāhuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:18.2":{"pli":"ettha gacchatha bhaddaṁ vo; ","html":"<span class='verse-line'>{}</span>"},"pv21:18.3":{"pli":"Ettha dānaṁ padīyati, ","html":"<span class='verse-line'>{}</span>"},"pv21:18.4":{"pli":"asayhassa nivesane. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:19.1":{"pli":"Tena pāṇi kāmadado, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:19.2":{"pli":"tena pāṇi madhussavo; ","html":"<span class='verse-line'>{}</span>"},"pv21:19.3":{"pli":"Tena me brahmacariyena, ","html":"<span class='verse-line'>{}</span>"},"pv21:19.4":{"pli":"puññaṁ pāṇimhi ijjhatī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:20.1":{"pli":"“Na kira tvaṁ adā dānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:20.2":{"pli":"Sakapāṇīhi kassaci; ","html":"<span class='verse-line'>{}</span>"},"pv21:20.3":{"pli":"Parassa dānaṁ anumodamāno, ","html":"<span class='verse-line'>{}</span>"},"pv21:20.4":{"pli":"Pāṇiṁ paggayha pāvadi. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:21.1":{"pli":"Tena pāṇi kāmadado, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:21.2":{"pli":"tena pāṇi madhussavo; ","html":"<span class='verse-line'>{}</span>"},"pv21:21.3":{"pli":"Tena te brahmacariyena, ","html":"<span class='verse-line'>{}</span>"},"pv21:21.4":{"pli":"puññaṁ pāṇimhi ijjhati. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:22.1":{"pli":"Yo so dānamadā bhante, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:22.2":{"pli":"pasanno sakapāṇibhi; ","html":"<span class='verse-line'>{}</span>"},"pv21:22.3":{"pli":"So hitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv21:22.4":{"pli":"kiṁ nu so disataṁ gato”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:23.1":{"pli":"“Nāhaṁ pajānāmi asayhasāhino, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:23.2":{"pli":"Aṅgīrasassa gatiṁ āgatiṁ vā; ","html":"<span class='verse-line'>{}</span>"},"pv21:23.3":{"pli":"Sutañca me vessavaṇassa santike, ","html":"<span class='verse-line'>{}</span>"},"pv21:23.4":{"pli":"Sakkassa sahabyataṁ gato asayho”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:24.1":{"pli":"“Alameva kātuṁ kalyāṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:24.2":{"pli":"dānaṁ dātuṁ yathārahaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv21:24.3":{"pli":"Pāṇiṁ kāmadadaṁ disvā, ","html":"<span class='verse-line'>{}</span>"},"pv21:24.4":{"pli":"ko puññaṁ na karissati. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:25.1":{"pli":"So hi nūna ito gantvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:25.2":{"pli":"anuppatvāna dvārakaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv21:25.3":{"pli":"Dānaṁ paṭṭhapayissāmi, ","html":"<span class='verse-line'>{}</span>"},"pv21:25.4":{"pli":"yaṁ mamassa sukhāvahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:26.1":{"pli":"Dassāmannañca pānañca, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:26.2":{"pli":"vatthasenāsanāni ca; ","html":"<span class='verse-line'>{}</span>"},"pv21:26.3":{"pli":"Papañca udapānañca, ","html":"<span class='verse-line'>{}</span>"},"pv21:26.4":{"pli":"dugge saṅkamanāni cā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:27.1":{"pli":"“Kena te aṅgulī kuṇā, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:27.2":{"pli":"mukhañca kuṇalīkataṁ; ","html":"<span class='verse-line'>{}</span>"},"pv21:27.3":{"pli":"Akkhīni ca paggharanti, ","html":"<span class='verse-line'>{}</span>"},"pv21:27.4":{"pli":"kiṁ pāpaṁ pakataṁ tayā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:28.1":{"pli":"“Aṅgīrasassa gahapatino, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:28.2":{"pli":"Saddhassa gharamesino; ","html":"<span class='verse-line'>{}</span>"},"pv21:28.3":{"pli":"Tassāhaṁ dānavissagge, ","html":"<span class='verse-line'>{}</span>"},"pv21:28.4":{"pli":"Dāne adhikato ahuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:29.1":{"pli":"Tattha yācanake disvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:29.2":{"pli":"āgate bhojanatthike; ","html":"<span class='verse-line'>{}</span>"},"pv21:29.3":{"pli":"Ekamantaṁ apakkamma, ","html":"<span class='verse-line'>{}</span>"},"pv21:29.4":{"pli":"akāsiṁ kuṇaliṁ mukhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:30.1":{"pli":"Tena me aṅgulī kuṇā, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:30.2":{"pli":"mukhañca kuṇalīkataṁ; ","html":"<span class='verse-line'>{}</span>"},"pv21:30.3":{"pli":"Akkhīni me paggharanti, ","html":"<span class='verse-line'>{}</span>"},"pv21:30.4":{"pli":"taṁ pāpaṁ pakataṁ mayā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:31.1":{"pli":"“Dhammena te kāpurisa, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:31.2":{"pli":"mukhañca kuṇalīkataṁ; ","html":"<span class='verse-line'>{}</span>"},"pv21:31.3":{"pli":"Akkhīni ca paggharanti, ","html":"<span class='verse-line'>{}</span>"},"pv21:31.4":{"pli":"yaṁ taṁ parassa dānassa; ","html":"<span class='verse-line'>{}</span>"},"pv21:31.5":{"pli":"Akāsi kuṇaliṁ mukhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:32.1":{"pli":"Kathaṁ hi dānaṁ dadamāno, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:32.2":{"pli":"kareyya parapattiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv21:32.3":{"pli":"Annaṁ pānaṁ khādanīyaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv21:32.4":{"pli":"vatthasenāsanāni ca. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:33.1":{"pli":"So hi nūna ito gantvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:33.2":{"pli":"anuppatvāna dvārakaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv21:33.3":{"pli":"Dānaṁ paṭṭhapayissāmi, ","html":"<span class='verse-line'>{}</span>"},"pv21:33.4":{"pli":"yaṁ mamassa sukhāvahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:34.1":{"pli":"Dassāmannañca pānañca, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:34.2":{"pli":"vatthasenāsanāni ca; ","html":"<span class='verse-line'>{}</span>"},"pv21:34.3":{"pli":"Papañca udapānañca, ","html":"<span class='verse-line'>{}</span>"},"pv21:34.4":{"pli":"dugge saṅkamanāni cā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:35.1":{"pli":"Tato hi so nivattitvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:35.2":{"pli":"anuppatvāna dvārakaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv21:35.3":{"pli":"Dānaṁ paṭṭhapayi aṅkuro, ","html":"<span class='verse-line'>{}</span>"},"pv21:35.4":{"pli":"yaṁtumassa sukhāvahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:36.1":{"pli":"Adā annañca pānañca, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:36.2":{"pli":"vatthasenāsanāni ca; ","html":"<span class='verse-line'>{}</span>"},"pv21:36.3":{"pli":"Papañca udapānañca, ","html":"<span class='verse-line'>{}</span>"},"pv21:36.4":{"pli":"vippasannena cetasā. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:37.1":{"pli":"Ko chāto ko ca tasito, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:37.2":{"pli":"ko vatthaṁ paridahissati; ","html":"<span class='verse-line'>{}</span>"},"pv21:37.3":{"pli":"Kassa santāni yoggāni, ","html":"<span class='verse-line'>{}</span>"},"pv21:37.4":{"pli":"ito yojentu vāhanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:38.1":{"pli":"Ko chatticchati gandhañca, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:38.2":{"pli":"ko mālaṁ ko upāhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv21:38.3":{"pli":"Itissu tattha ghosenti, ","html":"<span class='verse-line'>{}</span>"},"pv21:38.4":{"pli":"kappakā sūdamāgadhā; ","html":"<span class='verse-line'>{}</span>"},"pv21:38.5":{"pli":"Sadā sāyañca pāto ca, ","html":"<span class='verse-line'>{}</span>"},"pv21:38.6":{"pli":"aṅkurassa nivesane. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:39.1":{"pli":"“‘Sukhaṁ supati aṅkuro’, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:39.2":{"pli":"iti jānāti maṁ jano; ","html":"<span class='verse-line'>{}</span>"},"pv21:39.3":{"pli":"Dukkhaṁ supāmi sindhaka, ","html":"<span class='verse-line'>{}</span>"},"pv21:39.4":{"pli":"yaṁ na passāmi yācake. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:40.1":{"pli":"‘Sukhaṁ supati aṅkuro’, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:40.2":{"pli":"iti jānāti maṁ jano; ","html":"<span class='verse-line'>{}</span>"},"pv21:40.3":{"pli":"Dukkhaṁ sindhaka supāmi, ","html":"<span class='verse-line'>{}</span>"},"pv21:40.4":{"pli":"appake su vanibbake”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:41.1":{"pli":"“Sakko ce te varaṁ dajjā, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:41.2":{"pli":"tāvatiṁsānamissaro; ","html":"<span class='verse-line'>{}</span>"},"pv21:41.3":{"pli":"Kissa sabbassa lokassa, ","html":"<span class='verse-line'>{}</span>"},"pv21:41.4":{"pli":"varamāno varaṁ vare”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:42.1":{"pli":"“Sakko ce me varaṁ dajjā, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:42.2":{"pli":"tāvatiṁsānamissaro; ","html":"<span class='verse-line'>{}</span>"},"pv21:42.3":{"pli":"Kāluṭṭhitassa me sato, ","html":"<span class='verse-line'>{}</span>"},"pv21:42.4":{"pli":"sūriyuggamanaṁ pati; ","html":"<span class='verse-line'>{}</span>"},"pv21:42.5":{"pli":"Dibbā bhakkhā pātubhaveyyuṁ, ","html":"<span class='verse-line'>{}</span>"},"pv21:42.6":{"pli":"sīlavanto ca yācakā. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:43.1":{"pli":"Dadato me na khīyetha, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:43.2":{"pli":"datvā nānutapeyyahaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv21:43.3":{"pli":"Dadaṁ cittaṁ pasādeyyaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv21:43.4":{"pli":"etaṁ sakkaṁ varaṁ vare”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:44.1":{"pli":"“Na sabbavittāni pare pavecche, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:44.2":{"pli":"Dadeyya dānañca dhanañca rakkhe; ","html":"<span class='verse-line'>{}</span>"},"pv21:44.3":{"pli":"Tasmā hi dānā dhanameva seyyo, ","html":"<span class='verse-line'>{}</span>"},"pv21:44.4":{"pli":"Atippadānena kulā na honti. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:45.1":{"pli":"Adānamatidānañca, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:45.2":{"pli":"Nappasaṁsanti paṇḍitā; ","html":"<span class='verse-line'>{}</span>"},"pv21:45.3":{"pli":"Tasmā hi dānā dhanameva seyyo, ","html":"<span class='verse-line'>{}</span>"},"pv21:45.4":{"pli":"Samena vatteyya sa dhīradhammo”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:46.1":{"pli":"“Aho vata re ahameva dajjaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:46.2":{"pli":"Santo ca maṁ sappurisā bhajeyyuṁ; ","html":"<span class='verse-line'>{}</span>"},"pv21:46.3":{"pli":"Meghova ninnāni paripūrayanto, ","html":"<span class='verse-line'>{}</span>"},"pv21:46.4":{"pli":"Santappaye sabbavanibbakānaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:47.1":{"pli":"Yassa yācanake disvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:47.2":{"pli":"mukhavaṇṇo pasīdati; ","html":"<span class='verse-line'>{}</span>"},"pv21:47.3":{"pli":"Datvā attamano hoti, ","html":"<span class='verse-line'>{}</span>"},"pv21:47.4":{"pli":"taṁ gharaṁ vasato sukhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:48.1":{"pli":"Yassa yācanake disvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:48.2":{"pli":"mukhavaṇṇo pasīdati; ","html":"<span class='verse-line'>{}</span>"},"pv21:48.3":{"pli":"Datvā attamano hoti, ","html":"<span class='verse-line'>{}</span>"},"pv21:48.4":{"pli":"esā yaññassa sampadā. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:49.1":{"pli":"Pubbeva dānā sumano, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:49.2":{"pli":"dadaṁ cittaṁ pasādaye; ","html":"<span class='verse-line'>{}</span>"},"pv21:49.3":{"pli":"Datvā attamano hoti, ","html":"<span class='verse-line'>{}</span>"},"pv21:49.4":{"pli":"esā yaññassa sampadā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:50.1":{"pli":"Saṭṭhi vāhasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:50.2":{"pli":"aṅkurassa nivesane; ","html":"<span class='verse-line'>{}</span>"},"pv21:50.3":{"pli":"Bhojanaṁ dīyate niccaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv21:50.4":{"pli":"puññapekkhassa jantuno. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:51.1":{"pli":"Tisahassāni sūdāni hi, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:51.2":{"pli":"āmuttamaṇikuṇḍalā; ","html":"<span class='verse-line'>{}</span>"},"pv21:51.3":{"pli":"Aṅkuraṁ upajīvanti, ","html":"<span class='verse-line'>{}</span>"},"pv21:51.4":{"pli":"dāne yaññassa vāvaṭā. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:52.1":{"pli":"Saṭṭhi purisasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:52.2":{"pli":"āmuttamaṇikuṇḍalā; ","html":"<span class='verse-line'>{}</span>"},"pv21:52.3":{"pli":"Aṅkurassa mahādāne, ","html":"<span class='verse-line'>{}</span>"},"pv21:52.4":{"pli":"kaṭṭhaṁ phālenti māṇavā. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:53.1":{"pli":"Soḷasitthisahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:53.2":{"pli":"sabbālaṅkārabhūsitā; ","html":"<span class='verse-line'>{}</span>"},"pv21:53.3":{"pli":"Aṅkurassa mahādāne, ","html":"<span class='verse-line'>{}</span>"},"pv21:53.4":{"pli":"vidhā piṇḍenti nāriyo. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:54.1":{"pli":"Soḷasitthisahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:54.2":{"pli":"sabbālaṅkārabhūsitā; ","html":"<span class='verse-line'>{}</span>"},"pv21:54.3":{"pli":"Aṅkurassa mahādāne, ","html":"<span class='verse-line'>{}</span>"},"pv21:54.4":{"pli":"dabbigāhā upaṭṭhitā. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:55.1":{"pli":"Bahuṁ bahūnaṁ pādāsi, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:55.2":{"pli":"ciraṁ pādāsi khattiyo; ","html":"<span class='verse-line'>{}</span>"},"pv21:55.3":{"pli":"Sakkaccañca sahatthā ca, ","html":"<span class='verse-line'>{}</span>"},"pv21:55.4":{"pli":"cittīkatvā punappunaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:56.1":{"pli":"Bahū māse ca pakkhe ca, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:56.2":{"pli":"utusaṁvaccharāni ca; ","html":"<span class='verse-line'>{}</span>"},"pv21:56.3":{"pli":"Mahādānaṁ pavattesi, ","html":"<span class='verse-line'>{}</span>"},"pv21:56.4":{"pli":"aṅkuro dīghamantaraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:57.1":{"pli":"Evaṁ datvā yajitvā ca, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:57.2":{"pli":"aṅkuro dīghamantaraṁ; ","html":"<span class='verse-line'>{}</span>"},"pv21:57.3":{"pli":"So hitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv21:57.4":{"pli":"tāvatiṁsūpago ahu. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:58.1":{"pli":"Kaṭacchubhikkhaṁ datvāna, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:58.2":{"pli":"anuruddhassa indako; ","html":"<span class='verse-line'>{}</span>"},"pv21:58.3":{"pli":"So hitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv21:58.4":{"pli":"tāvatiṁsūpago ahu. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:59.1":{"pli":"Dasahi ṭhānehi aṅkuraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:59.2":{"pli":"indako atirocati; ","html":"<span class='verse-line'>{}</span>"},"pv21:59.3":{"pli":"Rūpe sadde rase gandhe, ","html":"<span class='verse-line'>{}</span>"},"pv21:59.4":{"pli":"phoṭṭhabbe ca manorame. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:60.1":{"pli":"Āyunā yasasā ceva, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:60.2":{"pli":"vaṇṇena ca sukhena ca; ","html":"<span class='verse-line'>{}</span>"},"pv21:60.3":{"pli":"Ādhipaccena aṅkuraṁ, ","html":"<span class='verse-line'>{}</span>"},"pv21:60.4":{"pli":"indako atirocati. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:61.1":{"pli":"(…) ","html":"<p>{}</p>"},"pv21:62.1":{"pli":"Tāvatiṁse yadā buddho, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:62.2":{"pli":"silāyaṁ paṇḍukambale; ","html":"<span class='verse-line'>{}</span>"},"pv21:62.3":{"pli":"Pāricchattakamūlamhi, ","html":"<span class='verse-line'>{}</span>"},"pv21:62.4":{"pli":"vihāsi purisuttamo. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:63.1":{"pli":"Dasasu lokadhātūsu, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:63.2":{"pli":"sannipatitvāna devatā; ","html":"<span class='verse-line'>{}</span>"},"pv21:63.3":{"pli":"Payirupāsanti sambuddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv21:63.4":{"pli":"vasantaṁ nagamuddhani. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:64.1":{"pli":"Na koci devo vaṇṇena, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:64.2":{"pli":"sambuddhaṁ atirocati; ","html":"<span class='verse-line'>{}</span>"},"pv21:64.3":{"pli":"Sabbe deve atikkamma, ","html":"<span class='verse-line'>{}</span>"},"pv21:64.4":{"pli":"sambuddhova virocati. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:65.1":{"pli":"Yojanāni dasa dve ca, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:65.2":{"pli":"aṅkuroyaṁ tadā ahu; ","html":"<span class='verse-line'>{}</span>"},"pv21:65.3":{"pli":"Avidūreva buddhassa, ","html":"<span class='verse-line'>{}</span>"},"pv21:65.4":{"pli":"indako atirocati. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:66.1":{"pli":"Oloketvāna sambuddho, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:66.2":{"pli":"Aṅkurañcāpi indakaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv21:66.3":{"pli":"Dakkhiṇeyyaṁ sambhāvento, ","html":"<span class='verse-line'>{}</span>"},"pv21:66.4":{"pli":"Idaṁ vacanamabravi. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:67.1":{"pli":"“Mahādānaṁ tayā dinnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:67.2":{"pli":"aṅkura dīghamantaraṁ; ","html":"<span class='verse-line'>{}</span>"},"pv21:67.3":{"pli":"Atidūre nisinnosi, ","html":"<span class='verse-line'>{}</span>"},"pv21:67.4":{"pli":"āgaccha mama santike”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:68.1":{"pli":"Codito bhāvitattena, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:68.2":{"pli":"aṅkuro idamabravi; ","html":"<span class='verse-line'>{}</span>"},"pv21:68.3":{"pli":"“Kiṁ mayhaṁ tena dānena, ","html":"<span class='verse-line'>{}</span>"},"pv21:68.4":{"pli":"dakkhiṇeyyena suññataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:69.1":{"pli":"Ayaṁ so indako yakkho, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:69.2":{"pli":"dajjā dānaṁ parittakaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv21:69.3":{"pli":"Atirocati amhehi, ","html":"<span class='verse-line'>{}</span>"},"pv21:69.4":{"pli":"cando tāragaṇe yathā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:70.1":{"pli":"“Ujjaṅgale yathā khette, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:70.2":{"pli":"bījaṁ bahumpi ropitaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv21:70.3":{"pli":"Na vipulaphalaṁ hoti, ","html":"<span class='verse-line'>{}</span>"},"pv21:70.4":{"pli":"napi toseti kassakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:71.1":{"pli":"Tatheva dānaṁ bahukaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:71.2":{"pli":"dussīlesu patiṭṭhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv21:71.3":{"pli":"Na vipulaphalaṁ hoti, ","html":"<span class='verse-line'>{}</span>"},"pv21:71.4":{"pli":"napi toseti dāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:72.1":{"pli":"Yathāpi bhaddake khette, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:72.2":{"pli":"bījaṁ appampi ropitaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv21:72.3":{"pli":"Sammā dhāraṁ pavecchante, ","html":"<span class='verse-line'>{}</span>"},"pv21:72.4":{"pli":"phalaṁ toseti kassakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:73.1":{"pli":"Tatheva sīlavantesu, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:73.2":{"pli":"guṇavantesu tādisu; ","html":"<span class='verse-line'>{}</span>"},"pv21:73.3":{"pli":"Appakampi kataṁ kāraṁ, ","html":"<span class='verse-line'>{}</span>"},"pv21:73.4":{"pli":"puññaṁ hoti mahapphalan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:74.1":{"pli":"Viceyya dānaṁ dātabbaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:74.2":{"pli":"yattha dinnaṁ mahapphalaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv21:74.3":{"pli":"Viceyya dānaṁ datvāna, ","html":"<span class='verse-line'>{}</span>"},"pv21:74.4":{"pli":"saggaṁ gacchanti dāyakā. ","html":"<span class='verse-line'>{}</span></p>"},"pv21:75.1":{"pli":"Viceyya dānaṁ sugatappasatthaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv21:75.2":{"pli":"Ye dakkhiṇeyyā idha jīvaloke; ","html":"<span class='verse-line'>{}</span>"},"pv21:75.3":{"pli":"Etesu dinnāni mahapphalāni, ","html":"<span class='verse-line'>{}</span>"},"pv21:75.4":{"pli":"Bījāni vuttāni yathā sukhetteti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv21:76.1":{"pli":"Aṅkurapetavatthu navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"pv22":{"pv22:0.1":{"pli":"Petavatthu ","html":"<article id='pv22'><header><ul><li class='division'>{}</li>"},"pv22:0.2":{"pli":"Ubbarivagga ","html":"<li>{}</li></ul>"},"pv22:0.3":{"pli":"10. Uttaramātupetivatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv22:1.1":{"pli":"Divāvihāragataṁ bhikkhuṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv22:1.2":{"pli":"gaṅgātīre nisinnakaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv22:1.3":{"pli":"Taṁ petī upasaṅkamma, ","html":"<span class='verse-line'>{}</span>"},"pv22:1.4":{"pli":"dubbaṇṇā bhīrudassanā. ","html":"<span class='verse-line'>{}</span></p>"},"pv22:2.1":{"pli":"Kesā cassā atidīghā, ","html":"<p><span class='verse-line'>{}</span>"},"pv22:2.2":{"pli":"yāvabhūmāvalambare; ","html":"<span class='verse-line'>{}</span>"},"pv22:2.3":{"pli":"Kesehi sā paṭicchannā, ","html":"<span class='verse-line'>{}</span>"},"pv22:2.4":{"pli":"samaṇaṁ etadabravi. ","html":"<span class='verse-line'>{}</span></p>"},"pv22:3.1":{"pli":"“Pañcapaṇṇāsavassāni, ","html":"<p><span class='verse-line'>{}</span>"},"pv22:3.2":{"pli":"yato kālaṅkatā ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv22:3.3":{"pli":"Nābhijānāmi bhuttaṁ vā, ","html":"<span class='verse-line'>{}</span>"},"pv22:3.4":{"pli":"pītaṁ vā pana pāniyaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv22:3.5":{"pli":"Dehi tvaṁ pāniyaṁ bhante, ","html":"<span class='verse-line'>{}</span>"},"pv22:3.6":{"pli":"tasitā pāniyāya me”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv22:4.1":{"pli":"“Ayaṁ sītodikā gaṅgā, ","html":"<p><span class='verse-line'>{}</span>"},"pv22:4.2":{"pli":"himavantato sandati; ","html":"<span class='verse-line'>{}</span>"},"pv22:4.3":{"pli":"Piva etto gahetvāna, ","html":"<span class='verse-line'>{}</span>"},"pv22:4.4":{"pli":"kiṁ maṁ yācasi pāniyan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv22:5.1":{"pli":"“Sacāhaṁ bhante gaṅgāya, ","html":"<p><span class='verse-line'>{}</span>"},"pv22:5.2":{"pli":"sayaṁ gaṇhāmi pāniyaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv22:5.3":{"pli":"Lohitaṁ me parivattati, ","html":"<span class='verse-line'>{}</span>"},"pv22:5.4":{"pli":"tasmā yācāmi pāniyan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv22:6.1":{"pli":"“Kiṁ nu kāyena vācāya, ","html":"<p><span class='verse-line'>{}</span>"},"pv22:6.2":{"pli":"manasā dukkaṭaṁ kataṁ; ","html":"<span class='verse-line'>{}</span>"},"pv22:6.3":{"pli":"Kissa kammavipākena, ","html":"<span class='verse-line'>{}</span>"},"pv22:6.4":{"pli":"gaṅgā te hoti lohitan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv22:7.1":{"pli":"“Putto me uttaro nāma, ","html":"<p><span class='verse-line'>{}</span>"},"pv22:7.2":{"pli":"saddho āsi upāsako; ","html":"<span class='verse-line'>{}</span>"},"pv22:7.3":{"pli":"So ca mayhaṁ akāmāya, ","html":"<span class='verse-line'>{}</span>"},"pv22:7.4":{"pli":"samaṇānaṁ pavecchati. ","html":"<span class='verse-line'>{}</span></p>"},"pv22:8.1":{"pli":"Cīvaraṁ piṇḍapātañca, ","html":"<p><span class='verse-line'>{}</span>"},"pv22:8.2":{"pli":"paccayaṁ sayanāsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv22:8.3":{"pli":"Tamahaṁ paribhāsāmi, ","html":"<span class='verse-line'>{}</span>"},"pv22:8.4":{"pli":"maccherena upaddutā. ","html":"<span class='verse-line'>{}</span></p>"},"pv22:9.1":{"pli":"Yaṁ tvaṁ mayhaṁ akāmāya, ","html":"<p><span class='verse-line'>{}</span>"},"pv22:9.2":{"pli":"samaṇānaṁ pavecchasi; ","html":"<span class='verse-line'>{}</span>"},"pv22:9.3":{"pli":"Cīvaraṁ piṇḍapātañca, ","html":"<span class='verse-line'>{}</span>"},"pv22:9.4":{"pli":"paccayaṁ sayanāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv22:10.1":{"pli":"Etaṁ te paralokasmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv22:10.2":{"pli":"lohitaṁ hotu uttara; ","html":"<span class='verse-line'>{}</span>"},"pv22:10.3":{"pli":"Tassa kammassa vipākena, ","html":"<span class='verse-line'>{}</span>"},"pv22:10.4":{"pli":"gaṅgā me hoti lohitan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv22:11.1":{"pli":"Uttaramātupetivatthu dasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"pv23":{"pv23:0.1":{"pli":"Petavatthu ","html":"<article id='pv23'><header><ul><li class='division'>{}</li>"},"pv23:0.2":{"pli":"Ubbarivagga ","html":"<li>{}</li></ul>"},"pv23:0.3":{"pli":"11. Suttapetavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv23:1.1":{"pli":"“Ahaṁ pure pabbajitassa bhikkhuno, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv23:1.2":{"pli":"Suttaṁ adāsiṁ upasaṅkamma yācitā; ","html":"<span class='verse-line'>{}</span>"},"pv23:1.3":{"pli":"Tassa vipāko vipulaphalūpalabbhati, ","html":"<span class='verse-line'>{}</span>"},"pv23:1.4":{"pli":"Bahukā ca me uppajjare vatthakoṭiyo. ","html":"<span class='verse-line'>{}</span></p>"},"pv23:2.1":{"pli":"Pupphābhikiṇṇaṁ ramitaṁ vimānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv23:2.2":{"pli":"Anekacittaṁ naranārisevitaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv23:2.3":{"pli":"Sāhaṁ bhuñjāmi ca pārupāmi ca, ","html":"<span class='verse-line'>{}</span>"},"pv23:2.4":{"pli":"Pahūtavittā na ca tāva khīyati. ","html":"<span class='verse-line'>{}</span></p>"},"pv23:3.1":{"pli":"Tasseva kammassa vipākamanvayā, ","html":"<p><span class='verse-line'>{}</span>"},"pv23:3.2":{"pli":"Sukhañca sātañca idhūpalabbhati; ","html":"<span class='verse-line'>{}</span>"},"pv23:3.3":{"pli":"Sāhaṁ gantvā punadeva mānusaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv23:3.4":{"pli":"Kāhāmi puññāni nayayyaputta man”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv23:4.1":{"pli":"“Satta tuvaṁ vassasatā idhāgatā, ","html":"<p><span class='verse-line'>{}</span>"},"pv23:4.2":{"pli":"Jiṇṇā ca vuḍḍhā ca tahiṁ bhavissasi; ","html":"<span class='verse-line'>{}</span>"},"pv23:4.3":{"pli":"Sabbeva te kālakatā ca ñātakā, ","html":"<span class='verse-line'>{}</span>"},"pv23:4.4":{"pli":"Kiṁ tattha gantvāna ito karissasī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv23:5.1":{"pli":"“Satteva vassāni idhāgatāya me, ","html":"<p><span class='verse-line'>{}</span>"},"pv23:5.2":{"pli":"Dibbañca sukhañca samappitāya; ","html":"<span class='verse-line'>{}</span>"},"pv23:5.3":{"pli":"Sāhaṁ gantvāna punadeva mānusaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv23:5.4":{"pli":"Kāhāmi puññāni nayayyaputta man”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv23:6.1":{"pli":"So taṁ gahetvāna pasayha bāhāyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv23:6.2":{"pli":"Paccānayitvāna theriṁ sudubbalaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv23:6.3":{"pli":"“Vajjesi aññampi janaṁ idhāgataṁ, ","html":"<span class='verse-line'>{}</span>"},"pv23:6.4":{"pli":"‘Karotha puññāni sukhūpalabbhati’. ","html":"<span class='verse-line'>{}</span></p>"},"pv23:7.1":{"pli":"Diṭṭhā mayā akatena sādhunā, ","html":"<p><span class='verse-line'>{}</span>"},"pv23:7.2":{"pli":"Petā vihaññanti tatheva manussā; ","html":"<span class='verse-line'>{}</span>"},"pv23:7.3":{"pli":"Kammañca katvā sukhavedanīyaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv23:7.4":{"pli":"Devā manussā ca sukhe ṭhitā pajā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv23:8.1":{"pli":"Suttapetavatthu ekādasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}