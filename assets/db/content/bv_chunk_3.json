"pli":"Brahmunā yācito santo, ","html":"<p><span class='verse-line'>{}</span>"},"bv19:20.2":{"pli":"tisso lokagganāyako; ","html":"<span class='verse-line'>{}</span>"},"bv19:20.3":{"pli":"Vatti cakkaṁ mahāvīro, ","html":"<span class='verse-line'>{}</span>"},"bv19:20.4":{"pli":"yasavatiyamuttame. ","html":"<span class='verse-line'>{}</span></p>"},"bv19:21.1":{"pli":"Brahmadevo udayo ca, ","html":"<p><span class='verse-line'>{}</span>"},"bv19:21.2":{"pli":"ahesuṁ aggasāvakā; ","html":"<span class='verse-line'>{}</span>"},"bv19:21.3":{"pli":"Samaṅgo nāmupaṭṭhāko, ","html":"<span class='verse-line'>{}</span>"},"bv19:21.4":{"pli":"tissassa ca mahesino. ","html":"<span class='verse-line'>{}</span></p>"},"bv19:22.1":{"pli":"Phussā ceva sudattā ca, ","html":"<p><span class='verse-line'>{}</span>"},"bv19:22.2":{"pli":"ahesuṁ aggasāvikā; ","html":"<span class='verse-line'>{}</span>"},"bv19:22.3":{"pli":"Bodhi tassa bhagavato, ","html":"<span class='verse-line'>{}</span>"},"bv19:22.4":{"pli":"asanoti pavuccati. ","html":"<span class='verse-line'>{}</span></p>"},"bv19:23.1":{"pli":"Sambalo ca sirimā ceva, ","html":"<p><span class='verse-line'>{}</span>"},"bv19:23.2":{"pli":"ahesuṁ aggupaṭṭhakā; ","html":"<span class='verse-line'>{}</span>"},"bv19:23.3":{"pli":"Kisāgotamī upasenā, ","html":"<span class='verse-line'>{}</span>"},"bv19:23.4":{"pli":"ahesuṁ aggupaṭṭhikā. ","html":"<span class='verse-line'>{}</span></p>"},"bv19:24.1":{"pli":"So buddho saṭṭhiratano, ","html":"<p><span class='verse-line'>{}</span>"},"bv19:24.2":{"pli":"ahu uccattane jino; ","html":"<span class='verse-line'>{}</span>"},"bv19:24.3":{"pli":"Anūpamo asadiso, ","html":"<span class='verse-line'>{}</span>"},"bv19:24.4":{"pli":"himavā viya dissati. ","html":"<span class='verse-line'>{}</span></p>"},"bv19:25.1":{"pli":"Tassāpi atulatejassa, ","html":"<p><span class='verse-line'>{}</span>"},"bv19:25.2":{"pli":"āyu āsi anuttaro; ","html":"<span class='verse-line'>{}</span>"},"bv19:25.3":{"pli":"Vassasatasahassāni, ","html":"<span class='verse-line'>{}</span>"},"bv19:25.4":{"pli":"loke aṭṭhāsi cakkhumā. ","html":"<span class='verse-line'>{}</span></p>"},"bv19:26.1":{"pli":"Uttamaṁ pavaraṁ seṭṭhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"bv19:26.2":{"pli":"anubhotvā mahāyasaṁ; ","html":"<span class='verse-line'>{}</span>"},"bv19:26.3":{"pli":"Jalitvā aggikkhandhova, ","html":"<span class='verse-line'>{}</span>"},"bv19:26.4":{"pli":"nibbuto so sasāvako. ","html":"<span class='verse-line'>{}</span></p>"},"bv19:27.1":{"pli":"Valāhakova anilena, ","html":"<p><span class='verse-line'>{}</span>"},"bv19:27.2":{"pli":"sūriyena viya ussavo; ","html":"<span class='verse-line'>{}</span>"},"bv19:27.3":{"pli":"Andhakārova padīpena, ","html":"<span class='verse-line'>{}</span>"},"bv19:27.4":{"pli":"nibbuto so sasāvako. ","html":"<span class='verse-line'>{}</span></p>"},"bv19:28.1":{"pli":"Tisso jinavaro buddho, ","html":"<p data-counter='7811'><span class='verse-line'>{}</span>"},"bv19:28.2":{"pli":"Nandārāmamhi nibbuto; ","html":"<span class='verse-line'>{}</span>"},"bv19:28.3":{"pli":"Tatthevassa jinathūpo, ","html":"<span class='verse-line'>{}</span>"},"bv19:28.4":{"pli":"Tīṇiyojanamuggato”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"bv19:29.1":{"pli":"Tissassa bhagavato vaṁso sattarasamo. ","html":"<p class='endsutta'>{}</p></article>"}}}