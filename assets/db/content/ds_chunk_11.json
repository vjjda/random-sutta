{"ds2.3.1":{"ds2.3.1:0.1":{"pli":"Dhammasaṅgaṇī ","html":"<article id='ds2.3.1'><header><ul><li class='division'>{}</li>"},"ds2.3.1:0.2":{"pli":"2 Niddesa ","html":"<li>{}</li>"},"ds2.3.1:0.3":{"pli":"2.3 Nikkhepakaṇḍa ","html":"<li>{}</li></ul>"},"ds2.3.1:0.4":{"pli":"2.3.1. Tikanikkhepa ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ds2.3.1:1.0":{"pli":"2.3.1.1. Kusalattika ","html":"<h2>{}</h2>"},"ds2.3.1:1.1":{"pli":"Katame dhammā kusalā? ","html":"<p>{}"},"ds2.3.1:1.2":{"pli":"Tīṇi kusalamūlāni—","html":"{}"},"ds2.3.1:1.3":{"pli":"alobho, adoso, amoho; ","html":"{}"},"ds2.3.1:1.4":{"pli":"taṁsampayutto vedanākkhandho, saññākkhandho, saṅkhārakkhandho, viññāṇakkhandho; ","html":"{}"},"ds2.3.1:1.5":{"pli":"taṁsamuṭṭhānaṁ kāyakammaṁ, vacīkammaṁ, manokammaṁ—","html":"{}"},"ds2.3.1:1.6":{"pli":"ime dhammā kusalā. ","html":"{}</p>"},"ds2.3.1:2.1":{"pli":"Katame dhammā akusalā? ","html":"<p>{}"},"ds2.3.1:2.2":{"pli":"Tīṇi akusalamūlāni—","html":"{}"},"ds2.3.1:2.3":{"pli":"lobho, doso, moho; ","html":"{}"},"ds2.3.1:2.4":{"pli":"tadekaṭṭhā ca kilesā; ","html":"{}"},"ds2.3.1:2.5":{"pli":"taṁsampayutto vedanākkhandho, saññākkhandho, saṅkhārakkhandho, viññāṇakkhandho; ","html":"{}"},"ds2.3.1:2.6":{"pli":"taṁsamuṭṭhānaṁ kāyakammaṁ, vacīkammaṁ, manokammaṁ—","html":"{}"},"ds2.3.1:2.7":{"pli":"ime dhammā akusalā. ","html":"{}</p>"},"ds2.3.1:3.1":{"pli":"Katame dhammā abyākatā? ","html":"<p>{}"},"ds2.3.1:3.2":{"pli":"Kusalākusalānaṁ dhammānaṁ vipākā kāmāvacarā, rūpāvacarā, arūpāvacarā, apariyāpannā; ","html":"{}"},"ds2.3.1:3.3":{"pli":"vedanākkhandho, saññākkhandho, saṅkhārakkhandho, viññāṇakkhandho; ","html":"{}"},"ds2.3.1:3.4":{"pli":"ye ca dhammā kiriyā neva kusalā nākusalā na ca kammavipākā; ","html":"{}"},"ds2.3.1:3.5":{"pli":"sabbañca rūpaṁ, asaṅkhatā ca dhātu—","html":"{}"},"ds2.3.1:3.6":{"pli":"ime dhammā abyākatā. ","html":"{}</p>"},"ds2.3.1:4.0":{"pli":"2.3.1.2. Vedanāttika ","html":"<h2>{}</h2>"},"ds2.3.1:4.1":{"pli":"Katame dhammā sukhāya vedanāya sampayuttā? ","html":"<p>{}"},"ds2.3.1:4.2":{"pli":"Sukhabhūmiyaṁ kāmāvacare, rūpāvacare, apariyāpanne, sukhaṁ vedanaṁ ṭhapetvā; ","html":"{}"},"ds2.3.1:4.3":{"pli":"taṁsampayutto saññākkhandho, saṅkhārakkhandho, viññāṇakkhandho—","html":"{}"},"ds2.3.1:4.4":{"pli":"ime dhammā sukhāya vedanāya sampayuttā. ","html":"{}</p>"},"ds2.3.1:5.1":{"pli":"Katame dhammā dukkhāya vedanāya sampayuttā? ","html":"<p>{}"},"ds2.3.1:5.2":{"pli":"Dukkhabhūmiyaṁ kāmāvacare, dukkhaṁ vedanaṁ ṭhapetvā; ","html":"{}"},"ds2.3.1:5.3":{"pli":"taṁsampayutto saññākkhandho, saṅkhārakkhandho, viññāṇakkhandho—","html":"{}"},"ds2.3.1:5.4":{"pli":"ime dhammā dukkhāya vedanāya sampayuttā. ","html":"{}</p>"},"ds2.3.1:6.1":{"pli":"Katame dhammā adukkhamasukhāya vedanāya sampayuttā? ","html":"<p>{}"},"ds2.3.1:6.2":{"pli":"Adukkhamasukhabhūmiyaṁ kāmāvacare, rūpāvacare, arūpāvacare, apariyāpanne, adukkhamasukhaṁ vedanaṁ ṭhapetvā; ","html":"{}"},"ds2.3.1:6.3":{"pli":"taṁsampayutto saññākkhandho, saṅkhārakkhandho, viññāṇakkhandho—","html":"{}"},"ds2.3.1:6.4":{"pli":"ime dhammā adukkhamasukhāya vedanāya sampayuttā. ","html":"{}</p>"},"ds2.3.1:7.0":{"pli":"2.3.1.3. Vipākattika ","html":"<h2>{}</h2>"},"ds2.3.1:7.1":{"pli":"Katame dhammā vipākā? ","html":"<p>{}"},"ds2.3.1:7.2":{"pli":"Kusalākusalānaṁ dhammānaṁ vipākā kāmāvacarā, rūpāvacarā, arūpāvacarā, apariyāpannā; ","html":"{}"},"ds2.3.1:7.3":{"pli":"vedanākkhandho …pe… viññāṇakkhandho—","html":"{}"},"ds2.3.1:7.4":{"pli":"ime dhammā vipākā. ","html":"{}</p>"},"ds2.3.1:8.1":{"pli":"Katame dhammā vipākadhammadhammā? ","html":"<p>{}"},"ds2.3.1:8.2":{"pli":"Kusalākusalā dhammā kāmāvacarā, rūpāvacarā, arūpāvacarā, apariyāpannā; ","html":"{}"},"ds2.3.1:8.3":{"pli":"vedanākkhandho …pe… viññāṇakkhandho—","html":"{}"},"ds2.3.1:8.4":{"pli":"ime dhammā vipākadhammadhammā. ","html":"{}</p>"},"ds2.3.1:9.1":{"pli":"Katame dhammā nevavipākanavipākadhammadhammā? ","html":"<p>{}"},"ds2.3.1:9.2":{"pli":"Ye ca dhammā kiriyā neva kusalā nākusalā na ca kammavipākā, sabbañca rūpaṁ, asaṅkhatā ca dhātu—","html":"{}"},"ds2.3.1:9.3":{"pli":"ime dhammā nevavipākanavipākadhammadhammā. ","html":"{}</p>"},"ds2.3.1:10.0":{"pli":"2.3.1.4. Upādinnattika ","html":"<h2>{}</h2>"},"ds2.3.1:10.1":{"pli":"Katame dhammā upādinnupādāniyā? ","html":"<p>{}"},"ds2.3.1:10.2":{"pli":"Sāsavā kusalākusalānaṁ dhammānaṁ vipākā kāmāvacarā, rūpāvacarā, arūpāvacarā; ","html":"{}"},"ds2.3.1:10.3":{"pli":"vedanākkhandho …pe… viññāṇakkhandho; ","html":"{}"},"ds2.3.1:10.4":{"pli":"yañca rūpaṁ kammassa katattā—","html":"{}"},"ds2.3.1:10.5":{"pli":"ime dhammā upādinnupādāniyā. ","html":"{}</p>"},"ds2.3.1:11.1":{"pli":"Katame dhammā anupādinnupādāniyā? ","html":"<p>{}"},"ds2.3.1:11.2":{"pli":"Sāsavā kusalākusalā dhammā kāmāvacarā, rūpāvacarā, arūpāvacarā; ","html":"{}"},"ds2.3.1:11.3":{"pli":"vedanākkhandho …pe… viññāṇakkhandho; ","html":"{}"},"ds2.3.1:11.4":{"pli":"ye ca dhammā kiriyā neva kusalā nākusalā na ca kammavipākā; ","html":"{}"},"ds2.3.1:11.5":{"pli":"yañca rūpaṁ na kammassa katattā—","html":"{}"},"ds2.3.1:11.6":{"pli":"ime dhammā anupādinnupādāniyā. ","html":"{}</p>"},"ds2.3.1:12.1":{"pli":"Katame dhammā anupādinnaanupādāniyā? ","html":"<p>{}"},"ds2.3.1:12.2":{"pli":"Apariyāpannā maggā ca, maggaphalāni ca, asaṅkhatā ca dhātu—","html":"{}"},"ds2.3.1:12.3":{"pli":"ime dhammā anupādinnaanupādāniyā. ","html":"{}</p>"},"ds2.3.1:13.0":{"pli":"2.3.1.5. Saṅkiliṭṭhattika ","html":"<h2>{}</h2>"},"ds2.3.1:13.1":{"pli":"Katame dhammā saṅkiliṭṭhasaṅkilesikā? ","html":"<p>{}"},"ds2.3.1:13.2":{"pli":"Tīṇi akusalamūlāni—","html":"{}"},"ds2.3.1:13.3":{"pli":"lobho, doso, moho; ","html":"{}"},"ds2.3.1:13.4":{"pli":"tadekaṭṭhā ca kilesā; ","html":"{}"},"ds2.3.1:13.5":{"pli":"taṁsampayutto vedanākkhandho …pe… viññāṇakkhandho; ","html":"{}"},"ds2.3.1:13.6":{"pli":"taṁsamuṭṭhānaṁ kāyakammaṁ, vacīkammaṁ, manokammaṁ—","html":"{}"},"ds2.3.1:13.7":{"pli":"ime dhammā saṅkiliṭṭhasaṅkilesikā. ","html":"{}</p>"},"ds2.3.1:14.1":{"pli":"Katame dhammā asaṅkiliṭṭhasaṅkilesikā? ","html":"<p>{}"},"ds2.3.1:14.2":{"pli":"Sāsavā kusalābyākatā dhammā kāmāvacarā, rūpāvacarā, arūpāvacarā; ","html":"{}"},"ds2.3.1:14.3":{"pli":"rūpakkhandho, vedanākkhandho, saññākkhandho, saṅkhārakkhandho, viññāṇakkhandho—","html":"{}"},"ds2.3.1:14.4":{"pli":"ime dhammā asaṅkiliṭṭhasaṅkilesikā. ","html":"{}</p>"},"ds2.3.1:15.1":{"pli":"Katame dhammā asaṅkiliṭṭhaasaṅkilesikā? ","html":"<p>{}"},"ds2.3.1:15.2":{"pli":"Apariyāpannā maggā ca, maggaphalāni ca, asaṅkhatā ca dhātu—","html":"{}"},"ds2.3.1:15.3":{"pli":"ime dhammā asaṅkiliṭṭhaasaṅkilesikā. ","html":"{}</p>"},"ds2.3.1:16.0":{"pli":"2.3.1.6. Vitakkattika ","html":"<h2>{}</h2>"},"ds2.3.1:16.1":{"pli":"Katame dhammā savitakkasavicārā? ","html":"<p>{}"},"ds2.3.1:16.2":{"pli":"Savitakkasavicārabhūmiyaṁ kāmāvacare, rūpāvacare, apariyāpanne, vitakkavicāre ṭhapetvā; ","html":"{}"},"ds2.3.1:16.3":{"pli":"taṁsampayutto vedanākkhandho …pe… viññāṇakkhandho—","html":"{}"},"ds2.3.1:16.4":{"pli":"ime dhammā savitakkasavicārā. ","html":"{}</p>"},"ds2.3.1:17.1":{"pli":"Katame dhammā avitakkavicāramattā? ","html":"<p>{}"},"ds2.3.1:17.2":{"pli":"Avitakkavicāramattabhūmiyaṁ rūpāvacare, apariyāpanne, vicāraṁ ṭhapetvā; ","html":"{}"},"ds2.3.1:17.3":{"pli":"taṁsampayutto vedanākkhandho …pe… viññāṇakkhandho—","html":"{}"},"ds2.3.1:17.4":{"pli":"ime dhammā avitakkavicāramattā. ","html":"{}</p>"},"ds2.3.1:18.1":{"pli":"Katame dhammā avitakkaavicārā? ","html":"<p>{}"},"ds2.3.1:18.2":{"pli":"Avitakkaavicārabhūmiyaṁ kāmāvacare, rūpāvacare, arūpāvacare, apariyāpanne; ","html":"{}"},"ds2.3.1:18.3":{"pli":"vedanākkhandho …pe… viññāṇakkhandho; ","html":"{}"},"ds2.3.1:18.4":{"pli":"sabbañca rūpaṁ, asaṅkhatā ca dhātu—","html":"{}"},"ds2.3.1:18.5":{"pli":"ime dhammā avitakkaavicārā. ","html":"{}</p>"},"ds2.3.1:19.0":{"pli":"2.3.1.7. Pītittika ","html":"<h2>{}</h2>"},"ds2.3.1:19.1":{"pli":"Katame dhammā pītisahagatā? ","html":"<p>{}"},"ds2.3.1:19.2":{"pli":"Pītibhūmiyaṁ kāmāvacare, rūpāvacare, apariyāpanne, pītiṁ ṭhapetvā; ","html":"{}"},"ds2.3.1:19.3":{"pli":"taṁsampayutto vedanākkhandho …pe… viññāṇakkhandho—","html":"{}"},"ds2.3.1:19.4":{"pli":"ime dhammā pītisahagatā. ","html":"{}</p>"},"ds2.3.1:20.1":{"pli":"Katame dhammā sukhasahagatā? ","html":"<p>{}"},"ds2.3.1:20.2":{"pli":"Sukhabhūmiyaṁ kāmāvacare, rūpāvacare, apariyāpanne, sukhaṁ ṭhapetvā; ","html":"{}"},"ds2.3.1:20.3":{"pli":"taṁsampayutto saññākkhandho, saṅkhārakkhandho, viññāṇakkhandho—","html":"{}"},"ds2.3.1:20.4":{"pli":"ime dhammā sukhasahagatā. ","html":"{}</p>"},"ds2.3.1:21.1":{"pli":"Katame dhammā upekkhāsahagatā? ","html":"<p>{}"},"ds2.3.1:21.2":{"pli":"Upekkhābhūmiyaṁ kāmāvacare, rūpāvacare, arūpāvacare, apariyāpanne, upekkhaṁ ṭhapetvā; ","html":"{}"},"ds2.3.1:21.3":{"pli":"taṁsampayutto saññākkhandho, saṅkhārakkhandho, viññāṇakkhandho—","html":"{}"},"ds2.3.1:21.4":{"pli":"ime dhammā upekkhāsahagatā. ","html":"{}</p>"},"ds2.3.1:22.0":{"pli":"2.3.1.8. Dassanenapahātabbattika ","html":"<h2>{}</h2>"},"ds2.3.1:22.1":{"pli":"Katame dhammā dassanena pahātabbā? ","html":"<p>{}"},"ds2.3.1:22.2":{"pli":"Tīṇi saññojanāni—","html":"{}"},"ds2.3.1:22.3":{"pli":"sakkāyadiṭṭhi, vicikicchā, sīlabbataparāmāso. ","html":"{}</p>"},"ds2.3.1:23.1":{"pli":"Tattha katamā sakkāyadiṭṭhi? ","html":"<p>{}"},"ds2.3.1:23.2":{"pli":"Idha assutavā puthujjano ariyānaṁ adassāvī ariyadhammassa akovido ariyadhamme avinīto sappurisānaṁ adassāvī sappurisadhammassa akovido sappurisadhamme avinīto rūpaṁ attato samanupassati, rūpavantaṁ vā attānaṁ, attani vā rūpaṁ, rūpasmiṁ vā attānaṁ. ","html":"{}"},"ds2.3.1:23.3":{"pli":"Vedanaṁ attato samanupassati, vedanāvantaṁ vā attānaṁ, attani vā vedanaṁ, vedanāya vā attānaṁ. ","html":"{}"},"ds2.3.1:23.4":{"pli":"Saññaṁ attato samanupassati, saññāvantaṁ vā attānaṁ, attani vā saññaṁ, saññāya vā attānaṁ. ","html":"{}"},"ds2.3.1:23.5":{"pli":"Saṅkhāre attato samanupassati, saṅkhāravantaṁ vā attānaṁ, attani vā saṅkhāre, saṅkhāresu vā attānaṁ. ","html":"{}"},"ds2.3.1:23.6":{"pli":"Viññāṇaṁ attato samanupassati, viññāṇavantaṁ vā attānaṁ, attani vā viññāṇaṁ, viññāṇasmiṁ vā attānaṁ. ","html":"{}"},"ds2.3.1:23.7":{"pli":"Yā evarūpā diṭṭhi diṭṭhigataṁ diṭṭhigahanaṁ diṭṭhikantāro diṭṭhivisūkāyikaṁ diṭṭhivipphanditaṁ diṭṭhisaññojanaṁ gāho paṭiggāho abhiniveso parāmāso kummaggo micchāpatho micchattaṁ titthāyatanaṁ vipariyāsaggāho—","html":"{}"},"ds2.3.1:23.8":{"pli":"ayaṁ vuccati sakkāyadiṭṭhi. ","html":"{}</p>"},"ds2.3.1:24.1":{"pli":"Tattha katamā vicikicchā? ","html":"<p>{}"},"ds2.3.1:24.2":{"pli":"Satthari kaṅkhati vicikicchati, dhamme kaṅkhati vicikicchati, saṅghe kaṅkhati vicikicchati, sikkhāya kaṅkhati vicikicchati, pubbante kaṅkhati vicikicchati, aparante kaṅkhati vicikicchati, pubbantāparante kaṅkhati vicikicchati, idappaccayatā paṭiccasamuppannesu dhammesu kaṅkhati vicikicchati. ","html":"{}"},"ds2.3.1:24.3":{"pli":"Yā evarūpā kaṅkhā kaṅkhāyanā kaṅkhāyitattaṁ vimati vicikicchā dveḷhakaṁ dvedhāpatho saṁsayo anekaṁsaggāho āsappanā parisappanā apariyogāhanā thambhitattaṁ cittassa manovilekho—","html":"{}"},"ds2.3.1:24.4":{"pli":"ayaṁ vuccati vicikicchā. ","html":"{}</p>"},"ds2.3.1:25.1":{"pli":"Tattha katamo sīlabbataparāmāso? ","html":"<p>{}"},"ds2.3.1:25.2":{"pli":"Ito bahiddhā samaṇabrāhmaṇānaṁ ‘sīlena suddhi, vatena suddhi, sīlabbatena suddhī’ti yā evarūpā diṭṭhi diṭṭhigataṁ diṭṭhigahanaṁ diṭṭhikantāro diṭṭhivisūkāyikaṁ diṭṭhivipphanditaṁ diṭṭhisaññojanaṁ gāho paṭiggāho abhiniveso parāmāso kummaggo micchāpatho micchattaṁ titthāyatanaṁ vipariyāsaggāho—","html":"{}"},"ds2.3.1:25.3":{"pli":"ayaṁ vuccati sīlabbataparāmāso. ","html":"{}</p>"},"ds2.3.1:26.1":{"pli":"Imāni tīṇi saññojanāni; ","html":"<p>{}"},"ds2.3.1:26.2":{"pli":"tadekaṭṭhā ca kilesā; ","html":"{}"},"ds2.3.1:26.3":{"pli":"taṁsampayutto vedanākkhandho …pe… viññāṇakkhandho; ","html":"{}"},"ds2.3.1:26.4":{"pli":"taṁsamuṭṭhānaṁ kāyakammaṁ vacīkammaṁ manokammaṁ—","html":"{}"},"ds2.3.1:26.5":{"pli":"ime dhammā dassanena pahātabbā. ","html":"{}</p>"},"ds2.3.1:27.1":{"pli":"Katame dhammā bhāvanāya pahātabbā? ","html":"<p>{}"},"ds2.3.1:27.2":{"pli":"Avaseso lobho, doso, moho; ","html":"{}"},"ds2.3.1:27.3":{"pli":"tadekaṭṭhā ca kilesā; ","html":"{}"},"ds2.3.1:27.4":{"pli":"taṁsampayutto vedanākkhandho …pe… viññāṇakkhandho; ","html":"{}"},"ds2.3.1:27.5":{"pli":"taṁsamuṭṭhānaṁ kāyakammaṁ, vacīkammaṁ, manokammaṁ—","html":"{}"},"ds2.3.1:27.6":{"pli":"ime dhammā bhāvanāya pahātabbā. ","html":"{}</p>"},"ds2.3.1:28.1":{"pli":"Katame dhammā neva dassanena na bhāvanāya pahātabbā? ","html":"<p>{}"},"ds2.3.1:28.2":{"pli":"Kusalābyākatā dhammā kāmāvacarā, rūpāvacarā, arūpāvacarā, apariyāpannā; ","html":"{}"},"ds2.3.1:28.3":{"pli":"vedanākkhandho …pe… viññāṇakkhandho; ","html":"{}"},"ds2.3.1:28.4":{"pli":"sabbañca rūpaṁ, asaṅkhatā ca dhātu—","html":"{}"},"ds2.3.1:28.5":{"pli":"ime dhammā neva dassanena na bhāvanāya pahātabbā. ","html":"{}</p>"},"ds2.3.1:29.0":{"pli":"2.3.1.9. Dassanenapahātabbahetukattika ","html":"<h2>{}</h2>"},"ds2.3.1:29.1":{"pli":"Katame dhammā dassanena pahātabbahetukā? ","html":"<p>{}"},"ds2.3.1:29.2":{"pli":"Tīṇi saññojanāni—","html":"{}"},"ds2.3.1:29.3":{"pli":"sakkāyadiṭṭhi, vicikicchā, sīlabbataparāmāso. ","html":"{}</p>"},"ds2.3.1:30.1":{"pli":"Tattha katamā sakkāyadiṭṭhi …pe… ","html":"<p>{}"},"ds2.3.1:30.2":{"pli":"ayaṁ vuccati sakkāyadiṭṭhi. ","html":"{}</p>"},"ds2.3.1:31.1":{"pli":"Tattha katamā vicikicchā …pe… ","html":"<p>{}"},"ds2.3.1:31.2":{"pli":"ayaṁ vuccati vicikicchā. ","html":"{}</p>"},"ds2.3.1:32.1":{"pli":"Tattha katamo sīlabbataparāmāso …pe… ","html":"<p>{}"},"ds2.3.1:32.2":{"pli":"ayaṁ vuccati sīlabbataparāmāso. ","html":"{}</p>"},"ds2.3.1:33.1":{"pli":"Imāni tīṇi saññojanāni; ","html":"<p>{}"},"ds2.3.1:33.2":{"pli":"tadekaṭṭhā ca kilesā; ","html":"{}"},"ds2.3.1:33.3":{"pli":"taṁsampayutto vedanākkhandho …pe… viññāṇakkhandho; ","html":"{}"},"ds2.3.1:33.4":{"pli":"taṁsamuṭṭhānaṁ kāyakammaṁ, vacīkammaṁ, manokammaṁ—","html":"{}"},"ds2.3.1:33.5":{"pli":"ime dhammā dassanena pahātabbahetukā. ","html":"{}"},"ds2.3.1:33.6":{"pli":"Tīṇi saññojanāni—","html":"{}"},"ds2.3.1:33.7":{"pli":"sakkāyadiṭṭhi, vicikicchā, sīlabbataparāmāso—","html":"{}"},"ds2.3.1:33.8":{"pli":"ime dhammā dassanena pahātabbā. ","html":"{}"},"ds2.3.1:33.9":{"pli":"Tadekaṭṭho lobho, doso, moho—","html":"{}"},"ds2.3.1:33.10":{"pli":"ime dhammā dassanena pahātabbahetū. ","html":"{}"},"ds2.3.1:33.11":{"pli":"Tadekaṭṭhā ca kilesā; ","html":"{}"},"ds2.3.1:33.12":{"pli":"taṁsampayutto vedanākkhandho …pe… viññāṇakkhandho; ","html":"{}"},"ds2.3.1:33.13":{"pli":"taṁsamuṭṭhānaṁ kāyakammaṁ, vacīkammaṁ, manokammaṁ—","html":"{}"},"ds2.3.1:33.14":{"pli":"ime dhammā dassanena pahātabbahetukā. ","html":"{}</p>"},"ds2.3.1:34.1":{"pli":"Katame dhammā bhāvanāya pahātabbahetukā? ","html":"<p>{}"},"ds2.3.1:34.2":{"pli":"Avaseso lobho, doso, moho—","html":"{}"},"ds2.3.1:34.3":{"pli":"ime dhammā bhāvanāya pahātabbahetū. ","html":"{}"},"ds2.3.1:34.4":{"pli":"Tadekaṭṭhā ca kilesā; ","html":"{}"},"ds2.3.1:34.5":{"pli":"taṁsampayutto vedanākkhandho …pe… viññāṇakkhandho; ","html":"{}"},"ds2.3.1:34.6":{"pli":"taṁsamuṭṭhānaṁ kāyakammaṁ, vacīkammaṁ, manokammaṁ—","html":"{}"},"ds2.3.1:34.7":{"pli":"ime dhammā bhāvanāya pahātabbahetukā. ","html":"{}</p>"},"ds2.3.1:35.1":{"pli":"Katame dhammā neva dassanena na bhāvanāya pahātabbahetukā? ","html":"<p>{}"},"ds2.3.1:35.2":{"pli":"Te dhamme ṭhapetvā avasesā kusalākusalābyākatā dhammā kāmāvacarā rūpāvacarā, arūpāvacarā, apariyāpannā; ","html":"{}"},"ds2.3.1:35.3":{"pli":"vedanākkhandho, saññākkhandho, saṅkhārakkhandho, viññāṇakkhandho; ","html":"{}"},"ds2.3.1:35.4":{"pli":"sabbañca rūpaṁ, asaṅkhatā ca dhātu—","html":"{}"},"ds2.3.1:35.5":{"pli":"ime dhammā neva dassanena na bhāvanāya pahātabbahetukā. ","html":"{}</p>"},"ds2.3.1:36.0":{"pli":"2.3.1.10. Ācayagāmittika ","html":"<h2>{}</h2>"},"ds2.3.1:36.1":{"pli":"Katame dhammā ācayagāmino? ","html":"<p>{}"},"ds2.3.1:36.2":{"pli":"Sāsavā kusalākusalā dhammā kāmāvacarā, rūpāvacarā, arūpāvacarā; ","html":"{}"},"ds2.3.1:36.3":{"pli":"vedanākkhandho …pe… viññāṇakkhandho—","html":"{}"},"ds2.3.1:36.4":{"pli":"ime dhammā ācayagāmino. ","html":"{}</p>"},"ds2.3.1:37.1":{"pli":"Katame dhammā apacayagāmino? ","html":"<p>{}"},"ds2.3.1:37.2":{"pli":"Cattāro maggā apariyāpannā—","html":"{}"},"ds2.3.1:37.3":{"pli":"ime dhammā apacayagāmino. ","html":"{}</p>"},"ds2.3.1:38.1":{"pli":"Katame dhammā neva ācayagāmi na apacayagāmino? ","html":"<p>{}"},"ds2.3.1:38.2":{"pli":"Kusalākusalānaṁ dhammānaṁ vipākā kāmāvacarā, rūpāvacarā, arūpāvacarā, apariyāpannā; ","html":"{}"},"ds2.3.1:38.3":{"pli":"vedanākkhandho …pe… viññāṇakkhandho; ","html":"{}"},"ds2.3.1:38.4":{"pli":"ye ca dhammā kiriyā neva kusalā nākusalā na ca kammavipākā; ","html":"{}"},"ds2.3.1:38.5":{"pli":"sabbañca rūpaṁ, asaṅkhatā ca dhātu—","html":"{}"},"ds2.3.1:38.6":{"pli":"ime dhammā neva ācayagāmi na apacayagāmino. ","html":"{}</p>"},"ds2.3.1:39.0":{"pli":"2.3.1.11. Sekkhattika ","html":"<h2>{}</h2>"},"ds2.3.1:39.1":{"pli":"Katame dhammā sekkhā? ","html":"<p>{}"},"ds2.3.1:39.2":{"pli":"Cattāro maggā apariyāpannā, heṭṭhimāni ca tīṇi sāmaññaphalāni—","html":"{}"},"ds2.3.1:39.3":{"pli":"ime dhammā sekkhā. ","html":"{}</p>"},"ds2.3.1:40.1":{"pli":"Katame dhammā asekkhā? ","html":"<p>{}"},"ds2.3.1:40.2":{"pli":"Upariṭṭhimaṁ arahattaphalaṁ—","html":"{}"},"ds2.3.1:40.3":{"pli":"ime dhammā asekkhā. ","html":"{}</p>"},"ds2.3.1:41.1":{"pli":"Katame dhammā nevasekkhanāsekkhā? ","html":"<p>{}"},"ds2.3.1:41.2":{"pli":"Te dhamme ṭhapetvā, avasesā kusalākusalābyākatā dhammā kāmāvacarā, rūpāvacarā, arūpāvacarā; ","html":"{}"},"ds2.3.1:41.3":{"pli":"vedanākkhandho …pe… viññāṇakkhandho; ","html":"{}"},"ds2.3.1:41.4":{"pli":"sabbañca rūpaṁ, asaṅkhatā ca dhātu—","html":"{}"},"ds2.3.1:41.5":{"pli":"ime dhammā nevasekkhanāsekkhā. ","html":"{}</p>"},"ds2.3.1:42.0":{"pli":"2.3.1.12. Parittattika ","html":"<h2>{}</h2>"},"ds2.3.1:42.1":{"pli":"Katame dhammā parittā? ","html":"<p>{}"},"ds2.3.1:42.2":{"pli":"Sabbeva kāmāvacarā kusalākusalābyākatā dhammā; ","html":"{}"},"ds2.3.1:42.3":{"pli":"rūpakkhandho …pe… viññāṇakkhandho—","html":"{}"},"ds2.3.1:42.4":{"pli":"ime dhammā parittā. ","html":"{}</p>"},"ds2.3.1:43.1":{"pli":"Katame dhammā mahaggatā? ","html":"<p>{}"},"ds2.3.1:43.2":{"pli":"Rūpāvacarā, arūpāvacarā, kusalābyākatā dhammā; ","html":"{}"},"ds2.3.1:43.3":{"pli":"vedanākkhandho …pe… viññāṇakkhandho—","html":"{}"},"ds2.3.1:43.4":{"pli":"ime dhammā mahaggatā. ","html":"{}</p>"},"ds2.3.1:44.1":{"pli":"Katame dhammā appamāṇā? ","html":"<p>{}"},"ds2.3.1:44.2":{"pli":"Apariyāpannā maggā ca, maggaphalāni ca, asaṅkhatā ca dhātu—","html":"{}"},"ds2.3.1:44.3":{"pli":"ime dhammā appamāṇā. ","html":"{}</p>"},"ds2.3.1:45.0":{"pli":"2.3.1.13. Parittārammaṇattika ","html":"<h2>{}</h2>"},"ds2.3.1:45.1":{"pli":"Katame dhammā parittārammaṇā? ","html":"<p>{}"},"ds2.3.1:45.2":{"pli":"Paritte dhamme ārabbha ye uppajjanti cittacetasikā dhammā—","html":"{}"},"ds2.3.1:45.3":{"pli":"ime dhammā parittārammaṇā. ","html":"{}</p>"},"ds2.3.1:46.1":{"pli":"Katame dhammā mahaggatārammaṇā? ","html":"<p>{}"},"ds2.3.1:46.2":{"pli":"Mahaggate dhamme ārabbha ye uppajjanti cittacetasikā dhammā—","html":"{}"},"ds2.3.1:46.3":{"pli":"ime dhammā mahaggatārammaṇā. ","html":"{}</p>"},"ds2.3.1:47.1":{"pli":"Katame dhammā appamāṇārammaṇā? ","html":"<p>{}"},"ds2.3.1:47.2":{"pli":"Appamāṇe dhamme ārabbha ye uppajjanti cittacetasikā dhammā—","html":"{}"},"ds2.3.1:47.3":{"pli":"ime dhammā appamāṇārammaṇā. ","html":"{}</p>"},"ds2.3.1:48.0":{"pli":"2.3.1.14. Hīnattika ","html":"<h2>{}</h2>"},"ds2.3.1:48.1":{"pli":"Katame dhammā hīnā? ","html":"<p>{}"},"ds2.3.1:48.2":{"pli":"Tīṇi akusalamūlāni—","html":"{}"},"ds2.3.1:48.3":{"pli":"lobho, doso, moho; ","html":"{}"},"ds2.3.1:48.4":{"pli":"tadekaṭṭhā ca kilesā; ","html":"{}"},"ds2.3.1:48.5":{"pli":"taṁsampayutto vedanākkhandho …pe… viññāṇakkhandho; ","html":"{}"},"ds2.3.1:48.6":{"pli":"taṁsamuṭṭhānaṁ kāyakammaṁ, vacīkammaṁ, manokammaṁ—","html":"{}"},"ds2.3.1:48.7":{"pli":"ime dhammā hīnā. ","html":"{}</p>"},"ds2.3.1:49.1":{"pli":"Katame dhammā majjhimā? ","html":"<p>{}"},"ds2.3.1:49.2":{"pli":"Sāsavā kusalābyākatā dhammā kāmāvacarā, rūpāvacarā, arūpāvacarā, rūpakkhandho …pe… viññāṇakkhandho—","html":"{}"},"ds2.3.1:49.3":{"pli":"ime dhammā majjhimā. ","html":"{}</p>"},"ds2.3.1:50.1":{"pli":"Katame dhammā paṇītā? ","html":"<p>{}"},"ds2.3.1:50.2":{"pli":"Apariyāpannā maggā ca, maggaphalāni ca, asaṅkhatā ca dhātu—","html":"{}"},"ds2.3.1:50.3":{"pli":"ime dhammā paṇītā. ","html":"{}</p>"},"ds2.3.1:51.0":{"pli":"2.3.1.15. Micchattaniyatattika ","html":"<h2>{}</h2>"},"ds2.3.1:51.1":{"pli":"Katame dhammā micchattaniyatā? ","html":"<p>{}"},"ds2.3.1:51.2":{"pli":"Pañca kammāni ānantarikāni, yā ca micchādiṭṭhiniyatā—","html":"{}"},"ds2.3.1:51.3":{"pli":"ime dhammā micchattaniyatā. ","html":"{}</p>"},"ds2.3.1:52.1":{"pli":"Katame dhammā sammattaniyatā? ","html":"<p>{}"},"ds2.3.1:52.2":{"pli":"Cattāro maggā apariyāpannā—","html":"{}"},"ds2.3.1:52.3":{"pli":"ime dhammā sammattaniyatā. ","html":"{}</p>"},"ds2.3.1:53.1":{"pli":"Katame dhammā aniyatā? ","html":"<p>{}"},"ds2.3.1:53.2":{"pli":"Te dhamme ṭhapetvā, avasesā kusalākusalābyākatā dhammā kāmāvacarā, rūpāvacarā, arūpāvacarā, apariyāpannā; ","html":"{}"},"ds2.3.1:53.3":{"pli":"vedanākkhandho …pe… viññāṇakkhandho; ","html":"{}"},"ds2.3.1:53.4":{"pli":"sabbañca rūpaṁ, asaṅkhatā ca dhātu—","html":"{}"},"ds2.3.1:53.5":{"pli":"ime dhammā aniyatā. ","html":"{}</p>"},"ds2.3.1:54.0":{"pli":"2.3.1.16. Maggārammaṇattika ","html":"<h2>{}</h2>"},"ds2.3.1:54.1":{"pli":"Katame dhammā maggārammaṇā? ","html":"<p>{}"},"ds2.3.1:54.2":{"pli":"Ariyamaggaṁ ārabbha ye uppajjanti cittacetasikā dhammā—","html":"{}"},"ds2.3.1:54.3":{"pli":"ime dhammā maggārammaṇā. ","html":"{}</p>"},"ds2.3.1:55.1":{"pli":"Katame dhammā maggahetukā? ","html":"<p>{}"},"ds2.3.1:55.2":{"pli":"Ariyamaggasamaṅgissa maggaṅgāni ṭhapetvā; ","html":"{}"},"ds2.3.1:55.3":{"pli":"taṁsampayutto vedanākkhandho …pe… viññāṇakkhandho—","html":"{}"},"ds2.3.1:55.4":{"pli":"ime dhammā maggahetukā. ","html":"{}"},"ds2.3.1:55.5":{"pli":"Ariyamaggasamaṅgissa sammādiṭṭhi maggo ceva hetu ca, sammādiṭṭhiṁ ṭhapetvā, taṁsampayutto vedanākkhandho …pe… viññāṇakkhandho—","html":"{}"},"ds2.3.1:55.6":{"pli":"ime dhammā maggahetukā. ","html":"{}"},"ds2.3.1:55.7":{"pli":"Ariyamaggasamaṅgissa alobho, adoso, amoho—","html":"{}"},"ds2.3.1:55.8":{"pli":"ime dhammā maggahetū. ","html":"{}"},"ds2.3.1:55.9":{"pli":"Taṁsampayutto vedanākkhandho …pe… viññāṇakkhandho—","html":"{}"},"ds2.3.1:55.10":{"pli":"ime dhammā maggahetukā. ","html":"{}</p>"},"ds2.3.1:56.1":{"pli":"Katame dhammā maggādhipatino? ","html":"<p>{}"},"ds2.3.1:56.2":{"pli":"Ariyamaggaṁ adhipatiṁ karitvā ye uppajjanti cittacetasikā dhammā—","html":"{}"},"ds2.3.1:56.3":{"pli":"ime dhammā maggādhipatino. ","html":"{}"},"ds2.3.1:56.4":{"pli":"Ariyamaggasamaṅgissa vīmaṁsādhipateyyaṁ maggaṁ bhāvayantassa vīmaṁsaṁ ṭhapetvā; ","html":"{}"},"ds2.3.1:56.5":{"pli":"taṁsampayutto vedanākkhandho …pe… viññāṇakkhandho—","html":"{}"},"ds2.3.1:56.6":{"pli":"ime dhammā maggādhipatino. ","html":"{}</p>"},"ds2.3.1:57.0":{"pli":"2.3.1.17. Uppannattika ","html":"<h2>{}</h2>"},"ds2.3.1:57.1":{"pli":"Katame dhammā uppannā? ","html":"<p>{}"},"ds2.3.1:57.2":{"pli":"Ye dhammā jātā bhūtā sañjātā nibbattā abhinibbattā pātubhūtā uppannā samuppannā uṭṭhitā samuṭṭhitā uppannā uppannaṁsena saṅgahitā, rūpaṁ, vedanā, saññā, saṅkhārā, viññāṇaṁ—","html":"{}"},"ds2.3.1:57.3":{"pli":"ime dhammā uppannā. ","html":"{}</p>"},"ds2.3.1:58.1":{"pli":"Katame dhammā anuppannā? ","html":"<p>{}"},"ds2.3.1:58.2":{"pli":"Ye dhammā ajātā abhūtā asañjātā anibbattā anabhinibbattā apātubhūtā anuppannā asamuppannā anuṭṭhitā asamuṭṭhitā anuppannā anuppannaṁsena saṅgahitā, rūpaṁ, vedanā, saññā, saṅkhārā, viññāṇaṁ—","html":"{}"},"ds2.3.1:58.3":{"pli":"ime dhammā anuppannā. ","html":"{}</p>"},"ds2.3.1:59.1":{"pli":"Katame dhammā uppādino? ","html":"<p>{}"},"ds2.3.1:59.2":{"pli":"Kusalākusalānaṁ dhammānaṁ avipakkavipākānaṁ vipākā kāmāvacarā, rūpāvacarā, arūpāvacarā, apariyāpannā; ","html":"{}"},"ds2.3.1:59.3":{"pli":"vedanākkhandho …pe… viññāṇakkhandho; ","html":"{}"},"ds2.3.1:59.4":{"pli":"yañca rūpaṁ kammassa katattā uppajjissati—","html":"{}"},"ds2.3.1:59.5":{"pli":"ime dhammā uppādino. ","html":"{}</p>"},"ds2.3.1:60.0":{"pli":"2.3.1.18. Atītattika ","html":"<h2>{}</h2>"},"ds2.3.1:60.1":{"pli":"Katame dhammā atītā? ","html":"<p>{}"},"ds2.3.1:60.2":{"pli":"Ye dhammā atītā niruddhā vigatā vipariṇatā atthaṅgatā abbhatthaṅgatā uppajjitvā vigatā atītā atītaṁsena saṅgahitā, rūpaṁ, vedanā, saññā, saṅkhārā, viññāṇaṁ—","html":"{}"},"ds2.3.1:60.3":{"pli":"ime dhammā atītā. ","html":"{}</p>"},"ds2.3.1:61.1":{"pli":"Katame dhammā anāgatā? ","html":"<p>{}"},"ds2.3.1:61.2":{"pli":"Ye dhammā ajātā abhūtā asañjātā anibbattā anabhinibbattā apātubhūtā anuppannā asamuppannā anuṭṭhitā asamuṭṭhitā anāgatā anāgataṁsena saṅgahitā, rūpaṁ, vedanā, saññā, saṅkhārā, viññāṇaṁ—","html":"{}"},"ds2.3.1:61.3":{"pli":"ime dhammā anāgatā. ","html":"{}</p>"},"ds2.3.1:62.1":{"pli":"Katame dhammā paccuppannā? ","html":"<p>{}"},"ds2.3.1:62.2":{"pli":"Ye dhammā jātā bhūtā sañjātā nibbattā abhinibbattā pātubhūtā uppannā samuppannā uṭṭhitā samuṭṭhitā paccuppannā paccuppannaṁsena saṅgahitā, rūpaṁ, vedanā, saññā, saṅkhārā, viññāṇaṁ—","html":"{}"},"ds2.3.1:62.3":{"pli":"ime dhammā paccuppannā. ","html":"{}</p>"},"ds2.3.1:63.0":{"pli":"2.3.1.19. Atītārammaṇattika ","html":"<h2>{}</h2>"},"ds2.3.1:63.1":{"pli":"Katame dhammā atītārammaṇā? ","html":"<p>{}"},"ds2.3.1:63.2":{"pli":"Atīte dhamme ārabbha ye uppajjanti cittacetasikā dhammā—","html":"{}"},"ds2.3.1:63.3":{"pli":"ime dhammā atītārammaṇā. ","html":"{}</p>"},"ds2.3.1:64.1":{"pli":"Katame dhammā anāgatārammaṇā? ","html":"<p>{}"},"ds2.3.1:64.2":{"pli":"Anāgate dhamme ārabbha ye uppajjanti cittacetasikā dhammā—","html":"{}"},"ds2.3.1:64.3":{"pli":"ime dhammā anāgatārammaṇā. ","html":"{}</p>"},"ds2.3.1:65.1":{"pli":"Katame dhammā paccuppannārammaṇā? ","html":"<p>{}"},"ds2.3.1:65.2":{"pli":"Paccuppanne dhamme ārabbha ye uppajjanti cittacetasikā dhammā—","html":"{}"},"ds2.3.1:65.3":{"pli":"ime dhammā paccuppannārammaṇā. ","html":"{}</p>"},"ds2.3.1:66.0":{"pli":"2.3.1.20. Ajjhattattika ","html":"<h2>{}</h2>"},"ds2.3.1:66.1":{"pli":"Katame dhammā ajjhattā? ","html":"<p>{}"},"ds2.3.1:66.2":{"pli":"Ye dhammā tesaṁ tesaṁ sattānaṁ ajjhattaṁ paccattaṁ niyatā pāṭipuggalikā upādinnā, rūpaṁ, vedanā, saññā, saṅkhārā, viññāṇaṁ—","html":"{}"},"ds2.3.1:66.3":{"pli":"ime dhammā ajjhattā. ","html":"{}</p>"},"ds2.3.1:67.1":{"pli":"Katame dhammā bahiddhā? ","html":"<p>{}"},"ds2.3.1:67.2":{"pli":"Ye dhammā tesaṁ tesaṁ parasattānaṁ parapuggalānaṁ ajjhattaṁ paccattaṁ niyatā pāṭipuggalikā upādinnā, rūpaṁ, vedanā, saññā, saṅkhārā, viññāṇaṁ—","html":"{}"},"ds2.3.1:67.3":{"pli":"ime dhammā bahiddhā. ","html":"{}</p>"},"ds2.3.1:68.1":{"pli":"Katame dhammā ajjhattabahiddhā? ","html":"<p>{}"},"ds2.3.1:68.2":{"pli":"Tadubhayaṁ—","html":"{}"},"ds2.3.1:68.3":{"pli":"ime dhammā ajjhattabahiddhā. ","html":"{}</p>"},"ds2.3.1:69.0":{"pli":"2.3.1.21. Ajjhattārammaṇattika ","html":"<h2>{}</h2>"},"ds2.3.1:69.1":{"pli":"Katame dhammā ajjhattārammaṇā? ","html":"<p>{}"},"ds2.3.1:69.2":{"pli":"Ajjhatte dhamme ārabbha ye uppajjanti cittacetasikā dhammā—","html":"{}"},"ds2.3.1:69.3":{"pli":"ime dhammā ajjhattārammaṇā. ","html":"{}</p>"},"ds2.3.1:70.1":{"pli":"Katame dhammā bahiddhārammaṇā? ","html":"<p>{}"},"ds2.3.1:70.2":{"pli":"Bahiddhā dhamme ārabbha ye uppajjanti cittacetasikā dhammā—","html":"{}"},"ds2.3.1:70.3":{"pli":"ime dhammā bahiddhārammaṇā. ","html":"{}</p>"},"ds2.3.1:71.1":{"pli":"Katame dhammā ajjhattabahiddhārammaṇā? ","html":"<p>{}"},"ds2.3.1:71.2":{"pli":"Ajjhattabahiddhā dhamme ārabbha ye uppajjanti cittacetasikā dhammā—","html":"{}"},"ds2.3.1:71.3":{"pli":"ime dhammā ajjhattabahiddhārammaṇā. ","html":"{}</p>"},"ds2.3.1:72.0":{"pli":"2.3.1.22. Sanidassanattika ","html":"<h2>{}</h2>"},"ds2.3.1:72.1":{"pli":"Katame dhammā sanidassanasappaṭighā? ","html":"<p>{}"},"ds2.3.1:72.2":{"pli":"Rūpāyatanaṁ—","html":"{}"},"ds2.3.1:72.3":{"pli":"ime dhammā sanidassanasappaṭighā. ","html":"{}</p>"},"ds2.3.1:73.1":{"pli":"Katame dhammā anidassanasappaṭighā? ","html":"<p>{}"},"ds2.3.1:73.2":{"pli":"Cakkhāyatanaṁ, sotāyatanaṁ, ghānāyatanaṁ, jivhāyatanaṁ, kāyāyatanaṁ, saddāyatanaṁ, gandhāyatanaṁ, rasāyatanaṁ, phoṭṭhabbāyatanaṁ—","html":"{}"},"ds2.3.1:73.3":{"pli":"ime dhammā anidassanasappaṭighā. ","html":"{}</p>"},"ds2.3.1:74.1":{"pli":"Katame dhammā anidassanaappaṭighā? ","html":"<p>{}"},"ds2.3.1:74.2":{"pli":"Vedanākkhandho, saññākkhandho, saṅkhārakkhandho, viññāṇakkhandho; ","html":"{}"},"ds2.3.1:74.3":{"pli":"yañca rūpaṁ anidassanaṁ appaṭighaṁ dhammāyatanapariyāpannaṁ; ","html":"{}"},"ds2.3.1:74.4":{"pli":"asaṅkhatā ca dhātu—","html":"{}"},"ds2.3.1:74.5":{"pli":"ime dhammā anidassanaappaṭighā. ","html":"{}</p>"},"ds2.3.1:74.6":{"pli":"Tikaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}