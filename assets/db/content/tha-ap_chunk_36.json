.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap417:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap417:6.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap417:7.1":{"pli":"Itthaṁ sudaṁ āyasmā nāgapallavo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap417:8.1":{"pli":"Nāgapallavattherassāpadānaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap418":{"tha-ap418:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap418'><header><ul><li class='division'>{}</li>"},"tha-ap418:0.2":{"pli":"Bhaddālivagga ","html":"<li>{}</li></ul>"},"tha-ap418:0.3":{"pli":"Ekadīpiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap418:1.1":{"pli":"“Parinibbute sugate, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap418:1.2":{"pli":"siddhatthe lokanāyake; ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:1.3":{"pli":"Sadevamānusā sabbe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:1.4":{"pli":"pūjenti dvipaduttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap418:2.1":{"pli":"Āropite ca citake, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap418:2.2":{"pli":"siddhatthe lokanāyake; ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:2.3":{"pli":"Yathāsakena thāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:2.4":{"pli":"citaṁ pūjenti satthuno. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap418:3.1":{"pli":"Avidūre citakassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap418:3.2":{"pli":"dīpaṁ ujjālayiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:3.3":{"pli":"Yāva udeti sūriyo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:3.4":{"pli":"dīpaṁ me tāva ujjali. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap418:4.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap418:4.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:4.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:4.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap418:5.1":{"pli":"Tattha me sukataṁ byamhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap418:5.2":{"pli":"ekadīpīti ñāyati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:5.3":{"pli":"Dīpasatasahassāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:5.4":{"pli":"byamhe pajjalare mama. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap418:6.1":{"pli":"Udayantova sūriyo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap418:6.2":{"pli":"deho me jotate sadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:6.3":{"pli":"Sappabhāhi sarīrassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:6.4":{"pli":"āloko hoti me sadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap418:7.1":{"pli":"Tirokuṭṭaṁ tiroselaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap418:7.2":{"pli":"samatiggayha pabbataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:7.3":{"pli":"Samantā yojanasataṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:7.4":{"pli":"passāmi cakkhunā ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap418:8.1":{"pli":"Sattasattatikkhattuñca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap418:8.2":{"pli":"devaloke ramiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:8.3":{"pli":"Ekatiṁsatikkhattuñca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:8.4":{"pli":"devarajjamakārayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap418:9.1":{"pli":"Aṭṭhavīsatikkhattuñca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap418:9.2":{"pli":"cakkavattī ahosahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:9.3":{"pli":"Padesarajjaṁ vipulaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:9.4":{"pli":"gaṇanāto asaṅkhiyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap418:10.1":{"pli":"Devalokā cavitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap418:10.2":{"pli":"nibbattiṁ mātukucchiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:10.3":{"pli":"Mātukucchigatassāpi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:10.4":{"pli":"akkhi me na nimīlati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap418:11.1":{"pli":"Jātiyā catuvassohaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap418:11.2":{"pli":"pabbajiṁ anagāriyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:11.3":{"pli":"Aḍḍhamāse asampatte, ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:11.4":{"pli":"arahattamapāpuṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap418:12.1":{"pli":"Dibbacakkhuṁ visodhesiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap418:12.2":{"pli":"bhavā sabbe samūhatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:12.3":{"pli":"Sabbe kilesā sañchinnā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:12.4":{"pli":"ekadīpassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap418:13.1":{"pli":"Tirokuṭṭaṁ tiroselaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap418:13.2":{"pli":"pabbatañcāpi kevalaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:13.3":{"pli":"Samatikkamma passāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:13.4":{"pli":"ekadīpassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap418:14.1":{"pli":"Visamā me samā honti, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap418:14.2":{"pli":"andhakāro na vijjati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:14.3":{"pli":"Nāhaṁ passāmi timiraṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:14.4":{"pli":"ekadīpassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap418:15.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap418:15.2":{"pli":"yaṁ dīpamadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:15.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:15.4":{"pli":"ekadīpassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap418:16.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap418:16.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:16.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap418:17.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap418:17.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:17.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap418:18.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap418:18.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap418:18.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap418:19.1":{"pli":"Itthaṁ sudaṁ āyasmā ekadīpiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap418:20.1":{"pli":"Ekadīpiyattherassāpadānaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap419":{"tha-ap419:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap419'><header><ul><li class='division'>{}</li>"},"tha-ap419:0.2":{"pli":"Bhaddālivagga ","html":"<li>{}</li></ul>"},"tha-ap419:0.3":{"pli":"Ucchaṅgapupphiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap419:1.1":{"pli":"“Nagare bandhumatiyā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap419:1.2":{"pli":"ahosiṁ māliko tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap419:1.3":{"pli":"Ucchaṅgaṁ pūrayitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap419:1.4":{"pli":"agamaṁ antarāpaṇaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap419:2.1":{"pli":"Bhagavā tamhi samaye, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap419:2.2":{"pli":"bhikkhusaṅghapurakkhato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap419:2.3":{"pli":"Mahatā ānubhāvena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap419:2.4":{"pli":"niyyāti lokanāyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap419:3.1":{"pli":"Disvāna lokapajjotaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap419:3.2":{"pli":"vipassiṁ lokatāraṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap419:3.3":{"pli":"Pupphaṁ paggayha ucchaṅgā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap419:3.4":{"pli":"buddhaseṭṭhaṁ apūjayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap419:4.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap419:4.2":{"pli":"yaṁ pupphamabhipūjayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap419:4.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap419:4.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap419:5.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap419:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap419:5.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap419:6.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap419:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap419:6.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap419:7.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap419:7.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap419:7.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap419:8.1":{"pli":"Itthaṁ sudaṁ āyasmā ucchaṅgapupphiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap419:9.1":{"pli":"Ucchaṅgapupphiyattherassāpadānaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap42":{"tha-ap42:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap42'><header><ul><li class='division'>{}</li>"},"tha-ap42:0.2":{"pli":"Kuṇḍadhānavagga ","html":"<li>{}</li></ul>"},"tha-ap42:0.3":{"pli":"Kapparukkhiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap42:1.1":{"pli":"“Siddhatthassa bhagavato, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap42:1.2":{"pli":"thūpaseṭṭhassa sammukhā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap42:1.3":{"pli":"Vicittadusse lagetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap42:1.4":{"pli":"kapparukkhaṁ ṭhapesahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap42:2.1":{"pli":"Yaṁ yaṁ yonupapajjāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap42:2.2":{"pli":"devattaṁ atha mānusaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap42:2.3":{"pli":"Sobhayanto mama dvāraṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap42:2.4":{"pli":"kapparukkho patiṭṭhati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap42:3.1":{"pli":"Ahañca parisā ceva, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap42:3.2":{"pli":"ye keci mama vassitā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap42:3.3":{"pli":"Tamhā dussaṁ gahetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap42:3.4":{"pli":"nivāsema mayaṁ sadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap42:4.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap42:4.2":{"pli":"yaṁ rukkhaṁ ṭhapayiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap42:4.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap42:4.4":{"pli":"kapparukkhassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap42:5.1":{"pli":"Ito ca sattame kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap42:5.2":{"pli":"suceḷā aṭṭha khattiyā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap42:5.3":{"pli":"Sattaratanasampannā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap42:5.4":{"pli":"cakkavattī mahabbalā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap42:6.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap42:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap42:6.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap42:7.1":{"pli":"Itthaṁ sudaṁ āyasmā kapparukkhiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap42:8.1":{"pli":"Kapparukkhiyattherassāpadānaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap42:9.1":{"pli":"Kuṇḍadhānavaggo catuttho. ","html":"<p class='endsection'>{}</p>"},"tha-ap42:10.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"tha-ap42:11.1":{"pli":"Kuṇḍasāgatakaccānā, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"tha-ap42:11.2":{"pli":"udāyī mogharājako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap42:11.3":{"pli":"Adhimutto lasuṇado, ","html":"<span class='verse-line'>{}</span>"},"tha-ap42:11.4":{"pli":"āyāgī dhammacakkiko; ","html":"<span class='verse-line'>{}</span>"},"tha-ap42:11.5":{"pli":"Kapparukkhī ca dasamo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap42:11.6":{"pli":"gāthā dvayadasasataṁ. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"tha-ap420":{"tha-ap420:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap420'><header><ul><li class='division'>{}</li>"},"tha-ap420:0.2":{"pli":"Bhaddālivagga ","html":"<li>{}</li></ul>"},"tha-ap420:0.3":{"pli":"Yāgudāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap420:1.1":{"pli":"“Atithiṁ me gahetvāna, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap420:1.2":{"pli":"agacchiṁ gāmakaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:1.3":{"pli":"Sampuṇṇanadikaṁ disvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:1.4":{"pli":"saṅghārāmaṁ upāgamiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap420:2.1":{"pli":"Āraññakā dhutadharā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap420:2.2":{"pli":"jhāyino lūkhacīvarā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:2.3":{"pli":"Vivekābhiratā dhīrā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:2.4":{"pli":"saṅghārāme vasanti te. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap420:3.1":{"pli":"Gati tesaṁ upacchinnā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap420:3.2":{"pli":"suvimuttāna tādinaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:3.3":{"pli":"Piṇḍāya te na gacchanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:3.4":{"pli":"oruddhanaditāya hi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap420:4.1":{"pli":"Pasannacitto sumano, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap420:4.2":{"pli":"vedajāto katañjalī; ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:4.3":{"pli":"Taṇḍulaṁ me gahetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:4.4":{"pli":"yāgudānaṁ adāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap420:5.1":{"pli":"Pañcannaṁ yāguṁ datvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap420:5.2":{"pli":"pasanno sehi pāṇibhi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:5.3":{"pli":"Sakakammābhiraddhohaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:5.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap420:6.1":{"pli":"Maṇimayañca me byamhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap420:6.2":{"pli":"nibbatti tidase gaṇe; ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:6.3":{"pli":"Nārīgaṇehi sahito, ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:6.4":{"pli":"modāmi byamhamuttame. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap420:7.1":{"pli":"Tettiṁsakkhattuṁ devindo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap420:7.2":{"pli":"devarajjamakārayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:7.3":{"pli":"Tiṁsakkhattuṁ cakkavattī, ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:7.4":{"pli":"mahārajjamakārayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap420:8.1":{"pli":"Padesarajjaṁ vipulaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap420:8.2":{"pli":"gaṇanāto asaṅkhiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:8.3":{"pli":"Devaloke manusse vā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:8.4":{"pli":"anubhotvā sayaṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap420:9.1":{"pli":"Pacchime bhave sampatte, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap420:9.2":{"pli":"pabbajiṁ anagāriyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:9.3":{"pli":"Saha oropite kese, ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:9.4":{"pli":"sabbaṁ sampaṭivijjhahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap420:10.1":{"pli":"Khayato vayato cāpi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap420:10.2":{"pli":"sammasanto kaḷevaraṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:10.3":{"pli":"Pure sikkhāpadādānā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:10.4":{"pli":"arahattamapāpuṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap420:11.1":{"pli":"Sudinnaṁ me dānavaraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap420:11.2":{"pli":"vāṇijjaṁ sampayojitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:11.3":{"pli":"Teneva yāgudānena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:11.4":{"pli":"pattomhi acalaṁ padaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap420:12.1":{"pli":"Sokaṁ pariddavaṁ byādhiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap420:12.2":{"pli":"darathaṁ cittatāpanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:12.3":{"pli":"Nābhijānāmi uppannaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:12.4":{"pli":"yāgudānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap420:13.1":{"pli":"Yāguṁ saṅghassa datvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap420:13.2":{"pli":"puññakkhette anuttare; ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:13.3":{"pli":"Pañcānisaṁse anubhomi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:13.4":{"pli":"aho yāgusuyiṭṭhatā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap420:14.1":{"pli":"Abyādhitā rūpavatā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap420:14.2":{"pli":"khippaṁ dhammanisantitā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:14.3":{"pli":"Lābhitā annapānassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:14.4":{"pli":"āyu pañcamakaṁ mama. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap420:15.1":{"pli":"Yo koci vedaṁ janayaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap420:15.2":{"pli":"saṅghe yāguṁ dadeyya so; ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:15.3":{"pli":"Imāni pañca ṭhānāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:15.4":{"pli":"paṭigaṇheyya paṇḍito. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap420:16.1":{"pli":"Karaṇīyaṁ kataṁ sabbaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap420:16.2":{"pli":"bhavā ugghāṭitā mayā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:16.3":{"pli":"Sabbāsavā parikkhīṇā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:16.4":{"pli":"natthi dāni punabbhavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap420:17.1":{"pli":"So ahaṁ vicarissāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap420:17.2":{"pli":"gāmā gāmaṁ purā puraṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:17.3":{"pli":"Namassamāno sambuddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:17.4":{"pli":"dhammassa ca sudhammataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap420:18.1":{"pli":"Tiṁsakappasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap420:18.2":{"pli":"yaṁ dānamadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:18.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:18.4":{"pli":"yāgudānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap420:19.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap420:19.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:19.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap420:20.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap420:20.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:20.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap420:21.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap420:21.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap420:21.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap420:22.1":{"pli":"Itthaṁ sudaṁ āyasmā yāgudāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap420:23.1":{"pli":"Yāgudāyakattherassāpadānaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap421":{"tha-ap421:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap421'><header><ul><li class='division'>{}</li>"},"tha-ap421:0.2":{"pli":"Bhaddālivagga ","html":"<li>{}</li></ul>"},"tha-ap421:0.3":{"pli":"Patthodanadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap421:1.1":{"pli":"“Vanacārī pure āsiṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap421:1.2":{"pli":"satataṁ vanakammiko; ","html":"<span class='verse-line'>{}</span>"},"tha-ap421:1.3":{"pli":"Patthodanaṁ gahetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap421:1.4":{"pli":"kammantaṁ agamāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap421:2.1":{"pli":"Tatthaddasāsiṁ sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap421:2.2":{"pli":"sayambhuṁ aparājitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap421:2.3":{"pli":"Vanā piṇḍāya nikkhantaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap421:2.4":{"pli":"disvā cittaṁ pasādayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap421:3.1":{"pli":"Parakammāyane yutto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap421:3.2":{"pli":"puññañca me na vijjati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap421:3.3":{"pli":"Ayaṁ patthodano atthi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap421:3.4":{"pli":"bhojayissāmahaṁ muniṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap421:4.1":{"pli":"Patthodanaṁ gahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap421:4.2":{"pli":"sayambhussa adāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap421:4.3":{"pli":"Mama nijjhāyamānassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap421:4.4":{"pli":"paribhuñji tadā muni. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap421:5.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap421:5.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap421:5.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap421:5.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap421:6.1":{"pli":"Chattiṁsakkhattuṁ devindo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap421:6.2":{"pli":"devarajjamakārayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap421:6.3":{"pli":"Tettiṁsakkhattuṁ rājā ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap421:6.4":{"pli":"cakkavattī ahosahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap421:7.1":{"pli":"Padesarajjaṁ vipulaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap421:7.2":{"pli":"gaṇanāto asaṅkhiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap421:7.3":{"pli":"Sukhito yasavā homi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap421:7.4":{"pli":"patthodanassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap421:8.1":{"pli":"Bhavābhave saṁsaranto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap421:8.2":{"pli":"labhāmi amitaṁ dhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap421:8.3":{"pli":"Bhoge me ūnatā natthi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap421:8.4":{"pli":"patthodanassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap421:9.1":{"pli":"Nadīsotapaṭibhāgā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap421:9.2":{"pli":"bhogā nibbattare mama; ","html":"<span class='verse-line'>{}</span>"},"tha-ap421:9.3":{"pli":"Parimetuṁ na sakkomi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap421:9.4":{"pli":"patthodanassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap421:10.1":{"pli":"Imaṁ khāda imaṁ bhuñja, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap421:10.2":{"pli":"imamhi sayane saya; ","html":"<span class='verse-line'>{}</span>"},"tha-ap421:10.3":{"pli":"Tenāhaṁ sukhito homi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap421:10.4":{"pli":"patthodanassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap421:11.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap421:11.2":{"pli":"yaṁ dānamadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap421:11.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap421:11.4":{"pli":"patthodanassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap421:12.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap421:12.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap421:12.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap421:13.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap421:13.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap421:13.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap421:14.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap421:14.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap421:14.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap421:15.1":{"pli":"Itthaṁ sudaṁ āyasmā patthodanadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap421:16.1":{"pli":"Patthodanadāyakattherassāpadānaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap422":{"tha-ap422:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap422'><header><ul><li class='division'>{}</li>"},"tha-ap422:0.2":{"pli":"Bhaddālivagga ","html":"<li>{}</li></ul>"},"tha-ap422:0.3":{"pli":"Mañcadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap422:1.1":{"pli":"“Parinibbute kāruṇike, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap422:1.2":{"pli":"siddhatthe lokanāyake; ","html":"<span class='verse-line'>{}</span>"},"tha-ap422:1.3":{"pli":"Vitthārike pāvacane, ","html":"<span class='verse-line'>{}</span>"},"tha-ap422:1.4":{"pli":"devamānusasakkate. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap422:2.1":{"pli":"Caṇḍālo āsahaṁ tattha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap422:2.2":{"pli":"āsandipīṭhakārako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap422:2.3":{"pli":"Tena kammena jīvāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap422:2.4":{"pli":"tena posemi dārake. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap422:3.1":{"pli":"Āsandiṁ sukataṁ katvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap422:3.2":{"pli":"pasanno sehi pāṇibhi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap422:3.3":{"pli":"Sayamevupagantvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap422:3.4":{"pli":"bhikkhusaṅghassadāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap422:4.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap422:4.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap422:4.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap422:4.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap422:5.1":{"pli":"Devalokagato santo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap422:5.2":{"pli":"modāmi tidase gaṇe; ","html":"<span class='verse-line'>{}</span>"},"tha-ap422:5.3":{"pli":"Sayanāni mahagghāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap422:5.4":{"pli":"nibbattanti yadicchakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap422:6.1":{"pli":"Paññāsakkhattuṁ devindo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap422:6.2":{"pli":"devarajjamakārayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap422:6.3":{"pli":"Asītikkhattuṁ rājā ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap422:6.4":{"pli":"cakkavattī ahosahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap422:7.1":{"pli":"Padesarajjaṁ vipulaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap422:7.2":{"pli":"gaṇanāto asaṅkhiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap422:7.3":{"pli":"Sukhito yasavā homi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap422:7.4":{"pli":"mañcadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap422:8.1":{"pli":"Devalokā cavitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap422:8.2":{"pli":"emi ce mānusaṁ bhavaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap422:8.3":{"pli":"Mahārahā susayanā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap422:8.4":{"pli":"sayameva bhavanti me. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap422:9.1":{"pli":"Ayaṁ pacchimako mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap422:9.2":{"pli":"carimo vattate bhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap422:9.3":{"pli":"Ajjāpi sayane kāle, ","html":"<span class='verse-line'>{}</span>"},"tha-ap422:9.4":{"pli":"sayanaṁ upatiṭṭhati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap422:10.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap422:10.2":{"pli":"yaṁ dānamadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap422:10.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap422:10.4":{"pli":"mañcadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap422:11.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap422:11.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap422:11.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap422:12.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap422:12.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap422:12.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap422:13.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap422:13.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap422:13.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap422:14.1":{"pli":"Itthaṁ sudaṁ āyasmā mañcadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap422:15.1":{"pli":"Mañcadāyakattherassāpadānaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap422:16.1":{"pli":"Bhaddālivaggo bācattālīsamo. ","html":"<p class='endsection'>{}</p>"},"tha-ap422:17.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"tha-ap422:18.1":{"pli":"Bhaddālī ekachatto ca, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"tha-ap422:18.2":{"pli":"tiṇasūlo ca maṁsado; ","html":"<span class='verse-line'>{}</span>"},"tha-ap422:18.3":{"pli":"Nāgapallaviko dīpī, ","html":"<span class='verse-line'>{}</span>"},"tha-ap422:18.4":{"pli":"ucchaṅgi yāgudāyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap422:19.1":{"pli":"Patthodanī mañcadado, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap422:19.2":{"pli":"gāthāyo gaṇitā ciha; ","html":"<span class='verse-line'>{}</span>"},"tha-ap422:19.3":{"pli":"Dvesatāni ca gāthānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap422:19.4":{"pli":"gāthā cekā taduttari. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"tha-ap423":{"tha-ap423:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap423'><header><ul><li class='division'>{}</li>"},"tha-ap423:0.2":{"pli":"Sakiṁsammajjakavagga ","html":"<li>{}</li></ul>"},"tha-ap423:0.3":{"pli":"Sakiṁsammajjakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap423:1.1":{"pli":"“Vipassino bhagavato, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap423:1.2":{"pli":"pāṭaliṁ bodhimuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap423:1.3":{"pli":"Disvāva taṁ pādapaggaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap423:1.4":{"pli":"tattha cittaṁ pasādayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap423:2.1":{"pli":"Sammajjaniṁ gahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap423:2.2":{"pli":"bodhiṁ sammajji tāvade; ","html":"<span class='verse-line'>{}</span>"},"tha-ap423:2.3":{"pli":"Sammajjitvāna taṁ bodhiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap423:2.4":{"pli":"avandiṁ pāṭaliṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap423:3.1":{"pli":"Tattha cittaṁ pasādetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap423:3.2":{"pli":"sire katvāna añjaliṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap423:3.3":{"pli":"Namassamāno taṁ bodhiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap423:3.4":{"pli":"gañchiṁ paṭikuṭiṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap423:4.1":{"pli":"Tādimaggena gacchāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap423:4.2":{"pli":"saranto bodhimuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap423:4.3":{"pli":"Ajagaro maṁ pīḷesi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap423:4.4":{"pli":"ghorarūpo mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap423:5.1":{"pli":"Āsanne me kataṁ kammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap423:5.2":{"pli":"phalena tosayī mamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap423:5.3":{"pli":"Kaḷevaraṁ me gilati, ","html":"<span class='verse-line'>{}</span>"},"tha-ap423:5.4":{"pli":"devaloke ramāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap423:6.1":{"pli":"Anāvilaṁ mama cittaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap423:6.2":{"pli":"visuddhaṁ paṇḍaraṁ sadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap423:6.3":{"pli":"Sokasallaṁ na jānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap423:6.4":{"pli":"cittasantāpanaṁ mama. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap423:7.1":{"pli":"Kuṭṭhaṁ gaṇḍo kilāso ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap423:7.2":{"pli":"apamāro vitacchikā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap423:7.3":{"pli":"Daddu kaṇḍu ca me natthi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap423:7.4":{"pli":"phalaṁ sammajjanāyidaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap423:8.1":{"pli":"Soko ca paridevo ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap423:8.2":{"pli":"hadaye me na vijjati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap423:8.3":{"pli":"Abhantaṁ ujukaṁ cittaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap423:8.4":{"pli":"phalaṁ sammajjanāyidaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap423:9.1":{"pli":"Samādhīsu na majjāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap423:9.2":{"pli":"visadaṁ hoti mānasaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap423:9.3":{"pli":"Yaṁ yaṁ samādhimicchāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap423:9.4":{"pli":"so so sampajjate mamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap423:10.1":{"pli":"Rajanīye na rajjāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap423:10.2":{"pli":"atho dussaniyesu ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap423:10.3":{"pli":"Mohanīye na muyhāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap423:10.4":{"pli":"phalaṁ sammajjanāyidaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap423:11.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap423:11.2":{"pli":"yaṁ kammamakariṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap423:11.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap423:11.4":{"pli":"phalaṁ sammajjanāyidaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap423:12.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap423:12.2":{"pli":"bhavā sabbe samūhatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap423:12.3":{"pli":"Nāgova bandhanaṁ chetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap423:12.4":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap423:13.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap423:13.2":{"pli":"mama buddhassa santike; ","html":"<span class='verse-line'>{}</span>"},"tha-ap423:13.3":{"pli":"Tisso vijjā anuppattā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap423:13.4":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap423:14.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap423:14.2":{"pli":"vimokkhāpi ca aṭṭhime; ","html":"<span class='verse-line'>{}</span>"},"tha-ap423:14.3":{"pli":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap423:14.4":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap423:15.1":{"pli":"Itthaṁ sudaṁ āyasmā sakiṁsammajjako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap423:16.1":{"pli":"Sakiṁsammajjakattherassāpadānaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}