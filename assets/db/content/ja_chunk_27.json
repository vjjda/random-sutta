{"ja504":{"ja504:0.1":{"pli":"Jātaka ","html":"<article id='ja504'><header><ul><li class='division'>{}</li>"},"ja504:0.2":{"pli":"Vīsatinipāta ","html":"<li>{}</li>"},"ja504:0.3":{"pli":"Mātaṅgavagga ","html":"<li>{}</li></ul>"},"ja504:0.4":{"pli":"8. Bhallātiyajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja504:1.1":{"pli":"Bhallātiyo nāma ahosi rājā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja504:1.2":{"pli":"Raṭṭhaṁ pahāya migavaṁ acāri so; ","html":"<span class='verse-line'>{}</span>"},"ja504:1.3":{"pli":"Agamā girivaraṁ gandhamādanaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja504:1.4":{"pli":"Supupphitaṁ kimpurisānuciṇṇaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja504:2.1":{"pli":"Sāḷūrasaṅghañca nisedhayitvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja504:2.2":{"pli":"Dhanuṁ kalāpañca so nikkhipitvā; ","html":"<span class='verse-line'>{}</span>"},"ja504:2.3":{"pli":"Upāgami vacanaṁ vattukāmo, ","html":"<span class='verse-line'>{}</span>"},"ja504:2.4":{"pli":"Yatthaṭṭhitā kimpurisā ahesuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja504:3.1":{"pli":"“Himaccaye hemavatāya tīre, ","html":"<p><span class='verse-line'>{}</span>"},"ja504:3.2":{"pli":"Kimidhaṭṭhitā mantayavho abhiṇhaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja504:3.3":{"pli":"Pucchāmi vo mānusadehavaṇṇe, ","html":"<span class='verse-line'>{}</span>"},"ja504:3.4":{"pli":"Kathaṁ vo jānanti manussaloke”. ","html":"<span class='verse-line'>{}</span></p>"},"ja504:4.1":{"pli":"“Mallaṁ giriṁ paṇḍarakaṁ tikūṭaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja504:4.2":{"pli":"Sītodakā anuvicarāma najjo; ","html":"<span class='verse-line'>{}</span>"},"ja504:4.3":{"pli":"Migā manussāva nibhāsavaṇṇā, ","html":"<span class='verse-line'>{}</span>"},"ja504:4.4":{"pli":"Jānanti no kimpurisāti ludda”. ","html":"<span class='verse-line'>{}</span></p>"},"ja504:5.1":{"pli":"“Sukiccharūpaṁ paridevayavho, ","html":"<p><span class='verse-line'>{}</span>"},"ja504:5.2":{"pli":"Āliṅgito cāsi piyo piyāya; ","html":"<span class='verse-line'>{}</span>"},"ja504:5.3":{"pli":"Pucchāmi vo mānusadehavaṇṇe, ","html":"<span class='verse-line'>{}</span>"},"ja504:5.4":{"pli":"Kimidha vane rodatha appatītā. ","html":"<span class='verse-line'>{}</span></p>"},"ja504:6.1":{"pli":"Sukiccharūpaṁ paridevayavho, ","html":"<p><span class='verse-line'>{}</span>"},"ja504:6.2":{"pli":"Āliṅgito cāsi piyo piyāya; ","html":"<span class='verse-line'>{}</span>"},"ja504:6.3":{"pli":"Pucchāmi vo mānusadehavaṇṇe, ","html":"<span class='verse-line'>{}</span>"},"ja504:6.4":{"pli":"Kimidha vane vilapatha appatītā. ","html":"<span class='verse-line'>{}</span></p>"},"ja504:7.1":{"pli":"Sukiccharūpaṁ paridevayavho, ","html":"<p><span class='verse-line'>{}</span>"},"ja504:7.2":{"pli":"Āliṅgito cāsi piyo piyāya; ","html":"<span class='verse-line'>{}</span>"},"ja504:7.3":{"pli":"Pucchāmi vo mānusadehavaṇṇe, ","html":"<span class='verse-line'>{}</span>"},"ja504:7.4":{"pli":"Kimidha vane socatha appatītā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja504:8.1":{"pli":"“Mayekarattaṁ vippavasimha ludda, ","html":"<p><span class='verse-line'>{}</span>"},"ja504:8.2":{"pli":"Akāmakā aññamaññaṁ sarantā; ","html":"<span class='verse-line'>{}</span>"},"ja504:8.3":{"pli":"Tamekarattaṁ anutappamānā, ","html":"<span class='verse-line'>{}</span>"},"ja504:8.4":{"pli":"Socāma ‘sā ratti punaṁ na hessati’”. ","html":"<span class='verse-line'>{}</span></p>"},"ja504:9.1":{"pli":"“Yamekarattaṁ anutappathetaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja504:9.2":{"pli":"Dhanaṁ va naṭṭhaṁ pitaraṁ va petaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja504:9.3":{"pli":"Pucchāmi vo mānusadehavaṇṇe, ","html":"<span class='verse-line'>{}</span>"},"ja504:9.4":{"pli":"Kathaṁ vinā vāsamakappayittha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja504:10.1":{"pli":"“Yamimaṁ nadiṁ passasi sīghasotaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja504:10.2":{"pli":"Nānādumacchādanaṁ selakūlaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja504:10.3":{"pli":"Taṁ me piyo uttari vassakāle, ","html":"<span class='verse-line'>{}</span>"},"ja504:10.4":{"pli":"Mamañca maññaṁ anubandhatīti. ","html":"<span class='verse-line'>{}</span></p>"},"ja504:11.1":{"pli":"Ahañca aṅkolakamocināmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja504:11.2":{"pli":"Atimuttakaṁ sattaliyothikañca; ","html":"<span class='verse-line'>{}</span>"},"ja504:11.3":{"pli":"‘Piyo ca me hehiti mālabhārī, ","html":"<span class='verse-line'>{}</span>"},"ja504:11.4":{"pli":"Ahañca naṁ mālinī ajjhupessaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"ja504:12.1":{"pli":"Ahañcidaṁ kuravakamocināmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja504:12.2":{"pli":"Uddālakā pāṭalisindhuvārakā; ","html":"<span class='verse-line'>{}</span>"},"ja504:12.3":{"pli":"‘Piyo ca me hehiti mālabhārī, ","html":"<span class='verse-line'>{}</span>"},"ja504:12.4":{"pli":"Ahañca naṁ mālinī ajjhupessaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"ja504:13.1":{"pli":"Ahañca sālassa supupphitassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja504:13.2":{"pli":"Oceyya pupphāni karomi mālaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja504:13.3":{"pli":"‘Piyo ca me hehiti mālabhārī, ","html":"<span class='verse-line'>{}</span>"},"ja504:13.4":{"pli":"Ahañca naṁ mālinī ajjhupessaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"ja504:14.1":{"pli":"Ahañca sālassa supupphitassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja504:14.2":{"pli":"Oceyya pupphāni karomi bhāraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja504:14.3":{"pli":"Idañca no hehiti santharatthaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja504:14.4":{"pli":"Yatthajjimaṁ viharissāma rattiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja504:15.1":{"pli":"Ahañca kho agaḷuṁ candanañca, ","html":"<p><span class='verse-line'>{}</span>"},"ja504:15.2":{"pli":"Silāya piṁsāmi pamattarūpā; ","html":"<span class='verse-line'>{}</span>"},"ja504:15.3":{"pli":"‘Piyo ca me hehiti rositaṅgo, ","html":"<span class='verse-line'>{}</span>"},"ja504:15.4":{"pli":"Ahañca naṁ rositā ajjhupessaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"ja504:16.1":{"pli":"Athāgamā salilaṁ sīghasotaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja504:16.2":{"pli":"Nudaṁ sāle salaḷe kaṇṇikāre; ","html":"<span class='verse-line'>{}</span>"},"ja504:16.3":{"pli":"Āpūratha tena muhuttakena, ","html":"<span class='verse-line'>{}</span>"},"ja504:16.4":{"pli":"Sāyaṁ nadī āsi mayā suduttarā. ","html":"<span class='verse-line'>{}</span></p>"},"ja504:17.1":{"pli":"Ubhosu tīresu mayaṁ tadā ṭhitā, ","html":"<p><span class='verse-line'>{}</span>"},"ja504:17.2":{"pli":"Sampassantā ubhayo aññamaññaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja504:17.3":{"pli":"Sakimpi rodāma sakiṁ hasāma, ","html":"<span class='verse-line'>{}</span>"},"ja504:17.4":{"pli":"Kicchena no āgamā saṁvarī sā. ","html":"<span class='verse-line'>{}</span></p>"},"ja504:18.1":{"pli":"Pātova kho uggate sūriyamhi, ","html":"<p><span class='verse-line'>{}</span>"},"ja504:18.2":{"pli":"Catukkaṁ nadiṁ uttariyāna ludda; ","html":"<span class='verse-line'>{}</span>"},"ja504:18.3":{"pli":"Āliṅgiyā aññamaññaṁ mayaṁ ubho, ","html":"<span class='verse-line'>{}</span>"},"ja504:18.4":{"pli":"Sakimpi rodāma sakiṁ hasāma. ","html":"<span class='verse-line'>{}</span></p>"},"ja504:19.1":{"pli":"Tīhūnakaṁ sattasatāni ludda, ","html":"<p><span class='verse-line'>{}</span>"},"ja504:19.2":{"pli":"Yamidha mayaṁ vippavasimha pubbe; ","html":"<span class='verse-line'>{}</span>"},"ja504:19.3":{"pli":"Vassekimaṁ jīvitaṁ bhūmipāla, ","html":"<span class='verse-line'>{}</span>"},"ja504:19.4":{"pli":"Ko nīdha kantāya vinā vaseyya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja504:20.1":{"pli":"“Āyuñca vo kīvatako nu samma, ","html":"<p><span class='verse-line'>{}</span>"},"ja504:20.2":{"pli":"Sacepi jānātha vadetha āyuṁ; ","html":"<span class='verse-line'>{}</span>"},"ja504:20.3":{"pli":"Anussavā vuḍḍhato āgamā vā, ","html":"<span class='verse-line'>{}</span>"},"ja504:20.4":{"pli":"Akkhātha me taṁ avikampamānā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja504:21.1":{"pli":"“Āyuñca no vassasahassaṁ ludda, ","html":"<p><span class='verse-line'>{}</span>"},"ja504:21.2":{"pli":"Na cantarā pāpako atthi rogo; ","html":"<span class='verse-line'>{}</span>"},"ja504:21.3":{"pli":"Appañca dukkhaṁ sukhameva bhiyyo, ","html":"<span class='verse-line'>{}</span>"},"ja504:21.4":{"pli":"Avītarāgā vijahāma jīvitaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja504:22.1":{"pli":"“Idañca sutvāna amānusānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja504:22.2":{"pli":"Bhallātiyo ittara jīvitanti; ","html":"<span class='verse-line'>{}</span>"},"ja504:22.3":{"pli":"Nivattatha na migavaṁ acari, ","html":"<span class='verse-line'>{}</span>"},"ja504:22.4":{"pli":"Adāsi dānāni abhuñji bhoge. ","html":"<span class='verse-line'>{}</span></p>"},"ja504:23.1":{"pli":"Idañca sutvāna amānusānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja504:23.2":{"pli":"Sammodatha mā kalahaṁ akattha; ","html":"<span class='verse-line'>{}</span>"},"ja504:23.3":{"pli":"Mā vo tapī attakammāparādho, ","html":"<span class='verse-line'>{}</span>"},"ja504:23.4":{"pli":"Yathāpi te kimpurisekarattaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja504:24.1":{"pli":"Idañca sutvāna amānusānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja504:24.2":{"pli":"Sammodatha mā vivādaṁ akattha; ","html":"<span class='verse-line'>{}</span>"},"ja504:24.3":{"pli":"Mā vo tapī attakammāparādho, ","html":"<span class='verse-line'>{}</span>"},"ja504:24.4":{"pli":"Yathāpi te kimpurisekarattaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja504:25.1":{"pli":"“Vividhaṁ adhimanā suṇomahaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja504:25.2":{"pli":"Vacanapathaṁ tava atthasaṁhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja504:25.3":{"pli":"Muñcaṁ giraṁ nudaseva me daraṁ, ","html":"<span class='verse-line'>{}</span>"},"ja504:25.4":{"pli":"Samaṇa sukhāvaha jīva me ciran”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja504:26.1":{"pli":"Bhallātiyajātakaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja505":{"ja505:0.1":{"pli":"Jātaka ","html":"<article id='ja505'><header><ul><li class='division'>{}</li>"},"ja505:0.2":{"pli":"Vīsatinipāta ","html":"<li>{}</li>"},"ja505:0.3":{"pli":"Mātaṅgavagga ","html":"<li>{}</li></ul>"},"ja505:0.4":{"pli":"9. Somanassajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja505:1.1":{"pli":"“Ko taṁ hiṁsati heṭheti, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja505:1.2":{"pli":"Kiṁ dummano socasi appatīto; ","html":"<span class='verse-line'>{}</span>"},"ja505:1.3":{"pli":"Kassajja mātāpitaro rudantu, ","html":"<span class='verse-line'>{}</span>"},"ja505:1.4":{"pli":"Kvajja setu nihato pathabyā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja505:2.1":{"pli":"“Tuṭṭhosmi deva tava dassanena, ","html":"<p><span class='verse-line'>{}</span>"},"ja505:2.2":{"pli":"Cirassaṁ passāmi taṁ bhūmipāla; ","html":"<span class='verse-line'>{}</span>"},"ja505:2.3":{"pli":"Ahiṁsako reṇumanuppavissa, ","html":"<span class='verse-line'>{}</span>"},"ja505:2.4":{"pli":"Puttena te heṭhayitosmi deva”. ","html":"<span class='verse-line'>{}</span></p>"},"ja505:3.1":{"pli":"“Āyantu dovārikā khaggabandhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja505:3.2":{"pli":"Kāsāviyā yantu antepurantaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja505:3.3":{"pli":"Hantvāna taṁ somanassaṁ kumāraṁ, ","html":"<span class='verse-line'>{}</span>"},"ja505:3.4":{"pli":"Chetvāna sīsaṁ varamāharantu”. ","html":"<span class='verse-line'>{}</span></p>"},"ja505:4.1":{"pli":"“Pesitā rājino dūtā, ","html":"<p><span class='verse-line'>{}</span>"},"ja505:4.2":{"pli":"kumāraṁ etadabravuṁ; ","html":"<span class='verse-line'>{}</span>"},"ja505:4.3":{"pli":"Issarena vitiṇṇosi, ","html":"<span class='verse-line'>{}</span>"},"ja505:4.4":{"pli":"vadhaṁ pattosi khattiya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja505:5.1":{"pli":"“Sa rājaputto paridevayanto, ","html":"<p><span class='verse-line'>{}</span>"},"ja505:5.2":{"pli":"Dasaṅguliṁ añjaliṁ paggahetvā; ","html":"<span class='verse-line'>{}</span>"},"ja505:5.3":{"pli":"Ahampi icchāmi janinda daṭṭhuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja505:5.4":{"pli":"Jīvaṁ maṁ netvā paṭidassayetha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja505:6.1":{"pli":"Tassa taṁ vacanaṁ sutvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja505:6.2":{"pli":"rañño puttaṁ adassayuṁ; ","html":"<span class='verse-line'>{}</span>"},"ja505:6.3":{"pli":"Putto ca pitaraṁ disvā, ","html":"<span class='verse-line'>{}</span>"},"ja505:6.4":{"pli":"dūratovajjhabhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"ja505:7.1":{"pli":"“Āgacchuṁ dovārikā khaggabandhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja505:7.2":{"pli":"Kāsāviyā hantu mamaṁ janinda; ","html":"<span class='verse-line'>{}</span>"},"ja505:7.3":{"pli":"Akkhāhi me pucchito etamatthaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja505:7.4":{"pli":"Aparādho ko nidha mamajja atthi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja505:8.1":{"pli":"“Sāyañca pāto udakaṁ sajāti, ","html":"<p><span class='verse-line'>{}</span>"},"ja505:8.2":{"pli":"Aggiṁ sadā pāricaratappamatto; ","html":"<span class='verse-line'>{}</span>"},"ja505:8.3":{"pli":"Taṁ tādisaṁ saṁyataṁ brahmacāriṁ, ","html":"<span class='verse-line'>{}</span>"},"ja505:8.4":{"pli":"Kasmā tuvaṁ brūsi gahappatīti”. ","html":"<span class='verse-line'>{}</span></p>"},"ja505:9.1":{"pli":"“Tālā ca mūlā ca phalā ca deva, ","html":"<p><span class='verse-line'>{}</span>"},"ja505:9.2":{"pli":"Pariggahā vividhā santimassa; ","html":"<span class='verse-line'>{}</span>"},"ja505:9.3":{"pli":"Te rakkhati gopayatappamatto, ","html":"<span class='verse-line'>{}</span>"},"ja505:9.4":{"pli":"Tasmā ahaṁ brūmi gahappatīti”. ","html":"<span class='verse-line'>{}</span></p>"},"ja505:10.1":{"pli":"“Saccaṁ kho etaṁ vadasi kumāra, ","html":"<p><span class='verse-line'>{}</span>"},"ja505:10.2":{"pli":"Pariggahā vividhā santimassa; ","html":"<span class='verse-line'>{}</span>"},"ja505:10.3":{"pli":"Te rakkhati gopayatappamatto, ","html":"<span class='verse-line'>{}</span>"},"ja505:10.4":{"pli":"Sa brāhmaṇo gahapati tena hoti”. ","html":"<span class='verse-line'>{}</span></p>"},"ja505:11.1":{"pli":"“Suṇantu mayhaṁ parisā samāgatā, ","html":"<p><span class='verse-line'>{}</span>"},"ja505:11.2":{"pli":"Sanegamā jānapadā ca sabbe; ","html":"<span class='verse-line'>{}</span>"},"ja505:11.3":{"pli":"Bālāyaṁ bālassa vaco nisamma, ","html":"<span class='verse-line'>{}</span>"},"ja505:11.4":{"pli":"Ahetunā ghātayate maṁ janindo. ","html":"<span class='verse-line'>{}</span></p>"},"ja505:12.1":{"pli":"Daḷhasmi mūle visaṭe virūḷhe, ","html":"<p><span class='verse-line'>{}</span>"},"ja505:12.2":{"pli":"Dunnikkayo veḷu pasākhajāto; ","html":"<span class='verse-line'>{}</span>"},"ja505:12.3":{"pli":"Vandāmi pādāni tava janinda, ","html":"<span class='verse-line'>{}</span>"},"ja505:12.4":{"pli":"Anujāna maṁ pabbajissāmi deva”. ","html":"<span class='verse-line'>{}</span></p>"},"ja505:13.1":{"pli":"“Bhuñjassu bhoge vipule kumāra, ","html":"<p><span class='verse-line'>{}</span>"},"ja505:13.2":{"pli":"Sabbañca te issariyaṁ dadāmi; ","html":"<span class='verse-line'>{}</span>"},"ja505:13.3":{"pli":"Ajjeva tvaṁ kurūnaṁ hohi rājā, ","html":"<span class='verse-line'>{}</span>"},"ja505:13.4":{"pli":"Mā pabbajī pabbajjā hi dukkhā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja505:14.1":{"pli":"“Kinnūdha deva tavamatthi bhogā, ","html":"<p><span class='verse-line'>{}</span>"},"ja505:14.2":{"pli":"Pubbevahaṁ devaloke ramissaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja505:14.3":{"pli":"Rūpehi saddehi atho rasehi, ","html":"<span class='verse-line'>{}</span>"},"ja505:14.4":{"pli":"Gandhehi phassehi manoramehi. ","html":"<span class='verse-line'>{}</span></p>"},"ja505:15.1":{"pli":"Bhuttā ca me bhogā tidivasmiṁ deva, ","html":"<p><span class='verse-line'>{}</span>"},"ja505:15.2":{"pli":"Parivārito accharānaṁ gaṇena; ","html":"<span class='verse-line'>{}</span>"},"ja505:15.3":{"pli":"Tuvañca bālaṁ paraneyyaṁ viditvā, ","html":"<span class='verse-line'>{}</span>"},"ja505:15.4":{"pli":"Na tādise rājakule vaseyyaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja505:16.1":{"pli":"“Sacāhaṁ bālo paraneyyo asmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja505:16.2":{"pli":"Ekāparādhaṁ khama putta mayhaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja505:16.3":{"pli":"Punapi ce edisakaṁ bhaveyya, ","html":"<span class='verse-line'>{}</span>"},"ja505:16.4":{"pli":"Yathāmatiṁ somanassa karohi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja505:17.1":{"pli":"“Anisamma kataṁ kammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja505:17.2":{"pli":"anavatthāya cintitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja505:17.3":{"pli":"Bhesajjasseva vebhaṅgo, ","html":"<span class='verse-line'>{}</span>"},"ja505:17.4":{"pli":"vipāko hoti pāpako. ","html":"<span class='verse-line'>{}</span></p>"},"ja505:18.1":{"pli":"Nisamma ca kataṁ kammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja505:18.2":{"pli":"sammāvatthāya cintitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja505:18.3":{"pli":"Bhesajjasseva sampatti, ","html":"<span class='verse-line'>{}</span>"},"ja505:18.4":{"pli":"vipāko hoti bhadrako. ","html":"<span class='verse-line'>{}</span></p>"},"ja505:19.1":{"pli":"Alaso gihī kāmabhogī na sādhu, ","html":"<p><span class='verse-line'>{}</span>"},"ja505:19.2":{"pli":"Asaññato pabbajito na sādhu; ","html":"<span class='verse-line'>{}</span>"},"ja505:19.3":{"pli":"Rājā na sādhu anisammakārī, ","html":"<span class='verse-line'>{}</span>"},"ja505:19.4":{"pli":"Yo paṇḍito kodhano taṁ na sādhu. ","html":"<span class='verse-line'>{}</span></p>"},"ja505:20.1":{"pli":"Nisamma khattiyo kayirā, ","html":"<p><span class='verse-line'>{}</span>"},"ja505:20.2":{"pli":"nānisamma disampati; ","html":"<span class='verse-line'>{}</span>"},"ja505:20.3":{"pli":"Nisammakārino rāja, ","html":"<span class='verse-line'>{}</span>"},"ja505:20.4":{"pli":"yaso kitti ca vaḍḍhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja505:21.1":{"pli":"Nisamma daṇḍaṁ paṇayeyya issaro, ","html":"<p><span class='verse-line'>{}</span>"},"ja505:21.2":{"pli":"Vegā kataṁ tappati bhūmipāla; ","html":"<span class='verse-line'>{}</span>"},"ja505:21.3":{"pli":"Sammāpaṇīdhī ca narassa atthā, ","html":"<span class='verse-line'>{}</span>"},"ja505:21.4":{"pli":"Anānutappā te bhavanti pacchā. ","html":"<span class='verse-line'>{}</span></p>"},"ja505:22.1":{"pli":"Anānutappāni hi ye karonti, ","html":"<p><span class='verse-line'>{}</span>"},"ja505:22.2":{"pli":"Vibhajja kammāyatanāni loke; ","html":"<span class='verse-line'>{}</span>"},"ja505:22.3":{"pli":"Viññuppasatthāni sukhudrayāni, ","html":"<span class='verse-line'>{}</span>"},"ja505:22.4":{"pli":"Bhavanti buddhānumatāni tāni. ","html":"<span class='verse-line'>{}</span></p>"},"ja505:23.1":{"pli":"Āgacchuṁ dovārikā khaggabandhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja505:23.2":{"pli":"Kāsāviyā hantu mamaṁ janinda; ","html":"<span class='verse-line'>{}</span>"},"ja505:23.3":{"pli":"Mātuñca aṅkasmimahaṁ nisinno, ","html":"<span class='verse-line'>{}</span>"},"ja505:23.4":{"pli":"Ākaḍḍhito sahasā tehi deva. ","html":"<span class='verse-line'>{}</span></p>"},"ja505:24.1":{"pli":"Kaṭukañhi sambādhaṁ sukicchaṁ patto, ","html":"<p><span class='verse-line'>{}</span>"},"ja505:24.2":{"pli":"Madhurampi yaṁ jīvitaṁ laddha rāja; ","html":"<span class='verse-line'>{}</span>"},"ja505:24.3":{"pli":"Kicchenahaṁ ajja vadhā pamutto, ","html":"<span class='verse-line'>{}</span>"},"ja505:24.4":{"pli":"Pabbajjamevābhimanohamasmi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja505:25.1":{"pli":"“Putto tavāyaṁ taruṇo sudhamme, ","html":"<p><span class='verse-line'>{}</span>"},"ja505:25.2":{"pli":"Anukampako somanasso kumāro; ","html":"<span class='verse-line'>{}</span>"},"ja505:25.3":{"pli":"Taṁ yācamāno na labhāmi svajja, ","html":"<span class='verse-line'>{}</span>"},"ja505:25.4":{"pli":"Arahasi naṁ yācitave tuvampi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja505:26.1":{"pli":"“Ramassu bhikkhācariyāya putta, ","html":"<p><span class='verse-line'>{}</span>"},"ja505:26.2":{"pli":"Nisamma dhammesu paribbajassu; ","html":"<span class='verse-line'>{}</span>"},"ja505:26.3":{"pli":"Sabbesu bhūtesu nidhāya daṇḍaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja505:26.4":{"pli":"Anindito brahmamupehi ṭhānaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja505:27.1":{"pli":"“Acchera rūpaṁ vata yādisañca, ","html":"<p><span class='verse-line'>{}</span>"},"ja505:27.2":{"pli":"Dukkhitaṁ maṁ dukkhāpayase sudhamme; ","html":"<span class='verse-line'>{}</span>"},"ja505:27.3":{"pli":"Yācassu puttaṁ iti vuccamānā, ","html":"<span class='verse-line'>{}</span>"},"ja505:27.4":{"pli":"Bhiyyova ussāhayase kumāraṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja505:28.1":{"pli":"“Ye vippamuttā anavajjabhogino, ","html":"<p><span class='verse-line'>{}</span>"},"ja505:28.2":{"pli":"Parinibbutā lokamimaṁ caranti; ","html":"<span class='verse-line'>{}</span>"},"ja505:28.3":{"pli":"Tamariyamaggaṁ paṭipajjamānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja505:28.4":{"pli":"Na ussahe vārayituṁ kumāraṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja505:29.1":{"pli":"“Addhā have sevitabbā sapaññā, ","html":"<p><span class='verse-line'>{}</span>"},"ja505:29.2":{"pli":"Bahussutā ye bahuṭhānacintino; ","html":"<span class='verse-line'>{}</span>"},"ja505:29.3":{"pli":"Yesāyaṁ sutvāna subhāsitāni, ","html":"<span class='verse-line'>{}</span>"},"ja505:29.4":{"pli":"Appossukkā vītasokā sudhammā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja505:30.1":{"pli":"Somanassajātakaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja506":{"ja506:0.1":{"pli":"Jātaka ","html":"<article id='ja506'><header><ul><li class='division'>{}</li>"},"ja506:0.2":{"pli":"Vīsatinipāta ","html":"<li>{}</li>"},"ja506:0.3":{"pli":"Mātaṅgavagga ","html":"<li>{}</li></ul>"},"ja506:0.4":{"pli":"10. Campeyyajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja506:1.1":{"pli":"“Kā nu vijjurivābhāsi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja506:1.2":{"pli":"Osadhī viya tārakā; ","html":"<span class='verse-line'>{}</span>"},"ja506:1.3":{"pli":"Devatā nusi gandhabbī, ","html":"<span class='verse-line'>{}</span>"},"ja506:1.4":{"pli":"Na taṁ maññāmi mānusiṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:2.1":{"pli":"“Namhi devī na gandhabbī, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:2.2":{"pli":"na mahārāja mānusī; ","html":"<span class='verse-line'>{}</span>"},"ja506:2.3":{"pli":"Nāgakaññāsmi bhaddante, ","html":"<span class='verse-line'>{}</span>"},"ja506:2.4":{"pli":"atthenamhi idhāgatā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:3.1":{"pli":"“Vibbhantacittā kupitindriyāsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:3.2":{"pli":"Nettehi te vārigaṇā savanti; ","html":"<span class='verse-line'>{}</span>"},"ja506:3.3":{"pli":"Kiṁ te naṭṭhaṁ kiṁ pana patthayānā, ","html":"<span class='verse-line'>{}</span>"},"ja506:3.4":{"pli":"Idhāgatā nāri tadiṅgha brūhi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:4.1":{"pli":"“Yamuggatejo uragoti cāhu, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:4.2":{"pli":"Nāgoti naṁ āhu janā janinda; ","html":"<span class='verse-line'>{}</span>"},"ja506:4.3":{"pli":"Tamaggahī puriso jīvikattho, ","html":"<span class='verse-line'>{}</span>"},"ja506:4.4":{"pli":"Taṁ bandhanā muñca patī mameso”. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:5.1":{"pli":"“Kathaṁ nvayaṁ balaviriyūpapanno, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:5.2":{"pli":"Hatthattamāgacchi vanibbakassa; ","html":"<span class='verse-line'>{}</span>"},"ja506:5.3":{"pli":"Akkhāhi me nāgakaññe tamatthaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja506:5.4":{"pli":"Kathaṁ vijānemu gahītanāgaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:6.1":{"pli":"“Nagarampi nāgo bhasmaṁ kareyya, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:6.2":{"pli":"Tathā hi so balaviriyūpapanno; ","html":"<span class='verse-line'>{}</span>"},"ja506:6.3":{"pli":"Dhammañca nāgo apacāyamāno, ","html":"<span class='verse-line'>{}</span>"},"ja506:6.4":{"pli":"Tasmā parakkamma tapo karoti. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:7.1":{"pli":"Cātuddasiṁ pañcadasiñca rāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:7.2":{"pli":"Catuppathe sammati nāgarājā; ","html":"<span class='verse-line'>{}</span>"},"ja506:7.3":{"pli":"Tamaggahī puriso jīvikattho, ","html":"<span class='verse-line'>{}</span>"},"ja506:7.4":{"pli":"Taṁ bandhanā muñca patī mameso”. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:8.1":{"pli":"“Soḷasitthisahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:8.2":{"pli":"āmuttamaṇikuṇḍalā; ","html":"<span class='verse-line'>{}</span>"},"ja506:8.3":{"pli":"Vārigehasayā nārī, ","html":"<span class='verse-line'>{}</span>"},"ja506:8.4":{"pli":"tāpi taṁ saraṇaṁ gatā. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:9.1":{"pli":"Dhammena mocehi asāhasena, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:9.2":{"pli":"Gāmena nikkhena gavaṁ satena; ","html":"<span class='verse-line'>{}</span>"},"ja506:9.3":{"pli":"Ossaṭṭhakāyo urago carātu, ","html":"<span class='verse-line'>{}</span>"},"ja506:9.4":{"pli":"Puññatthiko muñcatu bandhanasmā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:10.1":{"pli":"“Dhammena mocemi asāhasena, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:10.2":{"pli":"Gāmena nikkhena gavaṁ satena; ","html":"<span class='verse-line'>{}</span>"},"ja506:10.3":{"pli":"Ossaṭṭhakāyo urago carātu, ","html":"<span class='verse-line'>{}</span>"},"ja506:10.4":{"pli":"Puññatthiko muñcatu bandhanasmā. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:11.1":{"pli":"Dammi nikkhasataṁ ludda, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:11.2":{"pli":"thūlañca maṇikuṇḍalaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja506:11.3":{"pli":"Catussadañca pallaṅkaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja506:11.4":{"pli":"umāpupphasarinnibhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:12.1":{"pli":"Dve ca sādisiyo bhariyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:12.2":{"pli":"Usabhañca gavaṁ sataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja506:12.3":{"pli":"Ossaṭṭhakāyo urago carātu, ","html":"<span class='verse-line'>{}</span>"},"ja506:12.4":{"pli":"Puññatthiko muñcatu bandhanasmā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:13.1":{"pli":"“Vināpi dānā tava vacanaṁ janinda, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:13.2":{"pli":"Muñcemu naṁ uragaṁ bandhanasmā; ","html":"<span class='verse-line'>{}</span>"},"ja506:13.3":{"pli":"Ossaṭṭhakāyo urago carātu, ","html":"<span class='verse-line'>{}</span>"},"ja506:13.4":{"pli":"Puññatthiko muñcatu bandhanasmā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:14.1":{"pli":"Mutto campeyyako nāgo, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:14.2":{"pli":"rājānaṁ etadabravi; ","html":"<span class='verse-line'>{}</span>"},"ja506:14.3":{"pli":"“Namo te kāsirājatthu, ","html":"<span class='verse-line'>{}</span>"},"ja506:14.4":{"pli":"namo te kāsivaḍḍhana; ","html":"<span class='verse-line'>{}</span>"},"ja506:14.5":{"pli":"Añjaliṁ te paggaṇhāmi, ","html":"<span class='verse-line'>{}</span>"},"ja506:14.6":{"pli":"passeyyaṁ me nivesanaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:15.1":{"pli":"“Addhā hi dubbissasametamāhu, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:15.2":{"pli":"Yaṁ mānuso vissase amānusamhi; ","html":"<span class='verse-line'>{}</span>"},"ja506:15.3":{"pli":"Sace ca maṁ yācasi etamatthaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja506:15.4":{"pli":"Dakkhemu te nāga nivesanāni”. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:16.1":{"pli":"“Sacepi vāto girimāvaheyya, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:16.2":{"pli":"Cando ca suriyo ca chamā pateyyuṁ; ","html":"<span class='verse-line'>{}</span>"},"ja506:16.3":{"pli":"Sabbā ca najjo paṭisotaṁ vajeyyuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja506:16.4":{"pli":"Na tvevahaṁ rāja musā bhaṇeyyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:17.1":{"pli":"Nabhaṁ phaleyya udadhīpi susse, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:17.2":{"pli":"Saṁvaṭṭaye bhūtadharā vasundharā; ","html":"<span class='verse-line'>{}</span>"},"ja506:17.3":{"pli":"Siluccayo meru samūlamuppate, ","html":"<span class='verse-line'>{}</span>"},"ja506:17.4":{"pli":"Na tvevahaṁ rāja musā bhaṇeyyaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:18.1":{"pli":"“Addhā hi dubbissasametamāhu, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:18.2":{"pli":"Yaṁ mānuso vissase amānusamhi; ","html":"<span class='verse-line'>{}</span>"},"ja506:18.3":{"pli":"Sace ca maṁ yācasi etamatthaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja506:18.4":{"pli":"Dakkhemu te nāga nivesanāni. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:19.1":{"pli":"Tumhe khottha ghoravisā uḷārā, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:19.2":{"pli":"Mahātejā khippakopī ca hotha; ","html":"<span class='verse-line'>{}</span>"},"ja506:19.3":{"pli":"Maṅkāraṇā bandhanasmā pamutto, ","html":"<span class='verse-line'>{}</span>"},"ja506:19.4":{"pli":"Arahasi no jānituye katāni”. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:20.1":{"pli":"“So paccataṁ niraye ghorarūpe, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:20.2":{"pli":"Mā kāyikaṁ sātamalattha kiñci; ","html":"<span class='verse-line'>{}</span>"},"ja506:20.3":{"pli":"Peḷāya baddho maraṇaṁ upetu, ","html":"<span class='verse-line'>{}</span>"},"ja506:20.4":{"pli":"Yo tādisaṁ kammakataṁ na jāne”. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:21.1":{"pli":"“Saccappaṭiññā tava mesa hotu, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:21.2":{"pli":"Akkodhano hohi anupanāhī; ","html":"<span class='verse-line'>{}</span>"},"ja506:21.3":{"pli":"Sabbañca te nāgakulaṁ supaṇṇā, ","html":"<span class='verse-line'>{}</span>"},"ja506:21.4":{"pli":"Aggiṁva gimhesu vivajjayantu”. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:22.1":{"pli":"“Anukampasī nāgakulaṁ janinda, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:22.2":{"pli":"Mātā yathā suppiyaṁ ekaputtaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja506:22.3":{"pli":"Ahañca te nāgakulena saddhiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja506:22.4":{"pli":"Kāhāmi veyyāvaṭikaṁ uḷāraṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:23.1":{"pli":"“Yojentu ve rājarathe sucitte, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:23.2":{"pli":"Kambojake assatare sudante; ","html":"<span class='verse-line'>{}</span>"},"ja506:23.3":{"pli":"Nāge ca yojentu suvaṇṇakappane, ","html":"<span class='verse-line'>{}</span>"},"ja506:23.4":{"pli":"Dakkhemu nāgassa nivesanāni”. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:24.1":{"pli":"Bherī mudiṅgā paṇavā ca saṅkhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:24.2":{"pli":"Avajjayiṁsu uggasenassa rañño; ","html":"<span class='verse-line'>{}</span>"},"ja506:24.3":{"pli":"Pāyāsi rājā bahusobhamāno, ","html":"<span class='verse-line'>{}</span>"},"ja506:24.4":{"pli":"Purakkhato nārigaṇassa majjhe. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:25.1":{"pli":"Suvaṇṇacitakaṁ bhūmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:25.2":{"pli":"addakkhi kāsivaḍḍhano; ","html":"<span class='verse-line'>{}</span>"},"ja506:25.3":{"pli":"Sovaṇṇamayapāsāde, ","html":"<span class='verse-line'>{}</span>"},"ja506:25.4":{"pli":"veḷuriyaphalakatthate. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:26.1":{"pli":"Sa rājā pāvisi byamhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:26.2":{"pli":"campeyyassa nivesanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja506:26.3":{"pli":"Ādiccavaṇṇasannibhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja506:26.4":{"pli":"kaṁsavijju pabhassaraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:27.1":{"pli":"Nānārukkhehi sañchannaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:27.2":{"pli":"nānāgandhasamīritaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja506:27.3":{"pli":"So pāvekkhi kāsirājā, ","html":"<span class='verse-line'>{}</span>"},"ja506:27.4":{"pli":"campeyyassa nivesanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:28.1":{"pli":"Paviṭṭhasmiṁ kāsiraññe, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:28.2":{"pli":"campeyyassa nivesanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja506:28.3":{"pli":"Dibbā tūriyā pavajjiṁsu, ","html":"<span class='verse-line'>{}</span>"},"ja506:28.4":{"pli":"nāgakaññā ca naccisuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:29.1":{"pli":"Taṁ nāgakaññā caritaṁ gaṇena, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:29.2":{"pli":"Anvāruhī kāsirājā pasanno; ","html":"<span class='verse-line'>{}</span>"},"ja506:29.3":{"pli":"Nisīdi sovaṇṇamayamhi pīṭhe, ","html":"<span class='verse-line'>{}</span>"},"ja506:29.4":{"pli":"Sāpassaye candanasāralitte. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:30.1":{"pli":"So tattha bhutvā ca atho ramitvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:30.2":{"pli":"Campeyyakaṁ kāsirājā avoca; ","html":"<span class='verse-line'>{}</span>"},"ja506:30.3":{"pli":"“Vimānaseṭṭhāni imāni tuyhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja506:30.4":{"pli":"Ādiccavaṇṇāni pabhassarāni; ","html":"<span class='verse-line'>{}</span>"},"ja506:30.5":{"pli":"Netādisaṁ atthi manussaloke, ","html":"<span class='verse-line'>{}</span>"},"ja506:30.6":{"pli":"Kiṁ patthayaṁ nāga tapo karosi. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:31.1":{"pli":"Tā kambukāyūradharā suvatthā, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:31.2":{"pli":"Vaṭṭaṅgulī tambatalūpapannā; ","html":"<span class='verse-line'>{}</span>"},"ja506:31.3":{"pli":"Paggayha pāyenti anomavaṇṇā, ","html":"<span class='verse-line'>{}</span>"},"ja506:31.4":{"pli":"Netādisaṁ atthi manussaloke; ","html":"<span class='verse-line'>{}</span>"},"ja506:31.5":{"pli":"Kiṁ patthayaṁ nāga tapo karosi. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:32.1":{"pli":"Najjo ca temā puthulomamacchā, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:32.2":{"pli":"Āṭā sakuntābhirudā sutitthā; ","html":"<span class='verse-line'>{}</span>"},"ja506:32.3":{"pli":"Netādisaṁ atthi manussaloke, ","html":"<span class='verse-line'>{}</span>"},"ja506:32.4":{"pli":"Kiṁ patthayaṁ nāga tapo karosi. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:33.1":{"pli":"Koñcā mayūrā diviyā ca haṁsā, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:33.2":{"pli":"Vaggussarā kokilā sampatanti; ","html":"<span class='verse-line'>{}</span>"},"ja506:33.3":{"pli":"Netādisaṁ atthi manussaloke, ","html":"<span class='verse-line'>{}</span>"},"ja506:33.4":{"pli":"Kiṁ patthayaṁ nāga tapo karosi. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:34.1":{"pli":"Ambā ca sālā tilakā ca jambuyo, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:34.2":{"pli":"Uddālakā pāṭaliyo ca phullā; ","html":"<span class='verse-line'>{}</span>"},"ja506:34.3":{"pli":"Netādisaṁ atthi manussaloke, ","html":"<span class='verse-line'>{}</span>"},"ja506:34.4":{"pli":"Kiṁ patthayaṁ nāga tapo karosi. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:35.1":{"pli":"Imā ca te pokkharañño samantato, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:35.2":{"pli":"Dibbā ca gandhā satataṁ pavāyanti; ","html":"<span class='verse-line'>{}</span>"},"ja506:35.3":{"pli":"Netādisaṁ atthi manussaloke, ","html":"<span class='verse-line'>{}</span>"},"ja506:35.4":{"pli":"Kiṁ patthayaṁ nāga tapo karosi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:36.1":{"pli":"“Na puttahetu na dhanassa hetu, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:36.2":{"pli":"Na āyuno cāpi janinda hetu; ","html":"<span class='verse-line'>{}</span>"},"ja506:36.3":{"pli":"Manussayoniṁ abhipatthayāno, ","html":"<span class='verse-line'>{}</span>"},"ja506:36.4":{"pli":"Tasmā parakkamma tapo karomi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:37.1":{"pli":"“Tvaṁ lohitakkho vihatantaraṁso, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:37.2":{"pli":"Alaṅkato kappitakesamassu; ","html":"<span class='verse-line'>{}</span>"},"ja506:37.3":{"pli":"Surosito lohitacandanena, ","html":"<span class='verse-line'>{}</span>"},"ja506:37.4":{"pli":"Gandhabbarājāva disā pabhāsasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:38.1":{"pli":"Deviddhipattosi mahānubhāvo, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:38.2":{"pli":"Sabbehi kāmehi samaṅgibhūto; ","html":"<span class='verse-line'>{}</span>"},"ja506:38.3":{"pli":"Pucchāmi taṁ nāgarājetamatthaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja506:38.4":{"pli":"Seyyo ito kena manussaloko”. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:39.1":{"pli":"“Janinda nāññatra manussalokā, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:39.2":{"pli":"Suddhī va saṁvijjati saṁyamo vā; ","html":"<span class='verse-line'>{}</span>"},"ja506:39.3":{"pli":"Ahañca laddhāna manussayoniṁ, ","html":"<span class='verse-line'>{}</span>"},"ja506:39.4":{"pli":"Kāhāmi jātimaraṇassa antaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:40.1":{"pli":"“Addhā have sevitabbā sapaññā, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:40.2":{"pli":"Bahussutā ye bahuṭhānacintino; ","html":"<span class='verse-line'>{}</span>"},"ja506:40.3":{"pli":"Nāriyo ca disvāna tuvañca nāga, ","html":"<span class='verse-line'>{}</span>"},"ja506:40.4":{"pli":"Kāhāmi puññāni anappakāni”. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:41.1":{"pli":"“Addhā have sevitabbā sapaññā, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:41.2":{"pli":"Bahussutā ye bahuṭhānacintino; ","html":"<span class='verse-line'>{}</span>"},"ja506:41.3":{"pli":"Nāriyo ca disvāna mamañca rāja, ","html":"<span class='verse-line'>{}</span>"},"ja506:41.4":{"pli":"Karohi puññāni anappakāni”. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:42.1":{"pli":"“Idañca me jātarūpaṁ pahūtaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:42.2":{"pli":"Rāsī suvaṇṇassa ca tālamattā; ","html":"<span class='verse-line'>{}</span>"},"ja506:42.3":{"pli":"Ito haritvāna suvaṇṇagharāni, ","html":"<span class='verse-line'>{}</span>"},"ja506:42.4":{"pli":"Karassu rūpiyapākāraṁ karontu. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:43.1":{"pli":"Muttā ca vāhasahassāni pañca, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:43.2":{"pli":"Veḷuriyamissāni ito haritvā; ","html":"<span class='verse-line'>{}</span>"},"ja506:43.3":{"pli":"Antepure bhūmiyaṁ santharantu, ","html":"<span class='verse-line'>{}</span>"},"ja506:43.4":{"pli":"Nikkaddamā hehiti nīrajā ca. ","html":"<span class='verse-line'>{}</span></p>"},"ja506:44.1":{"pli":"Etādisaṁ āvasa rājaseṭṭha, ","html":"<p><span class='verse-line'>{}</span>"},"ja506:44.2":{"pli":"Vimānaseṭṭhaṁ bahu sobhamānaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja506:44.3":{"pli":"Bārāṇasiṁ nagaraṁ iddhaṁ phītaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja506:44.4":{"pli":"Rajjañca kārehi anomapaññā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja506:45.1":{"pli":"Campeyyajātakaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}