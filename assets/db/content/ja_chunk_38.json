{"ja528":{"ja528:0.1":{"pli":"Jātaka ","html":"<article id='ja528'><header><ul><li class='division'>{}</li>"},"ja528:0.2":{"pli":"Paṇṇāsanipāta ","html":"<li>{}</li>"},"ja528:0.3":{"pli":"Niḷinikāvagga ","html":"<li>{}</li></ul>"},"ja528:0.4":{"pli":"3. Mahābodhijātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja528:1.1":{"pli":"“Kiṁ nu daṇḍaṁ kimajinaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja528:1.2":{"pli":"kiṁ chattaṁ kimupāhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja528:1.3":{"pli":"Kimaṅkusañca pattañca, ","html":"<span class='verse-line'>{}</span>"},"ja528:1.4":{"pli":"saṅghāṭiñcāpi brāhmaṇa; ","html":"<span class='verse-line'>{}</span>"},"ja528:1.5":{"pli":"Taramānarūpohāsi, ","html":"<span class='verse-line'>{}</span>"},"ja528:1.6":{"pli":"kiṁ nu patthayase disaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:2.1":{"pli":"“Dvādasetāni vassāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:2.2":{"pli":"vusitāni tavantike; ","html":"<span class='verse-line'>{}</span>"},"ja528:2.3":{"pli":"Nābhijānāmi soṇena, ","html":"<span class='verse-line'>{}</span>"},"ja528:2.4":{"pli":"piṅgalenābhikūjitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:3.1":{"pli":"Svāyaṁ dittova nadati, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:3.2":{"pli":"sukkadāṭhaṁ vidaṁsayaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja528:3.3":{"pli":"Tava sutvā sabhariyassa, ","html":"<span class='verse-line'>{}</span>"},"ja528:3.4":{"pli":"vītasaddhassa maṁ pati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:4.1":{"pli":"“Ahu esa kato doso, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:4.2":{"pli":"yathā bhāsasi brāhmaṇa; ","html":"<span class='verse-line'>{}</span>"},"ja528:4.3":{"pli":"Esa bhiyyo pasīdāmi, ","html":"<span class='verse-line'>{}</span>"},"ja528:4.4":{"pli":"vasa brāhmaṇa māgamā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:5.1":{"pli":"“Sabbaseto pure āsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:5.2":{"pli":"tatopi sabalo ahu; ","html":"<span class='verse-line'>{}</span>"},"ja528:5.3":{"pli":"Sabbalohitako dāni, ","html":"<span class='verse-line'>{}</span>"},"ja528:5.4":{"pli":"kālo pakkamituṁ mama. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:6.1":{"pli":"Abbhantaraṁ pure āsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:6.2":{"pli":"tato majjhe tato bahi; ","html":"<span class='verse-line'>{}</span>"},"ja528:6.3":{"pli":"Purā niddhamanā hoti, ","html":"<span class='verse-line'>{}</span>"},"ja528:6.4":{"pli":"sayameva vajāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:7.1":{"pli":"Vītasaddhaṁ na seveyya, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:7.2":{"pli":"udapānaṁvanodakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja528:7.3":{"pli":"Sacepi naṁ anukhaṇe, ","html":"<span class='verse-line'>{}</span>"},"ja528:7.4":{"pli":"vāri kaddamagandhikaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:8.1":{"pli":"Pasannameva seveyya, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:8.2":{"pli":"appasannaṁ vivajjaye; ","html":"<span class='verse-line'>{}</span>"},"ja528:8.3":{"pli":"Pasannaṁ payirupāseyya, ","html":"<span class='verse-line'>{}</span>"},"ja528:8.4":{"pli":"rahadaṁ vudakatthiko. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:9.1":{"pli":"Bhaje bhajantaṁ purisaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:9.2":{"pli":"abhajantaṁ na bhajjaye; ","html":"<span class='verse-line'>{}</span>"},"ja528:9.3":{"pli":"Asappurisadhammo so, ","html":"<span class='verse-line'>{}</span>"},"ja528:9.4":{"pli":"yo bhajantaṁ na bhajjati. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:10.1":{"pli":"Yo bhajantaṁ na bhajati, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:10.2":{"pli":"sevamānaṁ na sevati; ","html":"<span class='verse-line'>{}</span>"},"ja528:10.3":{"pli":"Sa ve manussapāpiṭṭho, ","html":"<span class='verse-line'>{}</span>"},"ja528:10.4":{"pli":"migo sākhassito yathā. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:11.1":{"pli":"Accābhikkhaṇasaṁsaggā, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:11.2":{"pli":"asamosaraṇena ca; ","html":"<span class='verse-line'>{}</span>"},"ja528:11.3":{"pli":"Etena mittā jīranti, ","html":"<span class='verse-line'>{}</span>"},"ja528:11.4":{"pli":"akāle yācanāya ca. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:12.1":{"pli":"Tasmā nābhikkhaṇaṁ gacche, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:12.2":{"pli":"na ca gacche cirāciraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja528:12.3":{"pli":"Kālena yācaṁ yāceyya, ","html":"<span class='verse-line'>{}</span>"},"ja528:12.4":{"pli":"evaṁ mittā na jīyare. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:13.1":{"pli":"Aticiraṁ nivāsena, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:13.2":{"pli":"piyo bhavati appiyo; ","html":"<span class='verse-line'>{}</span>"},"ja528:13.3":{"pli":"Āmanta kho taṁ gacchāma, ","html":"<span class='verse-line'>{}</span>"},"ja528:13.4":{"pli":"purā te homa appiyā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:14.1":{"pli":"“Evañce yācamānānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:14.2":{"pli":"Añjaliṁ nāvabujjhasi; ","html":"<span class='verse-line'>{}</span>"},"ja528:14.3":{"pli":"Paricārakānaṁ sataṁ, ","html":"<span class='verse-line'>{}</span>"},"ja528:14.4":{"pli":"Vacanaṁ na karosi no; ","html":"<span class='verse-line'>{}</span>"},"ja528:14.5":{"pli":"Evaṁ taṁ abhiyācāma, ","html":"<span class='verse-line'>{}</span>"},"ja528:14.6":{"pli":"Puna kayirāsi pariyāyaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:15.1":{"pli":"“Evañce no viharataṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:15.2":{"pli":"Antarāyo na hessati; ","html":"<span class='verse-line'>{}</span>"},"ja528:15.3":{"pli":"Tuyhaṁ vāpi mahārāja, ","html":"<span class='verse-line'>{}</span>"},"ja528:15.4":{"pli":"Mayhaṁ vā raṭṭhavaddhana; ","html":"<span class='verse-line'>{}</span>"},"ja528:15.5":{"pli":"Appeva nāma passema, ","html":"<span class='verse-line'>{}</span>"},"ja528:15.6":{"pli":"Ahorattānamaccaye. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:16.1":{"pli":"Udīraṇā ce saṅgatyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:16.2":{"pli":"bhāvāya manuvattati; ","html":"<span class='verse-line'>{}</span>"},"ja528:16.3":{"pli":"Akāmā akaraṇīyaṁ vā, ","html":"<span class='verse-line'>{}</span>"},"ja528:16.4":{"pli":"karaṇīyaṁ vāpi kubbati; ","html":"<span class='verse-line'>{}</span>"},"ja528:16.5":{"pli":"Akāmākaraṇīyamhi, ","html":"<span class='verse-line'>{}</span>"},"ja528:16.6":{"pli":"kvidha pāpena lippati. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:17.1":{"pli":"So ce attho ca dhammo ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:17.2":{"pli":"kalyāṇo na ca pāpako; ","html":"<span class='verse-line'>{}</span>"},"ja528:17.3":{"pli":"Bhoto ce vacanaṁ saccaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja528:17.4":{"pli":"suhato vānaro mayā. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:18.1":{"pli":"Attano ce hi vādassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:18.2":{"pli":"aparādhaṁ vijāniyā; ","html":"<span class='verse-line'>{}</span>"},"ja528:18.3":{"pli":"Na maṁ tvaṁ garaheyyāsi, ","html":"<span class='verse-line'>{}</span>"},"ja528:18.4":{"pli":"bhoto vādo hi tādiso. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:19.1":{"pli":"Issaro sabbalokassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:19.2":{"pli":"sace kappeti jīvitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja528:19.3":{"pli":"Iddhiṁ byasanabhāvañca, ","html":"<span class='verse-line'>{}</span>"},"ja528:19.4":{"pli":"kammaṁ kalyāṇapāpakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja528:19.5":{"pli":"Niddesakārī puriso, ","html":"<span class='verse-line'>{}</span>"},"ja528:19.6":{"pli":"issaro tena lippati. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:20.1":{"pli":"So ce attho ca dhammo ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:20.2":{"pli":"kalyāṇo na ca pāpako; ","html":"<span class='verse-line'>{}</span>"},"ja528:20.3":{"pli":"Bhoto ce vacanaṁ saccaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja528:20.4":{"pli":"suhato vānaro mayā. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:21.1":{"pli":"Attano ce hi vādassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:21.2":{"pli":"aparādhaṁ vijāniyā; ","html":"<span class='verse-line'>{}</span>"},"ja528:21.3":{"pli":"Na maṁ tvaṁ garaheyyāsi, ","html":"<span class='verse-line'>{}</span>"},"ja528:21.4":{"pli":"bhoto vādo hi tādiso. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:22.1":{"pli":"Sace pubbekatahetu, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:22.2":{"pli":"sukhadukkhaṁ nigacchati; ","html":"<span class='verse-line'>{}</span>"},"ja528:22.3":{"pli":"Porāṇakaṁ kataṁ pāpaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja528:22.4":{"pli":"tameso muccate iṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja528:22.5":{"pli":"Porāṇakaiṇamokkho, ","html":"<span class='verse-line'>{}</span>"},"ja528:22.6":{"pli":"kvidha pāpena lippati. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:23.1":{"pli":"So ce attho ca dhammo ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:23.2":{"pli":"kalyāṇo na ca pāpako; ","html":"<span class='verse-line'>{}</span>"},"ja528:23.3":{"pli":"Bhoto ce vacanaṁ saccaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja528:23.4":{"pli":"suhato vānaro mayā. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:24.1":{"pli":"Attano ce hi vādassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:24.2":{"pli":"aparādhaṁ vijāniyā; ","html":"<span class='verse-line'>{}</span>"},"ja528:24.3":{"pli":"Na maṁ tvaṁ garaheyyāsi, ","html":"<span class='verse-line'>{}</span>"},"ja528:24.4":{"pli":"bhoto vādo hi tādiso. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:25.1":{"pli":"Catunnaṁyevupādāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:25.2":{"pli":"rūpaṁ sambhoti pāṇinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja528:25.3":{"pli":"Yato ca rūpaṁ sambhoti, ","html":"<span class='verse-line'>{}</span>"},"ja528:25.4":{"pli":"tatthevānupagacchati; ","html":"<span class='verse-line'>{}</span>"},"ja528:25.5":{"pli":"Idheva jīvati jīvo, ","html":"<span class='verse-line'>{}</span>"},"ja528:25.6":{"pli":"pecca pecca vinassati. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:26.1":{"pli":"Ucchijjati ayaṁ loko, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:26.2":{"pli":"ye bālā ye ca paṇḍitā; ","html":"<span class='verse-line'>{}</span>"},"ja528:26.3":{"pli":"Ucchijjamāne lokasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja528:26.4":{"pli":"kvidha pāpena lippati. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:27.1":{"pli":"So ce attho ca dhammo ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:27.2":{"pli":"kalyāṇo na ca pāpako; ","html":"<span class='verse-line'>{}</span>"},"ja528:27.3":{"pli":"Bhoto ce vacanaṁ saccaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja528:27.4":{"pli":"suhato vānaro mayā. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:28.1":{"pli":"Attano ce hi vādassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:28.2":{"pli":"aparādhaṁ vijāniyā; ","html":"<span class='verse-line'>{}</span>"},"ja528:28.3":{"pli":"Na maṁ tvaṁ garaheyyāsi, ","html":"<span class='verse-line'>{}</span>"},"ja528:28.4":{"pli":"bhoto vādo hi tādiso. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:29.1":{"pli":"Āhu khattavidā loke, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:29.2":{"pli":"bālā paṇḍitamānino; ","html":"<span class='verse-line'>{}</span>"},"ja528:29.3":{"pli":"‘Mātaraṁ pitaraṁ haññe, ","html":"<span class='verse-line'>{}</span>"},"ja528:29.4":{"pli":"atho jeṭṭhampi bhātaraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja528:29.5":{"pli":"Haneyya puttadāre ca, ","html":"<span class='verse-line'>{}</span>"},"ja528:29.6":{"pli":"attho ce tādiso siyā’. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:30.1":{"pli":"Yassa rukkhassa chāyāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:30.2":{"pli":"nisīdeyya sayeyya vā; ","html":"<span class='verse-line'>{}</span>"},"ja528:30.3":{"pli":"Na tassa sākhaṁ bhañjeyya, ","html":"<span class='verse-line'>{}</span>"},"ja528:30.4":{"pli":"mittadubbho hi pāpako. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:31.1":{"pli":"Atha atthe samuppanne, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:31.2":{"pli":"samūlamapi abbahe; ","html":"<span class='verse-line'>{}</span>"},"ja528:31.3":{"pli":"Attho me sambalenāpi, ","html":"<span class='verse-line'>{}</span>"},"ja528:31.4":{"pli":"suhato vānaro mayā. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:32.1":{"pli":"So ce attho ca dhammo ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:32.2":{"pli":"kalyāṇo na ca pāpako; ","html":"<span class='verse-line'>{}</span>"},"ja528:32.3":{"pli":"Bhoto ce vacanaṁ saccaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja528:32.4":{"pli":"suhato vānaro mayā. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:33.1":{"pli":"Attano ce hi vādassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:33.2":{"pli":"aparādhaṁ vijāniyā; ","html":"<span class='verse-line'>{}</span>"},"ja528:33.3":{"pli":"Na maṁ tvaṁ garaheyyāsi, ","html":"<span class='verse-line'>{}</span>"},"ja528:33.4":{"pli":"bhoto vādo hi tādiso. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:34.1":{"pli":"Ahetuvādo puriso, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:34.2":{"pli":"yo ca issarakuttiko; ","html":"<span class='verse-line'>{}</span>"},"ja528:34.3":{"pli":"Pubbekatī ca ucchedī, ","html":"<span class='verse-line'>{}</span>"},"ja528:34.4":{"pli":"yo ca khattavido naro. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:35.1":{"pli":"Ete asappurisā loke, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:35.2":{"pli":"bālā paṇḍitamānino; ","html":"<span class='verse-line'>{}</span>"},"ja528:35.3":{"pli":"Kareyya tādiso pāpaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja528:35.4":{"pli":"atho aññampi kāraye; ","html":"<span class='verse-line'>{}</span>"},"ja528:35.5":{"pli":"Asappurisasaṁsaggo, ","html":"<span class='verse-line'>{}</span>"},"ja528:35.6":{"pli":"dukkhanto kaṭukudrayo. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:36.1":{"pli":"Urabbharūpena vakassu pubbe, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:36.2":{"pli":"Asaṅkito ajayūthaṁ upeti; ","html":"<span class='verse-line'>{}</span>"},"ja528:36.3":{"pli":"Hantvā uraṇiṁ ajikaṁ ajañca, ","html":"<span class='verse-line'>{}</span>"},"ja528:36.4":{"pli":"Utrāsayitvā yena kāmaṁ paleti. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:37.1":{"pli":"Tathāvidheke samaṇabrāhmaṇāse, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:37.2":{"pli":"Chadanaṁ katvā vañcayanti manusse; ","html":"<span class='verse-line'>{}</span>"},"ja528:37.3":{"pli":"Anāsakā thaṇḍilaseyyakā ca, ","html":"<span class='verse-line'>{}</span>"},"ja528:37.4":{"pli":"Rajojallaṁ ukkuṭikappadhānaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja528:37.5":{"pli":"Pariyāyabhattañca apānakattā, ","html":"<span class='verse-line'>{}</span>"},"ja528:37.6":{"pli":"Pāpācārā arahanto vadānā. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:38.1":{"pli":"Ete asappurisā loke, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:38.2":{"pli":"bālā paṇḍitamānino; ","html":"<span class='verse-line'>{}</span>"},"ja528:38.3":{"pli":"Kareyya tādiso pāpaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja528:38.4":{"pli":"atho aññampi kāraye; ","html":"<span class='verse-line'>{}</span>"},"ja528:38.5":{"pli":"Asappurisasaṁsaggo, ","html":"<span class='verse-line'>{}</span>"},"ja528:38.6":{"pli":"dukkhanto kaṭukudrayo. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:39.1":{"pli":"Yamāhu natthi vīriyanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:39.2":{"pli":"ahetuñca pavadanti ye; ","html":"<span class='verse-line'>{}</span>"},"ja528:39.3":{"pli":"Parakāraṁ attakārañca, ","html":"<span class='verse-line'>{}</span>"},"ja528:39.4":{"pli":"ye tucchaṁ samavaṇṇayuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:40.1":{"pli":"Ete asappurisā loke, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:40.2":{"pli":"bālā paṇḍitamānino; ","html":"<span class='verse-line'>{}</span>"},"ja528:40.3":{"pli":"Kareyya tādiso pāpaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja528:40.4":{"pli":"atho aññampi kāraye; ","html":"<span class='verse-line'>{}</span>"},"ja528:40.5":{"pli":"Asappurisasaṁsaggo, ","html":"<span class='verse-line'>{}</span>"},"ja528:40.6":{"pli":"dukkhanto kaṭukudrayo. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:41.1":{"pli":"Sace hi vīriyaṁ nāssa, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:41.2":{"pli":"kammaṁ kalyāṇapāpakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja528:41.3":{"pli":"Na bhare vaḍḍhakiṁ rājā, ","html":"<span class='verse-line'>{}</span>"},"ja528:41.4":{"pli":"napi yantāni kāraye. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:42.1":{"pli":"Yasmā ca vīriyaṁ atthi, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:42.2":{"pli":"kammaṁ kalyāṇapāpakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja528:42.3":{"pli":"Tasmā yantāni kāreti, ","html":"<span class='verse-line'>{}</span>"},"ja528:42.4":{"pli":"rājā bharati vaḍḍhakiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:43.1":{"pli":"Yadi vassasataṁ devo, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:43.2":{"pli":"na vasse na himaṁ pate; ","html":"<span class='verse-line'>{}</span>"},"ja528:43.3":{"pli":"Ucchijjeyya ayaṁ loko, ","html":"<span class='verse-line'>{}</span>"},"ja528:43.4":{"pli":"vinasseyya ayaṁ pajā. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:44.1":{"pli":"Yasmā ca vassatī devo, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:44.2":{"pli":"himañcānuphusāyati; ","html":"<span class='verse-line'>{}</span>"},"ja528:44.3":{"pli":"Tasmā sassāni paccanti, ","html":"<span class='verse-line'>{}</span>"},"ja528:44.4":{"pli":"raṭṭhañca pālite ciraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:45.1":{"pli":"Gavañce taramānānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:45.2":{"pli":"jimhaṁ gacchati puṅgavo; ","html":"<span class='verse-line'>{}</span>"},"ja528:45.3":{"pli":"Sabbā tā jimhaṁ gacchanti, ","html":"<span class='verse-line'>{}</span>"},"ja528:45.4":{"pli":"nette jimhaṁ gate sati. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:46.1":{"pli":"Evameva manussesu, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:46.2":{"pli":"yo hoti seṭṭhasammato; ","html":"<span class='verse-line'>{}</span>"},"ja528:46.3":{"pli":"So ce adhammaṁ carati, ","html":"<span class='verse-line'>{}</span>"},"ja528:46.4":{"pli":"pageva itarā pajā; ","html":"<span class='verse-line'>{}</span>"},"ja528:46.5":{"pli":"Sabbaṁ raṭṭhaṁ dukhaṁ seti, ","html":"<span class='verse-line'>{}</span>"},"ja528:46.6":{"pli":"rājā ce hoti adhammiko. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:47.1":{"pli":"Gavañce taramānānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:47.2":{"pli":"ujuṁ gacchati puṅgavo; ","html":"<span class='verse-line'>{}</span>"},"ja528:47.3":{"pli":"Sabbā gāvī ujuṁ yanti, ","html":"<span class='verse-line'>{}</span>"},"ja528:47.4":{"pli":"nette ujuṁ gate sati. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:48.1":{"pli":"Evameva manussesu, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:48.2":{"pli":"yo hoti seṭṭhasammato; ","html":"<span class='verse-line'>{}</span>"},"ja528:48.3":{"pli":"So sace dhammaṁ carati, ","html":"<span class='verse-line'>{}</span>"},"ja528:48.4":{"pli":"pageva itarā pajā; ","html":"<span class='verse-line'>{}</span>"},"ja528:48.5":{"pli":"Sabbaṁ raṭṭhaṁ sukhaṁ seti, ","html":"<span class='verse-line'>{}</span>"},"ja528:48.6":{"pli":"rājā ce hoti dhammiko. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:49.1":{"pli":"Mahārukkhassa phalino, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:49.2":{"pli":"āmaṁ chindati yo phalaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja528:49.3":{"pli":"Rasañcassa na jānāti, ","html":"<span class='verse-line'>{}</span>"},"ja528:49.4":{"pli":"bījañcassa vinassati. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:50.1":{"pli":"Mahārukkhūpamaṁ raṭṭhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:50.2":{"pli":"adhammena pasāsati; ","html":"<span class='verse-line'>{}</span>"},"ja528:50.3":{"pli":"Rasañcassa na jānāti, ","html":"<span class='verse-line'>{}</span>"},"ja528:50.4":{"pli":"raṭṭhañcassa vinassati. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:51.1":{"pli":"Mahārukkhassa phalino, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:51.2":{"pli":"pakkaṁ chindati yo phalaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja528:51.3":{"pli":"Rasañcassa vijānāti, ","html":"<span class='verse-line'>{}</span>"},"ja528:51.4":{"pli":"bījañcassa na nassati. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:52.1":{"pli":"Mahārukkhūpamaṁ raṭṭhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:52.2":{"pli":"dhammena yo pasāsati; ","html":"<span class='verse-line'>{}</span>"},"ja528:52.3":{"pli":"Rasañcassa vijānāti, ","html":"<span class='verse-line'>{}</span>"},"ja528:52.4":{"pli":"raṭṭhañcassa na nassati. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:53.1":{"pli":"Yo ca rājā janapadaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:53.2":{"pli":"adhammena pasāsati; ","html":"<span class='verse-line'>{}</span>"},"ja528:53.3":{"pli":"Sabbosadhīhi so rājā, ","html":"<span class='verse-line'>{}</span>"},"ja528:53.4":{"pli":"viruddho hoti khattiyo. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:54.1":{"pli":"Tatheva negame hiṁsaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:54.2":{"pli":"ye yuttā kayavikkaye; ","html":"<span class='verse-line'>{}</span>"},"ja528:54.3":{"pli":"Ojadānabalīkāre, ","html":"<span class='verse-line'>{}</span>"},"ja528:54.4":{"pli":"sa kosena virujjhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:55.1":{"pli":"Pahāravarakhettaññū, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:55.2":{"pli":"saṅgāme katanissame; ","html":"<span class='verse-line'>{}</span>"},"ja528:55.3":{"pli":"Ussite hiṁsayaṁ rājā, ","html":"<span class='verse-line'>{}</span>"},"ja528:55.4":{"pli":"sa balena virujjhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:56.1":{"pli":"Tatheva isayo hiṁsaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:56.2":{"pli":"saññate brahmacārino; ","html":"<span class='verse-line'>{}</span>"},"ja528:56.3":{"pli":"Adhammacārī khattiyo, ","html":"<span class='verse-line'>{}</span>"},"ja528:56.4":{"pli":"so saggena virujjhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:57.1":{"pli":"Yo ca rājā adhammaṭṭho, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:57.2":{"pli":"bhariyaṁ hanti adūsikaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja528:57.3":{"pli":"Luddaṁ pasavate ṭhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja528:57.4":{"pli":"puttehi ca virujjhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:58.1":{"pli":"Dhammaṁ care jānapade, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:58.2":{"pli":"negamesu balesu ca; ","html":"<span class='verse-line'>{}</span>"},"ja528:58.3":{"pli":"Isayo ca na hiṁseyya, ","html":"<span class='verse-line'>{}</span>"},"ja528:58.4":{"pli":"puttadāre samaṁ care. ","html":"<span class='verse-line'>{}</span></p>"},"ja528:59.1":{"pli":"Sa tādiso bhūmipati, ","html":"<p><span class='verse-line'>{}</span>"},"ja528:59.2":{"pli":"Raṭṭhapālo akodhano; ","html":"<span class='verse-line'>{}</span>"},"ja528:59.3":{"pli":"Sapatte sampakampeti, ","html":"<span class='verse-line'>{}</span>"},"ja528:59.4":{"pli":"Indova asurādhipo”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja528:60.1":{"pli":"Mahābodhijātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja528:61.1":{"pli":"Paṇṇāsanipātaṁ niṭṭhitaṁ. ","html":"<p class='endsection'>{}</p>"},"ja528:62.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja528:63.1":{"pli":"Saniḷīnikamavhayano paṭhamo, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja528:63.2":{"pli":"Dutiyo pana saummadantivaro; ","html":"<span class='verse-line'>{}</span>"},"ja528:63.3":{"pli":"Tatiyo pana bodhisirīvhayano, ","html":"<span class='verse-line'>{}</span>"},"ja528:63.4":{"pli":"Kathitā pana tīṇi jinena subhāti. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}}}