},"tha-ap59:3.1":{"pli":"Yaṁ yaṁ yonupapajjāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap59:3.2":{"pli":"devattaṁ atha mānusaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap59:3.3":{"pli":"Ākāse ukkaṁ dhārenti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap59:3.4":{"pli":"dīpadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap59:4.1":{"pli":"Tirokuṭṭaṁ tiroselaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap59:4.2":{"pli":"samatiggayha pabbataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap59:4.3":{"pli":"Samantā yojanasataṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap59:4.4":{"pli":"dassanaṁ anubhomahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap59:5.1":{"pli":"Tena kammāvasesena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap59:5.2":{"pli":"pattomhi āsavakkhayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap59:5.3":{"pli":"Dhāremi antimaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap59:5.4":{"pli":"dvipadindassa sāsane. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap59:6.1":{"pli":"Catuttiṁse kappasate, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap59:6.2":{"pli":"satacakkhusanāmakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap59:6.3":{"pli":"Rājāhesuṁ mahātejā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap59:6.4":{"pli":"cakkavattī mahabbalā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap59:7.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap59:7.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap59:7.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap59:8.1":{"pli":"Itthaṁ sudaṁ āyasmā pañcadīpako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap59:9.1":{"pli":"Pañcadīpakattherassāpadānaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap6":{"tha-ap6:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap6'><header><ul><li class='division'>{}</li>"},"tha-ap6:0.2":{"pli":"Buddhavagga ","html":"<li>{}</li></ul>"},"tha-ap6:0.3":{"pli":"Anuruddhattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap6:1.1":{"pli":"“Sumedhaṁ bhagavantāhaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap6:1.2":{"pli":"lokajeṭṭhaṁ narāsabhaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap6:1.3":{"pli":"Vūpakaṭṭhaṁ viharantaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap6:1.4":{"pli":"addasaṁ lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap6:2.1":{"pli":"Upagantvāna sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap6:2.2":{"pli":"sumedhaṁ lokanāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap6:2.3":{"pli":"Añjaliṁ paggahetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap6:2.4":{"pli":"buddhaseṭṭhamayācahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap6:3.1":{"pli":"Anukampa mahāvīra, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap6:3.2":{"pli":"lokajeṭṭha narāsabha; ","html":"<span class='verse-line'>{}</span>"},"tha-ap6:3.3":{"pli":"Padīpaṁ te padassāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap6:3.4":{"pli":"rukkhamūlamhi jhāyato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap6:4.1":{"pli":"Adhivāsesi so dhīro, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap6:4.2":{"pli":"sayambhū vadataṁ varo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap6:4.3":{"pli":"Dumesu vinivijjhitvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap6:4.4":{"pli":"yantaṁ yojiyahaṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap6:5.1":{"pli":"Sahassavaṭṭiṁ pādāsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap6:5.2":{"pli":"buddhassa lokabandhuno; ","html":"<span class='verse-line'>{}</span>"},"tha-ap6:5.3":{"pli":"Sattāhaṁ pajjalitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap6:5.4":{"pli":"dīpā vūpasamiṁsu me. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap6:6.1":{"pli":"Tena cittappasādena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap6:6.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap6:6.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap6:6.4":{"pli":"vimānamupapajjahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap6:7.1":{"pli":"Upapannassa devattaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap6:7.2":{"pli":"byamhaṁ āsi sunimmitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap6:7.3":{"pli":"Samantato pajjalati, ","html":"<span class='verse-line'>{}</span>"},"tha-ap6:7.4":{"pli":"dīpadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap6:8.1":{"pli":"Samantā yojanasataṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap6:8.2":{"pli":"virocesimahaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap6:8.3":{"pli":"Sabbe deve abhibhomi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap6:8.4":{"pli":"dīpadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap6:9.1":{"pli":"Tiṁsakappāni devindo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap6:9.2":{"pli":"devarajjamakārayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap6:9.3":{"pli":"Na maṁ kecītimaññanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap6:9.4":{"pli":"dīpadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap6:10.1":{"pli":"Aṭṭhavīsatikkhattuñca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap6:10.2":{"pli":"cakkavattī ahosahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap6:10.3":{"pli":"Divā rattiñca passāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap6:10.4":{"pli":"samantā yojanaṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap6:11.1":{"pli":"Sahassalokaṁ ñāṇena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap6:11.2":{"pli":"passāmi satthu sāsane; ","html":"<span class='verse-line'>{}</span>"},"tha-ap6:11.3":{"pli":"Dibbacakkhumanuppatto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap6:11.4":{"pli":"dīpadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap6:12.1":{"pli":"Sumedho nāma sambuddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap6:12.2":{"pli":"tiṁsakappasahassito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap6:12.3":{"pli":"Tassa dīpo mayā dinno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap6:12.4":{"pli":"vippasannena cetasā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap6:13.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap6:13.2":{"pli":"vimokkhāpi ca aṭṭhime; ","html":"<span class='verse-line'>{}</span>"},"tha-ap6:13.3":{"pli":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap6:13.4":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap6:14.1":{"pli":"Itthaṁ sudaṁ āyasmā anuruddho thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap6:15.1":{"pli":"Anuruddhattherassāpadānaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}