{"tha-ap562":{"tha-ap562:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap562'><header><ul><li class='division'>{}</li>"},"tha-ap562:0.2":{"pli":"Yasavagga ","html":"<li>{}</li></ul>"},"tha-ap562:0.3":{"pli":"Upavānattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap562:1.1":{"pli":"“Padumuttaro nāma jino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap562:1.2":{"pli":"sabbadhammāna pāragū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:1.3":{"pli":"Jalitvā aggikkhandhova, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:1.4":{"pli":"sambuddho parinibbuto. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:2.1":{"pli":"Mahājanā samāgamma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:2.2":{"pli":"pūjayitvā tathāgataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:2.3":{"pli":"Citakaṁ katvā sugataṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:2.4":{"pli":"sarīraṁ abhiropayuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:3.1":{"pli":"Sarīrakiccaṁ katvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:3.2":{"pli":"dhātuṁ tattha samānayuṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:3.3":{"pli":"Sadevamanussā sabbe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:3.4":{"pli":"buddhathūpaṁ akaṁsu te. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:4.1":{"pli":"Paṭhamā kañcanamayā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:4.2":{"pli":"dutiyā ca maṇimayā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:4.3":{"pli":"Tatiyā rūpiyamayā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:4.4":{"pli":"catutthī phalikāmayā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:5.1":{"pli":"Tattha pañcamikā ceva, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:5.2":{"pli":"lohitaṅkamayā ahu; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:5.3":{"pli":"Chaṭṭhā masāragallassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:5.4":{"pli":"sabbaṁ ratanamayūpari. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:6.1":{"pli":"Jaṅghā maṇimayā āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:6.2":{"pli":"vedikā ratanāmayā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:6.3":{"pli":"Sabbasoṇṇamayo thūpo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:6.4":{"pli":"uddhaṁ yojanamuggato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:7.1":{"pli":"Devā tattha samāgantvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:7.2":{"pli":"ekato mantayuṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:7.3":{"pli":"‘Mayampi thūpaṁ kassāma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:7.4":{"pli":"lokanāthassa tādino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:8.1":{"pli":"Dhātu āveṇikā natthi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:8.2":{"pli":"sarīraṁ ekapiṇḍitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:8.3":{"pli":"Imamhi buddhathūpamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:8.4":{"pli":"kassāma kañcukaṁ mayaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:9.1":{"pli":"Devā sattahi ratnehi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:9.2":{"pli":"aññaṁ vaḍḍhesuṁ yojanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:9.3":{"pli":"Thūpo dviyojanubbedho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:9.4":{"pli":"timiraṁ byapahanti so. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:10.1":{"pli":"Nāgā tattha samāgantvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:10.2":{"pli":"ekato mantayuṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:10.3":{"pli":"‘Manussā ceva devā ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:10.4":{"pli":"buddhathūpaṁ akaṁsu te. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:11.1":{"pli":"Mā no pamattā assumha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:11.2":{"pli":"appamattā sadevakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:11.3":{"pli":"Mayampi thūpaṁ kassāma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:11.4":{"pli":"lokanāthassa tādino’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:12.1":{"pli":"Indanīlaṁ mahānīlaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:12.2":{"pli":"atho jotirasaṁ maṇiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:12.3":{"pli":"Ekato sannipātetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:12.4":{"pli":"buddhathūpaṁ achādayuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:13.1":{"pli":"Sabbaṁ maṇimayaṁ āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:13.2":{"pli":"yāvatā buddhacetiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:13.3":{"pli":"Tiyojanasamubbedhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:13.4":{"pli":"ālokakaraṇaṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:14.1":{"pli":"Garuḷā ca samāgantvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:14.2":{"pli":"ekato mantayuṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:14.3":{"pli":"‘Manussā devanāgā ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:14.4":{"pli":"buddhapūjaṁ akaṁsu te. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:15.1":{"pli":"Mā no pamattā assumha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:15.2":{"pli":"appamattā sadevakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:15.3":{"pli":"Mayampi thūpaṁ kassāma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:15.4":{"pli":"lokanāthassa tādino’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:16.1":{"pli":"Sabbaṁ maṇimayaṁ thūpaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:16.2":{"pli":"akaruṁ te ca kañcukaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:16.3":{"pli":"Yojanaṁ tepi vaḍḍhesuṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:16.4":{"pli":"āyataṁ buddhacetiyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:17.1":{"pli":"Catuyojanamubbedho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:17.2":{"pli":"buddhathūpo virocati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:17.3":{"pli":"Obhāseti disā sabbā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:17.4":{"pli":"sataraṁsīva uggato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:18.1":{"pli":"Kumbhaṇḍā ca samāgantvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:18.2":{"pli":"ekato mantayuṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:18.3":{"pli":"‘Manussā ceva devā ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:18.4":{"pli":"nāgā ca garuḷā tathā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:19.1":{"pli":"Paccekaṁ buddhaseṭṭhassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:19.2":{"pli":"akaṁsu thūpamuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:19.3":{"pli":"Mā no pamattā assumha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:19.4":{"pli":"appamattā sadevakā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:20.1":{"pli":"Mayampi thūpaṁ kassāma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:20.2":{"pli":"lokanāthassa tādino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:20.3":{"pli":"Ratanehi chādessāma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:20.4":{"pli":"āyataṁ buddhacetiyaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:21.1":{"pli":"Yojanaṁ tepi vaḍḍhesuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:21.2":{"pli":"āyataṁ buddhacetiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:21.3":{"pli":"Pañcayojanamubbedho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:21.4":{"pli":"thūpo obhāsate tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:22.1":{"pli":"Yakkhā tattha samāgantvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:22.2":{"pli":"ekato mantayuṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:22.3":{"pli":"‘Manussā devanāgā ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:22.4":{"pli":"garuḷā ca kumbhaṇḍakā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:23.1":{"pli":"Paccekaṁ buddhaseṭṭhassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:23.2":{"pli":"akaṁsu thūpamuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:23.3":{"pli":"Mā no pamattā assumha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:23.4":{"pli":"appamattā sadevakā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:24.1":{"pli":"Mayampi thūpaṁ kassāma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:24.2":{"pli":"lokanāthassa tādino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:24.3":{"pli":"Phalikā chādayissāma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:24.4":{"pli":"āyataṁ buddhacetiyaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:25.1":{"pli":"Yojanaṁ tepi vaḍḍhesuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:25.2":{"pli":"āyataṁ buddhacetiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:25.3":{"pli":"Chayojanikamubbedho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:25.4":{"pli":"thūpo obhāsate tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:26.1":{"pli":"Gandhabbā ca samāgantvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:26.2":{"pli":"ekato mantayuṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:26.3":{"pli":"‘Manujā devatā nāgā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:26.4":{"pli":"kumbhaṇḍā guyhakā tathā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:27.1":{"pli":"Sabbe akaṁsu buddhathūpaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:27.2":{"pli":"mayamettha akārakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:27.3":{"pli":"Mayampi thūpaṁ kassāma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:27.4":{"pli":"lokanāthassa tādino’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:28.1":{"pli":"Vediyo satta katvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:28.2":{"pli":"dhajaṁ chattaṁ akaṁsu te; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:28.3":{"pli":"Sabbasoṇṇamayaṁ thūpaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:28.4":{"pli":"gandhabbā kārayuṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:29.1":{"pli":"Sattayojanamubbedho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:29.2":{"pli":"thūpo obhāsate tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:29.3":{"pli":"Rattindivā na ñāyanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:29.4":{"pli":"āloko hoti sabbadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:30.1":{"pli":"Abhibhonti na tassābhā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:30.2":{"pli":"candasūrā satārakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:30.3":{"pli":"Samantā yojanasate, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:30.4":{"pli":"padīpopi na pajjali. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:31.1":{"pli":"Tena kālena ye keci, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:31.2":{"pli":"thūpaṁ pūjenti mānusā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:31.3":{"pli":"Na te thūpaṁ āruhanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:31.4":{"pli":"ambare ukkhipanti te. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:32.1":{"pli":"Devehi ṭhapito yakkho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:32.2":{"pli":"abhisammatanāmako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:32.3":{"pli":"Dhajaṁ vā pupphadāmaṁ vā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:32.4":{"pli":"abhiropeti uttariṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:33.1":{"pli":"Na te passanti taṁ yakkhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:33.2":{"pli":"dāmaṁ passanti gacchato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:33.3":{"pli":"Evaṁ passitvā gacchantā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:33.4":{"pli":"sabbe gacchanti suggatiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:34.1":{"pli":"Viruddhā ye pāvacane, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:34.2":{"pli":"pasannā ye ca sāsane; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:34.3":{"pli":"Pāṭihīraṁ daṭṭhukāmā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:34.4":{"pli":"thūpaṁ pūjenti mānusā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:35.1":{"pli":"Nagare haṁsavatiyā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:35.2":{"pli":"ahosiṁ bhatako tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:35.3":{"pli":"Āmoditaṁ janaṁ disvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:35.4":{"pli":"evaṁ cintesahaṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:36.1":{"pli":"‘Uḷāro bhagavā neso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:36.2":{"pli":"yassa dhātughare disaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:36.3":{"pli":"Imā ca janatā tuṭṭhā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:36.4":{"pli":"kāraṁ kubbaṁ na tappare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:37.1":{"pli":"Ahampi kāraṁ kassāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:37.2":{"pli":"lokanāthassa tādino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:37.3":{"pli":"Tassa dhammesu dāyādo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:37.4":{"pli":"bhavissāmi anāgate’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:38.1":{"pli":"Sudhotaṁ rajakenāhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:38.2":{"pli":"uttareyyaṁ paṭaṁ mama; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:38.3":{"pli":"Veḷagge ālaggetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:38.4":{"pli":"dhajaṁ ukkhipimambare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:39.1":{"pli":"Abhisammatako gayha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:39.2":{"pli":"ambare hāsi me dhajaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:39.3":{"pli":"Vāteritaṁ dhajaṁ disvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:39.4":{"pli":"bhiyyo hāsaṁ janesahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:40.1":{"pli":"Tattha cittaṁ pasādetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:40.2":{"pli":"samaṇaṁ upasaṅkamiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:40.3":{"pli":"Taṁ bhikkhuṁ abhivādetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:40.4":{"pli":"vipākaṁ pucchahaṁ dhaje. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:41.1":{"pli":"So me kathesi ānandī, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:41.2":{"pli":"pītisañjananaṁ mama; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:41.3":{"pli":"‘Tassa dhajassa vipākaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:41.4":{"pli":"anubhossasi sabbadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:42.1":{"pli":"Hatthiassarathāpattī, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:42.2":{"pli":"senā ca caturaṅginī; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:42.3":{"pli":"Parivāressanti taṁ niccaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:42.4":{"pli":"dhajadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:43.1":{"pli":"Saṭṭhituriyasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:43.2":{"pli":"bheriyo samalaṅkatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:43.3":{"pli":"Parivāressanti taṁ niccaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:43.4":{"pli":"dhajadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:44.1":{"pli":"Chaḷasītisahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:44.2":{"pli":"nāriyo samalaṅkatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:44.3":{"pli":"Vicittavatthābharaṇā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:44.4":{"pli":"āmukkamaṇikuṇḍalā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:45.1":{"pli":"Aḷārapamhā hasulā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:45.2":{"pli":"susaññā tanumajjhimā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:45.3":{"pli":"Parivāressanti taṁ niccaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:45.4":{"pli":"dhajadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:46.1":{"pli":"Tiṁsakappasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:46.2":{"pli":"devaloke ramissasi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:46.3":{"pli":"Asītikkhattuṁ devindo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:46.4":{"pli":"devarajjaṁ karissasi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:47.1":{"pli":"Sahassakkhattuṁ rājā ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:47.2":{"pli":"cakkavattī bhavissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:47.3":{"pli":"Padesarajjaṁ vipulaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:47.4":{"pli":"gaṇanāto asaṅkhiyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:48.1":{"pli":"Kappasatasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:48.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:48.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:48.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:49.1":{"pli":"Devalokā cavitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:49.2":{"pli":"sukkamūlena codito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:49.3":{"pli":"Puññakammena saññutto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:49.4":{"pli":"brahmabandhu bhavissasi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:50.1":{"pli":"Asītikoṭiṁ chaḍḍetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:50.2":{"pli":"dāse kammakare bahū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:50.3":{"pli":"Gotamassa bhagavato, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:50.4":{"pli":"sāsane pabbajissasi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:51.1":{"pli":"Ārādhayitvā sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:51.2":{"pli":"gotamaṁ sakyapuṅgavaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:51.3":{"pli":"Upavānoti nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:51.4":{"pli":"hessasi satthu sāvako’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:52.1":{"pli":"Satasahasse kataṁ kammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:52.2":{"pli":"phalaṁ dassesi me idha; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:52.3":{"pli":"Sumutto saravegova, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:52.4":{"pli":"kilese jhāpayiṁ mama. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:53.1":{"pli":"Cakkavattissa santassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:53.2":{"pli":"cātuddīpissarassa me; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:53.3":{"pli":"Tīṇi yojanāni sāmantā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:53.4":{"pli":"ussīyanti dhajā sadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:54.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:54.2":{"pli":"yaṁ kammamakariṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:54.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:54.4":{"pli":"dhajadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:55.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:55.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:55.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:56.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:56.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:56.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap562:57.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap562:57.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap562:57.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap562:58.1":{"pli":"Itthaṁ sudaṁ āyasmā upavānatthero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap562:59.1":{"pli":"Upavānattherassāpadānaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap563":{"tha-ap563:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap563'><header><ul><li class='division'>{}</li>"},"tha-ap563:0.2":{"pli":"Yasavagga ","html":"<li>{}</li></ul>"},"tha-ap563:0.3":{"pli":"Raṭṭhapālattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap563:1.1":{"pli":"“Padumuttarassa bhagavato, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap563:1.2":{"pli":"Lokajeṭṭhassa tādino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:1.3":{"pli":"Varanāgo mayā dinno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:1.4":{"pli":"Īsādanto urūḷhavā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap563:2.1":{"pli":"Setacchattopasobhito, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap563:2.2":{"pli":"sakappano sahatthipo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:2.3":{"pli":"Agghāpetvāna taṁ sabbaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:2.4":{"pli":"saṅghārāmaṁ akārayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap563:3.1":{"pli":"Catupaññāsasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap563:3.2":{"pli":"pāsāde kārayiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:3.3":{"pli":"Mahoghadānaṁ karitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:3.4":{"pli":"niyyādesiṁ mahesino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap563:4.1":{"pli":"Anumodi mahāvīro, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap563:4.2":{"pli":"sayambhū aggapuggalo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:4.3":{"pli":"Sabbe jane hāsayanto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:4.4":{"pli":"desesi amataṁ padaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap563:5.1":{"pli":"Taṁ me buddho viyākāsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap563:5.2":{"pli":"jalajuttamanāmako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:5.3":{"pli":"Bhikkhusaṅghe nisīditvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:5.4":{"pli":"imā gāthā abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap563:6.1":{"pli":"‘Catupaññāsasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap563:6.2":{"pli":"pāsāde kārayī ayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:6.3":{"pli":"Kathayissāmi vipākaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:6.4":{"pli":"suṇātha mama bhāsato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap563:7.1":{"pli":"Aṭṭhārasasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap563:7.2":{"pli":"kūṭāgārā bhavissare; ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:7.3":{"pli":"Byamhuttamamhi nibbattā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:7.4":{"pli":"sabbasoṇṇamayā ca te. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap563:8.1":{"pli":"Paññāsakkhattuṁ devindo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap563:8.2":{"pli":"devarajjaṁ karissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:8.3":{"pli":"Aṭṭhapaññāsakkhattuñca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:8.4":{"pli":"cakkavattī bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap563:9.1":{"pli":"Kappasatasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap563:9.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:9.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:9.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap563:10.1":{"pli":"Devalokā cavitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap563:10.2":{"pli":"sukkamūlena codito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:10.3":{"pli":"Aḍḍhe kule mahābhoge, ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:10.4":{"pli":"nibbattissati tāvade. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap563:11.1":{"pli":"So pacchā pabbajitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap563:11.2":{"pli":"sukkamūlena codito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:11.3":{"pli":"Raṭṭhapāloti nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:11.4":{"pli":"hessati satthu sāvako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap563:12.1":{"pli":"Padhānapahitatto so, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap563:12.2":{"pli":"upasanto nirūpadhi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:12.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:12.4":{"pli":"nibbāyissatināsavo’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap563:13.1":{"pli":"Uṭṭhāya abhinikkhamma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap563:13.2":{"pli":"jahitā bhogasampadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:13.3":{"pli":"Kheḷapiṇḍeva bhogamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:13.4":{"pli":"pemaṁ mayhaṁ na vijjati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap563:14.1":{"pli":"Vīriyaṁ me dhuradhorayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap563:14.2":{"pli":"yogakkhemādhivāhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:14.3":{"pli":"Dhāremi antimaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:14.4":{"pli":"sammāsambuddhasāsane. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap563:15.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap563:15.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:15.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap563:16.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap563:16.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:16.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap563:17.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap563:17.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:17.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap563:18.1":{"pli":"Itthaṁ sudaṁ āyasmā raṭṭhapālo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap563:19.1":{"pli":"Raṭṭhapālattherassāpadānaṁ ekādasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap563:20.1":{"pli":"Yasavaggo chapaññāsamo. ","html":"<p class='endsection'>{}</p>"},"tha-ap563:21.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"tha-ap563:22.1":{"pli":"Yaso nadīkassapo ca, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"tha-ap563:22.2":{"pli":"gayākimilavajjino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:22.3":{"pli":"Duve uttarā bhaddajī, ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:22.4":{"pli":"sivako upavāhano; ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:22.5":{"pli":"Raṭṭhapālo ekasataṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap563:22.6":{"pli":"gāthānaṁ pañcanavuti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap563:23.1":{"pli":"Therāpadānaṁ samattaṁ. ","html":"<p class='endbook'>{}</p></article>"}},"tha-ap57":{"tha-ap57:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap57'><header><ul><li class='division'>{}</li>"},"tha-ap57:0.2":{"pli":"Bījanivagga ","html":"<li>{}</li></ul>"},"tha-ap57:0.3":{"pli":"5 Opavayhattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap57:1.1":{"pli":"“Padumuttarabuddhassa, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap57:1.2":{"pli":"ājānīyamadāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap57:1.3":{"pli":"Niyyādetvāna sambuddhe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap57:1.4":{"pli":"agamāsiṁ sakaṁ gharaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap57:2.1":{"pli":"Devalo nāma nāmena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap57:2.2":{"pli":"satthuno aggasāvako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap57:2.3":{"pli":"Varadhammassa dāyādo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap57:2.4":{"pli":"āgacchi mama santikaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap57:3.1":{"pli":"Sapattabhāro bhagavā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap57:3.2":{"pli":"ājāneyyo na kappati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap57:3.3":{"pli":"Tava saṅkappamaññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap57:3.4":{"pli":"adhivāsesi cakkhumā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap57:4.1":{"pli":"Agghāpetvā vātajavaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap57:4.2":{"pli":"sindhavaṁ sīghavāhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap57:4.3":{"pli":"Padumuttarabuddhassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap57:4.4":{"pli":"khamanīyamadāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap57:5.1":{"pli":"Yaṁ yaṁ yonupapajjāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap57:5.2":{"pli":"devattaṁ atha mānusaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap57:5.3":{"pli":"Khamanīyaṁ vātajavaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap57:5.4":{"pli":"cittaṁ nibbattate mama. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap57:6.1":{"pli":"Lābhaṁ tesaṁ suladdhaṁva, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap57:6.2":{"pli":"ye labhantupasampadaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap57:6.3":{"pli":"Punapi payirupāseyyaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap57:6.4":{"pli":"buddho loke sace bhave. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap57:7.1":{"pli":"Aṭṭhavīsatikkhattuṁhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap57:7.2":{"pli":"rājā āsiṁ mahabbalo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap57:7.3":{"pli":"Cāturanto vijitāvī, ","html":"<span class='verse-line'>{}</span>"},"tha-ap57:7.4":{"pli":"jambusaṇḍassa issaro. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap57:8.1":{"pli":"Idaṁ pacchimakaṁ mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap57:8.2":{"pli":"carimo vattate bhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap57:8.3":{"pli":"Pattosmi acalaṁ ṭhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap57:8.4":{"pli":"hitvā jayaparājayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap57:9.1":{"pli":"Catutiṁsasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap57:9.2":{"pli":"mahātejosi khattiyo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap57:9.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap57:9.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap57:10.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap57:10.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap57:10.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap57:11.1":{"pli":"Itthaṁ sudaṁ āyasmā opavayho thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap57:12.1":{"pli":"Opavayhattherassāpadānaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap58":{"tha-ap58:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap58'><header><ul><li class='division'>{}</li>"},"tha-ap58:0.2":{"pli":"Bījanivagga ","html":"<li>{}</li></ul>"},"tha-ap58:0.3":{"pli":"Saparivārāsanattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap58:1.1":{"pli":"“Padumuttarabuddhassa, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap58:1.2":{"pli":"piṇḍapātaṁ adāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap58:1.3":{"pli":"Gantvā kiliṭṭhakaṁ ṭhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap58:1.4":{"pli":"mallikāhi parikkhitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap58:2.1":{"pli":"Tamhāsanamhi āsīno, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap58:2.2":{"pli":"buddho lokagganāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap58:2.3":{"pli":"Akittayi piṇḍapātaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap58:2.4":{"pli":"ujubhūto samāhito. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap58:3.1":{"pli":"Yathāpi bhaddake khette, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap58:3.2":{"pli":"bījaṁ appampi ropitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap58:3.3":{"pli":"Sammā dhāraṁ pavecchante, ","html":"<span class='verse-line'>{}</span>"},"tha-ap58:3.4":{"pli":"phalaṁ toseti kassakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap58:4.1":{"pli":"Tathevāyaṁ piṇḍapāto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap58:4.2":{"pli":"sukhette ropito tayā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap58:4.3":{"pli":"Bhave nibbattamānamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap58:4.4":{"pli":"phalaṁ te tosayissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap58:5.1":{"pli":"Idaṁ vatvāna sambuddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap58:5.2":{"pli":"jalajuttamanāmako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap58:5.3":{"pli":"Piṇḍapātaṁ gahetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap58:5.4":{"pli":"pakkāmi utt