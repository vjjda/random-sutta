{"bv14":{"bv14:0.1":{"pli":"Buddhavaṁsa ","html":"<article id='bv14'><header><ul><li class='division'>{}</li></ul>"},"bv14:0.2":{"pli":"14. Sujātabuddhavaṁsa ","html":"<h1 class='sutta-title'>{}</h1></header>"},"bv14:1.1":{"pli":"“Tattheva maṇḍakappamhi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"bv14:1.2":{"pli":"sujāto nāma nāyako; ","html":"<span class='verse-line'>{}</span>"},"bv14:1.3":{"pli":"Sīhahanusabhakkhandho, ","html":"<span class='verse-line'>{}</span>"},"bv14:1.4":{"pli":"appameyyo durāsado. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:2.1":{"pli":"Candova vimalo suddho, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:2.2":{"pli":"sataraṁsīva patāpavā; ","html":"<span class='verse-line'>{}</span>"},"bv14:2.3":{"pli":"Evaṁ sobhati sambuddho, ","html":"<span class='verse-line'>{}</span>"},"bv14:2.4":{"pli":"jalanto siriyā sadā. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:3.1":{"pli":"Pāpuṇitvāna sambuddho, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:3.2":{"pli":"kevalaṁ bodhimuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"bv14:3.3":{"pli":"Sumaṅgalamhi nagare, ","html":"<span class='verse-line'>{}</span>"},"bv14:3.4":{"pli":"dhammacakkaṁ pavattayi. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:4.1":{"pli":"Desente pavaraṁ dhammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:4.2":{"pli":"Sujāte lokanāyake; ","html":"<span class='verse-line'>{}</span>"},"bv14:4.3":{"pli":"Asītikoṭī abhisamiṁsu, ","html":"<span class='verse-line'>{}</span>"},"bv14:4.4":{"pli":"Paṭhame dhammadesane. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:5.1":{"pli":"Yadā sujāto amitayaso, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:5.2":{"pli":"Deve vassaṁ upāgami; ","html":"<span class='verse-line'>{}</span>"},"bv14:5.3":{"pli":"Sattatiṁsasatasahassānaṁ, ","html":"<span class='verse-line'>{}</span>"},"bv14:5.4":{"pli":"Dutiyābhisamayo ahu. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:6.1":{"pli":"Yadā sujāto asamasamo, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:6.2":{"pli":"Upagacchi pitusantikaṁ; ","html":"<span class='verse-line'>{}</span>"},"bv14:6.3":{"pli":"Saṭṭhisatasahassānaṁ, ","html":"<span class='verse-line'>{}</span>"},"bv14:6.4":{"pli":"Tatiyābhisamayo ahu. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:7.1":{"pli":"Sannipātā tayo āsuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:7.2":{"pli":"sujātassa mahesino; ","html":"<span class='verse-line'>{}</span>"},"bv14:7.3":{"pli":"Khīṇāsavānaṁ vimalānaṁ, ","html":"<span class='verse-line'>{}</span>"},"bv14:7.4":{"pli":"santacittāna tādinaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:8.1":{"pli":"Abhiññābalappattānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:8.2":{"pli":"appattānaṁ bhavābhave; ","html":"<span class='verse-line'>{}</span>"},"bv14:8.3":{"pli":"Saṭṭhisatasahassāni, ","html":"<span class='verse-line'>{}</span>"},"bv14:8.4":{"pli":"paṭhamaṁ sannipatiṁsu te. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:9.1":{"pli":"Punāparaṁ sannipāte, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:9.2":{"pli":"tidivorohaṇe jine; ","html":"<span class='verse-line'>{}</span>"},"bv14:9.3":{"pli":"Paññāsasatasahassānaṁ, ","html":"<span class='verse-line'>{}</span>"},"bv14:9.4":{"pli":"dutiyo āsi samāgamo. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:10.1":{"pli":"Upasaṅkamanto narāsabhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:10.2":{"pli":"Tassa yo aggasāvako; ","html":"<span class='verse-line'>{}</span>"},"bv14:10.3":{"pli":"Catūhi satasahassehi, ","html":"<span class='verse-line'>{}</span>"},"bv14:10.4":{"pli":"Sambuddhaṁ upasaṅkami. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:11.1":{"pli":"Ahaṁ tena samayena, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:11.2":{"pli":"catudīpamhi issaro; ","html":"<span class='verse-line'>{}</span>"},"bv14:11.3":{"pli":"Antalikkhacaro āsiṁ, ","html":"<span class='verse-line'>{}</span>"},"bv14:11.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:12.1":{"pli":"Loke acchariyaṁ disvā, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:12.2":{"pli":"abbhutaṁ lomahaṁsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"bv14:12.3":{"pli":"Upagantvāna vandiṁ so, ","html":"<span class='verse-line'>{}</span>"},"bv14:12.4":{"pli":"sujātaṁ lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:13.1":{"pli":"Catudīpe mahārajjaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:13.2":{"pli":"ratane satta uttame; ","html":"<span class='verse-line'>{}</span>"},"bv14:13.3":{"pli":"Buddhe niyyādayitvāna, ","html":"<span class='verse-line'>{}</span>"},"bv14:13.4":{"pli":"pabbajiṁ tassa santike. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:14.1":{"pli":"Ārāmikā janapade, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:14.2":{"pli":"uṭṭhānaṁ paṭipiṇḍiya; ","html":"<span class='verse-line'>{}</span>"},"bv14:14.3":{"pli":"Upanenti bhikkhusaṅghassa, ","html":"<span class='verse-line'>{}</span>"},"bv14:14.4":{"pli":"paccayaṁ sayanāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:15.1":{"pli":"Sopi maṁ buddho byākāsi, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:15.2":{"pli":"dasasahassimhi issaro; ","html":"<span class='verse-line'>{}</span>"},"bv14:15.3":{"pli":"‘Tiṁsakappasahassamhi, ","html":"<span class='verse-line'>{}</span>"},"bv14:15.4":{"pli":"ayaṁ buddho bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:16.1":{"pli":"Padhānaṁ padahitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:16.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"bv14:16.3":{"pli":"hessāma sammukhā imaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:17.1":{"pli":"Tassāpi vacanaṁ sutvā, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:17.2":{"pli":"bhiyyo hāsaṁ janesahaṁ; ","html":"<span class='verse-line'>{}</span>"},"bv14:17.3":{"pli":"Adhiṭṭhahiṁ vataṁ uggaṁ, ","html":"<span class='verse-line'>{}</span>"},"bv14:17.4":{"pli":"dasapāramipūriyā. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:18.1":{"pli":"Suttantaṁ vinayañcāpi, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:18.2":{"pli":"navaṅgaṁ satthusāsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"bv14:18.3":{"pli":"Sabbaṁ pariyāpuṇitvāna, ","html":"<span class='verse-line'>{}</span>"},"bv14:18.4":{"pli":"sobhayiṁ jinasāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:19.1":{"pli":"Tatthappamatto viharanto, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:19.2":{"pli":"brahmaṁ bhāvetva bhāvanaṁ; ","html":"<span class='verse-line'>{}</span>"},"bv14:19.3":{"pli":"Abhiññāpāramiṁ gantvā, ","html":"<span class='verse-line'>{}</span>"},"bv14:19.4":{"pli":"brahmalokamagañchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:20.1":{"pli":"Sumaṅgalaṁ nāma nagaraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:20.2":{"pli":"uggato nāma khattiyo; ","html":"<span class='verse-line'>{}</span>"},"bv14:20.3":{"pli":"Mātā pabhāvatī nāma, ","html":"<span class='verse-line'>{}</span>"},"bv14:20.4":{"pli":"sujātassa mahesino. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:21.1":{"pli":"Navavassasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:21.2":{"pli":"agāraṁ ajjha so vasi; ","html":"<span class='verse-line'>{}</span>"},"bv14:21.3":{"pli":"Sirī upasirī nando, ","html":"<span class='verse-line'>{}</span>"},"bv14:21.4":{"pli":"tayo pāsādamuttamā. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:22.1":{"pli":"Tevīsatisahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:22.2":{"pli":"nāriyo samalaṅkatā; ","html":"<span class='verse-line'>{}</span>"},"bv14:22.3":{"pli":"Sirinandā nāma nārī, ","html":"<span class='verse-line'>{}</span>"},"bv14:22.4":{"pli":"upaseno nāma atrajo. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:23.1":{"pli":"Nimitte caturo disvā, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:23.2":{"pli":"assayānena nikkhami; ","html":"<span class='verse-line'>{}</span>"},"bv14:23.3":{"pli":"Anūnanavamāsāni, ","html":"<span class='verse-line'>{}</span>"},"bv14:23.4":{"pli":"padhānaṁ padahī jino. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:24.1":{"pli":"Brahmunā yācito santo, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:24.2":{"pli":"sujāto lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"bv14:24.3":{"pli":"Vatti cakkaṁ mahāvīro, ","html":"<span class='verse-line'>{}</span>"},"bv14:24.4":{"pli":"sumaṅgaluyyānamuttame. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:25.1":{"pli":"Sudassano sudevo ca, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:25.2":{"pli":"ahesuṁ aggasāvakā; ","html":"<span class='verse-line'>{}</span>"},"bv14:25.3":{"pli":"Nārado nāmupaṭṭhāko, ","html":"<span class='verse-line'>{}</span>"},"bv14:25.4":{"pli":"sujātassa mahesino. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:26.1":{"pli":"Nāgā ca nāgasamālā ca, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:26.2":{"pli":"ahesuṁ aggasāvikā; ","html":"<span class='verse-line'>{}</span>"},"bv14:26.3":{"pli":"Bodhi tassa bhagavato, ","html":"<span class='verse-line'>{}</span>"},"bv14:26.4":{"pli":"mahāveḷūti vuccati. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:27.1":{"pli":"So ca rukkho ghanakkhandho, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:27.2":{"pli":"Acchiddo hoti pattiko; ","html":"<span class='verse-line'>{}</span>"},"bv14:27.3":{"pli":"Uju vaṁso brahā hoti, ","html":"<span class='verse-line'>{}</span>"},"bv14:27.4":{"pli":"Dassanīyo manoramo. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:28.1":{"pli":"Ekakkhandho pavaḍḍhitvā, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:28.2":{"pli":"tato sākhā pabhijjati; ","html":"<span class='verse-line'>{}</span>"},"bv14:28.3":{"pli":"Yathā subaddho morahattho, ","html":"<span class='verse-line'>{}</span>"},"bv14:28.4":{"pli":"evaṁ sobhati so dumo. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:29.1":{"pli":"Na tassa kaṇṭakā honti, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:29.2":{"pli":"nāpi chiddaṁ mahā ahu; ","html":"<span class='verse-line'>{}</span>"},"bv14:29.3":{"pli":"Vitthiṇṇasākho aviralo, ","html":"<span class='verse-line'>{}</span>"},"bv14:29.4":{"pli":"sandacchāyo manoramo. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:30.1":{"pli":"Sudatto ceva citto ca, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:30.2":{"pli":"ahesuṁ aggupaṭṭhakā; ","html":"<span class='verse-line'>{}</span>"},"bv14:30.3":{"pli":"Subhaddā ca padumā ca, ","html":"<span class='verse-line'>{}</span>"},"bv14:30.4":{"pli":"ahesuṁ aggupaṭṭhikā. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:31.1":{"pli":"Paññāsaratano āsi, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:31.2":{"pli":"uccattanena so jino; ","html":"<span class='verse-line'>{}</span>"},"bv14:31.3":{"pli":"Sabbākāravarūpeto, ","html":"<span class='verse-line'>{}</span>"},"bv14:31.4":{"pli":"sabbaguṇamupāgato. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:32.1":{"pli":"Tassa pabhā asamasamā, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:32.2":{"pli":"niddhāvati samantato; ","html":"<span class='verse-line'>{}</span>"},"bv14:32.3":{"pli":"Appamāṇo atuliyo, ","html":"<span class='verse-line'>{}</span>"},"bv14:32.4":{"pli":"opammehi anūpamo. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:33.1":{"pli":"Navutivassasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:33.2":{"pli":"āyu vijjati tāvade; ","html":"<span class='verse-line'>{}</span>"},"bv14:33.3":{"pli":"Tāvatā tiṭṭhamāno so, ","html":"<span class='verse-line'>{}</span>"},"bv14:33.4":{"pli":"tāresi janataṁ bahuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:34.1":{"pli":"Yathāpi sāgare ūmī, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:34.2":{"pli":"gagane tārakā yathā; ","html":"<span class='verse-line'>{}</span>"},"bv14:34.3":{"pli":"Evaṁ tadā pāvacanaṁ, ","html":"<span class='verse-line'>{}</span>"},"bv14:34.4":{"pli":"arahantehi cittitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:35.1":{"pli":"So ca buddho asamasamo, ","html":"<p><span class='verse-line'>{}</span>"},"bv14:35.2":{"pli":"Guṇāni ca tāni atuliyāni; ","html":"<span class='verse-line'>{}</span>"},"bv14:35.3":{"pli":"Sabbaṁ tamantarahitaṁ, ","html":"<span class='verse-line'>{}</span>"},"bv14:35.4":{"pli":"Nanu rittā sabbasaṅkhārā. ","html":"<span class='verse-line'>{}</span></p>"},"bv14:36.1":{"pli":"Sujāto jinavaro buddho, ","html":"<p data-counter='6511'><span class='verse-line'>{}</span>"},"bv14:36.2":{"pli":"Silārāmamhi nibbuto; ","html":"<span class='verse-line'>{}</span>"},"bv14:36.3":{"pli":"Tattheva tassa cetiyo, ","html":"<span class='verse-line'>{}</span>"},"bv14:36.4":{"pli":"Tīṇigāvutamuggato”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"bv14:37.1":{"pli":"Sujātassa bhagavato vaṁso dvādasamo. ","html":"<p class='endsutta'>{}</p></article>"}},"bv15":{"bv15:0.1":{"pli":"Buddhavaṁsa ","html":"<article id='bv15'><header><ul><li class='division'>{}</li></ul>"},"bv15:0.2":{"pli":"15 Piyadassībuddhavaṁsa ","html":"<h1 class='sutta-title'>{}</h1></header>"},"bv15:1.1":{"pli":"“Sujātassa aparena, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"bv15:1.2":{"pli":"sayambhū lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"bv15:1.3":{"pli":"Durāsado asamasamo, ","html":"<span class='verse-line'>{}</span>"},"bv15:1.4":{"pli":"piyadassī mahāyaso. ","html":"<span class='verse-line'>{}</span></p>"},"bv15:2.1":{"pli":"Sopi buddho amitayaso, ","html":"<p><span class='verse-line'>{}</span