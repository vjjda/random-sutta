.8:4.1":{"pli":"Na vattabbaṁ—","html":"<p data-doxy='heterodox'>{}"},"kv16.8:4.2":{"pli":"“rūpaṁ vipāko”ti? ","html":"{}"},"kv16.8:4.3":{"pli":"Āmantā. ","html":"{}"},"kv16.8:4.4":{"pli":"Nanu kammassa katattā uppannā cittacetasikā dhammā vipākoti? ","html":"{}"},"kv16.8:4.5":{"pli":"Āmantā. ","html":"{}"},"kv16.8:4.6":{"pli":"Hañci kammassa katattā uppannā cittacetasikā dhammā vipāko, tena vata re vattabbe—","html":"{}"},"kv16.8:4.7":{"pli":"“kammassa katattā uppannaṁ rūpaṁ vipāko”ti. ","html":"{}</p>"},"kv16.8:4.8":{"pli":"Rūpaṁ vipākotikathā niṭṭhitā. ","html":"<p class='endsutta'>{}</p></article>"}},"kv16.9":{"kv16.9:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv16.9'><header><ul><li class='division'>{}</li>"},"kv16.9:0.2":{"pli":"Mahāpaṇṇāsaka ","html":"<li>{}</li>"},"kv16.9:0.3":{"pli":"Soḷasamavagga ","html":"<li>{}</li></ul>"},"kv16.9:0.4":{"pli":"Rūpaṁrūpāvacarārūpāvacarantikathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv16.9:1.1":{"pli":"Atthi rūpaṁ rūpāvacaranti? ","html":"<p data-doxy='orthodox'>{}"},"kv16.9:1.2":{"pli":"Āmantā. ","html":"{}"},"kv16.9:1.3":{"pli":"Samāpattesiyaṁ upapattesiyaṁ diṭṭhadhammasukhavihāraṁ, samāpattesiyena cittena upapattesiyena cittena diṭṭhadhammasukhavihārena cittena sahagataṁ sahajātaṁ saṁsaṭṭhaṁ sampayuttaṁ ekuppādaṁ ekanirodhaṁ ekavatthukaṁ ekārammaṇanti? ","html":"{}"},"kv16.9:1.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv16.9:1.5":{"pli":"nanu na samāpattesiyaṁ na upapattesiyaṁ na diṭṭhadhammasukhavihāraṁ, na samāpattesiyena cittena na upapattesiyena cittena na diṭṭhadhammasukhavihārena cittena sahagataṁ sahajātaṁ saṁsaṭṭhaṁ sampayuttaṁ ekuppādaṁ ekanirodhaṁ ekavatthukaṁ ekārammaṇanti? ","html":"{}"},"kv16.9:1.6":{"pli":"Āmantā. ","html":"{}"},"kv16.9:1.7":{"pli":"Hañci na samāpattesiyaṁ na upapattesiyaṁ na diṭṭhadhammasukhavihāraṁ, na samāpattesiyena cittena …pe… ","html":"{}"},"kv16.9:1.8":{"pli":"ekārammaṇaṁ, no ca vata re vattabbe—","html":"{}"},"kv16.9:1.9":{"pli":"“atthi rūpaṁ rūpāvacaran”ti. ","html":"{}</p>"},"kv16.9:2.1":{"pli":"Atthi rūpaṁ arūpāvacaranti? ","html":"<p data-doxy='orthodox'>{}"},"kv16.9:2.2":{"pli":"Āmantā. ","html":"{}"},"kv16.9:2.3":{"pli":"Samāpattesiyaṁ upapattesiyaṁ diṭṭhadhammasukhavihāraṁ, samāpattesiyena cittena upapattesiyena cittena diṭṭhadhammasukhavihārena cittena sahagataṁ sahajātaṁ saṁsaṭṭhaṁ sampayuttaṁ ekuppādaṁ ekanirodhaṁ ekavatthukaṁ ekārammaṇanti? ","html":"{}"},"kv16.9:2.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv16.9:2.5":{"pli":"nanu na samāpattesiyaṁ na upapattesiyaṁ na diṭṭhadhammasukhavihāraṁ, na samāpattesiyena cittena …pe… ","html":"{}"},"kv16.9:2.6":{"pli":"ekārammaṇanti? ","html":"{}"},"kv16.9:2.7":{"pli":"Āmantā. ","html":"{}"},"kv16.9:2.8":{"pli":"Hañci na samāpattesiyaṁ na upapattesiyaṁ …pe… ","html":"{}"},"kv16.9:2.9":{"pli":"ekavatthukaṁ ekārammaṇaṁ, no ca vata re vattabbe—","html":"{}"},"kv16.9:2.10":{"pli":"“atthi rūpaṁ arūpāvacaran”ti. ","html":"{}</p>"},"kv16.9:3.1":{"pli":"Na vattabbaṁ—","html":"<p data-doxy='heterodox'>{}"},"kv16.9:3.2":{"pli":"“atthi rūpaṁ rūpāvacaraṁ, atthi rūpaṁ arūpāvacaran”ti? ","html":"{}"},"kv16.9:3.3":{"pli":"Āmantā. ","html":"{}"},"kv16.9:3.4":{"pli":"Nanu kāmāvacarakammassa katattā rūpaṁ kāmāvacaranti? ","html":"{}"},"kv16.9:3.5":{"pli":"Āmantā. ","html":"{}"},"kv16.9:3.6":{"pli":"Hañci kāmāvacarakammassa katattā rūpaṁ kāmāvacaraṁ, tena vata re vattabbe—","html":"{}"},"kv16.9:3.7":{"pli":"“rūpāvacarakammassa katattā rūpaṁ rūpāvacaraṁ, arūpāvacarakammassa katattā rūpaṁ arūpāvacaran”ti. ","html":"{}</p>"},"kv16.9:3.8":{"pli":"Rūpaṁ rūpāvacarārūpāvacarantikathā niṭṭhitā. ","html":"<p class='endsutta'>{}</p></article>"}}}