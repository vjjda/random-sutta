{"thi-ap1":{"thi-ap1:0.1":{"pli":"Therīapadāna ","html":"<article id='thi-ap1'><header><ul><li class='division'>{}</li>"},"thi-ap1:0.2":{"pli":"Sumedhāvagga ","html":"<li>{}</li></ul>"},"thi-ap1:0.3":{"pli":"Sumedhātherīapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"thi-ap1:1.1":{"pli":"Namo tassa Bhagavato Arahato Sammāsambuddhassa. ","html":"<p class='namo'>{}</p>"},"thi-ap1:2.1":{"pli":"Atha therikāpadānāni suṇātha—","html":"<p>{}</p>"},"thi-ap1:3.1":{"pli":"“Bhagavati koṇāgamane, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"thi-ap1:3.2":{"pli":"Saṅghārāmamhi navanivesanamhi; ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:3.3":{"pli":"Sakhiyo tisso janiyo, ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:3.4":{"pli":"Vihāradānaṁ adāsimha. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap1:4.1":{"pli":"Dasakkhattuṁ satakkhattuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap1:4.2":{"pli":"Dasasatakkhattuṁ satānañca satakkhattuṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:4.3":{"pli":"Devesu upapajjimha, ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:4.4":{"pli":"Ko vādo mānuse bhave. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap1:5.1":{"pli":"Deve mahiddhikā ahumha, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap1:5.2":{"pli":"mānusakamhi ko vādo; ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:5.3":{"pli":"Sattaratanamahesī, ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:5.4":{"pli":"itthiratanaṁ ahaṁ bhaviṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap1:6.1":{"pli":"Idha sañcitakusalā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap1:6.2":{"pli":"susamiddhakulappajā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:6.3":{"pli":"Dhanañjānī ca khemā ca, ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:6.4":{"pli":"ahampi ca tayo janā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap1:7.1":{"pli":"Ārāmaṁ sukataṁ katvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap1:7.2":{"pli":"sabbāvayavamaṇḍitaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:7.3":{"pli":"Buddhappamukhasaṅghassa, ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:7.4":{"pli":"niyyādetvā samoditā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap1:8.1":{"pli":"Yattha yatthūpapajjāmi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap1:8.2":{"pli":"tassa kammassa vāhasā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:8.3":{"pli":"Devesu aggataṁ pattā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:8.4":{"pli":"manussesu tatheva ca. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap1:9.1":{"pli":"Imasmiṁyeva kappamhi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap1:9.2":{"pli":"brahmabandhu mahāyaso; ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:9.3":{"pli":"Kassapo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:9.4":{"pli":"uppajji vadataṁ varo. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap1:10.1":{"pli":"Upaṭṭhāko mahesissa, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap1:10.2":{"pli":"tadā āsi narissaro; ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:10.3":{"pli":"Kāsirājā kikī nāma, ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:10.4":{"pli":"bārāṇasipuruttame. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap1:11.1":{"pli":"Tassāsuṁ satta dhītaro, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap1:11.2":{"pli":"rājakaññā sukhedhitā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:11.3":{"pli":"Buddhopaṭṭhānaniratā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:11.4":{"pli":"brahmacariyaṁ cariṁsu tā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap1:12.1":{"pli":"Tāsaṁ sahāyikā hutvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap1:12.2":{"pli":"sīlesu susamāhitā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:12.3":{"pli":"Datvā dānāni sakkaccaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:12.4":{"pli":"agāreva vataṁ cariṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap1:13.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap1:13.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:13.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:13.4":{"pli":"tāvatiṁsūpagā ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap1:14.1":{"pli":"Tato cutā yāmamagaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap1:14.2":{"pli":"tatohaṁ tusitaṁ gatā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:14.3":{"pli":"Tato ca nimmānaratiṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:14.4":{"pli":"vasavattipuraṁ tato. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap1:15.1":{"pli":"Yattha yatthūpapajjāmi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap1:15.2":{"pli":"puññakammasamohitā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:15.3":{"pli":"Tattha tattheva rājūnaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:15.4":{"pli":"mahesittamakārayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap1:16.1":{"pli":"Tato cutā manussatte, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap1:16.2":{"pli":"rājūnaṁ cakkavattinaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:16.3":{"pli":"Maṇḍalīnañca rājūnaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:16.4":{"pli":"mahesittamakārayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap1:17.1":{"pli":"Sampattimanubhotvāna, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap1:17.2":{"pli":"devesu mānusesu ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:17.3":{"pli":"Sabbattha sukhitā hutvā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:17.4":{"pli":"nekajātīsu saṁsariṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap1:18.1":{"pli":"So hetu ca so pabhavo, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap1:18.2":{"pli":"Tammūlaṁ sāsane khamaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:18.3":{"pli":"Paṭhamaṁ taṁ samodhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:18.4":{"pli":"Taṁ dhammaratāya nibbānaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap1:19.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap1:19.2":{"pli":"bhavā sabbe samūhatā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:19.3":{"pli":"Nāgīva bandhanaṁ chetvā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:19.4":{"pli":"viharāmi anāsavā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap1:20.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap1:20.2":{"pli":"buddhaseṭṭhassa santike; ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:20.3":{"pli":"Tisso vijjā anuppattā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:20.4":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap1:21.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap1:21.2":{"pli":"vimokkhāpi ca aṭṭhime; ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:21.3":{"pli":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap1:21.4":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"thi-ap1:22.1":{"pli":"Itthaṁ sudaṁ sumedhā bhikkhunī imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"thi-ap1:23.1":{"pli":"Sumedhātheriyāpadānaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"thi-ap10":{"thi-ap10:0.1":{"pli":"Therīapadāna ","html":"<article id='thi-ap10'><header><ul><li class='division'>{}</li>"},"thi-ap10:0.2":{"pli":"Sumedhāvagga ","html":"<li>{}</li></ul>"},"thi-ap10:0.3":{"pli":"Udakadāyikātherīapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"thi-ap10:1.1":{"pli":"“Nagare bandhumatiyā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"thi-ap10:1.2":{"pli":"ahosiṁ udahārikā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap10:1.3":{"pli":"Udahārena jīvāmi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap10:1.4":{"pli":"tena posemi dārake. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap10:2.1":{"pli":"Deyyadhammo ca me natthi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap10:2.2":{"pli":"puññakkhette anuttare; ","html":"<span class='verse-line'>{}</span>"},"thi-ap10:2.3":{"pli":"Koṭṭhakaṁ upasaṅkamma, ","html":"<span class='verse-line'>{}</span>"},"thi-ap10:2.4":{"pli":"udakaṁ paṭṭhapesahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap10:3.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap10:3.2":{"pli":"tāvatiṁsamagacchahaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap10:3.3":{"pli":"Tattha me sukataṁ byamhaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap10:3.4":{"pli":"udahārena nimmitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap10:4.1":{"pli":"Accharānaṁ sahassassa, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap10:4.2":{"pli":"ahañhi pavarā tadā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap10:4.3":{"pli":"Dasaṭṭhānehi tā sabbā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap10:4.4":{"pli":"abhibhomi sadā ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap10:5.1":{"pli":"Paññāsaṁ devarājūnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap10:5.2":{"pli":"mahesittamakārayiṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap10:5.3":{"pli":"Vīsaticakkavattīnaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap10:5.4":{"pli":"mahesittamakārayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap10:6.1":{"pli":"Duve bhave saṁsarāmi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap10:6.2":{"pli":"devatte atha mānuse; ","html":"<span class='verse-line'>{}</span>"},"thi-ap10:6.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap10:6.4":{"pli":"dakadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap10:7.1":{"pli":"Pabbatagge dumagge vā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap10:7.2":{"pli":"antalikkhe ca bhūmiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap10:7.3":{"pli":"Yadā udakamicchāmi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap10:7.4":{"pli":"khippaṁ paṭilabhāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap10:8.1":{"pli":"Avuṭṭhikā disā natthi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap10:8.2":{"pli":"santattā kuthitāpi ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap10:8.3":{"pli":"Mama saṅkappamaññāya, ","html":"<span class='verse-line'>{}</span>"},"thi-ap10:8.4":{"pli":"mahāmegho pavassati. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap10:9.1":{"pli":"Kadāci nīyamānāya, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap10:9.2":{"pli":"ñātisaṅghena me tadā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap10:9.3":{"pli":"Yadā icchāmahaṁ vassaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap10:9.4":{"pli":"mahāmegho ajāyatha. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap10:10.1":{"pli":"Uṇhaṁ vā pariḷāho vā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap10:10.2":{"pli":"sarīre me na vijjati; ","html":"<span class='verse-line'>{}</span>"},"thi-ap10:10.3":{"pli":"Kāye ca me rajo natthi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap10:10.4":{"pli":"dakadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap10:11.1":{"pli":"Visuddhamanasā ajja, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap10:11.2":{"pli":"apetamanapāpikā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap10:11.3":{"pli":"Sabbāsavaparikkhīṇā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap10:11.4":{"pli":"natthi dāni punabbhavo. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap10:12.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap10:12.2":{"pli":"yaṁ dakaṁ adadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap10:12.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap10:12.4":{"pli":"dakadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap10:13.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap10:13.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap10:13.3":{"pli":"viharāmi anāsavā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap10:14.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap10:14.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap10:14.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap10:15.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap10:15.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap10:15.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"thi-ap10:16.1":{"pli":"Itthaṁ sudaṁ udakadāyikā bhikkhunī imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"thi-ap10:17.1":{"pli":"Udakadāyikātheriyāpadānaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"thi-ap10:18.1":{"pli":"Sumedhāvaggo paṭhamo. ","html":"<p class='endsection'>{}</p>"},"thi-ap10:19.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"thi-ap10:20.1":{"pli":"Sumedhā mekhalādāyī, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"thi-ap10:20.2":{"pli":"maṇḍapaṁ saṅkamaṁ dadā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap10:20.3":{"pli":"Naḷamālī piṇḍadadā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap10:20.4":{"pli":"kaṭacchu uppalappadā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap10:21.1":{"pli":"Dīpadā dakadā ceva, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap10:21.2":{"pli":"gāthāyo gaṇitā iha; ","html":"<span class='verse-line'>{}</span>"},"thi-ap10:21.3":{"pli":"Ekagāthāsatañceva, ","html":"<span class='verse-line'>{}</span>"},"thi-ap10:21.4":{"pli":"tiṁsati ca taduttari. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"thi-ap11":{"thi-ap11:0.1":{"pli":"Therīapadāna ","html":"<article id='thi-ap11'><header><ul><li class='division'>{}</li>"},"thi-ap11:0.2":{"pli":"Ekūposathikavagga ","html":"<li>{}</li></ul>"},"thi-ap11:0.3":{"pli":"1 Ekūposathikātherīapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"thi-ap11:1.1":{"pli":"“Nagare bandhumatiyā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"thi-ap11:1.2":{"pli":"bandhumā nāma khattiyo; ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:1.3":{"pli":"Divase puṇṇamāya so, ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:1.4":{"pli":"upavasi uposathaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap11:2.1":{"pli":"Ahaṁ tena samayena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap11:2.2":{"pli":"kumbhadāsī ahaṁ tahiṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:2.3":{"pli":"Disvā sarājakaṁ senaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:2.4":{"pli":"evāhaṁ cintayiṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap11:3.1":{"pli":"‘Rājāpi rajjaṁ chaḍḍetvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap11:3.2":{"pli":"upavasi uposathaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:3.3":{"pli":"Saphalaṁ nūna taṁ kammaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:3.4":{"pli":"janakāyo pamodito’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap11:4.1":{"pli":"Yoniso paccavekkhitvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap11:4.2":{"pli":"duggaccañca daliddataṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:4.3":{"pli":"Mānasaṁ sampahaṁsitvā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:4.4":{"pli":"upavasiṁ uposathaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap11:5.1":{"pli":"Ahaṁ uposathaṁ katvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap11:5.2":{"pli":"sammāsambuddhasāsane; ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:5.3":{"pli":"Tena kammena sukatena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:5.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap11:6.1":{"pli":"Tattha me sukataṁ byamhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap11:6.2":{"pli":"ubbhayojanamuggataṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:6.3":{"pli":"Kūṭāgāravarūpetaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:6.4":{"pli":"mahāsanasubhūsitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap11:7.1":{"pli":"Accharā satasahassā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap11:7.2":{"pli":"upatiṭṭhanti maṁ sadā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:7.3":{"pli":"Aññe deve atikkamma, ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:7.4":{"pli":"atirocāmi sabbadā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap11:8.1":{"pli":"Catusaṭṭhi devarājūnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap11:8.2":{"pli":"mahesittamakārayiṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:8.3":{"pli":"Tesaṭṭhi cakkavattīnaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:8.4":{"pli":"mahesittamakārayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap11:9.1":{"pli":"Suvaṇṇavaṇṇā hutvāna, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap11:9.2":{"pli":"bhavesu saṁsarāmahaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:9.3":{"pli":"Sabbattha pavarā homi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:9.4":{"pli":"uposathassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap11:10.1":{"pli":"Hatthiyānaṁ assayānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap11:10.2":{"pli":"rathayānañca sīvikaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:10.3":{"pli":"Labhāmi sabbamevetaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:10.4":{"pli":"uposathassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap11:11.1":{"pli":"Soṇṇamayaṁ rūpimayaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap11:11.2":{"pli":"athopi phalikāmayaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:11.3":{"pli":"Lohitaṅgamayañceva, ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:11.4":{"pli":"sabbaṁ paṭilabhāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap11:12.1":{"pli":"Koseyyakambaliyāni, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap11:12.2":{"pli":"khomakappāsikāni ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:12.3":{"pli":"Mahagghāni ca vatthāni, ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:12.4":{"pli":"sabbaṁ paṭilabhāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap11:13.1":{"pli":"Annaṁ pānaṁ khādanīyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap11:13.2":{"pli":"vatthasenāsanāni ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:13.3":{"pli":"Sabbametaṁ paṭilabhe, ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:13.4":{"pli":"uposathassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap11:14.1":{"pli":"Varagandhañca mālañca, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap11:14.2":{"pli":"cuṇṇakañca vilepanaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:14.3":{"pli":"Sabbametaṁ paṭilabhe, ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:14.4":{"pli":"uposathassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap11:15.1":{"pli":"Kūṭāgārañca pāsādaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap11:15.2":{"pli":"maṇḍapaṁ hammiyaṁ guhaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:15.3":{"pli":"Sabbametaṁ paṭilabhe, ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:15.4":{"pli":"uposathassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap11:16.1":{"pli":"Jātiyā sattavassāhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap11:16.2":{"pli":"pabbajiṁ anagāriyaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:16.3":{"pli":"Aḍḍhamāse asampatte, ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:16.4":{"pli":"arahattamapāpuṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap11:17.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap11:17.2":{"pli":"bhavā sabbe samūhatā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:17.3":{"pli":"Sabbāsavā parikkhīṇā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:17.4":{"pli":"natthi dāni punabbhavo. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap11:18.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap11:18.2":{"pli":"yaṁ kammamakariṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:18.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:18.4":{"pli":"uposathassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap11:19.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap11:19.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:19.3":{"pli":"viharāmi anāsavā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap11:20.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap11:20.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:20.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap11:21.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap11:21.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap11:21.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"thi-ap11:22.1":{"pli":"Itthaṁ sudaṁ ekūposathikā bhikkhunī imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"thi-ap11:23.1":{"pli":"Ekūposathikātheriyāpadānaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"thi-ap12":{"thi-ap12:0.1":{"pli":"Therīapadāna ","html":"<article id='thi-ap12'><header><ul><li class='division'>{}</li>"},"thi-ap12:0.2":{"pli":"Ekūposathikavagga ","html":"<li>{}</li></ul>"},"thi-ap12:0.3":{"pli":"2 Saḷalapupphikātherīapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"thi-ap12:1.1":{"pli":"“Candabhāgānadītīre, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"thi-ap12:1.2":{"pli":"ahosiṁ kinnarī tadā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap12:1.3":{"pli":"Addasāhaṁ devadevaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap12:1.4":{"pli":"caṅkamantaṁ narāsabhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap12:2.1":{"pli":"Ocinitvāna saḷalaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap12:2.2":{"pli":"buddhaseṭṭhassadāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap12:2.3":{"pli":"Upasiṅghi mahāvīro, ","html":"<span class='verse-line'>{}</span>"},"thi-ap12:2.4":{"pli":"saḷalaṁ devagandhikaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap12:3.1":{"pli":"Paṭiggahetvā sambuddho, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap12:3.2":{"pli":"vipassī lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"thi-ap12:3.3":{"pli":"Upasiṅghi mahāvīro, ","html":"<span class='verse-line'>{}</span>"},"thi-ap12:3.4":{"pli":"pekkhamānāya me tadā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap12:4.1":{"pli":"Añjaliṁ paggahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap12:4.2":{"pli":"vanditvā dvipaduttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap12:4.3":{"pli":"Sakaṁ cittaṁ pasādetvā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap12:4.4":{"pli":"tato pabbatamāruhiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap12:5.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap12:5.2":{"pli":"yaṁ pupphamadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap12:5.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap12:5.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap12:6.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap12:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap12:6.3":{"pli":"viharāmi anāsavā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap12:7.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap12:7.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap12:7.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap12:8.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap12:8.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap12:8.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"thi-ap12:9.1":{"pli":"Itthaṁ sudaṁ saḷalapupphikā bhikkhunī imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"thi-ap12:10.1":{"pli":"Saḷalapupphikātheriyāpadānaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"thi-ap13":{"thi-ap13:0.1":{"pli":"Therīapadāna ","html":"<article id='thi-ap13'><header><ul><li class='division'>{}</li>"},"thi-ap13:0.2":{"pli":"Ekūposathikavagga ","html":"<li>{}</li></ul>"},"thi-ap13:0.3":{"pli":"Modakadāyikātherīapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"thi-ap13:1.1":{"pli":"“Nagare bandhumatiyā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"thi-ap13:1.2":{"pli":"kumbhadāsī ahosahaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap13:1.3":{"pli":"Mama bhāgaṁ gahetvāna, ","html":"<span class='verse-line'>{}</span>"},"thi-ap13:1.4":{"pli":"gacchaṁ udakahārikā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap13:2.1":{"pli":"Panthamhi samaṇaṁ disvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap13:2.2":{"pli":"santacittaṁ samāhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap13:2.3":{"pli":"Pasannacittā sumanā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap13:2.4":{"pli":"modake tīṇidāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap13:3.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap13:3.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap13:3.3":{"pli":"Ekanavutikappāni, ","html":"<span class='verse-line'>{}</span>"},"thi-ap13:3.4":{"pli":"vinipātaṁ nagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap13:4.1":{"pli":"Sampatti taṁ karitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap13:4.2":{"pli":"sabbaṁ anubhaviṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap13:4.3":{"pli":"Modake tīṇi datvāna, ","html":"<span class='verse-line'>{}</span>"},"thi-ap13:4.4":{"pli":"pattāhaṁ acalaṁ padaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap13:5.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap13:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap13:5.3":{"pli":"viharāmi anāsavā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap13:6.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap13:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap13:6.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap13:7.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap13:7.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap13:7.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"thi-ap13:8.1":{"pli":"Itthaṁ sudaṁ modakadāyikā bhikkhunī imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"thi-ap13:9.1":{"pli":"Modakadāyikātheriyāpadānaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"thi-ap14":{"thi-ap14:0.1":{"pli":"Therīapadāna ","html":"<article id='thi-ap14'><header><ul><li class='division'>{}</li>"},"thi-ap14:0.2":{"pli":"Ekūposathikavagga ","html":"<li>{}</li></ul>"},"thi-ap14:0.3":{"pli":"Ekāsanadāyikātherīapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"thi-ap14:1.1":{"pli":"“Nagare haṁsavatiyā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"thi-ap14:1.2":{"pli":"ahosiṁ bālikā tadā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:1.3":{"pli":"Mātā ca me pitā ceva, ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:1.4":{"pli":"kammantaṁ agamaṁsu te. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap14:2.1":{"pli":"Majjhanhikamhi sūriye, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap14:2.2":{"pli":"addasaṁ samaṇaṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:2.3":{"pli":"Vīthiyā anugacchantaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:2.4":{"pli":"āsanaṁ paññapesahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap14:3.1":{"pli":"Gonakāvikatikāhi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap14:3.2":{"pli":"paññapetvā mamāsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:3.3":{"pli":"Pasannacittā sumanā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:3.4":{"pli":"idaṁ vacanamabraviṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap14:4.1":{"pli":"‘Santattā kuthitā bhūmi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap14:4.2":{"pli":"sūro majjhanhike ṭhito; ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:4.3":{"pli":"Mālutā ca na vāyanti, ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:4.4":{"pli":"kālo cevettha mehiti. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap14:5.1":{"pli":"Paññattamāsanamidaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap14:5.2":{"pli":"tavatthāya mahāmuni; ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:5.3":{"pli":"Anukampaṁ upādāya, ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:5.4":{"pli":"nisīda mama āsane’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap14:6.1":{"pli":"Nisīdi tattha samaṇo, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap14:6.2":{"pli":"sudanto suddhamānaso; ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:6.3":{"pli":"Tassa pattaṁ gahetvāna, ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:6.4":{"pli":"yathārandhaṁ adāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap14:7.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap14:7.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:7.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:7.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap14:8.1":{"pli":"Tattha me sukataṁ byamhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap14:8.2":{"pli":"āsanena sunimmitaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:8.3":{"pli":"Saṭṭhiyojanamubbedhaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:8.4":{"pli":"tiṁsayojanavitthataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap14:9.1":{"pli":"Soṇṇamayā maṇimayā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap14:9.2":{"pli":"athopi phalikāmayā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:9.3":{"pli":"Lohitaṅgamayā ceva, ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:9.4":{"pli":"pallaṅkā vividhā mama. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap14:10.1":{"pli":"Tūlikāvikatikāhi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap14:10.2":{"pli":"kaṭṭissacittakāhi ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:10.3":{"pli":"Uddaekantalomī ca, ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:10.4":{"pli":"pallaṅkā me susaṇṭhitā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap14:11.1":{"pli":"Yadā icchāmi gamanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap14:11.2":{"pli":"hāsakhiḍḍasamappitā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:11.3":{"pli":"Saha pallaṅkaseṭṭhena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:11.4":{"pli":"gacchāmi mama patthitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap14:12.1":{"pli":"Asīti devarājūnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap14:12.2":{"pli":"mahesittamakārayiṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:12.3":{"pli":"Sattati cakkavattīnaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:12.4":{"pli":"mahesittamakārayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap14:13.1":{"pli":"Bhavābhave saṁsarantī, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap14:13.2":{"pli":"mahābhogaṁ labhāmahaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:13.3":{"pli":"Bhoge me ūnatā natthi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:13.4":{"pli":"ekāsanassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap14:14.1":{"pli":"Duve bhave saṁsarāmi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap14:14.2":{"pli":"devatte atha mānuse; ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:14.3":{"pli":"Aññe bhave na jānāmi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:14.4":{"pli":"ekāsanassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap14:15.1":{"pli":"Duve kule pajāyāmi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap14:15.2":{"pli":"khattiye cāpi brāhmaṇe; ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:15.3":{"pli":"Uccākulīnā sabbattha, ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:15.4":{"pli":"ekāsanassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap14:16.1":{"pli":"Domanassaṁ na jānāmi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap14:16.2":{"pli":"cittasantāpanaṁ mama; ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:16.3":{"pli":"Vevaṇṇiyaṁ na jānāmi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:16.4":{"pli":"ekāsanassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap14:17.1":{"pli":"Dhātiyo maṁ upaṭṭhanti, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap14:17.2":{"pli":"khujjā celāpikā bahū; ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:17.3":{"pli":"Aṅkena aṅkaṁ gacchāmi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:17.4":{"pli":"ekāsanassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap14:18.1":{"pli":"Aññā nhāpenti bhojenti, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap14:18.2":{"pli":"aññā ramenti maṁ sadā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:18.3":{"pli":"Aññā gandhaṁ vilimpanti, ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:18.4":{"pli":"ekāsanassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap14:19.1":{"pli":"Maṇḍape rukkhamūle vā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap14:19.2":{"pli":"suññāgāre vasantiyā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:19.3":{"pli":"Mama saṅkappamaññāya, ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:19.4":{"pli":"pallaṅko upatiṭṭhati. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap14:20.1":{"pli":"Ayaṁ pacchimako mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap14:20.2":{"pli":"carimo vattate bhavo; ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:20.3":{"pli":"Ajjāpi rajjaṁ chaḍḍetvā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:20.4":{"pli":"pabbajiṁ anagāriyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap14:21.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap14:21.2":{"pli":"yaṁ dānamadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:21.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:21.4":{"pli":"ekāsanassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap14:22.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap14:22.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:22.3":{"pli":"viharāmi anāsavā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap14:23.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap14:23.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:23.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap14:24.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap14:24.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap14:24.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"thi-ap14:25.1":{"pli":"Itthaṁ sudaṁ ekāsanadāyikā bhikkhunī imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"thi-ap14:26.1":{"pli":"Ekāsanadāyikātheriyāpadānaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}