{"ja522":{"ja522:0.1":{"pli":"Jātaka ","html":"<article id='ja522'><header><ul><li class='division'>{}</li>"},"ja522:0.2":{"pli":"Cattālīsanipāta ","html":"<li>{}</li>"},"ja522:0.3":{"pli":"Tesakuṇavagga ","html":"<li>{}</li></ul>"},"ja522:0.4":{"pli":"2. Sarabhaṅgajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja522:1.1":{"pli":"“Alaṅkatā kuṇḍalino suvatthā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja522:1.2":{"pli":"Veḷuriyamuttātharukhaggabandhā; ","html":"<span class='verse-line'>{}</span>"},"ja522:1.3":{"pli":"Rathesabhā tiṭṭhatha ke nu tumhe, ","html":"<span class='verse-line'>{}</span>"},"ja522:1.4":{"pli":"Kathaṁ vo jānanti manussaloke”. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:2.1":{"pli":"“Ahamaṭṭhako bhīmaratho panāyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:2.2":{"pli":"Kāliṅgarājā pana uggatoyaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja522:2.3":{"pli":"Susaññatānaṁ isīnaṁ dassanāya, ","html":"<span class='verse-line'>{}</span>"},"ja522:2.4":{"pli":"Idhāgatā pucchitāyemha pañhe”. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:3.1":{"pli":"“Vehāyasaṁ tiṭṭhasi antalikkhe, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:3.2":{"pli":"Pathaddhuno pannaraseva cando; ","html":"<span class='verse-line'>{}</span>"},"ja522:3.3":{"pli":"Pucchāmi taṁ yakkha mahānubhāva, ","html":"<span class='verse-line'>{}</span>"},"ja522:3.4":{"pli":"Kathaṁ taṁ jānanti manussaloke”. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:4.1":{"pli":"“Yamāhu devesu sujampatīti, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:4.2":{"pli":"Maghavāti taṁ āhu manussaloke; ","html":"<span class='verse-line'>{}</span>"},"ja522:4.3":{"pli":"Sa devarājā idamajja patto, ","html":"<span class='verse-line'>{}</span>"},"ja522:4.4":{"pli":"Susaññatānaṁ isīnaṁ dassanāya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:5.1":{"pli":"“Dūre sutā no isayo samāgatā, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:5.2":{"pli":"Mahiddhikā iddhiguṇūpapannā; ","html":"<span class='verse-line'>{}</span>"},"ja522:5.3":{"pli":"Vandāmi te ayire pasannacitto, ","html":"<span class='verse-line'>{}</span>"},"ja522:5.4":{"pli":"Ye jīvalokettha manussaseṭṭhā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:6.1":{"pli":"“Gandho isīnaṁ ciradikkhitānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:6.2":{"pli":"Kāyā cuto gacchati mālutena; ","html":"<span class='verse-line'>{}</span>"},"ja522:6.3":{"pli":"Ito paṭikkamma sahassanetta, ","html":"<span class='verse-line'>{}</span>"},"ja522:6.4":{"pli":"Gandho isīnaṁ asuci devarāja”. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:7.1":{"pli":"“Gandho isīnaṁ ciradikkhitānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:7.2":{"pli":"Kāyā cuto gacchatu mālutena; ","html":"<span class='verse-line'>{}</span>"},"ja522:7.3":{"pli":"Vicitrapupphaṁ surabhiṁva mālaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja522:7.4":{"pli":"Gandhañca etaṁ pāṭikaṅkhāma bhante; ","html":"<span class='verse-line'>{}</span>"},"ja522:7.5":{"pli":"Na hettha devā paṭikkūlasaññino”. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:8.1":{"pli":"“Purindado bhūtapatī yasassī, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:8.2":{"pli":"Devānamindo sakko maghavā sujampati; ","html":"<span class='verse-line'>{}</span>"},"ja522:8.3":{"pli":"Sa devarājā asuragaṇappamaddano, ","html":"<span class='verse-line'>{}</span>"},"ja522:8.4":{"pli":"Okāsamākaṅkhati pañha pucchituṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:9.1":{"pli":"Ko nevimesaṁ idha paṇḍitānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:9.2":{"pli":"Pañhe puṭṭho nipuṇe byākarissati; ","html":"<span class='verse-line'>{}</span>"},"ja522:9.3":{"pli":"Tiṇṇañca raññaṁ manujādhipānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja522:9.4":{"pli":"Devānamindassa ca vāsavassa”. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:10.1":{"pli":"“Ayaṁ isi sarabhaṅgo tapassī, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:10.2":{"pli":"Yato jāto virato methunasmā; ","html":"<span class='verse-line'>{}</span>"},"ja522:10.3":{"pli":"Āceraputto suvinītarūpo, ","html":"<span class='verse-line'>{}</span>"},"ja522:10.4":{"pli":"So nesaṁ pañhāni viyākarissati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:11.1":{"pli":"“Koṇḍañña pañhāni viyākarohi, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:11.2":{"pli":"Yācanti taṁ isayo sādhurūpā; ","html":"<span class='verse-line'>{}</span>"},"ja522:11.3":{"pli":"Koṇḍañña eso manujesu dhammo, ","html":"<span class='verse-line'>{}</span>"},"ja522:11.4":{"pli":"Yaṁ vuddhamāgacchati esa bhāro”. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:12.1":{"pli":"“Katāvakāsā pucchantu bhonto, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:12.2":{"pli":"Yaṁ kiñci pañhaṁ manasābhipatthitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja522:12.3":{"pli":"Ahañhi taṁ taṁ vo viyākarissaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja522:12.4":{"pli":"Ñatvā sayaṁ lokamimaṁ parañca”. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:13.1":{"pli":"Tato ca maghavā sakko, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:13.2":{"pli":"atthadassī purindado; ","html":"<span class='verse-line'>{}</span>"},"ja522:13.3":{"pli":"Apucchi paṭhamaṁ pañhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja522:13.4":{"pli":"yañcāsi abhipatthitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:14.1":{"pli":"“Kiṁ sū vadhitvā na kadāci socati, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:14.2":{"pli":"Kissappahānaṁ isayo vaṇṇayanti; ","html":"<span class='verse-line'>{}</span>"},"ja522:14.3":{"pli":"Kassīdha vuttaṁ pharusaṁ khametha, ","html":"<span class='verse-line'>{}</span>"},"ja522:14.4":{"pli":"Akkhāhi me koṇḍañña etamatthaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:15.1":{"pli":"“Kodhaṁ vadhitvā na kadāci socati, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:15.2":{"pli":"Makkhappahānaṁ isayo vaṇṇayanti; ","html":"<span class='verse-line'>{}</span>"},"ja522:15.3":{"pli":"Sabbesaṁ vuttaṁ pharusaṁ khametha, ","html":"<span class='verse-line'>{}</span>"},"ja522:15.4":{"pli":"Etaṁ khantiṁ uttamamāhu santo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:16.1":{"pli":"“Sakkā ubhinnaṁ vacanaṁ titikkhituṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:16.2":{"pli":"Sadisassa vā seṭṭhatarassa vāpi; ","html":"<span class='verse-line'>{}</span>"},"ja522:16.3":{"pli":"Kathaṁ nu hīnassa vaco khametha, ","html":"<span class='verse-line'>{}</span>"},"ja522:16.4":{"pli":"Akkhāhi me koṇḍañña etamatthaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:17.1":{"pli":"“Bhayā hi seṭṭhassa vaco khametha, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:17.2":{"pli":"Sārambhahetū pana sādisassa; ","html":"<span class='verse-line'>{}</span>"},"ja522:17.3":{"pli":"Yo cīdha hīnassa vaco khametha, ","html":"<span class='verse-line'>{}</span>"},"ja522:17.4":{"pli":"Etaṁ khantiṁ uttamamāhu santo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:18.1":{"pli":"“Kathaṁ vijaññā catupattharūpaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:18.2":{"pli":"Seṭṭhaṁ sarikkhaṁ athavāpi hīnaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja522:18.3":{"pli":"Virūparūpena caranti santo, ","html":"<span class='verse-line'>{}</span>"},"ja522:18.4":{"pli":"Tasmā hi sabbesaṁ vaco khametha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:19.1":{"pli":"“Na hetamatthaṁ mahatīpi senā, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:19.2":{"pli":"Sarājikā yujjhamānā labhetha; ","html":"<span class='verse-line'>{}</span>"},"ja522:19.3":{"pli":"Yaṁ khantimā sappuriso labhetha, ","html":"<span class='verse-line'>{}</span>"},"ja522:19.4":{"pli":"Khantī balassūpasamanti verā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:20.1":{"pli":"“Subhāsitaṁ te anumodiyāna, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:20.2":{"pli":"Aññaṁ taṁ pucchāmi tadiṅgha brūhi; ","html":"<span class='verse-line'>{}</span>"},"ja522:20.3":{"pli":"Yathā ahuṁ daṇḍakī nāḷikero, ","html":"<span class='verse-line'>{}</span>"},"ja522:20.4":{"pli":"Athajjuno kalābu cāpi rājā; ","html":"<span class='verse-line'>{}</span>"},"ja522:20.5":{"pli":"Tesaṁ gatiṁ brūhi supāpakamminaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja522:20.6":{"pli":"Katthūpapannā isinaṁ viheṭhakā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:21.1":{"pli":"“Kisañhi vacchaṁ avakiriya daṇḍakī, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:21.2":{"pli":"Ucchinnamūlo sajano saraṭṭho; ","html":"<span class='verse-line'>{}</span>"},"ja522:21.3":{"pli":"Kukkuḷanāme nirayamhi paccati, ","html":"<span class='verse-line'>{}</span>"},"ja522:21.4":{"pli":"Tassa phuliṅgāni patanti kāye. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:22.1":{"pli":"Yo saññate pabbajite aheṭhayi, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:22.2":{"pli":"Dhammaṁ bhaṇante samaṇe adūsake; ","html":"<span class='verse-line'>{}</span>"},"ja522:22.3":{"pli":"Taṁ nāḷikeraṁ sunakhā parattha, ","html":"<span class='verse-line'>{}</span>"},"ja522:22.4":{"pli":"Saṅgamma khādanti viphandamānaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:23.1":{"pli":"Athajjuno niraye sattisūle, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:23.2":{"pli":"Avaṁsiro patito uddhampādo; ","html":"<span class='verse-line'>{}</span>"},"ja522:23.3":{"pli":"Aṅgīrasaṁ gotamaṁ heṭhayitvā, ","html":"<span class='verse-line'>{}</span>"},"ja522:23.4":{"pli":"Khantiṁ tapassiṁ cirabrahmacāriṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:24.1":{"pli":"Yo khaṇḍaso pabbajitaṁ achedayi, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:24.2":{"pli":"Khantiṁ vadantaṁ samaṇaṁ adūsakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja522:24.3":{"pli":"Kalābuvīciṁ upapajja paccati, ","html":"<span class='verse-line'>{}</span>"},"ja522:24.4":{"pli":"Mahāpatāpaṁ kaṭukaṁ bhayānakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:25.1":{"pli":"Etāni sutvā nirayāni paṇḍito, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:25.2":{"pli":"Aññāni pāpiṭṭhatarāni cettha; ","html":"<span class='verse-line'>{}</span>"},"ja522:25.3":{"pli":"Dhammaṁ care samaṇabrāhmaṇesu, ","html":"<span class='verse-line'>{}</span>"},"ja522:25.4":{"pli":"Evaṅkaro saggamupeti ṭhānaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:26.1":{"pli":"“Subhāsitaṁ te anumodiyāna, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:26.2":{"pli":"Aññaṁ taṁ pucchāmi tadiṅgha brūhi; ","html":"<span class='verse-line'>{}</span>"},"ja522:26.3":{"pli":"Kathaṁvidhaṁ sīlavantaṁ vadanti, ","html":"<span class='verse-line'>{}</span>"},"ja522:26.4":{"pli":"Kathaṁvidhaṁ paññavantaṁ vadanti; ","html":"<span class='verse-line'>{}</span>"},"ja522:26.5":{"pli":"Kathaṁvidhaṁ sappurisaṁ vadanti, ","html":"<span class='verse-line'>{}</span>"},"ja522:26.6":{"pli":"Kathaṁvidhaṁ no siri no jahāti”. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:27.1":{"pli":"“Kāyena vācāya ca yodha saññato, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:27.2":{"pli":"Manasā ca kiñci na karoti pāpaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja522:27.3":{"pli":"Na attahetū alikaṁ bhaṇeti, ","html":"<span class='verse-line'>{}</span>"},"ja522:27.4":{"pli":"Tathāvidhaṁ sīlavantaṁ vadanti. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:28.1":{"pli":"Gambhīrapañhaṁ manasābhicintayaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:28.2":{"pli":"Nāccāhitaṁ kamma karoti luddaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja522:28.3":{"pli":"Kālāgataṁ atthapadaṁ na riñcati, ","html":"<span class='verse-line'>{}</span>"},"ja522:28.4":{"pli":"Tathāvidhaṁ paññavantaṁ vadanti. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:29.1":{"pli":"Yo ve kataññū katavedi dhīro, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:29.2":{"pli":"Kalyāṇamitto daḷhabhatti ca hoti; ","html":"<span class='verse-line'>{}</span>"},"ja522:29.3":{"pli":"Dukhitassa sakkacca karoti kiccaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja522:29.4":{"pli":"Tathāvidhaṁ sappurisaṁ vadanti. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:30.1":{"pli":"Etehi sabbehi guṇehupeto, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:30.2":{"pli":"Saddho mudū saṁvibhāgī vadaññū; ","html":"<span class='verse-line'>{}</span>"},"ja522:30.3":{"pli":"Saṅgāhakaṁ sakhilaṁ saṇhavācaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja522:30.4":{"pli":"Tathāvidhaṁ no siri no jahāti”. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:31.1":{"pli":"“Subhāsitaṁ te anumodiyāna, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:31.2":{"pli":"Aññaṁ taṁ pucchāmi tadiṅgha brūhi; ","html":"<span class='verse-line'>{}</span>"},"ja522:31.3":{"pli":"Sīlaṁ siriñcāpi satañca dhammaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja522:31.4":{"pli":"Paññañca kaṁ seṭṭhataraṁ vadanti”. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:32.1":{"pli":"“Paññā hi seṭṭhā kusalā vadanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:32.2":{"pli":"Nakkhattarājāriva tārakānaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja522:32.3":{"pli":"Sīlaṁ sīrī cāpi satañca dhammo, ","html":"<span class='verse-line'>{}</span>"},"ja522:32.4":{"pli":"Anvāyikā paññavato bhavanti”. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:33.1":{"pli":"“Subhāsitaṁ te anumodiyāna, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:33.2":{"pli":"Aññaṁ taṁ pucchāmi tadiṅgha brūhi; ","html":"<span class='verse-line'>{}</span>"},"ja522:33.3":{"pli":"Kathaṅkaro kintikaro kimācaraṁ, ","html":"<span class='verse-line'>{}</span>"},"ja522:33.4":{"pli":"Kiṁ sevamāno labhatīdha paññaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja522:33.5":{"pli":"Paññāya dāni paṭipadaṁ vadehi, ","html":"<span class='verse-line'>{}</span>"},"ja522:33.6":{"pli":"Kathaṅkaro paññavā hoti macco”. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:34.1":{"pli":"“Sevetha vuddhe nipuṇe bahussute, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:34.2":{"pli":"Uggāhako ca paripucchako siyā; ","html":"<span class='verse-line'>{}</span>"},"ja522:34.3":{"pli":"Suṇeyya sakkacca subhāsitāni, ","html":"<span class='verse-line'>{}</span>"},"ja522:34.4":{"pli":"Evaṅkaro paññavā hoti macco. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:35.1":{"pli":"Sa paññavā kāmaguṇe avekkhati, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:35.2":{"pli":"Aniccato dukkhato rogato ca; ","html":"<span class='verse-line'>{}</span>"},"ja522:35.3":{"pli":"Evaṁ vipassī pajahāti chandaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja522:35.4":{"pli":"Dukkhesu kāmesu mahabbhayesu. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:36.1":{"pli":"Sa vītarāgo pavineyya dosaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:36.2":{"pli":"Mettaṁ cittaṁ bhāvaye appamāṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja522:36.3":{"pli":"Sabbesu bhūtesu nidhāya daṇḍaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja522:36.4":{"pli":"Anindito brahmamupeti ṭhānaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:37.1":{"pli":"“Mahatthiyaṁ āgamanaṁ ahosi, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:37.2":{"pli":"Tavamaṭṭhakā bhīmarathassa cāpi; ","html":"<span class='verse-line'>{}</span>"},"ja522:37.3":{"pli":"Kāliṅgarājassa ca uggatassa, ","html":"<span class='verse-line'>{}</span>"},"ja522:37.4":{"pli":"Sabbesa vo kāmarāgo pahīno”. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:38.1":{"pli":"“Evametaṁ paracittavedi, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:38.2":{"pli":"Sabbesa no kāmarāgo pahīno; ","html":"<span class='verse-line'>{}</span>"},"ja522:38.3":{"pli":"Karohi okāsamanuggahāya, ","html":"<span class='verse-line'>{}</span>"},"ja522:38.4":{"pli":"Yathā gatiṁ te abhisambhavema”. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:39.1":{"pli":"“Karomi okāsamanuggahāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:39.2":{"pli":"Tathā hi vo kāmarāgo pahīno; ","html":"<span class='verse-line'>{}</span>"},"ja522:39.3":{"pli":"Pharātha kāyaṁ vipulāya pītiyā, ","html":"<span class='verse-line'>{}</span>"},"ja522:39.4":{"pli":"Yathā gatiṁ me abhisambhavetha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:40.1":{"pli":"“Sabbaṁ karissāma tavānusāsaniṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:40.2":{"pli":"Yaṁ yaṁ tuvaṁ vakkhasi bhūripañña; ","html":"<span class='verse-line'>{}</span>"},"ja522:40.3":{"pli":"Pharāma kāyaṁ vipulāya pītiyā, ","html":"<span class='verse-line'>{}</span>"},"ja522:40.4":{"pli":"Yathā gatiṁ te abhisambhavema”. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:41.1":{"pli":"“Katāya vacchassa kisassa pūjā, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:41.2":{"pli":"Gacchantu bhonto isayo sādhurūpā; ","html":"<span class='verse-line'>{}</span>"},"ja522:41.3":{"pli":"Jhāne ratā hotha sadā samāhitā, ","html":"<span class='verse-line'>{}</span>"},"ja522:41.4":{"pli":"Esā ratī pabbajitassa seṭṭhā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:42.1":{"pli":"Sutvāna gāthā paramatthasaṁhitā, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:42.2":{"pli":"Subhāsitā isinā paṇḍitena; ","html":"<span class='verse-line'>{}</span>"},"ja522:42.3":{"pli":"Te vedajātā anumodamānā, ","html":"<span class='verse-line'>{}</span>"},"ja522:42.4":{"pli":"Pakkāmu devā devapuraṁ yasassino. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:43.1":{"pli":"Gāthā imā atthavatī subyañjanā, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:43.2":{"pli":"Subhāsitā isinā paṇḍitena; ","html":"<span class='verse-line'>{}</span>"},"ja522:43.3":{"pli":"Yo kocimā aṭṭhikatvā suṇeyya, ","html":"<span class='verse-line'>{}</span>"},"ja522:43.4":{"pli":"Labhetha pubbāpariyaṁ visesaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja522:43.5":{"pli":"Laddhāna pubbāpariyaṁ visesaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja522:43.6":{"pli":"Adassanaṁ maccurājassa gacche. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:44.1":{"pli":"“Sālissaro sāriputto, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:44.2":{"pli":"meṇḍissaro ca kassapo; ","html":"<span class='verse-line'>{}</span>"},"ja522:44.3":{"pli":"Pabbato anuruddho ca, ","html":"<span class='verse-line'>{}</span>"},"ja522:44.4":{"pli":"kaccāyano ca devalo. ","html":"<span class='verse-line'>{}</span></p>"},"ja522:45.1":{"pli":"Anusisso ca ānando, ","html":"<p><span class='verse-line'>{}</span>"},"ja522:45.2":{"pli":"kisavaccho ca kolito; ","html":"<span class='verse-line'>{}</span>"},"ja522:45.3":{"pli":"Nārado udāyitthero, ","html":"<span class='verse-line'>{}</span>"},"ja522:45.4":{"pli":"parisā buddhaparisā; ","html":"<span class='verse-line'>{}</span>"},"ja522:45.5":{"pli":"Sarabhaṅgo lokanātho, ","html":"<span class='verse-line'>{}</span>"},"ja522:45.6":{"pli":"evaṁ dhāretha jātakan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja522:46.1":{"pli":"Sarabhaṅgajātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja523":{"ja523:0.1":{"pli":"Jātaka ","html":"<article id='ja523'><header><ul><li class='division'>{}</li>"},"ja523:0.2":{"pli":"Cattālīsanipāta ","html":"<li>{}</li>"},"ja523:0.3":{"pli":"Tesakuṇavagga ","html":"<li>{}</li></ul>"},"ja523:0.4":{"pli":"3. Alambusājātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja523:1.1":{"pli":"Atha bravi brahā indo, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja523:1.2":{"pli":"vatrabhū jayataṁ pitā; ","html":"<span class='verse-line'>{}</span>"},"ja523:1.3":{"pli":"Devakaññaṁ parābhetvā, ","html":"<span class='verse-line'>{}</span>"},"ja523:1.4":{"pli":"sudhammāyaṁ alambusaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:2.1":{"pli":"“Misse devā taṁ yācanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:2.2":{"pli":"tāvatiṁsā saindakā; ","html":"<span class='verse-line'>{}</span>"},"ja523:2.3":{"pli":"Isippalobhane gaccha, ","html":"<span class='verse-line'>{}</span>"},"ja523:2.4":{"pli":"isisiṅgaṁ alambuse. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:3.1":{"pli":"Purāyaṁ amhe acceti, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:3.2":{"pli":"vattavā brahmacariyavā; ","html":"<span class='verse-line'>{}</span>"},"ja523:3.3":{"pli":"Nibbānābhirato vuddho, ","html":"<span class='verse-line'>{}</span>"},"ja523:3.4":{"pli":"tassa maggāni āvara”. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:4.1":{"pli":"“Devarāja kimeva tvaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:4.2":{"pli":"mameva tuvaṁ sikkhasi; ","html":"<span class='verse-line'>{}</span>"},"ja523:4.3":{"pli":"Isippalobhane gaccha, ","html":"<span class='verse-line'>{}</span>"},"ja523:4.4":{"pli":"santi aññāpi accharā. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:5.1":{"pli":"Mādisiyo pavarā ceva, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:5.2":{"pli":"asoke nandane vane; ","html":"<span class='verse-line'>{}</span>"},"ja523:5.3":{"pli":"Tāsampi hotu pariyāyo, ","html":"<span class='verse-line'>{}</span>"},"ja523:5.4":{"pli":"tāpi yantu palobhanā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:6.1":{"pli":"“Addhā hi saccaṁ bhaṇasi, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:6.2":{"pli":"santi aññāpi accharā; ","html":"<span class='verse-line'>{}</span>"},"ja523:6.3":{"pli":"Tādisiyo pavarā ceva, ","html":"<span class='verse-line'>{}</span>"},"ja523:6.4":{"pli":"asoke nandane vane. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:7.1":{"pli":"Na tā evaṁ pajānanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:7.2":{"pli":"pāricariyaṁ pumaṁ gatā; ","html":"<span class='verse-line'>{}</span>"},"ja523:7.3":{"pli":"Yādisaṁ tvaṁ pajānāsi, ","html":"<span class='verse-line'>{}</span>"},"ja523:7.4":{"pli":"nāri sabbaṅgasobhane. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:8.1":{"pli":"Tvameva gaccha kalyāṇi, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:8.2":{"pli":"itthīnaṁ pavarā casi; ","html":"<span class='verse-line'>{}</span>"},"ja523:8.3":{"pli":"Taveva vaṇṇarūpena, ","html":"<span class='verse-line'>{}</span>"},"ja523:8.4":{"pli":"savasamānayissasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:9.1":{"pli":"“Na vāhaṁ na gamissāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:9.2":{"pli":"devarājena pesitā; ","html":"<span class='verse-line'>{}</span>"},"ja523:9.3":{"pli":"Vibhemi cetaṁ āsāduṁ, ","html":"<span class='verse-line'>{}</span>"},"ja523:9.4":{"pli":"uggatejo hi brāhmaṇo. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:10.1":{"pli":"Aneke nirayaṁ pattā, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:10.2":{"pli":"isimāsādiyā janā; ","html":"<span class='verse-line'>{}</span>"},"ja523:10.3":{"pli":"Āpannā mohasaṁsāraṁ, ","html":"<span class='verse-line'>{}</span>"},"ja523:10.4":{"pli":"tasmā lomāni haṁsaye”. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:11.1":{"pli":"Idaṁ vatvāna pakkāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:11.2":{"pli":"accharā kāmavaṇṇinī; ","html":"<span class='verse-line'>{}</span>"},"ja523:11.3":{"pli":"Missā missitumicchantī, ","html":"<span class='verse-line'>{}</span>"},"ja523:11.4":{"pli":"isisiṅgaṁ alambusā. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:12.1":{"pli":"Sā ca taṁ vanamogayha, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:12.2":{"pli":"isisiṅgena rakkhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja523:12.3":{"pli":"Bimbajālakasañchannaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja523:12.4":{"pli":"samantā addhayojanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:13.1":{"pli":"Pātova pātarāsamhi, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:13.2":{"pli":"udaṇhasamayaṁ pati; ","html":"<span class='verse-line'>{}</span>"},"ja523:13.3":{"pli":"Aggiṭṭhaṁ parimajjantaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja523:13.4":{"pli":"isisiṅgaṁ upāgami. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:14.1":{"pli":"“Kā nu vijjurivābhāsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:14.2":{"pli":"osadhī viya tārakā; ","html":"<span class='verse-line'>{}</span>"},"ja523:14.3":{"pli":"Vicittahatthābharaṇā, ","html":"<span class='verse-line'>{}</span>"},"ja523:14.4":{"pli":"āmuttamaṇikuṇḍalā. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:15.1":{"pli":"Ādiccavaṇṇasaṅkāsā, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:15.2":{"pli":"hemacandanagandhinī; ","html":"<span class='verse-line'>{}</span>"},"ja523:15.3":{"pli":"Saññatūrū mahāmāyā, ","html":"<span class='verse-line'>{}</span>"},"ja523:15.4":{"pli":"kumārī cārudassanā. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:16.1":{"pli":"Vilaggā mudukā suddhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:16.2":{"pli":"pādā te suppatiṭṭhitā; ","html":"<span class='verse-line'>{}</span>"},"ja523:16.3":{"pli":"Gamanā kāmanīyā te, ","html":"<span class='verse-line'>{}</span>"},"ja523:16.4":{"pli":"harantiyeva me mano. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:17.1":{"pli":"Anupubbāva te ūrū, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:17.2":{"pli":"nāganāsasamūpamā; ","html":"<span class='verse-line'>{}</span>"},"ja523:17.3":{"pli":"Vimaṭṭhā tuyhaṁ sussoṇī, ","html":"<span class='verse-line'>{}</span>"},"ja523:17.4":{"pli":"akkhassa phalakaṁ yathā. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:18.1":{"pli":"Uppalasseva kiñjakkhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:18.2":{"pli":"nābhi te sādhu saṇṭhitā; ","html":"<span class='verse-line'>{}</span>"},"ja523:18.3":{"pli":"Pūrā kaṇhañjanasseva, ","html":"<span class='verse-line'>{}</span>"},"ja523:18.4":{"pli":"dūrato paṭidissati. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:19.1":{"pli":"Duvidhā jātā urajā, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:19.2":{"pli":"avaṇṭā sādhupaccudā; ","html":"<span class='verse-line'>{}</span>"},"ja523:19.3":{"pli":"Payodharā apatitā, ","html":"<span class='verse-line'>{}</span>"},"ja523:19.4":{"pli":"aḍḍhalābusamā thanā. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:20.1":{"pli":"Dīghā kambutalābhāsā, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:20.2":{"pli":"gīvā eṇeyyakā yathā; ","html":"<span class='verse-line'>{}</span>"},"ja523:20.3":{"pli":"Paṇḍarāvaraṇā vaggu, ","html":"<span class='verse-line'>{}</span>"},"ja523:20.4":{"pli":"catutthamanasannibhā. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:21.1":{"pli":"Uddhaggā ca adhaggā ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:21.2":{"pli":"dumaggaparimajjitā; ","html":"<span class='verse-line'>{}</span>"},"ja523:21.3":{"pli":"Duvijā nelasambhūtā, ","html":"<span class='verse-line'>{}</span>"},"ja523:21.4":{"pli":"dantā tava sudassanā. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:22.1":{"pli":"Apaṇḍarā lohitantā, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:22.2":{"pli":"jiñjūkaphalasannibhā; ","html":"<span class='verse-line'>{}</span>"},"ja523:22.3":{"pli":"Āyatā ca visālā ca, ","html":"<span class='verse-line'>{}</span>"},"ja523:22.4":{"pli":"nettā tava sudassanā. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:23.1":{"pli":"Nātidīghā susammaṭṭhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:23.2":{"pli":"kanakabyā samocitā; ","html":"<span class='verse-line'>{}</span>"},"ja523:23.3":{"pli":"Uttamaṅgaruhā tuyhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja523:23.4":{"pli":"kesā candanagandhikā. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:24.1":{"pli":"Yāvatā kasigorakkhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:24.2":{"pli":"vāṇijānaṁ ca yā gati; ","html":"<span class='verse-line'>{}</span>"},"ja523:24.3":{"pli":"Isīnañca parakkantaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja523:24.4":{"pli":"saññatānaṁ tapassinaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:25.1":{"pli":"Na te samasamaṁ passe, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:25.2":{"pli":"asmiṁ pathavimaṇḍale; ","html":"<span class='verse-line'>{}</span>"},"ja523:25.3":{"pli":"Ko vā tvaṁ kassa vā putto, ","html":"<span class='verse-line'>{}</span>"},"ja523:25.4":{"pli":"kathaṁ jānemu taṁ mayaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:26.1":{"pli":"“Na pañhakālo bhaddante, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:26.2":{"pli":"kassapevaṁ gate sati; ","html":"<span class='verse-line'>{}</span>"},"ja523:26.3":{"pli":"Ehi samma ramissāma, ","html":"<span class='verse-line'>{}</span>"},"ja523:26.4":{"pli":"ubho asmākamassame; ","html":"<span class='verse-line'>{}</span>"},"ja523:26.5":{"pli":"Ehi taṁ upagūhissaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja523:26.6":{"pli":"ratīnaṁ kusalo bhava”. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:27.1":{"pli":"Idaṁ vatvāna pakkāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:27.2":{"pli":"accharā kāmavaṇṇinī; ","html":"<span class='verse-line'>{}</span>"},"ja523:27.3":{"pli":"Missā missitumicchantī, ","html":"<span class='verse-line'>{}</span>"},"ja523:27.4":{"pli":"isisiṅgaṁ alambusā. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:28.1":{"pli":"So ca vegena nikkhamma, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:28.2":{"pli":"Chetvā dandhaparakkamaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja523:28.3":{"pli":"Tamuttamāsu veṇīsu, ","html":"<span class='verse-line'>{}</span>"},"ja523:28.4":{"pli":"Ajjhappatto parāmasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:29.1":{"pli":"Tamudāvatta kalyāṇī, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:29.2":{"pli":"palissaji susobhanā; ","html":"<span class='verse-line'>{}</span>"},"ja523:29.3":{"pli":"Cavitamhi brahmacariyā, ","html":"<span class='verse-line'>{}</span>"},"ja523:29.4":{"pli":"yathā taṁ atha tositā. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:30.1":{"pli":"Manasā agamā indaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:30.2":{"pli":"vasantaṁ nandane vane; ","html":"<span class='verse-line'>{}</span>"},"ja523:30.3":{"pli":"Tassā saṅkappamaññāya, ","html":"<span class='verse-line'>{}</span>"},"ja523:30.4":{"pli":"maghavā devakuñjaro. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:31.1":{"pli":"Pallaṅkaṁ pahiṇī khippaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:31.2":{"pli":"sovaṇṇaṁ sopavāhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja523:31.3":{"pli":"Sauttaracchadapaññāsaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja523:31.4":{"pli":"sahassapaṭiyatthataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:32.1":{"pli":"Tamenaṁ tattha dhāresi, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:32.2":{"pli":"ure katvāna sobhanā; ","html":"<span class='verse-line'>{}</span>"},"ja523:32.3":{"pli":"Yathā ekamuhuttaṁva, ","html":"<span class='verse-line'>{}</span>"},"ja523:32.4":{"pli":"tīṇi vassāni dhārayi. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:33.1":{"pli":"Vimado tīhi vassehi, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:33.2":{"pli":"pabujjhitvāna brāhmaṇo; ","html":"<span class='verse-line'>{}</span>"},"ja523:33.3":{"pli":"Addasāsi haritarukkhe, ","html":"<span class='verse-line'>{}</span>"},"ja523:33.4":{"pli":"samantā aggiyāyanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:34.1":{"pli":"Navapattavanaṁ phullaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:34.2":{"pli":"kokilaggaṇaghositaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja523:34.3":{"pli":"Samantā paviloketvā, ","html":"<span class='verse-line'>{}</span>"},"ja523:34.4":{"pli":"rudaṁ assūni vattayi. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:35.1":{"pli":"“Na juhe na jape mante, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:35.2":{"pli":"aggihuttaṁ pahāpitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja523:35.3":{"pli":"Ko nu me pāricariyāya, ","html":"<span class='verse-line'>{}</span>"},"ja523:35.4":{"pli":"pubbe cittaṁ palobhayi. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:36.1":{"pli":"Araññe me viharato, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:36.2":{"pli":"yo me tejā ha sambhutaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja523:36.3":{"pli":"Nānāratnaparipūraṁ, ","html":"<span class='verse-line'>{}</span>"},"ja523:36.4":{"pli":"nāvaṁva gaṇhi aṇṇave”. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:37.1":{"pli":"“Ahaṁ te pāricariyāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:37.2":{"pli":"devarājena pesitā; ","html":"<span class='verse-line'>{}</span>"},"ja523:37.3":{"pli":"Avadhiṁ cittaṁ cittena, ","html":"<span class='verse-line'>{}</span>"},"ja523:37.4":{"pli":"pamādo tvaṁ na bujjhasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:38.1":{"pli":"“Imāni kira maṁ tāto, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:38.2":{"pli":"kassapo anusāsati; ","html":"<span class='verse-line'>{}</span>"},"ja523:38.3":{"pli":"Kamalāsadisitthiyo, ","html":"<span class='verse-line'>{}</span>"},"ja523:38.4":{"pli":"tāyo bujjhesi māṇava. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:39.1":{"pli":"Uregaṇḍāyo bujjhesi, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:39.2":{"pli":"tāyo bujjhesi māṇava; ","html":"<span class='verse-line'>{}</span>"},"ja523:39.3":{"pli":"Iccānusāsi maṁ tāto, ","html":"<span class='verse-line'>{}</span>"},"ja523:39.4":{"pli":"yathā maṁ anukampako. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:40.1":{"pli":"Tassāhaṁ vacanaṁ nākaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:40.2":{"pli":"pitu vuddhassa sāsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja523:40.3":{"pli":"Araññe nimmanussamhi, ","html":"<span class='verse-line'>{}</span>"},"ja523:40.4":{"pli":"svajja jhāyāmi ekako. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:41.1":{"pli":"Sohaṁ tathā karissāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:41.2":{"pli":"dhiratthu jīvitena me; ","html":"<span class='verse-line'>{}</span>"},"ja523:41.3":{"pli":"Puna vā tādiso hessaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja523:41.4":{"pli":"maraṇaṁ me bhavissati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:42.1":{"pli":"Tassa tejaṁ vīriyañca, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:42.2":{"pli":"Dhitiṁ ñatvā avaṭṭhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja523:42.3":{"pli":"Sirasā aggahī pāde, ","html":"<span class='verse-line'>{}</span>"},"ja523:42.4":{"pli":"Isisiṅgaṁ alambusā. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:43.1":{"pli":"“Mā me kujjha mahāvīra, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:43.2":{"pli":"mā me kujjha mahāise; ","html":"<span class='verse-line'>{}</span>"},"ja523:43.3":{"pli":"Mahā attho mayā ciṇṇo, ","html":"<span class='verse-line'>{}</span>"},"ja523:43.4":{"pli":"tidasānaṁ yasassinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja523:43.5":{"pli":"Tayā saṅkampitaṁ āsi, ","html":"<span class='verse-line'>{}</span>"},"ja523:43.6":{"pli":"sabbaṁ devapuraṁ tadā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:44.1":{"pli":"“Tāvatiṁsā ca ye devā, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:44.2":{"pli":"tidasānañca vāsavo; ","html":"<span class='verse-line'>{}</span>"},"ja523:44.3":{"pli":"Tvañca bhadde sukhī hohi, ","html":"<span class='verse-line'>{}</span>"},"ja523:44.4":{"pli":"gaccha kaññe yathāsukhaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:45.1":{"pli":"Tassa pāde gahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:45.2":{"pli":"katvā ca naṁ padakkhiṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja523:45.3":{"pli":"Añjaliṁ paggahetvāna, ","html":"<span class='verse-line'>{}</span>"},"ja523:45.4":{"pli":"tamhā ṭhānā apakkami. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:46.1":{"pli":"Yo ca tassāsi pallaṅko, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:46.2":{"pli":"sovaṇṇo sopavāhano; ","html":"<span class='verse-line'>{}</span>"},"ja523:46.3":{"pli":"Sauttaracchadapaññāso, ","html":"<span class='verse-line'>{}</span>"},"ja523:46.4":{"pli":"sahassapaṭiyatthato; ","html":"<span class='verse-line'>{}</span>"},"ja523:46.5":{"pli":"Tameva pallaṅkamāruyha, ","html":"<span class='verse-line'>{}</span>"},"ja523:46.6":{"pli":"agā devāna santike. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:47.1":{"pli":"Tamokkamiva āyantiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:47.2":{"pli":"jalantiṁ vijjutaṁ yathā; ","html":"<span class='verse-line'>{}</span>"},"ja523:47.3":{"pli":"Patīto sumano vitto, ","html":"<span class='verse-line'>{}</span>"},"ja523:47.4":{"pli":"devindo adadā varaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja523:48.1":{"pli":"“Varañce me ado sakka, ","html":"<p><span class='verse-line'>{}</span>"},"ja523:48.2":{"pli":"sabbabhūtānamissara; ","html":"<span class='verse-line'>{}</span>"},"ja523:48.3":{"pli":"Nisippalobhikā gacche, ","html":"<span class='verse-line'>{}</span>"},"ja523:48.4":{"pli":"etaṁ sakka varaṁ vare”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja523:49.1":{"pli":"Alambusājātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}