{"tha-ap424":{"tha-ap424:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap424'><header><ul><li class='division'>{}</li>"},"tha-ap424:0.2":{"pli":"Sakiṁsammajjakavagga ","html":"<li>{}</li></ul>"},"tha-ap424:0.3":{"pli":"Ekadussadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap424:1.1":{"pli":"“Nagare haṁsavatiyā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap424:1.2":{"pli":"ahosiṁ tiṇahārako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:1.3":{"pli":"Tiṇahārena jīvāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:1.4":{"pli":"tena posemi dārake. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap424:2.1":{"pli":"Padumuttaro nāma jino, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap424:2.2":{"pli":"sabbadhammāna pāragū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:2.3":{"pli":"Tamandhakāraṁ nāsetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:2.4":{"pli":"uppajji lokanāyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap424:3.1":{"pli":"Sake ghare nisīditvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap424:3.2":{"pli":"evaṁ cintesi tāvade; ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:3.3":{"pli":"‘Buddho loke samuppanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:3.4":{"pli":"deyyadhammo na vijjati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap424:4.1":{"pli":"Idaṁ me sāṭakaṁ ekaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap424:4.2":{"pli":"natthi me koci dāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:4.3":{"pli":"Dukkho nirayasamphasso, ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:4.4":{"pli":"ropayissāmi dakkhiṇaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap424:5.1":{"pli":"Evāhaṁ cintayitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap424:5.2":{"pli":"sakaṁ cittaṁ pasādayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:5.3":{"pli":"Ekaṁ dussaṁ gahetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:5.4":{"pli":"buddhaseṭṭhassadāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap424:6.1":{"pli":"Ekaṁ dussaṁ daditvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap424:6.2":{"pli":"ukkuṭṭhiṁ sampavattayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:6.3":{"pli":"‘Yadi buddho tuvaṁ vīra, ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:6.4":{"pli":"tārehi maṁ mahāmuni’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap424:7.1":{"pli":"Padumuttaro lokavidū, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap424:7.2":{"pli":"āhutīnaṁ paṭiggaho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:7.3":{"pli":"Mama dānaṁ pakittento, ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:7.4":{"pli":"akā me anumodanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap424:8.1":{"pli":"‘Iminā ekadussena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap424:8.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:8.3":{"pli":"Kappasatasahassāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:8.4":{"pli":"vinipātaṁ na gacchasi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap424:9.1":{"pli":"Chattiṁsakkhattuṁ devindo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap424:9.2":{"pli":"devarajjaṁ karissasi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:9.3":{"pli":"Tettiṁsakkhattuṁ rājā ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:9.4":{"pli":"cakkavattī bhavissasi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap424:10.1":{"pli":"Padesarajjaṁ vipulaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap424:10.2":{"pli":"gaṇanāto asaṅkhiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:10.3":{"pli":"Devaloke manusse vā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:10.4":{"pli":"saṁsaranto tuvaṁ bhave. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap424:11.1":{"pli":"Rūpavā guṇasampanno, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap424:11.2":{"pli":"anavakkantadehavā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:11.3":{"pli":"Akkhobhaṁ amitaṁ dussaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:11.4":{"pli":"labhissasi yadicchakaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap424:12.1":{"pli":"Idaṁ vatvāna sambuddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap424:12.2":{"pli":"jalajuttamanāmako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:12.3":{"pli":"Nabhaṁ abbhuggamī vīro, ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:12.4":{"pli":"haṁsarājāva ambare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap424:13.1":{"pli":"Yaṁ yaṁ yonupapajjāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap424:13.2":{"pli":"devattaṁ atha mānusaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:13.3":{"pli":"Bhoge me ūnatā natthi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:13.4":{"pli":"ekadussassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap424:14.1":{"pli":"Paduddhāre paduddhāre, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap424:14.2":{"pli":"dussaṁ nibbattate mamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:14.3":{"pli":"Heṭṭhā dussamhi tiṭṭhāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:14.4":{"pli":"uparicchadanaṁ mama. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap424:15.1":{"pli":"Cakkavāḷaṁ upādāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap424:15.2":{"pli":"sakānanaṁ sapabbataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:15.3":{"pli":"Icchamāno cahaṁ ajja, ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:15.4":{"pli":"dussehacchādayeyya taṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap424:16.1":{"pli":"Teneva ekadussena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap424:16.2":{"pli":"saṁsaranto bhavābhave; ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:16.3":{"pli":"Suvaṇṇavaṇṇo hutvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:16.4":{"pli":"saṁsarāmi bhavābhave. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap424:17.1":{"pli":"Vipākaṁ ekadussassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap424:17.2":{"pli":"nājjhagaṁ katthacikkhayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:17.3":{"pli":"Ayaṁ me antimā jāti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:17.4":{"pli":"vipaccati idhāpi me. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap424:18.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap424:18.2":{"pli":"yaṁ dussamadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:18.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:18.4":{"pli":"ekadussassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap424:19.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap424:19.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:19.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap424:20.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap424:20.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:20.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap424:21.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap424:21.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap424:21.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap424:22.1":{"pli":"Itthaṁ sudaṁ āyasmā ekadussadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap424:23.1":{"pli":"Ekadussadāyakattherassāpadānaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap425":{"tha-ap425:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap425'><header><ul><li class='division'>{}</li>"},"tha-ap425:0.2":{"pli":"Sakiṁsammajjakavagga ","html":"<li>{}</li></ul>"},"tha-ap425:0.3":{"pli":"Ekāsanadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap425:1.1":{"pli":"“Himavantassāvidūre, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap425:1.2":{"pli":"gosito nāma pabbato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap425:1.3":{"pli":"Assamo sukato mayhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap425:1.4":{"pli":"paṇṇasālā sumāpitā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap425:2.1":{"pli":"Nārado nāma nāmena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap425:2.2":{"pli":"kassapo iti maṁ vidū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap425:2.3":{"pli":"Suddhimaggaṁ gavesanto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap425:2.4":{"pli":"vasāmi gosite tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap425:3.1":{"pli":"Padumuttaro nāma jino, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap425:3.2":{"pli":"sabbadhammāna pāragū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap425:3.3":{"pli":"Vivekakāmo sambuddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap425:3.4":{"pli":"agañchi anilañjasā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap425:4.1":{"pli":"Vanagge gacchamānassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap425:4.2":{"pli":"disvā raṁsiṁ mahesino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap425:4.3":{"pli":"Kaṭṭhamañcaṁ paññāpetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap425:4.4":{"pli":"ajinañca apatthariṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap425:5.1":{"pli":"Āsanaṁ paññapetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap425:5.2":{"pli":"sire katvāna añjaliṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap425:5.3":{"pli":"Somanassaṁ paveditvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap425:5.4":{"pli":"idaṁ vacanamabraviṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap425:6.1":{"pli":"‘Sallakatto mahāvīra, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap425:6.2":{"pli":"āturānaṁ tikicchako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap425:6.3":{"pli":"Mamaṁ rogaparetassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap425:6.4":{"pli":"tikicchaṁ dehi nāyaka. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap425:7.1":{"pli":"Kallatthikā ye passanti, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap425:7.2":{"pli":"buddhaseṭṭha tuvaṁ mune; ","html":"<span class='verse-line'>{}</span>"},"tha-ap425:7.3":{"pli":"Dhuvatthasiddhiṁ papponti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap425:7.4":{"pli":"etesaṁ ajaro bhave. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap425:8.1":{"pli":"Na me deyyadhammo atthi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap425:8.2":{"pli":"pavattaphalabhojihaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap425:8.3":{"pli":"Idaṁ me āsanaṁ atthi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap425:8.4":{"pli":"nisīda kaṭṭhamañcake’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap425:9.1":{"pli":"Nisīdi tattha bhagavā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap425:9.2":{"pli":"asambhītova kesarī; ","html":"<span class='verse-line'>{}</span>"},"tha-ap425:9.3":{"pli":"Muhuttaṁ vītināmetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap425:9.4":{"pli":"idaṁ vacanamabravi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap425:10.1":{"pli":"‘Vissattho hohi mā bhāyi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap425:10.2":{"pli":"laddho jotiraso tayā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap425:10.3":{"pli":"Yaṁ tuyhaṁ patthitaṁ sabbaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap425:10.4":{"pli":"paripūrissatināgate. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap425:11.1":{"pli":"Na moghaṁ taṁ kataṁ tuyhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap425:11.2":{"pli":"puññakkhette anuttare; ","html":"<span class='verse-line'>{}</span>"},"tha-ap425:11.3":{"pli":"Sakkā uddharituṁ attā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap425:11.4":{"pli":"yassa cittaṁ paṇīhitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap425:12.1":{"pli":"Imināsanadānena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap425:12.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap425:12.3":{"pli":"Kappasatasahassāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap425:12.4":{"pli":"vinipātaṁ na gacchasi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap425:13.1":{"pli":"Paññāsakkhattuṁ devindo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap425:13.2":{"pli":"devarajjaṁ karissasi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap425:13.3":{"pli":"Asītikkhattuṁ rājā ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap425:13.4":{"pli":"cakkavattī bhavissasi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap425:14.1":{"pli":"Padesarajjaṁ vipulaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap425:14.2":{"pli":"gaṇanāto asaṅkhiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap425:14.3":{"pli":"Sabbattha sukhito hutvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap425:14.4":{"pli":"saṁsāre saṁsarissasi’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap425:15.1":{"pli":"Idaṁ vatvāna sambud