{"pv1":{"pv1:0.1":{"pli":"Petavatthu ","html":"<article id='pv1'><header><ul><li class='division'>{}</li>"},"pv1:0.2":{"pli":"Uragavagga ","html":"<li>{}</li></ul>"},"pv1:0.3":{"pli":"1. Khettūpamapetavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv1:1.1":{"pli":"Namo tassa Bhagavato Arahato Sammāsambuddhassa. ","html":"<p class='namo'>{}</p>"},"pv1:2.1":{"pli":"“Khettūpamā arahanto, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv1:2.2":{"pli":"dāyakā kassakūpamā; ","html":"<span class='verse-line'>{}</span>"},"pv1:2.3":{"pli":"Bījūpamaṁ deyyadhammaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv1:2.4":{"pli":"etto nibbattate phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv1:3.1":{"pli":"Etaṁ bījaṁ kasi khettaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv1:3.2":{"pli":"petānaṁ dāyakassa ca; ","html":"<span class='verse-line'>{}</span>"},"pv1:3.3":{"pli":"Taṁ petā paribhuñjanti, ","html":"<span class='verse-line'>{}</span>"},"pv1:3.4":{"pli":"dātā puññena vaḍḍhati. ","html":"<span class='verse-line'>{}</span></p>"},"pv1:4.1":{"pli":"Idheva kusalaṁ katvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv1:4.2":{"pli":"Pete ca paṭipūjiya; ","html":"<span class='verse-line'>{}</span>"},"pv1:4.3":{"pli":"Saggañca kamatiṭṭhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv1:4.4":{"pli":"Kammaṁ katvāna bhaddakan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv1:5.1":{"pli":"Khettūpamapetavatthu paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"pv10":{"pv10:0.1":{"pli":"Petavatthu ","html":"<article id='pv10'><header><ul><li class='division'>{}</li>"},"pv10:0.2":{"pli":"Uragavagga ","html":"<li>{}</li></ul>"},"pv10:0.3":{"pli":"10. Khallāṭiyapetivatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv10:1.1":{"pli":"“Kā nu antovimānasmiṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv10:1.2":{"pli":"tiṭṭhantī nūpanikkhami; ","html":"<span class='verse-line'>{}</span>"},"pv10:1.3":{"pli":"Upanikkhamassu bhadde, ","html":"<span class='verse-line'>{}</span>"},"pv10:1.4":{"pli":"passāma taṁ bahiṭṭhitan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv10:2.1":{"pli":"“Aṭṭīyāmi harāyāmi, ","html":"<p><span class='verse-line'>{}</span>"},"pv10:2.2":{"pli":"naggā nikkhamituṁ bahi; ","html":"<span class='verse-line'>{}</span>"},"pv10:2.3":{"pli":"Kesehamhi paṭicchannā, ","html":"<span class='verse-line'>{}</span>"},"pv10:2.4":{"pli":"puññaṁ me appakaṁ katan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv10:3.1":{"pli":"“Handuttarīyaṁ dadāmi te, ","html":"<p><span class='verse-line'>{}</span>"},"pv10:3.2":{"pli":"idaṁ dussaṁ nivāsaya; ","html":"<span class='verse-line'>{}</span>"},"pv10:3.3":{"pli":"Idaṁ dussaṁ nivāsetvā, ","html":"<span class='verse-line'>{}</span>"},"pv10:3.4":{"pli":"ehi nikkhama sobhane; ","html":"<span class='verse-line'>{}</span>"},"pv10:3.5":{"pli":"Upanikkhamassu bhadde, ","html":"<span class='verse-line'>{}</span>"},"pv10:3.6":{"pli":"passāma taṁ bahiṭṭhitan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv10:4.1":{"pli":"“Hatthena hatthe te dinnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv10:4.2":{"pli":"na mayhaṁ upakappati; ","html":"<span class='verse-line'>{}</span>"},"pv10:4.3":{"pli":"Esetthupāsako saddho, ","html":"<span class='verse-line'>{}</span>"},"pv10:4.4":{"pli":"sammāsambuddhasāvako. ","html":"<span class='verse-line'>{}</span></p>"},"pv10:5.1":{"pli":"Etaṁ acchādayitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"pv10:5.2":{"pli":"mama dakkhiṇamādisa; ","html":"<span class='verse-line'>{}</span>"},"pv10:5.3":{"pli":"Tathāhaṁ sukhitā hessaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv10:5.4":{"pli":"sabbakāmasamiddhinī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv10:6.1":{"pli":"Tañca te nhāpayitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"pv10:6.2":{"pli":"vilimpetvāna vāṇijā; ","html":"<span class='verse-line'>{}</span>"},"pv10:6.3":{"pli":"Vatthehacchādayitvāna, ","html":"<span class='verse-line'>{}</span>"},"pv10:6.4":{"pli":"tassā dakkhiṇamādisuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv10:7.1":{"pli":"Samanantarānuddiṭṭhe, ","html":"<p><span class='verse-line'>{}</span>"},"pv10:7.2":{"pli":"vipāko udapajjatha; ","html":"<span class='verse-line'>{}</span>"},"pv10:7.3":{"pli":"Bhojanacchādanapānīyaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv10:7.4":{"pli":"dakkhiṇāya idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv10:8.1":{"pli":"Tato suddhā sucivasanā, ","html":"<p><span class='verse-line'>{}</span>"},"pv10:8.2":{"pli":"kāsikuttamadhārinī; ","html":"<span class='verse-line'>{}</span>"},"pv10:8.3":{"pli":"Hasantī vimānā nikkhami, ","html":"<span class='verse-line'>{}</span>"},"pv10:8.4":{"pli":"dakkhiṇāya idaṁ phalanti. ","html":"<span class='verse-line'>{}</span></p>"},"pv10:9.1":{"pli":"“Sucittarūpaṁ ruciraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv10:9.2":{"pli":"vimānaṁ te pabhāsati; ","html":"<span class='verse-line'>{}</span>"},"pv10:9.3":{"pli":"Devate pucchitācikkha, ","html":"<span class='verse-line'>{}</span>"},"pv10:9.4":{"pli":"kissa kammassidaṁ phalan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv10:10.1":{"pli":"“Bhikkhuno caramānassa, ","html":"<p><span class='verse-line'>{}</span>"},"pv10:10.2":{"pli":"doṇinimmajjaniṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv10:10.3":{"pli":"Adāsiṁ ujubhūtassa, ","html":"<span class='verse-line'>{}</span>"},"pv10:10.4":{"pli":"vippasannena cetasā. ","html":"<span class='verse-line'>{}</span></p>"},"pv10:11.1":{"pli":"Tassa kammassa kusalassa, ","html":"<p><span class='verse-line'>{}</span>"},"pv10:11.2":{"pli":"vipākaṁ dīghamantaraṁ; ","html":"<span class='verse-line'>{}</span>"},"pv10:11.3":{"pli":"Anubhomi vimānasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"pv10:11.4":{"pli":"tañca dāni parittakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv10:12.1":{"pli":"Uddhaṁ catūhi māsehi, ","html":"<p><span class='verse-line'>{}</span>"},"pv10:12.2":{"pli":"kālakiriyā bhavissati; ","html":"<span class='verse-line'>{}</span>"},"pv10:12.3":{"pli":"Ekantakaṭukaṁ ghoraṁ, ","html":"<span class='verse-line'>{}</span>"},"pv10:12.4":{"pli":"nirayaṁ papatissahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv10:13.1":{"pli":"Catukkaṇṇaṁ catudvāraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv10:13.2":{"pli":"vibhattaṁ bhāgaso mitaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv10:13.3":{"pli":"Ayopākārapariyantaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv10:13.4":{"pli":"ayasā paṭikujjitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv10:14.1":{"pli":"Tassa ayomayā bhūmi, ","html":"<p><span class='verse-line'>{}</span>"},"pv10:14.2":{"pli":"jalitā tejasā yutā; ","html":"<span class='verse-line'>{}</span>"},"pv10:14.3":{"pli":"Samantā yojanasataṁ, ","html":"<span class='verse-line'>{}</span>"},"pv10:14.4":{"pli":"pharitvā tiṭṭhati sabbadā. ","html":"<span class='verse-line'>{}</span></p>"},"pv10:15.1":{"pli":"Tatthāhaṁ dīghamaddhānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv10:15.2":{"pli":"dukkhaṁ vedissa vedanaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv10:15.3":{"pli":"Phalañca pāpakammassa, ","html":"<span class='verse-line'>{}</span>"},"pv10:15.4":{"pli":"tasmā socāmahaṁ bhusan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv10:16.1":{"pli":"Khallāṭiyapetivatthu dasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"pv11":{"pv11:0.1":{"pli":"Petavatthu ","html":"<article id='pv11'><header><ul><li class='division'>{}</li>"},"pv11:0.2":{"pli":"Uragavagga ","html":"<li>{}</li></ul>"},"pv11:0.3":{"pli":"11. Nāgapetavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv11:1.1":{"pli":"“Puratova setena paleti hatthinā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv11:1.2":{"pli":"Majjhe pana assatarīrathena; ","html":"<span class='verse-line'>{}</span>"},"pv11:1.3":{"pli":"Pacchā ca kaññā sivikāya nīyati, ","html":"<span class='verse-line'>{}</span>"},"pv11:1.4":{"pli":"Obhāsayantī dasa sabbaso disā. ","html":"<span class='verse-line'>{}</span></p>"},"pv11:2.1":{"pli":"Tumhe pana muggarahatthapāṇino, ","html":"<p><span class='verse-line'>{}</span>"},"pv11:2.2":{"pli":"Rudammukhā chinnapabhinnagattā; ","html":"<span class='verse-line'>{}</span>"},"pv11:2.3":{"pli":"Manussabhūtā kimakattha pāpaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv11:2.4":{"pli":"Yenaññamaññassa pivātha lohitan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv11:3.1":{"pli":"“Puratova yo gacchati kuñjarena, ","html":"<p><span class='verse-line'>{}</span>"},"pv11:3.2":{"pli":"Setena nāgena catukkamena; ","html":"<span class='verse-line'>{}</span>"},"pv11:3.3":{"pli":"Amhāka putto ahu jeṭṭhako so, ","html":"<span class='verse-line'>{}</span>"},"pv11:3.4":{"pli":"Dānāni datvāna sukhī pamodati. ","html":"<span class='verse-line'>{}</span></p>"},"pv11:4.1":{"pli":"Yo so majjhe assatarīrathena, ","html":"<p><span class='verse-line'>{}</span>"},"pv11:4.2":{"pli":"Catubbhi yuttena suvaggitena; ","html":"<span class='verse-line'>{}</span>"},"pv11:4.3":{"pli":"Amhāka putto ahu majjhimo so, ","html":"<span class='verse-line'>{}</span>"},"pv11:4.4":{"pli":"Amaccharī dānavatī virocati. ","html":"<span class='verse-line'>{}</span></p>"},"pv11:5.1":{"pli":"Yā sā ca pacchā sivikāya nīyati, ","html":"<p><span class='verse-line'>{}</span>"},"pv11:5.2":{"pli":"Nārī sapaññā migamandalocanā; ","html":"<span class='verse-line'>{}</span>"},"pv11:5.3":{"pli":"Amhāka dhītā ahu sā kaniṭṭhikā, ","html":"<span class='verse-line'>{}</span>"},"pv11:5.4":{"pli":"Bhāgaḍḍhabhāgena sukhī pamodati. ","html":"<span class='verse-line'>{}</span></p>"},"pv11:6.1":{"pli":"Ete ca dānāni adaṁsu pubbe, ","html":"<p><span class='verse-line'>{}</span>"},"pv11:6.2":{"pli":"Pasannacittā samaṇabrāhmaṇānaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv11:6.3":{"pli":"Mayaṁ pana maccharino ahumha, ","html":"<span class='verse-line'>{}</span>"},"pv11:6.4":{"pli":"Paribhāsakā samaṇabrāhmaṇānaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv11:6.5":{"pli":"Ete ca datvā paricārayanti, ","html":"<span class='verse-line'>{}</span>"},"pv11:6.6":{"pli":"Mayañca sussāma naḷova chinno”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv11:7.1":{"pli":"“Kiṁ tumhākaṁ bhojanaṁ kiṁ sayānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv11:7.2":{"pli":"Kathañca yāpetha supāpadhammino; ","html":"<span class='verse-line'>{}</span>"},"pv11:7.3":{"pli":"Pahūtabhogesu anappakesu, ","html":"<span class='verse-line'>{}</span>"},"pv11:7.4":{"pli":"Sukhaṁ virādhāya dukkhajja pattā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv11:8.1":{"pli":"“Aññamaññaṁ vadhitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"pv11:8.2":{"pli":"pivāma pubbalohitaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv11:8.3":{"pli":"Bahuṁ pitvā na dhātā homa, ","html":"<span class='verse-line'>{}</span>"},"pv11:8.4":{"pli":"nacchādimhase mayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv11:9.1":{"pli":"Icceva maccā paridevayanti, ","html":"<p><span class='verse-line'>{}</span>"},"pv11:9.2":{"pli":"Adāyakā pecca yamassa ṭhāyino; ","html":"<span class='verse-line'>{}</span>"},"pv11:9.3":{"pli":"Ye te vidicca adhigamma bhoge, ","html":"<span class='verse-line'>{}</span>"},"pv11:9.4":{"pli":"Na bhuñjare nāpi karonti puññaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv11:10.1":{"pli":"Te khuppipāsūpagatā parattha, ","html":"<p><span class='verse-line'>{}</span>"},"pv11:10.2":{"pli":"Pacchā ciraṁ jhāyare ḍayhamānā; ","html":"<span class='verse-line'>{}</span>"},"pv11:10.3":{"pli":"Kammāni katvāna dukhudrāni, ","html":"<span class='verse-line'>{}</span>"},"pv11:10.4":{"pli":"Anubhonti dukkhaṁ kaṭukapphalāni. ","html":"<span class='verse-line'>{}</span></p>"},"pv11:11.1":{"pli":"Ittaraṁ hi dhanaṁ dhaññaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv11:11.2":{"pli":"ittaraṁ idha jīvitaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv11:11.3":{"pli":"Ittaraṁ ittarato ñatvā, ","html":"<span class='verse-line'>{}</span>"},"pv11:11.4":{"pli":"dīpaṁ kayirātha paṇḍito. ","html":"<span class='verse-line'>{}</span></p>"},"pv11:12.1":{"pli":"Ye te evaṁ pajānanti, ","html":"<p><span class='verse-line'>{}</span>"},"pv11:12.2":{"pli":"narā dhammassa kovidā; ","html":"<span class='verse-line'>{}</span>"},"pv11:12.3":{"pli":"Te dāne nappamajjanti, ","html":"<span class='verse-line'>{}</span>"},"pv11:12.4":{"pli":"sutvā arahataṁ vaco”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv11:13.1":{"pli":"Nāgapetavatthu ekādasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"pv12":{"pv12:0.1":{"pli":"Petavatthu ","html":"<article id='pv12'><header><ul><li class='division'>{}</li>"},"pv12:0.2":{"pli":"Uragavagga ","html":"<li>{}</li></ul>"},"pv12:0.3":{"pli":"12. Uragapetavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv12:1.1":{"pli":"“Uragova tacaṁ jiṇṇaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv12:1.2":{"pli":"hitvā gacchati saṁ tanuṁ; ","html":"<span class='verse-line'>{}</span>"},"pv12:1.3":{"pli":"Evaṁ sarīre nibbhoge, ","html":"<span class='verse-line'>{}</span>"},"pv12:1.4":{"pli":"pete kālaṅkate sati. ","html":"<span class='verse-line'>{}</span></p>"},"pv12:2.1":{"pli":"Ḍayhamāno na jānāti, ","html":"<p><span class='verse-line'>{}</span>"},"pv12:2.2":{"pli":"ñātīnaṁ paridevitaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv12:2.3":{"pli":"Tasmā etaṁ na rodāmi, ","html":"<span class='verse-line'>{}</span>"},"pv12:2.4":{"pli":"gato so tassa yā gati”. ","html":"<span class='verse-line'>{}</span></p>"},"pv12:3.1":{"pli":"“Anabbhito tato āgā, ","html":"<p><span class='verse-line'>{}</span>"},"pv12:3.2":{"pli":"nānuññāto ito gato; ","html":"<span class='verse-line'>{}</span>"},"pv12:3.3":{"pli":"Yathāgato tathā gato, ","html":"<span class='verse-line'>{}</span>"},"pv12:3.4":{"pli":"tattha kā paridevanā. ","html":"<span class='verse-line'>{}</span></p>"},"pv12:4.1":{"pli":"Ḍayhamāno na jānāti, ","html":"<p><span class='verse-line'>{}</span>"},"pv12:4.2":{"pli":"ñātīnaṁ paridevitaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv12:4.3":{"pli":"Tasmā etaṁ na rodāmi, ","html":"<span class='verse-line'>{}</span>"},"pv12:4.4":{"pli":"gato so tassa yā gati”. ","html":"<span class='verse-line'>{}</span></p>"},"pv12:5.1":{"pli":"“Sace rode kisā assaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv12:5.2":{"pli":"tattha me kiṁ phalaṁ siyā; ","html":"<span class='verse-line'>{}</span>"},"pv12:5.3":{"pli":"Ñātimittasuhajjānaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv12:5.4":{"pli":"bhiyyo no aratī siyā. ","html":"<span class='verse-line'>{}</span></p>"},"pv12:6.1":{"pli":"Ḍayhamāno na jānāti, ","html":"<p><span class='verse-line'>{}</span>"},"pv12:6.2":{"pli":"ñātīnaṁ paridevitaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv12:6.3":{"pli":"Tasmā etaṁ na rodāmi, ","html":"<span class='verse-line'>{}</span>"},"pv12:6.4":{"pli":"gato so tassa yā gati”. ","html":"<span class='verse-line'>{}</span></p>"},"pv12:7.1":{"pli":"“Yathāpi dārako candaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv12:7.2":{"pli":"gacchantamanurodati; ","html":"<span class='verse-line'>{}</span>"},"pv12:7.3":{"pli":"Evaṁ sampadamevetaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv12:7.4":{"pli":"yo petamanusocati. ","html":"<span class='verse-line'>{}</span></p>"},"pv12:8.1":{"pli":"Ḍayhamāno na jānāti, ","html":"<p><span class='verse-line'>{}</span>"},"pv12:8.2":{"pli":"ñātīnaṁ paridevitaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv12:8.3":{"pli":"Tasmā etaṁ na rodāmi, ","html":"<span class='verse-line'>{}</span>"},"pv12:8.4":{"pli":"gato so tassa yā gati”. ","html":"<span class='verse-line'>{}</span></p>"},"pv12:9.1":{"pli":"“Yathāpi brahme udakumbho, ","html":"<p><span class='verse-line'>{}</span>"},"pv12:9.2":{"pli":"bhinno appaṭisandhiyo; ","html":"<span class='verse-line'>{}</span>"},"pv12:9.3":{"pli":"Evaṁ sampadamevetaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv12:9.4":{"pli":"yo petamanusocati. ","html":"<span class='verse-line'>{}</span></p>"},"pv12:10.1":{"pli":"Ḍayhamāno na jānāti, ","html":"<p><span class='verse-line'>{}</span>"},"pv12:10.2":{"pli":"ñātīnaṁ paridevitaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv12:10.3":{"pli":"Tasmā etaṁ na rodāmi, ","html":"<span class='verse-line'>{}</span>"},"pv12:10.4":{"pli":"gato so tassa yā gatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv12:11.1":{"pli":"Uragapetavatthu dvādasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"pv12:12.1":{"pli":"Uragavaggo paṭhamo. ","html":"<p class='endsection'>{}</p>"},"pv12:13.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"pv12:14.1":{"pli":"Khettañca sūkaraṁ pūti, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"pv12:14.2":{"pli":"piṭṭhaṁ cāpi tirokuṭṭaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv12:14.3":{"pli":"Pañcāpi sattaputtañca, ","html":"<span class='verse-line'>{}</span>"},"pv12:14.4":{"pli":"goṇaṁ pesakārakañca; ","html":"<span class='verse-line'>{}</span>"},"pv12:14.5":{"pli":"Tathā khallāṭiyaṁ nāgaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv12:14.6":{"pli":"dvādasaṁ uragañcevāti. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"pv13":{"pv13:0.1":{"pli":"Petavatthu ","html":"<article id='pv13'><header><ul><li class='division'>{}</li>"},"pv13:0.2":{"pli":"Ubbarivagga ","html":"<li>{}</li></ul>"},"pv13:0.3":{"pli":"1. Saṁsāramocakapetivatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv13:1.1":{"pli":"“Naggā dubbaṇṇarūpāsi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv13:1.2":{"pli":"kisā dhamanisanthatā; ","html":"<span class='verse-line'>{}</span>"},"pv13:1.3":{"pli":"Upphāsulike kisike, ","html":"<span class='verse-line'>{}</span>"},"pv13:1.4":{"pli":"kā nu tvaṁ idha tiṭṭhasī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv13:2.1":{"pli":"“Ahaṁ bhadante petīmhi, ","html":"<p><span class='verse-line'>{}</span>"},"pv13:2.2":{"pli":"duggatā yamalokikā; ","html":"<span class='verse-line'>{}</span>"},"pv13:2.3":{"pli":"Pāpakammaṁ karitvāna, ","html":"<span class='verse-line'>{}</span>"},"pv13:2.4":{"pli":"petalokaṁ ito gatā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv13:3.1":{"pli":"“Kiṁ nu kāyena vācāya, ","html":"<p><span class='verse-line'>{}</span>"},"pv13:3.2":{"pli":"manasā dukkaṭaṁ kataṁ; ","html":"<span class='verse-line'>{}</span>"},"pv13:3.3":{"pli":"Kissa kammavipākena, ","html":"<span class='verse-line'>{}</span>"},"pv13:3.4":{"pli":"petalokaṁ ito gatā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv13:4.1":{"pli":"“Anukampakā mayhaṁ nāhesuṁ bhante, ","html":"<p><span class='verse-line'>{}</span>"},"pv13:4.2":{"pli":"Pitā ca mātā athavāpi ñātakā; ","html":"<span class='verse-line'>{}</span>"},"pv13:4.3":{"pli":"Ye maṁ niyojeyyuṁ dadāhi dānaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv13:4.4":{"pli":"Pasannacittā samaṇabrāhmaṇānaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv13:5.1":{"pli":"Ito ahaṁ vassasatāni pañca, ","html":"<p><span class='verse-line'>{}</span>"},"pv13:5.2":{"pli":"Yaṁ evarūpā vicarāmi naggā; ","html":"<span class='verse-line'>{}</span>"},"pv13:5.3":{"pli":"Khudāya taṇhāya ca khajjamānā, ","html":"<span class='verse-line'>{}</span>"},"pv13:5.4":{"pli":"Pāpassa kammassa phalaṁ mamedaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv13:6.1":{"pli":"Vandāmi taṁ ayya pasannacittā, ","html":"<p><span class='verse-line'>{}</span>"},"pv13:6.2":{"pli":"Anukampa maṁ vīra mahānubhāva; ","html":"<span class='verse-line'>{}</span>"},"pv13:6.3":{"pli":"Datvā ca me ādisa yaṁ hi kiñci, ","html":"<span class='verse-line'>{}</span>"},"pv13:6.4":{"pli":"Mocehi maṁ duggatiyā bhadante”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv13:7.1":{"pli":"Sādhūti so paṭissutvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv13:7.2":{"pli":"sāriputtonukampako; ","html":"<span class='verse-line'>{}</span>"},"pv13:7.3":{"pli":"Bhikkhūnaṁ ālopaṁ datvā, ","html":"<span class='verse-line'>{}</span>"},"pv13:7.4":{"pli":"pāṇimattañca coḷakaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv13:7.5":{"pli":"Thālakassa ca pānīyaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv13:7.6":{"pli":"tassā dakkhiṇamādisi. ","html":"<span class='verse-line'>{}</span></p>"},"pv13:8.1":{"pli":"Samanantarānuddiṭṭhe, ","html":"<p><span class='verse-line'>{}</span>"},"pv13:8.2":{"pli":"vipāko udapajjatha; ","html":"<span class='verse-line'>{}</span>"},"pv13:8.3":{"pli":"Bhojanacchādanapānīyaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv13:8.4":{"pli":"dakkhiṇāya idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv13:9.1":{"pli":"Tato suddhā sucivasanā, ","html":"<p><span class='verse-line'>{}</span>"},"pv13:9.2":{"pli":"kāsikuttamadhārinī; ","html":"<span class='verse-line'>{}</span>"},"pv13:9.3":{"pli":"Vicittavatthābharaṇā, ","html":"<span class='verse-line'>{}</span>"},"pv13:9.4":{"pli":"sāriputtaṁ upasaṅkami. ","html":"<span class='verse-line'>{}</span></p>"},"pv13:10.1":{"pli":"“Abhikkantena vaṇṇena, ","html":"<p><span class='verse-line'>{}</span>"},"pv13:10.2":{"pli":"yā tvaṁ tiṭṭhasi devate; ","html":"<span class='verse-line'>{}</span>"},"pv13:10.3":{"pli":"Obhāsentī disā sabbā, ","html":"<span class='verse-line'>{}</span>"},"pv13:10.4":{"pli":"osadhī viya tārakā. ","html":"<span class='verse-line'>{}</span></p>"},"pv13:11.1":{"pli":"Kena te tādiso vaṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"pv13:11.2":{"pli":"kena te idha mijjhati; ","html":"<span class='verse-line'>{}</span>"},"pv13:11.3":{"pli":"Uppajjanti ca te bhogā, ","html":"<span class='verse-line'>{}</span>"},"pv13:11.4":{"pli":"ye keci manaso piyā. ","html":"<span class='verse-line'>{}</span></p>"},"pv13:12.1":{"pli":"Pucchāmi taṁ devi mahānubhāve, ","html":"<p><span class='verse-line'>{}</span>"},"pv13:12.2":{"pli":"Manussabhūtā kimakāsi puññaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv13:12.3":{"pli":"Kenāsi evaṁ jalitānubhāvā, ","html":"<span class='verse-line'>{}</span>"},"pv13:12.4":{"pli":"Vaṇṇo ca te sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv13:13.1":{"pli":"“Uppaṇḍukiṁ kisaṁ chātaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv13:13.2":{"pli":"naggaṁ sampatitacchaviṁ; ","html":"<span class='verse-line'>{}</span>"},"pv13:13.3":{"pli":"Muni kāruṇiko loke, ","html":"<span class='verse-line'>{}</span>"},"pv13:13.4":{"pli":"taṁ maṁ addakkhi duggataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv13:14.1":{"pli":"Bhikkhūnaṁ ālopaṁ datvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv13:14.2":{"pli":"pāṇimattañca coḷakaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv13:14.3":{"pli":"Thālakassa ca pānīyaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv13:14.4":{"pli":"mama dakkhiṇamādisi. ","html":"<span class='verse-line'>{}</span></p>"},"pv13:15.1":{"pli":"Ālopassa phalaṁ passa, ","html":"<p><span class='verse-line'>{}</span>"},"pv13:15.2":{"pli":"bhattaṁ vassasataṁ dasa; ","html":"<span class='verse-line'>{}</span>"},"pv13:15.3":{"pli":"Bhuñjāmi kāmakāminī, ","html":"<span class='verse-line'>{}</span>"},"pv13:15.4":{"pli":"anekarasabyañjanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv13:16.1":{"pli":"Pāṇimattassa coḷassa, ","html":"<p><span class='verse-line'>{}</span>"},"pv13:16.2":{"pli":"vipākaṁ passa yādisaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv13:16.3":{"pli":"Yāvatā nandarājassa, ","html":"<span class='verse-line'>{}</span>"},"pv13:16.4":{"pli":"vijitasmiṁ paṭicchadā. ","html":"<span class='verse-line'>{}</span></p>"},"pv13:17.1":{"pli":"Tato bahutarā bhante, ","html":"<p><span class='verse-line'>{}</span>"},"pv13:17.2":{"pli":"vatthānacchādanāni me; ","html":"<span class='verse-line'>{}</span>"},"pv13:17.3":{"pli":"Koseyyakambalīyāni, ","html":"<span class='verse-line'>{}</span>"},"pv13:17.4":{"pli":"khomakappāsikāni ca. ","html":"<span class='verse-line'>{}</span></p>"},"pv13:18.1":{"pli":"Vipulā ca mahagghā ca, ","html":"<p><span class='verse-line'>{}</span>"},"pv13:18.2":{"pli":"tepākāsevalambare; ","html":"<span class='verse-line'>{}</span>"},"pv13:18.3":{"pli":"Sāhaṁ taṁ paridahāmi, ","html":"<span class='verse-line'>{}</span>"},"pv13:18.4":{"pli":"yaṁ yaṁ hi manaso piyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv13:19.1":{"pli":"Thālakassa ca pānīyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv13:19.2":{"pli":"vipākaṁ passa yādisaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv13:19.3":{"pli":"Gambhīrā caturassā ca, ","html":"<span class='verse-line'>{}</span>"},"pv13:19.4":{"pli":"pokkharañño sunimmitā. ","html":"<span class='verse-line'>{}</span></p>"},"pv13:20.1":{"pli":"Setodakā suppatitthā, ","html":"<p><span class='verse-line'>{}</span>"},"pv13:20.2":{"pli":"sītā appaṭigandhiyā; ","html":"<span class='verse-line'>{}</span>"},"pv13:20.3":{"pli":"Padumuppalasañchannā, ","html":"<span class='verse-line'>{}</span>"},"pv13:20.4":{"pli":"vārikiñjakkhapūritā. ","html":"<span class='verse-line'>{}</span></p>"},"pv13:21.1":{"pli":"Sāhaṁ ramāmi kīḷāmi, ","html":"<p><span class='verse-line'>{}</span>"},"pv13:21.2":{"pli":"modāmi akutobhayā; ","html":"<span class='verse-line'>{}</span>"},"pv13:21.3":{"pli":"Muniṁ kāruṇikaṁ loke, ","html":"<span class='verse-line'>{}</span>"},"pv13:21.4":{"pli":"bhante vanditumāgatā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv13:22.1":{"pli":"Saṁsāramocakapetivatthu paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"pv14":{"pv14:0.1":{"pli":"Petavatthu ","html":"<article id='pv14'><header><ul><li class='division'>{}</li>"},"pv14:0.2":{"pli":"Ubbarivagga ","html":"<li>{}</li></ul>"},"pv14:0.3":{"pli":"2. Sāriputtattheramātupetivatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv14:1.1":{"pli":"“Naggā dubbaṇṇarūpāsi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv14:1.2":{"pli":"kisā dhamanisanthatā; ","html":"<span class='verse-line'>{}</span>"},"pv14:1.3":{"pli":"Upphāsulike kisike, ","html":"<span class='verse-line'>{}</span>"},"pv14:1.4":{"pli":"kā nu tvaṁ idha tiṭṭhasi”. ","html":"<span class='verse-line'>{}</span></p>"},"pv14:2.1":{"pli":"“Ahaṁ te sakiyā mātā, ","html":"<p><span class='verse-line'>{}</span>"},"pv14:2.2":{"pli":"pubbe aññāsu jātīsu; ","html":"<span class='verse-line'>{}</span>"},"pv14:2.3":{"pli":"Upapannā pettivisayaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv14:2.4":{"pli":"khuppipāsasamappitā. ","html":"<span class='verse-line'>{}</span></p>"},"pv14:3.1":{"pli":"Chaḍḍitaṁ khipitaṁ kheḷaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv14:3.2":{"pli":"siṅghāṇikaṁ silesumaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv14:3.3":{"pli":"Vasañca ḍayhamānānaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv14:3.4":{"pli":"vijātānañca lohitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv14:4.1":{"pli":"Vaṇikānañca yaṁ ghāna- ","html":"<p><span class='verse-line'>{}</span>"},"pv14:4.2":{"pli":"sīsacchinnāna lohitaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv14:4.3":{"pli":"Khudāparetā bhuñjāmi, ","html":"<span class='verse-line'>{}</span>"},"pv14:4.4":{"pli":"itthipurisanissitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv14:5.1":{"pli":"Pubbalohitaṁ bhakkhāmi, ","html":"<p><span class='verse-line'>{}</span>"},"pv14:5.2":{"pli":"pasūnaṁ mānusāna ca; ","html":"<span class='verse-line'>{}</span>"},"pv14:5.3":{"pli":"Aleṇā anagārā ca, ","html":"<span class='verse-line'>{}</span>"},"pv14:5.4":{"pli":"nīlamañcaparāyaṇā. ","html":"<span class='verse-line'>{}</span></p>"},"pv14:6.1":{"pli":"Dehi puttaka me dānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv14:6.2":{"pli":"datvā anvādisāhi me; ","html":"<span class='verse-line'>{}</span>"},"pv14:6.3":{"pli":"Appeva nāma mucceyyaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv14:6.4":{"pli":"pubbalohitabhojanā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv14:7.1":{"pli":"Mātuyā vacanaṁ sutvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv14:7.2":{"pli":"upatissonukampako; ","html":"<span class='verse-line'>{}</span>"},"pv14:7.3":{"pli":"Āmantayi moggallānaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv14:7.4":{"pli":"anuruddhañca kappinaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv14:8.1":{"pli":"Catasso kuṭiyo katvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv14:8.2":{"pli":"saṅghe cātuddise adā; ","html":"<span class='verse-line'>{}</span>"},"pv14:8.3":{"pli":"Kuṭiyo annapānañca, ","html":"<span class='verse-line'>{}</span>"},"pv14:8.4":{"pli":"mātu dakkhiṇamādisī. ","html":"<span class='verse-line'>{}</span></p>"},"pv14:9.1":{"pli":"Samanantarānuddiṭṭhe, ","html":"<p><span class='verse-line'>{}</span>"},"pv14:9.2":{"pli":"vipāko udapajjatha; ","html":"<span class='verse-line'>{}</span>"},"pv14:9.3":{"pli":"Bhojanaṁ pānīyaṁ vatthaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv14:9.4":{"pli":"dakkhiṇāya idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv14:10.1":{"pli":"Tato suddhā sucivasanā, ","html":"<p><span class='verse-line'>{}</span>"},"pv14:10.2":{"pli":"kāsikuttamadhārinī; ","html":"<span class='verse-line'>{}</span>"},"pv14:10.3":{"pli":"Vicittavatthābharaṇā, ","html":"<span class='verse-line'>{}</span>"},"pv14:10.4":{"pli":"kolitaṁ upasaṅkami. ","html":"<span class='verse-line'>{}</span></p>"},"pv14:11.1":{"pli":"“Abhikkantena vaṇṇena, ","html":"<p><span class='verse-line'>{}</span>"},"pv14:11.2":{"pli":"yā tvaṁ tiṭṭhasi devate; ","html":"<span class='verse-line'>{}</span>"},"pv14:11.3":{"pli":"Obhāsentī disā sabbā, ","html":"<span class='verse-line'>{}</span>"},"pv14:11.4":{"pli":"osadhī viya tārakā. ","html":"<span class='verse-line'>{}</span></p>"},"pv14:12.1":{"pli":"Kena tetādiso vaṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"pv14:12.2":{"pli":"kena te idha mijjhati; ","html":"<span class='verse-line'>{}</span>"},"pv14:12.3":{"pli":"Uppajjanti ca te bhogā, ","html":"<span class='verse-line'>{}</span>"},"pv14:12.4":{"pli":"ye keci manaso piyā. ","html":"<span class='verse-line'>{}</span></p>"},"pv14:13.1":{"pli":"Pucchāmi taṁ devi mahānubhāve, ","html":"<p><span class='verse-line'>{}</span>"},"pv14:13.2":{"pli":"Manussabhūtā kimakāsi puññaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv14:13.3":{"pli":"Kenāsi evaṁ jalitānubhāvā, ","html":"<span class='verse-line'>{}</span>"},"pv14:13.4":{"pli":"Vaṇṇo ca te sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv14:14.1":{"pli":"“Sāriputtassāhaṁ mātā, ","html":"<p><span class='verse-line'>{}</span>"},"pv14:14.2":{"pli":"pubbe aññāsu jātīsu; ","html":"<span class='verse-line'>{}</span>"},"pv14:14.3":{"pli":"Upapannā pettivisayaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv14:14.4":{"pli":"khuppipāsasamappitā. ","html":"<span class='verse-line'>{}</span></p>"},"pv14:15.1":{"pli":"Chaḍḍitaṁ khipitaṁ kheḷaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv14:15.2":{"pli":"siṅghāṇikaṁ silesumaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv14:15.3":{"pli":"Vasañca ḍayhamānānaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv14:15.4":{"pli":"vijātānañca lohitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv14:16.1":{"pli":"Vaṇikānañca yaṁ ghāna- ","html":"<p><span class='verse-line'>{}</span>"},"pv14:16.2":{"pli":"sīsacchinnāna lohitaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv14:16.3":{"pli":"Khudāparetā bhuñjāmi, ","html":"<span class='verse-line'>{}</span>"},"pv14:16.4":{"pli":"itthipurisanissitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv14:17.1":{"pli":"Pubbalohitaṁ bhakkhissaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv14:17.2":{"pli":"pasūnaṁ mānusāna ca; ","html":"<span class='verse-line'>{}</span>"},"pv14:17.3":{"pli":"Aleṇā anagārā ca, ","html":"<span class='verse-line'>{}</span>"},"pv14:17.4":{"pli":"nīlamañcaparāyaṇā. ","html":"<span class='verse-line'>{}</span></p>"},"pv14:18.1":{"pli":"Sāriputtassa dānena, ","html":"<p><span class='verse-line'>{}</span>"},"pv14:18.2":{"pli":"modāmi akutobhayā; ","html":"<span class='verse-line'>{}</span>"},"pv14:18.3":{"pli":"Muniṁ kāruṇikaṁ loke, ","html":"<span class='verse-line'>{}</span>"},"pv14:18.4":{"pli":"bhante vanditumāgatā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv14:19.1":{"pli":"Sāriputtattherassa mātupetivatthu dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}