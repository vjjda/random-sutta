"pli":"Kathāvatthu ","html":"<article id='kv19.1'><header><ul><li class='division'>{}</li>"},"kv19.1:0.2":{"pli":"Niggahapaṇṇāsaka ","html":"<li>{}</li>"},"kv19.1:0.3":{"pli":"Ekūnavīsatimavagga ","html":"<li>{}</li></ul>"},"kv19.1:0.4":{"pli":"Kilesajahanakathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv19.1:1.1":{"pli":"Atīte kilese jahatīti? ","html":"<p data-doxy='orthodox'>{}"},"kv19.1:1.2":{"pli":"Āmantā. ","html":"{}"},"kv19.1:1.3":{"pli":"Niruddhaṁ nirodheti, vigataṁ vigameti, khīṇaṁ khepeti, atthaṅgataṁ atthaṅgameti, abbhatthaṅgataṁ abbhatthaṅgametīti? ","html":"{}"},"kv19.1:1.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv19.1:1.5":{"pli":"atīte kilese jahatīti? ","html":"{}"},"kv19.1:1.6":{"pli":"Āmantā. ","html":"{}"},"kv19.1:1.7":{"pli":"Nanu atītaṁ niruddhanti? ","html":"{}"},"kv19.1:1.8":{"pli":"Āmantā. ","html":"{}"},"kv19.1:1.9":{"pli":"Hañci atītaṁ niruddhaṁ, no ca vata re vattabbe—","html":"{}"},"kv19.1:1.10":{"pli":"“atīte kilese jahatī”ti. ","html":"{}"},"kv19.1:1.11":{"pli":"Atīte kilese jahatīti? ","html":"{}"},"kv19.1:1.12":{"pli":"Āmantā. ","html":"{}"},"kv19.1:1.13":{"pli":"Nanu atītaṁ natthīti? ","html":"{}"},"kv19.1:1.14":{"pli":"Āmantā. ","html":"{}"},"kv19.1:1.15":{"pli":"Hañci atītaṁ natthi, no ca vata re vattabbe—","html":"{}"},"kv19.1:1.16":{"pli":"“atīte kilese jahatī”ti. ","html":"{}</p>"},"kv19.1:2.1":{"pli":"Anāgate kilese jahatīti? ","html":"<p data-doxy='orthodox'>{}"},"kv19.1:2.2":{"pli":"Āmantā. ","html":"{}"},"kv19.1:2.3":{"pli":"Ajātaṁ ajaneti, asañjātaṁ asañjaneti, anibbattaṁ anibbatteti, apātubhūtaṁ apātubhāvetīti? ","html":"{}"},"kv19.1:2.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv19.1:2.5":{"pli":"anāgate kilese jahatīti? ","html":"{}"},"kv19.1:2.6":{"pli":"Āmantā. ","html":"{}"},"kv19.1:2.7":{"pli":"Nanu anāgataṁ ajātanti? ","html":"{}"},"kv19.1:2.8":{"pli":"Āmantā. ","html":"{}"},"kv19.1:2.9":{"pli":"Hañci anāgataṁ ajātaṁ, no ca vata re vattabbe—","html":"{}"},"kv19.1:2.10":{"pli":"“anāgate kilese jahatī”ti. ","html":"{}"},"kv19.1:2.11":{"pli":"Anāgate kilese jahatīti? ","html":"{}"},"kv19.1:2.12":{"pli":"Āmantā. ","html":"{}"},"kv19.1:2.13":{"pli":"Nanu anāgataṁ natthīti? ","html":"{}"},"kv19.1:2.14":{"pli":"Āmantā. ","html":"{}"},"kv19.1:2.15":{"pli":"Hañci anāgataṁ natthi, no ca vata re vattabbe—","html":"{}"},"kv19.1:2.16":{"pli":"“anāgate kilese jahatī”ti. ","html":"{}</p>"},"kv19.1:3.1":{"pli":"Paccuppanne kilese jahatīti? ","html":"<p data-doxy='orthodox'>{}"},"kv19.1:3.2":{"pli":"Āmantā. ","html":"{}"},"kv19.1:3.3":{"pli":"Ratto rāgaṁ jahati, duṭṭho dosaṁ jahati, mūḷho mohaṁ jahati, kiliṭṭho kilese jahatīti? ","html":"{}"},"kv19.1:3.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv19.1:3.5":{"pli":"rāgena rāgaṁ jahati, dosena dosaṁ jahati, mohena mohaṁ jahati, kilesehi kilese jahatīti? ","html":"{}"},"kv19.1:3.6":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}</p>"},"kv19.1:4.1":{"pli":"Rāgo cittasampayutto, maggo cittasampayuttoti? ","html":"<p data-doxy='orthodox'>{}"},"kv19.1:4.2":{"pli":"Āmantā. ","html":"{}"},"kv19.1:4.3":{"pli":"Dvinnaṁ cittānaṁ samodhānaṁ hotīti? ","html":"{}"},"kv19.1:4.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv19.1:5.1":{"pli":"Rāgo akusalo, maggo kusaloti? ","html":"<p data-doxy='orthodox'>{}"},"kv19.1:5.2":{"pli":"Āmantā. ","html":"{}"},"kv19.1:5.3":{"pli":"Kusalākusalā sāvajjānavajjā hīnapaṇītā kaṇhasukkasappaṭibhāgā dhammā sammukhībhāvaṁ āgacchantīti? ","html":"{}"},"kv19.1:5.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv19.1:6.1":{"pli":"Kusalākusalā sāvajjānavajjā hīnapaṇītā kaṇhasukkasappaṭibhāgā dhammā sammukhībhāvaṁ āgacchantīti? ","html":"<p data-doxy='orthodox'>{}"},"kv19.1:6.2":{"pli":"Āmantā. ","html":"{}"},"kv19.1:6.3":{"pli":"Nanu vuttaṁ bhagavatā—","html":"{}"},"kv19.1:6.4":{"pli":"“cattārimāni, bhikkhave, suvidūravidūrāni. ","html":"{}"},"kv19.1:6.5":{"pli":"Katamāni cattāri? ","html":"{}"},"kv19.1:6.6":{"pli":"Nabhañca, bhikkhave, pathavī ca—","html":"{}"},"kv19.1:6.7":{"pli":"idaṁ paṭhamaṁ suvidūravidūraṁ …pe… tasmā sataṁ dhammo asabbhi ārakā”ti. ","html":"{}"},"kv19.1:6.8":{"pli":"Attheva suttantoti? ","html":"{}"},"kv19.1:6.9":{"pli":"Āmantā. ","html":"{}"},"kv19.1:6.10":{"pli":"Tena hi na vattabbaṁ—","html":"{}"},"kv19.1:6.11":{"pli":"“kusalākusalā …pe… ","html":"{}"},"kv19.1:6.12":{"pli":"sammukhībhāvaṁ āgacchantī”ti. ","html":"{}</p>"},"kv19.1:7.1":{"pli":"Na vattabbaṁ—","html":"<p data-doxy='heterodox'>{}"},"kv19.1:7.2":{"pli":"“atīte kilese jahati, anāgate kilese jahati, paccuppanne kilese jahatī”ti? ","html":"{}"},"kv19.1:7.3":{"pli":"Āmantā. ","html":"{}"},"kv19.1:7.4":{"pli":"Natthi kilese jahatīti? ","html":"{}"},"kv19.1:7.5":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv19.1:7.6":{"pli":"tena hi atīte kilese jahati, anāgate kilese jahati, paccuppanne kilese jahatīti. ","html":"{}</p>"},"kv19.1:7.7":{"pli":"Kilesajahanakathā niṭṭhitā. ","html":"<p class='endsutta'>{}</p></article>"}}}