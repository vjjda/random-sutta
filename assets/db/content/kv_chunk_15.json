{"kv18.2":{"kv18.2:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv18.2'><header><ul><li class='division'>{}</li>"},"kv18.2:0.2":{"pli":"Mahāpaṇṇāsaka ","html":"<li>{}</li>"},"kv18.2:0.3":{"pli":"Aṭṭhārasamavagga ","html":"<li>{}</li></ul>"},"kv18.2:0.4":{"pli":"Dhammadesanākathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv18.2:1.1":{"pli":"Na vattabbaṁ—","html":"<p data-doxy='orthodox'>{}"},"kv18.2:1.2":{"pli":"“buddhena bhagavatā dhammo desito”ti? ","html":"{}"},"kv18.2:1.3":{"pli":"Āmantā. ","html":"{}"},"kv18.2:1.4":{"pli":"Kena desitoti? ","html":"{}"},"kv18.2:1.5":{"pli":"Abhinimmitena desitoti. ","html":"{}"},"kv18.2:1.6":{"pli":"Abhinimmito jino satthā sammāsambuddho sabbaññū sabbadassāvī dhammassāmī dhammappaṭisaraṇoti? ","html":"{}"},"kv18.2:1.7":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv18.2:2.1":{"pli":"Na vattabbaṁ—","html":"<p data-doxy='orthodox'>{}"},"kv18.2:2.2":{"pli":"“buddhena bhagavatā dhammo desito”ti? ","html":"{}"},"kv18.2:2.3":{"pli":"Āmantā. ","html":"{}"},"kv18.2:2.4":{"pli":"Kena desitoti? ","html":"{}"},"kv18.2:2.5":{"pli":"Āyasmatā ānandena desitoti. ","html":"{}"},"kv18.2:2.6":{"pli":"Āyasmā ānando jino satthā sammāsambuddho sabbaññū sabbadassāvī dhammassāmī dhammappaṭisaraṇoti? ","html":"{}"},"kv18.2:2.7":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv18.2:3.1":{"pli":"Na vattabbaṁ—","html":"<p data-doxy='orthodox'>{}"},"kv18.2:3.2":{"pli":"“buddhena bhagavatā dhammo desito”ti? ","html":"{}"},"kv18.2:3.3":{"pli":"Āmantā. ","html":"{}"},"kv18.2:3.4":{"pli":"Nanu vuttaṁ bhagavatā—","html":"{}"},"kv18.2:3.5":{"pli":"“saṅkhittenapi kho ahaṁ, sāriputta, dhammaṁ deseyyaṁ; ","html":"{}"},"kv18.2:3.6":{"pli":"vitthārenapi kho ahaṁ, sāriputta, dhammaṁ deseyyaṁ; ","html":"{}"},"kv18.2:3.7":{"pli":"saṅkhittavitthārenapi kho ahaṁ, sāriputta, dhammaṁ deseyyaṁ; ","html":"{}"},"kv18.2:3.8":{"pli":"aññātāro ca dullabhā”ti. ","html":"{}"},"kv18.2:3.9":{"pli":"Attheva suttantoti? ","html":"{}"},"kv18.2:3.10":{"pli":"Āmantā. ","html":"{}"},"kv18.2:3.11":{"pli":"Tena hi buddhena bhagavatā dhammo desitoti. ","html":"{}</p>"},"kv18.2:4.1":{"pli":"Na vattabbaṁ—","html":"<p data-doxy='orthodox'>{}"},"kv18.2:4.2":{"pli":"“buddhena bhagavatā dhammo desito”ti? ","html":"{}"},"kv18.2:4.3":{"pli":"Āmantā. ","html":"{}"},"kv18.2:4.4":{"pli":"Nanu vuttaṁ bhagavatā—","html":"{}"},"kv18.2:4.5":{"pli":"“‘abhiññāyāhaṁ, bhikkhave, dhammaṁ desemi, no anabhiññāya; ","html":"{}"},"kv18.2:4.6":{"pli":"sanidānāhaṁ, bhikkhave, dhammaṁ desemi, no anidānaṁ; ","html":"{}"},"kv18.2:4.7":{"pli":"sappāṭihāriyāhaṁ, bhikkhave, dhammaṁ desemi, no appāṭihāriyaṁ; ","html":"{}"},"kv18.2:4.8":{"pli":"tassa mayhaṁ, bhikkhave, abhiññāya dhammaṁ desayato no anabhiññāya, sanidānaṁ dhammaṁ desayato no anidānaṁ, sappāṭihāriyaṁ dhammaṁ desayato no appāṭihāriyaṁ karaṇīyo ovādo karaṇīyā anusāsanī; ","html":"{}"},"kv18.2:4.9":{"pli":"alañca pana vo, bhikkhave, tuṭṭhiyā alaṁ attamanatāya alaṁ somanassāya—","html":"{}"},"kv18.2:4.10":{"pli":"sammāsambuddho bhagavā, svākkhāto dhammo, suppaṭipanno saṅgho’ti. ","html":"{}"},"kv18.2:4.11":{"pli":"Imasmiñca pana veyyākaraṇasmiṁ bhaññamāne dasasahassilokadhātu akampitthā”ti. ","html":"{}"},"kv18.2:4.12":{"pli":"Attheva suttantoti? ","html":"{}"},"kv18.2:4.13":{"pli":"Āmantā. ","html":"{}"},"kv18.2:4.14":{"pli":"Tena hi buddhena bhagavatā dhammo desitoti. ","html":"{}</p>"},"kv18.2:4.15":{"pli":"Dhammadesanākathā niṭṭhitā. ","html":"<p class='endsutta'>{}</p></article>"}},"kv18.3":{"kv18.3:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv18.3'><header><ul><li class='division'>{}</li>"},"kv18.3:0.2":{"pli":"Mahāpaṇṇāsaka ","html":"<li>{}</li>"},"kv18.3:0.3":{"pli":"Aṭṭhārasamavagga ","html":"<li>{}</li></ul>"},"kv18.3:0.4":{"pli":"Karuṇākathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv18.3:1.1":{"pli":"Natthi buddhassa bhagavato karuṇāti? ","html":"<p data-doxy='orthodox'>{}"},"kv18.3:1.2":{"pli":"Āmantā. ","html":"{}"},"kv18.3:1.3":{"pli":"Natthi buddhassa bhagavato mettāti? ","html":"{}"},"kv18.3:1.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv18.3:1.5":{"pli":"natthi buddhassa bhagavato karuṇāti? ","html":"{}"},"kv18.3:1.6":{"pli":"Āmantā. ","html":"{}"},"kv18.3:1.7":{"pli":"Natthi buddhassa bhagavato muditā …pe… ","html":"{}"},"kv18.3:1.8":{"pli":"upekkhāti? ","html":"{}"},"kv18.3:1.9":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv18.3:2.1":{"pli":"Atthi buddhassa bhagavato mettāti? ","html":"<p data-doxy='orthodox'>{}"},"kv18.3:2.2":{"pli":"Āmantā. ","html":"{}"},"kv18.3:2.3":{"pli":"Atthi buddhassa bhagavato karuṇāti? ","html":"{}"},"kv18.3:2.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv18.3:2.5":{"pli":"atthi buddhassa bhagavato muditā …pe… ","html":"{}"},"kv18.3:2.6":{"pli":"upekkhāti? ","html":"{}"},"kv18.3:2.7":{"pli":"Āmantā. ","html":"{}"},"kv18.3:2.8":{"pli":"Atthi buddhassa bhagavato karuṇāti? ","html":"{}"},"kv18.3:2.9":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv18.3:3.1":{"pli":"Natthi buddhassa bhagavato karuṇāti? ","html":"<p data-doxy='orthodox'>{}"},"kv18.3:3.2":{"pli":"Āmantā. ","html":"{}"},"kv18.3:3.3":{"pli":"Bhagavā akāruṇikoti? ","html":"{}"},"kv18.3:3.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv18.3:3.5":{"pli":"nanu bhagavā kāruṇiko lokahito lokānukampako lokatthacaroti? ","html":"{}"},"kv18.3:3.6":{"pli":"Āmantā. ","html":"{}"},"kv18.3:3.7":{"pli":"Hañci bhagavā kāruṇiko lokahito lokānukampako lokatthacaro, no ca vata re vattabbe—","html":"{}"},"kv18.3:3.8":{"pli":"“natthi buddhassa bhagavato karuṇā”ti …pe…. ","html":"{}</p>"},"kv18.3:4.1":{"pli":"Natthi buddhassa bhagavato karuṇāti? ","html":"<p data-doxy='orthodox'>{}"},"kv18.3:4.2":{"pli":"Āmantā. ","html":"{}"},"kv18.3:4.3":{"pli":"Nanu bhagavā mahākaruṇāsamāpattiṁ samāpajjīti? ","html":"{}"},"kv18.3:4.4":{"pli":"Āmantā. ","html":"{}"},"kv18.3:4.5":{"pli":"Hañci bhagavā mahākaruṇāsamāpattiṁ samāpajji, no ca vata re vattabbe—","html":"{}"},"kv18.3:4.6":{"pli":"“natthi buddhassa bhagavato karuṇā”ti. ","html":"{}</p>"},"kv18.3:5.1":{"pli":"Atthi buddhassa bhagavato karuṇāti? ","html":"<p data-doxy='heterodox'>{}"},"kv18.3:5.2":{"pli":"Āmantā. ","html":"{}"},"kv18.3:5.3":{"pli":"Bhagavā sarāgoti? ","html":"{}"},"kv18.3:5.4":{"pli":"Na hevaṁ vattabbe. ","html":"{}"},"kv18.3:5.5":{"pli":"Tena hi natthi buddhassa bhagavato karuṇāti. ","html":"{}</p>"},"kv18.3:5.6":{"pli":"Karuṇākathā niṭṭhitā. ","html":"<p class='endsutta'>{}</p></article>"}},"kv18.4":{"kv18.4:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv18.4'><header><ul><li class='division'>{}</li>"},"kv18.4:0.2":{"pli":"Mahāpaṇṇāsaka ","html":"<li>{}</li>"},"kv18.4:0.3":{"pli":"Aṭṭhārasamavagga ","html":"<li>{}</li></ul>"},"kv18.4:0.4":{"pli":"Gandhajātikathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv18.4:1.1":{"pli":"Buddhassa bhagavato uccārapassāvo ativiya aññe gandhajāte adhiggaṇhātīti? ","html":"<p data-doxy='orthodox'>{}"},"kv18.4:1.2":{"pli":"Āmantā. ","html":"{}"},"kv18.4:1.3":{"pli":"Bhagavā gandhabhojīti? ","html":"{}"},"kv18.4:1.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv18.4:1.5":{"pli":"nanu bhagavā odanakummāsaṁ bhuñjatīti? ","html":"{}"},"kv18.4:1.6":{"pli":"Āmantā. ","html":"{}"},"kv18.4:1.7":{"pli":"Hañci bhagavā odanakummāsaṁ bhuñjati, no ca vata re vattabbe—","html":"{}"},"kv18.4:1.8":{"pli":"“buddhassa bhagavato uccārapassāvo ativiya aññe gandhajāte adhiggaṇhātī”ti. ","html":"{}</p>"},"kv18.4:2.1":{"pli":"Buddhassa bhagavato uccārapassāvo ativiya aññe gandhajāte adhiggaṇhātīti? ","html":"<p data-doxy='orthodox'>{}"},"kv18.4:2.2":{"pli":"Āmantā. ","html":"{}"},"kv18.4:2.3":{"pli":"Atthi keci buddhassa bhagavato uccārapassāvaṁ nhāyanti vilimpanti ucchādenti peḷāya paṭisāmenti karaṇḍāya nikkhipanti āpaṇe pasārenti, tena ca gandhena gandhakaraṇīyaṁ karontīti? ","html":"{}"},"kv18.4:2.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv18.4:2.5":{"pli":"Gandhajātikathā niṭṭhitā. ","html":"<p class='endsutta'>{}</p></article>"}},"kv18.5":{"kv18.5:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv18.5'><header><ul><li class='division'>{}</li>"},"kv18.5:0.2":{"pli":"Mahāpaṇṇāsaka ","html":"<li>{}</li>"},"kv18.5:0.3":{"pli":"Aṭṭhārasamavagga ","html":"<li>{}</li></ul>"},"kv18.5:0.4":{"pli":"Ekamaggakathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv18.5:1.1":{"pli":"Ekena ariyamaggena cattāri sāmaññaphalāni sacchikarotīti? ","html":"<p data-doxy='orthodox'>{}"},"kv18.5:1.2":{"pli":"Āmantā. ","html":"{}"},"kv18.5:1.3":{"pli":"Catunnaṁ phassānaṁ …pe… ","html":"{}"},"kv18.5:1.4":{"pli":"catunnaṁ saññānaṁ samodhānaṁ hotīti? ","html":"{}"},"kv18.5:1.5":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv18.5:1.6":{"pli":"ekena ariyamaggena cattāri sāmaññaphalāni sacchikarotīti? ","html":"{}"},"kv18.5:1.7":{"pli":"Āmantā. ","html":"{}"},"kv18.5:1.8":{"pli":"Sotāpattimaggenāti? ","html":"{}"},"kv18.5:1.9":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv18.5:1.10":{"pli":"sakadāgāmi …pe… ","html":"{}"},"kv18.5:1.11":{"pli":"anāgāmimaggenāti? ","html":"{}"},"kv18.5:1.12":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv18.5:2.1":{"pli":"Katamena maggenāti? ","html":"<p data-doxy='orthodox'>{}"},"kv18.5:2.2":{"pli":"Arahattamaggenāti. ","html":"{}"},"kv18.5:2.3":{"pli":"Arahattamaggena sakkāyadiṭṭhiṁ vicikicchaṁ sīlabbataparāmāsaṁ jahatīti? ","html":"{}"},"kv18.5:2.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv18.5:2.5":{"pli":"arahattamaggena sakkāyadiṭṭhiṁ vicikicchaṁ sīlabbataparāmāsaṁ jahatīti? ","html":"{}"},"kv18.5:2.6":{"pli":"Āmantā. ","html":"{}"},"kv18.5:2.7":{"pli":"Nanu tiṇṇaṁ saṁyojanānaṁ pahānaṁ sotāpattiphalaṁ vuttaṁ bhagavatāti? ","html":"{}"},"kv18.5:2.8":{"pli":"Āmantā. ","html":"{}"},"kv18.5:2.9":{"pli":"Hañci tiṇṇaṁ saṁyojanānaṁ pahānaṁ sotāpattiphalaṁ vuttaṁ bhagavatā, no ca vata re vattabbe—","html":"{}"},"kv18.5:2.10":{"pli":"“arahattamaggena sakkāyadiṭṭhiṁ vicikicchaṁ sīlabbataparāmāsaṁ jahatī”ti. ","html":"{}</p>"},"kv18.5:3.1":{"pli":"Arahattamaggena oḷārikaṁ kāmarāgaṁ oḷārikaṁ byāpādaṁ jahatīti? ","html":"<p data-doxy='orthodox'>{}"},"kv18.5:3.2":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv18.5:3.3":{"pli":"arahattamaggena oḷārikaṁ kāmarāgaṁ oḷārikaṁ byāpādaṁ jahatīti? ","html":"{}"},"kv18.5:3.4":{"pli":"Āmantā. ","html":"{}"},"kv18.5:3.5":{"pli":"Nanu kāmarāgabyāpādānaṁ tanubhāvaṁ sakadāgāmiphalaṁ vuttaṁ bhagavatāti? ","html":"{}"},"kv18.5:3.6":{"pli":"Āmantā. ","html":"{}"},"kv18.5:3.7":{"pli":"Hañci kāmarāgabyāpādānaṁ tanubhāvaṁ sakadāgāmiphalaṁ vuttaṁ bhagavatā, no ca vata re vattabbe—","html":"{}"},"kv18.5:3.8":{"pli":"“arahattamaggena oḷārikaṁ kāmarāgaṁ oḷārikaṁ byāpādaṁ jahatī”ti. ","html":"{}</p>"},"kv18.5:4.1":{"pli":"Arahattamaggena aṇusahagataṁ kāmarāgaṁ aṇusahagataṁ byāpādaṁ jahatīti? ","html":"<p data-doxy='orthodox'>{}"},"kv18.5:4.2":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv18.5:4.3":{"pli":"arahattamaggena aṇusahagataṁ kāmarāgaṁ aṇusahagataṁ byāpādaṁ jahatīti? ","html":"{}"},"kv18.5:4.4":{"pli":"Āmantā. ","html":"{}"},"kv18.5:4.5":{"pli":"Nanu kāmarāgabyāpādānaṁ anavasesappahānaṁ anāgāmiphalaṁ vuttaṁ bhagavatāti? ","html":"{}"},"kv18.5:4.6":{"pli":"Āmantā. ","html":"{}"},"kv18.5:4.7":{"pli":"Hañci kāmarāgabyāpādānaṁ anavasesappahānaṁ anāgāmiphalaṁ vuttaṁ bhagavatā, no ca vata re vattabbe—","html":"{}"},"kv18.5:4.8":{"pli":"“arahattamaggena aṇusahagataṁ kāmarāgaṁ aṇusahagataṁ byāpādaṁ jahatī”ti. ","html":"{}</p>"},"kv18.5:5.1":{"pli":"Na vattabbaṁ—","html":"<p data-doxy='heterodox'>{}"},"kv18.5:5.2":{"pli":"“ekena ariyamaggena cattāri sāmaññaphalāni sacchikarotī”ti? ","html":"{}"},"kv18.5:5.3":{"pli":"Āmantā. ","html":"{}"},"kv18.5:5.4":{"pli":"Bhagavatā sotāpattimaggo bhāvitoti? ","html":"{}"},"kv18.5:5.5":{"pli":"Āmantā. ","html":"{}"},"kv18.5:5.6":{"pli":"Bhagavā sotāpannoti? ","html":"{}"},"kv18.5:5.7":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv18.5:5.8":{"pli":"bhagavatā sakadāgāmi …pe… ","html":"{}"},"kv18.5:5.9":{"pli":"anāgāmimaggo bhāvitoti? ","html":"{}"},"kv18.5:5.10":{"pli":"Āmantā. ","html":"{}"},"kv18.5:5.11":{"pli":"Bhaga