{"ja462":{"ja462:0.1":{"pli":"Jātaka ","html":"<article id='ja462'><header><ul><li class='division'>{}</li>"},"ja462:0.2":{"pli":"Ekādasakanipāta ","html":"<li>{}</li>"},"ja462:0.3":{"pli":"Mātuposakavagga ","html":"<li>{}</li></ul>"},"ja462:0.4":{"pli":"8. Saṁvarajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja462:1.1":{"pli":"“Jānanto no mahārāja, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja462:1.2":{"pli":"tava sīlaṁ janādhipo; ","html":"<span class='verse-line'>{}</span>"},"ja462:1.3":{"pli":"Ime kumāre pūjento, ","html":"<span class='verse-line'>{}</span>"},"ja462:1.4":{"pli":"na taṁ kenaci maññatha. ","html":"<span class='verse-line'>{}</span></p>"},"ja462:2.1":{"pli":"Tiṭṭhante no mahārāje, ","html":"<p><span class='verse-line'>{}</span>"},"ja462:2.2":{"pli":"adu deve divaṅgate; ","html":"<span class='verse-line'>{}</span>"},"ja462:2.3":{"pli":"Ñātī taṁ samanuññiṁsu, ","html":"<span class='verse-line'>{}</span>"},"ja462:2.4":{"pli":"sampassaṁ atthamattano. ","html":"<span class='verse-line'>{}</span></p>"},"ja462:3.1":{"pli":"Kena saṁvara vattena, ","html":"<p><span class='verse-line'>{}</span>"},"ja462:3.2":{"pli":"sañjāte abhitiṭṭhasi; ","html":"<span class='verse-line'>{}</span>"},"ja462:3.3":{"pli":"Kena taṁ nātivattanti, ","html":"<span class='verse-line'>{}</span>"},"ja462:3.4":{"pli":"ñātisaṅghā samāgatā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja462:4.1":{"pli":"“Na rājaputta usūyāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja462:4.2":{"pli":"samaṇānaṁ mahesinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja462:4.3":{"pli":"Sakkaccaṁ te namassāmi, ","html":"<span class='verse-line'>{}</span>"},"ja462:4.4":{"pli":"pāde vandāmi tādinaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja462:5.1":{"pli":"Te maṁ dhammaguṇe yuttaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja462:5.2":{"pli":"sussūsamanusūyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja462:5.3":{"pli":"Samaṇā manusāsanti, ","html":"<span class='verse-line'>{}</span>"},"ja462:5.4":{"pli":"isī dhammaguṇe ratā. ","html":"<span class='verse-line'>{}</span></p>"},"ja462:6.1":{"pli":"Tesāhaṁ vacanaṁ sutvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja462:6.2":{"pli":"samaṇānaṁ mahesinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja462:6.3":{"pli":"Na kiñci atimaññāmi, ","html":"<span class='verse-line'>{}</span>"},"ja462:6.4":{"pli":"dhamme me nirato mano. ","html":"<span class='verse-line'>{}</span></p>"},"ja462:7.1":{"pli":"Hatthārohā anīkaṭṭhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja462:7.2":{"pli":"rathikā pattikārakā; ","html":"<span class='verse-line'>{}</span>"},"ja462:7.3":{"pli":"Tesaṁ nappaṭibandhāmi, ","html":"<span class='verse-line'>{}</span>"},"ja462:7.4":{"pli":"niviṭṭhaṁ bhattavetanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja462:8.1":{"pli":"Mahāmattā ca me atthi, ","html":"<p><span class='verse-line'>{}</span>"},"ja462:8.2":{"pli":"mantino paricārakā; ","html":"<span class='verse-line'>{}</span>"},"ja462:8.3":{"pli":"Bārāṇasiṁ voharanti, ","html":"<span class='verse-line'>{}</span>"},"ja462:8.4":{"pli":"bahumaṁsasurodakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja462:9.1":{"pli":"Athopi vāṇijā phītā, ","html":"<p><span class='verse-line'>{}</span>"},"ja462:9.2":{"pli":"nānāraṭṭhehi āgatā; ","html":"<span class='verse-line'>{}</span>"},"ja462:9.3":{"pli":"Tesu me vihitā rakkhā, ","html":"<span class='verse-line'>{}</span>"},"ja462:9.4":{"pli":"evaṁ jānāhuposatha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja462:10.1":{"pli":"“Dhammena kira ñātīnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja462:10.2":{"pli":"rajjaṁ kārehi saṁvara; ","html":"<span class='verse-line'>{}</span>"},"ja462:10.3":{"pli":"Medhāvī paṇḍito cāsi, ","html":"<span class='verse-line'>{}</span>"},"ja462:10.4":{"pli":"athopi ñātinaṁ hito. ","html":"<span class='verse-line'>{}</span></p>"},"ja462:11.1":{"pli":"Taṁ taṁ ñātiparibyūḷhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja462:11.2":{"pli":"nānāratanamocitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja462:11.3":{"pli":"Amittā nappasahanti, ","html":"<span class='verse-line'>{}</span>"},"ja462:11.4":{"pli":"indaṁva asurādhipo”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja462:12.1":{"pli":"Saṁvarajātakaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja463":{"ja463:0.1":{"pli":"Jātaka ","html":"<article id='ja463'><header><ul><li class='division'>{}</li>"},"ja463:0.2":{"pli":"Ekādasakanipāta ","html":"<li>{}</li>"},"ja463:0.3":{"pli":"Mātuposakavagga ","html":"<li>{}</li></ul>"},"ja463:0.4":{"pli":"9. Suppārakajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja463:1.1":{"pli":"“Ummujjanti nimujjanti, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja463:1.2":{"pli":"manussā khuranāsikā; ","html":"<span class='verse-line'>{}</span>"},"ja463:1.3":{"pli":"Suppārakaṁ taṁ pucchāma, ","html":"<span class='verse-line'>{}</span>"},"ja463:1.4":{"pli":"samuddo katamo ayaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja463:2.1":{"pli":"“Kurukacchā payātānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja463:2.2":{"pli":"vāṇijānaṁ dhanesinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja463:2.3":{"pli":"Nāvāya vippanaṭṭhāya, ","html":"<span class='verse-line'>{}</span>"},"ja463:2.4":{"pli":"khuramālīti vuccati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja463:3.1":{"pli":"“Yathā aggīva suriyova, ","html":"<p><span class='verse-line'>{}</span>"},"ja463:3.2":{"pli":"samuddo paṭidissati; ","html":"<span class='verse-line'>{}</span>"},"ja463:3.3":{"pli":"Suppārakaṁ taṁ pucchāma, ","html":"<span class='verse-line'>{}</span>"},"ja463:3.4":{"pli":"samuddo katamo ayaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja463:4.1":{"pli":"“Kurukacchā payātānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja463:4.2":{"pli":"vāṇijānaṁ dhanesinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja463:4.3":{"pli":"Nāvāya vippanaṭṭhāya, ","html":"<span class='verse-line'>{}</span>"},"ja463:4.4":{"pli":"aggimālīti vuccati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja463:5.1":{"pli":"“Yathā dadhīva khīraṁva, ","html":"<p><span class='verse-line'>{}</span>"},"ja463:5.2":{"pli":"samuddo paṭidissati; ","html":"<span class='verse-line'>{}</span>"},"ja463:5.3":{"pli":"Suppārakaṁ taṁ pucchāma, ","html":"<span class='verse-line'>{}</span>"},"ja463:5.4":{"pli":"samuddo katamo ayaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja463:6.1":{"pli":"“Kurukacchā payātānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja463:6.2":{"pli":"vāṇijānaṁ dhanesinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja463:6.3":{"pli":"Nāvāya vippanaṭṭhāya, ","html":"<span class='verse-line'>{}</span>"},"ja463:6.4":{"pli":"dadhimālīti vuccati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja463:7.1":{"pli":"“Yathā kusova sassova, ","html":"<p><span class='verse-line'>{}</span>"},"ja463:7.2":{"pli":"samuddo paṭidissati; ","html":"<span class='verse-line'>{}</span>"},"ja463:7.3":{"pli":"Suppārakaṁ taṁ pucchāma, ","html":"<span class='verse-line'>{}</span>"},"ja463:7.4":{"pli":"samuddo katamo ayaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja463:8.1":{"pli":"“Kurukacchā payātānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja463:8.2":{"pli":"vāṇijānaṁ dhanesinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja463:8.3":{"pli":"Nāvāya vippanaṭṭhāya, ","html":"<span class='verse-line'>{}</span>"},"ja463:8.4":{"pli":"kusamālīti vuccati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja463:9.1":{"pli":"“Yathā naḷova veḷūva, ","html":"<p><span class='verse-line'>{}</span>"},"ja463:9.2":{"pli":"samuddo paṭidissati; ","html":"<span class='verse-line'>{}</span>"},"ja463:9.3":{"pli":"Suppārakaṁ taṁ pucchāma, ","html":"<span class='verse-line'>{}</span>"},"ja463:9.4":{"pli":"samuddo katamo ayaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja463:10.1":{"pli":"“Kurukacchā payātānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja463:10.2":{"pli":"vāṇijānaṁ dhanesinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja463:10.3":{"pli":"Nāvāya vippanaṭṭhāya, ","html":"<span class='verse-line'>{}</span>"},"ja463:10.4":{"pli":"naḷamālīti vuccati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja463:11.1":{"pli":"“Mahabbhayo bhiṁsanako, ","html":"<p><span class='verse-line'>{}</span>"},"ja463:11.2":{"pli":"saddo suyyatimānuso; ","html":"<span class='verse-line'>{}</span>"},"ja463:11.3":{"pli":"Yathā sobbho papātova, ","html":"<span class='verse-line'>{}</span>"},"ja463:11.4":{"pli":"samuddo paṭidissati; ","html":"<span class='verse-line'>{}</span>"},"ja463:11.5":{"pli":"Suppārakaṁ taṁ pucchāma, ","html":"<span class='verse-line'>{}</span>"},"ja463:11.6":{"pli":"samuddo katamo ayaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja463:12.1":{"pli":"“Kurukacchā payātānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja463:12.2":{"pli":"vāṇijānaṁ dhanesinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja463:12.3":{"pli":"Nāvāya vippanaṭṭhāya, ","html":"<span class='verse-line'>{}</span>"},"ja463:12.4":{"pli":"baḷavāmukhīti vuccati. ","html":"<span class='verse-line'>{}</span></p>"},"ja463:13.1":{"pli":"Yato sarāmi attānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja463:13.2":{"pli":"Yato pattosmi viññutaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja463:13.3":{"pli":"Nābhijānāmi sañcicca, ","html":"<span class='verse-line'>{}</span>"},"ja463:13.4":{"pli":"Ekapāṇampi hiṁsitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja463:13.5":{"pli":"Etena saccavajjena, ","html":"<span class='verse-line'>{}</span>"},"ja463:13.6":{"pli":"Sotthiṁ nāvā nivattatū”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja463:14.1":{"pli":"Suppārakajātakaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja463:15.1":{"pli":"Ekādasakanipātaṁ niṭṭhitaṁ. ","html":"<p class='endsection'>{}</p>"},"ja463:16.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja463:17.1":{"pli":"Sirimātusuposakanāgavaro, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja463:17.2":{"pli":"Puna juṇhaka dhammamudayavaro; ","html":"<span class='verse-line'>{}</span>"},"ja463:17.3":{"pli":"Atha pāni yudhañcayako ca dasa- ","html":"<span class='verse-line'>{}</span>"},"ja463:17.4":{"pli":"Ratha saṁvara pāragatena navāti. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"ja464":{"ja464:0.1":{"pli":"Jātaka ","html":"<article id='ja464'><header><ul><li class='division'>{}</li>"},"ja464:0.2":{"pli":"Dvādasakanipāta ","html":"<li>{}</li>"},"ja464:0.3":{"pli":"Cūḷakuṇālavagga ","html":"<li>{}</li></ul>"},"ja464:0.4":{"pli":"1. Cūḷakuṇālajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja464:1.1":{"pli":"“Luddhānaṁ lahucittānaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja464:1.2":{"pli":"akataññūna dubbhinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja464:1.3":{"pli":"Nādevasatto puriso, ","html":"<span class='verse-line'>{}</span>"},"ja464:1.4":{"pli":"thīnaṁ saddhātumarahati. ","html":"<span class='verse-line'>{}</span></p>"},"ja464:2.1":{"pli":"Na tā pajānanti kataṁ na kiccaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja464:2.2":{"pli":"Na mātaraṁ pitaraṁ bhātaraṁ vā; ","html":"<span class='verse-line'>{}</span>"},"ja464:2.3":{"pli":"Anariyā samatikkantadhammā, ","html":"<span class='verse-line'>{}</span>"},"ja464:2.4":{"pli":"Sasseva cittassa vasaṁ vajanti. ","html":"<span class='verse-line'>{}</span></p>"},"ja464:3.1":{"pli":"Cirānuvutthampi piyaṁ manāpaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja464:3.2":{"pli":"Anukampakaṁ pāṇasamampi bhattuṁ; ","html":"<span class='verse-line'>{}</span>"},"ja464:3.3":{"pli":"Āvāsu kiccesu ca naṁ jahanti, ","html":"<span class='verse-line'>{}</span>"},"ja464:3.4":{"pli":"Tasmāhamitthīnaṁ na vissasāmi. ","html":"<span class='verse-line'>{}</span></p>"},"ja464:4.1":{"pli":"Thīnañhi cittaṁ yathā vānarassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja464:4.2":{"pli":"Kannappakannaṁ yathā rukkhachāyā; ","html":"<span class='verse-line'>{}</span>"},"ja464:4.3":{"pli":"Calācalaṁ hadayamitthiyānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja464:4.4":{"pli":"Cakkassa nemi viya parivattati. ","html":"<span class='verse-line'>{}</span></p>"},"ja464:5.1":{"pli":"Yadā tā passanti samekkhamānā, ","html":"<p><span class='verse-line'>{}</span>"},"ja464:5.2":{"pli":"Ādeyyarūpaṁ purisassa vittaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja464:5.3":{"pli":"Saṇhāhi vācāhi nayanti menaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja464:5.4":{"pli":"Kambojakā jalajeneva assaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja464:6.1":{"pli":"Yadā na passanti samekkhamānā, ","html":"<p><span class='verse-line'>{}</span>"},"ja464:6.2":{"pli":"Ādeyyarūpaṁ purisassa vittaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja464:6.3":{"pli":"Samantato naṁ parivajjayanti, ","html":"<span class='verse-line'>{}</span>"},"ja464:6.4":{"pli":"Tiṇṇo nadīpāragatova kullaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja464:7.1":{"pli":"Silesūpamā sikhiriva sabbabhakkhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja464:7.2":{"pli":"Tikkhamāyā nadīriva sīghasotā; ","html":"<span class='verse-line'>{}</span>"},"ja464:7.3":{"pli":"Sevanti hetā piyamappiyañca, ","html":"<span class='verse-line'>{}</span>"},"ja464:7.4":{"pli":"Nāvā yathā orakūlaṁ parañca. ","html":"<span class='verse-line'>{}</span></p>"},"ja464:8.1":{"pli":"Na tā ekassa na dvinnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja464:8.2":{"pli":"āpaṇova pasārito; ","html":"<span class='verse-line'>{}</span>"},"ja464:8.3":{"pli":"Yo tā mayhanti maññeyya, ","html":"<span class='verse-line'>{}</span>"},"ja464:8.4":{"pli":"vātaṁ jālena bādhaye. ","html":"<span class='verse-line'>{}</span></p>"},"ja464:9.1":{"pli":"Yathā nadī ca pantho ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja464:9.2":{"pli":"pānāgāraṁ sabhā papā; ","html":"<span class='verse-line'>{}</span>"},"ja464:9.3":{"pli":"Evaṁ lokitthiyo nāma, ","html":"<span class='verse-line'>{}</span>"},"ja464:9.4":{"pli":"velā tāsaṁ na vijjati. ","html":"<span class='verse-line'>{}</span></p>"},"ja464:10.1":{"pli":"Ghatāsanasamā etā, ","html":"<p><span class='verse-line'>{}</span>"},"ja464:10.2":{"pli":"kaṇhasappasirūpamā; ","html":"<span class='verse-line'>{}</span>"},"ja464:10.3":{"pli":"Gāvo bahitiṇasseva, ","html":"<span class='verse-line'>{}</span>"},"ja464:10.4":{"pli":"omasanti varaṁ varaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja464:11.1":{"pli":"Ghatāsanaṁ kuñjaraṁ kaṇhasappaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja464:11.2":{"pli":"Muddhābhisittaṁ pamadā ca sabbā; ","html":"<span class='verse-line'>{}</span>"},"ja464:11.3":{"pli":"Ete naro niccayato bhajetha, ","html":"<span class='verse-line'>{}</span>"},"ja464:11.4":{"pli":"Tesaṁ have dubbidu sabbabhāvo. ","html":"<span class='verse-line'>{}</span></p>"},"ja464:12.1":{"pli":"Naccantavaṇṇā na bahūnaṁ kantā, ","html":"<p><span class='verse-line'>{}</span>"},"ja464:12.2":{"pli":"Na dakkhiṇā pamadā sevitabbā; ","html":"<span class='verse-line'>{}</span>"},"ja464:12.3":{"pli":"Na parassa bhariyā na dhanassa hetu, ","html":"<span class='verse-line'>{}</span>"},"ja464:12.4":{"pli":"Etitthiyo pañca na sevitabbā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja464:13.1":{"pli":"Cūḷakuṇālajātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja465":{"ja465:0.1":{"pli":"Jātaka ","html":"<article id='ja465'><header><ul><li class='division'>{}</li>"},"ja465:0.2":{"pli":"Dvādasakanipāta ","html":"<li>{}</li>"},"ja465:0.3":{"pli":"Cūḷakuṇālavagga ","html":"<li>{}</li></ul>"},"ja465:0.4":{"pli":"2. Bhaddasālajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja465:1.1":{"pli":"“Kā tvaṁ suddhehi vatthehi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja465:1.2":{"pli":"aghe vehāyasaṁ ṭhitā; ","html":"<span class='verse-line'>{}</span>"},"ja465:1.3":{"pli":"Kena tyāssūni vattanti, ","html":"<span class='verse-line'>{}</span>"},"ja465:1.4":{"pli":"kuto taṁ bhayamāgataṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja465:2.1":{"pli":"“Taveva deva vijite, ","html":"<p><span class='verse-line'>{}</span>"},"ja465:2.2":{"pli":"bhaddasāloti maṁ vidū; ","html":"<span class='verse-line'>{}</span>"},"ja465:2.3":{"pli":"Saṭṭhi vassasahassāni, ","html":"<span class='verse-line'>{}</span>"},"ja465:2.4":{"pli":"tiṭṭhato pūjitassa me. ","html":"<span class='verse-line'>{}</span></p>"},"ja465:3.1":{"pli":"Kārayantā nagarāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja465:3.2":{"pli":"agāre ca disampati; ","html":"<span class='verse-line'>{}</span>"},"ja465:3.3":{"pli":"Vividhe cāpi pāsāde, ","html":"<span class='verse-line'>{}</span>"},"ja465:3.4":{"pli":"na maṁ te accamaññisuṁ; ","html":"<span class='verse-line'>{}</span>"},"ja465:3.5":{"pli":"Yatheva maṁ te pūjesuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja465:3.6":{"pli":"tatheva tvampi pūjaya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja465:4.1":{"pli":"“Taṁ ivāhaṁ na passāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja465:4.2":{"pli":"thūlaṁ kāyena te dumaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja465:4.3":{"pli":"Ārohapariṇāhena, ","html":"<span class='verse-line'>{}</span>"},"ja465:4.4":{"pli":"abhirūposi jātiyā. ","html":"<span class='verse-line'>{}</span></p>"},"ja465:5.1":{"pli":"Pāsādaṁ kārayissāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja465:5.2":{"pli":"ekatthambhaṁ manoramaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja465:5.3":{"pli":"Tattha taṁ upanessāmi, ","html":"<span class='verse-line'>{}</span>"},"ja465:5.4":{"pli":"ciraṁ te yakkha jīvitaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja465:6.1":{"pli":"“Evaṁ cittaṁ udapādi, ","html":"<p><span class='verse-line'>{}</span>"},"ja465:6.2":{"pli":"sarīrena vinābhāvo; ","html":"<span class='verse-line'>{}</span>"},"ja465:6.3":{"pli":"Puthuso maṁ vikantitvā, ","html":"<span class='verse-line'>{}</span>"},"ja465:6.4":{"pli":"khaṇḍaso avakantatha. ","html":"<span class='verse-line'>{}</span></p>"},"ja465:7.1":{"pli":"Agge ca chetvā majjhe ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja465:7.2":{"pli":"pacchā mūlamhi chindatha; ","html":"<span class='verse-line'>{}</span>"},"ja465:7.3":{"pli":"Evaṁ me chijjamānassa, ","html":"<span class='verse-line'>{}</span>"},"ja465:7.4":{"pli":"na dukkhaṁ maraṇaṁ siyā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja465:8.1":{"pli":"“Hatthapādaṁ yathā chinde, ","html":"<p><span class='verse-line'>{}</span>"},"ja465:8.2":{"pli":"Kaṇṇanāsañca jīvato; ","html":"<span class='verse-line'>{}</span>"},"ja465:8.3":{"pli":"Tato pacchā siro chinde, ","html":"<span class='verse-line'>{}</span>"},"ja465:8.4":{"pli":"Taṁ dukkhaṁ maraṇaṁ siyā. ","html":"<span class='verse-line'>{}</span></p>"},"ja465:9.1":{"pli":"Sukhaṁ nu khaṇḍaso chinnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja465:9.2":{"pli":"bhaddasāla vanappati; ","html":"<span class='verse-line'>{}</span>"},"ja465:9.3":{"pli":"Kiṁhetu kiṁ upādāya, ","html":"<span class='verse-line'>{}</span>"},"ja465:9.4":{"pli":"khaṇḍaso chinnamicchasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja465:10.1":{"pli":"“Yañca hetumupādāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja465:10.2":{"pli":"hetuṁ dhammūpasaṁhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja465:10.3":{"pli":"Khaṇḍaso chinnamicchāmi, ","html":"<span class='verse-line'>{}</span>"},"ja465:10.4":{"pli":"mahārāja suṇohi me. ","html":"<span class='verse-line'>{}</span></p>"},"ja465:11.1":{"pli":"Ñātī me sukhasaṁvaddhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja465:11.2":{"pli":"mama passe nivātajā; ","html":"<span class='verse-line'>{}</span>"},"ja465:11.3":{"pli":"Tepihaṁ upahiṁseyyaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja465:11.4":{"pli":"paresaṁ asukhocitaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja465:12.1":{"pli":"“Ceteyyarūpaṁ cetesi, ","html":"<p><span class='verse-line'>{}</span>"},"ja465:12.2":{"pli":"bhaddasāla vanappati; ","html":"<span class='verse-line'>{}</span>"},"ja465:12.3":{"pli":"Hitakāmosi ñātīnaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja465:12.4":{"pli":"abhayaṁ samma dammi te”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja465:13.1":{"pli":"Bhaddasālajātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja466":{"ja466:0.1":{"pli":"Jātaka ","eng":"Stories of Past Lives 466 ","html":"<article id='ja466'><header><ul><li class='division'>{}</li>"},"ja466:0.2":{"pli":"Dvādasakanipāta ","eng":"The Book of the Twelves ","html":"<li>{}</li>"},"ja466:0.3":{"pli":"Cūḷakuṇālavagga ","eng":"The Chapter With Cūḷakuṇāla ","html":"<li>{}</li></ul>"},"ja466:0.4":{"pli":"3. Samuddavāṇijajātaka ","eng":"The Sea Merchants: a past life story ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja466:1.1":{"pli":"“Kasanti vapanti te janā, ","eng":"“Those folk sow and reap, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>","comm":"A castaway reflects on the abundance of his lonely isle. "},"ja466:1.2":{"pli":"Manujā kammaphalūpajīvino; ","eng":"men living on the fruit of their work. ","html":"<span class='verse-line'>{}</span>"},"ja466:1.3":{"pli":"Nayimassa dīpakassa bhāgino, ","eng":"They have no share of this island. ","html":"<span class='verse-line'>{}</span>"},"ja466:1.4":{"pli":"Jambudīpā idameva no varaṁ”. ","eng":"This is better far than India!” ","html":"<span class='verse-line'>{}</span></p>"},"ja466:2.1":{"pli":"“Tipañcarattūpagatamhi cande, ","eng":"“When the fifteenth day full moon has risen, ","html":"<p><span class='verse-line'>{}</span>","comm":"A righteous god stands in the north and warns the newly arrived refugees. "},"ja466:2.2":{"pli":"Vego mahā hehiti sāgarassa; ","eng":"there will be a great flood from the sea, ","html":"<span class='verse-line'>{}</span>"},"ja466:2.3":{"pli":"Uplavissaṁ dīpamimaṁ uḷāraṁ, ","eng":"drowning this splendid isle. ","html":"<span class='verse-line'>{}</span>"},"ja466:2.4":{"pli":"Mā vo vadhī gacchatha leṇamaññaṁ”. ","eng":"Let it not destroy you all! Go to some other haven!” ","html":"<span class='verse-line'>{}</span></p>"},"ja466:3.1":{"pli":"“Na jātuyaṁ sāgaravārivego, ","eng":"“Never shall a mighty flood of water from the sea ","html":"<p><span class='verse-line'>{}</span>","comm":"A wicked god speaks in the south. "},"ja466:3.2":{"pli":"Uplavissaṁ dīpamimaṁ uḷāraṁ; ","eng":"drown this splendid isle—","html":"<span class='verse-line'>{}</span>"},"ja466:3.3":{"pli":"Taṁ me nimittehi bahūhi diṭṭhaṁ, ","eng":"I have seen that through many a sign. ","html":"<span class='verse-line'>{}</span>"},"ja466:3.4":{"pli":"Mā bhetha kiṁ socatha modathavho. ","eng":"Don’t fear! Why worry? Celebrate! ","html":"<span class='verse-line'>{}</span></p>","comm":"<i lang='pi' translate='no'>Modathavho</i> is second imperative plural reflexive, “Let you all celebrate”. "},"ja466:4.1":{"pli":"Pahūtabhakkhaṁ bahuannapānaṁ, ","eng":"You’ve come to this splendid abode, ","html":"<p><span class='verse-line'>{}</span>"},"ja466:4.2":{"pli":"Pattattha āvāsamimaṁ uḷāraṁ; ","eng":"full of food and drink. ","html":"<span class='verse-line'>{}</span>"},"ja466:4.3":{"pli":"Na vo bhayaṁ paṭipassāmi kiñci, ","eng":"I see no danger for you at all—","html":"<span class='verse-line'>{}</span>"},"ja466:4.4":{"pli":"Āputtaputtehi pamodathavho”. ","eng":"Celebrate, even unto the sons of sons!” ","html":"<span class='verse-line'>{}</span></p>","comm":"Here <i lang='pi' translate='no'>ā</i> is a separate preposition, glossed by <i lang='pi' translate='no'>yāva</i>. "},"ja466:5.1":{"pli":"“Yo devoyaṁ dakkhiṇāyaṁ disāyaṁ, ","eng":"“This god in the southern quarter ","html":"<p><span class='verse-line'>{}</span>","comm":"A foolish refugee endorses the southern god. "},"ja466:5.2":{"pli":"Khemanti pakkosati tassa saccaṁ; ","eng":"crying, ‘It is safe!’: his is the truth! ","html":"<span class='verse-line'>{}</span>"},"ja466:5.3":{"pli":"Na uttaro vedi bhayābhayassa, ","eng":"The northern doesn’t know if there’s a danger or not. ","html":"<span class='verse-line'>{}</span>"},"ja466:5.4":{"pli":"Mā bhetha kiṁ socatha modathavho”. ","eng":"Don’t fear! Why worry? Celebrate!” ","html":"<span class='verse-line'>{}</span></p>"},"ja466:6.1":{"pli":"“Yathā ime vippavadanti yakkhā, ","eng":"“As these spirits argue, ","html":"<p><span class='verse-line'>{}</span>","comm":"A wise refugee counsels action. "},"ja466:6.2":{"pli":"Eko bhayaṁ saṁsati khemameko; ","eng":"one reporting danger, one safety, ","html":"<span class='verse-line'>{}</span>"},"ja466:6.3":{"pli":"Tadiṅgha mayhaṁ vacanaṁ suṇātha, ","eng":"please heed my advice, ","html":"<span class='verse-line'>{}</span>"},"ja466:6.4":{"pli":"Khippaṁ lahuṁ mā vinassimha sabbe. ","eng":"lest we perish swift and fleet. ","html":"<span class='verse-line'>{}</span></p>"},"ja466:7.1":{"pli":"Sabbe samāgamma karoma nāvaṁ, ","eng":"Let all join together to build a boat, ","html":"<p><span class='verse-line'>{}</span>"},"ja466:7.2":{"pli":"Doṇiṁ daḷhaṁ sabbayantūpapannaṁ; ","eng":"a strong vessel fully equipped. ","html":"<span class='verse-line'>{}</span>"},"ja466:7.3":{"pli":"Sace ayaṁ dakkhiṇo saccamāha, ","eng":"If this southern one speaks true, ","html":"<span class='verse-line'>{}</span>"},"ja466:7.4":{"pli":"Moghaṁ paṭikkosati uttaroyaṁ; ","eng":"and is falsely rejected by the northern, ","html":"<span class='verse-line'>{}</span>"},"ja466:7.5":{"pli":"Sā ceva no hehiti āpadatthā, ","eng":"it shall serve us in time of need, ","html":"<span class='verse-line'>{}</span>"},"ja466:7.6":{"pli":"Imañca dīpaṁ na pariccajema. ","eng":"and we would not give up the island. ","html":"<span class='verse-line'>{}</span></p>"},"ja466:8.1":{"pli":"Sace ca kho uttaro saccamāha, ","eng":"But if the northern speaks true, ","html":"<p><span class='verse-line'>{}</span>"},"ja466:8.2":{"pli":"Moghaṁ paṭikkosati dakkhiṇoyaṁ; ","eng":"and is falsely rejected by the southern, ","html":"<span class='verse-line'>{}</span>"},"ja466:8.3":{"pli":"Tameva nāvaṁ abhiruyha sabbe, ","eng":"then having all boarded the boat, ","html":"<span class='verse-line'>{}</span>"},"ja466:8.4":{"pli":"Evaṁ mayaṁ sotthi taremu pāraṁ. ","eng":"we shall cross safely to the far shore. ","html":"<span class='verse-line'>{}</span></p>"},"ja466:9.1":{"pli":"Na ve sugaṇhaṁ paṭhamena seṭṭhaṁ, ","eng":"Truly, best not accept the last word that came your way, ","html":"<p><span class='verse-line'>{}</span>"},"ja466:9.2":{"pli":"Kaniṭṭhamāpāthagataṁ gahetvā; ","eng":"when what was spoken by the first was best. ","html":"<span class='verse-line'>{}</span>"},"ja466:9.3":{"pli":"Yo cīdha tacchaṁ paviceyya gaṇhati, ","eng":"Who here accepts the truth after examination, ","html":"<span class='verse-line'>{}</span>"},"ja466:9.4":{"pli":"Sa ve naro seṭṭhamupeti ṭhānaṁ. ","eng":"that man goes to the best place.” ","html":"<span class='verse-line'>{}</span></p>"},"ja466:10.1":{"pli":"Yathāpi te sāgaravārimajjhe, ","eng":"Just as, in the middle of the watery sea, ","html":"<p><span class='verse-line'>{}</span>","comm":"These editorializing verses are attributed to the Buddha. "},"ja466:10.2":{"pli":"Sakammunā sotthi vahiṁsu vāṇijā; ","eng":"the merchants fled to safety by their own efforts, ","html":"<span class='verse-line'>{}</span>"},"ja466:10.3":{"pli":"Anāgatatthaṁ paṭivijjhiyāna, ","eng":"so, realizing his future welfare, ","html":"<span class='verse-line'>{}</span>"},"ja466:10.4":{"pli":"Appampi nācceti sa bhūripañño. ","eng":"he of vast wisdom transgresses not at all. ","html":"<span class='verse-line'>{}</span></p>"},"ja466:11.1":{"pli":"Bālā ca mohena rasānugiddhā, ","eng":"Fools deluded by desire for tastes, ","html":"<p><span class='verse-line'>{}</span>"},"ja466:11.2":{"pli":"Anāgataṁ appaṭivijjhiyatthaṁ; ","eng":"not realizing their future welfare, ","html":"<span class='verse-line'>{}</span>"},"ja466:11.3":{"pli":"Paccuppanne sīdanti atthajāte, ","eng":"sink down in face of present need, ","html":"<span class='verse-line'>{}</span>"},"ja466:11.4":{"pli":"Samuddamajjhe yathā te manussā. ","eng":"like those people in mid-ocean. ","html":"<span class='verse-line'>{}</span></p>"},"ja466:12.1":{"pli":"Anāgataṁ paṭikayirātha kiccaṁ, ","eng":"Prepare what must be done for the future, thinking, ","html":"<p><span class='verse-line'>{}</span>"},"ja466:12.2":{"pli":"‘Mā maṁ kiccaṁ kiccakāle byadhesi’; ","eng":"‘Let what must be done not harm me on the day the duty ripens.’ ","html":"<span class='verse-line'>{}</span>"},"ja466:12.3":{"pli":"Taṁ tādisaṁ paṭikatakiccakāriṁ, ","eng":"The kind who acts to prepare what must be done, ","html":"<span class='verse-line'>{}</span>"},"ja466:12.4":{"pli":"Na taṁ kiccaṁ kiccakāle byadhetī”ti. ","eng":"is not harmed by what must be done on the day the duty ripens.” ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja466:13.1":{"pli":"Samuddavāṇijajātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja467":{"ja467:0.1":{"pli":"Jātaka ","html":"<article id='ja467'><header><ul><li class='division'>{}</li>"},"ja467:0.2":{"pli":"Dvādasakanipāta ","html":"<li>{}</li>"},"ja467:0.3":{"pli":"Cūḷakuṇālavagga ","html":"<li>{}</li></ul>"},"ja467:0.4":{"pli":"4. Kāmajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja467:1.1":{"pli":"“Kāmaṁ kāmayamānassa, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja467:1.2":{"pli":"tassa ce taṁ samijjhati; ","html":"<span class='verse-line'>{}</span>"},"ja467:1.3":{"pli":"Addhā pītimano hoti, ","html":"<span class='verse-line'>{}</span>"},"ja467:1.4":{"pli":"laddhā macco yadicchati. ","html":"<span class='verse-line'>{}</span></p>"},"ja467:2.1":{"pli":"Kāmaṁ kāmayamānassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja467:2.2":{"pli":"tassa ce taṁ samijjhati; ","html":"<span class='verse-line'>{}</span>"},"ja467:2.3":{"pli":"Tato naṁ aparaṁ kāme, ","html":"<span class='verse-line'>{}</span>"},"ja467:2.4":{"pli":"ghamme taṇhaṁva vindati. ","html":"<span class='verse-line'>{}</span></p>"},"ja467:3.1":{"pli":"Gavaṁva siṅgino siṅgaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja467:3.2":{"pli":"vaḍḍhamānassa vaḍḍhati; ","html":"<span class='verse-line'>{}</span>"},"ja467:3.3":{"pli":"Evaṁ mandassa posassa, ","html":"<span class='verse-line'>{}</span>"},"ja467:3.4":{"pli":"bālassa avijānato; ","html":"<span class='verse-line'>{}</span>"},"ja467:3.5":{"pli":"Bhiyyo taṇhā pipāsā ca, ","html":"<span class='verse-line'>{}</span>"},"ja467:3.6":{"pli":"vaḍḍhamānassa vaḍḍhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja467:4.1":{"pli":"Pathabyā sāliyavakaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja467:4.2":{"pli":"gavāssaṁ dāsaporisaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja467:4.3":{"pli":"Datvā ca nālamekassa, ","html":"<span class='verse-line'>{}</span>"},"ja467:4.4":{"pli":"iti vidvā samaṁ care. ","html":"<span class='verse-line'>{}</span></p>"},"ja467:5.1":{"pli":"Rājā pasayha pathaviṁ vijitvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja467:5.2":{"pli":"Sasāgarantaṁ mahimāvasanto; ","html":"<span class='verse-line'>{}</span>"},"ja467:5.3":{"pli":"Oraṁ samuddassa atittarūpo, ","html":"<span class='verse-line'>{}</span>"},"ja467:5.4":{"pli":"Pāraṁ samuddassapi patthayetha. ","html":"<span class='verse-line'>{}</span></p>"},"ja467:6.1":{"pli":"Yāva anussaraṁ kāme, ","html":"<p><span class='verse-line'>{}</span>"},"ja467:6.2":{"pli":"Manasā titti nājjhagā; ","html":"<span class='verse-line'>{}</span>"},"ja467:6.3":{"pli":"Tato nivattā paṭikkamma disvā, ","html":"<span class='verse-line'>{}</span>"},"ja467:6.4":{"pli":"Te ve sutittā ye paññāya tittā. ","html":"<span class='verse-line'>{}</span></p>"},"ja467:7.1":{"pli":"Paññāya tittinaṁ seṭṭhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja467:7.2":{"pli":"na so kāmehi tappati; ","html":"<span class='verse-line'>{}</span>"},"ja467:7.3":{"pli":"Paññāya tittaṁ purisaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja467:7.4":{"pli":"taṇhā na kurute vasaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja467:8.1":{"pli":"Apacinetheva kāmānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja467:8.2":{"pli":"appicchassa alolupo; ","html":"<span class='verse-line'>{}</span>"},"ja467:8.3":{"pli":"Samuddamatto puriso, ","html":"<span class='verse-line'>{}</span>"},"ja467:8.4":{"pli":"na so kāmehi tappati. ","html":"<span class='verse-line'>{}</span></p>"},"ja467:9.1":{"pli":"Rathakārova cammassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja467:9.2":{"pli":"parikantaṁ upāhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja467:9.3":{"pli":"Yaṁ yaṁ cajati kāmānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja467:9.4":{"pli":"taṁ taṁ sampajjate sukhaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja467:9.5":{"pli":"Sabbañce sukhamiccheyya, ","html":"<span class='verse-line'>{}</span>"},"ja467:9.6":{"pli":"sabbe kāme pariccaje”. ","html":"<span class='verse-line'>{}</span></p>"},"ja467:10.1":{"pli":"“Aṭṭha te bhāsitā gāthā, ","html":"<p><span class='verse-line'>{}</span>"},"ja467:10.2":{"pli":"sabbā honti sahassiyo; ","html":"<span class='verse-line'>{}</span>"},"ja467:10.3":{"pli":"Paṭigaṇha mahābrahme, ","html":"<span class='verse-line'>{}</span>"},"ja467:10.4":{"pli":"sādhetaṁ tava bhāsitaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja467:11.1":{"pli":"“Na me attho sahassehi, ","html":"<p><span class='verse-line'>{}</span>"},"ja467:11.2":{"pli":"satehi nahutehi vā; ","html":"<span class='verse-line'>{}</span>"},"ja467:11.3":{"pli":"Pacchimaṁ bhāsato gāthaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja467:11.4":{"pli":"kāme me na rato mano”. ","html":"<span class='verse-line'>{}</span></p>"},"ja467:12.1":{"pli":"“Bhadrako vatāyaṁ māṇavako, ","html":"<p><span class='verse-line'>{}</span>"},"ja467:12.2":{"pli":"Sabbalokavidū muni; ","html":"<span class='verse-line'>{}</span>"},"ja467:12.3":{"pli":"Yo imaṁ taṇhaṁ dukkhajananiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja467:12.4":{"pli":"Parijānāti paṇḍito”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja467:13.1":{"pli":"Kāmajātakaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja468":{"ja468:0.1":{"pli":"Jātaka ","html":"<article id='ja468'><header><ul><li class='division'>{}</li>"},"ja468:0.2":{"pli":"Dvādasakanipāta ","html":"<li>{}</li>"},"ja468:0.3":{"pli":"Cūḷakuṇālavagga ","html":"<li>{}</li></ul>"},"ja468:0.4":{"pli":"5. Janasandhajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja468:1.1":{"pli":"“Dasa khalu imāni ṭhānāni, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja468:1.2":{"pli":"Yāni pubbe akaritvā; ","html":"<span class='verse-line'>{}</span>"},"ja468:1.3":{"pli":"Sa pacchā manutappati, ","html":"<span class='verse-line'>{}</span>"},"ja468:1.4":{"pli":"Iccevāha janasandho. ","html":"<span class='verse-line'>{}</span></p>"},"ja468:2.1":{"pli":"Aladdhā vittaṁ tappati, ","html":"<p><span class='verse-line'>{}</span>"},"ja468:2.2":{"pli":"pubbe asamudānitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja468:2.3":{"pli":"Na pubbe dhanamesissaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja468:2.4":{"pli":"iti pacchānutappati. ","html":"<span class='verse-line'>{}</span></p>"},"ja468:3.1":{"pli":"Sakyarūpaṁ pure santaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja468:3.2":{"pli":"mayā sippaṁ na sikkhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja468:3.3":{"pli":"Kicchā vutti asippassa, ","html":"<span class='verse-line'>{}</span>"},"ja468:3.4":{"pli":"iti pacchānutappati. ","html":"<span class='verse-line'>{}</span></p>"},"ja468:4.1":{"pli":"Kūṭavedī pure āsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja468:4.2":{"pli":"pisuṇo piṭṭhimaṁsiko; ","html":"<span class='verse-line'>{}</span>"},"ja468:4.3":{"pli":"Caṇḍo ca pharuso cāpi, ","html":"<span class='verse-line'>{}</span>"},"ja468:4.4":{"pli":"iti pacchānutappati. ","html":"<span class='verse-line'>{}</span></p>"},"ja468:5.1":{"pli":"Pāṇātipātī pure āsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja468:5.2":{"pli":"luddo cāpi anāriyo; ","html":"<span class='verse-line'>{}</span>"},"ja468:5.3":{"pli":"Bhūtānaṁ nāpacāyissaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja468:5.4":{"pli":"iti pacchānutappati. ","html":"<span class='verse-line'>{}</span></p>"},"ja468:6.1":{"pli":"Bahūsu vata santīsu, ","html":"<p><span class='verse-line'>{}</span>"},"ja468:6.2":{"pli":"anāpādāsu itthisu; ","html":"<span class='verse-line'>{}</span>"},"ja468:6.3":{"pli":"Paradāraṁ asevissaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja468:6.4":{"pli":"iti pacchānutappati. ","html":"<span class='verse-line'>{}</span></p>"},"ja468:7.1":{"pli":"Bahumhi vata santamhi, ","html":"<p><span class='verse-line'>{}</span>"},"ja468:7.2":{"pli":"annapāne upaṭṭhite; ","html":"<span class='verse-line'>{}</span>"},"ja468:7.3":{"pli":"Na pubbe adadaṁ dānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja468:7.4":{"pli":"iti pacchānutappati. ","html":"<span class='verse-line'>{}</span></p>"},"ja468:8.1":{"pli":"Mātaraṁ pitarañcāpi, ","html":"<p><span class='verse-line'>{}</span>"},"ja468:8.2":{"pli":"jiṇṇakaṁ gatayobbanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja468:8.3":{"pli":"Pahu santo na posissaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja468:8.4":{"pli":"iti pacchānutappati. ","html":"<span class='verse-line'>{}</span></p>"},"ja468:9.1":{"pli":"Ācariyamanusatthāraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja468:9.2":{"pli":"sabbakāmarasāharaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja468:9.3":{"pli":"Pitaraṁ atimaññissaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja468:9.4":{"pli":"iti pacchānutappati. ","html":"<span class='verse-line'>{}</span></p>"},"ja468:10.1":{"pli":"Samaṇe brāhmaṇe cāpi, ","html":"<p><span class='verse-line'>{}</span>"},"ja468:10.2":{"pli":"sīlavante bahussute; ","html":"<span class='verse-line'>{}</span>"},"ja468:10.3":{"pli":"Na pubbe payirupāsissaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja468:10.4":{"pli":"iti pacchānutappati. ","html":"<span class='verse-line'>{}</span></p>"},"ja468:11.1":{"pli":"Sādhu hoti tapo ciṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"ja468:11.2":{"pli":"santo ca payirupāsito; ","html":"<span class='verse-line'>{}</span>"},"ja468:11.3":{"pli":"Na ca pubbe tapo ciṇṇo, ","html":"<span class='verse-line'>{}</span>"},"ja468:11.4":{"pli":"iti pacchānutappati. ","html":"<span class='verse-line'>{}</span></p>"},"ja468:12.1":{"pli":"Yo ca etāni ṭhānāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja468:12.2":{"pli":"yoniso paṭipajjati; ","html":"<span class='verse-line'>{}</span>"},"ja468:12.3":{"pli":"Karaṁ purisakiccāni, ","html":"<span class='verse-line'>{}</span>"},"ja468:12.4":{"pli":"sa pacchā nānutappatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja468:13.1":{"pli":"Janasandhajātakaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja469":{"ja469:0.1":{"pli":"Jātaka ","html":"<article id='ja469'><header><ul><li class='division'>{}</li>"},"ja469:0.2":{"pli":"Dvādasakanipāta ","html":"<li>{}</li>"},"ja469:0.3":{"pli":"Cūḷakuṇālavagga ","html":"<li>{}</li></ul>"},"ja469:0.4":{"pli":"6. Mahākaṇhajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja469:1.1":{"pli":"“Kaṇho kaṇho ca ghoro ca, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja469:1.2":{"pli":"sukkadāṭho pabhāsavā; ","html":"<span class='verse-line'>{}</span>"},"ja469:1.3":{"pli":"Baddho pañcahi rajjūhi, ","html":"<span class='verse-line'>{}</span>"},"ja469:1.4":{"pli":"kiṁ ravi sunakho tava”. ","html":"<span class='verse-line'>{}</span></p>"},"ja469:2.1":{"pli":"“Nāyaṁ migānamatthāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja469:2.2":{"pli":"usīnaka bhavissati; ","html":"<span class='verse-line'>{}</span>"},"ja469:2.3":{"pli":"Manussānaṁ anayo hutvā, ","html":"<span class='verse-line'>{}</span>"},"ja469:2.4":{"pli":"tadā kaṇho pamokkhati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja469:3.1":{"pli":"“Pattahatthā samaṇakā, ","html":"<p><span class='verse-line'>{}</span>"},"ja469:3.2":{"pli":"muṇḍā saṅghāṭipārutā; ","html":"<span class='verse-line'>{}</span>"},"ja469:3.3":{"pli":"Naṅgalehi kasissanti, ","html":"<span class='verse-line'>{}</span>"},"ja469:3.4":{"pli":"tadā kaṇho pamokkhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja469:4.1":{"pli":"Tapassiniyo pabbajitā, ","html":"<p><span class='verse-line'>{}</span>"},"ja469:4.2":{"pli":"muṇḍā saṅghāṭipārutā; ","html":"<span class='verse-line'>{}</span>"},"ja469:4.3":{"pli":"Yadā loke gamissanti, ","html":"<span class='verse-line'>{}</span>"},"ja469:4.4":{"pli":"tadā kaṇho pamokkhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja469:5.1":{"pli":"Dīghottaroṭṭhā jaṭilā, ","html":"<p><span class='verse-line'>{}</span>"},"ja469:5.2":{"pli":"paṅkadantā rajassirā; ","html":"<span class='verse-line'>{}</span>"},"ja469:5.3":{"pli":"Iṇaṁ codāya gacchanti, ","html":"<span class='verse-line'>{}</span>"},"ja469:5.4":{"pli":"tadā kaṇho pamokkhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja469:6.1":{"pli":"Adhicca vede sāvittiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja469:6.2":{"pli":"yaññatantañca brāhmaṇā; ","html":"<span class='verse-line'>{}</span>"},"ja469:6.3":{"pli":"Bhatikāya yajissanti, ","html":"<span class='verse-line'>{}</span>"},"ja469:6.4":{"pli":"tadā kaṇho pamokkhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja469:7.1":{"pli":"Mātaraṁ pitarañcāpi, ","html":"<p><span class='verse-line'>{}</span>"},"ja469:7.2":{"pli":"jiṇṇakaṁ gatayobbanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja469:7.3":{"pli":"Pahū santo na bharanti, ","html":"<span class='verse-line'>{}</span>"},"ja469:7.4":{"pli":"tadā kaṇho pamokkhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja469:8.1":{"pli":"Mātaraṁ pitarañcāpi, ","html":"<p><span class='verse-line'>{}</span>"},"ja469:8.2":{"pli":"jiṇṇakaṁ gatayobbanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja469:8.3":{"pli":"Bālā tumheti vakkhanti, ","html":"<span class='verse-line'>{}</span>"},"ja469:8.4":{"pli":"tadā kaṇho pamokkhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja469:9.1":{"pli":"Ācariyabhariyaṁ sakhiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja469:9.2":{"pli":"mātulāniṁ pitucchakiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja469:9.3":{"pli":"Yadā loke gamissanti, ","html":"<span class='verse-line'>{}</span>"},"ja469:9.4":{"pli":"tadā kaṇho pamokkhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja469:10.1":{"pli":"Asicammaṁ gahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"ja469:10.2":{"pli":"khaggaṁ paggayha brāhmaṇā; ","html":"<span class='verse-line'>{}</span>"},"ja469:10.3":{"pli":"Panthaghātaṁ karissanti, ","html":"<span class='verse-line'>{}</span>"},"ja469:10.4":{"pli":"tadā kaṇho pamokkhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja469:11.1":{"pli":"Sukkacchavī vedhaverā, ","html":"<p><span class='verse-line'>{}</span>"},"ja469:11.2":{"pli":"thūlabāhū apātubhā; ","html":"<span class='verse-line'>{}</span>"},"ja469:11.3":{"pli":"Mittabhedaṁ karissanti, ","html":"<span class='verse-line'>{}</span>"},"ja469:11.4":{"pli":"tadā kaṇho pamokkhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja469:12.1":{"pli":"Māyāvino nekatikā, ","html":"<p><span class='verse-line'>{}</span>"},"ja469:12.2":{"pli":"asappurisacintakā; ","html":"<span class='verse-line'>{}</span>"},"ja469:12.3":{"pli":"Yadā loke bhavissanti, ","html":"<span class='verse-line'>{}</span>"},"ja469:12.4":{"pli":"tadā kaṇho pamokkhatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja469:13.1":{"pli":"Mahākaṇhajātakaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja47":{"ja47:0.1":{"pli":"Jātaka ","eng":"Stories of Past Lives 47 ","html":"<article id='ja47'><header><ul><li class='division'>{}</li>"},"ja47:0.2":{"pli":"Ekakanipāta ","eng":"The Book of the Ones ","html":"<li>{}</li>"},"ja47:0.3":{"pli":"Atthakāmavagga ","eng":"Wanting to Help ","html":"<li>{}</li></ul>"},"ja47:0.4":{"pli":"7. Vāruṇidūsakajātaka ","eng":"Spoiling the Toddy: a past life story ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja47:1.1":{"pli":"“Na ve anatthakusalena, ","eng":"Surely not with one who misunderstands the meaning ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>","comm":"The brewer’s apprentice ruins a batch of toddy due to misunderstanding the instructions. "},"ja47:1.2":{"pli":"atthacariyā sukhāvahā; ","eng":"does good conduct lead to happiness. ","html":"<span class='verse-line'>{}</span>"},"ja47:1.3":{"pli":"Hāpeti atthaṁ dummedho, ","eng":"The simpleton destroys the good, ","html":"<span class='verse-line'>{}</span>"},"ja47:1.4":{"pli":"koṇḍañño vāruṇiṁ yathā”ti. ","eng":"as Koṇḍañña did the toddy. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja47:2.1":{"pli":"Vāruṇidūsakajātakaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}