":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap15:8.4":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap15:9.1":{"pli":"Itthaṁ sudaṁ āyasmā nando thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap15:10.1":{"pli":"Nandattherassāpadānaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap150":{"tha-ap150:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap150'><header><ul><li class='division'>{}</li>"},"tha-ap150:0.2":{"pli":"Chattavagga ","html":"<li>{}</li></ul>"},"tha-ap150:0.3":{"pli":"Phalakadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap150:1.1":{"pli":"“Yānakāro pure āsiṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap150:1.2":{"pli":"dārukamme susikkhito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap150:1.3":{"pli":"Candanaṁ phalakaṁ katvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap150:1.4":{"pli":"adāsiṁ lokabandhuno. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap150:2.1":{"pli":"Pabhāsati idaṁ byamhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap150:2.2":{"pli":"suvaṇṇassa sunimmitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap150:2.3":{"pli":"Hatthiyānaṁ assayānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap150:2.4":{"pli":"dibbayānaṁ upaṭṭhitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap150:3.1":{"pli":"Pāsādā sivikā ceva, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap150:3.2":{"pli":"Nibbattanti yadicchakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap150:3.3":{"pli":"Akkhobhaṁ ratanaṁ mayhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap150:3.4":{"pli":"Phalakassa idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap150:4.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap150:4.2":{"pli":"phalakaṁ yamahaṁ 