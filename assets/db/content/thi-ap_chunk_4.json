{"thi-ap19":{"thi-ap19:0.1":{"pli":"Therīapadāna ","html":"<article id='thi-ap19'><header><ul><li class='division'>{}</li>"},"thi-ap19:0.2":{"pli":"Ekūposathikavagga ","html":"<li>{}</li></ul>"},"thi-ap19:0.3":{"pli":"Uppalavaṇṇātherīapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"thi-ap19:1.1":{"pli":"“Bhikkhunī uppalavaṇṇā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"thi-ap19:1.2":{"pli":"iddhiyā pāramiṁ gatā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:1.3":{"pli":"Vanditvā satthuno pāde, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:1.4":{"pli":"idaṁ vacanamabravi. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:2.1":{"pli":"‘Nitthiṇṇā jātisaṁsāraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:2.2":{"pli":"pattāhaṁ acalaṁ padaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:2.3":{"pli":"Sabbadukkhaṁ mayā khīṇaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:2.4":{"pli":"ārocemi mahāmuni. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:3.1":{"pli":"Yāvatā parisā atthi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:3.2":{"pli":"pasannā jinasāsane; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:3.3":{"pli":"Yassā ca meparādhotthi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:3.4":{"pli":"khamantu jinasammukhā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:4.1":{"pli":"Saṁsāre saṁsarantiyā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:4.2":{"pli":"khalitaṁ me sace bhave; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:4.3":{"pli":"Ārocemi mahāvīra, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:4.4":{"pli":"aparādhaṁ khamassu taṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:5.1":{"pli":"‘Iddhiñcāpi nidassehi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:5.2":{"pli":"mama sāsanakārike; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:5.3":{"pli":"Catasso parisā ajja, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:5.4":{"pli":"kaṅkhaṁ chindāhi yāvatā’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:6.1":{"pli":"‘Dhītā tuyhaṁ mahāvīra, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:6.2":{"pli":"paññavanta jutindhara; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:6.3":{"pli":"Bahuñca dukkaraṁ kammaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:6.4":{"pli":"kataṁ me atidukkaraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:7.1":{"pli":"Uppalasseva me vaṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:7.2":{"pli":"nāmenuppalanāmikā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:7.3":{"pli":"Sāvikā te mahāvīra, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:7.4":{"pli":"pāde vandāmi cakkhuma. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:8.1":{"pli":"Rāhulo ca ahañceva, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:8.2":{"pli":"nekajātisate bahū; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:8.3":{"pli":"Ekasmiṁ sambhave jātā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:8.4":{"pli":"samānachandamānasā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:9.1":{"pli":"Nibbatti ekato hoti, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:9.2":{"pli":"jātiyāpi ca ekato; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:9.3":{"pli":"Pacchime bhave sampatte, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:9.4":{"pli":"ubhopi nānāsambhavā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:10.1":{"pli":"Putto ca rāhulo nāma, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:10.2":{"pli":"dhītā uppalasavhayā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:10.3":{"pli":"Passa vīra mamaṁ iddhiṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:10.4":{"pli":"balaṁ dassemi satthuno’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:11.1":{"pli":"Mahāsamudde caturo, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:11.2":{"pli":"pakkhipi hatthapātiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:11.3":{"pli":"Telaṁ hatthagatañceva, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:11.4":{"pli":"khiḍḍo komārako yathā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:12.1":{"pli":"Ubbattayitvā pathaviṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:12.2":{"pli":"pakkhipi hatthapātiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:12.3":{"pli":"Cittaṁ muñjaṁ yathā nāma, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:12.4":{"pli":"luñci komārako yuvā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:13.1":{"pli":"Cakkavāḷasamaṁ pāṇiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:13.2":{"pli":"chādayitvāna matthake; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:13.3":{"pli":"Vassāpetvāna phusitaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:13.4":{"pli":"nānāvaṇṇaṁ punappunaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:14.1":{"pli":"Bhūmiṁ udukkhalaṁ katvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:14.2":{"pli":"dhaññaṁ katvāna sakkharaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:14.3":{"pli":"Sineruṁ musalaṁ katvā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:14.4":{"pli":"maddi komārikā yathā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:15.1":{"pli":"‘Dhītāhaṁ buddhaseṭṭhassa, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:15.2":{"pli":"nāmenuppalasavhayā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:15.3":{"pli":"Abhiññāsu vasībhūtā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:15.4":{"pli":"tava sāsanakārikā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:16.1":{"pli":"Nānāvikubbanaṁ katvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:16.2":{"pli":"dassetvā lokanāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:16.3":{"pli":"Nāmagottañca sāvetvā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:16.4":{"pli":"pāde vandāmi cakkhuma. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:17.1":{"pli":"Iddhīsu ca vasī homi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:17.2":{"pli":"dibbāya sotadhātuyā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:17.3":{"pli":"Cetopariyañāṇassa, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:17.4":{"pli":"vasī homi mahāmune. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:18.1":{"pli":"Pubbenivāsaṁ jānāmi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:18.2":{"pli":"dibbacakkhu visodhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:18.3":{"pli":"Sabbāsavā parikkhīṇā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:18.4":{"pli":"natthi dāni punabbhavo. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:19.1":{"pli":"Atthadhammaniruttīsu, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:19.2":{"pli":"Paṭibhāne tatheva ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:19.3":{"pli":"Ñāṇaṁ me vimalaṁ suddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:19.4":{"pli":"Sabhāvena mahesino. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:20.1":{"pli":"Purimānaṁ jinaggānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:20.2":{"pli":"saṅgamaṁ te nidassitaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:20.3":{"pli":"Adhikāraṁ bahuṁ mayhaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:20.4":{"pli":"tuyhatthāya mahāmuni. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:21.1":{"pli":"Yaṁ mayā pūritaṁ kammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:21.2":{"pli":"Kusalaṁ sara me muni; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:21.3":{"pli":"Tavatthāya mahāvīra, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:21.4":{"pli":"Puññaṁ upacitaṁ mayā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:22.1":{"pli":"Abhabbaṭṭhāne vajjetvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:22.2":{"pli":"vārayantī anācaraṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:22.3":{"pli":"Tavatthāya mahāvīra, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:22.4":{"pli":"cattaṁ me jīvituttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:23.1":{"pli":"Dasakoṭisahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:23.2":{"pli":"adāsiṁ mama jīvitaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:23.3":{"pli":"Pariccattā ca me homi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:23.4":{"pli":"tavatthāya mahāmuni’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:24.1":{"pli":"Tadātivimhitā sabbā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:24.2":{"pli":"sirasāva katañjalī; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:24.3":{"pli":"‘Avocayye kathaṁ āsi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:24.4":{"pli":"atuliddhiparakkamā’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:25.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:25.2":{"pli":"nāgakaññā ahaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:25.3":{"pli":"Vimalā nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:25.4":{"pli":"kaññānaṁ sādhusammatā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:26.1":{"pli":"Mahorago mahānāgo, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:26.2":{"pli":"pasanno jinasāsane; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:26.3":{"pli":"Padumuttaraṁ mahātejaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:26.4":{"pli":"nimantesi sasāvakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:27.1":{"pli":"Ratanamayaṁ maṇḍapaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:27.2":{"pli":"pallaṅkaṁ ratanāmayaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:27.3":{"pli":"Ratanaṁ vālukākiṇṇaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:27.4":{"pli":"upabhogaṁ ratanāmayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:28.1":{"pli":"Maggañca paṭiyādesi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:28.2":{"pli":"ratanaddhajabhūsitaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:28.3":{"pli":"Paccuggantvāna sambuddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:28.4":{"pli":"vajjanto tūriyehi so. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:29.1":{"pli":"Parisāhi ca catūhi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:29.2":{"pli":"parivuto lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:29.3":{"pli":"Mahoragassa bhavane, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:29.4":{"pli":"nisīdi paramāsane. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:30.1":{"pli":"Annaṁ pānaṁ khādanīyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:30.2":{"pli":"bhojanañca mahārahaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:30.3":{"pli":"Varaṁ varañca pādāsi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:30.4":{"pli":"nāgarājā mahāyasaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:31.1":{"pli":"Bhuñjitvāna sambuddho, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:31.2":{"pli":"pattaṁ dhovitvā yoniso; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:31.3":{"pli":"Anumodanīyaṅkāsi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:31.4":{"pli":"nāgakaññā mahiddhikā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:32.1":{"pli":"Sabbaññuṁ phullitaṁ disvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:32.2":{"pli":"nāgakaññā mahāyasaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:32.3":{"pli":"Pasannaṁ satthuno cittaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:32.4":{"pli":"sunibandhañca mānasaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:33.1":{"pli":"Mamañca cittamaññāya, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:33.2":{"pli":"jalajuttamanāmako; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:33.3":{"pli":"Tasmiṁ khaṇe mahāvīro, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:33.4":{"pli":"bhikkhuniṁ dassayiddhiyā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:34.1":{"pli":"Iddhī anekā dassesi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:34.2":{"pli":"bhikkhunī sā visāradā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:34.3":{"pli":"Pamoditā vedajātā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:34.4":{"pli":"satthāraṁ idamabravi. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:35.1":{"pli":"‘Addasāhaṁ imaṁ iddhiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:35.2":{"pli":"sumanaṁ itarāyapi; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:35.3":{"pli":"Kathaṁ ahosi sā vīra, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:35.4":{"pli":"iddhiyā suvisāradā’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:36.1":{"pli":"‘Orasā mukhato jātā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:36.2":{"pli":"dhītā mama mahiddhikā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:36.3":{"pli":"Mamānusāsanikarā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:36.4":{"pli":"iddhiyā suvisāradā’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:37.1":{"pli":"Buddhassa vacanaṁ sutvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:37.2":{"pli":"evaṁ patthesahaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:37.3":{"pli":"‘Ahampi tādisā homi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:37.4":{"pli":"iddhiyā suvisāradā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:38.1":{"pli":"Pamoditāhaṁ sumanā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:38.2":{"pli":"patthe uttamamānasā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:38.3":{"pli":"Anāgatamhi addhāne, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:38.4":{"pli":"īdisā homi nāyaka’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:39.1":{"pli":"Maṇimayamhi pallaṅke, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:39.2":{"pli":"maṇḍapamhi pabhassare; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:39.3":{"pli":"Annapānena tappetvā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:39.4":{"pli":"sasaṅghaṁ lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:40.1":{"pli":"Nāgānaṁ pavaraṁ pupphaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:40.2":{"pli":"aruṇaṁ nāma uppalaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:40.3":{"pli":"‘Vaṇṇaṁ me īdisaṁ hotu’, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:40.4":{"pli":"pūjesiṁ lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:41.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:41.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:41.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:41.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:42.1":{"pli":"Tato cutāhaṁ manuje, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:42.2":{"pli":"upapannā sayambhuno; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:42.3":{"pli":"Uppalehi paṭicchannaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:42.4":{"pli":"piṇḍapātamadāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:43.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:43.2":{"pli":"vipassī nāma nāyako; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:43.3":{"pli":"Uppajji cārudassano, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:43.4":{"pli":"sabbadhammesu cakkhumā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:44.1":{"pli":"Seṭṭhidhītā tadā hutvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:44.2":{"pli":"bārāṇasipuruttame; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:44.3":{"pli":"Nimantetvāna sambuddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:44.4":{"pli":"sasaṅghaṁ lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:45.1":{"pli":"Mahādānaṁ daditvāna, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:45.2":{"pli":"uppalehi vināyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:45.3":{"pli":"Pūjayitvā cetasāva, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:45.4":{"pli":"vaṇṇasobhaṁ apatthayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:46.1":{"pli":"Imamhi bhaddake kappe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:46.2":{"pli":"brahmabandhu mahāyaso; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:46.3":{"pli":"Kassapo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:46.4":{"pli":"uppajji vadataṁ varo. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:47.1":{"pli":"Upaṭṭhāko mahesissa, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:47.2":{"pli":"tadā āsi narissaro; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:47.3":{"pli":"Kāsirājā kikī nāma, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:47.4":{"pli":"bārāṇasipuruttame. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:48.1":{"pli":"Tassāsiṁ dutiyā dhītā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:48.2":{"pli":"samaṇaguttasavhayā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:48.3":{"pli":"Dhammaṁ sutvā jinaggassa, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:48.4":{"pli":"pabbajjaṁ samarocayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:49.1":{"pli":"Anujāni na no tāto, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:49.2":{"pli":"agāreva tadā mayaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:49.3":{"pli":"Vīsavassasahassāni, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:49.4":{"pli":"vicarimha atanditā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:50.1":{"pli":"Komāribrahmacariyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:50.2":{"pli":"rājakaññā sukhedhitā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:50.3":{"pli":"Buddhopaṭṭhānaniratā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:50.4":{"pli":"muditā sattadhītaro. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:51.1":{"pli":"Samaṇī samaṇaguttā ca, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:51.2":{"pli":"bhikkhunī bhikkhudāyikā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:51.3":{"pli":"Dhammā ceva sudhammā ca, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:51.4":{"pli":"sattamī saṅghadāyikā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:52.1":{"pli":"Ahaṁ khemā ca sappaññā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:52.2":{"pli":"paṭācārā ca kuṇḍalā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:52.3":{"pli":"Kisāgotamī dhammadinnā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:52.4":{"pli":"visākhā hoti sattamī. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:53.1":{"pli":"Tehi kammehi sukatehi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:53.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:53.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:53.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:54.1":{"pli":"Tato cutā manussesu, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:54.2":{"pli":"upapannā mahākule; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:54.3":{"pli":"Pītaṁ maṭṭhaṁ varaṁ dussaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:54.4":{"pli":"adaṁ arahato ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:55.1":{"pli":"Tato cutāriṭṭhapure, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:55.2":{"pli":"jātā vippakule ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:55.3":{"pli":"Dhītā tiriṭivacchassa, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:55.4":{"pli":"ummādantī manoharā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:56.1":{"pli":"Tato cutā janapade, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:56.2":{"pli":"kule aññatare ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:56.3":{"pli":"Pasūtā nātiphītamhi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:56.4":{"pli":"sāliṁ gopemahaṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:57.1":{"pli":"Disvā paccekasambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:57.2":{"pli":"pañcalājāsatānihaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:57.3":{"pli":"Datvā padumacchannāni, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:57.4":{"pli":"pañca puttasatānihaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:58.1":{"pli":"Patthayiṁ tepi patthesuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:58.2":{"pli":"madhuṁ datvā sayambhuno; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:58.3":{"pli":"Tato cutā araññehaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:58.4":{"pli":"ajāyiṁ padumodare. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:59.1":{"pli":"Kāsirañño mahesīhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:59.2":{"pli":"hutvā sakkatapūjitā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:59.3":{"pli":"Ajaniṁ rājaputtānaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:59.4":{"pli":"anūnaṁ satapañcakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:60.1":{"pli":"Yadā te yobbanappattā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:60.2":{"pli":"kīḷantā jalakīḷitaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:60.3":{"pli":"Disvā opattapadumaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:60.4":{"pli":"āsuṁ paccekanāyakā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:61.1":{"pli":"Sāhaṁ tehi vinābhūtā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:61.2":{"pli":"sutavīrehi sokinī; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:61.3":{"pli":"Cutā isigilipasse, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:61.4":{"pli":"gāmakamhi ajāyihaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:62.1":{"pli":"Yadā buddhā sutamatī, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:62.2":{"pli":"sutānaṁ bhattunopi ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:62.3":{"pli":"Yāguṁ ādāya gacchantī, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:62.4":{"pli":"aṭṭha paccekanāyake. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:63.1":{"pli":"Bhikkhāya gāmaṁ gacchante, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:63.2":{"pli":"disvā putte anussariṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:63.3":{"pli":"Khīradhārā viniggacchi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:63.4":{"pli":"tadā me puttapemasā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:64.1":{"pli":"Tato tesaṁ adaṁ yāguṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:64.2":{"pli":"pasannā sehi pāṇibhi; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:64.3":{"pli":"Tato cutāhaṁ tidasaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:64.4":{"pli":"nandanaṁ upapajjahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:65.1":{"pli":"Anubhotvā sukhaṁ dukkhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:65.2":{"pli":"saṁsaritvā bhavābhave; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:65.3":{"pli":"Tavatthāya mahāvīra, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:65.4":{"pli":"pariccattañca jīvitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:66.1":{"pli":"Evaṁ bahuvidhaṁ dukkhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:66.2":{"pli":"sampattī ca bahubbidhā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:66.3":{"pli":"Pacchime bhave sampatte, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:66.4":{"pli":"jātā sāvatthiyaṁ pure. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:67.1":{"pli":"Mahādhanaseṭṭhikule, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:67.2":{"pli":"sukhite sajjite tathā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:67.3":{"pli":"Nānāratanapajjote, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:67.4":{"pli":"sabbakāmasamiddhine. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:68.1":{"pli":"Sakkatā pūjitā ceva, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:68.2":{"pli":"mānitāpacitā tathā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:68.3":{"pli":"Rūpasobhaggasampannā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:68.4":{"pli":"kulesu atisakkatā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:69.1":{"pli":"Atīva patthitā cāsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:69.2":{"pli":"rūpabhogasirīhi ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:69.3":{"pli":"Patthitā seṭṭhiputtehi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:69.4":{"pli":"anekehi satehipi. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:70.1":{"pli":"Agāraṁ pajahitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:70.2":{"pli":"pabbajiṁ anagāriyaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:70.3":{"pli":"Aḍḍhamāse asampatte, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:70.4":{"pli":"catusaccamapāpuṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:71.1":{"pli":"Iddhiyā abhinimmitvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:71.2":{"pli":"caturassaṁ rathaṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:71.3":{"pli":"Buddhassa pāde vandissaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:71.4":{"pli":"lokanāthassa tādino. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:72.1":{"pli":"‘Supupphitaggaṁ upagamma pādapaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:72.2":{"pli":"Ekā tuvaṁ tiṭṭhasi sālamūle; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:72.3":{"pli":"Na cāpi te dutiyo atthi koci, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:72.4":{"pli":"Bāle na tvaṁ bhāyasi dhuttakānaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:73.1":{"pli":"‘Sataṁ sahassānipi dhuttakānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:73.2":{"pli":"Samāgatā edisakā bhaveyyuṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:73.3":{"pli":"Lomaṁ na iñje na sampavedhe, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:73.4":{"pli":"Kiṁ me tuvaṁ māra karissaseko. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:74.1":{"pli":"Esā antaradhāyāmi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:74.2":{"pli":"kucchiṁ vā pavisāmi te; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:74.3":{"pli":"Bhamukantarikāyampi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:74.4":{"pli":"tiṭṭhantiṁ maṁ na dakkhasi. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:75.1":{"pli":"Cittasmiṁ vasībhūtāmhi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:75.2":{"pli":"iddhipādā subhāvitā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:75.3":{"pli":"Sabbabandhanamuttāmhi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:75.4":{"pli":"na taṁ bhāyāmi āvuso. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:76.1":{"pli":"Sattisūlūpamā kāmā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:76.2":{"pli":"khandhāsaṁ adhikuṭṭanā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:76.3":{"pli":"Yaṁ tvaṁ kāmaratiṁ brūsi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:76.4":{"pli":"aratī dāni sā mama. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:77.1":{"pli":"Sabbattha vihatā nandī, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:77.2":{"pli":"tamokhandho padālito; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:77.3":{"pli":"Evaṁ jānāhi pāpima, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:77.4":{"pli":"nihato tvamasi antaka’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:78.1":{"pli":"Jino tamhi guṇe tuṭṭho, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:78.2":{"pli":"etadagge ṭhapesi maṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:78.3":{"pli":"Aggā iddhimatīnanti, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:78.4":{"pli":"parisāsu vināyako. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:79.1":{"pli":"Pariciṇṇo mayā satthā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:79.2":{"pli":"kataṁ buddhassa sāsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:79.3":{"pli":"Ohito garuko bhāro, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:79.4":{"pli":"bhavanettisamūhatā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:80.1":{"pli":"Yassatthāya pabbajitā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:80.2":{"pli":"agārasmānagāriyaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:80.3":{"pli":"So me attho anuppatto, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:80.4":{"pli":"sabbasaṁyojanakkhayo. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:81.1":{"pli":"Cīvaraṁ piṇḍapātañca, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:81.2":{"pli":"paccayaṁ sayanāsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:81.3":{"pli":"Khaṇena upanāmenti, ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:81.4":{"pli":"sahassāni samantato. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:82.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:82.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:82.3":{"pli":"viharāmi anāsavā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:83.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:83.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:83.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap19:84.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap19:84.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap19:84.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"thi-ap19:85.1":{"pli":"Itthaṁ sudaṁ uppalavaṇṇā bhikkhunī imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"thi-ap19:86.1":{"pli":"Uppalavaṇṇātheriyāpadānaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"thi-ap2":{"thi-ap2:0.1":{"pli":"Therīapadāna ","html":"<article id='thi-ap2'><header><ul><li class='division'>{}</li>"},"thi-ap2:0.2":{"pli":"Sumedhāvagga ","html":"<li>{}</li></ul>"},"thi-ap2:0.3":{"pli":"2 Mekhalādāyikātherīapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"thi-ap2:1.1":{"pli":"“Siddhatthassa bhagavato, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"thi-ap2:1.2":{"pli":"thūpakārāpikā ahuṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap2:1.3":{"pli":"Mekhalikā mayā dinnā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap2:1.4":{"pli":"navakammāya satthuno. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap2:2.1":{"pli":"Niṭṭhite ca mahāthūpe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap2:2.2":{"pli":"mekhalaṁ punadāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap2:2.3":{"pli":"Lokanāthassa munino, ","html":"<span class='verse-line'>{}</span>"},"thi-ap2:2.4":{"pli":"pasannā sehi pāṇibhi. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap2:3.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap2:3.2":{"pli":"yaṁ mekhalamadaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap2:3.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap2:3.4":{"pli":"thūpakārassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap2:4.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap2:4.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap2:4.3":{"pli":"viharāmi anāsavā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap2:5.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap2:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap2:5.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap2:6.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap2:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap2:6.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"thi-ap2:7.1":{"pli":"Itthaṁ sudaṁ mekhalādāyikā bhikkhunī imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"thi-ap2:8.1":{"pli":"Mekhalādāyikātheriyāpadānaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}