{"ja524":{"ja524:0.1":{"pli":"Jātaka ","html":"<article id='ja524'><header><ul><li class='division'>{}</li>"},"ja524:0.2":{"pli":"Cattālīsanipāta ","html":"<li>{}</li>"},"ja524:0.3":{"pli":"Tesakuṇavagga ","html":"<li>{}</li></ul>"},"ja524:0.4":{"pli":"4. Saṅkhapālajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja524:1.1":{"pli":"“Ariyāvakāsosi pasannanetto, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja524:1.2":{"pli":"Maññe bhavaṁ pabbajito kulamhā; ","html":"<span class='verse-line'>{}</span>"},"ja524:1.3":{"pli":"Kathaṁ nu vittāni pahāya bhoge, ","html":"<span class='verse-line'>{}</span>"},"ja524:1.4":{"pli":"Pabbaji nikkhamma gharā sapañña”. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:2.1":{"pli":"“Sayaṁ vimānaṁ naradeva disvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:2.2":{"pli":"Mahānubhāvassa mahoragassa; ","html":"<span class='verse-line'>{}</span>"},"ja524:2.3":{"pli":"Disvāna puññāna mahāvipākaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja524:2.4":{"pli":"Saddhāyahaṁ pabbajitomhi rāja”. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:3.1":{"pli":"“Na kāmakāmā na bhayā na dosā, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:3.2":{"pli":"Vācaṁ musā pabbajitā bhaṇanti; ","html":"<span class='verse-line'>{}</span>"},"ja524:3.3":{"pli":"Akkhāhi me pucchito etamatthaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja524:3.4":{"pli":"Sutvāna me jāyihitippasādo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:4.1":{"pli":"“Vāṇijja raṭṭhādhipa gacchamāno, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:4.2":{"pli":"Pathe addasāsimhi bhojaputte; ","html":"<span class='verse-line'>{}</span>"},"ja524:4.3":{"pli":"Pavaddhakāyaṁ uragaṁ mahantaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja524:4.4":{"pli":"Ādāya gacchante pamodamāne. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:5.1":{"pli":"Sohaṁ samāgamma janinda tehi, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:5.2":{"pli":"Pahaṭṭhalomo avacamhi bhīto; ","html":"<span class='verse-line'>{}</span>"},"ja524:5.3":{"pli":"‘Kuhiṁ ayaṁ nīyati bhīmakāyo, ","html":"<span class='verse-line'>{}</span>"},"ja524:5.4":{"pli":"Nāgena kiṁ kāhatha bhojaputtā’. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:6.1":{"pli":"‘Nāgo ayaṁ nīyati bhojanatthā, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:6.2":{"pli":"Pavaddhakāyo urago mahanto; ","html":"<span class='verse-line'>{}</span>"},"ja524:6.3":{"pli":"Sāduñca thūlañca muduñca maṁsaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja524:6.4":{"pli":"Na tvaṁ rasaññāsi videhaputta. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:7.1":{"pli":"Ito mayaṁ gantvā sakaṁ niketaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:7.2":{"pli":"Ādāya satthāni vikopayitvā; ","html":"<span class='verse-line'>{}</span>"},"ja524:7.3":{"pli":"Maṁsāni bhokkhāma pamodamānā, ","html":"<span class='verse-line'>{}</span>"},"ja524:7.4":{"pli":"Mayañhi ve sattavo pannagānaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:8.1":{"pli":"‘Sace ayaṁ nīyati bhojanatthā, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:8.2":{"pli":"Pavaddhakāyo urago mahanto; ","html":"<span class='verse-line'>{}</span>"},"ja524:8.3":{"pli":"Dadāmi vo balibaddāni soḷasa, ","html":"<span class='verse-line'>{}</span>"},"ja524:8.4":{"pli":"Nāgaṁ imaṁ muñcatha bandhanasmā’. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:9.1":{"pli":"‘Addhā hi no bhakkho ayaṁ manāpo, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:9.2":{"pli":"Bahū ca no uragā bhuttapubbā; ","html":"<span class='verse-line'>{}</span>"},"ja524:9.3":{"pli":"Karoma te taṁ vacanaṁ aḷāra, ","html":"<span class='verse-line'>{}</span>"},"ja524:9.4":{"pli":"Mittañca no hohi videhaputta’. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:10.1":{"pli":"Tadāssu te bandhanā mocayiṁsu, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:10.2":{"pli":"Yaṁ natthuto paṭimokkassa pāse; ","html":"<span class='verse-line'>{}</span>"},"ja524:10.3":{"pli":"Mutto ca so bandhanā nāgarājā, ","html":"<span class='verse-line'>{}</span>"},"ja524:10.4":{"pli":"Pakkāmi pācīnamukho muhuttaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:11.1":{"pli":"Gantvāna pācīnamukho muhuttaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:11.2":{"pli":"Puṇṇehi nettehi palokayī maṁ; ","html":"<span class='verse-line'>{}</span>"},"ja524:11.3":{"pli":"Tadāssahaṁ piṭṭhito anvagacchiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja524:11.4":{"pli":"Dasaṅguliṁ añjaliṁ paggahetvā. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:12.1":{"pli":"‘Gaccheva kho tvaṁ taramānarūpo, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:12.2":{"pli":"Mā taṁ amittā punaraggahesuṁ; ","html":"<span class='verse-line'>{}</span>"},"ja524:12.3":{"pli":"Dukkho hi luddehi punā samāgamo, ","html":"<span class='verse-line'>{}</span>"},"ja524:12.4":{"pli":"Adassanaṁ bhojaputtāna gaccha’. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:13.1":{"pli":"Agamāsi so rahadaṁ vippasannaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:13.2":{"pli":"Nīlobhāsaṁ ramaṇīyaṁ sutitthaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja524:13.3":{"pli":"Samotataṁ jambuhi vetasāhi, ","html":"<span class='verse-line'>{}</span>"},"ja524:13.4":{"pli":"Pāvekkhi nittiṇṇabhayo patīto. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:14.1":{"pli":"So taṁ pavissa na cirassa nāgo, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:14.2":{"pli":"Dibbena me pāturahuṁ janinda; ","html":"<span class='verse-line'>{}</span>"},"ja524:14.3":{"pli":"Upaṭṭhahī maṁ pitaraṁva putto, ","html":"<span class='verse-line'>{}</span>"},"ja524:14.4":{"pli":"Hadayaṅgamaṁ kaṇṇasukhaṁ bhaṇanto. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:15.1":{"pli":"‘Tvaṁ mesi mātā ca pitā aḷāra, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:15.2":{"pli":"Abbhantaro pāṇadado sahāyo; ","html":"<span class='verse-line'>{}</span>"},"ja524:15.3":{"pli":"Sakañca iddhiṁ paṭilābhakosmi, ","html":"<span class='verse-line'>{}</span>"},"ja524:15.4":{"pli":"Aḷāra passa me nivesanāni; ","html":"<span class='verse-line'>{}</span>"},"ja524:15.5":{"pli":"Pahūtabhakkhaṁ bahuannapānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja524:15.6":{"pli":"Masakkasāraṁ viya vāsavassa. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:16.1":{"pli":"Taṁ bhūmibhāgehi upetarūpaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:16.2":{"pli":"Asakkharā ceva mudū subhā ca; ","html":"<span class='verse-line'>{}</span>"},"ja524:16.3":{"pli":"Nīcattiṇā apparajā ca bhūmi, ","html":"<span class='verse-line'>{}</span>"},"ja524:16.4":{"pli":"Pāsādikā yattha jahanti sokaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:17.1":{"pli":"Anāvakulā veḷuriyūpanīlā, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:17.2":{"pli":"Catuddisaṁ ambavanaṁ surammaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja524:17.3":{"pli":"Pakkā ca pesī ca phalā suphullā, ","html":"<span class='verse-line'>{}</span>"},"ja524:17.4":{"pli":"Niccotukā dhārayantī phalāni’. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:18.1":{"pli":"Tesaṁ vanānaṁ naradeva majjhe, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:18.2":{"pli":"Nivesanaṁ bhassarasannikāsaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja524:18.3":{"pli":"Rajataggaḷaṁ sovaṇṇamayaṁ uḷāraṁ, ","html":"<span class='verse-line'>{}</span>"},"ja524:18.4":{"pli":"Obhāsatī vijjurivantalikkhe. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:19.1":{"pli":"Maṇīmayā soṇṇamayā uḷārā, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:19.2":{"pli":"Anekacittā satataṁ sunimmitā; ","html":"<span class='verse-line'>{}</span>"},"ja524:19.3":{"pli":"Paripūrā kaññāhi alaṅkatābhi, ","html":"<span class='verse-line'>{}</span>"},"ja524:19.4":{"pli":"Suvaṇṇakāyūradharāhi rāja. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:20.1":{"pli":"So saṅkhapālo taramānarūpo, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:20.2":{"pli":"Pāsādamāruyha anomavaṇṇo; ","html":"<span class='verse-line'>{}</span>"},"ja524:20.3":{"pli":"Sahassathambhaṁ atulānubhāvaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja524:20.4":{"pli":"Yatthassa bhariyā mahesī ahosi. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:21.1":{"pli":"Ekā ca nārī taramānarūpā, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:21.2":{"pli":"Ādāya veḷuriyamayaṁ mahagghaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja524:21.3":{"pli":"Subhaṁ maṇiṁ jātimantūpapannaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja524:21.4":{"pli":"Acoditā āsanamabbhihāsi. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:22.1":{"pli":"Tato maṁ urago hatthe gahetvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:22.2":{"pli":"Nisīdayī pāmukhaāsanasmiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja524:22.3":{"pli":"‘Idamāsanaṁ atra bhavaṁ nisīdatu, ","html":"<span class='verse-line'>{}</span>"},"ja524:22.4":{"pli":"Bhavañhi me aññataro garūnaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:23.1":{"pli":"Aññā ca nārī taramānarūpā, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:23.2":{"pli":"Ādāya vāriṁ upasaṅkamitvā; ","html":"<span class='verse-line'>{}</span>"},"ja524:23.3":{"pli":"Pādāni pakkhālayī me janinda, ","html":"<span class='verse-line'>{}</span>"},"ja524:23.4":{"pli":"Bhariyāva bhattū patino piyassa. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:24.1":{"pli":"Aparā ca nārī taramānarūpā, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:24.2":{"pli":"Paggayha sovaṇṇamayāya pātiyā; ","html":"<span class='verse-line'>{}</span>"},"ja524:24.3":{"pli":"Anekasūpaṁ vividhaṁ viyañjanaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja524:24.4":{"pli":"Upanāmayī bhatta manuññarūpaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:25.1":{"pli":"Turiyehi maṁ bhārata bhuttavantaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:25.2":{"pli":"Upaṭṭhahuṁ bhattu mano viditvā; ","html":"<span class='verse-line'>{}</span>"},"ja524:25.3":{"pli":"Tatuttariṁ maṁ nipatī mahantaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja524:25.4":{"pli":"Dibbehi kāmehi anappakehi. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:26.1":{"pli":"‘Bhariyā mametā tisatā aḷāra, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:26.2":{"pli":"Sabbattamajjhā padumuttarābhā; ","html":"<span class='verse-line'>{}</span>"},"ja524:26.3":{"pli":"Aḷāra etāssu te kāmakārā, ","html":"<span class='verse-line'>{}</span>"},"ja524:26.4":{"pli":"Dadāmi te tā paricārayassu’. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:27.1":{"pli":"Saṁvaccharaṁ dibbarasānubhutvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:27.2":{"pli":"Tadāssuhaṁ uttarimajjhabhāsiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja524:27.3":{"pli":"‘Nāgassidaṁ kinti kathañca laddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja524:27.4":{"pli":"Kathajjhagamāsi vimānaseṭṭhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:28.1":{"pli":"Adhiccaladdhaṁ pariṇāmajaṁ te, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:28.2":{"pli":"Sayaṅkataṁ udāhu devehi dinnaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja524:28.3":{"pli":"Pucchāmi taṁ nāgarājetamatthaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja524:28.4":{"pli":"Kathajjhagamāsi vimānaseṭṭhaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:29.1":{"pli":"‘Nādhiccaladdhaṁ na pariṇāmajaṁ me, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:29.2":{"pli":"Na sayaṅkataṁ nāpi devehi dinnaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja524:29.3":{"pli":"Sakehi kammehi apāpakehi, ","html":"<span class='verse-line'>{}</span>"},"ja524:29.4":{"pli":"Puññehi me laddhamidaṁ vimānaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:30.1":{"pli":"‘Kiṁ te vataṁ kiṁ pana brahmacariyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:30.2":{"pli":"Kissa suciṇṇassa ayaṁ vipāko; ","html":"<span class='verse-line'>{}</span>"},"ja524:30.3":{"pli":"Akkhāhi me nāgarājetamatthaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja524:30.4":{"pli":"Kathaṁ nu te laddhamidaṁ vimānaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:31.1":{"pli":"‘Rājā ahosiṁ magadhānamissaro, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:31.2":{"pli":"Duyyodhano nāma mahānubhāvo; ","html":"<span class='verse-line'>{}</span>"},"ja524:31.3":{"pli":"So ittaraṁ jīvitaṁ saṁviditvā, ","html":"<span class='verse-line'>{}</span>"},"ja524:31.4":{"pli":"Asassataṁ vipariṇāmadhammaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:32.1":{"pli":"Annañca pānañca pasannacitto, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:32.2":{"pli":"Sakkacca dānaṁ vipulaṁ adāsiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja524:32.3":{"pli":"Opānabhūtaṁ me gharaṁ tadāsi, ","html":"<span class='verse-line'>{}</span>"},"ja524:32.4":{"pli":"Santappitā samaṇabrāhmaṇā ca. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:33.1":{"pli":"Mālañca gandhañca vilepanañca, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:33.2":{"pli":"Padīpiyaṁ yānamupassayañca; ","html":"<span class='verse-line'>{}</span>"},"ja524:33.3":{"pli":"Acchādanaṁ seyyamathannapānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja524:33.4":{"pli":"Sakkacca dānāni adamha tattha. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:34.1":{"pli":"Taṁ me vataṁ taṁ pana brahmacariyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:34.2":{"pli":"Tassa suciṇṇassa ayaṁ vipāko; ","html":"<span class='verse-line'>{}</span>"},"ja524:34.3":{"pli":"Teneva me laddhamidaṁ vimānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja524:34.4":{"pli":"Pahūtabhakkhaṁ bahuannapānaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja524:34.5":{"pli":"Naccehi gītehi cupetarūpaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja524:34.6":{"pli":"Ciraṭṭhitikaṁ na ca sassatāyaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:35.1":{"pli":"‘Appānubhāvā taṁ mahānubhāvaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:35.2":{"pli":"Tejassinaṁ hanti atejavanto; ","html":"<span class='verse-line'>{}</span>"},"ja524:35.3":{"pli":"Kimeva dāṭhāvudha kiṁ paṭicca, ","html":"<span class='verse-line'>{}</span>"},"ja524:35.4":{"pli":"Hatthattamāgacchi vanibbakānaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:36.1":{"pli":"Bhayaṁ nu te anvagataṁ mahantaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:36.2":{"pli":"Tejo nu te nānvagaṁ dantamūlaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja524:36.3":{"pli":"Kimeva dāṭhāvudha kiṁ paṭicca, ","html":"<span class='verse-line'>{}</span>"},"ja524:36.4":{"pli":"Kilesamāpajji vanibbakānaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:37.1":{"pli":"‘Na me bhayaṁ anvagataṁ mahantaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:37.2":{"pli":"Tejo na sakkā mama tehi hantuṁ; ","html":"<span class='verse-line'>{}</span>"},"ja524:37.3":{"pli":"Satañca dhammāni sukittitāni, ","html":"<span class='verse-line'>{}</span>"},"ja524:37.4":{"pli":"Samuddavelāva duraccayāni. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:38.1":{"pli":"Cātuddasiṁ pañcadasiṁ aḷāra, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:38.2":{"pli":"Uposathaṁ niccamupāvasāmi; ","html":"<span class='verse-line'>{}</span>"},"ja524:38.3":{"pli":"Athāgamuṁ soḷasa bhojaputtā, ","html":"<span class='verse-line'>{}</span>"},"ja524:38.4":{"pli":"Rajjuṁ gahetvāna daḷhañca pāsaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:39.1":{"pli":"Bhetvāna nāsaṁ atikassa rajjuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:39.2":{"pli":"Nayiṁsu maṁ samparigayha luddā; ","html":"<span class='verse-line'>{}</span>"},"ja524:39.3":{"pli":"Etādisaṁ dukkhamahaṁ titikkhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja524:39.4":{"pli":"Uposathaṁ appaṭikopayanto’. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:40.1":{"pli":"‘Ekāyane taṁ pathe addasaṁsu, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:40.2":{"pli":"Balena vaṇṇena cupetarūpaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja524:40.3":{"pli":"Siriyā paññāya ca bhāvitosi, ","html":"<span class='verse-line'>{}</span>"},"ja524:40.4":{"pli":"Kiṁ patthayaṁ nāga tapo karosi’. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:41.1":{"pli":"‘Na puttahetū na dhanassa hetu, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:41.2":{"pli":"Na āyuno cāpi aḷāra hetu; ","html":"<span class='verse-line'>{}</span>"},"ja524:41.3":{"pli":"Manussayoniṁ abhipatthayāno, ","html":"<span class='verse-line'>{}</span>"},"ja524:41.4":{"pli":"Tasmā parakkamma tapo karomi’. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:42.1":{"pli":"‘Tvaṁ lohitakkho vihatantaraṁso, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:42.2":{"pli":"Alaṅkato kappitakesamassu; ","html":"<span class='verse-line'>{}</span>"},"ja524:42.3":{"pli":"Surosito lohitacandanena, ","html":"<span class='verse-line'>{}</span>"},"ja524:42.4":{"pli":"Gandhabbarājāva disā pabhāsasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:43.1":{"pli":"Deviddhipattosi mahānubhāvo, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:43.2":{"pli":"Sabbehi kāmehi samaṅgibhūto; ","html":"<span class='verse-line'>{}</span>"},"ja524:43.3":{"pli":"Pucchāmi taṁ nāgarājetamatthaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja524:43.4":{"pli":"Seyyo ito kena manussaloko’. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:44.1":{"pli":"‘Aḷāra nāññatra manussalokā, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:44.2":{"pli":"Suddhī va saṁvijjati saṁyamo vā; ","html":"<span class='verse-line'>{}</span>"},"ja524:44.3":{"pli":"Ahañca laddhāna manussayoniṁ, ","html":"<span class='verse-line'>{}</span>"},"ja524:44.4":{"pli":"Kāhāmi jātimaraṇassa antaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:45.1":{"pli":"‘Saṁvaccharo me vasato tavantike, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:45.2":{"pli":"Annena pānena upaṭṭhitosmi; ","html":"<span class='verse-line'>{}</span>"},"ja524:45.3":{"pli":"Āmantayitvāna palemi nāga, ","html":"<span class='verse-line'>{}</span>"},"ja524:45.4":{"pli":"Cirappavutthosmi ahaṁ janinda’. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:46.1":{"pli":"‘Puttā ca dārā anujīvino ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:46.2":{"pli":"Niccānusiṭṭhā upatiṭṭhathetaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja524:46.3":{"pli":"Kaccinnu taṁ nābhisapittha koci, ","html":"<span class='verse-line'>{}</span>"},"ja524:46.4":{"pli":"Piyañhi me dassanaṁ tuyhaṁ aḷāra’. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:47.1":{"pli":"‘Yathāpi mātū ca pitū agāre, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:47.2":{"pli":"Putto piyo paṭivihito vaseyya; ","html":"<span class='verse-line'>{}</span>"},"ja524:47.3":{"pli":"Tatopi mayhaṁ idhameva seyyo, ","html":"<span class='verse-line'>{}</span>"},"ja524:47.4":{"pli":"Cittañhi te nāga mayī pasannaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:48.1":{"pli":"‘Maṇī mamaṁ vijjati lohitaṅko, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:48.2":{"pli":"Dhanāharo maṇiratanaṁ uḷāraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja524:48.3":{"pli":"Ādāya tvaṁ gaccha sakaṁ niketaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja524:48.4":{"pli":"Laddhā dhanaṁ taṁ maṇimossajassu’. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:49.1":{"pli":"Diṭṭhā mayā mānusakāpi kāmā, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:49.2":{"pli":"Asassatā vipariṇāmadhammā; ","html":"<span class='verse-line'>{}</span>"},"ja524:49.3":{"pli":"Ādīnavaṁ kāmaguṇesu disvā, ","html":"<span class='verse-line'>{}</span>"},"ja524:49.4":{"pli":"Saddhāyahaṁ pabbajitomhi rāja. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:50.1":{"pli":"Dumapphalānīva patanti māṇavā, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:50.2":{"pli":"Daharā ca vuddhā ca sarīrabhedā; ","html":"<span class='verse-line'>{}</span>"},"ja524:50.3":{"pli":"Etampi disvā pabbajitomhi rāja, ","html":"<span class='verse-line'>{}</span>"},"ja524:50.4":{"pli":"Apaṇṇakaṁ sāmaññameva seyyo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:51.1":{"pli":"“Addhā have sevitabbā sapaññā, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:51.2":{"pli":"Bahussutā ye bahuṭhānacintino; ","html":"<span class='verse-line'>{}</span>"},"ja524:51.3":{"pli":"Nāgañca sutvāna tavañcaḷāra, ","html":"<span class='verse-line'>{}</span>"},"ja524:51.4":{"pli":"Kāhāmi puññāni anappakāni”. ","html":"<span class='verse-line'>{}</span></p>"},"ja524:52.1":{"pli":"“Addhā have sevitabbā sapaññā, ","html":"<p><span class='verse-line'>{}</span>"},"ja524:52.2":{"pli":"Bahussutā ye bahuṭhānacintino; ","html":"<span class='verse-line'>{}</span>"},"ja524:52.3":{"pli":"Nāgañca sutvāna mamañca rāja, ","html":"<span class='verse-line'>{}</span>"},"ja524:52.4":{"pli":"Karohi puññāni anappakānī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja524:53.1":{"pli":"Saṅkhapālajātakaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja525":{"ja525:0.1":{"pli":"Jātaka ","html":"<article id='ja525'><header><ul><li class='division'>{}</li>"},"ja525:0.2":{"pli":"Cattālīsanipāta ","html":"<li>{}</li>"},"ja525:0.3":{"pli":"Tesakuṇavagga ","html":"<li>{}</li></ul>"},"ja525:0.4":{"pli":"5 Cūḷasutasomajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja525:1.1":{"pli":"“Āmantayāmi nigamaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja525:1.2":{"pli":"mittāmacce parissaje; ","html":"<span class='verse-line'>{}</span>"},"ja525:1.3":{"pli":"Sirasmiṁ palitaṁ jātaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja525:1.4":{"pli":"pabbajjaṁ dāni rocahaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:2.1":{"pli":"“Abhumme kathaṁ nu bhaṇasi, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:2.2":{"pli":"Sallaṁ me deva urasi kappesi; ","html":"<span class='verse-line'>{}</span>"},"ja525:2.3":{"pli":"Sattasatā te bhariyā, ","html":"<span class='verse-line'>{}</span>"},"ja525:2.4":{"pli":"Kathaṁ nu te tā bhavissanti”. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:3.1":{"pli":"“Paññāyihinti etā, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:3.2":{"pli":"Daharā aññampi tā gamissanti; ","html":"<span class='verse-line'>{}</span>"},"ja525:3.3":{"pli":"Saggañcassa patthayāno, ","html":"<span class='verse-line'>{}</span>"},"ja525:3.4":{"pli":"Tena ahaṁ pabbajissāmi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:4.1":{"pli":"“Dulladdhaṁ me āsi sutasoma, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:4.2":{"pli":"Yassa te homahaṁ mātā; ","html":"<span class='verse-line'>{}</span>"},"ja525:4.3":{"pli":"Yaṁ me vilapantiyā, ","html":"<span class='verse-line'>{}</span>"},"ja525:4.4":{"pli":"Anapekkho pabbajasi deva. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:5.1":{"pli":"Dulladdhaṁ me āsi sutasoma, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:5.2":{"pli":"Yaṁ taṁ ahaṁ vijāyissaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja525:5.3":{"pli":"Yaṁ me vilapantiyā, ","html":"<span class='verse-line'>{}</span>"},"ja525:5.4":{"pli":"Anapekkho pabbajasi deva”. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:6.1":{"pli":"“Ko nāmeso dhammo, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:6.2":{"pli":"Sutasoma kā ca nāma pabbajjā; ","html":"<span class='verse-line'>{}</span>"},"ja525:6.3":{"pli":"Yaṁ no amhe jiṇṇe, ","html":"<span class='verse-line'>{}</span>"},"ja525:6.4":{"pli":"Anapekkho pabbajasi deva. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:7.1":{"pli":"Puttāpi tuyhaṁ bahavo, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:7.2":{"pli":"daharā appattayobbanā; ","html":"<span class='verse-line'>{}</span>"},"ja525:7.3":{"pli":"Mañjū tepi taṁ apassantā, ","html":"<span class='verse-line'>{}</span>"},"ja525:7.4":{"pli":"maññe dukkhaṁ nigacchanti”. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:8.1":{"pli":"“Puttehi ca me etehi, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:8.2":{"pli":"Daharehi appattayobbanehi; ","html":"<span class='verse-line'>{}</span>"},"ja525:8.3":{"pli":"Mañjūhi sabbehipi tumhehi, ","html":"<span class='verse-line'>{}</span>"},"ja525:8.4":{"pli":"Cirampi ṭhatvā vināsabhāvo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:9.1":{"pli":"“Chinnaṁ nu tuyhaṁ hadayaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:9.2":{"pli":"Adu te karuṇā ca natthi amhesu; ","html":"<span class='verse-line'>{}</span>"},"ja525:9.3":{"pli":"Yaṁ no vikandantiyo, ","html":"<span class='verse-line'>{}</span>"},"ja525:9.4":{"pli":"Anapekkho pabbajasi deva”. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:10.1":{"pli":"“Na ca mayhaṁ chinnaṁ hadayaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:10.2":{"pli":"Atthi karuṇāpi mayhaṁ tumhesu; ","html":"<span class='verse-line'>{}</span>"},"ja525:10.3":{"pli":"Saggañca patthayāno, ","html":"<span class='verse-line'>{}</span>"},"ja525:10.4":{"pli":"Tena ahaṁ pabbajissāmi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:11.1":{"pli":"“Dulladdhaṁ me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:11.2":{"pli":"Sutasoma yassa te ahaṁ bhariyā; ","html":"<span class='verse-line'>{}</span>"},"ja525:11.3":{"pli":"Yaṁ me vilapantiyā, ","html":"<span class='verse-line'>{}</span>"},"ja525:11.4":{"pli":"Anapekkho pabbajasi deva. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:12.1":{"pli":"Dulladdhaṁ me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:12.2":{"pli":"Sutasoma yassa te ahaṁ bhariyā; ","html":"<span class='verse-line'>{}</span>"},"ja525:12.3":{"pli":"Yaṁ me kucchipaṭisandhiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja525:12.4":{"pli":"Anapekkho pabbajasi deva. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:13.1":{"pli":"Paripakko me gabbho, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:13.2":{"pli":"Kucchigato yāva naṁ vijāyāmi; ","html":"<span class='verse-line'>{}</span>"},"ja525:13.3":{"pli":"Māhaṁ ekā vidhavā, ","html":"<span class='verse-line'>{}</span>"},"ja525:13.4":{"pli":"Pacchā dukkhāni addakkhiṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:14.1":{"pli":"“Paripakko te gabbho, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:14.2":{"pli":"Kucchigato iṅgha tvaṁ vijāyassu; ","html":"<span class='verse-line'>{}</span>"},"ja525:14.3":{"pli":"Puttaṁ anomavaṇṇaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja525:14.4":{"pli":"Taṁ hitvā pabbajissāmi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:15.1":{"pli":"“Mā tvaṁ cande rudi, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:15.2":{"pli":"Mā soci vanatimiramattakkhi; ","html":"<span class='verse-line'>{}</span>"},"ja525:15.3":{"pli":"Āroha varapāsādaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja525:15.4":{"pli":"Anapekkho ahaṁ gamissāmi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:16.1":{"pli":"“Ko taṁ amma kopesi, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:16.2":{"pli":"Kiṁ rodasi pekkhasi ca maṁ bāḷhaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja525:16.3":{"pli":"Kaṁ avajjhaṁ ghātemi, ","html":"<span class='verse-line'>{}</span>"},"ja525:16.4":{"pli":"Ñātīnaṁ udikkhamānānaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:17.1":{"pli":"“Na hi so sakkā hantuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:17.2":{"pli":"Vijitāvī yo maṁ tāta kopesi; ","html":"<span class='verse-line'>{}</span>"},"ja525:17.3":{"pli":"Pitā te maṁ tāta avaca, ","html":"<span class='verse-line'>{}</span>"},"ja525:17.4":{"pli":"Anapekkho ahaṁ gamissāmi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:18.1":{"pli":"“Yohaṁ pubbe niyyāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:18.2":{"pli":"Uyyānaṁ mattakuñjare ca yodhemi; ","html":"<span class='verse-line'>{}</span>"},"ja525:18.3":{"pli":"Sutasome pabbajite, ","html":"<span class='verse-line'>{}</span>"},"ja525:18.4":{"pli":"Kathaṁ nu dāni karissāmi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:19.1":{"pli":"“Mātucca me rudantyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:19.2":{"pli":"Jeṭṭhassa ca bhātuno akāmassa; ","html":"<span class='verse-line'>{}</span>"},"ja525:19.3":{"pli":"Hatthepi te gahessaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja525:19.4":{"pli":"Na hi gacchasi no akāmānaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:20.1":{"pli":"“Uṭṭhehi tvaṁ dhāti, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:20.2":{"pli":"Imaṁ kumāraṁ ramehi aññattha; ","html":"<span class='verse-line'>{}</span>"},"ja525:20.3":{"pli":"Mā me paripanthamakāsi, ","html":"<span class='verse-line'>{}</span>"},"ja525:20.4":{"pli":"Saggaṁ mama patthayānassa”. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:21.1":{"pli":"“Yaṁnūnimaṁ dadeyyaṁ pabhaṅkaraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:21.2":{"pli":"Ko nu me imināttho; ","html":"<span class='verse-line'>{}</span>"},"ja525:21.3":{"pli":"Sutasome pabbajite, ","html":"<span class='verse-line'>{}</span>"},"ja525:21.4":{"pli":"Kiṁ nu menaṁ karissāmi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:22.1":{"pli":"“Koso ca tuyhaṁ vipulo, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:22.2":{"pli":"Koṭṭhāgārañca tuyhaṁ paripūraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja525:22.3":{"pli":"Pathavī ca tuyhaṁ vijitā, ","html":"<span class='verse-line'>{}</span>"},"ja525:22.4":{"pli":"Ramassu mā pabbaji deva”. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:23.1":{"pli":"“Koso ca mayhaṁ vipulo, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:23.2":{"pli":"Koṭṭhāgārañca mayhaṁ paripūraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja525:23.3":{"pli":"Pathavī ca mayhaṁ vijitā, ","html":"<span class='verse-line'>{}</span>"},"ja525:23.4":{"pli":"Taṁ hitvā pabbajissāmi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:24.1":{"pli":"“Mayhampi dhanaṁ pahūtaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:24.2":{"pli":"Saṅkhātuṁ nopi deva sakkomi; ","html":"<span class='verse-line'>{}</span>"},"ja525:24.3":{"pli":"Taṁ te dadāmi sabbampi, ","html":"<span class='verse-line'>{}</span>"},"ja525:24.4":{"pli":"Ramassu mā pabbaji deva”. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:25.1":{"pli":"“Jānāmi dhanaṁ pahūtaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:25.2":{"pli":"Kulavaddhana pūjito tayā casmi; ","html":"<span class='verse-line'>{}</span>"},"ja525:25.3":{"pli":"Saggañca patthayāno, ","html":"<span class='verse-line'>{}</span>"},"ja525:25.4":{"pli":"Tena ahaṁ pabbajissāmi. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:26.1":{"pli":"Ukkaṇṭhitosmi bāḷhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:26.2":{"pli":"Arati maṁ somadatta āvisati; ","html":"<span class='verse-line'>{}</span>"},"ja525:26.3":{"pli":"Bahukāpi me antarāyā, ","html":"<span class='verse-line'>{}</span>"},"ja525:26.4":{"pli":"Ajjevāhaṁ pabbajissāmi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:27.1":{"pli":"“Idañca tuyhaṁ rucitaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:27.2":{"pli":"Sutasoma ajjeva dāni tvaṁ pabbaja; ","html":"<span class='verse-line'>{}</span>"},"ja525:27.3":{"pli":"Ahampi pabbajissāmi, ","html":"<span class='verse-line'>{}</span>"},"ja525:27.4":{"pli":"Na ussahe tayā vinā ahaṁ ṭhātuṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:28.1":{"pli":"“Na hi sakkā pabbajituṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:28.2":{"pli":"Nagare na hi paccati janapade ca; ","html":"<span class='verse-line'>{}</span>"},"ja525:28.3":{"pli":"Sutasome pabbajite, ","html":"<span class='verse-line'>{}</span>"},"ja525:28.4":{"pli":"Kathaṁ nu dāni karissāma. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:29.1":{"pli":"Upanīyatidaṁ maññe, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:29.2":{"pli":"Parittaṁ udakaṁva caṅkavāramhi; ","html":"<span class='verse-line'>{}</span>"},"ja525:29.3":{"pli":"Evaṁ suparittake jīvite, ","html":"<span class='verse-line'>{}</span>"},"ja525:29.4":{"pli":"Na ca pamajjituṁ kālo. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:30.1":{"pli":"Upanīyatidaṁ maññe, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:30.2":{"pli":"Parittaṁ udakaṁva caṅkavāramhi; ","html":"<span class='verse-line'>{}</span>"},"ja525:30.3":{"pli":"Evaṁ suparittake jīvite, ","html":"<span class='verse-line'>{}</span>"},"ja525:30.4":{"pli":"Andhabālā pamajjanti. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:31.1":{"pli":"Te vaḍḍhayanti nirayaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:31.2":{"pli":"Tiracchānayoniñca pettivisayañca; ","html":"<span class='verse-line'>{}</span>"},"ja525:31.3":{"pli":"Taṇhāya bandhanabaddhā, ","html":"<span class='verse-line'>{}</span>"},"ja525:31.4":{"pli":"Vaḍḍhenti asurakāyaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:32.1":{"pli":"“Ūhaññate rajaggaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:32.2":{"pli":"Avidūre pubbakamhi ca pāsāde; ","html":"<span class='verse-line'>{}</span>"},"ja525:32.3":{"pli":"Maññe no kesā chinnā, ","html":"<span class='verse-line'>{}</span>"},"ja525:32.4":{"pli":"Yasassino dhammarājassa”. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:33.1":{"pli":"“Ayamassa pāsādo, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:33.2":{"pli":"Sovaṇṇapupphamālyavītikiṇṇo; ","html":"<span class='verse-line'>{}</span>"},"ja525:33.3":{"pli":"Yahimanuvicari rājā, ","html":"<span class='verse-line'>{}</span>"},"ja525:33.4":{"pli":"Parikiṇṇo itthāgārehi. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:34.1":{"pli":"Ayamassa pāsādo, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:34.2":{"pli":"Sovaṇṇapupphamālyavītikiṇṇo; ","html":"<span class='verse-line'>{}</span>"},"ja525:34.3":{"pli":"Yahimanuvicari rājā, ","html":"<span class='verse-line'>{}</span>"},"ja525:34.4":{"pli":"Parikiṇṇo ñātisaṅghena. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:35.1":{"pli":"Idamassa kūṭāgāraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:35.2":{"pli":"Sovaṇṇapupphamālyavītikiṇṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja525:35.3":{"pli":"Yahimanuvicari rājā, ","html":"<span class='verse-line'>{}</span>"},"ja525:35.4":{"pli":"Parikiṇṇo itthāgārehi. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:36.1":{"pli":"Idamassa kūṭāgāraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:36.2":{"pli":"Sovaṇṇapupphamālyavītikiṇṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja525:36.3":{"pli":"Yahimanuvicari rājā, ","html":"<span class='verse-line'>{}</span>"},"ja525:36.4":{"pli":"Parikiṇṇo ñātisaṅghena. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:37.1":{"pli":"Ayamassa asokavanikā, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:37.2":{"pli":"Supupphitā sabbakālikā rammā; ","html":"<span class='verse-line'>{}</span>"},"ja525:37.3":{"pli":"Yahimanuvicari rājā, ","html":"<span class='verse-line'>{}</span>"},"ja525:37.4":{"pli":"Parikiṇṇo itthāgārehi. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:38.1":{"pli":"Ayamassa asokavanikā, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:38.2":{"pli":"Supupphitā sabbakālikā rammā; ","html":"<span class='verse-line'>{}</span>"},"ja525:38.3":{"pli":"Yahimanuvicari rājā, ","html":"<span class='verse-line'>{}</span>"},"ja525:38.4":{"pli":"Parikiṇṇo ñātisaṅghena. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:39.1":{"pli":"Idamassa uyyānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:39.2":{"pli":"Supupphitaṁ sabbakālikaṁ rammaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja525:39.3":{"pli":"Yahimanuvicari rājā, ","html":"<span class='verse-line'>{}</span>"},"ja525:39.4":{"pli":"Parikiṇṇo itthāgārehi. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:40.1":{"pli":"Idamassa uyyānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:40.2":{"pli":"Supupphitaṁ sabbakālikaṁ rammaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja525:40.3":{"pli":"Yahimanuvicari rājā, ","html":"<span class='verse-line'>{}</span>"},"ja525:40.4":{"pli":"Parikiṇṇo ñātisaṅghena. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:41.1":{"pli":"Idamassa kaṇikāravanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:41.2":{"pli":"Supupphitaṁ sabbakālikaṁ rammaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja525:41.3":{"pli":"Yahimanuvicari rājā, ","html":"<span class='verse-line'>{}</span>"},"ja525:41.4":{"pli":"Parikiṇṇo itthāgārehi. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:42.1":{"pli":"Idamassa kaṇikāravanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:42.2":{"pli":"Supupphitaṁ sabbakālikaṁ rammaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja525:42.3":{"pli":"Yahimanuvicari rājā, ","html":"<span class='verse-line'>{}</span>"},"ja525:42.4":{"pli":"Parikiṇṇo ñātisaṅghena. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:43.1":{"pli":"Idamassa pāṭalivanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:43.2":{"pli":"Supupphitaṁ sabbakālikaṁ rammaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja525:43.3":{"pli":"Yahimanuvicari rājā, ","html":"<span class='verse-line'>{}</span>"},"ja525:43.4":{"pli":"Parikiṇṇo itthāgārehi. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:44.1":{"pli":"Idamassa pāṭalivanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:44.2":{"pli":"Supupphitaṁ sabbakālikaṁ rammaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja525:44.3":{"pli":"Yahimanuvicari rājā, ","html":"<span class='verse-line'>{}</span>"},"ja525:44.4":{"pli":"Parikiṇṇo ñātisaṅghena. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:45.1":{"pli":"Idamassa ambavanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:45.2":{"pli":"Supupphitaṁ sabbakālikaṁ rammaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja525:45.3":{"pli":"Yahimanuvicari rājā, ","html":"<span class='verse-line'>{}</span>"},"ja525:45.4":{"pli":"Parikiṇṇo itthāgārehi. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:46.1":{"pli":"Idamassa ambavanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:46.2":{"pli":"Supupphitaṁ sabbakālikaṁ rammaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja525:46.3":{"pli":"Yahimanuvicari rājā, ","html":"<span class='verse-line'>{}</span>"},"ja525:46.4":{"pli":"Parikiṇṇo ñātisaṅghena. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:47.1":{"pli":"Ayamassa pokkharaṇī, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:47.2":{"pli":"Sañchannā aṇḍajehi vītikiṇṇā; ","html":"<span class='verse-line'>{}</span>"},"ja525:47.3":{"pli":"Yahimanuvicari rājā, ","html":"<span class='verse-line'>{}</span>"},"ja525:47.4":{"pli":"Parikiṇṇo itthāgārehi. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:48.1":{"pli":"Ayamassa pokkharaṇī, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:48.2":{"pli":"Sañchannā aṇḍajehi vītikiṇṇā; ","html":"<span class='verse-line'>{}</span>"},"ja525:48.3":{"pli":"Yahimanuvicari rājā, ","html":"<span class='verse-line'>{}</span>"},"ja525:48.4":{"pli":"Parikiṇṇo ñātisaṅghena. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:49.1":{"pli":"Rājā vo kho pabbajito, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:49.2":{"pli":"Sutasomo rajjaṁ imaṁ pahatvāna; ","html":"<span class='verse-line'>{}</span>"},"ja525:49.3":{"pli":"Kāsāyavatthavasano, ","html":"<span class='verse-line'>{}</span>"},"ja525:49.4":{"pli":"Nāgova ekako carati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:50.1":{"pli":"“Māssu pubbe ratikīḷitāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:50.2":{"pli":"Hasitāni ca anussarittha; ","html":"<span class='verse-line'>{}</span>"},"ja525:50.3":{"pli":"Mā vo kāmā haniṁsu, ","html":"<span class='verse-line'>{}</span>"},"ja525:50.4":{"pli":"Rammaṁ hi sudassanaṁ nagaraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja525:51.1":{"pli":"Mettacittañca bhāvetha, ","html":"<p><span class='verse-line'>{}</span>"},"ja525:51.2":{"pli":"Appamāṇaṁ divā ca ratto ca; ","html":"<span class='verse-line'>{}</span>"},"ja525:51.3":{"pli":"Agacchittha devapuraṁ, ","html":"<span class='verse-line'>{}</span>"},"ja525:51.4":{"pli":"Āvāsaṁ puññakamminan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja525:52.1":{"pli":"Cūḷasutasomajātakaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja525:53.1":{"pli":"Cattālīsanipātaṁ niṭṭhitaṁ. ","html":"<p class='endsection'>{}</p>"},"ja525:54.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja525:55.1":{"pli":"Suvapaṇḍitajambukakuṇḍalino, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja525:55.2":{"pli":"Varakaññamalambusajātakañca; ","html":"<span class='verse-line'>{}</span>"},"ja525:55.3":{"pli":"Pavaruttamasaṅkhasirīvhayako, ","html":"<span class='verse-line'>{}</span>"},"ja525:55.4":{"pli":"Sutasomaarindhamarājavaro. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}}}