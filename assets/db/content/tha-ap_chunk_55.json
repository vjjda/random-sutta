{"tha-ap548":{"tha-ap548:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap548'><header><ul><li class='division'>{}</li>"},"tha-ap548:0.2":{"pli":"Bhaddiyavagga ","html":"<li>{}</li></ul>"},"tha-ap548:0.3":{"pli":"Kāḷudāyittheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap548:1.1":{"pli":"“Padumuttaro nāma jino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap548:1.2":{"pli":"sabbadhammesu cakkhumā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:1.3":{"pli":"Ito satasahassamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:1.4":{"pli":"kappe uppajji nāyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap548:2.1":{"pli":"Nāyakānaṁ varo satthā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap548:2.2":{"pli":"guṇāguṇavidū jino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:2.3":{"pli":"Kataññū katavedī ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:2.4":{"pli":"titthe yojeti pāṇine. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap548:3.1":{"pli":"Sabbaññutena ñāṇena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap548:3.2":{"pli":"tulayitvā dayāsayo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:3.3":{"pli":"Deseti pavaraṁ dhammaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:3.4":{"pli":"anantaguṇasañcayo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap548:4.1":{"pli":"Sa kadāci mahāvīro, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap548:4.2":{"pli":"anantajinasaṁsari; ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:4.3":{"pli":"Deseti madhuraṁ dhammaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:4.4":{"pli":"catusaccūpasañhitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap548:5.1":{"pli":"Sutvāna taṁ dhammavaraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap548:5.2":{"pli":"ādimajjhantasobhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:5.3":{"pli":"Pāṇasatasahassānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:5.4":{"pli":"dhammābhisamayo ahu. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap548:6.1":{"pli":"Ninnāditā tadā bhūmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap548:6.2":{"pli":"gajjiṁsu ca payodharā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:6.3":{"pli":"Sādhukāraṁ pavattiṁsu, ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:6.4":{"pli":"devabrahmanarāsurā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap548:7.1":{"pli":"‘Aho kāruṇiko satthā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap548:7.2":{"pli":"aho saddhammadesanā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:7.3":{"pli":"Aho bhavasamuddamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:7.4":{"pli":"nimugge uddharī jino’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap548:8.1":{"pli":"Evaṁ pavedajātesu, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap548:8.2":{"pli":"sanarāmarabrahmasu; ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:8.3":{"pli":"Kulappasādakānaggaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:8.4":{"pli":"sāvakaṁ vaṇṇayī jino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap548:9.1":{"pli":"Tadāhaṁ haṁsavatiyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap548:9.2":{"pli":"jātomaccakule ahuṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:9.3":{"pli":"Pāsādiko dassaniyo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:9.4":{"pli":"pahūtadhanadhaññavā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap548:10.1":{"pli":"Haṁsārāmamupeccāhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap548:10.2":{"pli":"vanditvā taṁ tathāgataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:10.3":{"pli":"Suṇitvā madhuraṁ dhammaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:10.4":{"pli":"kāraṁ katvā ca tādino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap548:11.1":{"pli":"Nipacca pādamūlehaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap548:11.2":{"pli":"imaṁ vacanamabraviṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:11.3":{"pli":"‘Kulappasādakānaggo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:11.4":{"pli":"yo tayā santhuto mune. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap548:12.1":{"pli":"Tādiso homahaṁ vīra, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap548:12.2":{"pli":"buddhaseṭṭhassa sāsane’; ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:12.3":{"pli":"Tadā mahākāruṇiko, ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:12.4":{"pli":"siñcanto vāmatena maṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap548:13.1":{"pli":"Āha maṁ ‘putta uttiṭṭha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap548:13.2":{"pli":"lacchase taṁ manorathaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:13.3":{"pli":"Kathaṁ nāma jine kāraṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:13.4":{"pli":"katvāna viphalo siyā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap548:14.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap548:14.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:14.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:14.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap548:15.1":{"pli":"Tassa dhammesu dāyādo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap548:15.2":{"pli":"oraso dhammanimmito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:15.3":{"pli":"Udāyi nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:15.4":{"pli":"hessati satthu sāvako’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap548:16.1":{"pli":"Taṁ sutvā mudito hutvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap548:16.2":{"pli":"yāvajīvaṁ tadā jinaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:16.3":{"pli":"Mettacitto paricariṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:16.4":{"pli":"paccayehi vināyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap548:17.1":{"pli":"Tena kammavipākena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap548:17.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:17.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:17.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap548:18.1":{"pli":"Pacchime ca bhave dāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap548:18.2":{"pli":"ramme kapilavatthave; ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:18.3":{"pli":"Jāto mahāmaccakule, ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:18.4":{"pli":"suddhodanamahīpate. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap548:19.1":{"pli":"Tadā ajāyi siddhattho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap548:19.2":{"pli":"ramme lumbinikānane; ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:19.3":{"pli":"Hitāya sabbalokassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:19.4":{"pli":"sukhāya ca narāsabho. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap548:20.1":{"pli":"Tadaheva ahaṁ jāto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap548:20.2":{"pli":"saha teneva vaḍḍhito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:20.3":{"pli":"Piyo sahāyo dayito, ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:20.4":{"pli":"viyatto nītikovido. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap548:21.1":{"pli":"Ekūnatiṁso vayasā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap548:21.2":{"pli":"nikkhamitvā agārato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:21.3":{"pli":"Chabbassaṁ vītināmetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:21.4":{"pli":"āsi buddho vināyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap548:22.1":{"pli":"Jetvā sasenakaṁ māraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap548:22.2":{"pli":"khepayitvāna āsave; ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:22.3":{"pli":"Bhavaṇṇavaṁ taritvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:22.4":{"pli":"buddho āsi sadevake. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap548:23.1":{"pli":"Isivhayaṁ gamitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap548:23.2":{"pli":"vinetvā pañcavaggiye; ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:23.3":{"pli":"Tato vinesi bhagavā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:23.4":{"pli":"gantvā gantvā tahiṁ tahiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap548:24.1":{"pli":"Veneyye vinayanto so, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap548:24.2":{"pli":"saṅgaṇhanto sadevakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:24.3":{"pli":"Upecca magadhe giriṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:24.4":{"pli":"viharittha tadā jino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap548:25.1":{"pli":"Tadā suddhodanenāhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap548:25.2":{"pli":"bhūmipālena pesito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:25.3":{"pli":"Gantvā disvā dasabalaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:25.4":{"pli":"pabbajitvārahā ahuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap548:26.1":{"pli":"Tadā mahesiṁ yācitvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap548:26.2":{"pli":"pāpayiṁ kapilavhayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:26.3":{"pli":"Tato purāhaṁ gantvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:26.4":{"pli":"pasādesiṁ mahākulaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap548:27.1":{"pli":"Jino tasmiṁ guṇe tuṭṭho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap548:27.2":{"pli":"maṁ mahāparisāya so; ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:27.3":{"pli":"Kulappasādakānaggaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:27.4":{"pli":"paññāpesi vināyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap548:28.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap548:28.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:28.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap548:29.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap548:29.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:29.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap548:30.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap548:30.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap548:30.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap548:31.1":{"pli":"Itthaṁ sudaṁ āyasmā kāḷudāyī thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap548:32.1":{"pli":"Kāḷudāyittherassāpadānaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap549":{"tha-ap549:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap549'><header><ul><li class='division'>{}</li>"},"tha-ap549:0.2":{"pli":"Bhaddiyavagga ","html":"<li>{}</li></ul>"},"tha-ap549:0.3":{"pli":"Abhayattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap549:1.1":{"pli":"“Padumuttaro nāma jino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap549:1.2":{"pli":"sabbadhammesu cakkhumā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:1.3":{"pli":"Ito satasahassamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:1.4":{"pli":"kappe uppajji nāyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap549:2.1":{"pli":"Saraṇagamane kiñci, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap549:2.2":{"pli":"nivesesi tathāgato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:2.3":{"pli":"Kiñci sīle nivesesi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:2.4":{"pli":"dasakammapathuttame. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap549:3.1":{"pli":"Deti kassaci so vīro, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap549:3.2":{"pli":"sāmaññaphalamuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:3.3":{"pli":"Samāpattī tathā aṭṭha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:3.4":{"pli":"tisso vijjā pavecchati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap549:4.1":{"pli":"Chaḷabhiññāsu yojesi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap549:4.2":{"pli":"kiñci sattaṁ naruttamo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:4.3":{"pli":"Deti kassaci nātho so, ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:4.4":{"pli":"catasso paṭisambhidā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap549:5.1":{"pli":"Bodhaneyyaṁ pajaṁ disvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap549:5.2":{"pli":"asaṅkheyyampi yojanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:5.3":{"pli":"Khaṇena upagantvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:5.4":{"pli":"vineti narasārathi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap549:6.1":{"pli":"Tadāhaṁ haṁsavatiyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap549:6.2":{"pli":"ahosiṁ brāhmaṇatrajo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:6.3":{"pli":"Pāragū sabbavedānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:6.4":{"pli":"veyyākaraṇasammato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap549:7.1":{"pli":"Niruttiyā ca kusalo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap549:7.2":{"pli":"nighaṇḍumhi visārado; ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:7.3":{"pli":"Padako keṭubhavidū, ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:7.4":{"pli":"chandovicitikovido. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap549:8.1":{"pli":"Jaṅghāvihāraṁ vicaraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap549:8.2":{"pli":"haṁsārāmamupeccahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:8.3":{"pli":"Addasaṁ varadaṁ seṭṭhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:8.4":{"pli":"mahājanapurakkhataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap549:9.1":{"pli":"Desentaṁ virajaṁ dhammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap549:9.2":{"pli":"paccanīkamatī ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:9.3":{"pli":"Upetvā tassa kalyāṇaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:9.4":{"pli":"sutvāna vimalaṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap549:10.1":{"pli":"Byāhataṁ punaruttaṁ vā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap549:10.2":{"pli":"apatthaṁ vā niratthakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:10.3":{"pli":"Nāddasaṁ tassa munino, ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:10.4":{"pli":"tato pabbajito ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap549:11.1":{"pli":"Nacireneva kālena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap549:11.2":{"pli":"sabbasattavisārado; ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:11.3":{"pli":"Nipuṇo buddhavacane, ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:11.4":{"pli":"ahosiṁ guṇisammato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap549:12.1":{"pli":"Tadā catasso gāthāyo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap549:12.2":{"pli":"ganthayitvā subyañjanā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:12.3":{"pli":"Santhavitvā tilokaggaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:12.4":{"pli":"desayissaṁ dine dine. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap549:13.1":{"pli":"‘Virattosi mahāvīro, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap549:13.2":{"pli":"saṁsāre sabhaye vasaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:13.3":{"pli":"Karuṇāya na nibbāyi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:13.4":{"pli":"tato kāruṇiko muni. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap549:14.1":{"pli":"Puthujjano vayo santo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap549:14.2":{"pli":"na kilesavaso ahu; ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:14.3":{"pli":"Sampajāno satiyutto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:14.4":{"pli":"tasmā eso acintiyo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap549:15.1":{"pli":"Dubbalāni kilesāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap549:15.2":{"pli":"yassāsayagatāni me; ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:15.3":{"pli":"Ñāṇaggiparidaḍḍhāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:15.4":{"pli":"na khīyiṁsu tamabbhutaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap549:16.1":{"pli":"Yo sabbalokassa garu, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap549:16.2":{"pli":"loko yassa tathā garu; ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:16.3":{"pli":"Tathāpi lokācariyo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:16.4":{"pli":"loko tassānuvattako’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap549:17.1":{"pli":"Evamādīhi sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap549:17.2":{"pli":"kittayaṁ dhammadesanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:17.3":{"pli":"Yāvajīvaṁ karitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:17.4":{"pli":"gato saggaṁ tato cuto. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap549:18.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap549:18.2":{"pli":"yaṁ buddhamabhikittayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:18.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:18.4":{"pli":"kittanāya idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap549:19.1":{"pli":"Devaloke mahārajjaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap549:19.2":{"pli":"pādesiṁ kañcanagghiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:19.3":{"pli":"Cakkavattī mahārajjaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:19.4":{"pli":"bahusonubhaviṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap549:20.1":{"pli":"Duve bhave pajāyāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap549:20.2":{"pli":"devatte atha mānuse; ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:20.3":{"pli":"Aññaṁ gatiṁ na jānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:20.4":{"pli":"kittanāya idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap549:21.1":{"pli":"Duve kule pajāyāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap549:21.2":{"pli":"khattiye atha brāhmaṇe; ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:21.3":{"pli":"Nīce kule na jāyāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:21.4":{"pli":"kittanāya idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap549:22.1":{"pli":"Pacchime ca bhave dāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap549:22.2":{"pli":"giribbajapuruttame; ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:22.3":{"pli":"Raññohaṁ bimbisārassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:22.4":{"pli":"putto nāmena cābhayo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap549:23.1":{"pli":"Pāpamittavasaṁ gantvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap549:23.2":{"pli":"nigaṇṭhena vimohito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:23.3":{"pli":"Pesito nāṭaputtena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:23.4":{"pli":"buddhaseṭṭhamupeccahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap549:24.1":{"pli":"Pucchitvā nipuṇaṁ pañhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap549:24.2":{"pli":"sutvā byākaraṇuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:24.3":{"pli":"Pabbajitvāna naciraṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:24.4":{"pli":"arahattamapāpuṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap549:25.1":{"pli":"Kittayitvā jinavaraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap549:25.2":{"pli":"kittito homi sabbadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:25.3":{"pli":"Sugandhadehavadano, ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:25.4":{"pli":"āsiṁ sukhasamappito. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap549:26.1":{"pli":"Tikkhahāsalahupañño, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap549:26.2":{"pli":"mahāpañño tathevahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:26.3":{"pli":"Vicittapaṭibhāno ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:26.4":{"pli":"tassa kammassa vāhasā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap549:27.1":{"pli":"Abhitthavitvā padumuttarāhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap549:27.2":{"pli":"Pasannacitto asamaṁ sayambhuṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:27.3":{"pli":"Na gacchi kappāni apāyabhūmiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:27.4":{"pli":"Sataṁsahassāni balena tassa. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap549:28.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap549:28.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:28.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap549:29.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap549:29.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:29.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap549:30.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap549:30.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap549:30.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap549:31.1":{"pli":"Itthaṁ sudaṁ āyasmā abhayo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap549:32.1":{"pli":"Abhayattherassāpadānaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap55":{"tha-ap55:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap55'><header><ul><li class='division'>{}</li>"},"tha-ap55:0.2":{"pli":"Bījanivagga ","html":"<li>{}</li></ul>"},"tha-ap55:0.3":{"pli":"Sayanadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap55:1.1":{"pli":"“Padumuttarabuddhassa, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap55:1.2":{"pli":"sabbalokānukampino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap55:1.3":{"pli":"Sayanaṁ tassa pādāsiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap55:1.4":{"pli":"vippasannena cetasā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap55:2.1":{"pli":"Tena sayanadānena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap55:2.2":{"pli":"sukhette bījasampadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap55:2.3":{"pli":"Bhogā nibbattare tassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap55:2.4":{"pli":"sayanassa idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap55:3.1":{"pli":"Ākāse seyyaṁ kappemi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap55:3.2":{"pli":"dhāremi pathaviṁ imaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap55:3.3":{"pli":"Pāṇesu me issariyaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap55:3.4":{"pli":"sayanassa idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap55:4.1":{"pli":"Pañcakappasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap55:4.2":{"pli":"aṭṭha āsuṁ mahātejā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap55:4.3":{"pli":"Catuttiṁse kappasate, ","html":"<span class='verse-line'>{}</span>"},"tha-ap55:4.4":{"pli":"caturo ca mahabbalā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap55:5.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap55:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap55:5.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap55:6.1":{"pli":"Itthaṁ sudaṁ āyasmā sayanadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap55:7.1":{"pli":"Sayanadāyakattherassāpadānaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap550":{"tha-ap550:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap550'><header><ul><li class='division'>{}</li>"},"tha-ap550:0.2":{"pli":"Bhaddiyavagga ","html":"<li>{}</li></ul>"},"tha-ap550:0.3":{"pli":"8 Lomasakaṅgiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap550:1.1":{"pli":"“Imamhi bhaddake kappe, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap550:1.2":{"pli":"brahmabandhu mahāyaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:1.3":{"pli":"Kassapo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:1.4":{"pli":"uppajji vadataṁ varo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap550:2.1":{"pli":"Tadāhaṁ candano ceva, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap550:2.2":{"pli":"pabbajitvāna sāsane; ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:2.3":{"pli":"Āpāṇakoṭikaṁ dhammaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:2.4":{"pli":"pūrayitvāna sāsane. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap550:3.1":{"pli":"Tato cutā santusitaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap550:3.2":{"pli":"upapannā ubho mayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:3.3":{"pli":"Tattha dibbehi naccehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:3.4":{"pli":"gītehi vāditehi ca. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap550:4.1":{"pli":"Rūpādidasahaṅgehi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap550:4.2":{"pli":"abhibhotvāna sesake; ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:4.3":{"pli":"Yāvatāyuṁ vasitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:4.4":{"pli":"anubhotvā mahāsukhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap550:5.1":{"pli":"Tato cavitvā tidasaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap550:5.2":{"pli":"candano upapajjatha; ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:5.3":{"pli":"Ahaṁ kapilavatthusmiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:5.4":{"pli":"ajāyiṁ sākiyatrajo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap550:6.1":{"pli":"Yadā udāyittherena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap550:6.2":{"pli":"ajjhiṭṭho lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:6.3":{"pli":"Anukampiya sakyānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:6.4":{"pli":"upesi kapilavhayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap550:7.1":{"pli":"Tadātimānino sakyā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap550:7.2":{"pli":"na buddhassa guṇaññuno; ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:7.3":{"pli":"Paṇamanti na sambuddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:7.4":{"pli":"jātithaddhā anādarā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap550:8.1":{"pli":"Tesaṁ saṅkappamaññāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap550:8.2":{"pli":"ākāse caṅkamī jino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:8.3":{"pli":"Pajjunno viya vassittha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:8.4":{"pli":"pajjalittha yathā sikhī. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap550:9.1":{"pli":"Dassetvā rūpamatulaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap550:9.2":{"pli":"puna antaradhāyatha; ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:9.3":{"pli":"Ekopi hutvā bahudhā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:9.4":{"pli":"ahosi punarekako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap550:10.1":{"pli":"Andhakāraṁ pakāsañca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap550:10.2":{"pli":"dassayitvā anekadhā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:10.3":{"pli":"Pāṭiheraṁ karitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:10.4":{"pli":"vinayī ñātake muni. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap550:11.1":{"pli":"Cātuddīpo mahāmegho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap550:11.2":{"pli":"tāvadeva pavassatha; ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:11.3":{"pli":"Tadā hi jātakaṁ buddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:11.4":{"pli":"vessantaramadesayi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap550:12.1":{"pli":"Tadā te khattiyā sabbe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap550:12.2":{"pli":"nihantvā jātijaṁ madaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:12.3":{"pli":"Upesuṁ saraṇaṁ buddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:12.4":{"pli":"āha suddhodano tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap550:13.1":{"pli":"‘Idaṁ tatiyaṁ tava bhūripañña, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap550:13.2":{"pli":"Pādāni vandāmi samantacakkhu; ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:13.3":{"pli":"Yadābhijāto pathavī pakampayī, ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:13.4":{"pli":"Yadā ca taṁ najjahi jambuchāyā’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap550:14.1":{"pli":"Tadā buddhānubhāvaṁ taṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap550:14.2":{"pli":"disvā vimhitamānaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:14.3":{"pli":"Pabbajitvāna tattheva, ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:14.4":{"pli":"nivasiṁ mātupūjako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap550:15.1":{"pli":"Candano devaputto maṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap550:15.2":{"pli":"upagantvānupucchatha; ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:15.3":{"pli":"Bhaddekarattassa tadā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:15.4":{"pli":"saṅkhepavitthāraṁ nayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap550:16.1":{"pli":"Coditohaṁ tadā tena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap550:16.2":{"pli":"upecca naranāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:16.3":{"pli":"Bhaddekarattaṁ sutvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:16.4":{"pli":"saṁviggo vanamāmako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap550:17.1":{"pli":"Tadā mātaramapucchiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap550:17.2":{"pli":"‘vane vacchāmi ekako’; ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:17.3":{"pli":"‘Sukhumālo’ti me mātā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:17.4":{"pli":"vārayī taṁ tadā vacaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap550:18.1":{"pli":"‘Kāsaṁ kusaṁ poṭakilaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap550:18.2":{"pli":"usīraṁ muñjapabbajaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:18.3":{"pli":"Urasā panudissāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:18.4":{"pli":"vivekamanubrūhayaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap550:19.1":{"pli":"Tadā vanaṁ paviṭṭhohaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap550:19.2":{"pli":"saritvā jinasāsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:19.3":{"pli":"Bhaddekarattaovādaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:19.4":{"pli":"arahattamapāpuṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap550:20.1":{"pli":"‘Atītaṁ nānvāgameyya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap550:20.2":{"pli":"nappaṭikaṅkhe anāgataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:20.3":{"pli":"Yadatītaṁ pahīnaṁ taṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:20.4":{"pli":"appattañca anāgataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap550:21.1":{"pli":"Paccuppannañca yo dhammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap550:21.2":{"pli":"tattha tattha vipassati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:21.3":{"pli":"Asaṁhīraṁ asaṅkuppaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:21.4":{"pli":"taṁ vidvā manubrūhaye. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap550:22.1":{"pli":"Ajjeva kiccamātappaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap550:22.2":{"pli":"ko jaññā maraṇaṁ suve; ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:22.3":{"pli":"Na hi no saṅgaraṁ tena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:22.4":{"pli":"mahāsenena maccunā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap550:23.1":{"pli":"Evaṁvihāriṁ ātāpiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap550:23.2":{"pli":"ahorattamatanditaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:23.3":{"pli":"Taṁ ve bhaddekarattoti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:23.4":{"pli":"santo ācikkhate muni’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap550:24.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap550:24.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:24.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap550:25.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap550:25.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:25.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap550:26.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap550:26.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap550:26.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap550:27.1":{"pli":"Itthaṁ sudaṁ āyasmā lomasakaṅgiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap550:28.1":{"pli":"Lomasakaṅgiyattherassāpadānaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap551":{"tha-ap551:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap551'><header><ul><li class='division'>{}</li>"},"tha-ap551:0.2":{"pli":"Bhaddiyavagga ","html":"<li>{}</li></ul>"},"tha-ap551:0.3":{"pli":"Vanavacchattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap551:1.1":{"pli":"“Imamhi bhaddake kappe, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap551:1.2":{"pli":"brahmabandhu mahāyaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:1.3":{"pli":"Kassapo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:1.4":{"pli":"uppajji vadataṁ varo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap551:2.1":{"pli":"Tadāhaṁ pabbajitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap551:2.2":{"pli":"tassa buddhassa sāsane; ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:2.3":{"pli":"Yāvajīvaṁ caritvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:2.4":{"pli":"brahmacāraṁ tato cuto. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap551:3.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap551:3.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:3.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:3.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap551:4.1":{"pli":"Tato cuto araññamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap551:4.2":{"pli":"kapoto āsahaṁ tahiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:4.3":{"pli":"Vasate guṇasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:4.4":{"pli":"bhikkhu jhānarato sadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap551:5.1":{"pli":"Mettacitto kāruṇiko, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap551:5.2":{"pli":"sadā pamuditānano; ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:5.3":{"pli":"Upekkhako mahāvīro, ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:5.4":{"pli":"appamaññāsu kovido. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap551:6.1":{"pli":"Vinīvaraṇasaṅkappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap551:6.2":{"pli":"sabbasattahitāsaye; ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:6.3":{"pli":"Visaṭṭho nacirenāsiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:6.4":{"pli":"tasmiṁ sugatasāvake. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap551:7.1":{"pli":"Upecca pādamūlamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap551:7.2":{"pli":"nisinnassa tadāssame; ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:7.3":{"pli":"Kadāci sāmisaṁ deti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:7.4":{"pli":"dhammaṁ desesi cekadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap551:8.1":{"pli":"Tadā vipulapemena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap551:8.2":{"pli":"upāsitvā jinatrajaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:8.3":{"pli":"Tato cuto gato saggaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:8.4":{"pli":"pavāso sagharaṁ yathā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap551:9.1":{"pli":"Saggā cuto manussesu, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap551:9.2":{"pli":"nibbatto puññakammunā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:9.3":{"pli":"Agāraṁ chaḍḍayitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:9.4":{"pli":"pabbajiṁ bahuso ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap551:10.1":{"pli":"Samaṇo tāpaso vippo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap551:10.2":{"pli":"paribbajo tathevahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:10.3":{"pli":"Hutvā vasiṁ araññamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:10.4":{"pli":"anekasataso ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap551:11.1":{"pli":"Pacchime ca bhave dāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap551:11.2":{"pli":"ramme kapilavatthave; ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:11.3":{"pli":"Vacchagotto dijo tassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:11.4":{"pli":"jāyāya ahamokkamiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap551:12.1":{"pli":"Mātu me dohaḷo āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap551:12.2":{"pli":"tirokucchigatassa me; ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:12.3":{"pli":"Jāyamānasamīpamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:12.4":{"pli":"vanavāsāya nicchayo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap551:13.1":{"pli":"Tato me ajanī mātā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap551:13.2":{"pli":"ramaṇīye vanantare; ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:13.3":{"pli":"Gabbhato nikkhamantaṁ maṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:13.4":{"pli":"kāsāyena paṭiggahuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap551:14.1":{"pli":"Tato kumāro siddhattho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap551:14.2":{"pli":"jāto sakyakuladdhajo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:14.3":{"pli":"Tassa mitto piyo āsiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:14.4":{"pli":"saṁvisaṭṭho sumāniyo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap551:15.1":{"pli":"Sattasārebhinikkhante, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap551:15.2":{"pli":"ohāya vipulaṁ yasaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:15.3":{"pli":"Ahampi pabbajitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:15.4":{"pli":"himavantamupāgamiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap551:16.1":{"pli":"Vanālayaṁ bhāvanīyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap551:16.2":{"pli":"kassapaṁ dhutavādikaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:16.3":{"pli":"Disvā sutvā jinuppādaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:16.4":{"pli":"upesiṁ narasārathiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap551:17.1":{"pli":"So me dhammamadesesi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap551:17.2":{"pli":"sabbatthaṁ sampakāsayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:17.3":{"pli":"Tatohaṁ pabbajitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:17.4":{"pli":"vanameva punāgamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap551:18.1":{"pli":"Tatthāppamatto viharaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap551:18.2":{"pli":"chaḷabhiññā aphassayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:18.3":{"pli":"Aho suladdhalābhomhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:18.4":{"pli":"sumittenānukampito. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap551:19.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap551:19.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:19.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap551:20.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap551:20.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:20.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap551:21.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap551:21.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap551:21.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap551:22.1":{"pli":"Itthaṁ sudaṁ āyasmā vanavaccho thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap551:23.1":{"pli":"Vanavacchattherassāpadānaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}