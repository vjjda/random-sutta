{"tha-ap399":{"tha-ap399:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap399'><header><ul><li class='division'>{}</li>"},"tha-ap399:0.2":{"pli":"Pilindavacchavagga ","html":"<li>{}</li></ul>"},"tha-ap399:0.3":{"pli":"Girimānandattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap399:1.1":{"pli":"“Bhariyā me kālaṅkatā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap399:1.2":{"pli":"putto sīvathikaṁ gato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:1.3":{"pli":"Mātā pitā matā bhātā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:1.4":{"pli":"ekacitamhi ḍayhare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap399:2.1":{"pli":"Tena sokena santatto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap399:2.2":{"pli":"kiso paṇḍu ahosahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:2.3":{"pli":"Cittakkhepo ca me āsi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:2.4":{"pli":"tena sokena aṭṭito. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap399:3.1":{"pli":"Sokasallaparetohaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap399:3.2":{"pli":"vanantamupasaṅkamiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:3.3":{"pli":"Pavattaphalaṁ bhuñjitvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:3.4":{"pli":"rukkhamūle vasāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap399:4.1":{"pli":"Sumedho nāma sambuddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap399:4.2":{"pli":"dukkhassantakaro jino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:4.3":{"pli":"Mamuddharitukāmo so, ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:4.4":{"pli":"āgañchi mama santikaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap399:5.1":{"pli":"Padasaddaṁ suṇitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap399:5.2":{"pli":"sumedhassa mahesino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:5.3":{"pli":"Paggahetvānahaṁ sīsaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:5.4":{"pli":"ullokesiṁ mahāmuniṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap399:6.1":{"pli":"Upāgate mahāvīre, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap399:6.2":{"pli":"pīti me udapajjatha; ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:6.3":{"pli":"Tadāsimekaggamano, ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:6.4":{"pli":"disvā taṁ lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap399:7.1":{"pli":"Satiṁ paṭilabhitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap399:7.2":{"pli":"paṇṇamuṭṭhimadāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:7.3":{"pli":"Nisīdi bhagavā tattha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:7.4":{"pli":"anukampāya cakkhumā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap399:8.1":{"pli":"Nisajja tattha bhagavā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap399:8.2":{"pli":"sumedho lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:8.3":{"pli":"Dhammaṁ me kathayī buddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:8.4":{"pli":"sokasallavinodanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap399:9.1":{"pli":"‘Anavhitā tato āguṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap399:9.2":{"pli":"ananuññātā ito gatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:9.3":{"pli":"Yathāgatā tathā gatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:9.4":{"pli":"tattha kā paridevanā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap399:10.1":{"pli":"Yathāpi pathikā sattā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap399:10.2":{"pli":"vassamānāya vuṭṭhiyā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:10.3":{"pli":"Sabhaṇḍā upagacchanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:10.4":{"pli":"vassassāpatanāya te. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap399:11.1":{"pli":"Vasse ca te oramite, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap399:11.2":{"pli":"sampayanti yadicchakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:11.3":{"pli":"Evaṁ mātā pitā tuyhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:11.4":{"pli":"tattha kā paridevanā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap399:12.1":{"pli":"Āgantukā pāhunakā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap399:12.2":{"pli":"caliteritakampitā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:12.3":{"pli":"Evaṁ mātā pitā tuyhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:12.4":{"pli":"tattha kā paridevanā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap399:13.1":{"pli":"Yathāpi urago jiṇṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap399:13.2":{"pli":"hitvā gacchati saṁ tacaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:13.3":{"pli":"Evaṁ mātā pitā tuyhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:13.4":{"pli":"saṁ tanuṁ idha hīyare’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap399:14.1":{"pli":"Buddhassa giramaññāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap399:14.2":{"pli":"sokasallaṁ vivajjayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:14.3":{"pli":"Pāmojjaṁ janayitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:14.4":{"pli":"buddhaseṭṭhaṁ avandahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap399:15.1":{"pli":"Vanditvāna mahānāgaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap399:15.2":{"pli":"Pūjayiṁ girimañjariṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:15.3":{"pli":"Dibbagandhaṁ sampavantaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:15.4":{"pli":"Sumedhaṁ lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap399:16.1":{"pli":"Pūjayitvāna sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap399:16.2":{"pli":"sire katvāna añjaliṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:16.3":{"pli":"Anussaraṁ guṇaggāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:16.4":{"pli":"santhaviṁ lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap399:17.1":{"pli":"‘Nittiṇṇosi mahāvīra, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap399:17.2":{"pli":"sabbaññu lokanāyaka; ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:17.3":{"pli":"Sabbe satte uddharasi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:17.4":{"pli":"ñāṇena tvaṁ mahāmune. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap399:18.1":{"pli":"Vimatiṁ dveḷhakaṁ vāpi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap399:18.2":{"pli":"sañchindasi mahāmune; ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:18.3":{"pli":"Paṭipādesi me maggaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:18.4":{"pli":"tava ñāṇena cakkhuma. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap399:19.1":{"pli":"Arahā vasipattā ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap399:19.2":{"pli":"chaḷabhiññā mahiddhikā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:19.3":{"pli":"Antalikkhacarā dhīrā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:19.4":{"pli":"parivārenti tāvade. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap399:20.1":{"pli":"Paṭipannā ca sekhā ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap399:20.2":{"pli":"phalaṭṭhā santi sāvakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:20.3":{"pli":"Sūrodayeva padumā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:20.4":{"pli":"pupphanti tava sāvakā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap399:21.1":{"pli":"Mahāsamuddovakkhobho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap399:21.2":{"pli":"atulopi duruttaro; ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:21.3":{"pli":"Evaṁ ñāṇena sampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:21.4":{"pli":"appameyyosi cakkhuma’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap399:22.1":{"pli":"Vanditvāhaṁ lokajinaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap399:22.2":{"pli":"cakkhumantaṁ mahāyasaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:22.3":{"pli":"Puthu disā namassanto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:22.4":{"pli":"paṭikuṭiko agañchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap399:23.1":{"pli":"Devalokā cavitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap399:23.2":{"pli":"sampajāno patissato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:23.3":{"pli":"Okkamiṁ mātuyā kucchiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:23.4":{"pli":"sandhāvanto bhavābhave. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap399:24.1":{"pli":"Agārā abhinikkhamma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap399:24.2":{"pli":"pabbajiṁ anagāriyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:24.3":{"pli":"Ātāpī nipako jhāyī, ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:24.4":{"pli":"paṭisallānagocaro. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap399:25.1":{"pli":"Padhānaṁ padahitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap399:25.2":{"pli":"tosayitvā mahāmuniṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:25.3":{"pli":"Candovabbhaghanā mutto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:25.4":{"pli":"vicarāmi ahaṁ sadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap399:26.1":{"pli":"Vivekamanuyuttomhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap399:26.2":{"pli":"upasanto nirūpadhi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:26.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:26.4":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap399:27.1":{"pli":"Tiṁsakappasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap399:27.2":{"pli":"yaṁ buddhamabhipūjayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:27.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:27.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap399:28.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap399:28.2":{"pli":"bhavā sabbe samūhatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:28.3":{"pli":"Sabbāsavā parikkhīṇā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:28.4":{"pli":"natthi dāni punabbhavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap399:29.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap399:29.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:29.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap399:30.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap399:30.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap399:30.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap399:31.1":{"pli":"Itthaṁ sudaṁ āyasmā girimānando thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap399:32.1":{"pli":"Girimānandattherassāpadānaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap4":{"tha-ap4:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap4'><header><ul><li class='division'>{}</li>"},"tha-ap4:0.2":{"pli":"Buddhavagga ","html":"<li>{}</li></ul>"},"tha-ap4:0.3":{"pli":"Mahāmoggallānattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap4:1.1":{"pli":"“Anomadassī bhagavā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap4:1.2":{"pli":"lokajeṭṭho narāsabho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:1.3":{"pli":"Vihāsi himavantamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:1.4":{"pli":"devasaṅghapurakkhato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap4:2.1":{"pli":"Varuṇo nāma nāmena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap4:2.2":{"pli":"nāgarājā ahaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:2.3":{"pli":"Kāmarūpī vikubbāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:2.4":{"pli":"mahodadhinivāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap4:3.1":{"pli":"Saṅgaṇiyaṁ gaṇaṁ hitvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap4:3.2":{"pli":"tūriyaṁ paṭṭhapesahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:3.3":{"pli":"Sambuddhaṁ parivāretvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:3.4":{"pli":"vādesuṁ accharā tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap4:4.1":{"pli":"Vajjamānesu tūresu, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap4:4.2":{"pli":"devā tūrāni vajjayuṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:4.3":{"pli":"Ubhinnaṁ saddaṁ sutvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:4.4":{"pli":"buddhopi sampabujjhatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap4:5.1":{"pli":"Nimantetvāna sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap4:5.2":{"pli":"sakaṁ bhavanupāgamiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:5.3":{"pli":"Āsanaṁ paññapetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:5.4":{"pli":"kālamārocayiṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap4:6.1":{"pli":"Khīṇāsavasahassehi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap4:6.2":{"pli":"parivuto lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:6.3":{"pli":"Obhāsento disā sabbā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:6.4":{"pli":"bhavanaṁ me upāgami. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap4:7.1":{"pli":"Upaviṭṭhaṁ mahāvīraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap4:7.2":{"pli":"Devadevaṁ narāsabhaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:7.3":{"pli":"Sabhikkhusaṅghaṁ tappesiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:7.4":{"pli":"Annapānenahaṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap4:8.1":{"pli":"Anumodi mahāvīro, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap4:8.2":{"pli":"sayambhū aggapuggalo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:8.3":{"pli":"Bhikkhusaṅghe nisīditvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:8.4":{"pli":"imā gāthā abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap4:9.1":{"pli":"Yo so saṅghaṁ apūjesi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap4:9.2":{"pli":"buddhañca lokanāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:9.3":{"pli":"Tena cittappasādena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:9.4":{"pli":"devalokaṁ gamissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap4:10.1":{"pli":"Sattasattatikkhattuñca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap4:10.2":{"pli":"devarajjaṁ karissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:10.3":{"pli":"Pathabyā rajjaṁ aṭṭhasataṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:10.4":{"pli":"vasudhaṁ āvasissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap4:11.1":{"pli":"Pañcapaññāsakkhattuñca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap4:11.2":{"pli":"cakkavattī bhavissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:11.3":{"pli":"Bhogā asaṅkhiyā tassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:11.4":{"pli":"uppajjissanti tāvade. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap4:12.1":{"pli":"Aparimeyye ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap4:12.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:12.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:12.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap4:13.1":{"pli":"Nirayā so cavitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap4:13.2":{"pli":"manussataṁ gamissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:13.3":{"pli":"Kolito nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:13.4":{"pli":"brahmabandhu bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap4:14.1":{"pli":"So pacchā pabbajitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap4:14.2":{"pli":"kusalamūlena codito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:14.3":{"pli":"Gotamassa bhagavato, ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:14.4":{"pli":"dutiyo hessati sāvako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap4:15.1":{"pli":"Āraddhavīriyo pahitatto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap4:15.2":{"pli":"Iddhiyā pāramiṁ gato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:15.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:15.4":{"pli":"Nibbāyissatināsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap4:16.1":{"pli":"Pāpamittopanissāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap4:16.2":{"pli":"kāmarāgavasaṁ gato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:16.3":{"pli":"Mātaraṁ pitarañcāpi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:16.4":{"pli":"ghātayiṁ duṭṭhamānaso. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap4:17.1":{"pli":"Yaṁ yaṁ yonupapajjāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap4:17.2":{"pli":"nirayaṁ atha mānusaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:17.3":{"pli":"Pāpakammasamaṅgitā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:17.4":{"pli":"bhinnasīso marāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap4:18.1":{"pli":"Idaṁ pacchimakaṁ mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap4:18.2":{"pli":"carimo vattate bhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:18.3":{"pli":"Idhāpi ediso mayhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:18.4":{"pli":"maraṇakāle bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap4:19.1":{"pli":"Pavivekamanuyutto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap4:19.2":{"pli":"samādhibhāvanārato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:19.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:19.4":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap4:20.1":{"pli":"Dharaṇimpi sugambhīraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap4:20.2":{"pli":"bahalaṁ duppadhaṁsiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:20.3":{"pli":"Vāmaṅguṭṭhena khobheyyaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:20.4":{"pli":"iddhiyā pāramiṁ gato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap4:21.1":{"pli":"Asmimānaṁ na passāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap4:21.2":{"pli":"māno mayhaṁ na vijjati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:21.3":{"pli":"Sāmaṇere upādāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:21.4":{"pli":"garucittaṁ karomahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap4:22.1":{"pli":"Aparimeyye ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap4:22.2":{"pli":"yaṁ kammamabhinīhariṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:22.3":{"pli":"Tāhaṁ bhūmimanuppatto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:22.4":{"pli":"pattomhi āsavakkhayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap4:23.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap4:23.2":{"pli":"vimokkhāpi ca aṭṭhime; ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:23.3":{"pli":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap4:23.4":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap4:24.1":{"pli":"Itthaṁ sudaṁ āyasmā mahāmoggallāno thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap4:25.1":{"pli":"Mahāmoggallānattherassāpadānaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap40":{"tha-ap40:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap40'><header><ul><li class='division'>{}</li>"},"tha-ap40:0.2":{"pli":"Kuṇḍadhānavagga ","html":"<li>{}</li></ul>"},"tha-ap40:0.3":{"pli":"8 Āyāgadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap40:1.1":{"pli":"“Nibbute lokanāthamhi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap40:1.2":{"pli":"sikhimhi vadataṁ vare; ","html":"<span class='verse-line'>{}</span>"},"tha-ap40:1.3":{"pli":"Haṭṭho haṭṭhena cittena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap40:1.4":{"pli":"avandiṁ thūpamuttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap40:2.1":{"pli":"Vaḍḍhakīhi kathāpetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap40:2.2":{"pli":"mūlaṁ datvānahaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap40:2.3":{"pli":"Haṭṭho haṭṭhena cittena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap40:2.4":{"pli":"āyāgaṁ kārapesahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap40:3.1":{"pli":"Aṭṭha kappāni devesu, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap40:3.2":{"pli":"abbokiṇṇaṁ vasiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap40:3.3":{"pli":"Avasesesu kappesu, ","html":"<span class='verse-line'>{}</span>"},"tha-ap40:3.4":{"pli":"vokiṇṇaṁ saṁsariṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap40:4.1":{"pli":"Kāye visaṁ na kamati, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap40:4.2":{"pli":"satthāni na ca hanti me; ","html":"<span class='verse-line'>{}</span>"},"tha-ap40:4.3":{"pli":"Udakehaṁ na miyyāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap40:4.4":{"pli":"āyāgassa idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap40:5.1":{"pli":"Yadicchāmi ahaṁ vassaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap40:5.2":{"pli":"mahāmegho pavassati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap40:5.3":{"pli":"Devāpi me vasaṁ enti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap40:5.4":{"pli":"puññakammassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap40:6.1":{"pli":"Sattaratanasampanno, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap40:6.2":{"pli":"tiṁsakkhattuṁ ahosahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap40:6.3":{"pli":"Na maṁ kecāvajānanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap40:6.4":{"pli":"puññakammassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap40:7.1":{"pli":"Ekattiṁse ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap40:7.2":{"pli":"āyāgaṁ yamakārayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap40:7.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap40:7.4":{"pli":"āyāgassa idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap40:8.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap40:8.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap40:8.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap40:9.1":{"pli":"Itthaṁ sudaṁ āyasmā āyāgadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap40:10.1":{"pli":"Āyāgadāyakattherassāpadānaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap400":{"tha-ap400:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap400'><header><ul><li class='division'>{}</li>"},"tha-ap400:0.2":{"pli":"Pilindavacchavagga ","html":"<li>{}</li></ul>"},"tha-ap400:0.3":{"pli":"8 Saḷalamaṇḍapiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap400:1.1":{"pli":"“Nibbute kakusandhamhi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap400:1.2":{"pli":"brāhmaṇamhi vusīmati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap400:1.3":{"pli":"Gahetvā saḷalaṁ mālaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap400:1.4":{"pli":"maṇḍapaṁ kārayiṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap400:2.1":{"pli":"Tāvatiṁsagato santo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap400:2.2":{"pli":"labhāmi byamhamuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap400:2.3":{"pli":"Aññe devetirocāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap400:2.4":{"pli":"puññakammassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap400:3.1":{"pli":"Divā vā yadi vā rattiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap400:3.2":{"pli":"caṅkamanto ṭhito cahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap400:3.3":{"pli":"Channo saḷalapupphehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap400:3.4":{"pli":"puññakammassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap400:4.1":{"pli":"Imasmiṁyeva kappamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap400:4.2":{"pli":"yaṁ buddhamabhipūjayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap400:4.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap400:4.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap400:5.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap400:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap400:5.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap400:6.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap400:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap400:6.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap400:7.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap400:7.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap400:7.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap400:8.1":{"pli":"Itthaṁ sudaṁ āyasmā saḷalamaṇḍapiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap400:9.1":{"pli":"Saḷalamaṇḍapiyattherassāpadānaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap401":{"tha-ap401:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap401'><header><ul><li class='division'>{}</li>"},"tha-ap401:0.2":{"pli":"Pilindavacchavagga ","html":"<li>{}</li></ul>"},"tha-ap401:0.3":{"pli":"Sabbadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap401:1.1":{"pli":"“Mahāsamuddaṁ ogayha, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap401:1.2":{"pli":"bhavanaṁ me sunimmitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:1.3":{"pli":"Sunimmitā pokkharaṇī, ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:1.4":{"pli":"cakkavākapakūjitā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap401:2.1":{"pli":"Mandālakehi sañchannā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap401:2.2":{"pli":"padumuppalakehi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:2.3":{"pli":"Nadī ca sandate tattha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:2.4":{"pli":"supatitthā manoramā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap401:3.1":{"pli":"Macchakacchapasañchannā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap401:3.2":{"pli":"nānādijasamotthatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:3.3":{"pli":"Mayūrakoñcābhirudā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:3.4":{"pli":"kokilādīhi vagguhi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap401:4.1":{"pli":"Pārevatā ravihaṁsā ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap401:4.2":{"pli":"cakkavākā nadīcarā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:4.3":{"pli":"Dindibhā sāḷikā cettha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:4.4":{"pli":"pampakā jīvajīvakā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap401:5.1":{"pli":"Haṁsā koñcāpi naditā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap401:5.2":{"pli":"kosiyā piṅgalā bahū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:5.3":{"pli":"Sattaratanasampannā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:5.4":{"pli":"maṇimuttikavālukā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap401:6.1":{"pli":"Sabbasoṇṇamayā rukkhā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap401:6.2":{"pli":"nānāgandhasameritā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:6.3":{"pli":"Ujjotenti divārattiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:6.4":{"pli":"bhavanaṁ sabbakālikaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap401:7.1":{"pli":"Saṭṭhi tūriyasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap401:7.2":{"pli":"sāyaṁ pāto pavajjare; ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:7.3":{"pli":"Soḷasitthisahassāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:7.4":{"pli":"parivārenti maṁ sadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap401:8.1":{"pli":"Abhinikkhamma bhavanā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap401:8.2":{"pli":"sumedhaṁ lokanāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:8.3":{"pli":"Pasannacitto sumano, ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:8.4":{"pli":"vandayiṁ taṁ mahāyasaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap401:9.1":{"pli":"Sambuddhaṁ abhivādetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap401:9.2":{"pli":"sasaṅghaṁ taṁ nimantayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:9.3":{"pli":"Adhivāsesi so dhīro, ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:9.4":{"pli":"sumedho lokanāyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap401:10.1":{"pli":"Mama dhammakathaṁ katvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap401:10.2":{"pli":"uyyojesi mahāmuni; ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:10.3":{"pli":"Sambuddhaṁ abhivādetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:10.4":{"pli":"bhavanaṁ me upāgamiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap401:11.1":{"pli":"Āmantayiṁ parijanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap401:11.2":{"pli":"‘sabbe sannipatātha vo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:11.3":{"pli":"Pubbaṇhasamayaṁ buddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:11.4":{"pli":"bhavanaṁ āgamissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap401:12.1":{"pli":"Lābhā amhaṁ suladdhaṁ no, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap401:12.2":{"pli":"ye vasāma tavantike; ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:12.3":{"pli":"Mayampi buddhaseṭṭhassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:12.4":{"pli":"pūjaṁ kassāma satthuno’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap401:13.1":{"pli":"Annapānaṁ paṭṭhapetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap401:13.2":{"pli":"kālaṁ ārocayiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:13.3":{"pli":"Vasīsatasahassehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:13.4":{"pli":"upesi lokanāyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap401:14.1":{"pli":"Pañcaṅgikehi tūriyehi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap401:14.2":{"pli":"paccuggamanamakāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:14.3":{"pli":"Sabbasoṇṇamaye pīṭhe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:14.4":{"pli":"nisīdi purisuttamo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap401:15.1":{"pli":"Uparicchadanaṁ āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap401:15.2":{"pli":"sabbasoṇṇamayaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:15.3":{"pli":"Bījaniyo pavāyanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:15.4":{"pli":"bhikkhusaṅghassa antare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap401:16.1":{"pli":"Pahūtenannapānena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap401:16.2":{"pli":"bhikkhusaṅghamatappayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:16.3":{"pli":"Paccekadussayugaḷe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:16.4":{"pli":"bhikkhusaṅghassadāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap401:17.1":{"pli":"Yaṁ vadanti sumedhoti, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap401:17.2":{"pli":"lokāhutipaṭiggahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:17.3":{"pli":"Bhikkhusaṅghe nisīditvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:17.4":{"pli":"imā gāthā abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap401:18.1":{"pli":"‘Yo me annena pānena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap401:18.2":{"pli":"sabbe ime ca tappayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:18.3":{"pli":"Tamahaṁ kittayissāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:18.4":{"pli":"suṇātha mama bhāsato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap401:19.1":{"pli":"Aṭṭhārase kappasate, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap401:19.2":{"pli":"devaloke ramissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:19.3":{"pli":"Sahassakkhattuṁ rājā ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:19.4":{"pli":"cakkavattī bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap401:20.1":{"pli":"Upapajjati yaṁ yoniṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap401:20.2":{"pli":"devattaṁ atha mānusaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:20.3":{"pli":"Sabbadā sabbasovaṇṇaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:20.4":{"pli":"chadanaṁ dhārayissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap401:21.1":{"pli":"Tiṁsakappasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap401:21.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:21.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:21.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap401:22.1":{"pli":"Tassa dhammesu dāyādo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap401:22.2":{"pli":"oraso dhammanimmito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:22.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:22.4":{"pli":"nibbāyissatināsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap401:23.1":{"pli":"Bhikkhusaṅghe nisīditvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap401:23.2":{"pli":"sīhanādaṁ nadissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:23.3":{"pli":"Citake chattaṁ dhārenti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:23.4":{"pli":"heṭṭhā chattamhi ḍayhatha’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap401:24.1":{"pli":"Sāmaññaṁ me anuppattaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap401:24.2":{"pli":"kilesā jhāpitā mayā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:24.3":{"pli":"Maṇḍape rukkhamūle vā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:24.4":{"pli":"santāpo me na vijjati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap401:25.1":{"pli":"Tiṁsakappasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap401:25.2":{"pli":"yaṁ dānamadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:25.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:25.4":{"pli":"sabbadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap401:26.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap401:26.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:26.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap401:27.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap401:27.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:27.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap401:28.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap401:28.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap401:28.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap401:29.1":{"pli":"Itthaṁ sudaṁ āyasmā sabbadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap401:30.1":{"pli":"Sabbadāyakattherassāpadānaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}