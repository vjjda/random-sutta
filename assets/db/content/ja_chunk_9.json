{"ja35":{"ja35:0.1":{"pli":"Jātaka ","eng":"Stories of Past Lives 35 ","html":"<article id='ja35'><header><ul><li class='division'>{}</li>"},"ja35:0.2":{"pli":"Ekakanipāta ","eng":"The Book of the Ones ","html":"<li>{}</li>"},"ja35:0.3":{"pli":"Kulāvakavagga ","eng":"Nests ","html":"<li>{}</li></ul>"},"ja35:0.4":{"pli":"5. Vaṭṭakajātaka ","eng":"The Quail: a past life story ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja35:1.1":{"pli":"“Santi pakkhā apatanā, ","eng":"I have wings that do not fly! ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>","comm":"A little quail, alone in the face of a great fire, turns back a wall of flame with the power of truth. | This verse, which remains a popular protection chant, is also found at <a href='index.html?q=cp29#10.1'>Cp 29:10.1</a>. | The bird in question is probably the jungle bush quail, which roosts on the ground. This small and adorable bird always seems to be in need of rescue, whether from wolves (Rig Veda 1.116.14), birds of prey, hunters, elephants, or, as here, fire. "},"ja35:1.2":{"pli":"santi pādā avañcanā; ","eng":"I have feet that do not walk! ","html":"<span class='verse-line'>{}</span>"},"ja35:1.3":{"pli":"Mātāpitā ca nikkhantā, ","eng":"Mother and father have fled! ","html":"<span class='verse-line'>{}</span>"},"ja35:1.4":{"pli":"jātaveda paṭikkamā”ti. ","eng":"Jātaveda the fire: go back! ","html":"<span class='verse-line'>{}</span></p></blockquote>","comm":"<i lang='pi' translate='no'>Jātaveda</i> is found commonly in the Rig Veda and rarely in the Pali canon. Where it does occur it is mostly in the Jātakas, showing how Vedic ideas are still alive in this collection. Here <i lang='pi' translate='no'>jātaveda</i> is addressed as an agent who can respond to pleas, the imminent deity Agni, who brings “knowledge to mortals”. "},"ja35:2.1":{"pli":"Vaṭṭakajātakaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja350":{"ja350:0.1":{"pli":"Jātaka ","html":"<article id='ja350'><header><ul><li class='division'>{}</li>"},"ja350:0.2":{"pli":"Catukkanipāta ","html":"<li>{}</li>"},"ja350:0.3":{"pli":"Cūḷakuṇālavagga ","html":"<li>{}</li></ul>"},"ja350:0.4":{"pli":"10. Devatāpañhajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja350:1.1":{"pli":"“Hanti hatthehi pādehi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja350:1.2":{"pli":"mukhañca parisumbhati; ","html":"<span class='verse-line'>{}</span>"},"ja350:1.3":{"pli":"Sa ve rāja piyo hoti, ","html":"<span class='verse-line'>{}</span>"},"ja350:1.4":{"pli":"kaṁ tena tvābhipassasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja350:2.1":{"pli":"“Akkosati yathākāmaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja350:2.2":{"pli":"āgamañcassa icchati; ","html":"<span class='verse-line'>{}</span>"},"ja350:2.3":{"pli":"Sa ve rāja piyo hoti, ","html":"<span class='verse-line'>{}</span>"},"ja350:2.4":{"pli":"kaṁ tena tvābhipassasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja350:3.1":{"pli":"“Abbhakkhāti abhūtena, ","html":"<p><span class='verse-line'>{}</span>"},"ja350:3.2":{"pli":"alikenābhisāraye; ","html":"<span class='verse-line'>{}</span>"},"ja350:3.3":{"pli":"Sa ve rāja piyo hoti, ","html":"<span class='verse-line'>{}</span>"},"ja350:3.4":{"pli":"kaṁ tena tvābhipassasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja350:4.1":{"pli":"“Haraṁ annañca pānañca, ","html":"<p><span class='verse-line'>{}</span>"},"ja350:4.2":{"pli":"Vatthasenāsanāni ca; ","html":"<span class='verse-line'>{}</span>"},"ja350:4.3":{"pli":"Aññadatthuharā santā, ","html":"<span class='verse-line'>{}</span>"},"ja350:4.4":{"pli":"Te ve rāja piyā honti; ","html":"<span class='verse-line'>{}</span>"},"ja350:4.5":{"pli":"Kaṁ tena tvābhipassasī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja350:5.1":{"pli":"Devatāpañhajātakaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja350:5.2":{"pli":"Cūḷakuṇālavaggo pañcamo. ","html":"<p class='endvagga'>{}</p>"},"ja350:6.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja350:7.1":{"pli":"Narānaṁ asakkhivasimhavaro, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja350:7.2":{"pli":"Nīliyamaggivarañca puna; ","html":"<span class='verse-line'>{}</span>"},"ja350:7.3":{"pli":"Puna rasāyasakūṭavaro, ","html":"<span class='verse-line'>{}</span>"},"ja350:7.4":{"pli":"Tathārañña sārathi hanti dasāti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja350:8.1":{"pli":"Atha vagguddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja350:9.1":{"pli":"Kāliṅgaṁ pucimandañca, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja350:9.2":{"pli":"kuṭidūsaka kokilā; ","html":"<span class='verse-line'>{}</span>"},"ja350:9.3":{"pli":"Cūḷakuṇālavaggo so, ","html":"<span class='verse-line'>{}</span>"},"ja350:9.4":{"pli":"pañcamo suppakāsitoti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja350:10.1":{"pli":"Catukkanipātaṁ niṭṭhitaṁ. ","html":"<p class='endsection'>{}</p></article>"}},"ja351":{"ja351:0.1":{"pli":"Jātaka ","html":"<article id='ja351'><header><ul><li class='division'>{}</li>"},"ja351:0.2":{"pli":"Pañcakanipāta ","html":"<li>{}</li>"},"ja351:0.3":{"pli":"Maṇikuṇḍalavagga ","html":"<li>{}</li></ul>"},"ja351:0.4":{"pli":"1. Maṇikuṇḍalajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja351:1.1":{"pli":"“Jīno rathassaṁ maṇikuṇḍale ca, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja351:1.2":{"pli":"Putte ca dāre ca tatheva jīno; ","html":"<span class='verse-line'>{}</span>"},"ja351:1.3":{"pli":"Sabbesu bhogesu asesakesu, ","html":"<span class='verse-line'>{}</span>"},"ja351:1.4":{"pli":"Kasmā na santappasi sokakāle”. ","html":"<span class='verse-line'>{}</span></p>"},"ja351:2.1":{"pli":"“Pubbeva maccaṁ vijahanti bhogā, ","html":"<p><span class='verse-line'>{}</span>"},"ja351:2.2":{"pli":"Macco vā te pubbataraṁ jahāti; ","html":"<span class='verse-line'>{}</span>"},"ja351:2.3":{"pli":"Asassatā bhogino kāmakāmi, ","html":"<span class='verse-line'>{}</span>"},"ja351:2.4":{"pli":"Tasmā na socāmahaṁ sokakāle. ","html":"<span class='verse-line'>{}</span></p>"},"ja351:3.1":{"pli":"Udeti āpūrati veti cando, ","html":"<p><span class='verse-line'>{}</span>"},"ja351:3.2":{"pli":"Atthaṁ tapetvāna paleti sūriyo; ","html":"<span class='verse-line'>{}</span>"},"ja351:3.3":{"pli":"Viditā mayā sattuka lokadhammā, ","html":"<span class='verse-line'>{}</span>"},"ja351:3.4":{"pli":"Tasmā na socāmahaṁ sokakāle”. ","html":"<span class='verse-line'>{}</span></p>"},"ja351:4.1":{"pli":"“Alaso gihī kāmabhogī na sādhu, ","html":"<p><span class='verse-line'>{}</span>"},"ja351:4.2":{"pli":"Asaññato pabbajito na sādhu; ","html":"<span class='verse-line'>{}</span>"},"ja351:4.3":{"pli":"Rājā na sādhu anisammakārī, ","html":"<span class='verse-line'>{}</span>"},"ja351:4.4":{"pli":"Yo paṇḍito kodhano taṁ na sādhu. ","html":"<span class='verse-line'>{}</span></p>"},"ja351:5.1":{"pli":"Nisamma khattiyo kayirā, ","html":"<p><span class='verse-line'>{}</span>"},"ja351:5.2":{"pli":"nānisamma disampati; ","html":"<span class='verse-line'>{}</span>"},"ja351:5.3":{"pli":"Nisammakārino rāja, ","html":"<span class='verse-line'>{}</span>"},"ja351:5.4":{"pli":"yaso kitti ca vaḍḍhatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja351:6.1":{"pli":"Maṇikuṇḍalajātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja352":{"ja352:0.1":{"pli":"Jātaka ","html":"<article id='ja352'><header><ul><li class='division'>{}</li>"},"ja352:0.2":{"pli":"Pañcakanipāta ","html":"<li>{}</li>"},"ja352:0.3":{"pli":"Maṇikuṇḍalavagga ","html":"<li>{}</li></ul>"},"ja352:0.4":{"pli":"2. Sujātajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja352:1.1":{"pli":"“Kiṁ nu santaramānova, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja352:1.2":{"pli":"lāyitvā haritaṁ tiṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja352:1.3":{"pli":"Khāda khādāti lapasi, ","html":"<span class='verse-line'>{}</span>"},"ja352:1.4":{"pli":"gatasattaṁ jaraggavaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja352:2.1":{"pli":"Na hi annena pānena, ","html":"<p><span class='verse-line'>{}</span>"},"ja352:2.2":{"pli":"mato goṇo samuṭṭhahe; ","html":"<span class='verse-line'>{}</span>"},"ja352:2.3":{"pli":"Tvañca tucchaṁ vilapasi, ","html":"<span class='verse-line'>{}</span>"},"ja352:2.4":{"pli":"yathā taṁ dummatī tathā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja352:3.1":{"pli":"“Tatheva tiṭṭhati sīsaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja352:3.2":{"pli":"hatthapādā ca vāladhi; ","html":"<span class='verse-line'>{}</span>"},"ja352:3.3":{"pli":"Sotā tatheva tiṭṭhanti, ","html":"<span class='verse-line'>{}</span>"},"ja352:3.4":{"pli":"maññe goṇo samuṭṭhahe. ","html":"<span class='verse-line'>{}</span></p>"},"ja352:4.1":{"pli":"Nevayyakassa sīsañca, ","html":"<p><span class='verse-line'>{}</span>"},"ja352:4.2":{"pli":"hatthapādā ca dissare; ","html":"<span class='verse-line'>{}</span>"},"ja352:4.3":{"pli":"Rudaṁ mattikathūpasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja352:4.4":{"pli":"nanu tvaññeva dummati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja352:5.1":{"pli":"“Ādittaṁ vata maṁ santaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja352:5.2":{"pli":"ghatasittaṁva pāvakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja352:5.3":{"pli":"Vārinā viya osiñcaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja352:5.4":{"pli":"sabbaṁ nibbāpaye daraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja352:6.1":{"pli":"Abbahī vata me sallaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja352:6.2":{"pli":"yamāsi hadayassitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja352:6.3":{"pli":"Yo me sokaparetassa, ","html":"<span class='verse-line'>{}</span>"},"ja352:6.4":{"pli":"pitusokaṁ apānudi. ","html":"<span class='verse-line'>{}</span></p>"},"ja352:7.1":{"pli":"Sohaṁ abbūḷhasallosmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja352:7.2":{"pli":"vītasoko anāvilo; ","html":"<span class='verse-line'>{}</span>"},"ja352:7.3":{"pli":"Na socāmi na rodāmi, ","html":"<span class='verse-line'>{}</span>"},"ja352:7.4":{"pli":"tava sutvāna māṇava. ","html":"<span class='verse-line'>{}</span></p>"},"ja352:8.1":{"pli":"Evaṁ karonti sappaññā, ","html":"<p><span class='verse-line'>{}</span>"},"ja352:8.2":{"pli":"ye honti anukampakā; ","html":"<span class='verse-line'>{}</span>"},"ja352:8.3":{"pli":"Vinivattenti sokamhā, ","html":"<span class='verse-line'>{}</span>"},"ja352:8.4":{"pli":"sujāto pitaraṁ yathā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja352:9.1":{"pli":"Sujātajātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja353":{"ja353:0.1":{"pli":"Jātaka ","html":"<article id='ja353'><header><ul><li class='division'>{}</li>"},"ja353:0.2":{"pli":"Pañcakanipāta ","html":"<li>{}</li>"},"ja353:0.3":{"pli":"Maṇikuṇḍalavagga ","html":"<li>{}</li></ul>"},"ja353:0.4":{"pli":"3. Venasākhajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja353:1.1":{"pli":"“Nayidaṁ niccaṁ bhavitabbaṁ brahmadatta, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja353:1.2":{"pli":"Khemaṁ subhikkhaṁ sukhatā ca kāye; ","html":"<span class='verse-line'>{}</span>"},"ja353:1.3":{"pli":"Atthaccaye mā ahu sampamūḷho, ","html":"<span class='verse-line'>{}</span>"},"ja353:1.4":{"pli":"Bhinnaplavo sāgarasseva majjhe. ","html":"<span class='verse-line'>{}</span></p>"},"ja353:2.1":{"pli":"Yāni karoti puriso, ","html":"<p><span class='verse-line'>{}</span>"},"ja353:2.2":{"pli":"tāni attani passati; ","html":"<span class='verse-line'>{}</span>"},"ja353:2.3":{"pli":"Kalyāṇakārī kalyāṇaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja353:2.4":{"pli":"pāpakārī ca pāpakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja353:2.5":{"pli":"Yādisaṁ vapate bījaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja353:2.6":{"pli":"tādisaṁ harate phalaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja353:3.1":{"pli":"“Idaṁ tadācariyavaco, ","html":"<p><span class='verse-line'>{}</span>"},"ja353:3.2":{"pli":"pārāsariyo yadabravi; ","html":"<span class='verse-line'>{}</span>"},"ja353:3.3":{"pli":"Mā su tvaṁ akari pāpaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja353:3.4":{"pli":"yaṁ tvaṁ pacchā kataṁ tape. ","html":"<span class='verse-line'>{}</span></p>"},"ja353:4.1":{"pli":"Ayameva so piṅgiya venasākho, ","html":"<p><span class='verse-line'>{}</span>"},"ja353:4.2":{"pli":"Yamhi ghātayiṁ khattiyānaṁ sahassaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja353:4.3":{"pli":"Alaṅkate candanasārānulitte, ","html":"<span class='verse-line'>{}</span>"},"ja353:4.4":{"pli":"Tameva dukkhaṁ paccāgataṁ mamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja353:5.1":{"pli":"Sāmā ca kho candanalittagattā, ","html":"<p><span class='verse-line'>{}</span>"},"ja353:5.2":{"pli":"Laṭṭhīva sobhañjanakassa uggatā; ","html":"<span class='verse-line'>{}</span>"},"ja353:5.3":{"pli":"Adisvā kālaṁ karissāmi ubbariṁ, ","html":"<span class='verse-line'>{}</span>"},"ja353:5.4":{"pli":"Taṁ me ito dukkhataraṁ bhavissatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja353:6.1":{"pli":"Venasākhajātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja354":{"ja354:0.1":{"pli":"Jātaka ","html":"<article id='ja354'><header><ul><li class='division'>{}</li>"},"ja354:0.2":{"pli":"Pañcakanipāta ","html":"<li>{}</li>"},"ja354:0.3":{"pli":"Maṇikuṇḍalavagga ","html":"<li>{}</li></ul>"},"ja354:0.4":{"pli":"4. Uragajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja354:1.1":{"pli":"“Uragova tacaṁ jiṇṇaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja354:1.2":{"pli":"hitvā gacchati saṁ tanuṁ; ","html":"<span class='verse-line'>{}</span>"},"ja354:1.3":{"pli":"Evaṁ sarīre nibbhoge, ","html":"<span class='verse-line'>{}</span>"},"ja354:1.4":{"pli":"pete kālaṅkate sati. ","html":"<span class='verse-line'>{}</span></p>"},"ja354:2.1":{"pli":"Ḍayhamāno na jānāti, ","html":"<p><span class='verse-line'>{}</span>"},"ja354:2.2":{"pli":"ñātīnaṁ paridevitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja354:2.3":{"pli":"Tasmā etaṁ na socāmi, ","html":"<span class='verse-line'>{}</span>"},"ja354:2.4":{"pli":"gato so tassa yā gati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja354:3.1":{"pli":"“Anavhito tato āgā, ","html":"<p><span class='verse-line'>{}</span>"},"ja354:3.2":{"pli":"ananuññāto ito gato; ","html":"<span class='verse-line'>{}</span>"},"ja354:3.3":{"pli":"Yathāgato tathā gato, ","html":"<span class='verse-line'>{}</span>"},"ja354:3.4":{"pli":"tattha kā paridevanā. ","html":"<span class='verse-line'>{}</span></p>"},"ja354:4.1":{"pli":"Ḍayhamāno na jānāti, ","html":"<p><span class='verse-line'>{}</span>"},"ja354:4.2":{"pli":"ñātīnaṁ paridevitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja354:4.3":{"pli":"Tasmā etaṁ na socāmi, ","html":"<span class='verse-line'>{}</span>"},"ja354:4.4":{"pli":"gato so tassa yā gati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja354:5.1":{"pli":"“Sace rode kisā assaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja354:5.2":{"pli":"tassā me kiṁ phalaṁ siyā; ","html":"<span class='verse-line'>{}</span>"},"ja354:5.3":{"pli":"Ñātimittasuhajjānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja354:5.4":{"pli":"bhiyyo no aratī siyā. ","html":"<span class='verse-line'>{}</span></p>"},"ja354:6.1":{"pli":"Ḍayhamāno na jānāti, ","html":"<p><span class='verse-line'>{}</span>"},"ja354:6.2":{"pli":"ñātīnaṁ paridevitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja354:6.3":{"pli":"Tasmā etaṁ na socāmi, ","html":"<span class='verse-line'>{}</span>"},"ja354:6.4":{"pli":"gato so tassa yā gati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja354:7.1":{"pli":"“Yathāpi dārako candaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja354:7.2":{"pli":"gacchantamanurodati; ","html":"<span class='verse-line'>{}</span>"},"ja354:7.3":{"pli":"Evaṁsampadamevetaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja354:7.4":{"pli":"yo petamanusocati. ","html":"<span class='verse-line'>{}</span></p>"},"ja354:8.1":{"pli":"Ḍayhamāno na jānāti, ","html":"<p><span class='verse-line'>{}</span>"},"ja354:8.2":{"pli":"ñātīnaṁ paridevitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja354:8.3":{"pli":"Tasmā etaṁ na socāmi, ","html":"<span class='verse-line'>{}</span>"},"ja354:8.4":{"pli":"gato so tassa yā gati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja354:9.1":{"pli":"“Yathāpi udakakumbho, ","html":"<p><span class='verse-line'>{}</span>"},"ja354:9.2":{"pli":"bhinno appaṭisandhiyo; ","html":"<span class='verse-line'>{}</span>"},"ja354:9.3":{"pli":"Evaṁsampadamevetaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja354:9.4":{"pli":"yo petamanusocati. ","html":"<span class='verse-line'>{}</span></p>"},"ja354:10.1":{"pli":"Ḍayhamāno na jānāti, ","html":"<p><span class='verse-line'>{}</span>"},"ja354:10.2":{"pli":"ñātīnaṁ paridevitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja354:10.3":{"pli":"Tasmā etaṁ na socāmi, ","html":"<span class='verse-line'>{}</span>"},"ja354:10.4":{"pli":"gato so tassa yā gatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja354:11.1":{"pli":"Uragajātakaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja355":{"ja355:0.1":{"pli":"Jātaka ","html":"<article id='ja355'><header><ul><li class='division'>{}</li>"},"ja355:0.2":{"pli":"Pañcakanipāta ","html":"<li>{}</li>"},"ja355:0.3":{"pli":"Maṇikuṇḍalavagga ","html":"<li>{}</li></ul>"},"ja355:0.4":{"pli":"5. Ghaṭajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja355:1.1":{"pli":"“Aññe socanti rodanti, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja355:1.2":{"pli":"aññe assumukhā janā; ","html":"<span class='verse-line'>{}</span>"},"ja355:1.3":{"pli":"Pasannamukhavaṇṇosi, ","html":"<span class='verse-line'>{}</span>"},"ja355:1.4":{"pli":"kasmā ghaṭa na socasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja355:2.1":{"pli":"“Nābbhatītaharo soko, ","html":"<p><span class='verse-line'>{}</span>"},"ja355:2.2":{"pli":"nānāgatasukhāvaho; ","html":"<span class='verse-line'>{}</span>"},"ja355:2.3":{"pli":"Tasmā dhaṅka na socāmi, ","html":"<span class='verse-line'>{}</span>"},"ja355:2.4":{"pli":"natthi soke dutīyatā. ","html":"<span class='verse-line'>{}</span></p>"},"ja355:3.1":{"pli":"Socaṁ paṇḍu kiso hoti, ","html":"<p><span class='verse-line'>{}</span>"},"ja355:3.2":{"pli":"bhattañcassa na ruccati; ","html":"<span class='verse-line'>{}</span>"},"ja355:3.3":{"pli":"Amittā sumanā honti, ","html":"<span class='verse-line'>{}</span>"},"ja355:3.4":{"pli":"sallaviddhassa ruppato. ","html":"<span class='verse-line'>{}</span></p>"},"ja355:4.1":{"pli":"Gāme vā yadi vāraññe, ","html":"<p><span class='verse-line'>{}</span>"},"ja355:4.2":{"pli":"ninne vā yadi vā thale; ","html":"<span class='verse-line'>{}</span>"},"ja355:4.3":{"pli":"Ṭhitaṁ maṁ nāgamissati, ","html":"<span class='verse-line'>{}</span>"},"ja355:4.4":{"pli":"evaṁ diṭṭhapado ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja355:5.1":{"pli":"Yassattā nālamekova, ","html":"<p><span class='verse-line'>{}</span>"},"ja355:5.2":{"pli":"sabbakāmarasāharo; ","html":"<span class='verse-line'>{}</span>"},"ja355:5.3":{"pli":"Sabbāpi pathavī tassa, ","html":"<span class='verse-line'>{}</span>"},"ja355:5.4":{"pli":"na sukhaṁ āvahissatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja355:6.1":{"pli":"Ghaṭajātakaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja356":{"ja356:0.1":{"pli":"Jātaka ","html":"<article id='ja356'><header><ul><li class='division'>{}</li>"},"ja356:0.2":{"pli":"Pañcakanipāta ","html":"<li>{}</li>"},"ja356:0.3":{"pli":"Maṇikuṇḍalavagga ","html":"<li>{}</li></ul>"},"ja356:0.4":{"pli":"6. Koraṇḍiyajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja356:1.1":{"pli":"“Eko araññe girikandarāyaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja356:1.2":{"pli":"Paggayha paggayha silaṁ pavecchasi; ","html":"<span class='verse-line'>{}</span>"},"ja356:1.3":{"pli":"Punappunaṁ santaramānarūpo, ","html":"<span class='verse-line'>{}</span>"},"ja356:1.4":{"pli":"Koraṇḍiya ko nu tava yidhattho”. ","html":"<span class='verse-line'>{}</span></p>"},"ja356:2.1":{"pli":"“Ahañhimaṁ sāgara sevitantaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja356:2.2":{"pli":"Samaṁ karissāmi yathāpi pāṇi; ","html":"<span class='verse-line'>{}</span>"},"ja356:2.3":{"pli":"Vikiriya sānūni ca pabbatāni ca, ","html":"<span class='verse-line'>{}</span>"},"ja356:2.4":{"pli":"Tasmā silaṁ dariyā pakkhipāmi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja356:3.1":{"pli":"“Nayimaṁ mahiṁ arahati pāṇikappaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja356:3.2":{"pli":"Samaṁ manusso karaṇāya meko; ","html":"<span class='verse-line'>{}</span>"},"ja356:3.3":{"pli":"Maññāmimaññeva dariṁ jigīsaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja356:3.4":{"pli":"Koraṇḍiya hāhasi jīvalokaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja356:4.1":{"pli":"“Sace ahaṁ bhūtadharaṁ na sakkā, ","html":"<p><span class='verse-line'>{}</span>"},"ja356:4.2":{"pli":"Samaṁ manusso karaṇāya meko; ","html":"<span class='verse-line'>{}</span>"},"ja356:4.3":{"pli":"Evameva tvaṁ brahme ime manusse, ","html":"<span class='verse-line'>{}</span>"},"ja356:4.4":{"pli":"Nānādiṭṭhike nānayissasi te”. ","html":"<span class='verse-line'>{}</span></p>"},"ja356:5.1":{"pli":"“Saṅkhittarūpena bhavaṁ mamatthaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja356:5.2":{"pli":"Akkhāsi koraṇḍiya evametaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja356:5.3":{"pli":"Yathā na sakkā pathavī samāyaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja356:5.4":{"pli":"Kattuṁ manussena tathā manussā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja356:6.1":{"pli":"Koraṇḍiyajātakaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja357":{"ja357:0.1":{"pli":"Jātaka ","html":"<article id='ja357'><header><ul><li class='division'>{}</li>"},"ja357:0.2":{"pli":"Pañcakanipāta ","html":"<li>{}</li>"},"ja357:0.3":{"pli":"Maṇikuṇḍalavagga ","html":"<li>{}</li></ul>"},"ja357:0.4":{"pli":"7. Laṭukikajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja357:1.1":{"pli":"“Vandāmi taṁ kuñjara saṭṭhihāyanaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja357:1.2":{"pli":"Āraññakaṁ yūthapatiṁ yasassiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja357:1.3":{"pli":"Pakkhehi taṁ pañjalikaṁ karomi, ","html":"<span class='verse-line'>{}</span>"},"ja357:1.4":{"pli":"Mā me vadhī puttake dubbalāya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja357:2.1":{"pli":"“Vandāmi taṁ kuñjara ekacāriṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja357:2.2":{"pli":"Āraññakaṁ pabbatasānugocaraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja357:2.3":{"pli":"Pakkhehi taṁ pañjalikaṁ karomi, ","html":"<span class='verse-line'>{}</span>"},"ja357:2.4":{"pli":"Mā me vadhī puttake dubbalāya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja357:3.1":{"pli":"“Vadhissāmi te laṭukike puttakāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja357:3.2":{"pli":"Kiṁ me tuvaṁ kāhasi dubbalāsi; ","html":"<span class='verse-line'>{}</span>"},"ja357:3.3":{"pli":"Sataṁ sahassānipi tādisīnaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja357:3.4":{"pli":"Vāmena pādena papothayeyyaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja357:4.1":{"pli":"“Na heva sabbattha balena kiccaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja357:4.2":{"pli":"Balañhi bālassa vadhāya hoti; ","html":"<span class='verse-line'>{}</span>"},"ja357:4.3":{"pli":"Karissāmi te nāgarājā anatthaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja357:4.4":{"pli":"Yo me vadhī puttake dubbalāya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja357:5.1":{"pli":"“Kākañca passa laṭukikaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja357:5.2":{"pli":"Maṇḍūkaṁ nīlamakkhikaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja357:5.3":{"pli":"Ete nāgaṁ aghātesuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja357:5.4":{"pli":"Passa verassa verinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja357:5.5":{"pli":"Tasmā hi veraṁ na kayirātha, ","html":"<span class='verse-line'>{}</span>"},"ja357:5.6":{"pli":"Appiyenapi kenacī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja357:6.1":{"pli":"Laṭukikajātakaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja358":{"ja358:0.1":{"pli":"Jātaka ","html":"<article id='ja358'><header><ul><li class='division'>{}</li>"},"ja358:0.2":{"pli":"Pañcakanipāta ","html":"<li>{}</li>"},"ja358:0.3":{"pli":"Maṇikuṇḍalavagga ","html":"<li>{}</li></ul>"},"ja358:0.4":{"pli":"8. Cūḷadhammapālajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja358:1.1":{"pli":"“Ahameva dūsiyā bhūnahatā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja358:1.2":{"pli":"Rañño mahāpatāpassa; ","html":"<span class='verse-line'>{}</span>"},"ja358:1.3":{"pli":"Etaṁ muñcatu dhammapālaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja358:1.4":{"pli":"Hatthe me deva chedehi. ","html":"<span class='verse-line'>{}</span></p>"},"ja358:2.1":{"pli":"Ahameva dūsiyā bhūnahatā, ","html":"<p><span class='verse-line'>{}</span>"},"ja358:2.2":{"pli":"Rañño mahāpatāpassa; ","html":"<span class='verse-line'>{}</span>"},"ja358:2.3":{"pli":"Etaṁ muñcatu dhammapālaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja358:2.4":{"pli":"Pāde me deva chedehi. ","html":"<span class='verse-line'>{}</span></p>"},"ja358:3.1":{"pli":"Ahameva dūsiyā bhūnahatā, ","html":"<p><span class='verse-line'>{}</span>"},"ja358:3.2":{"pli":"Rañño mahāpatāpassa; ","html":"<span class='verse-line'>{}</span>"},"ja358:3.3":{"pli":"Etaṁ muñcatu dhammapālaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja358:3.4":{"pli":"Sīsaṁ me deva chedehi. ","html":"<span class='verse-line'>{}</span></p>"},"ja358:4.1":{"pli":"Na hi nūnimassa rañño, ","html":"<p><span class='verse-line'>{}</span>"},"ja358:4.2":{"pli":"Mittāmaccā ca vijjare suhadā; ","html":"<span class='verse-line'>{}</span>"},"ja358:4.3":{"pli":"Ye na vadanti rājānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja358:4.4":{"pli":"Mā ghātayi orasaṁ puttaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja358:5.1":{"pli":"Na hi nūnimassa rañño, ","html":"<p><span class='verse-line'>{}</span>"},"ja358:5.2":{"pli":"Ñātī mittā ca vijjare suhadā; ","html":"<span class='verse-line'>{}</span>"},"ja358:5.3":{"pli":"Ye na vadanti rājānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja358:5.4":{"pli":"Mā ghātayi atrajaṁ puttaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja358:6.1":{"pli":"Candanasārānulittā, ","html":"<p><span class='verse-line'>{}</span>"},"ja358:6.2":{"pli":"Bāhā chijjanti dhammapālassa; ","html":"<span class='verse-line'>{}</span>"},"ja358:6.3":{"pli":"Dāyādassa pathabyā, ","html":"<span class='verse-line'>{}</span>"},"ja358:6.4":{"pli":"Pāṇā me deva rujjhantī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja358:7.1":{"pli":"Cūḷadhammapālajātakaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja359":{"ja359:0.1":{"pli":"Jātaka ","html":"<article id='ja359'><header><ul><li class='division'>{}</li>"},"ja359:0.2":{"pli":"Pañcakanipāta ","html":"<li>{}</li>"},"ja359:0.3":{"pli":"Maṇikuṇḍalavagga ","html":"<li>{}</li></ul>"},"ja359:0.4":{"pli":"9. Suvaṇṇamigajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja359:1.1":{"pli":"“Vikkama re haripāda, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja359:1.2":{"pli":"vikkama re mahāmiga; ","html":"<span class='verse-line'>{}</span>"},"ja359:1.3":{"pli":"Chinda vārattikaṁ pāsaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja359:1.4":{"pli":"nāhaṁ ekā vane rame”. ","html":"<span class='verse-line'>{}</span></p>"},"ja359:2.1":{"pli":"“Vikkamāmi na pāremi, ","html":"<p><span class='verse-line'>{}</span>"},"ja359:2.2":{"pli":"bhūmiṁ sumbhāmi vegasā; ","html":"<span class='verse-line'>{}</span>"},"ja359:2.3":{"pli":"Daḷho vārattiko pāso, ","html":"<span class='verse-line'>{}</span>"},"ja359:2.4":{"pli":"pādaṁ me parikantati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja359:3.1":{"pli":"“Attharassu palāsāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja359:3.2":{"pli":"asiṁ nibbāha luddaka; ","html":"<span class='verse-line'>{}</span>"},"ja359:3.3":{"pli":"Paṭhamaṁ maṁ vadhitvāna, ","html":"<span class='verse-line'>{}</span>"},"ja359:3.4":{"pli":"hana pacchā mahāmigaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja359:4.1":{"pli":"“Na me sutaṁ vā diṭṭhaṁ vā, ","html":"<p><span class='verse-line'>{}</span>"},"ja359:4.2":{"pli":"Bhāsantiṁ mānusiṁ migiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja359:4.3":{"pli":"Tvañca bhadde sukhī hohi, ","html":"<span class='verse-line'>{}</span>"},"ja359:4.4":{"pli":"Eso cāpi mahāmigo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja359:5.1":{"pli":"“Evaṁ luddaka nandassu, ","html":"<p><span class='verse-line'>{}</span>"},"ja359:5.2":{"pli":"saha sabbehi ñātibhi; ","html":"<span class='verse-line'>{}</span>"},"ja359:5.3":{"pli":"Yathāhamajja nandāmi, ","html":"<span class='verse-line'>{}</span>"},"ja359:5.4":{"pli":"muttaṁ disvā mahāmigan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja359:6.1":{"pli":"Suvaṇṇamigajātakaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja36":{"ja36:0.1":{"pli":"Jātaka ","eng":"Stories of Past Lives 36 ","html":"<article id='ja36'><header><ul><li class='division'>{}</li>"},"ja36:0.2":{"pli":"Ekakanipāta ","eng":"The Book of the Ones ","html":"<li>{}</li>"},"ja36:0.3":{"pli":"Kulāvakavagga ","eng":"Nests ","html":"<li>{}</li></ul>"},"ja36:0.4":{"pli":"6. Sakuṇajātaka ","eng":"Bird: a past life story ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja36:1.1":{"pli":"“Yaṁ nissitā jagatiruhaṁ vihaṅgamā, ","eng":"You sky-flyers staying near the great evergreen, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>","comm":"Noticing a fire starting in the tree under which they shelter, the Bodhisatta tries to warn the flock, but the foolish birds dismissed him, “for he is always seeing crocodiles in a drop of water”. | “Evergreen” (<i lang='pi' translate='no'>jagatirūha</i>, literally “planet-growth”) is a poetic term for a tree. "},"ja36:1.2":{"pli":"Svāyaṁ aggiṁ pamuñcati; ","eng":"this fire is emerging! ","html":"<span class='verse-line'>{}</span>"},"ja36:1.3":{"pli":"Disā bhajatha vakkaṅgā, ","eng":"Geese! Flee to the quarters! ","html":"<span class='verse-line'>{}</span>","comm":"<i lang='pi' translate='no'>Vakkaṅga</i>, in Sanskrit variously spelled <i lang='pi' translate='no'>vakrāṅga</i> or <i lang='pi' translate='no'>cakrāṅga</i> is the <i lang='pi' translate='no'>cakravāka</i> or Brahminy goose. It is named for its curved neck. "},"ja36:1.4":{"pli":"Jātaṁ saraṇato bhayan”ti. ","eng":"The threat is born from the refuge! ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja36:2.1":{"pli":"Sakuṇajātakaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja360":{"ja360:0.1":{"pli":"Jātaka ","html":"<article id='ja360'><header><ul><li class='division'>{}</li>"},"ja360:0.2":{"pli":"Pañcakanipāta ","html":"<li>{}</li>"},"ja360:0.3":{"pli":"Maṇikuṇḍalavagga ","html":"<li>{}</li></ul>"},"ja360:0.4":{"pli":"10. Suyonandījātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja360:1.1":{"pli":"“Vāti gandho timirānaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja360:1.2":{"pli":"kusamuddo ca ghosavā; ","html":"<span class='verse-line'>{}</span>"},"ja360:1.3":{"pli":"Dūre ito suyonandī, ","html":"<span class='verse-line'>{}</span>"},"ja360:1.4":{"pli":"tamba kāmā tudanti maṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja360:2.1":{"pli":"“Kathaṁ samuddamatari, ","html":"<p><span class='verse-line'>{}</span>"},"ja360:2.2":{"pli":"Kathaṁ addakkhi sedumaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja360:2.3":{"pli":"Kathaṁ tassā ca tuyhañca, ","html":"<span class='verse-line'>{}</span>"},"ja360:2.4":{"pli":"Ahu saggasamāgamo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja360:3.1":{"pli":"“Kurukacchā payātānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja360:3.2":{"pli":"vāṇijānaṁ dhanesinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja360:3.3":{"pli":"Makarehi abhidā nāvā, ","html":"<span class='verse-line'>{}</span>"},"ja360:3.4":{"pli":"phalakenāhamaplaviṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja360:4.1":{"pli":"Sā maṁ saṇhena mudunā, ","html":"<p><span class='verse-line'>{}</span>"},"ja360:4.2":{"pli":"niccaṁ candanagandhinī; ","html":"<span class='verse-line'>{}</span>"},"ja360:4.3":{"pli":"Aṅgena uddharī bhaddā, ","html":"<span class='verse-line'>{}</span>"},"ja360:4.4":{"pli":"mātā puttaṁva orasaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja360:5.1":{"pli":"Sā maṁ annena pānena, ","html":"<p><span class='verse-line'>{}</span>"},"ja360:5.2":{"pli":"vatthena sayanena ca; ","html":"<span class='verse-line'>{}</span>"},"ja360:5.3":{"pli":"Attanāpi ca mandakkhī, ","html":"<span class='verse-line'>{}</span>"},"ja360:5.4":{"pli":"evaṁ tamba vijānahī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja360:6.1":{"pli":"Suyonandījātakaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja360:6.2":{"pli":"Maṇikuṇḍalavaggo paṭhamo. ","html":"<p class='endvagga'>{}</p>"},"ja360:7.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja360:8.1":{"pli":"Atha jinavaro haritaṁ tiṇako, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja360:8.2":{"pli":"Atha bhinnaplavo uragova ghaṭo; ","html":"<span class='verse-line'>{}</span>"},"ja360:8.3":{"pli":"Dariyā puna kuñjara bhūnahatā, ","html":"<span class='verse-line'>{}</span>"},"ja360:8.4":{"pli":"Migamuttamasaggavarena dasāti. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"ja361":{"ja361:0.1":{"pli":"Jātaka ","html":"<article id='ja361'><header><ul><li class='division'>{}</li>"},"ja361:0.2":{"pli":"Pañcakanipāta ","html":"<li>{}</li>"},"ja361:0.3":{"pli":"Vaṇṇārohavagga ","html":"<li>{}</li></ul>"},"ja361:0.4":{"pli":"1. Vaṇṇārohajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja361:1.1":{"pli":"“Vaṇṇārohena jātiyā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja361:1.2":{"pli":"balanikkamanena ca; ","html":"<span class='verse-line'>{}</span>"},"ja361:1.3":{"pli":"Subāhu na mayā seyyo, ","html":"<span class='verse-line'>{}</span>"},"ja361:1.4":{"pli":"sudāṭha iti bhāsasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja361:2.1":{"pli":"“Vaṇṇārohena jātiyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja361:2.2":{"pli":"balanikkamanena ca; ","html":"<span class='verse-line'>{}</span>"},"ja361:2.3":{"pli":"Sudāṭho na mayā seyyo, ","html":"<span class='verse-line'>{}</span>"},"ja361:2.4":{"pli":"subāhu iti bhāsasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja361:3.1":{"pli":"Evañce maṁ viharantaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja361:3.2":{"pli":"subāhu samma dubbhasi; ","html":"<span class='verse-line'>{}</span>"},"ja361:3.3":{"pli":"Na dānāhaṁ tayā saddhiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja361:3.4":{"pli":"saṁvāsamabhirocaye. ","html":"<span class='verse-line'>{}</span></p>"},"ja361:4.1":{"pli":"Yo paresaṁ vacanāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja361:4.2":{"pli":"saddaheyya yathātathaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja361:4.3":{"pli":"Khippaṁ bhijjetha mittasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja361:4.4":{"pli":"verañca pasave bahuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja361:5.1":{"pli":"Na so mitto yo sadā appamatto, ","html":"<p><span class='verse-line'>{}</span>"},"ja361:5.2":{"pli":"Bhedāsaṅkī randhamevānupassī; ","html":"<span class='verse-line'>{}</span>"},"ja361:5.3":{"pli":"Yasmiñca setī urasīva putto, ","html":"<span class='verse-line'>{}</span>"},"ja361:5.4":{"pli":"Sa ve mitto yo abhejjo parehī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja361:6.1":{"pli":"Vaṇṇārohajātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja362":{"ja362:0.1":{"pli":"Jātaka ","html":"<article id='ja362'><header><ul><li class='division'>{}</li>"},"ja362:0.2":{"pli":"Pañcakanipāta ","html":"<li>{}</li>"},"ja362:0.3":{"pli":"Vaṇṇārohavagga ","html":"<li>{}</li></ul>"},"ja362:0.4":{"pli":"2. Sīlavīmaṁsajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja362:1.1":{"pli":"“Sīlaṁ seyyo sutaṁ seyyo, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja362:1.2":{"pli":"iti me saṁsayo ahu; ","html":"<span class='verse-line'>{}</span>"},"ja362:1.3":{"pli":"Sīlameva sutā seyyo, ","html":"<span class='verse-line'>{}</span>"},"ja362:1.4":{"pli":"iti me natthi saṁsayo. ","html":"<span class='verse-line'>{}</span></p>"},"ja362:2.1":{"pli":"Moghā jāti ca vaṇṇo ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja362:2.2":{"pli":"sīlameva kiruttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja362:2.3":{"pli":"Sīlena anupetassa, ","html":"<span class='verse-line'>{}</span>"},"ja362:2.4":{"pli":"sutenattho na vijjati. ","html":"<span class='verse-line'>{}</span></p>"},"ja362:3.1":{"pli":"Khattiyo ca adhammaṭṭho, ","html":"<p><span class='verse-line'>{}</span>"},"ja362:3.2":{"pli":"vesso cādhammanissito; ","html":"<span class='verse-line'>{}</span>"},"ja362:3.3":{"pli":"Te pariccajjubho loke, ","html":"<span class='verse-line'>{}</span>"},"ja362:3.4":{"pli":"upapajjanti duggatiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja362:4.1":{"pli":"Khattiyā brāhmaṇā vessā, ","html":"<p><span class='verse-line'>{}</span>"},"ja362:4.2":{"pli":"suddā caṇḍālapukkusā; ","html":"<span class='verse-line'>{}</span>"},"ja362:4.3":{"pli":"Idha dhammaṁ caritvāna, ","html":"<span class='verse-line'>{}</span>"},"ja362:4.4":{"pli":"bhavanti tidive samā. ","html":"<span class='verse-line'>{}</span></p>"},"ja362:5.1":{"pli":"Na vedā samparāyāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja362:5.2":{"pli":"Na jāti nāpi bandhavā; ","html":"<span class='verse-line'>{}</span>"},"ja362:5.3":{"pli":"Sakañca sīlaṁ saṁsuddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja362:5.4":{"pli":"Samparāyāya sukhāya cā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja362:6.1":{"pli":"Sīlavīmaṁsajātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja363":{"ja363:0.1":{"pli":"Jātaka ","html":"<article id='ja363'><header><ul><li class='division'>{}</li>"},"ja363:0.2":{"pli":"Pañcakanipāta ","html":"<li>{}</li>"},"ja363:0.3":{"pli":"Vaṇṇārohavagga ","html":"<li>{}</li></ul>"},"ja363:0.4":{"pli":"3. Hirijātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja363:1.1":{"pli":"“Hiriṁ tarantaṁ vijigucchamānaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja363:1.2":{"pli":"Tavāhamasmī iti bhāsamānaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja363:1.3":{"pli":"Seyyāni kammāni anādiyantaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja363:1.4":{"pli":"Neso mamanti iti naṁ vijaññā. ","html":"<span class='verse-line'>{}</span></p>"},"ja363:2.1":{"pli":"Yañhi kayirā tañhi vade, ","html":"<p><span class='verse-line'>{}</span>"},"ja363:2.2":{"pli":"yaṁ na kayirā na taṁ vade; ","html":"<span class='verse-line'>{}</span>"},"ja363:2.3":{"pli":"Akarontaṁ bhāsamānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja363:2.4":{"pli":"parijānanti paṇḍitā. ","html":"<span class='verse-line'>{}</span></p>"},"ja363:3.1":{"pli":"Na so mitto yo sadā appamatto, ","html":"<p><span class='verse-line'>{}</span>"},"ja363:3.2":{"pli":"Bhedāsaṅkī randhamevānupassī; ","html":"<span class='verse-line'>{}</span>"},"ja363:3.3":{"pli":"Yasmiñca setī urasīva putto, ","html":"<span class='verse-line'>{}</span>"},"ja363:3.4":{"pli":"Sa ve mitto yo abhejjo parehi. ","html":"<span class='verse-line'>{}</span></p>"},"ja363:4.1":{"pli":"Pāmojjakaraṇaṁ ṭhānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja363:4.2":{"pli":"pasaṁsāvahanaṁ sukhaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja363:4.3":{"pli":"Phalānisaṁso bhāveti, ","html":"<span class='verse-line'>{}</span>"},"ja363:4.4":{"pli":"vahanto porisaṁ dhuraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja363:5.1":{"pli":"Pavivekarasaṁ pitvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja363:5.2":{"pli":"rasaṁ upasamassa ca; ","html":"<span class='verse-line'>{}</span>"},"ja363:5.3":{"pli":"Niddaro hoti nippāpo, ","html":"<span class='verse-line'>{}</span>"},"ja363:5.4":{"pli":"dhammappītirasaṁ pivan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja363:6.1":{"pli":"Hirijātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja364":{"ja364:0.1":{"pli":"Jātaka ","html":"<article id='ja364'><header><ul><li class='division'>{}</li>"},"ja364:0.2":{"pli":"Pañcakanipāta ","html":"<li>{}</li>"},"ja364:0.3":{"pli":"Vaṇṇārohavagga ","html":"<li>{}</li></ul>"},"ja364:0.4":{"pli":"4. Khajjopanakajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja364:1.1":{"pli":"“Ko nu santamhi pajjote, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja364:1.2":{"pli":"aggipariyesanaṁ caraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja364:1.3":{"pli":"Addakkhi ratti khajjotaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja364:1.4":{"pli":"jātavedaṁ amaññatha. ","html":"<span class='verse-line'>{}</span></p>"},"ja364:2.1":{"pli":"Svassa gomayacuṇṇāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja364:2.2":{"pli":"abhimatthaṁ tiṇāni ca; ","html":"<span class='verse-line'>{}</span>"},"ja364:2.3":{"pli":"Viparītāya saññāya, ","html":"<span class='verse-line'>{}</span>"},"ja364:2.4":{"pli":"nāsakkhi pajjaletave. ","html":"<span class='verse-line'>{}</span></p>"},"ja364:3.1":{"pli":"Evampi anupāyena, ","html":"<p><span class='verse-line'>{}</span>"},"ja364:3.2":{"pli":"atthaṁ na labhate migo; ","html":"<span class='verse-line'>{}</span>"},"ja364:3.3":{"pli":"Visāṇato gavaṁ dohaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja364:3.4":{"pli":"yattha khīraṁ na vindati. ","html":"<span class='verse-line'>{}</span></p>"},"ja364:4.1":{"pli":"Vividhehi upāyehi, ","html":"<p><span class='verse-line'>{}</span>"},"ja364:4.2":{"pli":"atthaṁ papponti māṇavā; ","html":"<span class='verse-line'>{}</span>"},"ja364:4.3":{"pli":"Niggahena amittānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja364:4.4":{"pli":"mittānaṁ paggahena ca. ","html":"<span class='verse-line'>{}</span></p>"},"ja364:5.1":{"pli":"Senāmokkhapalābhena, ","html":"<p><span class='verse-line'>{}</span>"},"ja364:5.2":{"pli":"vallabhānaṁ nayena ca; ","html":"<span class='verse-line'>{}</span>"},"ja364:5.3":{"pli":"Jagatiṁ jagatipālā, ","html":"<span class='verse-line'>{}</span>"},"ja364:5.4":{"pli":"āvasanti vasundharan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja364:6.1":{"pli":"Khajjopanakajātakaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja365":{"ja365:0.1":{"pli":"Jātaka ","html":"<article id='ja365'><header><ul><li class='division'>{}</li>"},"ja365:0.2":{"pli":"Pañcakanipāta ","html":"<li>{}</li>"},"ja365:0.3":{"pli":"Vaṇṇārohavagga ","html":"<li>{}</li></ul>"},"ja365:0.4":{"pli":"5. Ahituṇḍikajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja365:1.1":{"pli":"“Dhuttomhi samma sumukha, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja365:1.2":{"pli":"jūte akkhaparājito; ","html":"<span class='verse-line'>{}</span>"},"ja365:1.3":{"pli":"Harehi ambapakkāni, ","html":"<span class='verse-line'>{}</span>"},"ja365:1.4":{"pli":"vīriyaṁ te bhakkhayāmase”. ","html":"<span class='verse-line'>{}</span></p>"},"ja365:2.1":{"pli":"“Alikaṁ vata maṁ samma, ","html":"<p><span class='verse-line'>{}</span>"},"ja365:2.2":{"pli":"abhūtena pasaṁsasi; ","html":"<span class='verse-line'>{}</span>"},"ja365:2.3":{"pli":"Ko te suto vā diṭṭho vā, ","html":"<span class='verse-line'>{}</span>"},"ja365:2.4":{"pli":"sumukho nāma makkaṭo. ","html":"<span class='verse-line'>{}</span></p>"},"ja365:3.1":{"pli":"Ajjāpi me taṁ manasi, ","html":"<p><span class='verse-line'>{}</span>"},"ja365:3.2":{"pli":"yaṁ maṁ tvaṁ ahituṇḍika; ","html":"<span class='verse-line'>{}</span>"},"ja365:3.3":{"pli":"Dhaññāpaṇaṁ pavisitvā, ","html":"<span class='verse-line'>{}</span>"},"ja365:3.4":{"pli":"matto chātaṁ hanāsi maṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja365:4.1":{"pli":"Tāhaṁ saraṁ dukkhaseyyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja365:4.2":{"pli":"api rajjampi kāraye; ","html":"<span class='verse-line'>{}</span>"},"ja365:4.3":{"pli":"Nevāhaṁ yācito dajjaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja365:4.4":{"pli":"tathā hi bhayatajjito. ","html":"<span class='verse-line'>{}</span></p>"},"ja365:5.1":{"pli":"Yañca jaññā kule jātaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja365:5.2":{"pli":"Gabbhe tittaṁ amacchariṁ; ","html":"<span class='verse-line'>{}</span>"},"ja365:5.3":{"pli":"Tena sakhiñca mittañca, ","html":"<span class='verse-line'>{}</span>"},"ja365:5.4":{"pli":"Dhīro sandhātumarahatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja365:6.1":{"pli":"Ahituṇḍikajātakaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}