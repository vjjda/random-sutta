{"ja329":{"ja329:0.1":{"pli":"Jātaka ","html":"<article id='ja329'><header><ul><li class='division'>{}</li>"},"ja329:0.2":{"pli":"Catukkanipāta ","html":"<li>{}</li>"},"ja329:0.3":{"pli":"Kuṭidūsakavagga ","html":"<li>{}</li></ul>"},"ja329:0.4":{"pli":"9. Kāḷabāhujātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja329:1.1":{"pli":"“Yaṁ annapānassa pure labhāma, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja329:1.2":{"pli":"Taṁ dāni sākhamigameva gacchati; ","html":"<span class='verse-line'>{}</span>"},"ja329:1.3":{"pli":"Gacchāma dāni vanameva rādha, ","html":"<span class='verse-line'>{}</span>"},"ja329:1.4":{"pli":"Asakkatā casma dhanañjayāya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja329:2.1":{"pli":"“Lābho alābho yaso ayaso ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja329:2.2":{"pli":"Nindā pasaṁsā ca sukhañca dukkhaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja329:2.3":{"pli":"Ete aniccā manujesu dhammā, ","html":"<span class='verse-line'>{}</span>"},"ja329:2.4":{"pli":"Mā soci kiṁ socasi poṭṭhapāda”. ","html":"<span class='verse-line'>{}</span></p>"},"ja329:3.1":{"pli":"“Addhā tuvaṁ paṇḍitakosi rādha, ","html":"<p><span class='verse-line'>{}</span>"},"ja329:3.2":{"pli":"Jānāsi atthāni anāgatāni; ","html":"<span class='verse-line'>{}</span>"},"ja329:3.3":{"pli":"Kathaṁ nu sākhāmigaṁ dakkhisāma, ","html":"<span class='verse-line'>{}</span>"},"ja329:3.4":{"pli":"Niddhāvitaṁ rājakulatova jammaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja329:4.1":{"pli":"“Cāleti kaṇṇaṁ bhakuṭiṁ karoti, ","html":"<p><span class='verse-line'>{}</span>"},"ja329:4.2":{"pli":"Muhuṁ muhuṁ bhāyayate kumāre; ","html":"<span class='verse-line'>{}</span>"},"ja329:4.3":{"pli":"Sayameva taṁ kāhati kāḷabāhu, ","html":"<span class='verse-line'>{}</span>"},"ja329:4.4":{"pli":"Yenārakā ṭhassati annapānā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja329:5.1":{"pli":"Kāḷabāhujātakaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja33":{"ja33:0.1":{"pli":"Jātaka ","eng":"Stories of Past Lives 33 ","html":"<article id='ja33'><header><ul><li class='division'>{}</li>"},"ja33:0.2":{"pli":"Ekakanipāta ","eng":"The Book of the Ones ","html":"<li>{}</li>"},"ja33:0.3":{"pli":"Kulāvakavagga ","eng":"Nests ","html":"<li>{}</li></ul>"},"ja33:0.4":{"pli":"3. Sammodamānajātaka ","eng":"Agreement: a past life story ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja33:1.1":{"pli":"“Sammodamānā gacchanti, ","eng":"In agreement, the birds fly, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>","comm":"A flock of birds escape the hunter by lifting off his net in unison. But the hunter knows that when they stop cooperating they will be his. "},"ja33:1.2":{"pli":"jālamādāya pakkhino; ","eng":"taking away the net. ","html":"<span class='verse-line'>{}</span>"},"ja33:1.3":{"pli":"Yadā te vivadissanti, ","eng":"But when they start arguing ","html":"<span class='verse-line'>{}</span>"},"ja33:1.4":{"pli":"tadā ehinti me vasan”ti. ","eng":"they’ll come under my sway. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja33:2.1":{"pli":"Sammodamānajātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja330":{"ja330:0.1":{"pli":"Jātaka ","html":"<article id='ja330'><header><ul><li class='division'>{}</li>"},"ja330:0.2":{"pli":"Catukkanipāta ","html":"<li>{}</li>"},"ja330:0.3":{"pli":"Kuṭidūsakavagga ","html":"<li>{}</li></ul>"},"ja330:0.4":{"pli":"10. Sīlavīmaṁsajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja330:1.1":{"pli":"“Sīlaṁ kireva kalyāṇaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja330:1.2":{"pli":"sīlaṁ loke anuttaraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja330:1.3":{"pli":"Passa ghoraviso nāgo, ","html":"<span class='verse-line'>{}</span>"},"ja330:1.4":{"pli":"sīlavāti na haññati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja330:2.1":{"pli":"“Yāvadevassahū kiñci, ","html":"<p><span class='verse-line'>{}</span>"},"ja330:2.2":{"pli":"tāvadeva akhādisuṁ; ","html":"<span class='verse-line'>{}</span>"},"ja330:2.3":{"pli":"Saṅgamma kulalā loke, ","html":"<span class='verse-line'>{}</span>"},"ja330:2.4":{"pli":"na hiṁsanti akiñcanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja330:3.1":{"pli":"Sukhaṁ nirāsā supati, ","html":"<p><span class='verse-line'>{}</span>"},"ja330:3.2":{"pli":"āsā phalavatī sukhā; ","html":"<span class='verse-line'>{}</span>"},"ja330:3.3":{"pli":"Āsaṁ nirāsaṁ katvāna, ","html":"<span class='verse-line'>{}</span>"},"ja330:3.4":{"pli":"sukhaṁ supati piṅgalā. ","html":"<span class='verse-line'>{}</span></p>"},"ja330:4.1":{"pli":"Na samādhiparo atthi, ","html":"<p><span class='verse-line'>{}</span>"},"ja330:4.2":{"pli":"asmiṁ loke paramhi ca; ","html":"<span class='verse-line'>{}</span>"},"ja330:4.3":{"pli":"Na paraṁ nāpi attānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja330:4.4":{"pli":"vihiṁsati samāhito”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja330:5.1":{"pli":"Sīlavīmaṁsajātakaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja330:5.2":{"pli":"Kuṭidūsakavaggo tatiyo. ","html":"<p class='endvagga'>{}</p>"},"ja330:6.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja330:7.1":{"pli":"Samanussa saduddubha yācanako, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja330:7.2":{"pli":"Atha meṇḍavaruttama godhavaro; ","html":"<span class='verse-line'>{}</span>"},"ja330:7.3":{"pli":"Atha kāyasakepuka bhotīvaro, ","html":"<span class='verse-line'>{}</span>"},"ja330:7.4":{"pli":"Atha rādhasusīlavarena dasāti. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"ja331":{"ja331:0.1":{"pli":"Jātaka ","html":"<article id='ja331'><header><ul><li class='division'>{}</li>"},"ja331:0.2":{"pli":"Catukkanipāta ","html":"<li>{}</li>"},"ja331:0.3":{"pli":"Kokilavagga ","html":"<li>{}</li></ul>"},"ja331:0.4":{"pli":"1. Kokilajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja331:1.1":{"pli":"“Yo ve kāle asampatte, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja331:1.2":{"pli":"ativelaṁ pabhāsati; ","html":"<span class='verse-line'>{}</span>"},"ja331:1.3":{"pli":"Evaṁ so nihato seti, ","html":"<span class='verse-line'>{}</span>"},"ja331:1.4":{"pli":"kokilāyiva atrajo. ","html":"<span class='verse-line'>{}</span></p>"},"ja331:2.1":{"pli":"Na hi satthaṁ sunisitaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja331:2.2":{"pli":"visaṁ halāhalāmiva; ","html":"<span class='verse-line'>{}</span>"},"ja331:2.3":{"pli":"Evaṁ nikaṭṭhe pāteti, ","html":"<span class='verse-line'>{}</span>"},"ja331:2.4":{"pli":"vācā dubbhāsitā yathā. ","html":"<span class='verse-line'>{}</span></p>"},"ja331:3.1":{"pli":"Tasmā kāle akāle vā, ","html":"<p><span class='verse-line'>{}</span>"},"ja331:3.2":{"pli":"vācaṁ rakkheyya paṇḍito; ","html":"<span class='verse-line'>{}</span>"},"ja331:3.3":{"pli":"Nātivelaṁ pabhāseyya, ","html":"<span class='verse-line'>{}</span>"},"ja331:3.4":{"pli":"api attasamamhi vā. ","html":"<span class='verse-line'>{}</span></p>"},"ja331:4.1":{"pli":"Yo ca kāle mitaṁ bhāse, ","html":"<p><span class='verse-line'>{}</span>"},"ja331:4.2":{"pli":"matipubbo vicakkhaṇo; ","html":"<span class='verse-line'>{}</span>"},"ja331:4.3":{"pli":"Sabbe amitte ādeti, ","html":"<span class='verse-line'>{}</span>"},"ja331:4.4":{"pli":"supaṇṇo uragāmivā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja331:5.1":{"pli":"Kokilajātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja332":{"ja332:0.1":{"pli":"Jātaka ","html":"<article id='ja332'><header><ul><li class='division'>{}</li>"},"ja332:0.2":{"pli":"Catukkanipāta ","html":"<li>{}</li>"},"ja332:0.3":{"pli":"Kokilavagga ","html":"<li>{}</li></ul>"},"ja332:0.4":{"pli":"2. Rathalaṭṭhijātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja332:1.1":{"pli":"“Api hantvā hato brūti, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja332:1.2":{"pli":"jetvā jitoti bhāsati; ","html":"<span class='verse-line'>{}</span>"},"ja332:1.3":{"pli":"Pubbamakkhāyino rāja, ","html":"<span class='verse-line'>{}</span>"},"ja332:1.4":{"pli":"aññadatthu na saddahe. ","html":"<span class='verse-line'>{}</span></p>"},"ja332:2.1":{"pli":"Tasmā paṇḍitajātiyo, ","html":"<p><span class='verse-line'>{}</span>"},"ja332:2.2":{"pli":"suṇeyya itarassapi; ","html":"<span class='verse-line'>{}</span>"},"ja332:2.3":{"pli":"Ubhinnaṁ vacanaṁ sutvā, ","html":"<span class='verse-line'>{}</span>"},"ja332:2.4":{"pli":"yathā dhammo tathā kare. ","html":"<span class='verse-line'>{}</span></p>"},"ja332:3.1":{"pli":"Alaso gihī kāmabhogī na sādhu, ","html":"<p><span class='verse-line'>{}</span>"},"ja332:3.2":{"pli":"Asaññato pabbajito na sādhu; ","html":"<span class='verse-line'>{}</span>"},"ja332:3.3":{"pli":"Rājā na sādhu anisammakārī, ","html":"<span class='verse-line'>{}</span>"},"ja332:3.4":{"pli":"Yo paṇḍito kodhano taṁ na sādhu. ","html":"<span class='verse-line'>{}</span></p>"},"ja332:4.1":{"pli":"Nisamma khattiyo kayirā, ","html":"<p><span class='verse-line'>{}</span>"},"ja332:4.2":{"pli":"nānisamma disampati; ","html":"<span class='verse-line'>{}</span>"},"ja332:4.3":{"pli":"Nisammakārino rāja, ","html":"<span class='verse-line'>{}</span>"},"ja332:4.4":{"pli":"yaso kitti ca vaḍḍhatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja332:5.1":{"pli":"Rathalaṭṭhijātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja333":{"ja333:0.1":{"pli":"Jātaka ","html":"<article id='ja333'><header><ul><li class='division'>{}</li>"},"ja333:0.2":{"pli":"Catukkanipāta ","html":"<li>{}</li>"},"ja333:0.3":{"pli":"Kokilavagga ","html":"<li>{}</li></ul>"},"ja333:0.4":{"pli":"3. Pakkagodhajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja333:1.1":{"pli":"“Tadeva me tvaṁ vidito, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja333:1.2":{"pli":"vanamajjhe rathesabha; ","html":"<span class='verse-line'>{}</span>"},"ja333:1.3":{"pli":"Yassa te khaggabaddhassa, ","html":"<span class='verse-line'>{}</span>"},"ja333:1.4":{"pli":"sannaddhassa tirīṭino; ","html":"<span class='verse-line'>{}</span>"},"ja333:1.5":{"pli":"Assatthadumasākhāya, ","html":"<span class='verse-line'>{}</span>"},"ja333:1.6":{"pli":"pakkā godhā palāyatha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja333:2.1":{"pli":"“Name namantassa bhaje bhajantaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja333:2.2":{"pli":"Kiccānukubbassa kareyya kiccaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja333:2.3":{"pli":"Nānatthakāmassa kareyya atthaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja333:2.4":{"pli":"Asambhajantampi na sambhajeyya. ","html":"<span class='verse-line'>{}</span></p>"},"ja333:3.1":{"pli":"Caje cajantaṁ vanathaṁ na kayirā, ","html":"<p><span class='verse-line'>{}</span>"},"ja333:3.2":{"pli":"Apetacittena na sambhajeyya; ","html":"<span class='verse-line'>{}</span>"},"ja333:3.3":{"pli":"Dijo dumaṁ khīṇaphalanti ñatvā, ","html":"<span class='verse-line'>{}</span>"},"ja333:3.4":{"pli":"Aññaṁ samekkheyya mahā hi loko”. ","html":"<span class='verse-line'>{}</span></p>"},"ja333:4.1":{"pli":"“So te karissāmi yathānubhāvaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja333:4.2":{"pli":"Kataññutaṁ khattiye pekkhamāno; ","html":"<span class='verse-line'>{}</span>"},"ja333:4.3":{"pli":"Sabbañca te issariyaṁ dadāmi, ","html":"<span class='verse-line'>{}</span>"},"ja333:4.4":{"pli":"Yassicchasī tassa tuvaṁ dadāmī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja333:5.1":{"pli":"Pakkagodhajātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja334":{"ja334:0.1":{"pli":"Jātaka ","html":"<article id='ja334'><header><ul><li class='division'>{}</li>"},"ja334:0.2":{"pli":"Catukkanipāta ","html":"<li>{}</li>"},"ja334:0.3":{"pli":"Kokilavagga ","html":"<li>{}</li></ul>"},"ja334:0.4":{"pli":"4. Rājovādajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja334:1.1":{"pli":"“Gavañce taramānānaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja334:1.2":{"pli":"jimhaṁ gacchati puṅgavo; ","html":"<span class='verse-line'>{}</span>"},"ja334:1.3":{"pli":"Sabbā tā jimhaṁ gacchanti, ","html":"<span class='verse-line'>{}</span>"},"ja334:1.4":{"pli":"nette jimhaṁ gate sati. ","html":"<span class='verse-line'>{}</span></p>"},"ja334:2.1":{"pli":"Evameva manussesu, ","html":"<p><span class='verse-line'>{}</span>"},"ja334:2.2":{"pli":"yo hoti seṭṭhasammato; ","html":"<span class='verse-line'>{}</span>"},"ja334:2.3":{"pli":"So ce adhammaṁ carati, ","html":"<span class='verse-line'>{}</span>"},"ja334:2.4":{"pli":"pageva itarā pajā; ","html":"<span class='verse-line'>{}</span>"},"ja334:2.5":{"pli":"Sabbaṁ raṭṭhaṁ dukhaṁ seti, ","html":"<span class='verse-line'>{}</span>"},"ja334:2.6":{"pli":"rājā ce hoti adhammiko. ","html":"<span class='verse-line'>{}</span></p>"},"ja334:3.1":{"pli":"Gavañce taramānānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja334:3.2":{"pli":"ujuṁ gacchati puṅgavo; ","html":"<span class='verse-line'>{}</span>"},"ja334:3.3":{"pli":"Sabbā gāvī ujuṁ yanti, ","html":"<span class='verse-line'>{}</span>"},"ja334:3.4":{"pli":"nette ujuṁ gate sati. ","html":"<span class='verse-line'>{}</span></p>"},"ja334:4.1":{"pli":"Evameva manussesu, ","html":"<p><span class='verse-line'>{}</span>"},"ja334:4.2":{"pli":"yo hoti seṭṭhasammato; ","html":"<span class='verse-line'>{}</span>"},"ja334:4.3":{"pli":"So sace dhammaṁ carati, ","html":"<span class='verse-line'>{}</span>"},"ja334:4.4":{"pli":"pageva itarā pajā; ","html":"<span class='verse-line'>{}</span>"},"ja334:4.5":{"pli":"Sabbaṁ raṭṭhaṁ sukhaṁ seti, ","html":"<span class='verse-line'>{}</span>"},"ja334:4.6":{"pli":"rājā ce hoti dhammiko”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja334:5.1":{"pli":"Rājovādajātakaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja335":{"ja335:0.1":{"pli":"Jātaka ","html":"<article id='ja335'><header><ul><li class='division'>{}</li>"},"ja335:0.2":{"pli":"Catukkanipāta ","html":"<li>{}</li>"},"ja335:0.3":{"pli":"Kokilavagga ","html":"<li>{}</li></ul>"},"ja335:0.4":{"pli":"5. Jambukajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja335:1.1":{"pli":"“Brahā pavaḍḍhakāyo so, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja335:1.2":{"pli":"dīghadāṭho ca jambuka; ","html":"<span class='verse-line'>{}</span>"},"ja335:1.3":{"pli":"Na tvaṁ tattha kule jāto, ","html":"<span class='verse-line'>{}</span>"},"ja335:1.4":{"pli":"yattha gaṇhanti kuñjaraṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja335:2.1":{"pli":"“Asīho sīhamānena, ","html":"<p><span class='verse-line'>{}</span>"},"ja335:2.2":{"pli":"yo attānaṁ vikubbati; ","html":"<span class='verse-line'>{}</span>"},"ja335:2.3":{"pli":"Kotthūva gajamāsajja, ","html":"<span class='verse-line'>{}</span>"},"ja335:2.4":{"pli":"seti bhūmyā anutthunaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja335:3.1":{"pli":"Yasassino uttamapuggalassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja335:3.2":{"pli":"Sañjātakhandhassa mahabbalassa; ","html":"<span class='verse-line'>{}</span>"},"ja335:3.3":{"pli":"Asamekkhiya thāmabalūpapattiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja335:3.4":{"pli":"Sa seti nāgena hatoyaṁ jambuko. ","html":"<span class='verse-line'>{}</span></p>"},"ja335:4.1":{"pli":"Yo cīdha kammaṁ kurute pamāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja335:4.2":{"pli":"Thāmabbalaṁ attani saṁviditvā; ","html":"<span class='verse-line'>{}</span>"},"ja335:4.3":{"pli":"Jappena mantena subhāsitena, ","html":"<span class='verse-line'>{}</span>"},"ja335:4.4":{"pli":"Parikkhavā so vipulaṁ jinātī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja335:5.1":{"pli":"Jambukajātakaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja336":{"ja336:0.1":{"pli":"Jātaka ","html":"<article id='ja336'><header><ul><li class='division'>{}</li>"},"ja336:0.2":{"pli":"Catukkanipāta ","html":"<li>{}</li>"},"ja336:0.3":{"pli":"Kokilavagga ","html":"<li>{}</li></ul>"},"ja336:0.4":{"pli":"6. Brahāchattajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja336:1.1":{"pli":"“Tiṇaṁ tiṇanti lapasi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja336:1.2":{"pli":"ko nu te tiṇamāhari; ","html":"<span class='verse-line'>{}</span>"},"ja336:1.3":{"pli":"Kiṁ nu te tiṇakiccatthi, ","html":"<span class='verse-line'>{}</span>"},"ja336:1.4":{"pli":"tiṇameva pabhāsasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja336:2.1":{"pli":"“Idhāgamā brahmacārī, ","html":"<p><span class='verse-line'>{}</span>"},"ja336:2.2":{"pli":"brahā chatto bahussuto; ","html":"<span class='verse-line'>{}</span>"},"ja336:2.3":{"pli":"So me sabbaṁ samādāya, ","html":"<span class='verse-line'>{}</span>"},"ja336:2.4":{"pli":"tiṇaṁ nikkhippa gacchati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja336:3.1":{"pli":"“Evetaṁ hoti kattabbaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja336:3.2":{"pli":"appena bahumicchatā; ","html":"<span class='verse-line'>{}</span>"},"ja336:3.3":{"pli":"Sabbaṁ sakassa ādānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja336:3.4":{"pli":"anādānaṁ tiṇassa ca”. ","html":"<span class='verse-line'>{}</span>"},"ja336:3.5":{"pli":"(…) ","html":"<span class='verse-line'>{}</span></p>"},"ja336:4.1":{"pli":"“Sīlavanto na kubbanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja336:4.2":{"pli":"bālo sīlāni kubbati; ","html":"<span class='verse-line'>{}</span>"},"ja336:4.3":{"pli":"Aniccasīlaṁ dussīlyaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja336:4.4":{"pli":"kiṁ paṇḍiccaṁ karissatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja336:5.1":{"pli":"Brahāchattajātakaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja337":{"ja337:0.1":{"pli":"Jātaka ","html":"<article id='ja337'><header><ul><li class='division'>{}</li>"},"ja337:0.2":{"pli":"Catukkanipāta ","html":"<li>{}</li>"},"ja337:0.3":{"pli":"Kokilavagga ","html":"<li>{}</li></ul>"},"ja337:0.4":{"pli":"7. Pīṭhajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja337:1.1":{"pli":"“Na te pīṭhamadāyimhā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja337:1.2":{"pli":"na pānaṁ napi bhojanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja337:1.3":{"pli":"Brahmacāri khamassu me, ","html":"<span class='verse-line'>{}</span>"},"ja337:1.4":{"pli":"etaṁ passāmi accayaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja337:2.1":{"pli":"“Nevābhisajjāmi na cāpi kuppe, ","html":"<p><span class='verse-line'>{}</span>"},"ja337:2.2":{"pli":"Na cāpi me appiyamāsi kiñci; ","html":"<span class='verse-line'>{}</span>"},"ja337:2.3":{"pli":"Athopi me āsi manovitakko, ","html":"<span class='verse-line'>{}</span>"},"ja337:2.4":{"pli":"Etādiso nūna kulassa dhammo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja337:3.1":{"pli":"“Esasmākaṁ kule dhammo, ","html":"<p><span class='verse-line'>{}</span>"},"ja337:3.2":{"pli":"pitupitāmaho sadā; ","html":"<span class='verse-line'>{}</span>"},"ja337:3.3":{"pli":"Āsanaṁ udakaṁ pajjaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja337:3.4":{"pli":"sabbetaṁ nipadāmase. ","html":"<span class='verse-line'>{}</span></p>"},"ja337:4.1":{"pli":"Esasmākaṁ kule dhammo, ","html":"<p><span class='verse-line'>{}</span>"},"ja337:4.2":{"pli":"pitupitāmaho sadā; ","html":"<span class='verse-line'>{}</span>"},"ja337:4.3":{"pli":"Sakkaccaṁ upatiṭṭhāma, ","html":"<span class='verse-line'>{}</span>"},"ja337:4.4":{"pli":"uttamaṁ viya ñātakan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja337:5.1":{"pli":"Pīṭhajātakaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja338":{"ja338:0.1":{"pli":"Jātaka ","html":"<article id='ja338'><header><ul><li class='division'>{}</li>"},"ja338:0.2":{"pli":"Catukkanipāta ","html":"<li>{}</li>"},"ja338:0.3":{"pli":"Kokilavagga ","html":"<li>{}</li></ul>"},"ja338:0.4":{"pli":"8. Thusajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja338:1.1":{"pli":"“Viditaṁ thusaṁ undurānaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja338:1.2":{"pli":"Viditaṁ pana taṇḍulaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja338:1.3":{"pli":"Thusaṁ thusaṁ vivajjetvā, ","html":"<span class='verse-line'>{}</span>"},"ja338:1.4":{"pli":"Taṇḍulaṁ pana khādare. ","html":"<span class='verse-line'>{}</span></p>"},"ja338:2.1":{"pli":"Yā mantanā araññasmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja338:2.2":{"pli":"yā ca gāme nikaṇṇikā; ","html":"<span class='verse-line'>{}</span>"},"ja338:2.3":{"pli":"Yañcetaṁ iti cīti ca, ","html":"<span class='verse-line'>{}</span>"},"ja338:2.4":{"pli":"etampi viditaṁ mayā. ","html":"<span class='verse-line'>{}</span></p>"},"ja338:3.1":{"pli":"Dhammena kira jātassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja338:3.2":{"pli":"pitā puttassa makkaṭo; ","html":"<span class='verse-line'>{}</span>"},"ja338:3.3":{"pli":"Daharasseva santassa, ","html":"<span class='verse-line'>{}</span>"},"ja338:3.4":{"pli":"dantehi phalamacchidā. ","html":"<span class='verse-line'>{}</span></p>"},"ja338:4.1":{"pli":"Yametaṁ parisappasi, ","html":"<p><span class='verse-line'>{}</span>"},"ja338:4.2":{"pli":"ajakāṇova sāsape; ","html":"<span class='verse-line'>{}</span>"},"ja338:4.3":{"pli":"Yopāyaṁ heṭṭhato seti, ","html":"<span class='verse-line'>{}</span>"},"ja338:4.4":{"pli":"etampi viditaṁ mayā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja338:5.1":{"pli":"Thusajātakaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja339":{"ja339:0.1":{"pli":"Jātaka ","html":"<article id='ja339'><header><ul><li class='division'>{}</li>"},"ja339:0.2":{"pli":"Catukkanipāta ","html":"<li>{}</li>"},"ja339:0.3":{"pli":"Kokilavagga ","html":"<li>{}</li></ul>"},"ja339:0.4":{"pli":"9. Bāverujātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja339:1.1":{"pli":"“Adassanena morassa, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja339:1.2":{"pli":"sikhino mañjubhāṇino; ","html":"<span class='verse-line'>{}</span>"},"ja339:1.3":{"pli":"Kākaṁ tattha apūjesuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja339:1.4":{"pli":"maṁsena ca phalena ca. ","html":"<span class='verse-line'>{}</span></p>"},"ja339:2.1":{"pli":"Yadā ca sarasampanno, ","html":"<p><span class='verse-line'>{}</span>"},"ja339:2.2":{"pli":"moro bāverumāgamā; ","html":"<span class='verse-line'>{}</span>"},"ja339:2.3":{"pli":"Atha lābho ca sakkāro, ","html":"<span class='verse-line'>{}</span>"},"ja339:2.4":{"pli":"vāyasassa ahāyatha. ","html":"<span class='verse-line'>{}</span></p>"},"ja339:3.1":{"pli":"Yāva nuppajjatī buddho, ","html":"<p><span class='verse-line'>{}</span>"},"ja339:3.2":{"pli":"dhammarājā pabhaṅkaro; ","html":"<span class='verse-line'>{}</span>"},"ja339:3.3":{"pli":"Tāva aññe apūjesuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja339:3.4":{"pli":"puthū samaṇabrāhmaṇe. ","html":"<span class='verse-line'>{}</span></p>"},"ja339:4.1":{"pli":"Yadā ca sarasampanno, ","html":"<p><span class='verse-line'>{}</span>"},"ja339:4.2":{"pli":"buddho dhammaṁ adesayi; ","html":"<span class='verse-line'>{}</span>"},"ja339:4.3":{"pli":"Atha lābho ca sakkāro, ","html":"<span class='verse-line'>{}</span>"},"ja339:4.4":{"pli":"titthiyānaṁ ahāyathā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja339:5.1":{"pli":"Bāverujātakaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja34":{"ja34:0.1":{"pli":"Jātaka ","eng":"Stories of Past Lives 34 ","html":"<article id='ja34'><header><ul><li class='division'>{}</li>"},"ja34:0.2":{"pli":"Ekakanipāta ","eng":"The Book of the Ones ","html":"<li>{}</li>"},"ja34:0.3":{"pli":"Kulāvakavagga ","eng":"Nests ","html":"<li>{}</li></ul>"},"ja34:0.4":{"pli":"4. Macchajātaka ","eng":"The Fish: a past life story ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja34:1.1":{"pli":"“Na maṁ sītaṁ na maṁ uṇhaṁ, ","eng":"It’s not the cold or heat for me, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>","comm":"When a fish is caught in the net while his wife escapes, he worries more about what she thinks of him than of his imminent fate. "},"ja34:1.2":{"pli":"na maṁ jālasmi bādhanaṁ; ","eng":"nor the being caught in the net; ","html":"<span class='verse-line'>{}</span>"},"ja34:1.3":{"pli":"Yañca maṁ maññate macchī, ","eng":"it’s that my lady, the fish, thinks of me, ","html":"<span class='verse-line'>{}</span>"},"ja34:1.4":{"pli":"aññaṁ so ratiyā gato”ti. ","eng":"“He went for joy to another.” ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja34:2.1":{"pli":"Macchajātakaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja340":{"ja340:0.1":{"pli":"Jātaka ","html":"<article id='ja340'><header><ul><li class='division'>{}</li>"},"ja340:0.2":{"pli":"Catukkanipāta ","html":"<li>{}</li>"},"ja340:0.3":{"pli":"Kokilavagga ","html":"<li>{}</li></ul>"},"ja340:0.4":{"pli":"10. Visayhajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja340:1.1":{"pli":"“Adāsi dānāni pure visayha, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja340:1.2":{"pli":"Dadato ca te khayadhammo ahosi; ","html":"<span class='verse-line'>{}</span>"},"ja340:1.3":{"pli":"Ito parañce na dadeyya dānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja340:1.4":{"pli":"Tiṭṭheyyuṁ te saṁyamantassa bhogā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja340:2.1":{"pli":"“Anariyamariyena sahassanetta, ","html":"<p><span class='verse-line'>{}</span>"},"ja340:2.2":{"pli":"Suduggatenāpi akiccamāhu; ","html":"<span class='verse-line'>{}</span>"},"ja340:2.3":{"pli":"Mā vo dhanaṁ taṁ ahu devarāja, ","html":"<span class='verse-line'>{}</span>"},"ja340:2.4":{"pli":"Yaṁ bhogahetu vijahemu saddhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja340:3.1":{"pli":"Yena eko ratho yāti, ","html":"<p><span class='verse-line'>{}</span>"},"ja340:3.2":{"pli":"yāti tenāparo ratho; ","html":"<span class='verse-line'>{}</span>"},"ja340:3.3":{"pli":"Porāṇaṁ nihitaṁ vattaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja340:3.4":{"pli":"vattataññeva vāsava. ","html":"<span class='verse-line'>{}</span></p>"},"ja340:4.1":{"pli":"Yadi hessati dassāma, ","html":"<p><span class='verse-line'>{}</span>"},"ja340:4.2":{"pli":"asante kiṁ dadāmase; ","html":"<span class='verse-line'>{}</span>"},"ja340:4.3":{"pli":"Evaṁbhūtāpi dassāma, ","html":"<span class='verse-line'>{}</span>"},"ja340:4.4":{"pli":"mā dānaṁ pamadamhase”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja340:5.1":{"pli":"Visayhajātakaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja340:5.2":{"pli":"Kokilavaggo catuttho. ","html":"<p class='endvagga'>{}</p>"},"ja340:6.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja340:7.1":{"pli":"Ativelapabhāsati jītavaro, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja340:7.2":{"pli":"Vanamajjha rathesabha jimhagamo; ","html":"<span class='verse-line'>{}</span>"},"ja340:7.3":{"pli":"Atha jambu tiṇāsanapīṭhavaraṁ, ","html":"<span class='verse-line'>{}</span>"},"ja340:7.4":{"pli":"Atha taṇḍula mora visayha dasāti. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"ja341":{"ja341:0.1":{"pli":"Jātaka ","html":"<article id='ja341'><header><ul><li class='division'>{}</li>"},"ja341:0.2":{"pli":"Catukkanipāta ","html":"<li>{}</li>"},"ja341:0.3":{"pli":"Cūḷakuṇālavagga ","html":"<li>{}</li></ul>"},"ja341:0.4":{"pli":"1. Kaṇḍarījātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja341:1.1":{"pli":"Narānamārāmakarāsu nārisu, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja341:1.2":{"pli":"Anekacittāsu aniggahāsu ca; ","html":"<span class='verse-line'>{}</span>"},"ja341:1.3":{"pli":"Sabbattha nāpītikarāpi ce siyā, ","html":"<span class='verse-line'>{}</span>"},"ja341:1.4":{"pli":"Na vissase titthasamā hi nāriyo. ","html":"<span class='verse-line'>{}</span></p>"},"ja341:2.1":{"pli":"“Yaṁ ve disvā kaṇḍarīkinnarānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja341:2.2":{"pli":"Sabbitthiyo na ramanti agāre; ","html":"<span class='verse-line'>{}</span>"},"ja341:2.3":{"pli":"Taṁ tādisaṁ maccaṁ cajitvā bhariyā, ","html":"<span class='verse-line'>{}</span>"},"ja341:2.4":{"pli":"Aññaṁ disvā purisaṁ pīṭhasappiṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja341:3.1":{"pli":"“Bakassa ca bāvarikassa rañño, ","html":"<p><span class='verse-line'>{}</span>"},"ja341:3.2":{"pli":"Accantakāmānugatassa bhariyā; ","html":"<span class='verse-line'>{}</span>"},"ja341:3.3":{"pli":"Avācarī paṭṭhavasānugassa, ","html":"<span class='verse-line'>{}</span>"},"ja341:3.4":{"pli":"Kaṁ vāpi itthī nāticare tadaññaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja341:4.1":{"pli":"“Piṅgiyānī sabbalokissarassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja341:4.2":{"pli":"Rañño piyā brahmadattassa bhariyā; ","html":"<span class='verse-line'>{}</span>"},"ja341:4.3":{"pli":"Avācarī paṭṭhavasānugassa, ","html":"<span class='verse-line'>{}</span>"},"ja341:4.4":{"pli":"Taṁ vāpi sā nājjhagā kāmakāminī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja341:5.1":{"pli":"Kaṇḍarījātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja342":{"ja342:0.1":{"pli":"Jātaka ","html":"<article id='ja342'><header><ul><li class='division'>{}</li>"},"ja342:0.2":{"pli":"Catukkanipāta ","html":"<li>{}</li>"},"ja342:0.3":{"pli":"Cūḷakuṇālavagga ","html":"<li>{}</li></ul>"},"ja342:0.4":{"pli":"2. Vānarajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja342:1.1":{"pli":"“Asakkhiṁ vata attānaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja342:1.2":{"pli":"uddhātuṁ udakā thalaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja342:1.3":{"pli":"Na dānāhaṁ puna tuyhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja342:1.4":{"pli":"vasaṁ gacchāmi vārija. ","html":"<span class='verse-line'>{}</span></p>"},"ja342:2.1":{"pli":"Alametehi ambehi, ","html":"<p><span class='verse-line'>{}</span>"},"ja342:2.2":{"pli":"jambūhi panasehi ca; ","html":"<span class='verse-line'>{}</span>"},"ja342:2.3":{"pli":"Yāni pāraṁ samuddassa, ","html":"<span class='verse-line'>{}</span>"},"ja342:2.4":{"pli":"varaṁ mayhaṁ udumbaro. ","html":"<span class='verse-line'>{}</span></p>"},"ja342:3.1":{"pli":"Yo ca uppatitaṁ atthaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja342:3.2":{"pli":"na khippamanubujjhati; ","html":"<span class='verse-line'>{}</span>"},"ja342:3.3":{"pli":"Amittavasamanveti, ","html":"<span class='verse-line'>{}</span>"},"ja342:3.4":{"pli":"pacchā ca anutappati. ","html":"<span class='verse-line'>{}</span></p>"},"ja342:4.1":{"pli":"Yo ca uppatitaṁ atthaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja342:4.2":{"pli":"khippameva nibodhati; ","html":"<span class='verse-line'>{}</span>"},"ja342:4.3":{"pli":"Muccate sattusambādhā, ","html":"<span class='verse-line'>{}</span>"},"ja342:4.4":{"pli":"na ca pacchānutappatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja342:5.1":{"pli":"Vānarajātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja343":{"ja343:0.1":{"pli":"Jātaka ","html":"<article id='ja343'><header><ul><li class='division'>{}</li>"},"ja343:0.2":{"pli":"Catukkanipāta ","html":"<li>{}</li>"},"ja343:0.3":{"pli":"Cūḷakuṇālavagga ","html":"<li>{}</li></ul>"},"ja343:0.4":{"pli":"3. Kuntinījātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja343:1.1":{"pli":"“Avasimha tavāgāre, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja343:1.2":{"pli":"niccaṁ sakkatapūjitā; ","html":"<span class='verse-line'>{}</span>"},"ja343:1.3":{"pli":"Tvameva dānimakari, ","html":"<span class='verse-line'>{}</span>"},"ja343:1.4":{"pli":"handa rāja vajāmahaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja343:2.1":{"pli":"“Yo ve kate paṭikate, ","html":"<p><span class='verse-line'>{}</span>"},"ja343:2.2":{"pli":"kibbise paṭikibbise; ","html":"<span class='verse-line'>{}</span>"},"ja343:2.3":{"pli":"Evaṁ taṁ sammatī veraṁ, ","html":"<span class='verse-line'>{}</span>"},"ja343:2.4":{"pli":"vasa kuntini māgamā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja343:3.1":{"pli":"“Na katassa ca kattā ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja343:3.2":{"pli":"metti sandhīyate puna; ","html":"<span class='verse-line'>{}</span>"},"ja343:3.3":{"pli":"Hadayaṁ nānujānāti, ","html":"<span class='verse-line'>{}</span>"},"ja343:3.4":{"pli":"gacchaññeva rathesabha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja343:4.1":{"pli":"“Katassa ceva kattā ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja343:4.2":{"pli":"metti sandhīyate puna; ","html":"<span class='verse-line'>{}</span>"},"ja343:4.3":{"pli":"Dhīrānaṁ no ca bālānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja343:4.4":{"pli":"vasa kuntini māgamā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja343:5.1":{"pli":"Kuntinījātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja344":{"ja344:0.1":{"pli":"Jātaka ","html":"<article id='ja344'><header><ul><li class='division'>{}</li>"},"ja344:0.2":{"pli":"Catukkanipāta ","html":"<li>{}</li>"},"ja344:0.3":{"pli":"Cūḷakuṇālavagga ","html":"<li>{}</li></ul>"},"ja344:0.4":{"pli":"4. Ambajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja344:1.1":{"pli":"“Yo nīliyaṁ maṇḍayati, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja344:1.2":{"pli":"saṇḍāsena vihaññati; ","html":"<span class='verse-line'>{}</span>"},"ja344:1.3":{"pli":"Tassa sā vasamanvetu, ","html":"<span class='verse-line'>{}</span>"},"ja344:1.4":{"pli":"yā te ambe avāhari”. ","html":"<span class='verse-line'>{}</span></p>"},"ja344:2.1":{"pli":"“Vīsaṁ vā pañcavīsaṁ vā, ","html":"<p><span class='verse-line'>{}</span>"},"ja344:2.2":{"pli":"ūnatiṁsaṁ va jātiyā; ","html":"<span class='verse-line'>{}</span>"},"ja344:2.3":{"pli":"Tādisā pati mā laddhā, ","html":"<span class='verse-line'>{}</span>"},"ja344:2.4":{"pli":"yā te ambe avāhari”. ","html":"<span class='verse-line'>{}</span></p>"},"ja344:3.1":{"pli":"“Dīghaṁ gacchatu addhānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja344:3.2":{"pli":"ekikā abhisārikā; ","html":"<span class='verse-line'>{}</span>"},"ja344:3.3":{"pli":"Saṅkete pati mā adda, ","html":"<span class='verse-line'>{}</span>"},"ja344:3.4":{"pli":"yā te ambe avāhari”. ","html":"<span class='verse-line'>{}</span></p>"},"ja344:4.1":{"pli":"“Alaṅkatā suvasanā, ","html":"<p><span class='verse-line'>{}</span>"},"ja344:4.2":{"pli":"mālinī candanussadā; ","html":"<span class='verse-line'>{}</span>"},"ja344:4.3":{"pli":"Ekikā sayane setu, ","html":"<span class='verse-line'>{}</span>"},"ja344:4.4":{"pli":"yā te ambe avāharī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja344:5.1":{"pli":"Ambajātakaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja345":{"ja345:0.1":{"pli":"Jātaka ","html":"<article id='ja345'><header><ul><li class='division'>{}</li>"},"ja345:0.2":{"pli":"Catukkanipāta ","html":"<li>{}</li>"},"ja345:0.3":{"pli":"Cūḷakuṇālavagga ","html":"<li>{}</li></ul>"},"ja345:0.4":{"pli":"5. Gajakumbhajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja345:1.1":{"pli":"“Vanaṁ yadaggi dahati, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja345:1.2":{"pli":"pāvako kaṇhavattanī; ","html":"<span class='verse-line'>{}</span>"},"ja345:1.3":{"pli":"Kathaṁ karosi pacalaka, ","html":"<span class='verse-line'>{}</span>"},"ja345:1.4":{"pli":"evaṁ dandhaparakkamo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja345:2.1":{"pli":"“Bahūni rukkhachiddāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja345:2.2":{"pli":"pathabyā vivarāni ca; ","html":"<span class='verse-line'>{}</span>"},"ja345:2.3":{"pli":"Tāni ce nābhisambhoma, ","html":"<span class='verse-line'>{}</span>"},"ja345:2.4":{"pli":"hoti no kālapariyāyo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja345:3.1":{"pli":"“Yo dandhakāle tarati, ","html":"<p><span class='verse-line'>{}</span>"},"ja345:3.2":{"pli":"taraṇīye ca dandhati; ","html":"<span class='verse-line'>{}</span>"},"ja345:3.3":{"pli":"Sukkhapaṇṇaṁva akkamma, ","html":"<span class='verse-line'>{}</span>"},"ja345:3.4":{"pli":"atthaṁ bhañjati attano. ","html":"<span class='verse-line'>{}</span></p>"},"ja345:4.1":{"pli":"Yo dandhakāle dandheti, ","html":"<p><span class='verse-line'>{}</span>"},"ja345:4.2":{"pli":"taraṇīye ca tārayi; ","html":"<span class='verse-line'>{}</span>"},"ja345:4.3":{"pli":"Sasīva rattiṁ vibhajaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja345:4.4":{"pli":"tassattho paripūratī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja345:5.1":{"pli":"Gajakumbhajātakaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja346":{"ja346:0.1":{"pli":"Jātaka ","html":"<article id='ja346'><header><ul><li class='division'>{}</li>"},"ja346:0.2":{"pli":"Catukkanipāta ","html":"<li>{}</li>"},"ja346:0.3":{"pli":"Cūḷakuṇālavagga ","html":"<li>{}</li></ul>"},"ja346:0.4":{"pli":"6. Kesavajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja346:1.1":{"pli":"“Manussindaṁ jahitvāna, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja346:1.2":{"pli":"sabbakāmasamiddhinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja346:1.3":{"pli":"Kathaṁ nu bhagavā kesī, ","html":"<span class='verse-line'>{}</span>"},"ja346:1.4":{"pli":"kappassa ramati assame”. ","html":"<span class='verse-line'>{}</span></p>"},"ja346:2.1":{"pli":"“Sādūni ramaṇīyāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja346:2.2":{"pli":"santi vakkhā manoramā; ","html":"<span class='verse-line'>{}</span>"},"ja346:2.3":{"pli":"Subhāsitāni kappassa, ","html":"<span class='verse-line'>{}</span>"},"ja346:2.4":{"pli":"nārada ramayanti maṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja346:3.1":{"pli":"“Sālīnaṁ odanaṁ bhuñje, ","html":"<p><span class='verse-line'>{}</span>"},"ja346:3.2":{"pli":"suciṁ maṁsūpasecanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja346:3.3":{"pli":"Kathaṁ sāmākanīvāraṁ, ","html":"<span class='verse-line'>{}</span>"},"ja346:3.4":{"pli":"aloṇaṁ chādayanti taṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja346:4.1":{"pli":"“Sāduṁ vā yadi vāsāduṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja346:4.2":{"pli":"appaṁ vā yadi vā bahuṁ; ","html":"<span class='verse-line'>{}</span>"},"ja346:4.3":{"pli":"Vissattho yattha bhuñjeyya, ","html":"<span class='verse-line'>{}</span>"},"ja346:4.4":{"pli":"vissāsaparamā rasā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja346:5.1":{"pli":"Kesavajātakaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja347":{"ja347:0.1":{"pli":"Jātaka ","html":"<article id='ja347'><header><ul><li class='division'>{}</li>"},"ja347:0.2":{"pli":"Catukkanipāta ","html":"<li>{}</li>"},"ja347:0.3":{"pli":"Cūḷakuṇālavagga ","html":"<li>{}</li></ul>"},"ja347:0.4":{"pli":"7. Ayakūṭajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja347:1.1":{"pli":"“Sabbāyasaṁ kūṭamatippamāṇaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja347:1.2":{"pli":"Paggayha yo tiṭṭhasi antalikkhe; ","html":"<span class='verse-line'>{}</span>"},"ja347:1.3":{"pli":"Rakkhāya me tvaṁ vihito nusajja, ","html":"<span class='verse-line'>{}</span>"},"ja347:1.4":{"pli":"Udāhu me cetayase vadhāya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja347:2.1":{"pli":"“Dūto ahaṁ rājidha rakkhasānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja347:2.2":{"pli":"Vadhāya tuyhaṁ pahitohamasmi; ","html":"<span class='verse-line'>{}</span>"},"ja347:2.3":{"pli":"Indo ca taṁ rakkhati devarājā, ","html":"<span class='verse-line'>{}</span>"},"ja347:2.4":{"pli":"Tenuttamaṅgaṁ na te phālayāmi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja347:3.1":{"pli":"“Sace ca maṁ rakkhati devarājā, ","html":"<p><span class='verse-line'>{}</span>"},"ja347:3.2":{"pli":"Devānamindo maghavā sujampati; ","html":"<span class='verse-line'>{}</span>"},"ja347:3.3":{"pli":"Kāmaṁ pisācā vinadantu sabbe, ","html":"<span class='verse-line'>{}</span>"},"ja347:3.4":{"pli":"Na santase rakkhasiyā pajāya. ","html":"<span class='verse-line'>{}</span></p>"},"ja347:4.1":{"pli":"Kāmaṁ kandantu kumbhaṇḍā, ","html":"<p><span class='verse-line'>{}</span>"},"ja347:4.2":{"pli":"Sabbe paṁsupisācakā; ","html":"<span class='verse-line'>{}</span>"},"ja347:4.3":{"pli":"Nālaṁ pisācā yuddhāya, ","html":"<span class='verse-line'>{}</span>"},"ja347:4.4":{"pli":"Mahatī sā vibhiṁsikā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja347:5.1":{"pli":"Ayakūṭajātakaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja348":{"ja348:0.1":{"pli":"Jātaka ","html":"<article id='ja348'><header><ul><li class='division'>{}</li>"},"ja348:0.2":{"pli":"Catukkanipāta ","html":"<li>{}</li>"},"ja348:0.3":{"pli":"Cūḷakuṇālavagga ","html":"<li>{}</li></ul>"},"ja348:0.4":{"pli":"8. Araññajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja348:1.1":{"pli":"“Araññā gāmamāgamma, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja348:1.2":{"pli":"kiṁsīlaṁ kiṁvataṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja348:1.3":{"pli":"Purisaṁ tāta seveyyaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja348:1.4":{"pli":"taṁ me akkhāhi pucchito”. ","html":"<span class='verse-line'>{}</span></p>"},"ja348:2.1":{"pli":"“Yo taṁ vissāsaye tāta, ","html":"<p><span class='verse-line'>{}</span>"},"ja348:2.2":{"pli":"vissāsañca khameyya te; ","html":"<span class='verse-line'>{}</span>"},"ja348:2.3":{"pli":"Sussūsī ca titikkhī ca, ","html":"<span class='verse-line'>{}</span>"},"ja348:2.4":{"pli":"taṁ bhajehi ito gato. ","html":"<span class='verse-line'>{}</span></p>"},"ja348:3.1":{"pli":"Yassa kāyena vācāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja348:3.2":{"pli":"manasā natthi dukkaṭaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja348:3.3":{"pli":"Urasīva patiṭṭhāya, ","html":"<span class='verse-line'>{}</span>"},"ja348:3.4":{"pli":"taṁ bhajehi ito gato. ","html":"<span class='verse-line'>{}</span></p>"},"ja348:4.1":{"pli":"Haliddirāgaṁ kapicittaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja348:4.2":{"pli":"purisaṁ rāgavirāginaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja348:4.3":{"pli":"Tādisaṁ tāta mā sevi, ","html":"<span class='verse-line'>{}</span>"},"ja348:4.4":{"pli":"nimmanussampi ce siyā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja348:5.1":{"pli":"Araññajātakaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja349":{"ja349:0.1":{"pli":"Jātaka ","html":"<article id='ja349'><header><ul><li class='division'>{}</li>"},"ja349:0.2":{"pli":"Catukkanipāta ","html":"<li>{}</li>"},"ja349:0.3":{"pli":"Cūḷakuṇālavagga ","html":"<li>{}</li></ul>"},"ja349:0.4":{"pli":"9. Sandhibhedajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja349:1.1":{"pli":"“Neva itthīsu sāmaññaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja349:1.2":{"pli":"nāpi bhakkhesu sārathi; ","html":"<span class='verse-line'>{}</span>"},"ja349:1.3":{"pli":"Athassa sandhibhedassa, ","html":"<span class='verse-line'>{}</span>"},"ja349:1.4":{"pli":"passa yāva sucintitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja349:2.1":{"pli":"Asi tikkhova maṁsamhi, ","html":"<p><span class='verse-line'>{}</span>"},"ja349:2.2":{"pli":"pesuññaṁ parivattati; ","html":"<span class='verse-line'>{}</span>"},"ja349:2.3":{"pli":"Yatthūsabhañca sīhañca, ","html":"<span class='verse-line'>{}</span>"},"ja349:2.4":{"pli":"bhakkhayanti migādhamā. ","html":"<span class='verse-line'>{}</span></p>"},"ja349:3.1":{"pli":"Imaṁ so sayanaṁ seti, ","html":"<p><span class='verse-line'>{}</span>"},"ja349:3.2":{"pli":"yamimaṁ passasi sārathi; ","html":"<span class='verse-line'>{}</span>"},"ja349:3.3":{"pli":"Yo vācaṁ sandhibhedassa, ","html":"<span class='verse-line'>{}</span>"},"ja349:3.4":{"pli":"pisuṇassa nibodhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja349:4.1":{"pli":"Te janā sukhamedhanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja349:4.2":{"pli":"narā saggagatāriva; ","html":"<span class='verse-line'>{}</span>"},"ja349:4.3":{"pli":"Ye vācaṁ sandhibhedassa, ","html":"<span class='verse-line'>{}</span>"},"ja349:4.4":{"pli":"nāvabodhanti sārathī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja349:5.1":{"pli":"Sandhibhedajātakaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}