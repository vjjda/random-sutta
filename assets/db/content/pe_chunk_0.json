{"pe1":{"pe1:0.1":{"pli":"Peṭakopadesa ","html":"<article id='pe1'><header><ul><li class='division'>{}</li></ul>"},"pe1:0.2":{"pli":"1. Ariyasaccappakāsanapaṭhamabhūmi ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pe1:1.1":{"pli":"Namo tassa Bhagavato Arahato Sammāsambuddhassa. ","html":"<p class='namo'>{}</p>"},"pe1:2.1":{"pli":"Namo sammāsambuddhānaṁ paramatthadassīnaṁ sīlādiguṇapāramippattānaṁ. ","html":"<p class='namo'>{}</p>"},"pe1:3.1":{"pli":"Duve hetū duve paccayā sāvakassa sammādiṭṭhiyā uppādāya—","html":"<p>{}"},"pe1:3.2":{"pli":"parato ca ghoso saccānusandhi, ajjhattañca yoniso manasikāro. ","html":"{}"},"pe1:3.3":{"pli":"Tattha katamo parato ghoso? ","html":"{}"},"pe1:3.4":{"pli":"Yā parato desanā ovādo anusāsanī saccakathā saccānulomo. ","html":"{}"},"pe1:3.5":{"pli":"Cattāri saccāni—","html":"{}"},"pe1:3.6":{"pli":"dukkhaṁ samudayo nirodho maggo. ","html":"{}"},"pe1:3.7":{"pli":"Imesaṁ catunnaṁ saccānaṁ yā desanā sandassanā vivaraṇā vibhajanā uttānīkiriyā pakāsanā—","html":"{}"},"pe1:3.8":{"pli":"ayaṁ vuccati saccānulomo ghosoti. ","html":"{}</p>"},"pe1:4.1":{"pli":"Tattha katamo ajjhattaṁ yoniso manasikāro? ","html":"<p>{}</p>"},"pe1:5.1":{"pli":"Ajjhattaṁ yoniso manasikāro nāma yo yathādesite dhamme bahiddhā ārammaṇaṁ anabhinīharitvā yoniso manasikāro—","html":"<p>{}"},"pe1:5.2":{"pli":"ayaṁ vuccati yoniso manasikāro. ","html":"{}</p>"},"pe1:6.1":{"pli":"Taṁākāro yoniso dvāro vidhi upāyo. ","html":"<p>{}"},"pe1:6.2":{"pli":"Yathā puriso sukkhe kaṭṭhe vigatasnehe sukkhāya uttarāraṇiyā thale abhimanthamānaṁ bhabbo jotissa adhigamāya. ","html":"{}"},"pe1:6.3":{"pli":"Taṁ kissa hetu. ","html":"{}"},"pe1:6.4":{"pli":"Yoniso aggissa adhigamāya. ","html":"{}"},"pe1:6.5":{"pli":"Evamevassa yamidaṁ dukkhasamudayanirodhamaggānaṁ aviparītadhammadesanaṁ manasikaroti—","html":"{}"},"pe1:6.6":{"pli":"ayaṁ vuccati yoniso manasikāro. ","html":"{}</p>"},"pe1:7.1":{"pli":"Yathā tisso upamā pubbe assutā ca assutapubbā ca paṭibhanti. ","html":"<p>{}"},"pe1:7.2":{"pli":"Yo hi koci kāmesu avītarāgoti …pe… ","html":"{}"},"pe1:7.3":{"pli":"duve upamā ayoniso kātabbā pacchimesu vuttaṁ. ","html":"{}"},"pe1:7.4":{"pli":"Tattha yo ca parato ghoso yo ca ajjhattaṁ yoniso manasikāro—","html":"{}"},"pe1:7.5":{"pli":"ime dve paccayā. ","html":"{}"},"pe1:7.6":{"pli":"Parato ghosena yā uppajjati paññā—","html":"{}"},"pe1:7.7":{"pli":"ayaṁ vuccati sutamayī paññā. ","html":"{}"},"pe1:7.8":{"pli":"Yā ajjhattaṁ yoniso manasikārena uppajjati paññā—","html":"{}"},"pe1:7.9":{"pli":"ayaṁ vuccati cintāmayī paññāti. ","html":"{}"},"pe1:7.10":{"pli":"Imā dve paññā veditabbā. ","html":"{}"},"pe1:7.11":{"pli":"Purimakā ca dve paccayā. ","html":"{}"},"pe1:7.12":{"pli":"Ime dve hetū dve paccayā sāvakassa sammādiṭṭhiyā uppādāya. ","html":"{}</p>"},"pe1:8.1":{"pli":"Tattha parato ghosassa saccānusandhissa desitassa atthaṁ avijānanto atthappaṭisaṁvedī bhavissatīti netaṁ ṭhānaṁ vijjati. ","html":"<p>{}"},"pe1:8.2":{"pli":"Na ca atthappaṭisaṁvedī yoniso manasikarissatīti netaṁ ṭhānaṁ vijjati. ","html":"{}"},"pe1:8.3":{"pli":"Parato ghosassa saccānusandhissa desitassa atthaṁ vijānanto atthappaṭisaṁvedī bhavissatīti ṭhānametaṁ vijjati. ","html":"{}"},"pe1:8.4":{"pli":"Atthappaṭisaṁvedī ca yoniso manasikarissatīti ṭhānametaṁ vijjati. ","html":"{}"},"pe1:8.5":{"pli":"Esa hetu etaṁ ārammaṇaṁ eso upāyo sāvakassa niyyānassa, natthañño. ","html":"{}"},"pe1:8.6":{"pli":"Soyaṁ na ca suttassa atthavijānanāya saha yutto nāpi ghosānuyogena parato ghosassa atthaṁ avijānantena sakkā uttari manussadhammaṁ alamariyañāṇadassanaṁ adhigantuṁ, tasmā nibbāyitukāmena sutamayena atthā pariyesitabbā. ","html":"{}"},"pe1:8.7":{"pli":"Tattha pariyesanāya ayaṁ anupubbī bhavati soḷasa hārā, pañca nayā, aṭṭhārasa mūlapadāni. ","html":"{}</p>"},"pe1:9.1":{"pli":"Tatthāyaṁ uddānagāthā ","html":"<p class='uddana-intro'>{}</p>"},"pe1:10.1":{"pli":"Soḷasahārā nettī, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"pe1:10.2":{"pli":"Pañcanayā sāsanassa pariyeṭṭhi; ","html":"<span class='verse-line'>{}</span>"},"pe1:10.3":{"pli":"Aṭṭhārasamūlapadā, ","html":"<span class='verse-line'>{}</span>"},"pe1:10.4":{"pli":"Kaccāyanagottaniddiṭṭhā. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:11.1":{"pli":"Tattha katame <b>soḷasahārā</b>? ","html":"<p>{}</p>"},"pe1:12.1":{"pli":"Desanā vicayo yutti padaṭṭhānaṁ lakkhaṇaṁ catubyūho āvaṭṭo vibhatti parivattano vevacano paññatti otaraṇo sodhano adhiṭṭhāno parikkhāro samāropano—","html":"<p>{}"},"pe1:12.2":{"pli":"ime soḷasa hārā. ","html":"{}</p>"},"pe1:13.1":{"pli":"Tattha uddānagāthā ","html":"<p class='uddana-intro'>{}</p>"},"pe1:14.1":{"pli":"Desanā vicayo yutti, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"pe1:14.2":{"pli":"padaṭṭhāno ca lakkhaṇo; ","html":"<span class='verse-line'>{}</span>"},"pe1:14.3":{"pli":"Catubyūho ca āvaṭṭo, ","html":"<span class='verse-line'>{}</span>"},"pe1:14.4":{"pli":"vibhatti parivattano. ","html":"<span class='verse-line'>{}</span></p>"},"pe1:15.1":{"pli":"Vevacano ca paññatti, ","html":"<p><span class='verse-line'>{}</span>"},"pe1:15.2":{"pli":"otaraṇo ca sodhano; ","html":"<span class='verse-line'>{}</span>"},"pe1:15.3":{"pli":"Adhiṭṭhāno parikkhāro, ","html":"<span class='verse-line'>{}</span>"},"pe1:15.4":{"pli":"samāropano soḷaso. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:16.1":{"pli":"Tattha katame <b>pañca nayā</b>? ","html":"<p>{}</p>"},"pe1:17.1":{"pli":"Nandiyāvaṭṭo tipukkhalo sīhavikkīḷito disālocano aṅkusoti. ","html":"<p>{}</p>"},"pe1:18.1":{"pli":"Tattha uddānagāthā ","html":"<p class='uddana-intro'>{}</p>"},"pe1:19.1":{"pli":"Paṭhamo nandiyāvaṭṭo, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"pe1:19.2":{"pli":"dutiyo ca tipukkhalo; ","html":"<span class='verse-line'>{}</span>"},"pe1:19.3":{"pli":"Sīhavikkīḷito nāma, ","html":"<span class='verse-line'>{}</span>"},"pe1:19.4":{"pli":"tatiyo hoti so nayo. ","html":"<span class='verse-line'>{}</span></p>"},"pe1:20.1":{"pli":"Disālocanamāhaṁsu, ","html":"<p><span class='verse-line'>{}</span>"},"pe1:20.2":{"pli":"catuttho nayalañjako; ","html":"<span class='verse-line'>{}</span>"},"pe1:20.3":{"pli":"Pañcamo aṅkuso nāma, ","html":"<span class='verse-line'>{}</span>"},"pe1:20.4":{"pli":"sabbe pañca nayā gatā. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:21.1":{"pli":"Tattha katamāni <b>aṭṭhārasa mūlapadāni</b>? ","html":"<p>{}</p>"},"pe1:22.1":{"pli":"Avijjā taṇhā lobho doso moho subhasaññā sukhasaññā niccasaññā attasaññā samatho vipassanā alobho adoso amoho asubhasaññā dukkhasaññā aniccasaññā anattasaññā, imāni aṭṭhārasa mūlapadāni. ","html":"<p>{}"},"pe1:22.2":{"pli":"Tattha nava padāni akusalāni yattha sabbaṁ akusalaṁ samosarati. ","html":"{}"},"pe1:22.3":{"pli":"Nava padāni kusalāni yattha sabbaṁ kusalaṁ samosarati. ","html":"{}</p>"},"pe1:23.1":{"pli":"Katamāni nava padāni akusalāni yattha sabbaṁ akusalaṁ samosarati? ","html":"<p>{}</p>"},"pe1:24.1":{"pli":"Avijjā yāva attasaññā, imāni nava padāni akusalāni, yattha sabbaṁ akusalaṁ samosarati. ","html":"<p>{}</p>"},"pe1:25.1":{"pli":"Katamāni nava padāni kusalāni yattha sabbaṁ kusalaṁ samosarati? ","html":"<p>{}</p>"},"pe1:26.1":{"pli":"Samatho yāva anattasaññā, imāni nava padāni kusalāni yattha sabbaṁ kusalaṁ samosarati. ","html":"<p>{}"},"pe1:26.2":{"pli":"Imāni aṭṭhārasa mūlapadāni. ","html":"{}</p>"},"pe1:27.1":{"pli":"Tattha imā uddānagāthā ","html":"<p class='uddana-intro'>{}</p>"},"pe1:28.1":{"pli":"Taṇhā ca avijjā lobho, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"pe1:28.2":{"pli":"Doso tatheva moho ca; ","html":"<span class='verse-line'>{}</span>"},"pe1:28.3":{"pli":"Cattāro ca vipallāsā, ","html":"<span class='verse-line'>{}</span>"},"pe1:28.4":{"pli":"Kilesabhūmi nava padāni. ","html":"<span class='verse-line'>{}</span></p>"},"pe1:29.1":{"pli":"Ye ca satipaṭṭhānā samatho, ","html":"<p><span class='verse-line'>{}</span>"},"pe1:29.2":{"pli":"Vipassanā kusalamūlaṁ; ","html":"<span class='verse-line'>{}</span>"},"pe1:29.3":{"pli":"Etaṁ sabbaṁ kusalaṁ, ","html":"<span class='verse-line'>{}</span>"},"pe1:29.4":{"pli":"Indriyabhūmi navapadāni. ","html":"<span class='verse-line'>{}</span></p>"},"pe1:30.1":{"pli":"Sabbaṁ kusalaṁ navahi padehi yujjati, ","html":"<p><span class='verse-line'>{}</span>"},"pe1:30.2":{"pli":"Navahi ceva akusalaṁ; ","html":"<span class='verse-line'>{}</span>"},"pe1:30.3":{"pli":"Ekake nava mūlapadāni, ","html":"<span class='verse-line'>{}</span>"},"pe1:30.4":{"pli":"Ubhayato aṭṭhārasa mūlapadāni. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:31.1":{"pli":"Imesaṁ aṭṭhārasannaṁ mūlapadānaṁ yāni nava padāni akusalāni, ayaṁ dukkhasamudayo; ","html":"<p>{}"},"pe1:31.2":{"pli":"yāni nava padāni kusalāni, ayaṁ dukkhanirodhagāminī paṭipadā. ","html":"{}"},"pe1:31.3":{"pli":"Iti samudayassa dukkhaṁ phalaṁ, dukkhanirodhagāminiyā paṭipadāya nirodhaṁ phalaṁ. ","html":"{}"},"pe1:31.4":{"pli":"Imāni cattāri ariyasaccāni bhagavatā bārāṇasiyaṁ desitāni. ","html":"{}</p>"},"pe1:32.1":{"pli":"Tattha dukkhassa ariyasaccassa aparimāṇāni akkharāni padāni byañjanāni ākārāni niruttiyo niddesā desitā etassevatthassa saṅkāsanāya pakāsanāya vivaraṇāya vibhajanāya uttānīkammatāya paññāpanāyāti. ","html":"<p>{}"},"pe1:32.2":{"pli":"Yā evaṁ sabbesaṁ saccānaṁ iti ekamekaṁ saccaṁ aparimāṇehi akkharapadabyañjanaākāraniruttiniddesehi pariyesitabbaṁ, tañca byañjanaṁ atthaputhuttena pana attheva byañjanaputhuttena. ","html":"{}</p>"},"pe1:33.1":{"pli":"Yo hi koci samaṇo vā brāhmaṇo vā evaṁ vadeyya “ahaṁ idaṁ dukkhaṁ paccakkhāya aññaṁ dukkhaṁ paññapessāmī”ti tassa taṁ vācāvatthukamevassa pucchito ca na sampāyissati. ","html":"<p>{}"},"pe1:33.2":{"pli":"Evaṁ saccāni. ","html":"{}"},"pe1:33.3":{"pli":"Yañca rattiṁ bhagavā abhisambuddho, yañca rattiṁ anupādāya parinibbuto, etthantare yaṁ kiñci bhagavatā bhāsitaṁ suttaṁ geyyaṁ veyyākaraṇaṁ gāthā udānaṁ itivuttakaṁ jātakaṁ abbhutadhammaṁ vedallaṁ, sabbaṁ taṁ dhammacakkaṁ pavattitaṁ. ","html":"{}"},"pe1:33.4":{"pli":"Na kiñci buddhānaṁ bhagavantānaṁ dhammadesanāya dhammacakkato bahiddhā, tassa sabbaṁ suttaṁ ariyadhammesu pariyesitabbaṁ. ","html":"{}"},"pe1:33.5":{"pli":"Tattha pariggaṇhanāya ālokasabhāni cattāri ariyasaccāni thāvarāni imāni. ","html":"{}</p>"},"pe1:34.1":{"pli":"Tattha katamaṁ <b>dukkhaṁ</b>? ","html":"<p>{}"},"pe1:34.2":{"pli":"Jāti jarā byādhi maraṇaṁ saṅkhittena pañcupādānakkhandhā dukkhā. ","html":"{}"},"pe1:34.3":{"pli":"Tatthāyaṁ lakkhaṇaniddeso, pātubhāvalakkhaṇā jāti, paripākalakkhaṇā jarā, dukkhadukkhatālakkhaṇo byādhi, cutilakkhaṇaṁ maraṇaṁ, piyavippayogavipariṇāmaparitāpanalakkhaṇo soko, lālappanalakkhaṇo paridevo, kāyasampīḷanalakkhaṇaṁ dukkhaṁ, cittasampīḷanalakkhaṇaṁ domanassaṁ, kilesaparidahanalakkhaṇo upāyāso, amanāpasamodhānalakkhaṇo appiyasampayogo, manāpavinābhāvalakkhaṇo piyavippayogo, adhippāyavivattanalakkhaṇo alābho, apariññālakkhaṇā pañcupādānakkhandhā, paripākacutilakkhaṇaṁ jarāmaraṇaṁ, pātubhāvacutilakkhaṇaṁ cutopapatti, paṭisandhinibbattanalakkhaṇo samudayo, samudayaparijahanalakkhaṇo nirodho, anusayasamucchedalakkhaṇo maggo. ","html":"{}"},"pe1:34.4":{"pli":"Byādhilakkhaṇaṁ dukkhaṁ, sañjānanalakkhaṇo samudayo, niyyānikalakkhaṇo maggo, santilakkhaṇo nirodho. ","html":"{}"},"pe1:34.5":{"pli":"Appaṭisandhibhāvanirodhalakkhaṇā anupādisesā nibbānadhātu, dukkhañca samudayo ca, dukkhañca nirodho ca, dukkhañca maggo ca, samudayo ca dukkhañca, samudayo ca nirodho ca, samudayo ca maggo ca, nirodho ca samudayo ca, nirodho ca dukkhañca, nirodho ca maggo ca, maggo ca nirodho ca, maggo ca samudayo ca, maggo ca dukkhañca. ","html":"{}</p>"},"pe1:35.1":{"pli":"Tatthimāni suttāni. ","html":"<p>{}</p>"},"pe1:36.1":{"pli":"“Yamekarattiṁ paṭhamaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pe1:36.2":{"pli":"gabbhe vasati māṇavo; ","html":"<span class='verse-line'>{}</span>"},"pe1:36.3":{"pli":"Abbhuṭṭhitova so yāti, ","html":"<span class='verse-line'>{}</span>"},"pe1:36.4":{"pli":"sa gacchaṁ na nivattatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:37.1":{"pli":"Aṭṭhimā, ānanda, dānūpapattiyo ekuttarike suttaṁ—","html":"<p>{}"},"pe1:37.2":{"pli":"ayaṁ jāti. ","html":"{}</p>"},"pe1:38.1":{"pli":"Tattha katamā jarā? ","html":"<p>{}</p>"},"pe1:39.1":{"pli":"“Acaritvā brahmacariyaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pe1:39.2":{"pli":"aladdhā yobbane dhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"pe1:39.3":{"pli":"Jiṇṇakoñcāva jhāyanti, ","html":"<span class='verse-line'>{}</span>"},"pe1:39.4":{"pli":"khīṇamaccheva pallale”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:40.1":{"pli":"Pañca pubbanimittāni devesu—","html":"<p>{}"},"pe1:40.2":{"pli":"ayaṁ jarā. ","html":"{}</p>"},"pe1:41.1":{"pli":"Tattha katamo byādhi? ","html":"<p>{}</p>"},"pe1:42.1":{"pli":"Sāmaṁ tena kuto rāja, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pe1:42.2":{"pli":"Tuvampi jarāyanti vedesi; ","html":"<span class='verse-line'>{}</span>"},"pe1:42.3":{"pli":"Khattiya kammassa phalo, ","html":"<span class='verse-line'>{}</span>"},"pe1:42.4":{"pli":"Loko na hi kammaṁ panayati. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:43.1":{"pli":"Tayo gilānā—","html":"<p>{}"},"pe1:43.2":{"pli":"ayaṁ byādhi. ","html":"{}</p>"},"pe1:44.1":{"pli":"Tattha katamaṁ maraṇaṁ? ","html":"<p>{}</p>"},"pe1:45.1":{"pli":"Yathāpi kumbhakārassa, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pe1:45.2":{"pli":"kataṁ mattikabhājanaṁ; ","html":"<span class='verse-line'>{}</span>"},"pe1:45.3":{"pli":"Khuddakañca mahantañca, ","html":"<span class='verse-line'>{}</span>"},"pe1:45.4":{"pli":"yaṁ pakkaṁ yañca āmakaṁ; ","html":"<span class='verse-line'>{}</span>"},"pe1:45.5":{"pli":"Sabbaṁ bhedanapariyantaṁ, ","html":"<span class='verse-line'>{}</span>"},"pe1:45.6":{"pli":"evaṁ maccāna jīvitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pe1:46.1":{"pli":"Mamāyite passatha phandamāne, ","html":"<p><span class='verse-line'>{}</span>"},"pe1:46.2":{"pli":"Maccheva appodake khīṇasote; ","html":"<span class='verse-line'>{}</span>"},"pe1:46.3":{"pli":"Etampi disvā amamo careyya, ","html":"<span class='verse-line'>{}</span>"},"pe1:46.4":{"pli":"Bhavesu āsattimakubbamāno. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:47.1":{"pli":"Udakappanasuttaṁ—","html":"<p>{}"},"pe1:47.2":{"pli":"idaṁ maraṇaṁ. ","html":"{}</p>"},"pe1:48.1":{"pli":"Tattha katamo soko? ","html":"<p>{}</p>"},"pe1:49.1":{"pli":"Idha socati pecca socati, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pe1:49.2":{"pli":"Pāpakārī ubhayattha socati; ","html":"<span class='verse-line'>{}</span>"},"pe1:49.3":{"pli":"So socati so vihaññati, ","html":"<span class='verse-line'>{}</span>"},"pe1:49.4":{"pli":"Disvā kammakiliṭṭhamattano. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:50.1":{"pli":"Tīṇi duccaritāni—","html":"<p>{}"},"pe1:50.2":{"pli":"ayaṁ soko. ","html":"{}</p>"},"pe1:51.1":{"pli":"Tattha katamo paridevo? ","html":"<p>{}</p>"},"pe1:52.1":{"pli":"Kāmesu giddhā pasutā pamūḷhā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pe1:52.2":{"pli":"Avadāniyā te visame niviṭṭhā; ","html":"<span class='verse-line'>{}</span>"},"pe1:52.3":{"pli":"Dukkhūpanītā paridevayanti, ","html":"<span class='verse-line'>{}</span>"},"pe1:52.4":{"pli":"Kiṁsu bhavissāma ito cutāse. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:53.1":{"pli":"Tisso vipattiyo—","html":"<p>{}"},"pe1:53.2":{"pli":"ayaṁ paridevo. ","html":"{}</p>"},"pe1:54.1":{"pli":"Tattha katamaṁ dukkhaṁ? ","html":"<p>{}</p>"},"pe1:55.1":{"pli":"Sataṁ āsi ayosaṅkū, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pe1:55.2":{"pli":"sabbe paccattavedanā; ","html":"<span class='verse-line'>{}</span>"},"pe1:55.3":{"pli":"Jalitā jātavedāva, ","html":"<span class='verse-line'>{}</span>"},"pe1:55.4":{"pli":"accisaṅghasamākulā. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:56.1":{"pli":"Mahā vata so pariḷāho saṁyuttake suttaṁ saccasaṁyuttesu—","html":"<p>{}"},"pe1:56.2":{"pli":"idaṁ dukkhaṁ. ","html":"{}</p>"},"pe1:57.1":{"pli":"Tattha katamaṁ domanassaṁ? ","html":"<p>{}</p>"},"pe1:58.1":{"pli":"Saṅkappehi pareto so, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pe1:58.2":{"pli":"kapaṇo viya jhāyati; ","html":"<span class='verse-line'>{}</span>"},"pe1:58.3":{"pli":"Sutvā paresaṁ nigghosaṁ, ","html":"<span class='verse-line'>{}</span>"},"pe1:58.4":{"pli":"maṅku hoti tathāvidho. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:59.1":{"pli":"Dveme tapanīyā dhammā—","html":"<p>{}"},"pe1:59.2":{"pli":"idaṁ domanassaṁ. ","html":"{}</p>"},"pe1:60.1":{"pli":"Tattha katamo upāyāso? ","html":"<p>{}</p>"},"pe1:61.1":{"pli":"Kammārānaṁ yathā ukkā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pe1:61.2":{"pli":"anto ḍayhati no bahi; ","html":"<span class='verse-line'>{}</span>"},"pe1:61.3":{"pli":"Evaṁ ḍayhati me hadayaṁ, ","html":"<span class='verse-line'>{}</span>"},"pe1:61.4":{"pli":"sutvā nibbattamambujaṁ. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:62.1":{"pli":"Tayo aggī—","html":"<p>{}"},"pe1:62.2":{"pli":"ayaṁ upāyāso. ","html":"{}</p>"},"pe1:63.1":{"pli":"Tattha katamo appiyasampayogo? ","html":"<p>{}</p>"},"pe1:64.1":{"pli":"Ayasāva malaṁ samuṭṭhitaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pe1:64.2":{"pli":"Tatuṭṭhāya tameva khādati; ","html":"<span class='verse-line'>{}</span>"},"pe1:64.3":{"pli":"Evaṁ atidhonacārinaṁ, ","html":"<span class='verse-line'>{}</span>"},"pe1:64.4":{"pli":"Sāni kammāni nayanti duggatiṁ. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:65.1":{"pli":"Dveme tathāgataṁ abbhācikkhanti, ekuttarike suttaṁ dukesu—","html":"<p>{}"},"pe1:65.2":{"pli":"ayaṁ appiyasampayogo. ","html":"{}</p>"},"pe1:66.1":{"pli":"Tattha katamo piyavippayogo? ","html":"<p>{}</p>"},"pe1:67.1":{"pli":"Supinena yathāpi saṅgataṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pe1:67.2":{"pli":"Paṭibuddho puriso na passati; ","html":"<span class='verse-line'>{}</span>"},"pe1:67.3":{"pli":"Evampi piyāyitaṁ janaṁ, ","html":"<span class='verse-line'>{}</span>"},"pe1:67.4":{"pli":"Petaṁ kālaṅkataṁ na passati. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:68.1":{"pli":"Te devā cavanadhammaṁ viditvā tīhi vācāhi anusāsanti. ","html":"<p>{}"},"pe1:68.2":{"pli":"Ayaṁ piyavippayogo. ","html":"{}</p>"},"pe1:69.1":{"pli":"Yampicchaṁ na labhati, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pe1:69.2":{"pli":"tisso māradhītaro; ","html":"<span class='verse-line'>{}</span>"},"pe1:69.3":{"pli":"Tassa ce kāmayānassa, ","html":"<span class='verse-line'>{}</span>"},"pe1:69.4":{"pli":"chandajātassa jantuno; ","html":"<span class='verse-line'>{}</span>"},"pe1:69.5":{"pli":"Te kāmā parihāyanti, ","html":"<span class='verse-line'>{}</span>"},"pe1:69.6":{"pli":"sallaviddhova ruppati. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:70.1":{"pli":"Saṅkhittena pañcupādānakkhandhā dukkhā. ","html":"<p>{}</p>"},"pe1:71.1":{"pli":"Cakkhu sotañca ghānañca, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pe1:71.2":{"pli":"jivhā kāyo tato manaṁ; ","html":"<span class='verse-line'>{}</span>"},"pe1:71.3":{"pli":"Ete lokāmisā ghorā, ","html":"<span class='verse-line'>{}</span>"},"pe1:71.4":{"pli":"yattha sattā puthujjanā. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:72.1":{"pli":"Pañcime bhikkhave khandhā—","html":"<p>{}"},"pe1:72.2":{"pli":"idaṁ dukkhaṁ. ","html":"{}</p>"},"pe1:73.1":{"pli":"Tattha katamā jarā ca maraṇañca? ","html":"<p>{}</p>"},"pe1:74.1":{"pli":"Appaṁ vata jīvitaṁ idaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pe1:74.2":{"pli":"Oraṁ vassasatāpi mīyate; ","html":"<span class='verse-line'>{}</span>"},"pe1:74.3":{"pli":"Atha vāpi akicchaṁ jīvitaṁ, ","html":"<span class='verse-line'>{}</span>"},"pe1:74.4":{"pli":"Atha kho so jarasāpi mīyate. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:75.1":{"pli":"Saṁyuttake pasenadisaṁyuttake suttaṁ ayyikā me kālaṅkatā—","html":"<p>{}"},"pe1:75.2":{"pli":"ayaṁ jarā ca maraṇañca. ","html":"{}</p>"},"pe1:76.1":{"pli":"Tattha katamā cuti ca upapatti ca? ","html":"<p>{}</p>"},"pe1:77.1":{"pli":"“Sabbe sattā marissanti, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pe1:77.2":{"pli":"Maraṇantaṁ hi jīvitaṁ; ","html":"<span class='verse-line'>{}</span>"},"pe1:77.3":{"pli":"Yathākammaṁ gamissanti, ","html":"<span class='verse-line'>{}</span>"},"pe1:77.4":{"pli":"Attakammaphalūpagā”ti.—","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:78.1":{"pli":"Ayaṁ cuti ca upapatti ca. ","html":"<p>{}</p>"},"pe1:79.1":{"pli":"Imehi suttehi ekasadisehi ca aññehi navavidhaṁ suttaṁ taṁ anupaviṭṭhehi lakkhaṇato dukkhaṁ ñatvā sādhāraṇañca asādhāraṇañca dukkhaṁ ariyasaccaṁ niddisitabbaṁ. ","html":"<p>{}"},"pe1:79.2":{"pli":"Gāthāhi gāthā anuminitabbā, byākaraṇehi vā byākaraṇaṁ—","html":"{}"},"pe1:79.3":{"pli":"idaṁ dukkhaṁ. ","html":"{}</p>"},"pe1:80.1":{"pli":"Tattha katamo <b>dukkhasamudayo</b>? ","html":"<p>{}</p>"},"pe1:81.1":{"pli":"Kāmesu sattā kāmasaṅgasattā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pe1:81.2":{"pli":"Saṁyojane vajjamapassamānā; ","html":"<span class='verse-line'>{}</span>"},"pe1:81.3":{"pli":"Na hi jātu saṁyojanasaṅgasattā, ","html":"<span class='verse-line'>{}</span>"},"pe1:81.4":{"pli":"Oghaṁ tareyyuṁ vipulaṁ mahantaṁ. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:82.1":{"pli":"Cattāro āsavā suttaṁ—","html":"<p>{}"},"pe1:82.2":{"pli":"ayaṁ dukkhasamudayo. ","html":"{}</p>"},"pe1:83.1":{"pli":"Tattha katamo <b>dukkhanirodho</b>? ","html":"<p>{}</p>"},"pe1:84.1":{"pli":"Yamhi na māyā vasatī na māno, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pe1:84.2":{"pli":"Yo vītalobho amamo nirāso; ","html":"<span class='verse-line'>{}</span>"},"pe1:84.3":{"pli":"Panuṇṇakodho abhinibbutatto, ","html":"<span class='verse-line'>{}</span>"},"pe1:84.4":{"pli":"So brāhmaṇo so samaṇo sa bhikkhu. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:85.1":{"pli":"Dvemā vimuttiyo, rāgavirāgā ca cetovimutti; ","html":"<p>{}"},"pe1:85.2":{"pli":"avijjāvirāgā ca paññāvimutti—","html":"{}"},"pe1:85.3":{"pli":"ayaṁ nirodho. ","html":"{}</p>"},"pe1:86.1":{"pli":"Tattha katamo <b>maggo</b>? ","html":"<p>{}</p>"},"pe1:87.1":{"pli":"Eseva maggo natthañño, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pe1:87.2":{"pli":"dassanassa visuddhiyā; ","html":"<span class='verse-line'>{}</span>"},"pe1:87.3":{"pli":"Ariyo aṭṭhaṅgiko maggo, ","html":"<span class='verse-line'>{}</span>"},"pe1:87.4":{"pli":"mārassetaṁ pamohanaṁ. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:88.1":{"pli":"Sattime, bhikkhave, bojjhaṅgā—","html":"<p>{}"},"pe1:88.2":{"pli":"ayaṁ maggo. ","html":"{}</p>"},"pe1:89.1":{"pli":"Tattha katamāni <b>cattāri ariyasaccāni</b>? ","html":"<p>{}</p>"},"pe1:90.1":{"pli":"“Ye dhammā hetuppabhavā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pe1:90.2":{"pli":"Tesaṁ hetuṁ tathāgato āha; ","html":"<span class='verse-line'>{}</span>"},"pe1:90.3":{"pli":"Tesañca yo nirodho, ","html":"<span class='verse-line'>{}</span>"},"pe1:90.4":{"pli":"Evaṁvādī mahāsamaṇo”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:91.1":{"pli":"Hetuppabhavā dhammā dukkhaṁ, hetusamudayo, yaṁ bhagavato vacanaṁ. ","html":"<p>{}"},"pe1:91.2":{"pli":"Ayaṁ dhammo yo nirodho, ye hi keci saṁyojaniyesu dhammesu assadānupassino viharanti. ","html":"{}"},"pe1:91.3":{"pli":"Kilesā taṇhā pavaḍḍhati, taṇhāpaccayā upādānaṁ …pe… ","html":"{}"},"pe1:91.4":{"pli":"evametassa kevalassa dukkhakkhandhassa samudayo hoti. ","html":"{}"},"pe1:91.5":{"pli":"Tattha yaṁ saṁyojanaṁ—","html":"{}"},"pe1:91.6":{"pli":"ayaṁ samudayo. ","html":"{}"},"pe1:91.7":{"pli":"Ye saṁyojaniyā dhammā ye ca sokaparidevadukkhadomanassupāyāsā sambhavanti—","html":"{}"},"pe1:91.8":{"pli":"idaṁ dukkhaṁ. ","html":"{}"},"pe1:91.9":{"pli":"Yā saṁyojaniyesu dhammesu ādīnavānupassanā—","html":"{}"},"pe1:91.10":{"pli":"ayaṁ maggo. ","html":"{}"},"pe1:91.11":{"pli":"Parimuccati jātiyā jarāya byādhīhi maraṇehi sokehi paridevehi yāva upāyāsehi—","html":"{}"},"pe1:91.12":{"pli":"idaṁ nibbānaṁ. ","html":"{}"},"pe1:91.13":{"pli":"Imāni cattāri saccāni. ","html":"{}</p>"},"pe1:92.1":{"pli":"Tattha katamā <b>anupādisesā nibbānadhātu</b>? ","html":"<p>{}</p>"},"pe1:93.1":{"pli":"Atthaṅgatassa na pamāṇamatthi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pe1:93.2":{"pli":"Taṁ hi vā natthi yena naṁ paññapeyya; ","html":"<span class='verse-line'>{}</span>"},"pe1:93.3":{"pli":"Sabbasaṅgānaṁ samūhatattā vidū, ","html":"<span class='verse-line'>{}</span>"},"pe1:93.4":{"pli":"Sitā vādasatassu sabbe. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:94.1":{"pli":"Saṁyuttake godhikasaṁyuttaṁ. ","html":"<p class='endsutta'>{}</p>"},"pe1:95.1":{"pli":"Imāni <b>asādhāraṇāni suttāni</b>. ","html":"<p>{}"},"pe1:95.2":{"pli":"Yahiṁ yahiṁ saccāni niddiṭṭhāni, tahiṁ tahiṁ saccalakkhaṇato otāretvā aparimāṇehi byañjanehi so attho pariyesitabbo. ","html":"{}"},"pe1:95.3":{"pli":"Tattha atthānuparivatti byañjanena puna byañjanānuparivatti atthena tassa ekamekassa aparimāṇāni byañjanāni imehi suttehi yathānikkhittehi cattāri ariyasaccāni niddisitabbāni. ","html":"{}"},"pe1:95.4":{"pli":"Pañcanikāye anupaviṭṭhāhi gāthāhi gāthā anuminitabbā, byākaraṇena byākaraṇaṁ. ","html":"{}"},"pe1:95.5":{"pli":"Imāni asādhāraṇāni suttāni. ","html":"{}</p>"},"pe1:96.1":{"pli":"Tesaṁ imā uddānagāthā ","html":"<p class='uddana-intro'>{}</p>"},"pe1:97.1":{"pli":"Yamekarattiṁ paṭhamaṁ, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"pe1:97.2":{"pli":"aṭṭha dānūpapattiyo; ","html":"<span class='verse-line'>{}</span>"},"pe1:97.3":{"pli":"Pañca pubbanimittāni, ","html":"<span class='verse-line'>{}</span>"},"pe1:97.4":{"pli":"khīṇamacchaṁva pallalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pe1:98.1":{"pli":"Sāmaṁ tena kuto rāja, ","html":"<p><span class='verse-line'>{}</span>"},"pe1:98.2":{"pli":"tayo devā gilānakā; ","html":"<span class='verse-line'>{}</span>"},"pe1:98.3":{"pli":"Yathāpi kumbhakārassa, ","html":"<span class='verse-line'>{}</span>"},"pe1:98.4":{"pli":"yathā nadidakappanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pe1:99.1":{"pli":"Idha socati pecca socati, ","html":"<p><span class='verse-line'>{}</span>"},"pe1:99.2":{"pli":"Tīṇi duccaritāni ca; ","html":"<span class='verse-line'>{}</span>"},"pe1:99.3":{"pli":"Kāmesu giddhā pasutā, ","html":"<span class='verse-line'>{}</span>"},"pe1:99.4":{"pli":"Yāva tisso vipattiyo. ","html":"<span class='verse-line'>{}</span></p>"},"pe1:100.1":{"pli":"Sataṁ āsi ayosaṅkū, ","html":"<p><span class='verse-line'>{}</span>"},"pe1:100.2":{"pli":"pariḷāho mahattaro; ","html":"<span class='verse-line'>{}</span>"},"pe1:100.3":{"pli":"Saṅkappehi pareto so, ","html":"<span class='verse-line'>{}</span>"},"pe1:100.4":{"pli":"tattha tapaniyehi ca. ","html":"<span class='verse-line'>{}</span></p>"},"pe1:101.1":{"pli":"Kammārānaṁ yathā ukkā, ","html":"<p><span class='verse-line'>{}</span>"},"pe1:101.2":{"pli":"tayo aggī pakāsitā; ","html":"<span class='verse-line'>{}</span>"},"pe1:101.3":{"pli":"Ayato malamuppannaṁ, ","html":"<span class='verse-line'>{}</span>"},"pe1:101.4":{"pli":"abbhakkhānaṁ tathāgate. ","html":"<span class='verse-line'>{}</span></p>"},"pe1:102.1":{"pli":"Tividhaṁ devānusāsanti, ","html":"<p><span class='verse-line'>{}</span>"},"pe1:102.2":{"pli":"supinena saṅgamo yathā; ","html":"<span class='verse-line'>{}</span>"},"pe1:102.3":{"pli":"Tisso ceva māradhītā, ","html":"<span class='verse-line'>{}</span>"},"pe1:102.4":{"pli":"sallaviddhova ruppati. ","html":"<span class='verse-line'>{}</span></p>"},"pe1:103.1":{"pli":"Cakkhu sotañca ghānañca, ","html":"<p><span class='verse-line'>{}</span>"},"pe1:103.2":{"pli":"pañcakkhandhā pakāsitā; ","html":"<span class='verse-line'>{}</span>"},"pe1:103.3":{"pli":"Appaṁ vata jīvitaṁ idaṁ, ","html":"<span class='verse-line'>{}</span>"},"pe1:103.4":{"pli":"ayyikā me mahallikā. ","html":"<span class='verse-line'>{}</span></p>"},"pe1:104.1":{"pli":"Sabbe sattā marissanti, ","html":"<p><span class='verse-line'>{}</span>"},"pe1:104.2":{"pli":"upapatti cuticayaṁ; ","html":"<span class='verse-line'>{}</span>"},"pe1:104.3":{"pli":"Kāmesu sattā pasutā, ","html":"<span class='verse-line'>{}</span>"},"pe1:104.4":{"pli":"āsavehi catūhi ca. ","html":"<span class='verse-line'>{}</span></p>"},"pe1:105.1":{"pli":"Yamhi na māyā vasati, ","html":"<p><span class='verse-line'>{}</span>"},"pe1:105.2":{"pli":"dvemā cetovimuttiyo; ","html":"<span class='verse-line'>{}</span>"},"pe1:105.3":{"pli":"Eseva maggo natthañño, ","html":"<span class='verse-line'>{}</span>"},"pe1:105.4":{"pli":"bojjhaṅgā ca sudesitā. ","html":"<span class='verse-line'>{}</span></p>"},"pe1:106.1":{"pli":"Atthaṅgatassa na pamāṇamatthi, ","html":"<p><span class='verse-line'>{}</span>"},"pe1:106.2":{"pli":"Godhiko parinibbuto; ","html":"<span class='verse-line'>{}</span>"},"pe1:106.3":{"pli":"Ye dhammā hetuppabhavā, ","html":"<span class='verse-line'>{}</span>"},"pe1:106.4":{"pli":"Saṁyojanānupassino. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:107.1":{"pli":"Imā dasa tesaṁ uddānagāthā. ","html":"<p class='endsutta'>{}</p>"},"pe1:108.1":{"pli":"Tatthimāni <b>sādhāraṇāni suttāni</b> yesu suttesu sādhāraṇāni saccāni desitāni anulomampi paṭilomampi vomissakampi. ","html":"<p>{}"},"pe1:108.2":{"pli":"Tattha ayaṁ ādi. ","html":"{}</p>"},"pe1:109.1":{"pli":"Avijjāya nivuto loko, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pe1:109.2":{"pli":"(ajitāti bhagavā) ","html":"<span class='speaker'>{}</span>"},"pe1:109.3":{"pli":"Vivicchā pamādā nappakāsati; ","html":"<span class='verse-line'>{}</span>"},"pe1:109.4":{"pli":"Jappābhilepanaṁ brūmi, ","html":"<span class='verse-line'>{}</span>"},"pe1:109.5":{"pli":"Dukkhamassa mahabbhayaṁ. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:110.1":{"pli":"Tattha yā avijjā ca vivicchā ca, ayaṁ samudayo. ","html":"<p>{}"},"pe1:110.2":{"pli":"Yaṁ mahabbhayaṁ, idaṁ dukkhaṁ. ","html":"{}"},"pe1:110.3":{"pli":"Imāni dve saccāni—","html":"{}"},"pe1:110.4":{"pli":"dukkhañca samudayo ca. ","html":"{}"},"pe1:110.5":{"pli":"“Saṁyojanaṁ saṁyojaniyā ca dhammā”ti saṁyuttake cittasaṁyuttakesu byākaraṇaṁ. ","html":"{}"},"pe1:110.6":{"pli":"Tattha yaṁ saṁyojanaṁ, ayaṁ samudayo. ","html":"{}"},"pe1:110.7":{"pli":"Ye saṁyojaniyā dhammā, idaṁ dukkhaṁ. ","html":"{}"},"pe1:110.8":{"pli":"Imāni dve saccāni—","html":"{}"},"pe1:110.9":{"pli":"dukkhañca samudayo ca. ","html":"{}</p>"},"pe1:111.1":{"pli":"Tattha katamaṁ dukkhañca nirodho ca? ","html":"<p>{}</p>"},"pe1:112.1":{"pli":"Ucchinnabhavataṇhassa, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pe1:112.2":{"pli":"netticchinnassa bhikkhuno; ","html":"<span class='verse-line'>{}</span>"},"pe1:112.3":{"pli":"Vikkhīṇo jātisaṁsāro, ","html":"<span class='verse-line'>{}</span>"},"pe1:112.4":{"pli":"natthi dāni punabbhavo. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:113.1":{"pli":"Yaṁ cittaṁ, idaṁ dukkhaṁ. ","html":"<p>{}"},"pe1:113.2":{"pli":"Yo bhavataṇhāya upacchedo, ayaṁ dukkhanirodho. ","html":"{}"},"pe1:113.3":{"pli":"Vikkhīṇo jātisaṁsāro, natthi dāni punabbhavoti niddeso. ","html":"{}"},"pe1:113.4":{"pli":"Imāni dve saccāni—","html":"{}"},"pe1:113.5":{"pli":"dukkhañca nirodho ca. ","html":"{}"},"pe1:113.6":{"pli":"Dvemā, bhikkhave, vimuttiyo; ","html":"{}"},"pe1:113.7":{"pli":"rāgavirāgā ca cetovimutti, avijjāvirāgā ca paññāvimutti. ","html":"{}"},"pe1:113.8":{"pli":"Yaṁ cittaṁ, idaṁ dukkhaṁ. ","html":"{}"},"pe1:113.9":{"pli":"Yā vimutti, ayaṁ nirodho. ","html":"{}"},"pe1:113.10":{"pli":"Imāni dve saccāni—","html":"{}"},"pe1:113.11":{"pli":"dukkhañca nirodho ca. ","html":"{}</p>"},"pe1:114.1":{"pli":"Tattha katamaṁ dukkhañca maggo ca? ","html":"<p>{}</p>"},"pe1:115.1":{"pli":"Kumbhūpamaṁ kāyamimaṁ viditvā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pe1:115.2":{"pli":"Nagarūpamaṁ cittamidaṁ ṭhapetvā; ","html":"<span class='verse-line'>{}</span>"},"pe1:115.3":{"pli":"Yodhetha māraṁ paññāvudhena, ","html":"<span class='verse-line'>{}</span>"},"pe1:115.4":{"pli":"Jitañca rakkhe anivesano siyā. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:116.1":{"pli":"Tattha yañca kumbhūpamo kāyo yañca nagarūpamaṁ cittaṁ, idaṁ dukkhaṁ. ","html":"<p>{}"},"pe1:116.2":{"pli":"Yaṁ paññāvudhena māraṁ yodhethāti ayaṁ maggo. ","html":"{}"},"pe1:116.3":{"pli":"Imāni dve saccāni. ","html":"{}"},"pe1:116.4":{"pli":"Yaṁ, bhikkhave, na tumhākaṁ, taṁ pajahitabbaṁ. ","html":"{}"},"pe1:116.5":{"pli":"Yā saṁyojanā, ayaṁ maggo. ","html":"{}"},"pe1:116.6":{"pli":"Ye te dhammā anattaniyā pahātabbā, rūpaṁ yāva viññāṇaṁ, idaṁ dukkhañca maggo ca. ","html":"{}</p>"},"pe1:117.1":{"pli":"Tattha katamaṁ dukkhañca samudayo ca nirodho ca? ","html":"<p>{}</p>"},"pe1:118.1":{"pli":"Ye keci sokā paridevitā vā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pe1:118.2":{"pli":"Dukkhā ca lokasmimanekarūpā; ","html":"<span class='verse-line'>{}</span>"},"pe1:118.3":{"pli":"Piyaṁ paṭiccappabhavanti ete, ","html":"<span class='verse-line'>{}</span>"},"pe1:118.4":{"pli":"Piye asante na bhavanti ete. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:119.1":{"pli":"Ye sokaparidevā, yaṁ ca anekarūpaṁ dukkhaṁ, yaṁ pemato bhavati, idaṁ dukkhaṁ. ","html":"<p>{}"},"pe1:119.2":{"pli":"Yaṁ pemaṁ, ayaṁ samudayo. ","html":"{}"},"pe1:119.3":{"pli":"Yo tattha chandarāgavinayo piyassa akiriyā, ayaṁ nirodho. ","html":"{}"},"pe1:119.4":{"pli":"Imāni tīṇi saccāni. ","html":"{}"},"pe1:119.5":{"pli":"Timbaruko paribbājako pacceti “sayaṅkataṁ paraṅkatan”ti. ","html":"{}"},"pe1:119.6":{"pli":"Yathesā vīmaṁsā, idaṁ dukkhaṁ. ","html":"{}"},"pe1:119.7":{"pli":"Yā ete dve ante anupagamma majjhimā paṭipadā avijjāpaccayā saṅkhārā yāva jātipaccayā jarāmaraṇaṁ, idampi dukkhañca samudayo ca. ","html":"{}"},"pe1:119.8":{"pli":"Viññāṇaṁ nāmarūpaṁ saḷāyatanaṁ phasso vedanā bhavo jāti jarāmaraṇaṁ, idaṁ dukkhaṁ. ","html":"{}"},"pe1:119.9":{"pli":"Avijjā saṅkhārā taṇhā upādānaṁ, ayaṁ samudayo. ","html":"{}"},"pe1:119.10":{"pli":"Iti idaṁ sayaṅkataṁ vīmaṁseyyāti yañca paṭiccasamuppāde dukkhaṁ, idaṁ eso samudayo niddiṭṭho. ","html":"{}"},"pe1:119.11":{"pli":"Avijjānirodhā saṅkhāranirodho ca yāva ca jarāmaraṇanirodhoti ayaṁ nirodho. ","html":"{}"},"pe1:119.12":{"pli":"Imāni tīṇi saccāni dukkhañca samudayo ca nirodho ca. ","html":"{}</p>"},"pe1:120.1":{"pli":"Tattha katamaṁ dukkhañca samudayo ca maggo ca? ","html":"<p>{}</p>"},"pe1:121.1":{"pli":"“Yo dukkhamaddakkhi yatonidānaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pe1:121.2":{"pli":"Kāmesu so jantu kathaṁ nameyya; ","html":"<span class='verse-line'>{}</span>"},"pe1:121.3":{"pli":"Kāmā hi loke saṅgāti ñatvā, ","html":"<span class='verse-line'>{}</span>"},"pe1:121.4":{"pli":"Tesaṁ satīmā vinayāya sikkhe”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:122.1":{"pli":"Yo dukkhamaddakkhi, idaṁ dukkhaṁ. ","html":"<p>{}"},"pe1:122.2":{"pli":"Yato bhavati, ayaṁ samudayo. ","html":"{}"},"pe1:122.3":{"pli":"Sandiṭṭhaṁ yato bhavati yāva tassa vinayāya sikkhā, ayaṁ maggo. ","html":"{}"},"pe1:122.4":{"pli":"Imāni tīṇi saccāni. ","html":"{}</p>"},"pe1:123.1":{"pli":"Ekādasaṅguttaresu gopālakopamasuttaṁ. ","html":"<p class='endsutta'>{}</p>"},"pe1:124.1":{"pli":"Tattha yāva rūpasaññuttā yañca saḷāyatanaṁ yathā vaṇaṁ paṭicchādeti yañca titthaṁ yathā ca labhati dhammūpasañhitaṁ uḷāraṁ pītipāmojjaṁ catubbidhaṁ ca attabhāvato ca vatthu, idaṁ dukkhaṁ. ","html":"<p>{}"},"pe1:124.2":{"pli":"Yāva āsāṭikaṁ hāretā hoti, ayaṁ samudayo. ","html":"{}"},"pe1:124.3":{"pli":"Rūpasaññuttā āsāṭakaharaṇaṁ vaṇapaṭicchādanaṁ vīthiññutā gocarakusalañca, ayaṁ maggo. ","html":"{}"},"pe1:124.4":{"pli":"Avasesā dhammā atthi hetū atthi paccayā atthi nissayā sāvasesadohitā anekapūjā ca kalyāṇamittatappaccayā dhammā vīthiññutā ca hetu, imāni tīṇi saccāni. ","html":"{}</p>"},"pe1:125.1":{"pli":"Tattha katamaṁ dukkhañca maggo ca nirodho ca? ","html":"<p>{}</p>"},"pe1:126.1":{"pli":"Sati kāyagatā upaṭṭhitā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pe1:126.2":{"pli":"Chasu phassāyatanesu saṁvuto; ","html":"<span class='verse-line'>{}</span>"},"pe1:126.3":{"pli":"Satataṁ bhikkhu samāhito, ","html":"<span class='verse-line'>{}</span>"},"pe1:126.4":{"pli":"Jaññā nibbānamattano. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:127.1":{"pli":"Tattha yā ca kāyagatā sati yañca saḷāyatanaṁ yattha sabbañcetaṁ dukkhaṁ. ","html":"<p>{}"},"pe1:127.2":{"pli":"Yā ca kāyagatā sati yo ca sīlasaṁvaro yo ca samādhi yattha yā sati, ayaṁ paññākkhandho. ","html":"{}"},"pe1:127.3":{"pli":"Sabbampi sīlakkhandho samādhikkhandho, ayaṁ maggo. ","html":"{}"},"pe1:127.4":{"pli":"Evaṁvihārinā ñātabbaṁ nibbānaṁ. ","html":"{}"},"pe1:127.5":{"pli":"Ayaṁ nirodho, imāni tīṇi saccāni. ","html":"{}"},"pe1:127.6":{"pli":"Sīle patiṭṭhāya dve dhammā bhāvetabbā samatho ca vipassanā ca. ","html":"{}"},"pe1:127.7":{"pli":"Tattha yaṁ cittasahajātā dhammā, idaṁ dukkhaṁ. ","html":"{}"},"pe1:127.8":{"pli":"Yo ca samatho yā ca vipassanā, ayaṁ maggo. ","html":"{}"},"pe1:127.9":{"pli":"Rāgavirāgā ca cetovimutti, avijjāvirāgā ca paññāvimutti, ayaṁ nirodho. ","html":"{}"},"pe1:127.10":{"pli":"Imāni tīṇi saccāni. ","html":"{}</p>"},"pe1:128.1":{"pli":"Tattha katamo samudayo ca nirodho ca? ","html":"<p>{}</p>"},"pe1:129.1":{"pli":"Āsā ca pīhā abhinandanā ca, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pe1:129.2":{"pli":"Anekadhātūsu sarā patiṭṭhitā; ","html":"<span class='verse-line'>{}</span>"},"pe1:129.3":{"pli":"Aññāṇamūlappabhavā pajappitā, ","html":"<span class='verse-line'>{}</span>"},"pe1:129.4":{"pli":"Sabbā mayā byantikatā samūlikā. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:130.1":{"pli":"Aññāṇamūlappabhavāti purimakehi samudayo. ","html":"<p>{}"},"pe1:130.2":{"pli":"Sabbā mayā byantikatā samūlikāti nirodho. ","html":"{}"},"pe1:130.3":{"pli":"Imāni dve saccāni. ","html":"{}"},"pe1:130.4":{"pli":"Catunnaṁ dhammānaṁ ananubodhā appaṭivedhā vitthārena kātabbaṁ. ","html":"{}"},"pe1:130.5":{"pli":"Ariyassa sīlassa samādhino paññāya vimuttiyā. ","html":"{}"},"pe1:130.6":{"pli":"Tattha yo imesaṁ catunnaṁ dhammānaṁ ananubodhā appaṭivedhā, ayaṁ samudayo. ","html":"{}"},"pe1:130.7":{"pli":"Paṭivedho bhavanettiyā, ayaṁ nirodho. ","html":"{}"},"pe1:130.8":{"pli":"Ayaṁ samudayo ca nirodho ca. ","html":"{}</p>"},"pe1:131.1":{"pli":"Tattha katamo samudayo ca maggo ca? ","html":"<p>{}</p>"},"pe1:132.1":{"pli":"Yāni sotāni lokasmiṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pe1:132.2":{"pli":"(ajitāti bhagavā) ","html":"<span class='speaker'>{}</span>"},"pe1:132.3":{"pli":"Sati tesaṁ nivāraṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"pe1:132.4":{"pli":"Sotānaṁ saṁvaraṁ brūmi, ","html":"<span class='verse-line'>{}</span>"},"pe1:132.5":{"pli":"Paññāyete pidhīyare. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:133.1":{"pli":"Yāni sotānīti ayaṁ samudayo. ","html":"<p>{}"},"pe1:133.2":{"pli":"Yā ca paññā yā ca sati nivāraṇaṁ pidhānañca, ayaṁ maggo. ","html":"{}"},"pe1:133.3":{"pli":"Imāni dve saccāni. ","html":"{}"},"pe1:133.4":{"pli":"Sañcetaniyaṁ suttaṁ daḷhanemiyānākāro chahi māsehi niddiṭṭho. ","html":"{}"},"pe1:133.5":{"pli":"Tattha yaṁ kāyaṁ kāyakammaṁ savaṅkaṁ sadosaṁ sakasāvaṁ yā savaṅkatā sadosatā sakasāvatā, ayaṁ samudayo. ","html":"{}"},"pe1:133.6":{"pli":"Evaṁ vacīkammaṁ manokammaṁ avaṅkaṁ adosaṁ akasāvaṁ, yā avaṅkatā adosatā akasāvatā, ayaṁ maggo. ","html":"{}"},"pe1:133.7":{"pli":"Evaṁ vacīkammaṁ manokammaṁ. ","html":"{}"},"pe1:133.8":{"pli":"Imāni dve saccāni samudayo ca maggo ca. ","html":"{}</p>"},"pe1:134.1":{"pli":"Tattha katamo samudayo ca nirodho ca maggo ca? ","html":"<p>{}</p>"},"pe1:135.1":{"pli":"“Nissitassa calitaṁ, anissitassa calitaṁ natthi, calite asati passaddhi, passaddhiyā sati nati na hoti, natiyā asati āgatigati na hoti, āgatigatiyā asati cutūpapāto na hoti, cutūpapāte asati nevidha na huraṁ na ubhayamantarena. ","html":"<p>{}"},"pe1:135.2":{"pli":"Esevanto dukkhassā”ti. ","html":"{}</p>"},"pe1:136.1":{"pli":"Tattha dve nissayā, ayaṁ samudayo. ","html":"<p>{}"},"pe1:136.2":{"pli":"Yo ca anissayo, yā ca anati, ayaṁ maggo. ","html":"{}"},"pe1:136.3":{"pli":"Yā āgatigati na hoti cutūpapāto ca yo esevanto dukkhassāti, ayaṁ nirodho. ","html":"{}"},"pe1:136.4":{"pli":"Imāni tīṇi saccāni. ","html":"{}"},"pe1:136.5":{"pli":"Anupaṭṭhitakāyagatā sati …pe… ","html":"{}"},"pe1:136.6":{"pli":"yaṁ vimuttiñāṇadassanaṁ, ayaṁ samudayo. ","html":"{}"},"pe1:136.7":{"pli":"Ekārasaupanissayā vimuttiyo yāva upanissayaupasampadā upaṭṭhitakāyagatāsatissa viharati. ","html":"{}"},"pe1:136.8":{"pli":"Sīlasaṁvaro sosāniyo hoti, yañca vimuttiñāṇadassanaṁ, ayaṁ maggo. ","html":"{}"},"pe1:136.9":{"pli":"Yā ca vimutti, ayaṁ nirodho. ","html":"{}"},"pe1:136.10":{"pli":"Imāni tīṇi saccāni. ","html":"{}"},"pe1:136.11":{"pli":"Samudayo ca nirodho ca maggo ca. ","html":"{}</p>"},"pe1:137.1":{"pli":"Tattha katamo nirodho ca maggo ca? ","html":"<p>{}</p>"},"pe1:138.1":{"pli":"Sayaṁ katena saccena, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pe1:138.2":{"pli":"Tena attanā abhinibbānagato vitiṇṇakaṅkho; ","html":"<span class='verse-line'>{}</span>"},"pe1:138.3":{"pli":"Vibhavañca ñatvā lokasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"pe1:138.4":{"pli":"Tāva khīṇapunabbhavo sa bhikkhu. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:139.1":{"pli":"Yaṁ saccena, ayaṁ maggo. ","html":"<p>{}"},"pe1:139.2":{"pli":"Yaṁ khīṇapunabbhavo, ayaṁ nirodho. ","html":"{}"},"pe1:139.3":{"pli":"Imāni dve saccāni. ","html":"{}"},"pe1:139.4":{"pli":"Pañca vimuttāyatanāni satthā vā dhammaṁ desesi aññataro vā viññū sabrahmacārīti vitthārena kātabbā. ","html":"{}"},"pe1:139.5":{"pli":"Tassa atthappaṭisaṁvedissa pāmojjaṁ jāyati, pamuditassa pīti jāyati, yāva nibbindanto virajjati, ayaṁ maggo. ","html":"{}"},"pe1:139.6":{"pli":"Yā vimutti, ayaṁ nirodho. ","html":"{}"},"pe1:139.7":{"pli":"Evaṁ pañca vimuttāyatanāni vitthārena. ","html":"{}"},"pe1:139.8":{"pli":"Imāni dve saccāni nirodho ca maggo ca. ","html":"{}</p>"},"pe1:140.1":{"pli":"Imāni sādhāraṇāni suttāni. ","html":"<p>{}"},"pe1:140.2":{"pli":"Imehi sādhāraṇehi suttehi yathānikkhittehi paṭivedhato ca lakkhaṇato ca otāretvā aññāni suttāni niddisitabbāni aparihāyantena. ","html":"{}"},"pe1:140.3":{"pli":"Gāthāhi gāthā anuminitabbā, byākaraṇehi byākaraṇaṁ. ","html":"{}"},"pe1:140.4":{"pli":"Ime ca sādhāraṇā dasa parivaḍḍhakā eko ca catukko niddeso sādhāraṇo. ","html":"{}"},"pe1:140.5":{"pli":"Ayañca pakiṇṇakaniddeso. ","html":"{}"},"pe1:140.6":{"pli":"Ekaṁ pañca cha ca savekadeso sabbaṁ. ","html":"{}"},"pe1:140.7":{"pli":"Ime dve parivajjanā purimakā ca dasa. ","html":"{}"},"pe1:140.8":{"pli":"Ime dvādasa parivaḍḍhakā saccāni. ","html":"{}"},"pe1:140.9":{"pli":"Ettāvatā sabbaṁ suttaṁ natthi, taṁ byākaraṇaṁ vā gāthā viya. ","html":"{}"},"pe1:140.10":{"pli":"Imehi dvādasahi parivaḍḍhakehi na otarituṁ appamattena pariyesitvā niddisitabbā. ","html":"{}</p>"},"pe1:141.1":{"pli":"Tatthāyaṁ saṅkhepo. ","html":"<p>{}"},"pe1:141.2":{"pli":"Sabbaṁ dukkhaṁ sattahi padehi samosaraṇaṁ gacchati. ","html":"{}"},"pe1:141.3":{"pli":"Katarehi sattahi? ","html":"{}"},"pe1:141.4":{"pli":"Appiyasampayogo ca piyavippayogo ca, imehi dvīhi padehi sabbaṁ dukkhaṁ niddisitabbaṁ. ","html":"{}"},"pe1:141.5":{"pli":"Tassa dve nissayā—","html":"{}"},"pe1:141.6":{"pli":"kāyo ca cittañca. ","html":"{}"},"pe1:141.7":{"pli":"Tena vuccati “kāyikaṁ dukkhaṁ cetasikañce”ti, natthi taṁ dukkhaṁ na kāyikaṁ vā na cetasikaṁ, sabbaṁ dukkhaṁ dvīhi dukkhehi niddisitabbaṁ kāyikena ca cetasikena ca. ","html":"{}"},"pe1:141.8":{"pli":"Tīhi dukkhatāhi saṅgahitaṁ dukkhadukkhatāya saṅkhāradukkhatāya vipariṇāmadukkhatāya. ","html":"{}"},"pe1:141.9":{"pli":"Iti taṁ sabbaṁ dukkhaṁ tīhi dukkhatāhi saṅgahitaṁ. ","html":"{}"},"pe1:141.10":{"pli":"Iti idañca dukkhaṁ tividhaṁ. ","html":"{}"},"pe1:141.11":{"pli":"Duvidhaṁ dukkhaṁ kāyikañca cetasikañca. ","html":"{}"},"pe1:141.12":{"pli":"Duvidhaṁ appiyasampayogo ca piyavippayogo ca. ","html":"{}"},"pe1:141.13":{"pli":"Idaṁ sattavidhaṁ dukkhaṁ. ","html":"{}</p>"},"pe1:142.1":{"pli":"Tattha tividho samudayo acatuttho apañcamo. ","html":"<p>{}"},"pe1:142.2":{"pli":"Katamo tividho? ","html":"{}"},"pe1:142.3":{"pli":"Taṇhā ca diṭṭhi ca kammaṁ. ","html":"{}"},"pe1:142.4":{"pli":"Tattha taṇhā ca bhavasamudayo kammaṁ. ","html":"{}"},"pe1:142.5":{"pli":"Tathā nibbattassa hīnapaṇītatā, ayaṁ samudayo. ","html":"{}"},"pe1:142.6":{"pli":"Iti yāpi bhavagatīsu hīnatā ca paṇītatā ca, yāpi tīhi dukkhatāhi saṅgahitā, yopi dvīhi mūlehi samudānīto avijjāya nivutassa bhavataṇhāsaṁyuttassa saviññāṇako kāyo, sopi tīhi dukkhatāhi saṅgahito. ","html":"{}</p>"},"pe1:143.1":{"pli":"Tathā vipallāsato diṭṭhi āgantabbā. ","html":"<p>{}"},"pe1:143.2":{"pli":"Sā sattavidhā niddisitabbā. ","html":"{}"},"pe1:143.3":{"pli":"Eko vipallāso tīṇi niddisīyati, cattāri vipallāsavatthūni. ","html":"{}"},"pe1:143.4":{"pli":"Tattha katamo eko vipallāso? ","html":"{}"},"pe1:143.5":{"pli":"Yo viparītaggāho paṭikkhepena, otaraṇaṁ yathā “anicce niccam”iti viparītaṁ gaṇhāti. ","html":"{}"},"pe1:143.6":{"pli":"Evaṁ cattāro vipallāsā. ","html":"{}"},"pe1:143.7":{"pli":"Ayameko vipallāsīyati saññā cittaṁ diṭṭhi. ","html":"{}"},"pe1:143.8":{"pli":"Katamāni cattāri vipallāsavatthūni? ","html":"{}"},"pe1:143.9":{"pli":"Kāyo vedanā cittaṁ dhammā. ","html":"{}"},"pe1:143.10":{"pli":"Evaṁ vipallāsagatassa akusalañca pavaḍḍheti. ","html":"{}"},"pe1:143.11":{"pli":"Tattha saññāvipallāso dosaṁ akusalamūlaṁ pavaḍḍheti. ","html":"{}"},"pe1:143.12":{"pli":"Cittavipallāso lobhaṁ akusalamūlaṁ pavaḍḍheti. ","html":"{}"},"pe1:143.13":{"pli":"Diṭṭhivipallāso mohaṁ akusalamūlaṁ pavaḍḍheti. ","html":"{}"},"pe1:143.14":{"pli":"Tattha dosassa akusalamūlassa tīṇi micchattāni phalaṁ—","html":"{}"},"pe1:143.15":{"pli":"micchāvācā micchākammanto micchāājīvo; ","html":"{}"},"pe1:143.16":{"pli":"lobhassa akusalamūlassa tīṇi micchattāni phalaṁ—","html":"{}"},"pe1:143.17":{"pli":"micchāsaṅkappo micchāvāyāmo micchāsamādhi; ","html":"{}"},"pe1:143.18":{"pli":"mohassa akusalamūlassa dve micchattāni phalaṁ—","html":"{}"},"pe1:143.19":{"pli":"micchādiṭṭhi ca micchāsati ca. ","html":"{}"},"pe1:143.20":{"pli":"Evaṁ akusalaṁ sahetu sappaccayaṁ vipallāsā ca paccayo, akusalamūlāni sahetū eteyeva paṭipakkhena anūnā anadhikā dvīhi paccayehi niddisitabbā. ","html":"{}"},"pe1:143.21":{"pli":"Nirodhe ca magge ca vipallāsamupādāya parato paṭipakkhena catasso. ","html":"{}</p>"},"pe1:144.1":{"pli":"Tatthimā uddānagāthā ","html":"<p class='uddana-intro'>{}</p>"},"pe1:145.1":{"pli":"Avijjāya nivuto loko, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"pe1:145.2":{"pli":"cittaṁ saṁyojanampi; ","html":"<span class='verse-line'>{}</span>"},"pe1:145.3":{"pli":"Sā pacchinnabhavataṇhā, ","html":"<span class='verse-line'>{}</span>"},"pe1:145.4":{"pli":"dvemā ceva vimuttiyo. ","html":"<span class='verse-line'>{}</span></p>"},"pe1:146.1":{"pli":"Kumbhūpamaṁ kāyamimaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pe1:146.2":{"pli":"Yaṁ na tumhākaṁ taṁ pajaha; ","html":"<span class='verse-line'>{}</span>"},"pe1:146.3":{"pli":"Ye keci sokaparidevā, ","html":"<span class='verse-line'>{}</span>"},"pe1:146.4":{"pli":"Timbaruko ca sayaṅkataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pe1:147.1":{"pli":"Dukkhaṁ diṭṭhi ca uppannaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pe1:147.2":{"pli":"yañca gopālakopamaṁ; ","html":"<span class='verse-line'>{}</span>"},"pe1:147.3":{"pli":"Sati kāyagatā māhu, ","html":"<span class='verse-line'>{}</span>"},"pe1:147.4":{"pli":"samatho ca vipassanā. ","html":"<span class='verse-line'>{}</span></p>"},"pe1:148.1":{"pli":"Āsā pihā ca abhinandanā ca, ","html":"<p><span class='verse-line'>{}</span>"},"pe1:148.2":{"pli":"Catunnamananubodhanā; ","html":"<span class='verse-line'>{}</span>"},"pe1:148.3":{"pli":"Yāni sotāni lokasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"pe1:148.4":{"pli":"Daḷhaṁ nemiyānākāro. ","html":"<span class='verse-line'>{}</span></p>"},"pe1:149.1":{"pli":"Yaṁ nissitassa calitaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pe1:149.2":{"pli":"Anupaṭṭhitakāyagatāsati; ","html":"<span class='verse-line'>{}</span>"},"pe1:149.3":{"pli":"Sayaṁ katena saccena, ","html":"<span class='verse-line'>{}</span>"},"pe1:149.4":{"pli":"Vimuttāyatanehi ca. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pe1:150.1":{"pli":"Peṭakopadese mahākaccāyanena bhāsite paṭhamabhūmi ariyasaccappakāsanā nāma taṁ jīvatā bhagavatā mādisena samuddanena tathāgatenāti. ","html":"<p class='endsutta'>{}</p></article>"}}}