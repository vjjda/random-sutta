{"tha-ap536":{"tha-ap536:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap536'><header><ul><li class='division'>{}</li>"},"tha-ap536:0.2":{"pli":"Kaccāyanavagga ","html":"<li>{}</li></ul>"},"tha-ap536:0.3":{"pli":"Dabbamallaputtattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap536:1.1":{"pli":"“Padumuttaro nāma jino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap536:1.2":{"pli":"sabbalokavidū muni; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:1.3":{"pli":"Ito satasahassamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:1.4":{"pli":"kappe uppajji cakkhumā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:2.1":{"pli":"Ovādako viññāpako, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:2.2":{"pli":"tārako sabbapāṇinaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:2.3":{"pli":"Desanākusalo buddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:2.4":{"pli":"tāresi janataṁ bahuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:3.1":{"pli":"Anukampako kāruṇiko, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:3.2":{"pli":"hitesī sabbapāṇinaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:3.3":{"pli":"Sampatte titthiye sabbe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:3.4":{"pli":"pañcasīle patiṭṭhapi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:4.1":{"pli":"Evaṁ nirākulaṁ āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:4.2":{"pli":"suññataṁ titthiyehi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:4.3":{"pli":"Vicittaṁ arahantehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:4.4":{"pli":"vasībhūtehi tādibhi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:5.1":{"pli":"Ratanānaṭṭhapaññāsaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:5.2":{"pli":"uggato so mahāmuni; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:5.3":{"pli":"Kañcanagghiyasaṅkāso, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:5.4":{"pli":"bāttiṁsavaralakkhaṇo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:6.1":{"pli":"Vassasatasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:6.2":{"pli":"āyu vijjati tāvade; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:6.3":{"pli":"Tāvatā tiṭṭhamāno so, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:6.4":{"pli":"tāresi janataṁ bahuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:7.1":{"pli":"Tadāhaṁ haṁsavatiyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:7.2":{"pli":"seṭṭhiputto mahāyaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:7.3":{"pli":"Upetvā lokapajjotaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:7.4":{"pli":"assosiṁ dhammadesanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:8.1":{"pli":"Senāsanāni bhikkhūnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:8.2":{"pli":"paññāpentaṁ sasāvakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:8.3":{"pli":"Kittayantassa vacanaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:8.4":{"pli":"suṇitvā mudito ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:9.1":{"pli":"Adhikāraṁ sasaṅghassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:9.2":{"pli":"katvā tassa mahesino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:9.3":{"pli":"Nipacca sirasā pāde, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:9.4":{"pli":"taṁ ṭhānamabhipatthayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:10.1":{"pli":"Tadāha sa mahāvīro, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:10.2":{"pli":"mama kammaṁ pakittayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:10.3":{"pli":"‘Yo sasaṅghamabhojesi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:10.4":{"pli":"sattāhaṁ lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:11.1":{"pli":"Soyaṁ kamalapattakkho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:11.2":{"pli":"sīhaṁso kanakattaco; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:11.3":{"pli":"Mama pādamūle nipati, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:11.4":{"pli":"patthayaṁ ṭhānamuttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:12.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:12.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:12.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:12.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:13.1":{"pli":"Sāvako tassa buddhassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:13.2":{"pli":"dabbo nāmena vissuto; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:13.3":{"pli":"Senāsanapaññāpako, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:13.4":{"pli":"aggo hessatiyaṁ tadā’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:14.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:14.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:14.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:14.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:15.1":{"pli":"Satānaṁ tīṇikkhattuñca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:15.2":{"pli":"devarajjamakārayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:15.3":{"pli":"Satānaṁ pañcakkhattuñca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:15.4":{"pli":"cakkavattī ahosahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:16.1":{"pli":"Padesarajjaṁ vipulaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:16.2":{"pli":"gaṇanāto asaṅkhiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:16.3":{"pli":"Sabbattha sukhito āsiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:16.4":{"pli":"tassa kammassa vāhasā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:17.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:17.2":{"pli":"vipassī nāma nāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:17.3":{"pli":"Uppajji cārudassano, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:17.4":{"pli":"sabbadhammavipassako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:18.1":{"pli":"Duṭṭhacitto upavadiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:18.2":{"pli":"sāvakaṁ tassa tādino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:18.3":{"pli":"Sabbāsavaparikkhīṇaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:18.4":{"pli":"suddhoti ca vijāniya. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:19.1":{"pli":"Tasseva naravīrassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:19.2":{"pli":"sāvakānaṁ mahesinaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:19.3":{"pli":"Salākañca gahetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:19.4":{"pli":"khīrodanamadāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:20.1":{"pli":"Imamhi bhaddake kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:20.2":{"pli":"brahmabandhu mahāyaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:20.3":{"pli":"Kassapo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:20.4":{"pli":"uppajji vadataṁ varo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:21.1":{"pli":"Sāsanaṁ jotayitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:21.2":{"pli":"abhibhuyya kutitthiye; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:21.3":{"pli":"Vineyye vinayitvāva, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:21.4":{"pli":"nibbuto so sasāvako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:22.1":{"pli":"Sasisse nibbute nāthe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:22.2":{"pli":"atthamentamhi sāsane; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:22.3":{"pli":"Devā kandiṁsu saṁviggā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:22.4":{"pli":"muttakesā rudammukhā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:23.1":{"pli":"‘Nibbāyissati dhammakkho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:23.2":{"pli":"na passissāma subbate; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:23.3":{"pli":"Na suṇissāma saddhammaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:23.4":{"pli":"aho no appapuññatā’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:24.1":{"pli":"Tadāyaṁ pathavī sabbā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:24.2":{"pli":"acalā sā calācalā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:24.3":{"pli":"Sāgaro ca sasokova, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:24.4":{"pli":"vinadī karuṇaṁ giraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:25.1":{"pli":"Catuddisā dundubhiyo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:25.2":{"pli":"nādayiṁsu amānusā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:25.3":{"pli":"Samantato asaniyo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:25.4":{"pli":"phaliṁsu ca bhayāvahā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:26.1":{"pli":"Ukkā patiṁsu nabhasā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:26.2":{"pli":"dhūmaketu ca dissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:26.3":{"pli":"Sadhūmā jālavaṭṭā ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:26.4":{"pli":"raviṁsu karuṇaṁ migā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:27.1":{"pli":"Uppāde dāruṇe disvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:27.2":{"pli":"sāsanatthaṅgasūcake; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:27.3":{"pli":"Saṁviggā bhikkhavo satta, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:27.4":{"pli":"cintayimha mayaṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:28.1":{"pli":"‘Sāsanena vināmhākaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:28.2":{"pli":"jīvitena alaṁ mayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:28.3":{"pli":"Pavisitvā mahāraññaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:28.4":{"pli":"yuñjāma jinasāsanaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:29.1":{"pli":"Addasamha tadāraññe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:29.2":{"pli":"ubbiddhaṁ selamuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:29.3":{"pli":"Nisseṇiyā tamāruyha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:29.4":{"pli":"nisseṇiṁ pātayimhase. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:30.1":{"pli":"Tadā ovadi no thero, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:30.2":{"pli":"‘buddhuppādo sudullabho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:30.3":{"pli":"Saddhātidullabhā laddhā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:30.4":{"pli":"thokaṁ sesañca sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:31.1":{"pli":"Nipatanti khaṇātītā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:31.2":{"pli":"anante dukkhasāgare; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:31.3":{"pli":"Tasmā payogo kattabbo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:31.4":{"pli":"yāva ṭhāti mune mataṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:32.1":{"pli":"Arahā āsi so thero, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:32.2":{"pli":"anāgāmī tadānugo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:32.3":{"pli":"Susīlā itare yuttā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:32.4":{"pli":"devalokaṁ agamhase. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:33.1":{"pli":"Nibbuto tiṇṇasaṁsāro, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:33.2":{"pli":"suddhāvāse ca ekako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:33.3":{"pli":"Ahañca pakkusāti ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:33.4":{"pli":"sabhiyo bāhiyo tathā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:34.1":{"pli":"Kumārakassapo ceva, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:34.2":{"pli":"tattha tatthūpagā mayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:34.3":{"pli":"Saṁsārabandhanā muttā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:34.4":{"pli":"gotamenānukampitā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:35.1":{"pli":"Mallesu kusinārāyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:35.2":{"pli":"jāto gabbheva me sato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:35.3":{"pli":"Mātā matā citāruḷhā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:35.4":{"pli":"tato nippatito ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:36.1":{"pli":"Patito dabbapuñjamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:36.2":{"pli":"tato dabboti vissuto; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:36.3":{"pli":"Brahmacārībalenāhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:36.4":{"pli":"vimutto sattavassiko. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:37.1":{"pli":"Khīrodanabalenāhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:37.2":{"pli":"pañcahaṅgehupāgato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:37.3":{"pli":"Khīṇāsavopavādena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:37.4":{"pli":"pāpehi bahucodito. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:38.1":{"pli":"Ubho puññañca pāpañca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:38.2":{"pli":"vītivattomhi dānihaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:38.3":{"pli":"Patvāna paramaṁ santiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:38.4":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:39.1":{"pli":"Senāsanaṁ paññāpayiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:39.2":{"pli":"hāsayitvāna subbate; ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:39.3":{"pli":"Jino tasmiṁ guṇe tuṭṭho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:39.4":{"pli":"etadagge ṭhapesi maṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:40.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:40.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:40.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:41.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:41.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:41.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap536:42.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap536:42.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap536:42.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap536:43.1":{"pli":"Itthaṁ sudaṁ āyasmā dabbamallaputto thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap536:44.1":{"pli":"Dabbamallaputtattherassāpadānaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap537":{"tha-ap537:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap537'><header><ul><li class='division'>{}</li>"},"tha-ap537:0.2":{"pli":"Kaccāyanavagga ","html":"<li>{}</li></ul>"},"tha-ap537:0.3":{"pli":"Kumārakassapattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap537:1.1":{"pli":"“Ito satasahassamhi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap537:1.2":{"pli":"kappe uppajji nāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:1.3":{"pli":"Sabbalokahito vīro, ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:1.4":{"pli":"padumuttaranāmako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap537:2.1":{"pli":"Tadāhaṁ brāhmaṇo hutvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap537:2.2":{"pli":"vissuto vedapāragū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:2.3":{"pli":"Divāvihāraṁ vicaraṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:2.4":{"pli":"addasaṁ lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap537:3.1":{"pli":"Catusaccaṁ pakāsentaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap537:3.2":{"pli":"bodhayantaṁ sadevakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:3.3":{"pli":"Vicittakathikānaggaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:3.4":{"pli":"vaṇṇayantaṁ mahājane. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap537:4.1":{"pli":"Tadā muditacittohaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap537:4.2":{"pli":"nimantetvā tathāgataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:4.3":{"pli":"Nānārattehi vatthehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:4.4":{"pli":"alaṅkaritvāna maṇḍapaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap537:5.1":{"pli":"Nānāratanapajjotaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap537:5.2":{"pli":"sasaṅghaṁ bhojayiṁ tahiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:5.3":{"pli":"Bhojayitvāna sattāhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:5.4":{"pli":"nānaggarasabhojanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap537:6.1":{"pli":"Nānācittehi pupphehi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap537:6.2":{"pli":"pūjayitvā sasāvakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:6.3":{"pli":"Nipacca pādamūlamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:6.4":{"pli":"taṁ ṭhānaṁ patthayiṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap537:7.1":{"pli":"Tadā munivaro āha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap537:7.2":{"pli":"karuṇekarasāsayo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:7.3":{"pli":"‘Passathetaṁ dijavaraṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:7.4":{"pli":"padumānanalocanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap537:8.1":{"pli":"Pītipāmojjabahulaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap537:8.2":{"pli":"samuggatatanūruhaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:8.3":{"pli":"Hāsamhitavisālakkhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:8.4":{"pli":"mama sāsanalālasaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap537:9.1":{"pli":"Patitaṁ pādamūle me, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap537:9.2":{"pli":"ekāvatthasumānasaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:9.3":{"pli":"Esa pattheti taṁ ṭhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:9.4":{"pli":"vicittakathikattanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap537:10.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap537:10.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:10.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:10.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap537:11.1":{"pli":"Tassa dhammesu dāyādo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap537:11.2":{"pli":"oraso dhammanimmito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:11.3":{"pli":"Kumārakassapo nāma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:11.4":{"pli":"hessati satthu sāvako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap537:12.1":{"pli":"Vicittapupphadussānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap537:12.2":{"pli":"ratanānañca vāhasā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:12.3":{"pli":"Vicittakathikānaṁ so, ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:12.4":{"pli":"aggataṁ pāpuṇissati’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap537:13.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap537:13.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:13.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:13.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap537:14.1":{"pli":"Paribbhamaṁ bhavābhave, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap537:14.2":{"pli":"raṅgamajjhe yathā naṭo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:14.3":{"pli":"Sākhamigatrajo hutvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:14.4":{"pli":"migiyā kucchimokkamiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap537:15.1":{"pli":"Tadā mayi kucchigate, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap537:15.2":{"pli":"vajjhavāro upaṭṭhito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:15.3":{"pli":"Sākhena cattā me mātā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:15.4":{"pli":"nigrodhaṁ saraṇaṁ gatā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap537:16.1":{"pli":"Tena sā migarājena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap537:16.2":{"pli":"maraṇā parimocitā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:16.3":{"pli":"Pariccajitvā sapāṇaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:16.4":{"pli":"mamevaṁ ovadī tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap537:17.1":{"pli":"‘Nigrodhameva seveyya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap537:17.2":{"pli":"na sākhamupasaṁvase; ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:17.3":{"pli":"Nigrodhasmiṁ mataṁ seyyo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:17.4":{"pli":"yañce sākhamhi jīvitaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap537:18.1":{"pli":"Tenānusiṭṭhā migayūthapena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap537:18.2":{"pli":"Ahañca mātā ca tathetare ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:18.3":{"pli":"Āgamma rammaṁ tusitādhivāsaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:18.4":{"pli":"Gatā pavāsaṁ sagharaṁ yatheva. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap537:19.1":{"pli":"Puno kassapavīrassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap537:19.2":{"pli":"atthamentamhi sāsane; ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:19.3":{"pli":"Āruyha selasikharaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:19.4":{"pli":"yuñjitvā jinasāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap537:20.1":{"pli":"Idānāhaṁ rājagahe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap537:20.2":{"pli":"jāto seṭṭhikule ahuṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:20.3":{"pli":"Āpannasattā me mātā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:20.4":{"pli":"pabbaji anagāriyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap537:21.1":{"pli":"Sagabbhaṁ taṁ viditvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap537:21.2":{"pli":"devadattamupānayuṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:21.3":{"pli":"So avoca ‘vināsetha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:21.4":{"pli":"pāpikaṁ bhikkhuniṁ imaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap537:22.1":{"pli":"Idānipi munindena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap537:22.2":{"pli":"jinena anukampitā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:22.3":{"pli":"Sukhinī ajanī mayhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:22.4":{"pli":"mātā bhikkhunupassaye. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap537:23.1":{"pli":"Taṁ viditvā mahīpālo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap537:23.2":{"pli":"kosalo maṁ aposayi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:23.3":{"pli":"Kumāraparihārena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:23.4":{"pli":"nāmenāhañca kassapo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap537:24.1":{"pli":"Mahākassapamāgamma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap537:24.2":{"pli":"ahaṁ kumārakassapo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:24.3":{"pli":"Vammikasadisaṁ kāyaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:24.4":{"pli":"sutvā buddhena desitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap537:25.1":{"pli":"Tato cittaṁ vimucci me, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap537:25.2":{"pli":"anupādāya sabbaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:25.3":{"pli":"Pāyāsiṁ damayitvāhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:25.4":{"pli":"etadaggamapāpuṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap537:26.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap537:26.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:26.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap537:27.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap537:27.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:27.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap537:28.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap537:28.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap537:28.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap537:29.1":{"pli":"Itthaṁ sudaṁ āyasmā kumārakassapo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap537:30.1":{"pli":"Kumārakassapattherassāpadānaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}<br>"},"tha-ap537:30.2":{"pli":"Catuvīsatimaṁ bhāṇavāraṁ. ","html":"{}</p></article>"}},"tha-ap538":{"tha-ap538:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap538'><header><ul><li class='division'>{}</li>"},"tha-ap538:0.2":{"pli":"Kaccāyanavagga ","html":"<li>{}</li></ul>"},"tha-ap538:0.3":{"pli":"Bāhiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap538:1.1":{"pli":"“Ito satasahassamhi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap538:1.2":{"pli":"kappe uppajji nāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:1.3":{"pli":"Mahappabho tilokaggo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:1.4":{"pli":"nāmena padumuttaro. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:2.1":{"pli":"Khippābhiññassa bhikkhussa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:2.2":{"pli":"guṇaṁ kittayato mune; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:2.3":{"pli":"Sutvā udaggacittohaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:2.4":{"pli":"kāraṁ katvā mahesino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:3.1":{"pli":"Datvā sattāhikaṁ dānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:3.2":{"pli":"sasissassa mune ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:3.3":{"pli":"Abhivādiya sambuddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:3.4":{"pli":"taṁ ṭhānaṁ patthayiṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:4.1":{"pli":"Tato maṁ byākari buddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:4.2":{"pli":"‘etaṁ passatha brāhmaṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:4.3":{"pli":"Patitaṁ pādamūle me, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:4.4":{"pli":"cariyaṁ paccavekkhaṇaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:5.1":{"pli":"Hemayaññopacitaṅgaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:5.2":{"pli":"avadātatanuttacaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:5.3":{"pli":"Palambabimbatamboṭṭhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:5.4":{"pli":"setatiṇhasamaṁ dijaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:6.1":{"pli":"Guṇathāmabahutaraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:6.2":{"pli":"samuggatatanūruhaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:6.3":{"pli":"Guṇoghāyatanībhūtaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:6.4":{"pli":"pītisamphullitānanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:7.1":{"pli":"Eso patthayate ṭhānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:7.2":{"pli":"khippābhiññassa bhikkhuno; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:7.3":{"pli":"Anāgate mahāvīro, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:7.4":{"pli":"gotamo nāma hessati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:8.1":{"pli":"Tassa dhammesu dāyādo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:8.2":{"pli":"oraso dhammanimmito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:8.3":{"pli":"Bāhiyo nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:8.4":{"pli":"hessati satthu sāvako’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:9.1":{"pli":"Tadā hi tuṭṭho vuṭṭhāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:9.2":{"pli":"yāvajīvaṁ mahāmune; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:9.3":{"pli":"Kāraṁ katvā cuto saggaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:9.4":{"pli":"agaṁ sabhavanaṁ yathā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:10.1":{"pli":"Devabhūto manusso vā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:10.2":{"pli":"sukhito tassa kammuno; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:10.3":{"pli":"Vāhasā saṁsaritvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:10.4":{"pli":"sampattimanubhomahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:11.1":{"pli":"Puna kassapavīrassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:11.2":{"pli":"atthamentamhi sāsane; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:11.3":{"pli":"Āruyha selasikharaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:11.4":{"pli":"yuñjitvā jinasāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:12.1":{"pli":"Visuddhasīlo sappañño, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:12.2":{"pli":"jinasāsanakārako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:12.3":{"pli":"Tato cutā pañca janā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:12.4":{"pli":"devalokaṁ agamhase. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:13.1":{"pli":"Tatohaṁ bāhiyo jāto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:13.2":{"pli":"bhārukacche puruttame; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:13.3":{"pli":"Tato nāvāya pakkhando, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:13.4":{"pli":"sāgaraṁ appasiddhiyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:14.1":{"pli":"Tato nāvā abhijjittha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:14.2":{"pli":"gantvāna katipāhakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:14.3":{"pli":"Tadā bhīsanake ghore, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:14.4":{"pli":"patito makarākare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:15.1":{"pli":"Tadāhaṁ vāyamitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:15.2":{"pli":"santaritvā mahodadhiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:15.3":{"pli":"Suppārapaṭṭanavaraṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:15.4":{"pli":"sampatto mandavedhito. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:16.1":{"pli":"Dārucīraṁ nivāsetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:16.2":{"pli":"gāmaṁ piṇḍāya pāvisiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:16.3":{"pli":"Tadāha so jano tuṭṭho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:16.4":{"pli":"‘arahāyamidhāgato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:17.1":{"pli":"Imaṁ annena pānena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:17.2":{"pli":"vatthena sayanena ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:17.3":{"pli":"Bhesajjena ca sakkatvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:17.4":{"pli":"hessāma sukhitā mayaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:18.1":{"pli":"Paccayānaṁ tadā lābhī, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:18.2":{"pli":"tehi sakkatapūjito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:18.3":{"pli":"Arahāhanti saṅkappaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:18.4":{"pli":"uppādesiṁ ayoniso. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:19.1":{"pli":"Tato me cittamaññāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:19.2":{"pli":"codayī pubbadevatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:19.3":{"pli":"‘Na tvaṁ upāyamaggaññū, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:19.4":{"pli":"kuto tvaṁ arahā bhave’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:20.1":{"pli":"Codito tāya saṁviggo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:20.2":{"pli":"tadāhaṁ paripucchi taṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:20.3":{"pli":"‘Ke vā ete kuhiṁ loke, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:20.4":{"pli":"arahanto naruttamā’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:21.1":{"pli":"‘Sāvatthiyaṁ kosalamandire jino, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:21.2":{"pli":"Pahūtapañño varabhūrimedhaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:21.3":{"pli":"So sakyaputto arahā anāsavo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:21.4":{"pli":"Deseti dhammaṁ arahattapattiyā’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:22.1":{"pli":"Tadassa sutvā vacanaṁ supīṇito, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:22.2":{"pli":"Nidhiṁva laddhā kapaṇoti vimhito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:22.3":{"pli":"Udaggacitto arahattamuttamaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:22.4":{"pli":"Sudassanaṁ daṭṭhumanantagocaraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:23.1":{"pli":"Tadā tato nikkhamitvāna ‘satthuno, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:23.2":{"pli":"Sadā jinaṁ passāmi vimalānanaṁ’; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:23.3":{"pli":"Upecca rammaṁ vijitavhayaṁ vanaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:23.4":{"pli":"Dije apucchiṁ ‘kuhiṁ lokanandano’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:24.1":{"pli":"‘Tato avocuṁ naradevavandito, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:24.2":{"pli":"Puraṁ paviṭṭho asanesanāya so; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:24.3":{"pli":"Sasova khippaṁ munidassanussuko, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:24.4":{"pli":"Upecca vandāhi tamaggapuggalaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:25.1":{"pli":"Tatohaṁ tuvaṭaṁ gantvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:25.2":{"pli":"sāvatthiṁ puramuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:25.3":{"pli":"Vicarantaṁ tamaddakkhiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:25.4":{"pli":"piṇḍatthaṁ apihāgidhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:26.1":{"pli":"Pattapāṇiṁ alolakkhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:26.2":{"pli":"pācayantaṁ pītākaraṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:26.3":{"pli":"Sirīnilayasaṅkāsaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:26.4":{"pli":"ravidittiharānanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:27.1":{"pli":"Taṁ samecca nipaccāhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:27.2":{"pli":"idaṁ vacanamabraviṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:27.3":{"pli":"‘Kupathe vippanaṭṭhassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:27.4":{"pli":"saraṇaṁ hohi gotama’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:28.1":{"pli":"‘Pāṇasantāraṇatthāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:28.2":{"pli":"piṇḍāya vicarāmahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:28.3":{"pli":"Na te dhammakathākālo’, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:28.4":{"pli":"iccāha munisattamo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:29.1":{"pli":"Tadā punappunaṁ buddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:29.2":{"pli":"āyāciṁ dhammalālaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:29.3":{"pli":"Yo me dhammamadesesi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:29.4":{"pli":"gambhīraṁ suññataṁ padaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:30.1":{"pli":"Tassa dhammaṁ suṇitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:30.2":{"pli":"pāpuṇiṁ āsavakkhayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:30.3":{"pli":"Parikkhīṇāyuko santo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:30.4":{"pli":"aho satthānukampako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:31.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:31.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:31.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:32.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:32.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:32.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:33.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:33.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:33.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:34.1":{"pli":"Evaṁ thero viyākāsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:34.2":{"pli":"bāhiyo dārucīriyo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:34.3":{"pli":"Saṅkārakūṭe patito, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:34.4":{"pli":"bhūtāviṭṭhāya gāviyā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:35.1":{"pli":"Attano pubbacariyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:35.2":{"pli":"kittayitvā mahāmati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:35.3":{"pli":"Parinibbāyi so thero, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:35.4":{"pli":"sāvatthiyaṁ puruttame. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:36.1":{"pli":"Nagarā nikkhamanto taṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:36.2":{"pli":"disvāna isisattamo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:36.3":{"pli":"Dārucīradharaṁ dhīraṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:36.4":{"pli":"bāhiyaṁ bāhitāgamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:37.1":{"pli":"Bhūmiyaṁ patitaṁ dantaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:37.2":{"pli":"indaketūva pātitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:37.3":{"pli":"Gatāyuṁ sukkhakilesaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:37.4":{"pli":"jinasāsanakārakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:38.1":{"pli":"Tato āmantayī satthā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:38.2":{"pli":"sāvake sāsane rate; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:38.3":{"pli":"‘Gaṇhatha netvā jhāpetha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:38.4":{"pli":"tanuṁ sabrahmacārino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:39.1":{"pli":"Thūpaṁ karotha pūjetha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:39.2":{"pli":"nibbuto so mahāmati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:39.3":{"pli":"Khippābhiññānamesaggo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:39.4":{"pli":"sāvako me vacokaro. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:40.1":{"pli":"Sahassamapi ce gāthā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:40.2":{"pli":"anatthapadasañhitā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:40.3":{"pli":"Ekaṁ gāthāpadaṁ seyyo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:40.4":{"pli":"yaṁ sutvā upasammati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:41.1":{"pli":"Yattha āpo ca pathavī, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:41.2":{"pli":"tejo vāyo na gādhati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:41.3":{"pli":"Na tattha sukkā jotanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:41.4":{"pli":"ādicco na pakāsati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:42.1":{"pli":"Na tattha candimā bhāti, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:42.2":{"pli":"tamo tattha na vijjati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:42.3":{"pli":"Yadā ca attanā vedi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:42.4":{"pli":"munimonena brāhmaṇo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap538:43.1":{"pli":"Atha rūpā arūpā ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap538:43.2":{"pli":"sukhadukkhā vimuccati’; ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:43.3":{"pli":"Iccevaṁ abhaṇī nātho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap538:43.4":{"pli":"tilokasaraṇo muni”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap538:44.1":{"pli":"Itthaṁ sudaṁ āyasmā bāhiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap538:45.1":{"pli":"Bāhiyattherassāpadānaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}