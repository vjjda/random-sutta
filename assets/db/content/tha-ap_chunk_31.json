{"tha-ap402":{"tha-ap402:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap402'><header><ul><li class='division'>{}</li>"},"tha-ap402:0.2":{"pli":"Pilindavacchavagga ","html":"<li>{}</li></ul>"},"tha-ap402:0.3":{"pli":"Ajitattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap402:1.1":{"pli":"“Padumuttaro nāma jino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap402:1.2":{"pli":"sabbadhammāna pāragū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:1.3":{"pli":"Ajjhogāhetvā himavantaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:1.4":{"pli":"nisīdi lokanāyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:2.1":{"pli":"Nāhaṁ addakkhiṁ sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:2.2":{"pli":"Napi saddaṁ suṇomahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:2.3":{"pli":"Mama bhakkhaṁ gavesanto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:2.4":{"pli":"Āhiṇḍāmi vane ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:3.1":{"pli":"Tatthaddassāsiṁ sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:3.2":{"pli":"dvattiṁsavaralakkhaṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:3.3":{"pli":"Disvāna vittimāpajjiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:3.4":{"pli":"satto ko nāmayaṁ bhave. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:4.1":{"pli":"Lakkhaṇāni viloketvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:4.2":{"pli":"mama vijjaṁ anussariṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:4.3":{"pli":"Sutañhi metaṁ vuḍḍhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:4.4":{"pli":"paṇḍitānaṁ subhāsitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:5.1":{"pli":"Tesaṁ yathā taṁ vacanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:5.2":{"pli":"ayaṁ buddho bhavissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:5.3":{"pli":"Yannūnāhaṁ sakkareyyaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:5.4":{"pli":"gatiṁ me sodhayissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:6.1":{"pli":"Khippaṁ assamamāgantvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:6.2":{"pli":"madhutelaṁ gahiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:6.3":{"pli":"Kolambakaṁ gahetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:6.4":{"pli":"upagacchiṁ vināyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:7.1":{"pli":"Tidaṇḍake gahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:7.2":{"pli":"abbhokāse ṭhapesahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:7.3":{"pli":"Padīpaṁ pajjalitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:7.4":{"pli":"aṭṭhakkhattuṁ avandahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:8.1":{"pli":"Sattarattindivaṁ buddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:8.2":{"pli":"nisīdi purisuttamo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:8.3":{"pli":"Tato ratyā vivasāne, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:8.4":{"pli":"vuṭṭhāsi lokanāyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:9.1":{"pli":"Pasannacitto sumano, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:9.2":{"pli":"sabbarattindivaṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:9.3":{"pli":"Dīpaṁ buddhassa pādāsiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:9.4":{"pli":"pasanno sehi pāṇibhi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:10.1":{"pli":"Sabbe vanā gandhamayā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:10.2":{"pli":"Pabbate gandhamādane; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:10.3":{"pli":"Buddhassa ānubhāvena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:10.4":{"pli":"Āgacchuṁ buddhasantikaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:11.1":{"pli":"Ye keci pupphagandhāse, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:11.2":{"pli":"pupphitā dharaṇīruhā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:11.3":{"pli":"Buddhassa ānubhāvena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:11.4":{"pli":"sabbe sannipatuṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:12.1":{"pli":"Yāvatā himavantamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:12.2":{"pli":"nāgā ca garuḷā ubho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:12.3":{"pli":"Dhammañca sotukāmā te, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:12.4":{"pli":"āgacchuṁ buddhasantikaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:13.1":{"pli":"Devalo nāma samaṇo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:13.2":{"pli":"buddhassa aggasāvako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:13.3":{"pli":"Vasīsatasahassehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:13.4":{"pli":"buddhasantikupāgami. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:14.1":{"pli":"Padumuttaro lokavidū, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:14.2":{"pli":"āhutīnaṁ paṭiggaho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:14.3":{"pli":"Bhikkhusaṅghe nisīditvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:14.4":{"pli":"imā gāthā abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:15.1":{"pli":"‘Yo me dīpaṁ padīpesi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:15.2":{"pli":"pasanno sehi pāṇibhi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:15.3":{"pli":"Tamahaṁ kittayissāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:15.4":{"pli":"suṇātha mama bhāsato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:16.1":{"pli":"Saṭṭhi kappasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:16.2":{"pli":"devaloke ramissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:16.3":{"pli":"Sahassakkhattuṁ rājā ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:16.4":{"pli":"cakkavattī bhavissati. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap402:17.1":{"pli":"Soḷasamaṁ bhāṇavāraṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap402:18.1":{"pli":"Chattiṁsakkhattuṁ devindo, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap402:18.2":{"pli":"devarajjaṁ karissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:18.3":{"pli":"Pathaviyaṁ sattasataṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:18.4":{"pli":"vipulaṁ rajjaṁ karissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:19.1":{"pli":"Padesarajjaṁ vipulaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:19.2":{"pli":"gaṇanāto asaṅkhiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:19.3":{"pli":"Iminā dīpadānena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:19.4":{"pli":"dibbacakkhu bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:20.1":{"pli":"Samantato aṭṭhakosaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:20.2":{"pli":"passissati ayaṁ sadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:20.3":{"pli":"Devalokā cavantassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:20.4":{"pli":"nibbattantassa jantuno. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:21.1":{"pli":"Divā vā yadi vā rattiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:21.2":{"pli":"padīpaṁ dhārayissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:21.3":{"pli":"Jāyamānassa sattassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:21.4":{"pli":"puññakammasamaṅgino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:22.1":{"pli":"Yāvatā nagaraṁ āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:22.2":{"pli":"tāvatā jotayissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:22.3":{"pli":"Upapajjati yaṁ yoniṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:22.4":{"pli":"devattaṁ atha mānusaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:23.1":{"pli":"Asseva dīpadānassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:23.2":{"pli":"aṭṭhadīpaphalena hi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:23.3":{"pli":"Na jayissantimaṁ jantū, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:23.4":{"pli":"dīpadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:24.1":{"pli":"Kappasatasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:24.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:24.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:24.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:25.1":{"pli":"Tassa dhammesu dāyādo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:25.2":{"pli":"oraso dhammanimmito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:25.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:25.4":{"pli":"nibbāyissatināsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:26.1":{"pli":"Tosayitvāna sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:26.2":{"pli":"gotamaṁ sakyapuṅgavaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:26.3":{"pli":"Ajito nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:26.4":{"pli":"hessati satthu sāvako’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:27.1":{"pli":"Saṭṭhi kappasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:27.2":{"pli":"devaloke ramiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:27.3":{"pli":"Tatrāpi me dīpasataṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:27.4":{"pli":"jotate niccakālikaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:28.1":{"pli":"Devaloke manusse vā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:28.2":{"pli":"niddhāvanti pabhā mama; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:28.3":{"pli":"Buddhaseṭṭhaṁ saritvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:28.4":{"pli":"bhiyyo hāsaṁ janesahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:29.1":{"pli":"Tusitāhaṁ cavitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:29.2":{"pli":"okkamiṁ mātukucchiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:29.3":{"pli":"Jāyamānassa santassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:29.4":{"pli":"āloko vipulo ahu. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:30.1":{"pli":"Agārā abhinikkhamma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:30.2":{"pli":"pabbajiṁ anagāriyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:30.3":{"pli":"Bāvariṁ upasaṅkamma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:30.4":{"pli":"sissattaṁ ajjhupāgamiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:31.1":{"pli":"Himavante vasantohaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:31.2":{"pli":"assosiṁ lokanāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:31.3":{"pli":"Uttamatthaṁ gavesanto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:31.4":{"pli":"upagacchiṁ vināyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:32.1":{"pli":"Danto buddho dametāvī, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:32.2":{"pli":"oghatiṇṇo nirūpadhi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:32.3":{"pli":"Nibbānaṁ kathayī buddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:32.4":{"pli":"sabbadukkhappamocanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:33.1":{"pli":"Taṁ me āgamanaṁ siddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:33.2":{"pli":"tositohaṁ mahāmuniṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:33.3":{"pli":"Tisso vijjā anuppattā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:33.4":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:34.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:34.2":{"pli":"yaṁ dīpamadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:34.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:34.4":{"pli":"dīpadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:35.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:35.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:35.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:36.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:36.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:36.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:37.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:37.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:37.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap402:38.1":{"pli":"Itthaṁ sudaṁ āyasmā ajito thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap402:39.1":{"pli":"Ajitattherassāpadānaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap402:39.2":{"pli":"Pilindavacchavaggo cattālīsamo. ","html":"<p class='endsection'>{}</p>"},"tha-ap402:40.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"tha-ap402:41.1":{"pli":"Pilindavaccho selo ca, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"tha-ap402:41.2":{"pli":"sabbakittī madhundado; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:41.3":{"pli":"Kūṭāgārī bākulo ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:41.4":{"pli":"giri saḷalasavhayo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:42.1":{"pli":"Sabbado ajito ceva, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:42.2":{"pli":"gāthāyo gaṇitā iha; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:42.3":{"pli":"Satāni pañca gāthānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:42.4":{"pli":"vīsati ca taduttarīti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap402:43.1":{"pli":"Atha vagguddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"tha-ap402:44.1":{"pli":"Padumārakkhado ceva, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"tha-ap402:44.2":{"pli":"umā gandhodakena ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:44.3":{"pli":"Ekapadma saddasaññī, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:44.4":{"pli":"mandāraṁ bodhivandako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap402:45.1":{"pli":"Avaṭañca pilindi ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap402:45.2":{"pli":"gāthāyo gaṇitā iha; ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:45.3":{"pli":"Catusattati gāthāyo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap402:45.4":{"pli":"ekādasa satāni ca. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap402:46.1":{"pli":"Padumavaggadasakaṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap402:47.1":{"pli":"Catutthasatakaṁ samattaṁ. ","html":"<p class='endsection'>{}</p></article>"}},"tha-ap403":{"tha-ap403:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap403'><header><ul><li class='division'>{}</li>"},"tha-ap403:0.2":{"pli":"Metteyyavagga ","html":"<li>{}</li></ul>"},"tha-ap403:0.3":{"pli":"Tissametteyyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap403:1.1":{"pli":"“Pabbhārakūṭaṁ nissāya, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap403:1.2":{"pli":"sobhito nāma tāpaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:1.3":{"pli":"Pavattaphalaṁ bhuñjitvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:1.4":{"pli":"vasati pabbatantare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap403:2.1":{"pli":"Aggiṁ dāruṁ āharitvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap403:2.2":{"pli":"ujjālesiṁ ahaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:2.3":{"pli":"Uttamatthaṁ gavesanto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:2.4":{"pli":"brahmalokūpapattiyā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap403:3.1":{"pli":"Padumuttaro lokavidū, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap403:3.2":{"pli":"āhutīnaṁ paṭiggaho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:3.3":{"pli":"Mamuddharitukāmo so, ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:3.4":{"pli":"āgacchi mama santike. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap403:4.1":{"pli":"‘Kiṁ karosi mahāpuñña, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap403:4.2":{"pli":"dehi me aggidārukaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:4.3":{"pli":"Ahamaggiṁ paricare, ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:4.4":{"pli":"tato me suddhi hohiti’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap403:5.1":{"pli":"‘Subhaddako tvaṁ manuje, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap403:5.2":{"pli":"devate tvaṁ pajānasi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:5.3":{"pli":"Tuvaṁ aggiṁ paricara, ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:5.4":{"pli":"handa te aggidārukaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap403:6.1":{"pli":"Tato kaṭṭhaṁ gahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap403:6.2":{"pli":"aggiṁ ujjālayī jino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:6.3":{"pli":"Na tattha kaṭṭhaṁ pajjhāyi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:6.4":{"pli":"pāṭiheraṁ mahesino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap403:7.1":{"pli":"‘Na te aggi pajjalati, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap403:7.2":{"pli":"āhutī te na vijjati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:7.3":{"pli":"Niratthakaṁ vataṁ tuyhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:7.4":{"pli":"aggiṁ paricarassu me’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap403:8.1":{"pli":"‘Kīdiso so mahāvīra, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap403:8.2":{"pli":"aggi tava pavuccati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:8.3":{"pli":"Mayhampi kathayassetaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:8.4":{"pli":"ubho paricarāmase’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap403:9.1":{"pli":"‘Hetudhammanirodhāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap403:9.2":{"pli":"kilesasamaṇāya ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:9.3":{"pli":"Issāmacchariyaṁ hitvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:9.4":{"pli":"tayo ete mamāhutī’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap403:10.1":{"pli":"‘Kīdiso tvaṁ mahāvīra, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap403:10.2":{"pli":"kathaṁ gottosi mārisa; ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:10.3":{"pli":"Ācārapaṭipatti te, ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:10.4":{"pli":"bāḷhaṁ kho mama ruccati’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap403:11.1":{"pli":"‘Khattiyamhi kule jāto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap403:11.2":{"pli":"abhiññāpāramiṁ gato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:11.3":{"pli":"Sabbāsavaparikkhīṇo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:11.4":{"pli":"natthi dāni punabbhavo’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap403:12.1":{"pli":"‘Yadi buddhosi sabbaññū, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap403:12.2":{"pli":"pabhaṅkara tamonuda; ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:12.3":{"pli":"Namassissāmi taṁ deva, ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:12.4":{"pli":"dukkhassantakaro tuvaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap403:13.1":{"pli":"Pattharitvājinacammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap403:13.2":{"pli":"nisīdanamadāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:13.3":{"pli":"Nisīda nātha sabbaññu, ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:13.4":{"pli":"upaṭṭhissāmahaṁ tuvaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap403:14.1":{"pli":"Nisīdi bhagavā tattha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap403:14.2":{"pli":"ajinamhi suvitthate; ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:14.3":{"pli":"Nimantayitvā sambuddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:14.4":{"pli":"pabbataṁ agamāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap403:15.1":{"pli":"Khāribhārañca pūretvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap403:15.2":{"pli":"tindukaphalamāhariṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:15.3":{"pli":"Madhunā yojayitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:15.4":{"pli":"phalaṁ buddhassadāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap403:16.1":{"pli":"Mama nijjhāyamānassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap403:16.2":{"pli":"paribhuñji tadā jino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:16.3":{"pli":"Tattha cittaṁ pasādesiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:16.4":{"pli":"pekkhanto lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap403:17.1":{"pli":"Padumuttaro lokavidū, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap403:17.2":{"pli":"āhutīnaṁ paṭiggaho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:17.3":{"pli":"Mamassame nisīditvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:17.4":{"pli":"imā gāthā abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap403:18.1":{"pli":"‘Yo maṁ phalena tappesi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap403:18.2":{"pli":"pasanno sehi pāṇibhi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:18.3":{"pli":"Tamahaṁ kittayissāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:18.4":{"pli":"suṇātha mama bhāsato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap403:19.1":{"pli":"Pañcavīsatikkhattuṁ so, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap403:19.2":{"pli":"devarajjaṁ karissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:19.3":{"pli":"Sahassakkhattuṁ rājā ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:19.4":{"pli":"cakkavattī bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap403:20.1":{"pli":"Tassa saṅkappamaññāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap403:20.2":{"pli":"pubbakammasamaṅgino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:20.3":{"pli":"Annaṁ pānañca vatthañca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:20.4":{"pli":"sayanañca mahārahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap403:21.1":{"pli":"Puññakammena saṁyuttā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap403:21.2":{"pli":"nibbattissanti tāvade; ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:21.3":{"pli":"Sadā pamudito cāyaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:21.4":{"pli":"bhavissati anāmayo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap403:22.1":{"pli":"Upapajjati yaṁ yoniṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap403:22.2":{"pli":"devattaṁ atha mānusaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:22.3":{"pli":"Sabbattha sukhito hutvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:22.4":{"pli":"manussattaṁ gamissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap403:23.1":{"pli":"Ajjhāyako mantadharo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap403:23.2":{"pli":"tiṇṇaṁ vedāna pāragū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:23.3":{"pli":"Sambuddhaṁ upagantvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:23.4":{"pli":"arahā so bhavissati’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap403:24.1":{"pli":"Yato sarāmi attānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap403:24.2":{"pli":"yato pattosmi viññutaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:24.3":{"pli":"Bhoge me ūnatā natthi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:24.4":{"pli":"phaladānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap403:25.1":{"pli":"Varadhammamanuppatto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap403:25.2":{"pli":"rāgadose samūhaniṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:25.3":{"pli":"Sabbāsavaparikkhīṇo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:25.4":{"pli":"natthi dāni punabbhavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap403:26.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap403:26.2":{"pli":"bhavā sabbe samūhatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:26.3":{"pli":"Nāgova bandhanaṁ chetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:26.4":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap403:27.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap403:27.2":{"pli":"mama buddhassa santike; ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:27.3":{"pli":"Tisso vijjā anuppattā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:27.4":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap403:28.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap403:28.2":{"pli":"vimokkhāpi ca aṭṭhime; ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:28.3":{"pli":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap403:28.4":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap403:29.1":{"pli":"Itthaṁ sudaṁ āyasmā tissametteyyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap403:30.1":{"pli":"Tissametteyyattherassāpadānaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap404":{"tha-ap404:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap404'><header><ul><li class='division'>{}</li>"},"tha-ap404:0.2":{"pli":"Metteyyavagga ","html":"<li>{}</li></ul>"},"tha-ap404:0.3":{"pli":"Puṇṇakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap404:1.1":{"pli":"“Pabbhārakūṭaṁ nissāya, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap404:1.2":{"pli":"sayambhū aparājito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap404:1.3":{"pli":"Ābādhiko ca so buddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap404:1.4":{"pli":"vasati pabbatantare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap404:2.1":{"pli":"Mama assamasāmantā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap404:2.2":{"pli":"panādo āsi tāvade; ","html":"<span class='verse-line'>{}</span>"},"tha-ap404:2.3":{"pli":"Buddhe nibbāyamānamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap404:2.4":{"pli":"āloko udapajjatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap404:3.1":{"pli":"Yāvatā vanasaṇḍasmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap404:3.2":{"pli":"acchakokataracchakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap404:3.3":{"pli":"Vāḷā ca kesarī sabbe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap404:3.4":{"pli":"abhigajjiṁsu tāvade. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap404:4.1":{"pli":"Uppātaṁ tamahaṁ disvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap404:4.2":{"pli":"pabbhāraṁ agamāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap404:4.3":{"pli":"Tatthaddassāsiṁ sambuddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap404:4.4":{"pli":"nibbutaṁ aparājitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap404:5.1":{"pli":"Suphullaṁ sālarājaṁva, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap404:5.2":{"pli":"sataraṁsiṁva uggataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap404:5.3":{"pli":"Vītaccikaṁva aṅgāraṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap404:5.4":{"pli":"nibbutaṁ aparājitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap404:6.1":{"pli":"Tiṇaṁ kaṭṭhañca pūretvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap404:6.2":{"pli":"citakaṁ tatthakāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap404:6.3":{"pli":"Citakaṁ sukataṁ katvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap404:6.4":{"pli":"sarīraṁ jhāpayiṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap404:7.1":{"pli":"Sarīraṁ jhāpayitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap404:7.2":{"pli":"gandhatoyaṁ samokiriṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap404:7.3":{"pli":"Antalikkhe ṭhito yakkho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap404:7.4":{"pli":"nāmamaggahi tāvade. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap404:8.1":{"pli":"‘Yaṁ pūritaṁ tayā kiccaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap404:8.2":{"pli":"sayambhussa mahesino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap404:8.3":{"pli":"Puṇṇako nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap404:8.4":{"pli":"sadā hohi tuvaṁ mune’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap404:9.1":{"pli":"Tamhā kāyā cavitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap404:9.2":{"pli":"devalokaṁ agacchahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap404:9.3":{"pli":"Tattha dibbamayo gandho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap404:9.4":{"pli":"antalikkhā pavassati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap404:10.1":{"pli":"Tatrāpi nāmadheyyaṁ me, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap404:10.2":{"pli":"puṇṇakoti ahū tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap404:10.3":{"pli":"Devabhūto manusso vā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap404:10.4":{"pli":"saṅkappaṁ pūrayāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap404:11.1":{"pli":"Idaṁ pacchimakaṁ mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap404:11.2":{"pli":"carimo vattate bhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap404:11.3":{"pli":"Idhāpi puṇṇako nāma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap404:11.4":{"pli":"nāmadheyyaṁ pakāsati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap404:12.1":{"pli":"Tosayitvāna sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap404:12.2":{"pli":"gotamaṁ sakyapuṅgavaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap404:12.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap404:12.4":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap404:13.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap404:13.2":{"pli":"yaṁ kammamakariṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap404:13.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap404:13.4":{"pli":"tanukiccassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap404:14.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap404:14.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap404:14.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap404:15.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap404:15.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap404:15.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap404:16.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap404:16.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap404:16.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap404:17.1":{"pli":"Itthaṁ sudaṁ āyasmā puṇṇako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap404:18.1":{"pli":"Puṇṇakattherassāpadānaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap405":{"tha-ap405:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap405'><header><ul><li class='division'>{}</li>"},"tha-ap405:0.2":{"pli":"Metteyyavagga ","html":"<li>{}</li></ul>"},"tha-ap405:0.3":{"pli":"Mettaguttheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap405:1.1":{"pli":"“Himavantassāvidūre, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap405:1.2":{"pli":"asoko nāma pabbato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:1.3":{"pli":"Tatthāsi assamo mayhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:1.4":{"pli":"vissakammena māpito. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap405:2.1":{"pli":"Sumedho nāma sambuddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap405:2.2":{"pli":"aggo kāruṇiko muni; ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:2.3":{"pli":"Nivāsayitvā pubbaṇhe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:2.4":{"pli":"piṇḍāya me upāgami. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap405:3.1":{"pli":"Upāgataṁ mahāvīraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap405:3.2":{"pli":"sumedhaṁ lokanāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:3.3":{"pli":"Paggayha sugatapattaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:3.4":{"pli":"sappitelaṁ apūrayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap405:4.1":{"pli":"Datvānahaṁ buddhaseṭṭhe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap405:4.2":{"pli":"sumedhe lokanāyake; ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:4.3":{"pli":"Añjaliṁ paggahetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:4.4":{"pli":"bhiyyo hāsaṁ janesahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap405:5.1":{"pli":"Iminā sappidānena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap405:5.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:5.3":{"pli":"Devabhūto manusso vā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:5.4":{"pli":"labhāmi vipulaṁ sukhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap405:6.1":{"pli":"Vinipātaṁ vivajjetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap405:6.2":{"pli":"saṁsarāmi bhavābhave; ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:6.3":{"pli":"Tattha cittaṁ paṇidhitvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:6.4":{"pli":"labhāmi acalaṁ padaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap405:7.1":{"pli":"‘Lābhā tuyhaṁ suladdhaṁ te, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap405:7.2":{"pli":"yaṁ maṁ addakkhi brāhmaṇa; ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:7.3":{"pli":"Mama dassanamāgamma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:7.4":{"pli":"arahattaṁ bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap405:8.1":{"pli":"Vissattho hohi mā bhāyi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap405:8.2":{"pli":"adhigantvā mahāyasaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:8.3":{"pli":"Mamañhi sappiṁ datvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:8.4":{"pli":"parimokkhasi jātiyā’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap405:9.1":{"pli":"Iminā sappidānena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap405:9.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:9.3":{"pli":"Devabhūto manusso vā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:9.4":{"pli":"labhase vipulaṁ sukhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap405:10.1":{"pli":"Iminā sappidānena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap405:10.2":{"pli":"mettacittavatāya ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:10.3":{"pli":"Aṭṭhārase kappasate, ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:10.4":{"pli":"devaloke ramissasi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap405:11.1":{"pli":"Aṭṭhatiṁsatikkhattuñca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap405:11.2":{"pli":"devarājā bhavissasi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:11.3":{"pli":"Padesarajjaṁ vipulaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:11.4":{"pli":"gaṇanāto asaṅkhiyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap405:12.1":{"pli":"Ekapaññāsakkhattuñca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap405:12.2":{"pli":"cakkavattī bhavissasi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:12.3":{"pli":"Cāturanto vijitāvī, ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:12.4":{"pli":"jambumaṇḍassa issaro. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap405:13.1":{"pli":"Mahāsamuddovakkhobho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap405:13.2":{"pli":"duddharo pathavī yathā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:13.3":{"pli":"Evamevaṁ ca te bhogā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:13.4":{"pli":"appameyyā bhavissare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap405:14.1":{"pli":"Saṭṭhikoṭī hiraññassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap405:14.2":{"pli":"cajitvā pabbajiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:14.3":{"pli":"Kiṁ kusalaṁ gavesanto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:14.4":{"pli":"bāvariṁ upasaṅkamiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap405:15.1":{"pli":"Tattha mante adhīyāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap405:15.2":{"pli":"chaḷaṅgaṁ nāma lakkhaṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:15.3":{"pli":"Tamandhakāraṁ vidhamaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:15.4":{"pli":"uppajji tvaṁ mahāmuni. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap405:16.1":{"pli":"Tava dassanakāmohaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap405:16.2":{"pli":"āgatomhi mahāmuni; ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:16.3":{"pli":"Tava dhammaṁ suṇitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:16.4":{"pli":"pattomhi acalaṁ padaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap405:17.1":{"pli":"Tiṁsakappasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap405:17.2":{"pli":"sappiṁ buddhassadāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:17.3":{"pli":"Etthantare nābhijāne, ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:17.4":{"pli":"sappiṁ viññāpitaṁ mayā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap405:18.1":{"pli":"Mama saṅkappamaññāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap405:18.2":{"pli":"uppajjati yadicchakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:18.3":{"pli":"Cittamaññāya nibbattaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:18.4":{"pli":"sabbe santappayāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap405:19.1":{"pli":"Aho buddhā aho dhammā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap405:19.2":{"pli":"aho no satthu sampadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:19.3":{"pli":"Thokañhi sappiṁ datvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:19.4":{"pli":"appameyyaṁ labhāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap405:20.1":{"pli":"Mahāsamudde udakaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap405:20.2":{"pli":"yāvatā nerupassato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:20.3":{"pli":"Mama sappiṁ upādāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:20.4":{"pli":"kalabhāgaṁ na hessati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap405:21.1":{"pli":"Yāvatā cakkavāḷassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap405:21.2":{"pli":"kariyantassa rāsito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:21.3":{"pli":"Mama nibbattavatthānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:21.4":{"pli":"okāso so na sammati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap405:22.1":{"pli":"Pabbatarājā himavā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap405:22.2":{"pli":"pavaropi siluccayo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:22.3":{"pli":"Mamānulittagandhassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:22.4":{"pli":"upanidhiṁ na hessati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap405:23.1":{"pli":"Vatthaṁ gandhañca sappiñca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap405:23.2":{"pli":"aññañca diṭṭhadhammikaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:23.3":{"pli":"Asaṅkhatañca nibbānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:23.4":{"pli":"sappidānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap405:24.1":{"pli":"Satipaṭṭhānasayano, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap405:24.2":{"pli":"samādhijhānagocaro; ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:24.3":{"pli":"Bojjhaṅgabhojano ajja, ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:24.4":{"pli":"sappidānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap405:25.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap405:25.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:25.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap405:26.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap405:26.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:26.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap405:27.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap405:27.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap405:27.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap405:28.1":{"pli":"Itthaṁ sudaṁ āyasmā mettagū thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap405:29.1":{"pli":"Mettaguttherassāpadānaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}