":"ambayāguṁ adāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap358:2.3":{"pli":"Vippasannamanaṁ tassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap358:2.4":{"pli":"vippasannena cetasā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap358:3.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap358:3.2":{"pli":"yaṁ kammamakariṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap358:3.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap358:3.4":{"pli":"ambayāguyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap358:4.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap358:4.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap358:4.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap358:5.1":{"pli":"Itthaṁ sudaṁ āyasmā ambayāgudāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap358:6.1":{"pli":"Ambayāgudāyakattherassāpadānaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap359":{"tha-ap359:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap359'><header><ul><li class='division'>{}</li>"},"tha-ap359:0.2":{"pli":"Saddasaññakavagga ","html":"<li>{}</li></ul>"},"tha-ap359:0.3":{"pli":"7 Supuṭakapūjakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap359:1.1":{"pli":"“Divāvihārā nikkhanto, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap359:1.2":{"pli":"vipassī lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap359:1.3":{"pli":"Bhikkhāya vicaranto so, ","html":"<span class='verse-line'>{}</span>"},"tha-ap359:1.4":{"pli":"mama santikupāgami. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap359:2.1":{"pli":"Tato patīto sumano, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap359:2.2":{"pli":"buddhaseṭṭhassa tādino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap359:2.3":{"pli":"Loṇasupuṭakaṁ datvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap359:2.4":{"pli":"kappaṁ saggamhi modahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap359:3.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap359:3.2":{"pli":"yaṁ puṭakamadāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap359:3.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap359:3.4":{"pli":"puṭakassa idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap359:4.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap359:4.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap359:4.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap359:5.1":{"pli":"Itthaṁ sudaṁ āyasmā supuṭakapūjako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap359:6.1":{"pli":"Supuṭakapūjakattherassāpadānaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap36":{"tha-ap36:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap36'><header><ul><li class='division'>{}</li>"},"tha-ap36:0.2":{"pli":"Kuṇḍadhānavagga ","html":"<li>{}</li></ul>"},"tha-ap36:0.3":{"pli":"Kāḷudāyittheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap36:1.1":{"pli":"“Padumuttarabuddhassa, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap36:1.2":{"pli":"lokajeṭṭhassa tādino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap36:1.3":{"pli":"Addhānaṁ paṭipannassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap36:1.4":{"pli":"carato cārikaṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap36:2.1":{"pli":"Suphullaṁ padumaṁ gayha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap36:2.2":{"pli":"uppalaṁ mallikañcahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap36:2.3":{"pli":"Paramannaṁ gahetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap36:2.4":{"pli":"adāsiṁ satthuno ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap36:3.1":{"pli":"Paribhuñji mahāvīro, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap36:3.2":{"pli":"paramannaṁ subhojanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap36:3.3":{"pli":"Tañca pupphaṁ gahetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap36:3.4":{"pli":"janassa sampadassayi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap36:4.1":{"pli":"Iṭṭhaṁ kantaṁ piyaṁ loke, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap36:4.2":{"pli":"jalajaṁ pupphamuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap36:4.3":{"pli":"Sudukkaraṁ kataṁ tena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap36:4.4":{"pli":"yo me pupphaṁ adāsidaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap36:5.1":{"pli":"Yo pupphamabhiropesi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap36:5.2":{"pli":"paramannañcadāsi me; ","html":"<span class='verse-line'>{}</span>"},"tha-ap36:5.3":{"pli":"Tamahaṁ kittayissāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap36:5.4":{"pli":"suṇātha mama bhāsato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap36:6.1":{"pli":"‘Dasa aṭṭha cakkhattuṁ so, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap36:6.2":{"pli":"devarajjaṁ karissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap36:6.3":{"pli":"Uppalaṁ padumañcāpi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap36:6.4":{"pli":"mallikañca taduttari. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap36:7.1":{"pli":"Assa puññavipākena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap36:7.2":{"pli":"dibbagandhasamāyutaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap36:7.3":{"pli":"Ākāse chadanaṁ katvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap36:7.4":{"pli":"dhārayissati tāvade. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap36:8.1":{"pli":"Pañcavīsatikkhattuñca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap36:8.2":{"pli":"cakkavattī bhavissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap36:8.3":{"pli":"Pathabyā rajjaṁ pañcasataṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap36:8.4":{"pli":"vasudhaṁ āvasissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap36:9.1":{"pli":"Kappasatasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap36:9.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap36:9.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap36:9.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap36:10.1":{"pli":"Sakakammābhiraddho so, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap36:10.2":{"pli":"sukkamūlena codito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap36:10.3":{"pli":"Sakyānaṁ nandijanano, ","html":"<span class='verse-line'>{}</span>"},"tha-ap36:10.4":{"pli":"ñātibandhu bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap36:11.1":{"pli":"So pacchā pabbajitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap36:11.2":{"pli":"sukkamūlena codito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap36:11.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap36:11.4":{"pli":"nibbāyissatināsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap36:12.1":{"pli":"Paṭisambhidamanuppattaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap36:12.2":{"pli":"katakiccamanāsavaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap36:12.3":{"pli":"Gotamo lokabandhu taṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap36:12.4":{"pli":"etadagge ṭhapessati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap36:13.1":{"pli":"Padhānapahitatto so, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap36:13.2":{"pli":"upasanto nirūpadhi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap36:13.3":{"pli":"Udāyī nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap36:13.4":{"pli":"hessati satthu sāvako’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap36:14.1":{"pli":"Rāgo doso ca moho ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap36:14.2":{"pli":"māno makkho ca dhaṁsito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap36:14.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap36:14.4":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap36:15.1":{"pli":"Tosayiñcāpi sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap36:15.2":{"pli":"ātāpī nipako ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap36:15.3":{"pli":"Pasādito ca sambuddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap36:15.4":{"pli":"etadagge ṭhapesi maṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap36:16.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap36:16.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap36:16.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap36:17.1":{"pli":"Itthaṁ sudaṁ āyasmā kāḷudāyī thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap36:18.1":{"pli":"Kāḷudāyittherassāpadānaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap360":{"tha-ap360:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap360'><header><ul><li class='division'>{}</li>"},"tha-ap360:0.2":{"pli":"Saddasaññakavagga ","html":"<li>{}</li></ul>"},"tha-ap360:0.3":{"pli":"8 Mañcadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap360:1.1":{"pli":"“Vipassino bhagavato, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap360:1.2":{"pli":"lokajeṭṭhassa tādino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap360:1.3":{"pli":"Ekaṁ mañcaṁ mayā dinnaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap360:1.4":{"pli":"pasannena sapāṇinā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap360:2.1":{"pli":"Hatthiyānaṁ assayānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap360:2.2":{"pli":"dibbayānaṁ samajjhagaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap360:2.3":{"pli":"Tena mañcakadānena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap360:2.4":{"pli":"pattomhi āsavakkhayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap360:3.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap360:3.2":{"pli":"yaṁ mañcamadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap360:3.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap360:3.4":{"pli":"mañcadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap360:4.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap360:4.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap360:4.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap360:5.1":{"pli":"Itthaṁ sudaṁ āyasmā mañcadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap360:6.1":{"pli":"Mañcadāyakattherassāpadānaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap361":{"tha-ap361:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap361'><header><ul><li class='division'>{}</li>"},"tha-ap361:0.2":{"pli":"Saddasaññakavagga ","html":"<li>{}</li></ul>"},"tha-ap361:0.3":{"pli":"9 Saraṇagamaniyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap361:1.1":{"pli":"“Āruhimha tadā nāvaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap361:1.2":{"pli":"bhikkhu cājīvako cahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap361:1.3":{"pli":"Nāvāya bhijjamānāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap361:1.4":{"pli":"bhikkhu me saraṇaṁ adā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap361:2.1":{"pli":"Ekattiṁse ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap361:2.2":{"pli":"yañca me saraṇaṁ adā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap361:2.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap361:2.4":{"pli":"saraṇāgamane phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap361:3.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap361:3.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap361:3.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap361:4.1":{"pli":"Itthaṁ sudaṁ āyasmā saraṇagamaniyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap361:5.1":{"pli":"Saraṇagamaniyattherassāpadānaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap362":{"tha-ap362:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap362'><header><ul><li class='division'>{}</li>"},"tha-ap362:0.2":{"pli":"Saddasaññakavagga ","html":"<li>{}</li></ul>"},"tha-ap362:0.3":{"pli":"Piṇḍapātikattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap362:1.1":{"pli":"“Tisso nāmāsi sambuddho, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap362:1.2":{"pli":"vihāsi vipine tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap362:1.3":{"pli":"Tusitā hi idhāgantvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap362:1.4":{"pli":"piṇḍapātaṁ adāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap362:2.1":{"pli":"Sambuddhamabhivādetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap36