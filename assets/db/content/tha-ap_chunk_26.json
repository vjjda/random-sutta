,"html":"<p><span class='verse-line'>{}</span>"},"tha-ap391:14.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap391:14.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap391:15.1":{"pli":"Thero koṭivīso soṇo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap391:15.2":{"pli":"bhikkhusaṅghassa aggato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap391:15.3":{"pli":"Pañhaṁ puṭṭho viyākāsi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap391:15.4":{"pli":"anotatte mahāsareti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap391:16.1":{"pli":"Itthaṁ sudaṁ āyasmā soṇo koṭivīso thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap391:17.1":{"pli":"Soṇakoṭivīsattherassāpadānaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap392":{"tha-ap392:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap392'><header><ul><li class='division'>{}</li>"},"tha-ap392:0.2":{"pli":"Avaṭaphalavagga ","html":"<li>{}</li></ul>"},"tha-ap392:0.3":{"pli":"10 Pubbakammapilotikabuddhaapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap392:1.1":{"pli":"Anotattasarāsanne, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap392:1.2":{"pli":"ramaṇīye silātale; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:1.3":{"pli":"Nānāratanapajjote, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:1.4":{"pli":"nānāgandhavanantare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap392:2.1":{"pli":"Mahatā bhikkhusaṅghena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap392:2.2":{"pli":"pareto lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:2.3":{"pli":"Āsīno byākarī tattha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:2.4":{"pli":"pubbakammāni attano. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap392:3.1":{"pli":"“Suṇātha bhikkhavo mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap392:3.2":{"pli":"yaṁ kammaṁ pakataṁ mayā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:3.3":{"pli":"Pilotikassa kammassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:3.4":{"pli":"buddhattepi vipaccati. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap392:4.0":{"pli":"10.1 ","html":"<h2>{}</h2>"},"tha-ap392:4.1":{"pli":"Munāḷi nāmahaṁ dhutto, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap392:4.2":{"pli":"pubbe aññāsu jātisu; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:4.3":{"pli":"Paccekabuddhaṁ surabhiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:4.4":{"pli":"abbhācikkhiṁ adūsakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap392:5.1":{"pli":"Tena kammavipākena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap392:5.2":{"pli":"niraye saṁsariṁ ciraṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:5.3":{"pli":"Bahūvassasahassāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:5.4":{"pli":"dukkhaṁ vedesi vedanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap392:6.1":{"pli":"Tena kammāvasesena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap392:6.2":{"pli":"idha pacchimake bhave; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:6.3":{"pli":"Abbhakkhānaṁ mayā laddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:6.4":{"pli":"sundarikāya kāraṇā. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap392:7.0":{"pli":"10.2 ","html":"<h2>{}</h2>"},"tha-ap392:7.1":{"pli":"Sabbābhibhussa buddhassa, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap392:7.2":{"pli":"nando nāmāsi sāvako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:7.3":{"pli":"Taṁ abbhakkhāya niraye, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:7.4":{"pli":"ciraṁ saṁsaritaṁ mayā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap392:8.1":{"pli":"Dasavassasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap392:8.2":{"pli":"niraye saṁsariṁ ciraṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:8.3":{"pli":"Manussabhāvaṁ laddhāhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:8.4":{"pli":"abbhakkhānaṁ bahuṁ labhiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap392:9.1":{"pli":"Tena kammāvasesena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap392:9.2":{"pli":"ciñcamānavikā mamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:9.3":{"pli":"Abbhācikkhi abhūtena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:9.4":{"pli":"janakāyassa aggato. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap392:10.0":{"pli":"10.3 ","html":"<h2>{}</h2>"},"tha-ap392:10.1":{"pli":"Brāhmaṇo sutavā āsiṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap392:10.2":{"pli":"ahaṁ sakkatapūjito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:10.3":{"pli":"Mahāvane pañcasate, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:10.4":{"pli":"mante vācemi māṇave. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap392:11.1":{"pli":"Tatthāgato isi bhīmo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap392:11.2":{"pli":"pañcābhiñño mahiddhiko; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:11.3":{"pli":"Tañcāhaṁ āgataṁ disvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:11.4":{"pli":"abbhācikkhiṁ adūsakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap392:12.1":{"pli":"Tatohaṁ avacaṁ sisse, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap392:12.2":{"pli":"kāmabhogī ayaṁ isi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:12.3":{"pli":"Mayhampi bhāsamānassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:12.4":{"pli":"anumodiṁsu māṇavā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap392:13.1":{"pli":"Tato māṇavakā sabbe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap392:13.2":{"pli":"bhikkhamānaṁ kule kule; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:13.3":{"pli":"Mahājanassa āhaṁsu, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:13.4":{"pli":"kāmabhogī ayaṁ isi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap392:14.1":{"pli":"Tena kammavipākena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap392:14.2":{"pli":"pañca bhikkhusatā ime; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:14.3":{"pli":"Abbhakkhānaṁ labhuṁ sabbe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:14.4":{"pli":"sundarikāya kāraṇā. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap392:15.0":{"pli":"10.4 ","html":"<h2>{}</h2>"},"tha-ap392:15.1":{"pli":"Vemātubhātaraṁ pubbe, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap392:15.2":{"pli":"dhanahetu haniṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:15.3":{"pli":"Pakkhipiṁ giriduggasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:15.4":{"pli":"silāya ca apiṁsayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap392:16.1":{"pli":"Tena kammavipākena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap392:16.2":{"pli":"devadatto silaṁ khipi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:16.3":{"pli":"Aṅguṭṭhaṁ piṁsayī pāde, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:16.4":{"pli":"mama pāsāṇasakkharā. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap392:17.0":{"pli":"10.5 ","html":"<h2>{}</h2>"},"tha-ap392:17.1":{"pli":"Purehaṁ dārako hutvā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap392:17.2":{"pli":"kīḷamāno mahāpathe; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:17.3":{"pli":"Paccekabuddhaṁ disvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:17.4":{"pli":"magge sakalikaṁ khipiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap392:18.1":{"pli":"Tena kammavipākena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap392:18.2":{"pli":"idha pacchimake bhave; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:18.3":{"pli":"Vadhatthaṁ maṁ devadatto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:18.4":{"pli":"abhimāre payojayi. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap392:19.0":{"pli":"10.6 ","html":"<h2>{}</h2>"},"tha-ap392:19.1":{"pli":"Hatthāroho pure āsiṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap392:19.2":{"pli":"paccekamunimuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:19.3":{"pli":"Piṇḍāya vicarantaṁ taṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:19.4":{"pli":"āsādesiṁ gajenahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap392:20.1":{"pli":"Tena kammavipākena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap392:20.2":{"pli":"bhanto nāḷāgirī gajo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:20.3":{"pli":"Giribbaje puravare, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:20.4":{"pli":"dāruṇo samupāgami. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap392:21.0":{"pli":"10.7 ","html":"<h2>{}</h2>"},"tha-ap392:21.1":{"pli":"Rājāhaṁ patthivo āsiṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap392:21.2":{"pli":"sattiyā purisaṁ haniṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:21.3":{"pli":"Tena kammavipākena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:21.4":{"pli":"niraye paccisaṁ bhusaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap392:22.1":{"pli":"Kammuno tassa sesena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap392:22.2":{"pli":"idāni sakalaṁ mama; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:22.3":{"pli":"Pāde chaviṁ pakappesi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:22.4":{"pli":"na hi kammaṁ vinassati. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap392:23.0":{"pli":"10.8 ","html":"<h2>{}</h2>"},"tha-ap392:23.1":{"pli":"Ahaṁ kevaṭṭagāmasmiṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap392:23.2":{"pli":"ahuṁ kevaṭṭadārako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:23.3":{"pli":"Macchake ghātite disvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:23.4":{"pli":"janayiṁ somanassakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap392:24.1":{"pli":"Tena kammavipākena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap392:24.2":{"pli":"sīsadukkhaṁ ahū mama; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:24.3":{"pli":"Sabbe sakkā ca haññiṁsu, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:24.4":{"pli":"yadā hani viṭaṭūbho. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap392:25.0":{"pli":"10.9 ","html":"<h2>{}</h2>"},"tha-ap392:25.1":{"pli":"Phussassāhaṁ pāvacane, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap392:25.2":{"pli":"sāvake paribhāsayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:25.3":{"pli":"Yavaṁ khādatha bhuñjatha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:25.4":{"pli":"mā ca bhuñjatha sālayo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap392:26.1":{"pli":"Tena kammavipākena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap392:26.2":{"pli":"temāsaṁ khāditaṁ yavaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:26.3":{"pli":"Nimantito brāhmaṇena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:26.4":{"pli":"verañjāyaṁ vasiṁ tadā. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap392:27.0":{"pli":"10.10 ","html":"<h2>{}</h2>"},"tha-ap392:27.1":{"pli":"Nibbuddhe vattamānamhi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap392:27.2":{"pli":"mallaputtaṁ niheṭhayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:27.3":{"pli":"Tena kammavipākena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:27.4":{"pli":"piṭṭhidukkhaṁ ahū mama. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap392:28.0":{"pli":"10.11 ","html":"<h2>{}</h2>"},"tha-ap392:28.1":{"pli":"Tikicchako ahaṁ āsiṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap392:28.2":{"pli":"seṭṭhiputtaṁ virecayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:28.3":{"pli":"Tena kammavipākena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:28.4":{"pli":"hoti pakkhandikā mama. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap392:29.0":{"pli":"10.12 ","html":"<h2>{}</h2>"},"tha-ap392:29.1":{"pli":"Avacāhaṁ jotipālo, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap392:29.2":{"pli":"sugataṁ kassapaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:29.3":{"pli":"Kuto nu bodhi muṇḍassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:29.4":{"pli":"bodhi paramadullabhā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap392:30.1":{"pli":"Tena kammavipākena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap392:30.2":{"pli":"acariṁ dukkaraṁ bahuṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:30.3":{"pli":"Chabbassānuruvelāyaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:30.4":{"pli":"tato bodhimapāpuṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap392:31.1":{"pli":"Nāhaṁ etena maggena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap392:31.2":{"pli":"pāpuṇiṁ bodhimuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:31.3":{"pli":"Kummaggena gavesissaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:31.4":{"pli":"pubbakammena vārito. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap392:32.1":{"pli":"Puññapāpaparikkhīṇo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap392:32.2":{"pli":"sabbasantāpavajjito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:32.3":{"pli":"Asoko anupāyāso, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:32.4":{"pli":"nibbāyissamanāsavo”. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap392:33.1":{"pli":"Evaṁ jino viyākāsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap392:33.2":{"pli":"Bhikkhusaṅghassa aggato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:33.3":{"pli":"Sabbābhiññābalappatto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:33.4":{"pli":"Anotatte mahāsareti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap392:34.1":{"pli":"Itthaṁ sudaṁ bhagavā attano pubbacaritaṁ kammapilotikaṁ nāma buddhāpadānadhammapariyāyaṁ abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap392:35.1":{"pli":"Pubbakammapilotikaṁ nāma buddhāpadānaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap392:36.1":{"pli":"Avaṭaphalavaggo ekūnacattālīsamo. ","html":"<p class='endsection'>{}</p>"},"tha-ap392:37.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"tha-ap392:38.1":{"pli":"Avaṭaṁ labujañceva, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"tha-ap392:38.2":{"pli":"udumbarapilakkhu ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:38.3":{"pli":"Phāru vallī ca kadalī, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:38.4":{"pli":"panaso koṭivīsako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap392:39.1":{"pli":"Pubbakammapiloti ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap392:39.2":{"pli":"apadānaṁ mahesino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:39.3":{"pli":"Gāthāyo ekanavuti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap392:39.4":{"pli":"gaṇitāyo vibhāvibhi. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap392:40.1":{"pli":"Cuddasamaṁ bhāṇavāraṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}