dukkhantikathā niṭṭhitā. ","html":"<p class='endsutta'>{}</p></article>"}},"kv11.5":{"kv11.5:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv11.5'><header><ul><li class='division'>{}</li>"},"kv11.5:0.2":{"pli":"Mahāpaṇṇāsaka ","html":"<li>{}</li>"},"kv11.5:0.3":{"pli":"Ekādasamavagga ","html":"<li>{}</li></ul>"},"kv11.5:0.4":{"pli":"Iddhibalakathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv11.5:1.1":{"pli":"Iddhibalena samannāgato kappaṁ tiṭṭheyyāti? ","html":"<p data-doxy='orthodox'>{}"},"kv11.5:1.2":{"pli":"Āmantā. ","html":"{}"},"kv11.5:1.3":{"pli":"Iddhimayiko so āyu, iddhimayikā sā gati, iddhimayiko so attabhāvappaṭilābhoti? ","html":"{}"},"kv11.5:1.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv11.5:2.1":{"pli":"Iddhibalena samannāgato kappaṁ tiṭṭheyyāti? ","html":"<p data-doxy='orthodox'>{}"},"kv11.5:2.2":{"pli":"Āmantā. ","html":"{}"},"kv11.5:2.3":{"pli":"Atītaṁ kappaṁ tiṭṭheyya, anāgataṁ kappaṁ tiṭṭheyyāti? ","html":"{}"},"kv11.5:2.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv11.5:2.5":{"pli":"iddhibalena samannāgato kappaṁ tiṭṭheyyāti? ","html":"{}"},"kv11.5:2.6":{"pli":"Āmantā. ","html":"{}"},"kv11.5:2.7":{"pli":"Dve kappe tiṭṭheyya, tayo kappe tiṭṭheyya, cattāro kappe tiṭṭheyyāti? ","html":"{}"},"kv11.5:2.8":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv11.5:2.9":{"pli":"iddhibalena samannāgato kappaṁ tiṭṭheyyāti? ","html":"{}"},"kv11.5:2.10":{"pli":"Āmantā. ","html":"{}"},"kv11.5:2.11":{"pli":"Sati jīvite jīvitāvasese tiṭṭheyya, asati jīvite jīvitāvasese tiṭṭheyyāti? ","html":"{}"},"kv11.5:2.12":{"pli":"Sati jīvite jīvitāvasese tiṭṭheyyāti. ","html":"{}"},"kv11.5:2.13":{"pli":"Hañci sati jīvite jīvitāvasese tiṭṭheyya, no ca vata re vattabbe—","html":"{}"},"kv11.5:2.14":{"pli":"“iddhibalena samannāgato kappaṁ tiṭṭheyyā”ti. ","html":"{}"},"kv11.5:2.15":{"pli":"Asati jīvite jīvitāvasese tiṭṭheyyāti, mato tiṭṭheyya, kālaṅkato tiṭṭheyyāti? ","html":"{}"},"kv11.5:2.16":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv11.5:3.1":{"pli":"Iddhibalena samannāgato kappaṁ tiṭṭheyyāti? ","html":"<p data-doxy='orthodox'>{}"},"kv11.5:3.2":{"pli":"Āmantā. ","html":"{}"},"kv11.5:3.3":{"pli":"Uppanno phasso mā nirujjhīti labbhā iddhiyā paggahetunti? ","html":"{}"},"kv11.5:3.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv11.5:3.5":{"pli":"uppannā vedanā …pe… ","html":"{}"},"kv11.5:3.6":{"pli":"uppannā saññā …pe… ","html":"{}"},"kv11.5:3.7":{"pli":"uppannā cetanā …pe… ","html":"{}"},"kv11.5:3.8":{"pli":"uppannaṁ cittaṁ … ","html":"{}"},"kv11.5:3.9":{"pli":"uppannā saddhā … ","html":"{}"},"kv11.5:3.10":{"pli":"uppannaṁ vīriyaṁ … ","html":"{}"},"kv11.5:3.11":{"pli":"uppannā sati … ","html":"{}"},"kv11.5:3.12":{"pli":"uppanno samādhi …pe… ","html":"{}"},"kv11.5:3.13":{"pli":"uppannā paññā mā nirujjhīti labbhā iddhiyā paggahetunti? ","html":"{}"},"kv11.5:3.14":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv11.5:4.1":{"pli":"Iddhibalena samannāgato kappaṁ tiṭṭheyyāti? ","html":"<p data-doxy='orthodox'>{}"},"kv11.5:4.2":{"pli":"Āmantā. ","html":"{}"},"kv11.5:4.3":{"pli":"Rūpaṁ niccaṁ hotūti labbhā iddhiyā paggahetunti? ","html":"{}"},"kv11.5:4.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv11.5:4.5":{"pli":"vedanā …pe… ","html":"{}"},"kv11.5:4.6":{"pli":"saññā … ","html":"{}"},"kv11.5:4.7":{"pli":"saṅkhārā … ","html":"{}"},"kv11.5:4.8":{"pli":"viññāṇaṁ niccaṁ hotūti labbhā iddhiyā paggahetunti? ","html":"{}"},"kv11.5:4.9":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv11.5:5.1":{"pli":"Iddhibalena samannāgato kappaṁ tiṭṭheyyāti? ","html":"<p data-doxy='orthodox'>{}"},"kv11.5:5.2":{"pli":"Āmantā. ","html":"{}"},"kv11.5:5.3":{"pli":"Jātidhammā sattā mā jāyiṁsūti labbhā iddhiyā paggahetunti? ","html":"{}"},"kv11.5:5.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv11.5:5.5":{"pli":"jarādhammā sattā mā jīriṁsūti …pe… ","html":"{}"},"kv11.5:5.6":{"pli":"byādhidhammā sattā mā byādhiyiṁsūti …pe… ","html":"{}"},"kv11.5:5.7":{"pli":"maraṇadhammā sattā mā mīyiṁsūti labbhā iddhiyā paggahetunti? ","html":"{}"},"kv11.5:5.8":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv11.5:6.1":{"pli":"Na vattabbaṁ—","html":"<p data-doxy='heterodox'>{}"},"kv11.5:6.2":{"pli":"“iddhibalena samannāgato kappaṁ tiṭṭheyyā”ti? ","html":"{}"},"kv11.5:6.3":{"pli":"Āmantā. ","html":"{}"},"kv11.5:6.4":{"pli":"Nanu vuttaṁ bhagavatā—","html":"{}"},"kv11.5:6.5":{"pli":"“yassa kassaci, ānanda, cattāro iddhipādā bhāvitā bahulīkatā yānīkatā vatthukatā anuṭṭhitā paricitā susamāraddhā, so ākaṅkhamāno kappaṁ vā tiṭṭheyya kappāvasesaṁ vā”ti. ","html":"{}"},"kv11.5:6.6":{"pli":"Attheva suttantoti? ","html":"{}"},"kv11.5:6.7":{"pli":"Āmantā. ","html":"{}"},"kv11.5:6.8":{"pli":"Tena hi iddhibalena samannāgato kappaṁ tiṭṭheyyāti. ","html":"{}</p>"},"kv11.5:7.1":{"pli":"Iddhibalena samannāgato kappaṁ tiṭṭheyyāti? ","html":"<p data-doxy='orthodox'>{}"},"kv11.5:7.2":{"pli":"Āmantā. ","html":"{}"},"kv11.5:7.3":{"pli":"Nanu vuttaṁ bhagavatā—","html":"{}"},"kv11.5:7.4":{"pli":"“catunnaṁ, bhikkhave, dhammānaṁ natthi koci pāṭibhogo samaṇo vā brāhmaṇo vā devo vā māro vā brahmā vā koci vā lokasmiṁ. ","html":"{}"},"kv11.5:7.5":{"pli":"Katamesaṁ catunnaṁ? ","html":"{}"},"kv11.5:7.6":{"pli":"‘Jarādhammo mā jīrī’ti natthi koci pāṭibhogo samaṇo vā brāhmaṇo vā devo vā māro vā brahmā vā koci vā lokasmiṁ. ","html":"{}"},"kv11.5:7.7":{"pli":"‘Byādhidhammo mā byādhiyī’ti …pe… ","html":"{}"},"kv11.5:7.8":{"pli":"‘maraṇadhammo mā mīyī’ti …pe… ","html":"{}"},"kv11.5:7.9":{"pli":"yāni kho pana tāni pubbe katāni pāpakāni kammāni saṅkilesikāni ponobbhavikāni sadarāni dukkhavipākāni āyatiṁ jātijarāmaraṇiyāni, ‘tesaṁ vipāko mā nibbattī’ti natthi koci pāṭibhogo samaṇo vā brāhmaṇo vā devo vā māro vā brahmā vā koci vā lokasmiṁ. ","html":"{}"},"kv11.5:7.10":{"pli":"Imesaṁ kho, bhikkhave, catunnaṁ dhammānaṁ natthi koci pāṭibhogo samaṇo vā brāhmaṇo vā devo vā māro vā brahmā vā koci vā lokasmin”ti. ","html":"{}"},"kv11.5:7.11":{"pli":"Attheva suttantoti? ","html":"{}"},"kv11.5:7.12":{"pli":"Āmantā. ","html":"{}"},"kv11.5:7.13":{"pli":"Tena hi na vattabbaṁ—","html":"{}"},"kv11.5:7.14":{"pli":"“iddhibalena samannāgato kappaṁ tiṭṭheyyā”ti. ","html":"{}</p>"},"kv11.5:7.15":{"pli":"Iddhibalakathā niṭṭhitā. ","html":"<p class='endsutta'>{}</p></article>"}}}