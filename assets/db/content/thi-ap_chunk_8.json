{"thi-ap27":{"thi-ap27:0.1":{"pli":"Therīapadāna ","html":"<article id='thi-ap27'><header><ul><li class='division'>{}</li>"},"thi-ap27:0.2":{"pli":"Kuṇḍalakesīvagga ","html":"<li>{}</li></ul>"},"thi-ap27:0.3":{"pli":"Bhaddākāpilānītherīapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"thi-ap27:1.1":{"pli":"“Padumuttaro nāma jino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"thi-ap27:1.2":{"pli":"sabbadhammāna pāragū; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:1.3":{"pli":"Ito satasahassamhi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:1.4":{"pli":"kappe uppajji nāyako. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:2.1":{"pli":"Tadāhu haṁsavatiyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:2.2":{"pli":"videho nāma nāmato; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:2.3":{"pli":"Seṭṭhī pahūtaratano, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:2.4":{"pli":"tassa jāyā ahosahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:3.1":{"pli":"Kadāci so narādiccaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:3.2":{"pli":"Upecca saparijjano; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:3.3":{"pli":"Dhammamassosi buddhassa, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:3.4":{"pli":"Sabbadukkhabhayappahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:4.1":{"pli":"Sāvakaṁ dhutavādānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:4.2":{"pli":"aggaṁ kittesi nāyako; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:4.3":{"pli":"Sutvā sattāhikaṁ dānaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:4.4":{"pli":"datvā buddhassa tādino. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:5.1":{"pli":"Nipacca sirasā pāde, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:5.2":{"pli":"taṁ ṭhānamabhipatthayiṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:5.3":{"pli":"Sa hāsayanto parisaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:5.4":{"pli":"tadā hi narapuṅgavo. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:6.1":{"pli":"Seṭṭhino anukampāya, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:6.2":{"pli":"imā gāthā abhāsatha; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:6.3":{"pli":"‘Lacchase patthitaṁ ṭhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:6.4":{"pli":"nibbuto hohi puttaka. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:7.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:7.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:7.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:7.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:8.1":{"pli":"Tassa dhammesu dāyādo, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:8.2":{"pli":"oraso dhammanimmito; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:8.3":{"pli":"Kassapo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:8.4":{"pli":"hessati satthu sāvako’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:9.1":{"pli":"Taṁ sutvā mudito hutvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:9.2":{"pli":"yāvajīvaṁ tadā jinaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:9.3":{"pli":"Mettacitto paricari, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:9.4":{"pli":"paccayehi vināyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:10.1":{"pli":"Sāsanaṁ jotayitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:10.2":{"pli":"so madditvā kutitthiye; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:10.3":{"pli":"Veneyyaṁ vinayitvā ca, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:10.4":{"pli":"nibbuto so sasāvako. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:11.1":{"pli":"Nibbute tamhi lokagge, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:11.2":{"pli":"pūjanatthāya satthuno; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:11.3":{"pli":"Ñātimitte samānetvā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:11.4":{"pli":"saha tehi akārayi. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:12.1":{"pli":"Sattayojanikaṁ thūpaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:12.2":{"pli":"ubbiddhaṁ ratanāmayaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:12.3":{"pli":"Jalantaṁ sataraṁsiṁva, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:12.4":{"pli":"sālarājaṁva phullitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:13.1":{"pli":"Sattasatasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:13.2":{"pli":"pātiyo tattha kārayi; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:13.3":{"pli":"Naḷaggī viya jotantī, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:13.4":{"pli":"rataneheva sattahi. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:14.1":{"pli":"Gandhatelena pūretvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:14.2":{"pli":"dīpānujjalayī tahiṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:14.3":{"pli":"Pūjanatthāya mahesissa, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:14.4":{"pli":"sabbabhūtānukampino. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:15.1":{"pli":"Sattasatasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:15.2":{"pli":"puṇṇakumbhāni kārayi; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:15.3":{"pli":"Rataneheva puṇṇāni, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:15.4":{"pli":"pūjanatthāya mahesino. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:16.1":{"pli":"Majjhe aṭṭhaṭṭhakumbhīnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:16.2":{"pli":"ussitā kañcanagghiyo; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:16.3":{"pli":"Atirocanti vaṇṇena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:16.4":{"pli":"saradeva divākaro. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:17.1":{"pli":"Catudvāresu sobhanti, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:17.2":{"pli":"toraṇā ratanāmayā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:17.3":{"pli":"Ussitā phalakā rammā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:17.4":{"pli":"sobhanti ratanāmayā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:18.1":{"pli":"Virocanti parikkhittā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:18.2":{"pli":"avaṭaṁsā sunimmitā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:18.3":{"pli":"Ussitāni paṭākāni, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:18.4":{"pli":"ratanāni virocare. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:19.1":{"pli":"Surattaṁ sukataṁ cittaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:19.2":{"pli":"cetiyaṁ ratanāmayaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:19.3":{"pli":"Atirocati vaṇṇena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:19.4":{"pli":"sasañjhova divākaro. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:20.1":{"pli":"Thūpassa vediyo tisso, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:20.2":{"pli":"haritālena pūrayi; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:20.3":{"pli":"Ekaṁ manosilāyekaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:20.4":{"pli":"añjanena ca ekikaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:21.1":{"pli":"Pūjaṁ etādisaṁ rammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:21.2":{"pli":"kāretvā varavādino; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:21.3":{"pli":"Adāsi dānaṁ saṅghassa, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:21.4":{"pli":"yāvajīvaṁ yathābalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:22.1":{"pli":"Sahāva seṭṭhinā tena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:22.2":{"pli":"tāni puññāni sabbaso; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:22.3":{"pli":"Yāvajīvaṁ karitvāna, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:22.4":{"pli":"sahāva sugatiṁ gatā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:23.1":{"pli":"Sampattiyonubhotvāna, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:23.2":{"pli":"devatte atha mānuse; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:23.3":{"pli":"Chāyā viya sarīrena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:23.4":{"pli":"saha teneva saṁsariṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:24.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:24.2":{"pli":"vipassī nāma nāyako; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:24.3":{"pli":"Uppajji cārudassano, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:24.4":{"pli":"sabbadhammavipassako. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:25.1":{"pli":"Tadāyaṁ bandhumatiyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:25.2":{"pli":"brāhmaṇo sādhusammato; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:25.3":{"pli":"Aḍḍho santo guṇenāpi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:25.4":{"pli":"dhanena ca suduggato. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:26.1":{"pli":"Tadāpi tassāhaṁ āsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:26.2":{"pli":"brāhmaṇī samacetasā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:26.3":{"pli":"Kadāci so dijavaro, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:26.4":{"pli":"saṅgamesi mahāmuniṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:27.1":{"pli":"Nisinnaṁ janakāyamhi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:27.2":{"pli":"desentaṁ amataṁ padaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:27.3":{"pli":"Sutvā dhammaṁ pamudito, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:27.4":{"pli":"adāsi ekasāṭakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:28.1":{"pli":"Gharamekena vatthena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:28.2":{"pli":"Gantvānetaṁ sa mabravi; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:28.3":{"pli":"‘Anumoda mahāpuññaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:28.4":{"pli":"Dinnaṁ buddhassa sāṭakaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:29.1":{"pli":"Tadāhaṁ añjaliṁ katvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:29.2":{"pli":"anumodiṁ supīṇitā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:29.3":{"pli":"‘Sudinno sāṭako sāmi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:29.4":{"pli":"buddhaseṭṭhassa tādino’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:30.1":{"pli":"Sukhito sajjito hutvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:30.2":{"pli":"saṁsaranto bhavābhave; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:30.3":{"pli":"Bārāṇasipure ramme, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:30.4":{"pli":"rājā āsi mahīpati. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:31.1":{"pli":"Tadā tassa mahesīhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:31.2":{"pli":"itthigumbassa uttamā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:31.3":{"pli":"Tassāti dayitā āsiṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:31.4":{"pli":"pubbasnehena bhattuno. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:32.1":{"pli":"Piṇḍāya vicarante te, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:32.2":{"pli":"aṭṭha paccekanāyake; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:32.3":{"pli":"Disvā pamudito hutvā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:32.4":{"pli":"datvā piṇḍaṁ mahārahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:33.1":{"pli":"Puno nimantayitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:33.2":{"pli":"katvā ratanamaṇḍapaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:33.3":{"pli":"Kammārehi kataṁ pattaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:33.4":{"pli":"sovaṇṇaṁ vata tattakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:34.1":{"pli":"Samānetvāna te sabbe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:34.2":{"pli":"tesaṁ dānamadāsi so; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:34.3":{"pli":"Soṇṇāsane paviṭṭhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:34.4":{"pli":"pasanno sehi pāṇibhi. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:35.1":{"pli":"Tampi dānaṁ sahādāsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:35.2":{"pli":"kāsirājenahaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:35.3":{"pli":"Punāhaṁ bārāṇasiyaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:35.4":{"pli":"jātā kāsikagāmake. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:36.1":{"pli":"Kuṭumbikakule phīte, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:36.2":{"pli":"sukhito so sabhātuko; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:36.3":{"pli":"Jeṭṭhassa bhātuno jāyā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:36.4":{"pli":"ahosiṁ supatibbatā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:37.1":{"pli":"Paccekabuddhaṁ disvāna, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:37.2":{"pli":"kaniyassa mama bhattuno; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:37.3":{"pli":"Bhāgannaṁ tassa datvāna, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:37.4":{"pli":"āgate tamhi pāvadiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:38.1":{"pli":"Nābhinandittha so dānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:38.2":{"pli":"tato tassa adāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:38.3":{"pli":"Ukhā āniya taṁ annaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:38.4":{"pli":"puno tasseva so adā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:39.1":{"pli":"Tadannaṁ chaḍḍayitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:39.2":{"pli":"duṭṭhā buddhassahaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:39.3":{"pli":"Pattaṁ kalalapuṇṇaṁ taṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:39.4":{"pli":"adāsiṁ tassa tādino. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:40.1":{"pli":"Dāne ca gahaṇe ceva, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:40.2":{"pli":"apace padusepi ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:40.3":{"pli":"Samacittamukhaṁ disvā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:40.4":{"pli":"tadāhaṁ saṁvijiṁ bhusaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:41.1":{"pli":"Puno pattaṁ gahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:41.2":{"pli":"sodhayitvā sugandhinā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:41.3":{"pli":"Pasannacittā pūretvā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:41.4":{"pli":"saghataṁ sakkaraṁ adaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:42.1":{"pli":"Yattha yatthūpapajjāmi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:42.2":{"pli":"surūpā homi dānato; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:42.3":{"pli":"Buddhassa apakārena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:42.4":{"pli":"duggandhā vadanena ca. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:43.1":{"pli":"Puna kassapavīrassa, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:43.2":{"pli":"nidhāyantamhi cetiye; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:43.3":{"pli":"Sovaṇṇaṁ iṭṭhakaṁ varaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:43.4":{"pli":"adāsiṁ muditā ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:44.1":{"pli":"Catujjātena gandhena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:44.2":{"pli":"nicayitvā tamiṭṭhakaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:44.3":{"pli":"Muttā duggandhadosamhā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:44.4":{"pli":"sabbaṅgasusamāgatā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:45.1":{"pli":"Sattapātisahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:45.2":{"pli":"rataneheva sattahi; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:45.3":{"pli":"Kāretvā ghatapūrāni, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:45.4":{"pli":"vaṭṭīni ca sahassaso. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:46.1":{"pli":"Pakkhipitvā padīpetvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:46.2":{"pli":"ṭhapayiṁ sattapantiyo; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:46.3":{"pli":"Pūjanatthaṁ lokanāthassa, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:46.4":{"pli":"vippasannena cetasā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:47.1":{"pli":"Tadāpi tamhi puññamhi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:47.2":{"pli":"bhāginīhaṁ visesato; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:47.3":{"pli":"Puna kāsīsu sañjāto, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:47.4":{"pli":"sumitto iti vissuto. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:48.1":{"pli":"Tassāhaṁ bhariyā āsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:48.2":{"pli":"sukhitā sajjitā piyā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:48.3":{"pli":"Tadā paccekamunino, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:48.4":{"pli":"adāsiṁ ghanaveṭhanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:49.1":{"pli":"Tassāpi bhāginī āsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:49.2":{"pli":"moditvā dānamuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:49.3":{"pli":"Punāpi kāsiraṭṭhamhi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:49.4":{"pli":"jāto koliyajātiyā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:50.1":{"pli":"Tadā koliyaputtānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:50.2":{"pli":"satehi saha pañcahi; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:50.3":{"pli":"Pañcapaccekabuddhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:50.4":{"pli":"satāni samupaṭṭhahi. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:51.1":{"pli":"Temāsaṁ tappayitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:51.2":{"pli":"adāsi ca ticīvaraṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:51.3":{"pli":"Jāyā tassa tadā āsiṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:51.4":{"pli":"puññakammapathānugā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:52.1":{"pli":"Tato cuto ahu rājā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:52.2":{"pli":"nando nāma mahāyaso; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:52.3":{"pli":"Tassāpi mahesī āsiṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:52.4":{"pli":"sabbakāmasamiddhinī. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:53.1":{"pli":"Tadā rājā bhavitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:53.2":{"pli":"brahmadatto mahīpati; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:53.3":{"pli":"Padumavatīputtānaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:53.4":{"pli":"paccekamuninaṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:54.1":{"pli":"Satāni pañcanūnāni, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:54.2":{"pli":"yāvajīvaṁ upaṭṭhahiṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:54.3":{"pli":"Rājuyyāne nivāsetvā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:54.4":{"pli":"nibbutāni ca pūjayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:55.1":{"pli":"Cetiyāni ca kāretvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:55.2":{"pli":"pabbajitvā ubho mayaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:55.3":{"pli":"Bhāvetvā appamaññāyo, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:55.4":{"pli":"brahmalokaṁ agamhase. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:56.1":{"pli":"Tato cuto mahātitthe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:56.2":{"pli":"sujāto pipphalāyano; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:56.3":{"pli":"Mātā sumanadevīti, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:56.4":{"pli":"kosigotto dijo pitā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:57.1":{"pli":"Ahaṁ madde janapade, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:57.2":{"pli":"sākalāya puruttame; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:57.3":{"pli":"Kappilassa dijassāsiṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:57.4":{"pli":"dhītā mātā sucīmati. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:58.1":{"pli":"Ghanakañcanabimbena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:58.2":{"pli":"nimminitvāna maṁ pitā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:58.3":{"pli":"Adā kassapadhīrassa, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:58.4":{"pli":"kāmehi vajjitassamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:59.1":{"pli":"Kadāci so kāruṇiko, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:59.2":{"pli":"gantvā kammantapekkhako; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:59.3":{"pli":"Kākādikehi khajjante, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:59.4":{"pli":"pāṇe disvāna saṁviji. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:60.1":{"pli":"Gharevāhaṁ tile jāte, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:60.2":{"pli":"disvānātapatāpane; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:60.3":{"pli":"Kimī kākehi khajjante, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:60.4":{"pli":"saṁvegamalabhiṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:61.1":{"pli":"Tadā so pabbajī dhīro, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:61.2":{"pli":"ahaṁ tamanupabbajiṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:61.3":{"pli":"Pañcavassāni nivasiṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:61.4":{"pli":"paribbājavate ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:62.1":{"pli":"Yadā pabbajitā āsi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:62.2":{"pli":"gotamī jinaposikā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:62.3":{"pli":"Tadāhaṁ tamupagantvā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:62.4":{"pli":"buddhena anusāsitā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:63.1":{"pli":"Na cireneva kālena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:63.2":{"pli":"arahattamapāpuṇiṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:63.3":{"pli":"Aho kalyāṇamittattaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:63.4":{"pli":"kassapassa sirīmato. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:64.1":{"pli":"Suto buddhassa dāyādo, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:64.2":{"pli":"kassapo susamāhito; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:64.3":{"pli":"Pubbenivāsaṁ yo vedi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:64.4":{"pli":"saggāpāyañca passati. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:65.1":{"pli":"Atho jātikkhayaṁ patto, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:65.2":{"pli":"abhiññāvosito muni; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:65.3":{"pli":"Etāhi tīhi vijjāhi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:65.4":{"pli":"tevijjo hoti brāhmaṇo. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:66.1":{"pli":"Tatheva bhaddākāpilānī, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:66.2":{"pli":"tevijjā maccuhāyinī; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:66.3":{"pli":"Dhāreti antimaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:66.4":{"pli":"jitvā māraṁ savāhanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:67.1":{"pli":"Disvā ādīnavaṁ loke, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:67.2":{"pli":"ubho pabbajitā mayaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:67.3":{"pli":"Tyamha khīṇāsavā dantā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:67.4":{"pli":"sītibhūtāmha nibbutā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:68.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:68.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:68.3":{"pli":"viharāmi anāsavā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:69.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:69.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:69.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap27:70.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap27:70.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap27:70.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"thi-ap27:71.1":{"pli":"Itthaṁ sudaṁ bhaddākāpilānī bhikkhunī imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"thi-ap27:72.1":{"pli":"Bhaddākāpilānītheriyāpadānaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}