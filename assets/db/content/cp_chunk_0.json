{"cp1":{"cp1:0.1":{"pli":"Cariyāpiṭaka ","eng":"The Conduct Leading to Buddhahood ","html":"<article id='cp1'><header><ul><li class='division'>{}</li>"},"cp1:0.2":{"pli":"Akittivagga ","eng":"The Chapter With Akitti ","html":"<li>{}</li>"},"cp1:0.3":{"pli":"Dānapāramī 1 ","eng":"The Perfection of Giving (1st) ","html":"<li>{}</li></ul>"},"cp1:0.4":{"pli":"Akitticariya ","eng":"Akitti’s Conduct ","html":"<h1 class='sutta-title'>{}</h1></header>"},"cp1:1.1":{"pli":"Namo tassa Bhagavato Arahato Sammāsambuddhassa. ","eng":"Homage to him, the blessed one, the perfected one, the fully awakened Buddha! ","html":"<p class='namo'>{}</p>"},"cp1:2.1":{"pli":"“Kappe ca satasahasse, ","eng":"“For a hundred thousand eons ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"cp1:2.2":{"pli":"caturo ca asaṅkhiye; ","eng":"and four incalculable ages, ","html":"<span class='verse-line'>{}</span>"},"cp1:2.3":{"pli":"Etthantare yaṁ caritaṁ, ","eng":"all my conduct in that period ","html":"<span class='verse-line'>{}</span>"},"cp1:2.4":{"pli":"sabbaṁ taṁ bodhipācanaṁ. ","eng":"ripens in awakening. ","html":"<span class='verse-line'>{}</span></p>"},"cp1:3.1":{"pli":"Atītakappe caritaṁ, ","eng":"Setting aside my conduct ","html":"<p><span class='verse-line'>{}</span>"},"cp1:3.2":{"pli":"ṭhapayitvā bhavābhave; ","eng":"in past eons through different lives, ","html":"<span class='verse-line'>{}</span>"},"cp1:3.3":{"pli":"Imamhi kappe caritaṁ, ","eng":"I shall speak of my conduct ","html":"<span class='verse-line'>{}</span>"},"cp1:3.4":{"pli":"pavakkhissaṁ suṇohi me. ","eng":"in this eon, hear me. ","html":"<span class='verse-line'>{}</span></p>"},"cp1:4.1":{"pli":"Yadā ahaṁ brahāraññe, ","eng":"When I lived having plunged ","html":"<p><span class='verse-line'>{}</span>"},"cp1:4.2":{"pli":"suññe vipinakānane; ","eng":"into the formidable jungle ","html":"<span class='verse-line'>{}</span>"},"cp1:4.3":{"pli":"Ajjhogāhetvā viharāmi, ","eng":"of empty thickets and glades, ","html":"<span class='verse-line'>{}</span>"},"cp1:4.4":{"pli":"akitti nāma tāpaso. ","eng":"my name was Akitti the mortifier. ","html":"<span class='verse-line'>{}</span></p>"},"cp1:5.1":{"pli":"Tadā maṁ tapatejena, ","eng":"Then, burned by the fires of my mortification, ","html":"<p><span class='verse-line'>{}</span>"},"cp1:5.2":{"pli":"santatto tidivābhibhū; ","eng":"the sovereign of the Third Heaven, ","html":"<span class='verse-line'>{}</span>","comm":"Namely Sakka AKA Indra. "},"cp1:5.3":{"pli":"Dhārento brāhmaṇavaṇṇaṁ, ","eng":"came to me for alms ","html":"<span class='verse-line'>{}</span>"},"cp1:5.4":{"pli":"bhikkhāya maṁ upāgami. ","eng":"in the form of a brahmin. ","html":"<span class='verse-line'>{}</span></p>"},"cp1:6.1":{"pli":"Pavanā ābhataṁ paṇṇaṁ, ","eng":"I had gathered leaves from the forest ","html":"<p><span class='verse-line'>{}</span>"},"cp1:6.2":{"pli":"atelañca aloṇikaṁ; ","eng":"without oil or salt, ","html":"<span class='verse-line'>{}</span>"},"cp1:6.3":{"pli":"Mama dvāre ṭhitaṁ disvā, ","eng":"and seeing him standing at my door, ","html":"<span class='verse-line'>{}</span>"},"cp1:6.4":{"pli":"sakaṭāhena ākiriṁ. ","eng":"I placed them in his pot. ","html":"<span class='verse-line'>{}</span></p>"},"cp1:7.1":{"pli":"Tassa datvānahaṁ paṇṇaṁ, ","eng":"After giving him the leaves ","html":"<p><span class='verse-line'>{}</span>"},"cp1:7.2":{"pli":"nikkujjitvāna bhājanaṁ; ","eng":"I turned over my plate, ","html":"<span class='verse-line'>{}</span>"},"cp1:7.3":{"pli":"Punesanaṁ jahitvāna, ","eng":"and having given up on seeking more food, ","html":"<span class='verse-line'>{}</span>"},"cp1:7.4":{"pli":"pāvisiṁ paṇṇasālakaṁ. ","eng":"I entered my hut of leaves. ","html":"<span class='verse-line'>{}</span></p>"},"cp1:8.1":{"pli":"Dutiyampi tatiyampi, ","eng":"A second and a third time ","html":"<p><span class='verse-line'>{}</span>"},"cp1:8.2":{"pli":"upagañchi mamantikaṁ; ","eng":"he came to me. ","html":"<span class='verse-line'>{}</span>"},"cp1:8.3":{"pli":"Akampito anolaggo, ","eng":"Undisturbed, ungrasping, ","html":"<span class='verse-line'>{}</span>"},"cp1:8.4":{"pli":"evamevamadāsahaṁ. ","eng":"I gave in just the same way. ","html":"<span class='verse-line'>{}</span></p>"},"cp1:9.1":{"pli":"Na me tappaccayā atthi, ","eng":"That is the reason why ","html":"<p><span class='verse-line'>{}</span>"},"cp1:9.2":{"pli":"sarīrasmiṁ vivaṇṇiyaṁ; ","eng":"my body is not discolored. ","html":"<span class='verse-line'>{}</span>"},"cp1:9.3":{"pli":"Pītisukhena ratiyā, ","eng":"In rapture and bliss free of relishing ","html":"<span class='verse-line'>{}</span>"},"cp1:9.4":{"pli":"vītināmemi taṁ divaṁ. ","eng":"I spend the day. ","html":"<span class='verse-line'>{}</span></p>"},"cp1:10.1":{"pli":"Yadi māsampi dvemāsaṁ, ","eng":"If even for a month or two ","html":"<p><span class='verse-line'>{}</span>"},"cp1:10.2":{"pli":"dakkhiṇeyyaṁ varaṁ labhe; ","eng":"I were to find a worthy recipient, ","html":"<span class='verse-line'>{}</span>"},"cp1:10.3":{"pli":"Akampito anolīno, ","eng":"undisturbed, unattached, ","html":"<span class='verse-line'>{}</span>"},"cp1:10.4":{"pli":"dadeyyaṁ dānamuttamaṁ. ","eng":"I would give the supreme gift. ","html":"<span class='verse-line'>{}</span></p>"},"cp1:11.1":{"pli":"Na tassa dānaṁ dadamāno, ","eng":"While giving him that gift ","html":"<p><span class='verse-line'>{}</span>"},"cp1:11.2":{"pli":"yasaṁ lābhañca patthayiṁ; ","eng":"I did not wish for fame or profit. ","html":"<span class='verse-line'>{}</span>"},"cp1:11.3":{"pli":"Sabbaññutaṁ patthayāno, ","eng":"Wishing for omniscience ","html":"<span class='verse-line'>{}</span>"},"cp1:11.4":{"pli":"tāni kammāni ācarin”ti. ","eng":"I performed those deeds.” ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"cp1:12.1":{"pli":"Akitticariyaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"cp10":{"cp10:0.1":{"pli":"Cariyāpiṭaka ","eng":"The Conduct Leading to Buddhahood ","html":"<article id='cp10'><header><ul><li class='division'>{}</li>"},"cp10:0.2":{"pli":"Akittivagga ","eng":"The Chapter With Akitti ","html":"<li>{}</li>"},"cp10:0.3":{"pli":"Dānapāramī 10 ","eng":"The Perfection of Giving (10th) ","html":"<li>{}</li></ul>"},"cp10:0.4":{"pli":"Sasapaṇḍitacariya ","eng":"The Wise Hare’s Conduct ","html":"<h1 class='sutta-title'>{}</h1></header>"},"cp10:1.1":{"pli":"“Punāparaṁ yadā homi, ","eng":"“Then again when I was ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"cp10:1.2":{"pli":"Sasako pavanacārako; ","eng":"a hare who roamed the forest, ","html":"<span class='verse-line'>{}</span>"},"cp10:1.3":{"pli":"Tiṇapaṇṇasākaphalabhakkho, ","eng":"eating grass, leaves, vegetables, and fruit, ","html":"<span class='verse-line'>{}</span>"},"cp10:1.4":{"pli":"Paraheṭhanavivajjito. ","eng":"refraining from harming others, ","html":"<span class='verse-line'>{}</span></p>"},"cp10:2.1":{"pli":"Makkaṭo ca siṅgālo ca, ","eng":"a monkey, a jackal, ","html":"<p><span class='verse-line'>{}</span>"},"cp10:2.2":{"pli":"suttapoto cahaṁ tadā; ","eng":"a young otter and I ","html":"<span class='verse-line'>{}</span>"},"cp10:2.3":{"pli":"Vasāma ekasāmantā, ","eng":"lived in the same neighborhood ","html":"<span class='verse-line'>{}</span>"},"cp10:2.4":{"pli":"sāyaṁ pāto ca dissare. ","eng":"and were seen together morning and evening. ","html":"<span class='verse-line'>{}</span></p>"},"cp10:3.1":{"pli":"Ahaṁ te anusāsāmi, ","eng":"I advised them ","html":"<p><span class='verse-line'>{}</span>"},"cp10:3.2":{"pli":"kiriye kalyāṇapāpake; ","eng":"regarding good and bad deeds: ","html":"<span class='verse-line'>{}</span>"},"cp10:3.3":{"pli":"‘Pāpāni parivajjetha, ","eng":"‘Shun bad deeds, ","html":"<span class='verse-line'>{}</span>"},"cp10:3.4":{"pli":"kalyāṇe abhinivissatha’. ","eng":"and cling to the good.’ ","html":"<span class='verse-line'>{}</span></p>"},"cp10:4.1":{"pli":"Uposathamhi divase, ","eng":"Seeing the full moon ","html":"<p><span class='verse-line'>{}</span>"},"cp10:4.2":{"pli":"candaṁ disvāna pūritaṁ; ","eng":"on the sabbath day, ","html":"<span class='verse-line'>{}</span>"},"cp10:4.3":{"pli":"Etesaṁ tattha ācikkhiṁ, ","eng":"I pointed it out to them, saying, ","html":"<span class='verse-line'>{}</span>"},"cp10:4.4":{"pli":"‘divaso ajjuposatho. ","eng":"‘Today is the sabbath. ","html":"<span class='verse-line'>{}</span></p>"},"cp10:5.1":{"pli":"Dānāni paṭiyādetha, ","eng":"Prepare gifts ","html":"<p><span class='verse-line'>{}</span>"},"cp10:5.2":{"pli":"dakkhiṇeyyassa dātave; ","eng":"for one worthy of offerings. ","html":"<span class='verse-line'>{}</span>"},"cp10:5.3":{"pli":"Datvā dānaṁ dakkhiṇeyye, ","eng":"Having given to one worthy of offerings, ","html":"<span class='verse-line'>{}</span>"},"cp10:5.4":{"pli":"upavassathuposathaṁ’. ","eng":"observe the sabbath day.’ ","html":"<span class='verse-line'>{}</span></p>"},"cp10:6.1":{"pli":"Te me sādhūti vatvāna, ","eng":"Saying ‘good!’ to me, ","html":"<p><span class='verse-line'>{}</span>"},"cp10:6.2":{"pli":"yathāsatti yathābalaṁ; ","eng":"they prepared gifts ","html":"<span class='verse-line'>{}</span>"},"cp10:6.3":{"pli":"Dānāni paṭiyādetvā, ","eng":"according to their capacity and means, ","html":"<span class='verse-line'>{}</span>"},"cp10:6.4":{"pli":"dakkhiṇeyyaṁ gavesisuṁ. ","eng":"and sought out one worthy of offerings. ","html":"<span class='verse-line'>{}</span></p>"},"cp10:7.1":{"pli":"Ahaṁ nisajja cintesiṁ, ","eng":"As I was sitting I thought about ","html":"<p><span class='verse-line'>{}</span>"},"cp10:7.2":{"pli":"dānaṁ dakkhiṇanucchavaṁ; ","eng":"what sort of gift would suit one worthy of offerings: ","html":"<span class='verse-line'>{}</span>"},"cp10:7.3":{"pli":"‘Yadihaṁ labhe dakkhiṇeyyaṁ, ","eng":"‘If I were to find a worthy recipient, ","html":"<span class='verse-line'>{}</span>"},"cp10:7.4":{"pli":"kiṁ me dānaṁ bhavissati. ","eng":"what gift would i give? ","html":"<span class='verse-line'>{}</span></p>"},"cp10:8.1":{"pli":"Na me atthi tilā muggā, ","eng":"I have no sesame or mung beans, ","html":"<p><span class='verse-line'>{}</span>"},"cp10:8.2":{"pli":"māsā vā taṇḍulā ghataṁ; ","eng":"no beans or rice or ghee. ","html":"<span class='verse-line'>{}</span>"},"cp10:8.3":{"pli":"Ahaṁ tiṇena yāpemi, ","eng":"I feed only on grass, ","html":"<span class='verse-line'>{}</span>"},"cp10:8.4":{"pli":"na sakkā tiṇa dātave. ","eng":"but that’s not something I can give. ","html":"<span class='verse-line'>{}</span></p>"},"cp10:9.1":{"pli":"Yadi koci eti dakkhiṇeyyo, ","eng":"If someone worthy of gifts comes, ","html":"<p><span class='verse-line'>{}</span>"},"cp10:9.2":{"pli":"Bhikkhāya mama santike; ","eng":"seeking alms near me, ","html":"<span class='verse-line'>{}</span>"},"cp10:9.3":{"pli":"Dajjāhaṁ sakamattānaṁ, ","eng":"I shall give my own self: ","html":"<span class='verse-line'>{}</span>"},"cp10:9.4":{"pli":"Na so tuccho gamissati’. ","eng":"they shall not leave empty-handed.’ ","html":"<span class='verse-line'>{}</span></p>"},"cp10:10.1":{"pli":"Mama saṅkappamaññāya, ","eng":"Knowing my thoughts, ","html":"<p><span class='verse-line'>{}</span>"},"cp10:10.2":{"pli":"sakko brāhmaṇavaṇṇinā; ","eng":"Sakka in the guise of a brahmin ","html":"<span class='verse-line'>{}</span>"},"cp10:10.3":{"pli":"Āsayaṁ me upāgacchi, ","eng":"approached my lair ","html":"<span class='verse-line'>{}</span>"},"cp10:10.4":{"pli":"dānavīmaṁsanāya me. ","eng":"in order to test my generosity. ","html":"<span class='verse-line'>{}</span></p>"},"cp10:11.1":{"pli":"Tamahaṁ disvāna santuṭṭho, ","eng":"Seeing him I was elated, ","html":"<p><span class='verse-line'>{}</span>"},"cp10:11.2":{"pli":"idaṁ vacanamabraviṁ; ","eng":"and said the following. ","html":"<span class='verse-line'>{}</span>"},"cp10:11.3":{"pli":"‘Sādhu khosi anuppatto, ","eng":"‘It is so good that you have come ","html":"<span class='verse-line'>{}</span>"},"cp10:11.4":{"pli":"ghāsahetu mamantike. ","eng":"to me looking for food. ","html":"<span class='verse-line'>{}</span></p>"},"cp10:12.1":{"pli":"Adinnapubbaṁ dānavaraṁ, ","eng":"Today I shall give to you ","html":"<p><span class='verse-line'>{}</span>"},"cp10:12.2":{"pli":"ajja dassāmi te ahaṁ; ","eng":"a fine gift never before given. ","html":"<span class='verse-line'>{}</span>"},"cp10:12.3":{"pli":"Tuvaṁ sīlaguṇūpeto, ","eng":"You are furnished with virtue, ","html":"<span class='verse-line'>{}</span>"},"cp10:12.4":{"pli":"ayuttaṁ te paraheṭhanaṁ. ","eng":"unattached to harming others. ","html":"<span class='verse-line'>{}</span></p>"},"cp10:13.1":{"pli":"Ehi aggiṁ padīpehi, ","eng":"Come, light a fire, ","html":"<p><span class='verse-line'>{}</span>"},"cp10:13.2":{"pli":"nānākaṭṭhe samānaya; ","eng":"having gathered different sticks. ","html":"<span class='verse-line'>{}</span>"},"cp10:13.3":{"pli":"Ahaṁ pacissamattānaṁ, ","eng":"I shall cook myself, ","html":"<span class='verse-line'>{}</span>"},"cp10:13.4":{"pli":"pakkaṁ tvaṁ bhakkhayissasi’. ","eng":"you shall eat me roasted.’ ","html":"<span class='verse-line'>{}</span></p>"},"cp10:14.1":{"pli":"‘Sādhū’ti so haṭṭhamano, ","eng":"‘Good!’ he said happily, ","html":"<p><span class='verse-line'>{}</span>"},"cp10:14.2":{"pli":"nānākaṭṭhe samānayi; ","eng":"and gathered different sticks. ","html":"<span class='verse-line'>{}</span>"},"cp10:14.3":{"pli":"Mahantaṁ akāsi citakaṁ, ","eng":"Building a great pyre, ","html":"<span class='verse-line'>{}</span>"},"cp10:14.4":{"pli":"katvā aṅgāragabbhakaṁ. ","eng":"he placed an ember in the recess. ","html":"<span class='verse-line'>{}</span></p>"},"cp10:15.1":{"pli":"Aggiṁ tattha padīpesi, ","eng":"He lit such a fire there ","html":"<p><span class='verse-line'>{}</span>"},"cp10:15.2":{"pli":"yathā so khippaṁ mahā bhave; ","eng":"that would quickly grow big. ","html":"<span class='verse-line'>{}</span>"},"cp10:15.3":{"pli":"Phoṭetvā rajagate gatte, ","eng":"Shaking my dusty limbs, ","html":"<span class='verse-line'>{}</span>"},"cp10:15.4":{"pli":"ekamantaṁ upāvisiṁ. ","eng":"I withdrew to one side. ","html":"<span class='verse-line'>{}</span></p>"},"cp10:16.1":{"pli":"Yadā mahākaṭṭhapuñjo, ","eng":"When the great pile of sticks ","html":"<p><span class='verse-line'>{}</span>"},"cp10:16.2":{"pli":"āditto dhamadhamāyati; ","eng":"was burning and blazing, ","html":"<span class='verse-line'>{}</span>"},"cp10:16.3":{"pli":"Taduppatitvā papatiṁ, ","eng":"I leapt up and fell on it, ","html":"<span class='verse-line'>{}</span>"},"cp10:16.4":{"pli":"majjhe jālasikhantare. ","eng":"in the midst of the fiery flames. ","html":"<span class='verse-line'>{}</span></p>"},"cp10:17.1":{"pli":"Yathā sītodakaṁ nāma, ","eng":"Like diving ","html":"<p><span class='verse-line'>{}</span>"},"cp10:17.2":{"pli":"Paviṭṭhaṁ yassa kassaci; ","eng":"into cool water, ","html":"<span class='verse-line'>{}</span>"},"cp10:17.3":{"pli":"Sameti darathapariḷāhaṁ, ","eng":"allaying distress and fever, ","html":"<span class='verse-line'>{}</span>"},"cp10:17.4":{"pli":"Assādaṁ deti pīti ca. ","eng":"bringing satisfaction and joy. ","html":"<span class='verse-line'>{}</span></p>"},"cp10:18.1":{"pli":"Tatheva jalitaṁ aggiṁ, ","eng":"That’s how it was ","html":"<p><span class='verse-line'>{}</span>"},"cp10:18.2":{"pli":"paviṭṭhassa mamaṁ tadā; ","eng":"when I entered the burning flame. ","html":"<span class='verse-line'>{}</span>"},"cp10:18.3":{"pli":"Sabbaṁ sameti darathaṁ, ","eng":"It allayed distress and fever, ","html":"<span class='verse-line'>{}</span>"},"cp10:18.4":{"pli":"yathā sītodakaṁ viya. ","eng":"just like cool water. ","html":"<span class='verse-line'>{}</span></p>"},"cp10:19.1":{"pli":"Chaviṁ cammaṁ maṁsaṁ nhāruṁ, ","eng":"Outer skin and inner, flesh and sinews, ","html":"<p><span class='verse-line'>{}</span>"},"cp10:19.2":{"pli":"Aṭṭhiṁ hadayabandhanaṁ; ","eng":"bones, and heart with cords: ","html":"<span class='verse-line'>{}</span>"},"cp10:19.3":{"pli":"Kevalaṁ sakalaṁ kāyaṁ, ","eng":"my whole entire body ","html":"<span class='verse-line'>{}</span>"},"cp10:19.4":{"pli":"Brāhmaṇassa adāsahan”ti. ","eng":"I gave to the brahmin.” ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"cp10:20.1":{"pli":"Sasapaṇḍitacariyaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"cp10:21.1":{"pli":"Akittivaggo paṭhamo. ","html":"<p class='endsection'>{}</p>"},"cp10:22.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"cp10:23.1":{"pli":"Akittibrāhmaṇo saṅkho, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"cp10:23.2":{"pli":"kururājā dhanañcayo; ","html":"<span class='verse-line'>{}</span>"},"cp10:23.3":{"pli":"Mahāsudassano rājā, ","html":"<span class='verse-line'>{}</span>"},"cp10:23.4":{"pli":"mahāgovindabrāhmaṇo. ","html":"<span class='verse-line'>{}</span></p>"},"cp10:24.1":{"pli":"Nimi candakumāro ca, ","html":"<p><span class='verse-line'>{}</span>"},"cp10:24.2":{"pli":"sivi vessantaro saso; ","html":"<span class='verse-line'>{}</span>"},"cp10:24.3":{"pli":"Ahameva tadā āsiṁ, ","html":"<span class='verse-line'>{}</span>"},"cp10:24.4":{"pli":"yo te dānavare adā. ","html":"<span class='verse-line'>{}</span></p>"},"cp10:25.1":{"pli":"Ete dānaparikkhārā, ","html":"<p><span class='verse-line'>{}</span>"},"cp10:25.2":{"pli":"ete dānassa pāramī; ","html":"<span class='verse-line'>{}</span>"},"cp10:25.3":{"pli":"Jīvitaṁ yācake datvā, ","html":"<span class='verse-line'>{}</span>"},"cp10:25.4":{"pli":"imaṁ pārami pūrayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"cp10:26.1":{"pli":"Bhikkhāya upagataṁ disvā, ","html":"<p><span class='verse-line'>{}</span>"},"cp10:26.2":{"pli":"sakattānaṁ pariccajiṁ; ","html":"<span class='verse-line'>{}</span>"},"cp10:26.3":{"pli":"Dānena me samo natthi, ","html":"<span class='verse-line'>{}</span>"},"cp10:26.4":{"pli":"esā me dānapāramīti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"cp10:27.1":{"pli":"Dānapāraminiddeso niṭṭhito. ","html":"<p class='endsutta'>{}</p></article>"}},"cp11":{"cp11:0.1":{"pli":"Cariyāpiṭaka ","eng":"The Conduct Leading to Buddhahood ","html":"<article id='cp11'><header><ul><li class='division'>{}</li>"},"cp11:0.2":{"pli":"Hatthināgavagga ","eng":"The Chapter on an Elephant ","html":"<li>{}</li>"},"cp11:0.3":{"pli":"Sīlapāramī 1 ","eng":"The Perfection of Ethics (1st) ","html":"<li>{}</li></ul>"},"cp11:0.4":{"pli":"Mātuposakacariya ","eng":"The Conduct of One Who Provided for His Mother ","html":"<h1 class='sutta-title'>{}</h1></header>"},"cp11:1.1":{"pli":"“Yadā ahosiṁ pavane, ","eng":"“Once I lived in the forest ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"cp11:1.2":{"pli":"kuñjaro mātuposako; ","eng":"as a elephant who provided for his mother. ","html":"<span class='verse-line'>{}</span>"},"cp11:1.3":{"pli":"Na tadā atthi mahiyā, ","eng":"At that time no-one on earth ","html":"<span class='verse-line'>{}</span>"},"cp11:1.4":{"pli":"guṇena mama sādiso. ","eng":"could equal my virtues. ","html":"<span class='verse-line'>{}</span></p>"},"cp11:2.1":{"pli":"Pavane disvā vanacaro, ","eng":"Seeing me in the forest, a forester ","html":"<p><span class='verse-line'>{}</span>"},"cp11:2.2":{"pli":"rañño maṁ paṭivedayi; ","eng":"informed the king about me. ","html":"<span class='verse-line'>{}</span>"},"cp11:2.3":{"pli":"‘Tavānucchavo mahārāja, ","eng":"‘Great King, an elephant that befits you ","html":"<span class='verse-line'>{}</span>"},"cp11:2.4":{"pli":"gajo vasati kānane. ","eng":"is dwelling in the forest grove. ","html":"<span class='verse-line'>{}</span></p>"},"cp11:3.1":{"pli":"Na tassa parikkhāyattho, ","eng":"No need to dig a moat around him, ","html":"<p><span class='verse-line'>{}</span>"},"cp11:3.2":{"pli":"napi āḷakakāsuyā; ","eng":"nor tether him to a post in a pit. ","html":"<span class='verse-line'>{}</span>"},"cp11:3.3":{"pli":"Saha gahite soṇḍāya, ","eng":"Taken by the trunk, ","html":"<span class='verse-line'>{}</span>"},"cp11:3.4":{"pli":"sayameva idhehi’ti. ","eng":"he will come here by himself.’ ","html":"<span class='verse-line'>{}</span></p>"},"cp11:4.1":{"pli":"Tassa taṁ vacanaṁ sutvā, ","eng":"When he heard these words, ","html":"<p><span class='verse-line'>{}</span>"},"cp11:4.2":{"pli":"rājāpi tuṭṭhamānaso; ","eng":"the king, elated, ","html":"<span class='verse-line'>{}</span>"},"cp11:4.3":{"pli":"Pesesi hatthidamakaṁ, ","eng":"sent an elephant-tamer, ","html":"<span class='verse-line'>{}</span>"},"cp11:4.4":{"pli":"chekācariyaṁ susikkhitaṁ. ","eng":"a well-trained and expert tutor. ","html":"<span class='verse-line'>{}</span></p>"},"cp11:5.1":{"pli":"Gantvā so hatthidamako, ","eng":"When the elephant-tamer reached there, ","html":"<p><span class='verse-line'>{}</span>"},"cp11:5.2":{"pli":"addasa padumassare; ","eng":"he saw me in a lotus pond, ","html":"<span class='verse-line'>{}</span>"},"cp11:5.3":{"pli":"Bhisamuḷālaṁ uddharantaṁ, ","eng":"pulling out lotus roots ","html":"<span class='verse-line'>{}</span>"},"cp11:5.4":{"pli":"yāpanatthāya mātuyā. ","eng":"to feed my mother. ","html":"<span class='verse-line'>{}</span></p>"},"cp11:6.1":{"pli":"Viññāya me sīlaguṇaṁ, ","eng":"Discerning my moral virtue, ","html":"<p><span class='verse-line'>{}</span>"},"cp11:6.2":{"pli":"lakkhaṇaṁ upadhārayi; ","eng":"he checked me for marks. ","html":"<span class='verse-line'>{}</span>"},"cp11:6.3":{"pli":"‘Ehi puttā’ti vatvāna, ","eng":"Saying, ‘Come, child’, ","html":"<span class='verse-line'>{}</span>"},"cp11:6.4":{"pli":"mama soṇḍāya aggahi. ","eng":"he took me by the trunk. ","html":"<span class='verse-line'>{}</span></p>"},"cp11:7.1":{"pli":"Yaṁ me tadā pākatikaṁ, ","eng":"What was at that time ","html":"<p><span class='verse-line'>{}</span>"},"cp11:7.2":{"pli":"sarīrānugataṁ balaṁ; ","eng":"the natural strength of my body, ","html":"<span class='verse-line'>{}</span>"},"cp11:7.3":{"pli":"Ajja nāgasahassānaṁ, ","eng":"would equal a thousand ","html":"<span class='verse-line'>{}</span>"},"cp11:7.4":{"pli":"balena samasādisaṁ. ","eng":"of the elephants of today. ","html":"<span class='verse-line'>{}</span></p>"},"cp11:8.1":{"pli":"Yadihaṁ tesaṁ pakuppeyyaṁ, ","eng":"If I had been upset ","html":"<p><span class='verse-line'>{}</span>"},"cp11:8.2":{"pli":"upetānaṁ gahaṇāya maṁ; ","eng":"with those who came to capture me, ","html":"<span class='verse-line'>{}</span>"},"cp11:8.3":{"pli":"Paṭibalo bhave tesaṁ, ","eng":"I would have had the power ","html":"<span class='verse-line'>{}</span>"},"cp11:8.4":{"pli":"yāva rajjampi mānusaṁ. ","eng":"to defeat even a kingdom of men. ","html":"<span class='verse-line'>{}</span></p>"},"cp11:9.1":{"pli":"Api cāhaṁ sīlarakkhāya, ","eng":"Nevertheless, for the sake of guarding my ethics, ","html":"<p><span class='verse-line'>{}</span>"},"cp11:9.2":{"pli":"Sīlapāramipūriyā; ","eng":"and fulfilling my perfection of ethics, ","html":"<span class='verse-line'>{}</span>"},"cp11:9.3":{"pli":"Na karomi citte aññathattaṁ, ","eng":"I did not let my mind change, ","html":"<span class='verse-line'>{}</span>"},"cp11:9.4":{"pli":"Pakkhipantaṁ mamāḷake. ","eng":"even as they caged me. ","html":"<span class='verse-line'>{}</span></p>"},"cp11:10.1":{"pli":"Yadi te maṁ tattha koṭṭeyyuṁ, ","eng":"And even were they to beat me ","html":"<p><span class='verse-line'>{}</span>"},"cp11:10.2":{"pli":"pharasūhi tomarehi ca; ","eng":"with hatchets and lances, ","html":"<span class='verse-line'>{}</span>"},"cp11:10.3":{"pli":"Neva tesaṁ pakuppeyyaṁ, ","eng":"I would never become upset, ","html":"<span class='verse-line'>{}</span>"},"cp11:10.4":{"pli":"sīlakhaṇḍabhayā mamā”ti. ","eng":"for fear of violating my ethics.” ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"cp11:11.1":{"pli":"Mātuposakacariyaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"cp12":{"cp12:0.1":{"pli":"Cariyāpiṭaka ","eng":"The Conduct Leading to Buddhahood ","html":"<article id='cp12'><header><ul><li class='division'>{}</li>"},"cp12:0.2":{"pli":"Hatthināgavagga ","eng":"The Chapter on an Elephant ","html":"<li>{}</li>"},"cp12:0.3":{"pli":"Sīlapāramī 2 ","eng":"The Perfection of Ethics (2nd) ","html":"<li>{}</li></ul>"},"cp12:0.4":{"pli":"Bhūridattacariya ","eng":"The Dragon Bhūridatta’s Conduct ","html":"<h1 class='sutta-title'>{}</h1></header>"},"cp12:1.1":{"pli":"“Punāparaṁ yadā homi, ","eng":"“Then again when I was ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"cp12:1.2":{"pli":"bhūridatto mahiddhiko; ","eng":"Bhūridatta, a dragon of great psychic power, ","html":"<span class='verse-line'>{}</span>","comm":"The text does not specify what kind of creature he was, thus relying on the fuller details of <a href='index.html?q=ja543'>Ja 543</a>. "},"cp12:1.3":{"pli":"Virūpakkhena mahāraññā, ","eng":"together with Virūpakkha the Great King ","html":"<span class='verse-line'>{}</span>"},"cp12:1.4":{"pli":"devalokamagañchahaṁ. ","eng":"I went to a heavenly realm. ","html":"<span class='verse-line'>{}</span></p>"},"cp12:2.1":{"pli":"Tattha passitvāhaṁ deve, ","eng":"There I saw gods ","html":"<p><span class='verse-line'>{}</span>"},"cp12:2.2":{"pli":"ekantaṁ sukhasamappite; ","eng":"wholly given over to pleasure. ","html":"<span class='verse-line'>{}</span>"},"cp12:2.3":{"pli":"Taṁ saggagamanatthāya, ","eng":"For the sake of going to that heaven, ","html":"<span class='verse-line'>{}</span>"},"cp12:2.4":{"pli":"sīlabbataṁ samādiyiṁ. ","eng":"I undertook the observance of ethics. ","html":"<span class='verse-line'>{}</span></p>"},"cp12:3.1":{"pli":"Sarīrakiccaṁ katvāna, ","eng":"After tending to me physical needs, ","html":"<p><span class='verse-line'>{}</span>"},"cp12:3.2":{"pli":"bhutvā yāpanamattakaṁ; ","eng":"and eating enough to get by, ","html":"<span class='verse-line'>{}</span>"},"cp12:3.3":{"pli":"Caturo aṅge adhiṭṭhāya, ","eng":"I resolved on the four factors, ","html":"<span class='verse-line'>{}</span>"},"cp12:3.4":{"pli":"semi vammikamuddhani. ","eng":"and lay down atop a termite mound, thinking: ","html":"<span class='verse-line'>{}</span></p>"},"cp12:4.1":{"pli":"‘Chaviyā cammena maṁsena, ","eng":"‘My outer skin and inner, flesh, ","html":"<p><span class='verse-line'>{}</span>"},"cp12:4.2":{"pli":"Nahāruaṭṭhikehi vā; ","eng":"sinews and bones: ","html":"<span class='verse-line'>{}</span>"},"cp12:4.3":{"pli":"Yassa etena karaṇīyaṁ, ","eng":"whoever has use for these, ","html":"<span class='verse-line'>{}</span>"},"cp12:4.4":{"pli":"Dinnaṁyeva harātu so’. ","eng":"they are already given, please take them.’ ","html":"<span class='verse-line'>{}</span></p>"},"cp12:5.1":{"pli":"Saṁsito akataññunā, ","eng":"While lying there the ingrate ","html":"<p><span class='verse-line'>{}</span>"},"cp12:5.2":{"pli":"ālampāyano mamaggahi; ","eng":"Ālampāyana grabbed me. ","html":"<span class='verse-line'>{}</span>"},"cp12:5.3":{"pli":"Peḷāya pakkhipitvāna, ","eng":"He threw me in a basket ","html":"<span class='verse-line'>{}</span>"},"cp12:5.4":{"pli":"kīḷeti maṁ tahiṁ tahiṁ. ","eng":"and made me perform in places all over. ","html":"<span class='verse-line'>{}</span></p>","comm":"The text conflates a divine <i lang='pi' translate='no'>nāga</i> with a cobra in a way we don’t really find in the suttas. "},"cp12:6.1":{"pli":"Peḷāya pakkhipantepi, ","eng":"Though thrown in a basket ","html":"<p><span class='verse-line'>{}</span>"},"cp12:6.2":{"pli":"sammaddantepi pāṇinā; ","eng":"and crushed by his hands, ","html":"<span class='verse-line'>{}</span>"},"cp12:6.3":{"pli":"Ālampāyane na kuppāmi, ","eng":"I did not get upset with Ālampāyana, ","html":"<span class='verse-line'>{}</span>"},"cp12:6.4":{"pli":"sīlakhaṇḍabhayā mama. ","eng":"for fear of breaking my ethics. ","html":"<span class='verse-line'>{}</span></p>"},"cp12:7.1":{"pli":"Sakajīvitapariccāgo, ","eng":"To give up my own life ","html":"<p><span class='verse-line'>{}</span>"},"cp12:7.2":{"pli":"tiṇato lahuko mama; ","eng":"was as light as a blade of grass. ","html":"<span class='verse-line'>{}</span>"},"cp12:7.3":{"pli":"Sīlavītikkamo mayhaṁ, ","eng":"To transgress my ethical principles ","html":"<span class='verse-line'>{}</span>"},"cp12:7.4":{"pli":"pathavīuppatanaṁ viya. ","eng":"was like overturning the earth. ","html":"<span class='verse-line'>{}</span></p>"},"cp12:8.1":{"pli":"Nirantaraṁ jātisataṁ, ","eng":"In a hundred successive lives ","html":"<p><span class='verse-line'>{}</span>"},"cp12:8.2":{"pli":"cajeyyaṁ mama jīvitaṁ; ","eng":"I would give up my own life. ","html":"<span class='verse-line'>{}</span>"},"cp12:8.3":{"pli":"Neva sīlaṁ pabhindeyyaṁ, ","eng":"I would not even violate my ethics ","html":"<span class='verse-line'>{}</span>"},"cp12:8.4":{"pli":"catuddīpāna hetupi. ","eng":"for the sake of the four continents. ","html":"<span class='verse-line'>{}</span></p>"},"cp12:9.1":{"pli":"Api cāhaṁ sīlarakkhāya, ","eng":"For the sake of protecting ethics, ","html":"<p><span class='verse-line'>{}</span>"},"cp12:9.2":{"pli":"Sīlapāramipūriyā; ","eng":"and fulfilling my perfection of ethics, ","html":"<span class='verse-line'>{}</span>"},"cp12:9.3":{"pli":"Na karomi citte aññathattaṁ, ","eng":"I did not let my mind change, ","html":"<span class='verse-line'>{}</span>"},"cp12:9.4":{"pli":"Pakkhipantampi peḷake”ti. ","eng":"even when thrown in a basket.” ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"cp12:10.1":{"pli":"Bhūridattacariyaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"cp13":{"cp13:0.1":{"pli":"Cariyāpiṭaka ","eng":"The Conduct Leading to Buddhahood ","html":"<article id='cp13'><header><ul><li class='division'>{}</li>"},"cp13:0.2":{"pli":"Hatthināgavagga ","eng":"The Chapter on an Elephant ","html":"<li>{}</li>"},"cp13:0.3":{"pli":"Sīlapāramī 3 ","eng":"The Perfection of Ethics (3rd) ","html":"<li>{}</li></ul>"},"cp13:0.4":{"pli":"Campeyyanāgacariya ","eng":"The Dragon Campeyyaka’s Conduct ","html":"<h1 class='sutta-title'>{}</h1></header>"},"cp13:1.1":{"pli":"“Punāparaṁ yadā homi, ","eng":"“Then again when I was ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"cp13:1.2":{"pli":"campeyyako mahiddhiko; ","eng":"Campeyyaka, a dragon of great psychic power, ","html":"<span class='verse-line'>{}</span>","comm":"The titular deity of the people of Campā. "},"cp13:1.3":{"pli":"Tadāpi dhammiko āsiṁ, ","eng":"I was just, ","html":"<span class='verse-line'>{}</span>"},"cp13:1.4":{"pli":"sīlabbatasamappito. ","eng":"furnished with precepts and vows. ","html":"<span class='verse-line'>{}</span></p>"},"cp13:2.1":{"pli":"Tadāpi maṁ dhammacāriṁ, ","eng":"Then the snake-charmer who caught me ","html":"<p><span class='verse-line'>{}</span>"},"cp13:2.2":{"pli":"upavutthaṁ uposathaṁ; ","eng":"lived righteously, ","html":"<span class='verse-line'>{}</span>"},"cp13:2.3":{"pli":"Ahituṇḍiko gahetvāna, ","eng":"observing the Sabbath, ","html":"<span class='verse-line'>{}</span>"},"cp13:2.4":{"pli":"rājadvāramhi kīḷati. ","eng":"and he made me perform at the royal gate. ","html":"<span class='verse-line'>{}</span></p>"},"cp13:3.1":{"pli":"Yaṁ yaṁ so vaṇṇaṁ cintayi, ","eng":"Whatever color he thought of—","html":"<p><span class='verse-line'>{}</span>"},"cp13:3.2":{"pli":"nīlaṁva pītalohitaṁ; ","eng":"blue, yellow, or red—","html":"<span class='verse-line'>{}</span>"},"cp13:3.3":{"pli":"Tassa cittānuvattanto, ","eng":"I conformed to his wish, ","html":"<span class='verse-line'>{}</span>"},"cp13:3.4":{"pli":"homi cintitasannibho. ","eng":"taking the appearance of his thought. ","html":"<span class='verse-line'>{}</span></p>"},"cp13:4.1":{"pli":"Thalaṁ kareyyamudakaṁ, ","eng":"I could turn dry land to water, ","html":"<p><span class='verse-line'>{}</span>"},"cp13:4.2":{"pli":"udakampi thalaṁ kare; ","eng":"and water to dry land. ","html":"<span class='verse-line'>{}</span>"},"cp13:4.3":{"pli":"Yadihaṁ tassa pakuppeyyaṁ, ","eng":"If I were upset with him ","html":"<span class='verse-line'>{}</span>"},"cp13:4.4":{"pli":"khaṇena chārikaṁ kare. ","eng":"I could reduce him to ash in an instant. ","html":"<span class='verse-line'>{}</span></p>"},"cp13:5.1":{"pli":"Yadi cittavasī hessaṁ, ","eng":"If I was under the sway of my thoughts, ","html":"<p><span class='verse-line'>{}</span>"},"cp13:5.2":{"pli":"parihāyissāmi sīlato; ","eng":"I would have fallen from my ethics. ","html":"<span class='verse-line'>{}</span>"},"cp13:5.3":{"pli":"Sīlena parihīnassa, ","eng":"But one who has fallen from their ethics ","html":"<span class='verse-line'>{}</span>"},"cp13:5.4":{"pli":"uttamattho na sijjhati. ","eng":"does not succeed at the highest goal. ","html":"<span class='verse-line'>{}</span></p>"},"cp13:6.1":{"pli":"Kāmaṁ bhijjatuyaṁ kāyo, ","eng":"Gladly, let this body be broken! ","html":"<p><span class='verse-line'>{}</span>"},"cp13:6.2":{"pli":"idheva vikirīyatu; ","eng":"Let it be scattered in this very place! ","html":"<span class='verse-line'>{}</span>"},"cp13:6.3":{"pli":"Neva sīlaṁ pabhindeyyaṁ, ","eng":"Not even for that would I break my ethics, ","html":"<span class='verse-line'>{}</span>"},"cp13:6.4":{"pli":"vikirante bhusaṁ viyā”ti. ","eng":"if it were being scattered like hay.” ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"cp13:7.1":{"pli":"Campeyyanāgacariyaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"cp14":{"cp14:0.1":{"pli":"Cariyāpiṭaka ","eng":"The Conduct Leading to Buddhahood ","html":"<article id='cp14'><header><ul><li class='division'>{}</li>"},"cp14:0.2":{"pli":"Hatthināgavagga ","eng":"The Chapter on an Elephant ","html":"<li>{}</li>"},"cp14:0.3":{"pli":"Sīlapāramī 4 ","eng":"The Perfection of Ethics (4th) ","html":"<li>{}</li></ul>"},"cp14:0.4":{"pli":"Cūḷabodhicariya ","eng":"Cūḷabodhi’s Conduct ","html":"<h1 class='sutta-title'>{}</h1></header>"},"cp14:1.1":{"pli":"“Punāparaṁ yadā homi, ","eng":"“Then again when I was ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"cp14:1.2":{"pli":"cūḷabodhi susīlavā; ","eng":"the very virtuous Cūḷabodhi, ","html":"<span class='verse-line'>{}</span>"},"cp14:1.3":{"pli":"Bhavaṁ disvāna bhayato, ","eng":"seeing rebirth as fearful, ","html":"<span class='verse-line'>{}</span>"},"cp14:1.4":{"pli":"nekkhammaṁ abhinikkhamiṁ. ","eng":"I renounced worldly life. ","html":"<span class='verse-line'>{}</span></p>"},"cp14:2.1":{"pli":"Yā me dutiyikā āsi, ","eng":"She who had been my partner, ","html":"<p><span class='verse-line'>{}</span>"},"cp14:2.2":{"pli":"brāhmaṇī kanakasannibhā; ","eng":"a brahmin lady with golden skin, ","html":"<span class='verse-line'>{}</span>"},"cp14:2.3":{"pli":"Sāpi vaṭṭe anapekkhā, ","eng":"unconcerned with the cycle of rebirths, ","html":"<span class='verse-line'>{}</span>"},"cp14:2.4":{"pli":"nekkhammaṁ abhinikkhami. ","eng":"also renounced worldly life. ","html":"<span class='verse-line'>{}</span></p>"},"cp14:3.1":{"pli":"Nirālayā chinnabandhū, ","eng":"Without clinging, cutting off family, ","html":"<p><span class='verse-line'>{}</span>"},"cp14:3.2":{"pli":"anapekkhā kule gaṇe; ","eng":"unconcerned with family or group, ","html":"<span class='verse-line'>{}</span>"},"cp14:3.3":{"pli":"Carantā gāmanigamaṁ, ","eng":"we walked from village to town ","html":"<span class='verse-line'>{}</span>"},"cp14:3.4":{"pli":"bārāṇasimupāgamuṁ. ","eng":"until we reached Varanasi. ","html":"<span class='verse-line'>{}</span></p>"},"cp14:4.1":{"pli":"Tattha vasāma nipakā, ","eng":"There we lived alert, ","html":"<p><span class='verse-line'>{}</span>"},"cp14:4.2":{"pli":"asaṁsaṭṭhā kule gaṇe; ","eng":"mixing not with a family or group. ","html":"<span class='verse-line'>{}</span>"},"cp14:4.3":{"pli":"Nirākule appasadde, ","eng":"Quiet and undisturbed, ","html":"<span class='verse-line'>{}</span>"},"cp14:4.4":{"pli":"rājuyyāne vasāmubho. ","eng":"we both stayed in the royal park. ","html":"<span class='verse-line'>{}</span></p>"},"cp14:5.1":{"pli":"Uyyānadassanaṁ gantvā, ","eng":"Visiting the park, ","html":"<p><span class='verse-line'>{}</span>"},"cp14:5.2":{"pli":"rājā addasa brāhmaṇiṁ; ","eng":"the king saw the brahmin lady. ","html":"<span class='verse-line'>{}</span>"},"cp14:5.3":{"pli":"Upagamma mamaṁ pucchi, ","eng":"He approached me and asked, ","html":"<span class='verse-line'>{}</span>"},"cp14:5.4":{"pli":"‘tuyhesā kā kassa bhariyā’. ","eng":"‘Is she your wife? Or whose is she?’ ","html":"<span class='verse-line'>{}</span></p>"},"cp14:6.1":{"pli":"Evaṁ vutte, ahaṁ tassa, ","eng":"When he said this, to him ","html":"<p><span class='verse-line'>{}</span>"},"cp14:6.2":{"pli":"idaṁ vacanamabraviṁ; ","eng":"I said the following. ","html":"<span class='verse-line'>{}</span>"},"cp14:6.3":{"pli":"‘Na mayhaṁ bhariyā esā, ","eng":"‘She is not my wife. ","html":"<span class='verse-line'>{}</span>"},"cp14:6.4":{"pli":"sahadhammā ekasāsanī’. ","eng":"We share the same teaching and belief.’ ","html":"<span class='verse-line'>{}</span></p>"},"cp14:7.1":{"pli":"Tissā sārattagadhito, ","eng":"Infatuated with her, ","html":"<p><span class='verse-line'>{}</span>"},"cp14:7.2":{"pli":"gāhāpetvāna ceṭake; ","eng":"he had his men seize her. ","html":"<span class='verse-line'>{}</span>"},"cp14:7.3":{"pli":"Nippīḷayanto balasā, ","eng":"Compelling her by force ","html":"<span class='verse-line'>{}</span>"},"cp14:7.4":{"pli":"antepuraṁ pavesayi. ","eng":"he brought her to the royal compound. ","html":"<span class='verse-line'>{}</span></p>"},"cp14:8.1":{"pli":"Odapattakiyā mayhaṁ, ","eng":"She who became mine by touching a water-jar, ","html":"<p><span class='verse-line'>{}</span>"},"cp14:8.2":{"pli":"sahajā ekasāsanī; ","eng":"born together, one in beliefs, ","html":"<span class='verse-line'>{}</span>"},"cp14:8.3":{"pli":"Ākaḍḍhitvā nayantiyā, ","eng":"when he dragged her away, ","html":"<span class='verse-line'>{}</span>"},"cp14:8.4":{"pli":"kopo me upapajjatha. ","eng":"I felt so angry. ","html":"<span class='verse-line'>{}</span></p>"},"cp14:9.1":{"pli":"Saha kope samuppanne, ","eng":"Together with the arising of anger, ","html":"<p><span class='verse-line'>{}</span>"},"cp14:9.2":{"pli":"sīlabbatamanussariṁ; ","eng":"I remembered my precepts and vows, ","html":"<span class='verse-line'>{}</span>"},"cp14:9.3":{"pli":"Tattheva kopaṁ niggaṇhiṁ, ","eng":"and right there controlled my anger, ","html":"<span class='verse-line'>{}</span>"},"cp14:9.4":{"pli":"nādāsiṁ vaḍḍhitūpari. ","eng":"I did not allow it to grow. ","html":"<span class='verse-line'>{}</span></p>"},"cp14:10.1":{"pli":"Yadi naṁ brāhmaṇiṁ koci, ","eng":"If anyone were to attack ","html":"<p><span class='verse-line'>{}</span>"},"cp14:10.2":{"pli":"koṭṭeyya tiṇhasattiyā; ","eng":"that brahmin lady with a sharp knife, ","html":"<span class='verse-line'>{}</span>"},"cp14:10.3":{"pli":"Neva sīlaṁ pabhindeyyaṁ, ","eng":"not even for that would I violate my ethics, ","html":"<span class='verse-line'>{}</span>"},"cp14:10.4":{"pli":"bodhiyāyeva kāraṇā. ","eng":"because it was solely for awakening. ","html":"<span class='verse-line'>{}</span></p>"},"cp14:11.1":{"pli":"Na mesā brāhmaṇī dessā, ","eng":"I did not dislike the brahmin lady, ","html":"<p><span class='verse-line'>{}</span>"},"cp14:11.2":{"pli":"napi me balaṁ na vijjati; ","eng":"nor did I lack the strength. ","html":"<span class='verse-line'>{}</span>"},"cp14:11.3":{"pli":"Sabbaññutaṁ piyaṁ mayhaṁ, ","eng":"But because omniscience is precious to me, ","html":"<span class='verse-line'>{}</span>"},"cp14:11.4":{"pli":"tasmā sīlānurakkhisan”ti. ","eng":"that’s why I guarded my ethics.” ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"cp14:12.1":{"pli":"Cūḷabodhicariyaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"cp15":{"cp15:0.1":{"pli":"Cariyāpiṭaka ","eng":"The Conduct Leading to Buddhahood ","html":"<article id='cp15'><header><ul><li class='division'>{}</li>"},"cp15:0.2":{"pli":"Hatthināgavagga ","eng":"The Chapter on an Elephant ","html":"<li>{}</li>"},"cp15:0.3":{"pli":"Sīlapāramī 5 ","eng":"The Perfection of Ethics (5th) ","html":"<li>{}</li></ul>"},"cp15:0.4":{"pli":"Mahiṁsarājacariya ","eng":"The Buffalo King’s Conduct ","html":"<h1 class='sutta-title'>{}</h1></header>"},"cp15:1.1":{"pli":"“Punāparaṁ yadā homi, ","eng":"“Then again when I was ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"cp15:1.2":{"pli":"mahiṁso pavanacārako; ","eng":"a buffalo who roamed the forest, ","html":"<span class='verse-line'>{}</span>"},"cp15:1.3":{"pli":"Pavaḍḍhakāyo balavā, ","eng":"large in body and strong, ","html":"<span class='verse-line'>{}</span>"},"cp15:1.4":{"pli":"mahanto bhīmadassano. ","eng":"big and scary to see. ","html":"<span class='verse-line'>{}</span></p>"},"cp15:2.1":{"pli":"Pabbhāre giridugge ca, ","eng":"In a cave, a craggy hillside, ","html":"<p><span class='verse-line'>{}</span>"},"cp15:2.2":{"pli":"rukkhamūle dakāsaye; ","eng":"at a tree root or a waterhole, ","html":"<span class='verse-line'>{}</span>"},"cp15:2.3":{"pli":"Hotettha ṭhānaṁ mahiṁsānaṁ, ","eng":"there’d be somewhere for buffalos, ","html":"<span class='verse-line'>{}</span>"},"cp15:2.4":{"pli":"koci koci tahiṁ tahiṁ. ","eng":"in one place or another. ","html":"<span class='verse-line'>{}</span></p>"},"cp15:3.1":{"pli":"Vicaranto brahāraññe, ","eng":"Wandering the mighty forest, ","html":"<p><span class='verse-line'>{}</span>"},"cp15:3.2":{"pli":"ṭhānaṁ addasa bhaddakaṁ; ","eng":"I saw a fine spot. ","html":"<span class='verse-line'>{}</span>"},"cp15:3.3":{"pli":"Taṁ ṭhānaṁ upagantvāna, ","eng":"Having gone there, ","html":"<span class='verse-line'>{}</span>"},"cp15:3.4":{"pli":"tiṭṭhāmi ca sayāmi ca. ","eng":"I stood and lay to rest. ","html":"<span class='verse-line'>{}</span></p>"},"cp15:4.1":{"pli":"Athettha kapimāgantvā, ","eng":"Then a monkey came along, ","html":"<p><span class='verse-line'>{}</span>"},"cp15:4.2":{"pli":"pāpo anariyo lahu; ","eng":"wicked, ignoble, and nimble. ","html":"<span class='verse-line'>{}</span>"},"cp15:4.3":{"pli":"Khandhe nalāṭe bhamuke, ","eng":"On my shoulder, forehead, and eyebrows, ","html":"<span class='verse-line'>{}</span>"},"cp15:4.4":{"pli":"mutteti ohadeti taṁ. ","eng":"he peed and pooed. ","html":"<span class='verse-line'>{}</span></p>"},"cp15:5.1":{"pli":"Sakimpi divasaṁ dutiyaṁ, ","eng":"Not just that day, but a second, ","html":"<p><span class='verse-line'>{}</span>"},"cp15:5.2":{"pli":"tatiyaṁ catutthampi ca; ","eng":"a third, and a fourth; ","html":"<span class='verse-line'>{}</span>"},"cp15:5.3":{"pli":"Dūseti maṁ sabbakālaṁ, ","eng":"he soiled me all the time, ","html":"<span class='verse-line'>{}</span>"},"cp15:5.4":{"pli":"tena homi upadduto. ","eng":"he was harrying me. ","html":"<span class='verse-line'>{}</span></p>"},"cp15:6.1":{"pli":"Mamaṁ upaddutaṁ disvā, ","eng":"Seeing me being harried, ","html":"<p><span class='verse-line'>{}</span>"},"cp15:6.2":{"pli":"yakkho maṁ idamabravi; ","eng":"a spirit said to me: ","html":"<span class='verse-line'>{}</span>"},"cp15:6.3":{"pli":"‘Nāsehetaṁ chavaṁ pāpaṁ, ","eng":"‘Kill that vile, wicked thing ","html":"<span class='verse-line'>{}</span>"},"cp15:6.4":{"pli":"siṅgehi ca khurehi ca’. ","eng":"with your horns and hooves.’ ","html":"<span class='verse-line'>{}</span></p>"},"cp15:7.1":{"pli":"Evaṁ vutte, tadā yakkhe, ","eng":"When he spoke, I said ","html":"<p><span class='verse-line'>{}</span>"},"cp15:7.2":{"pli":"ahaṁ taṁ idamabraviṁ; ","eng":"this to that spirit: ","html":"<span class='verse-line'>{}</span>"},"cp15:7.3":{"pli":"‘Kiṁ tvaṁ makkhesi kuṇapena, ","eng":"‘Why would you smear me ","html":"<span class='verse-line'>{}</span>"},"cp15:7.4":{"pli":"pāpena anariyena maṁ. ","eng":"with a wicked, ignoble carcass? ","html":"<span class='verse-line'>{}</span></p>"},"cp15:8.1":{"pli":"Yadihaṁ tassa pakuppeyyaṁ, ","eng":"If I were upset with him ","html":"<p><span class='verse-line'>{}</span>"},"cp15:8.2":{"pli":"tato hīnataro bhave; ","eng":"I would degrade myself, ","html":"<span class='verse-line'>{}</span>"},"cp15:8.3":{"pli":"Sīlañca me pabhijjeyya, ","eng":"violating my ethics, ","html":"<span class='verse-line'>{}</span>"},"cp15:8.4":{"pli":"viññū ca garaheyyu maṁ. ","eng":"and being criticized by sensible people. ","html":"<span class='verse-line'>{}</span></p>"},"cp15:9.1":{"pli":"Hīḷitā jīvitā vāpi, ","eng":"Better to die from purity ","html":"<p><span class='verse-line'>{}</span>"},"cp15:9.2":{"pli":"parisuddhena mataṁ varaṁ; ","eng":"than live in shame. ","html":"<span class='verse-line'>{}</span>"},"cp15:9.3":{"pli":"Kyāhaṁ jīvitahetūpi, ","eng":"How could I, for the sake of life, ","html":"<span class='verse-line'>{}</span>"},"cp15:9.4":{"pli":"kāhāmi paraheṭhanaṁ’. ","eng":"harm another?’ ","html":"<span class='verse-line'>{}</span></p>"},"cp15:10.1":{"pli":"Mamevāyaṁ maññamāno, ","eng":"Thinking of me, this one ","html":"<p><span class='verse-line'>{}</span>"},"cp15:10.2":{"pli":"aññepevaṁ karissati; ","eng":"will do the same to others, ","html":"<span class='verse-line'>{}</span>"},"cp15:10.3":{"pli":"Teva tassa vadhissanti, ","eng":"and for that they will kill him. ","html":"<span class='verse-line'>{}</span>"},"cp15:10.4":{"pli":"sā me mutti bhavissati. ","eng":"Then I shall be free. ","html":"<span class='verse-line'>{}</span></p>"},"cp15:11.1":{"pli":"Hīnamajjhimaukkaṭṭhe, ","eng":"Forgiving disrespect ","html":"<p><span class='verse-line'>{}</span>"},"cp15:11.2":{"pli":"sahanto avamānitaṁ; ","eng":"from the low, middle and high, ","html":"<span class='verse-line'>{}</span>"},"cp15:11.3":{"pli":"Evaṁ labhati sappañño, ","eng":"the wise one gains ","html":"<span class='verse-line'>{}</span>"},"cp15:11.4":{"pli":"manasā yathāpatthitan”ti. ","eng":"their heart’s desire.” ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"cp15:12.1":{"pli":"Mahiṁsarājacariyaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}