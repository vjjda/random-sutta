{"ja446":{"ja446:0.1":{"pli":"Jātaka ","html":"<article id='ja446'><header><ul><li class='division'>{}</li>"},"ja446:0.2":{"pli":"Dasakanipāta ","html":"<li>{}</li>"},"ja446:0.3":{"pli":"Catudvāravagga ","html":"<li>{}</li></ul>"},"ja446:0.4":{"pli":"8. Takkalajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja446:1.1":{"pli":"“Na takkalā santi na āluvāni, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja446:1.2":{"pli":"Na biḷāliyo na kaḷambāni tāta; ","html":"<span class='verse-line'>{}</span>"},"ja446:1.3":{"pli":"Eko araññamhi susānamajjhe, ","html":"<span class='verse-line'>{}</span>"},"ja446:1.4":{"pli":"Kimatthiko tāta khaṇāsi kāsuṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja446:2.1":{"pli":"“Pitāmaho tāta sudubbalo te, ","html":"<p><span class='verse-line'>{}</span>"},"ja446:2.2":{"pli":"Anekabyādhīhi dukhena phuṭṭho; ","html":"<span class='verse-line'>{}</span>"},"ja446:2.3":{"pli":"Tamajjahaṁ nikhaṇissāmi sobbhe, ","html":"<span class='verse-line'>{}</span>"},"ja446:2.4":{"pli":"Na hissa taṁ jīvitaṁ rocayāmi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja446:3.1":{"pli":"“Saṅkappametaṁ paṭiladdha pāpakaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja446:3.2":{"pli":"Accāhitaṁ kamma karosi luddaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja446:3.3":{"pli":"Mayāpi tāta paṭilacchase tuvaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja446:3.4":{"pli":"Etādisaṁ kamma jarūpanīto; ","html":"<span class='verse-line'>{}</span>"},"ja446:3.5":{"pli":"Taṁ kullavattaṁ anuvattamāno, ","html":"<span class='verse-line'>{}</span>"},"ja446:3.6":{"pli":"Ahampi taṁ nikhaṇissāmi sobbhe”. ","html":"<span class='verse-line'>{}</span></p>"},"ja446:4.1":{"pli":"“Pharusāhi vācāhi pakubbamāno, ","html":"<p><span class='verse-line'>{}</span>"},"ja446:4.2":{"pli":"Āsajja maṁ tvaṁ vadase kumāra; ","html":"<span class='verse-line'>{}</span>"},"ja446:4.3":{"pli":"Putto mamaṁ orasako samāno, ","html":"<span class='verse-line'>{}</span>"},"ja446:4.4":{"pli":"Ahitānukampī mama tvaṁsi putta”. ","html":"<span class='verse-line'>{}</span></p>"},"ja446:5.1":{"pli":"“Na tāhaṁ tāta ahitānukampī, ","html":"<p><span class='verse-line'>{}</span>"},"ja446:5.2":{"pli":"Hitānukampī te ahampi tāta; ","html":"<span class='verse-line'>{}</span>"},"ja446:5.3":{"pli":"Pāpañca taṁ kamma pakubbamānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja446:5.4":{"pli":"Arahāmi no vārayituṁ tato”. ","html":"<span class='verse-line'>{}</span></p>"},"ja446:6.1":{"pli":"“Yo mātaraṁ vā pitaraṁ saviṭṭha, ","html":"<p><span class='verse-line'>{}</span>"},"ja446:6.2":{"pli":"Adūsake hiṁsati pāpadhammo; ","html":"<span class='verse-line'>{}</span>"},"ja446:6.3":{"pli":"Kāyassa bhedā abhisamparāyaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja446:6.4":{"pli":"Asaṁsayaṁ so nirayaṁ upeti. ","html":"<span class='verse-line'>{}</span></p>"},"ja446:7.1":{"pli":"Yo mātaraṁ vā pitaraṁ saviṭṭha, ","html":"<p><span class='verse-line'>{}</span>"},"ja446:7.2":{"pli":"Annena pānena upaṭṭhahāti; ","html":"<span class='verse-line'>{}</span>"},"ja446:7.3":{"pli":"Kāyassa bhedā abhisamparāyaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja446:7.4":{"pli":"Asaṁsayaṁ so sugatiṁ upeti. ","html":"<span class='verse-line'>{}</span></p>"},"ja446:8.1":{"pli":"Na me tvaṁ putta ahitānukampī, ","html":"<p><span class='verse-line'>{}</span>"},"ja446:8.2":{"pli":"Hitānukampī me tvaṁsi putta; ","html":"<span class='verse-line'>{}</span>"},"ja446:8.3":{"pli":"Ahañca taṁ mātarā vuccamāno, ","html":"<span class='verse-line'>{}</span>"},"ja446:8.4":{"pli":"Etādisaṁ kamma karomi luddaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja446:9.1":{"pli":"“Yā te sā bhariyā anariyarūpā, ","html":"<p><span class='verse-line'>{}</span>"},"ja446:9.2":{"pli":"Mātā mamesā sakiyā janetti; ","html":"<span class='verse-line'>{}</span>"},"ja446:9.3":{"pli":"Niddhāpaye tañca sakā agārā, ","html":"<span class='verse-line'>{}</span>"},"ja446:9.4":{"pli":"Aññampi te sā dukhamāvaheyya. ","html":"<span class='verse-line'>{}</span></p>"},"ja446:10.1":{"pli":"Yā te sā bhariyā anariyarūpā, ","html":"<p><span class='verse-line'>{}</span>"},"ja446:10.2":{"pli":"Mātā mamesā sakiyā janetti; ","html":"<span class='verse-line'>{}</span>"},"ja446:10.3":{"pli":"Dantā kareṇūva vasūpanītā, ","html":"<span class='verse-line'>{}</span>"},"ja446:10.4":{"pli":"Sā pāpadhammā punarāvajātū”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja446:11.1":{"pli":"Takkalajātakaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja447":{"ja447:0.1":{"pli":"Jātaka ","html":"<article id='ja447'><header><ul><li class='division'>{}</li>"},"ja447:0.2":{"pli":"Dasakanipāta ","html":"<li>{}</li>"},"ja447:0.3":{"pli":"Catudvāravagga ","html":"<li>{}</li></ul>"},"ja447:0.4":{"pli":"9. Mahādhammapālajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja447:1.1":{"pli":"“Kiṁ te vataṁ kiṁ pana brahmacariyaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja447:1.2":{"pli":"Kissa suciṇṇassa ayaṁ vipāko; ","html":"<span class='verse-line'>{}</span>"},"ja447:1.3":{"pli":"Akkhāhi me brāhmaṇa etamatthaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja447:1.4":{"pli":"Kasmā nu tumhaṁ daharā na miyyare”. ","html":"<span class='verse-line'>{}</span></p>"},"ja447:2.1":{"pli":"“Dhammaṁ carāma na musā bhaṇāma, ","html":"<p><span class='verse-line'>{}</span>"},"ja447:2.2":{"pli":"Pāpāni kammāni parivajjayāma; ","html":"<span class='verse-line'>{}</span>"},"ja447:2.3":{"pli":"Anariyaṁ parivajjemu sabbaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja447:2.4":{"pli":"Tasmā hi amhaṁ daharā na miyyare. ","html":"<span class='verse-line'>{}</span></p>"},"ja447:3.1":{"pli":"Suṇoma dhammaṁ asataṁ satañca, ","html":"<p><span class='verse-line'>{}</span>"},"ja447:3.2":{"pli":"Na cāpi dhammaṁ asataṁ rocayāma; ","html":"<span class='verse-line'>{}</span>"},"ja447:3.3":{"pli":"Hitvā asante na jahāma sante, ","html":"<span class='verse-line'>{}</span>"},"ja447:3.4":{"pli":"Tasmā hi amhaṁ daharā na miyyare. ","html":"<span class='verse-line'>{}</span></p>"},"ja447:4.1":{"pli":"Pubbeva dānā sumanā bhavāma, ","html":"<p><span class='verse-line'>{}</span>"},"ja447:4.2":{"pli":"Dadampi ve attamanā bhavāma; ","html":"<span class='verse-line'>{}</span>"},"ja447:4.3":{"pli":"Datvāpi ve nānutappāma pacchā, ","html":"<span class='verse-line'>{}</span>"},"ja447:4.4":{"pli":"Tasmā hi amhaṁ daharā na miyyare. ","html":"<span class='verse-line'>{}</span></p>"},"ja447:5.1":{"pli":"Samaṇe mayaṁ brāhmaṇe addhike ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja447:5.2":{"pli":"Vanibbake yācanake dalidde; ","html":"<span class='verse-line'>{}</span>"},"ja447:5.3":{"pli":"Annena pānena abhitappayāma, ","html":"<span class='verse-line'>{}</span>"},"ja447:5.4":{"pli":"Tasmā hi amhaṁ daharā na miyyare. ","html":"<span class='verse-line'>{}</span></p>"},"ja447:6.1":{"pli":"Mayañca bhariyaṁ nātikkamāma, ","html":"<p><span class='verse-line'>{}</span>"},"ja447:6.2":{"pli":"Amhe ca bhariyā nātikkamanti; ","html":"<span class='verse-line'>{}</span>"},"ja447:6.3":{"pli":"Aññatra tāhi brahmacariyaṁ carāma, ","html":"<span class='verse-line'>{}</span>"},"ja447:6.4":{"pli":"Tasmā hi amhaṁ daharā na miyyare. ","html":"<span class='verse-line'>{}</span></p>"},"ja447:7.1":{"pli":"Pāṇātipātā viramāma sabbe, ","html":"<p><span class='verse-line'>{}</span>"},"ja447:7.2":{"pli":"Loke adinnaṁ parivajjayāma; ","html":"<span class='verse-line'>{}</span>"},"ja447:7.3":{"pli":"Amajjapā nopi musā bhaṇāma, ","html":"<span class='verse-line'>{}</span>"},"ja447:7.4":{"pli":"Tasmā hi amhaṁ daharā na miyyare. ","html":"<span class='verse-line'>{}</span></p>"},"ja447:8.1":{"pli":"Etāsu ve jāyare suttamāsu, ","html":"<p><span class='verse-line'>{}</span>"},"ja447:8.2":{"pli":"Medhāvino honti pahūtapaññā; ","html":"<span class='verse-line'>{}</span>"},"ja447:8.3":{"pli":"Bahussutā vedaguno ca honti, ","html":"<span class='verse-line'>{}</span>"},"ja447:8.4":{"pli":"Tasmā hi amhaṁ daharā na miyyare. ","html":"<span class='verse-line'>{}</span></p>"},"ja447:9.1":{"pli":"Mātā pitā ca bhaginī bhātaro ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja447:9.2":{"pli":"Puttā ca dārā ca mayañca sabbe; ","html":"<span class='verse-line'>{}</span>"},"ja447:9.3":{"pli":"Dhammaṁ carāma paralokahetu, ","html":"<span class='verse-line'>{}</span>"},"ja447:9.4":{"pli":"Tasmā hi amhaṁ daharā na miyyare. ","html":"<span class='verse-line'>{}</span></p>"},"ja447:10.1":{"pli":"Dāsā ca dāsyo anujīvino ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja447:10.2":{"pli":"Paricārakā kammakarā ca sabbe; ","html":"<span class='verse-line'>{}</span>"},"ja447:10.3":{"pli":"Dhammaṁ caranti paralokahetu, ","html":"<span class='verse-line'>{}</span>"},"ja447:10.4":{"pli":"Tasmā hi amhaṁ daharā na miyyare”. ","html":"<span class='verse-line'>{}</span></p>"},"ja447:11.1":{"pli":"“Dhammo have rakkhati dhammacāriṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja447:11.2":{"pli":"Dhammo suciṇṇo sukhamāvahāti; ","html":"<span class='verse-line'>{}</span>"},"ja447:11.3":{"pli":"Esānisaṁso dhamme suciṇṇe, ","html":"<span class='verse-line'>{}</span>"},"ja447:11.4":{"pli":"Na duggatiṁ gacchati dhammacārī. ","html":"<span class='verse-line'>{}</span></p>"},"ja447:12.1":{"pli":"Dhammo have rakkhati dhammacāriṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja447:12.2":{"pli":"Chattaṁ mahantaṁ viya vassakāle; ","html":"<span class='verse-line'>{}</span>"},"ja447:12.3":{"pli":"Dhammena gutto mama dhammapālo, ","html":"<span class='verse-line'>{}</span>"},"ja447:12.4":{"pli":"Aññassa aṭṭhīni sukhī kumāro”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja447:13.1":{"pli":"Mahādhammapālajātakaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja448":{"ja448:0.1":{"pli":"Jātaka ","html":"<article id='ja448'><header><ul><li class='division'>{}</li>"},"ja448:0.2":{"pli":"Dasakanipāta ","html":"<li>{}</li>"},"ja448:0.3":{"pli":"Catudvāravagga ","html":"<li>{}</li></ul>"},"ja448:0.4":{"pli":"10. Kukkuṭajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja448:1.1":{"pli":"“Nāsmase katapāpamhi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja448:1.2":{"pli":"nāsmase alikavādine; ","html":"<span class='verse-line'>{}</span>"},"ja448:1.3":{"pli":"Nāsmase attatthapaññamhi, ","html":"<span class='verse-line'>{}</span>"},"ja448:1.4":{"pli":"atisantepi nāsmase. ","html":"<span class='verse-line'>{}</span></p>"},"ja448:2.1":{"pli":"Bhavanti heke purisā, ","html":"<p><span class='verse-line'>{}</span>"},"ja448:2.2":{"pli":"gopipāsikajātikā; ","html":"<span class='verse-line'>{}</span>"},"ja448:2.3":{"pli":"Ghasanti maññe mittāni, ","html":"<span class='verse-line'>{}</span>"},"ja448:2.4":{"pli":"vācāya na ca kammunā. ","html":"<span class='verse-line'>{}</span></p>"},"ja448:3.1":{"pli":"Sukkhañjalipaggahitā, ","html":"<p><span class='verse-line'>{}</span>"},"ja448:3.2":{"pli":"vācāya paliguṇṭhitā; ","html":"<span class='verse-line'>{}</span>"},"ja448:3.3":{"pli":"Manussapheggū nāsīde, ","html":"<span class='verse-line'>{}</span>"},"ja448:3.4":{"pli":"yasmiṁ natthi kataññutā. ","html":"<span class='verse-line'>{}</span></p>"},"ja448:4.1":{"pli":"Na hi aññaññacittānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja448:4.2":{"pli":"itthīnaṁ purisāna vā; ","html":"<span class='verse-line'>{}</span>"},"ja448:4.3":{"pli":"Nānāvikatvā saṁsaggaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja448:4.4":{"pli":"tādisampi ca nāsmase. ","html":"<span class='verse-line'>{}</span></p>"},"ja448:5.1":{"pli":"Anariyakammamokkantaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja448:5.2":{"pli":"athetaṁ sabbaghātinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja448:5.3":{"pli":"Nisitaṁva paṭicchannaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja448:5.4":{"pli":"tādisampi ca nāsmase. ","html":"<span class='verse-line'>{}</span></p>"},"ja448:6.1":{"pli":"Mittarūpenidhekacce, ","html":"<p><span class='verse-line'>{}</span>"},"ja448:6.2":{"pli":"sākhalyena acetasā; ","html":"<span class='verse-line'>{}</span>"},"ja448:6.3":{"pli":"Vividhehi upāyanti, ","html":"<span class='verse-line'>{}</span>"},"ja448:6.4":{"pli":"tādisampi ca nāsmase. ","html":"<span class='verse-line'>{}</span></p>"},"ja448:7.1":{"pli":"Āmisaṁ vā dhanaṁ vāpi, ","html":"<p><span class='verse-line'>{}</span>"},"ja448:7.2":{"pli":"yattha passati tādiso; ","html":"<span class='verse-line'>{}</span>"},"ja448:7.3":{"pli":"Dubbhiṁ karoti dummedho, ","html":"<span class='verse-line'>{}</span>"},"ja448:7.4":{"pli":"tañca hantvāna gacchati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja448:8.1":{"pli":"“Mittarūpena bahavo, ","html":"<p><span class='verse-line'>{}</span>"},"ja448:8.2":{"pli":"channā sevanti sattavo; ","html":"<span class='verse-line'>{}</span>"},"ja448:8.3":{"pli":"Jahe kāpurise hete, ","html":"<span class='verse-line'>{}</span>"},"ja448:8.4":{"pli":"kukkuṭo viya senakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja448:9.1":{"pli":"Yo ca uppatitaṁ atthaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja448:9.2":{"pli":"na khippamanubujjhati; ","html":"<span class='verse-line'>{}</span>"},"ja448:9.3":{"pli":"Amittavasamanveti, ","html":"<span class='verse-line'>{}</span>"},"ja448:9.4":{"pli":"pacchā ca anutappati. ","html":"<span class='verse-line'>{}</span></p>"},"ja448:10.1":{"pli":"Yo ca uppatitaṁ atthaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja448:10.2":{"pli":"khippameva nibodhati; ","html":"<span class='verse-line'>{}</span>"},"ja448:10.3":{"pli":"Muccate sattusambādhā, ","html":"<span class='verse-line'>{}</span>"},"ja448:10.4":{"pli":"kukkuṭo viya senakā. ","html":"<span class='verse-line'>{}</span></p>"},"ja448:11.1":{"pli":"Taṁ tādisaṁ kūṭamivoḍḍitaṁ vane, ","html":"<p><span class='verse-line'>{}</span>"},"ja448:11.2":{"pli":"Adhammikaṁ niccavidhaṁsakārinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja448:11.3":{"pli":"Ārā vivajjeyya naro vicakkhaṇo, ","html":"<span class='verse-line'>{}</span>"},"ja448:11.4":{"pli":"Senaṁ yathā kukkuṭo vaṁsakānane”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja448:12.1":{"pli":"Kukkuṭajātakaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja449":{"ja449:0.1":{"pli":"Jātaka ","html":"<article id='ja449'><header><ul><li class='division'>{}</li>"},"ja449:0.2":{"pli":"Dasakanipāta ","html":"<li>{}</li>"},"ja449:0.3":{"pli":"Catudvāravagga ","html":"<li>{}</li></ul>"},"ja449:0.4":{"pli":"11. Maṭṭhakuṇḍalījātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja449:1.1":{"pli":"“Alaṅkato maṭṭhakuṇḍalī, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja449:1.2":{"pli":"Māladhārī haricandanussado; ","html":"<span class='verse-line'>{}</span>"},"ja449:1.3":{"pli":"Bāhā paggayha kandasi, ","html":"<span class='verse-line'>{}</span>"},"ja449:1.4":{"pli":"Vanamajjhe kiṁ dukkhito tuvaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja449:2.1":{"pli":"“Sovaṇṇamayo pabhassaro, ","html":"<p><span class='verse-line'>{}</span>"},"ja449:2.2":{"pli":"Uppanno rathapañjaro mama; ","html":"<span class='verse-line'>{}</span>"},"ja449:2.3":{"pli":"Tassa cakkayugaṁ na vindāmi, ","html":"<span class='verse-line'>{}</span>"},"ja449:2.4":{"pli":"Tena dukkhena jahāmi jīvitaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja449:3.1":{"pli":"“Sovaṇṇamayaṁ maṇīmayaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja449:3.2":{"pli":"Lohamayaṁ atha rūpiyāmayaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja449:3.3":{"pli":"Pāvada rathaṁ karissāmi te, ","html":"<span class='verse-line'>{}</span>"},"ja449:3.4":{"pli":"Cakkayugaṁ paṭipādayāmi taṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja449:4.1":{"pli":"“So māṇavo tassa pāvadi, ","html":"<p><span class='verse-line'>{}</span>"},"ja449:4.2":{"pli":"Candasūriyā ubhayettha bhātaro; ","html":"<span class='verse-line'>{}</span>"},"ja449:4.3":{"pli":"Sovaṇṇamayo ratho mama, ","html":"<span class='verse-line'>{}</span>"},"ja449:4.4":{"pli":"Tena cakkayugena sobhati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja449:5.1":{"pli":"“Bālo kho tvaṁsi māṇava, ","html":"<p><span class='verse-line'>{}</span>"},"ja449:5.2":{"pli":"Yo tvaṁ patthayase apatthiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja449:5.3":{"pli":"Maññāmi tuvaṁ marissasi, ","html":"<span class='verse-line'>{}</span>"},"ja449:5.4":{"pli":"Na hi tvaṁ lacchasi candasūriye”. ","html":"<span class='verse-line'>{}</span></p>"},"ja449:6.1":{"pli":"“Gamanāgamanampi dissati, ","html":"<p><span class='verse-line'>{}</span>"},"ja449:6.2":{"pli":"Vaṇṇadhātu ubhayettha vīthiyo; ","html":"<span class='verse-line'>{}</span>"},"ja449:6.3":{"pli":"Peto pana neva dissati, ","html":"<span class='verse-line'>{}</span>"},"ja449:6.4":{"pli":"Ko nu kho kandataṁ bālyataro”. ","html":"<span class='verse-line'>{}</span></p>"},"ja449:7.1":{"pli":"“Saccaṁ kho vadesi māṇava, ","html":"<p><span class='verse-line'>{}</span>"},"ja449:7.2":{"pli":"Ahameva kandataṁ bālyataro; ","html":"<span class='verse-line'>{}</span>"},"ja449:7.3":{"pli":"Candaṁ viya dārako rudaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja449:7.4":{"pli":"Petaṁ kālakatābhipatthaye. ","html":"<span class='verse-line'>{}</span></p>"},"ja449:8.1":{"pli":"Ādittaṁ vata maṁ santaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja449:8.2":{"pli":"ghatasittaṁva pāvakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja449:8.3":{"pli":"Vārinā viya osiñcaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja449:8.4":{"pli":"sabbaṁ nibbāpaye daraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja449:9.1":{"pli":"Abbahī vata me sallaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja449:9.2":{"pli":"yamāsi hadayassitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja449:9.3":{"pli":"Yo me sokaparetassa, ","html":"<span class='verse-line'>{}</span>"},"ja449:9.4":{"pli":"puttasokaṁ apānudi. ","html":"<span class='verse-line'>{}</span></p>"},"ja449:10.1":{"pli":"Sohaṁ abbūḷhasallosmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja449:10.2":{"pli":"vītasoko anāvilo; ","html":"<span class='verse-line'>{}</span>"},"ja449:10.3":{"pli":"Na socāmi na rodāmi, ","html":"<span class='verse-line'>{}</span>"},"ja449:10.4":{"pli":"tava sutvāna māṇavā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja449:11.1":{"pli":"Maṭṭhakuṇḍalījātakaṁ ekādasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja45":{"ja45:0.1":{"pli":"Jātaka ","eng":"Stories of Past Lives 45 ","html":"<article id='ja45'><header><ul><li class='division'>{}</li>"},"ja45:0.2":{"pli":"Ekakanipāta ","eng":"The Book of the Ones ","html":"<li>{}</li>"},"ja45:0.3":{"pli":"Atthakāmavagga ","eng":"Wanting to Help ","html":"<li>{}</li></ul>"},"ja45:0.4":{"pli":"5. Rohiṇijātaka ","eng":"About Rohinī: a past life story ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja45:1.1":{"pli":"“Seyyo amitto medhāvī, ","eng":"Better is an intelligent foe ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>","comm":"Similar to the previous story, a servant girl kills her mother with a pestle while trying to rid her of flies. "},"ja45:1.2":{"pli":"Yañce bālānukampako; ","eng":"than a foolish sympathizer. ","html":"<span class='verse-line'>{}</span>","comm":"The initial <i lang='pi' translate='no'>yañce</i> is hard to explain. The commentary offers several options, none of which are terribly convincing.  The previous verse has <i lang='pi' translate='no'>na tveva</i>, of which  <i lang='pi' translate='no'>yañce</i> might be an old corruption. "},"ja45:1.3":{"pli":"Passa rohiṇikaṁ jammiṁ, ","eng":"See that wretched Rohinī, ","html":"<span class='verse-line'>{}</span>"},"ja45:1.4":{"pli":"Mātaraṁ hantvāna socatī”ti. ","eng":"grieving after killing her mother. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja45:2.1":{"pli":"Rohiṇijātakaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja450":{"ja450:0.1":{"pli":"Jātaka ","html":"<article id='ja450'><header><ul><li class='division'>{}</li>"},"ja450:0.2":{"pli":"Dasakanipāta ","html":"<li>{}</li>"},"ja450:0.3":{"pli":"Catudvāravagga ","html":"<li>{}</li></ul>"},"ja450:0.4":{"pli":"12. Bilārakosiyajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja450:1.1":{"pli":"“Apacantāpi dicchanti, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja450:1.2":{"pli":"santo laddhāna bhojanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja450:1.3":{"pli":"Kimeva tvaṁ pacamāno, ","html":"<span class='verse-line'>{}</span>"},"ja450:1.4":{"pli":"yaṁ na dajjā na taṁ samaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja450:2.1":{"pli":"Maccherā ca pamādā ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja450:2.2":{"pli":"evaṁ dānaṁ na diyyati; ","html":"<span class='verse-line'>{}</span>"},"ja450:2.3":{"pli":"Puññaṁ ākaṅkhamānena, ","html":"<span class='verse-line'>{}</span>"},"ja450:2.4":{"pli":"deyyaṁ hoti vijānatā. ","html":"<span class='verse-line'>{}</span></p>"},"ja450:3.1":{"pli":"Yasseva bhīto na dadāti maccharī, ","html":"<p><span class='verse-line'>{}</span>"},"ja450:3.2":{"pli":"Tadevādadato bhayaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja450:3.3":{"pli":"Jighacchā ca pipāsā ca, ","html":"<span class='verse-line'>{}</span>"},"ja450:3.4":{"pli":"Yassa bhāyati maccharī; ","html":"<span class='verse-line'>{}</span>"},"ja450:3.5":{"pli":"Tameva bālaṁ phusati, ","html":"<span class='verse-line'>{}</span>"},"ja450:3.6":{"pli":"Asmiṁ loke paramhi ca. ","html":"<span class='verse-line'>{}</span></p>"},"ja450:4.1":{"pli":"Tasmā vineyya maccheraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja450:4.2":{"pli":"dajjā dānaṁ malābhibhū; ","html":"<span class='verse-line'>{}</span>"},"ja450:4.3":{"pli":"Puññāni paralokasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja450:4.4":{"pli":"patiṭṭhā honti pāṇinaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja450:5.1":{"pli":"“Duddadaṁ dadamānānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja450:5.2":{"pli":"dukkaraṁ kamma kubbataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja450:5.3":{"pli":"Asanto nānukubbanti, ","html":"<span class='verse-line'>{}</span>"},"ja450:5.4":{"pli":"sataṁ dhammo durannayo. ","html":"<span class='verse-line'>{}</span></p>"},"ja450:6.1":{"pli":"Tasmā satañca asataṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja450:6.2":{"pli":"nānā hoti ito gati; ","html":"<span class='verse-line'>{}</span>"},"ja450:6.3":{"pli":"Asanto nirayaṁ yanti, ","html":"<span class='verse-line'>{}</span>"},"ja450:6.4":{"pli":"santo saggaparāyaṇā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja450:7.1":{"pli":"“Appasmeke pavecchanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja450:7.2":{"pli":"bahuneke na dicchare; ","html":"<span class='verse-line'>{}</span>"},"ja450:7.3":{"pli":"Appasmā dakkhiṇā dinnā, ","html":"<span class='verse-line'>{}</span>"},"ja450:7.4":{"pli":"sahassena samaṁ mitā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja450:8.1":{"pli":"“Dhammaṁ care yopi samuñchakaṁ care, ","html":"<p><span class='verse-line'>{}</span>"},"ja450:8.2":{"pli":"Dārañca posaṁ dadamappakasmiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja450:8.3":{"pli":"Sataṁ sahassānaṁ sahassayāginaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja450:8.4":{"pli":"Kalampi nāgghanti tathāvidhassa te”. ","html":"<span class='verse-line'>{}</span></p>"},"ja450:9.1":{"pli":"“Kenesa yañño vipulo mahagghato, ","html":"<p><span class='verse-line'>{}</span>"},"ja450:9.2":{"pli":"Samena dinnassa na agghameti; ","html":"<span class='verse-line'>{}</span>"},"ja450:9.3":{"pli":"Kathaṁ sataṁ sahassānaṁ sahassayāginaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja450:9.4":{"pli":"Kalampi nāgghanti tathāvidhassa te”. ","html":"<span class='verse-line'>{}</span></p>"},"ja450:10.1":{"pli":"“Dadanti heke visame niviṭṭhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja450:10.2":{"pli":"Chetvā vadhitvā atha socayitvā; ","html":"<span class='verse-line'>{}</span>"},"ja450:10.3":{"pli":"Sā dakkhiṇā assumukhā sadaṇḍā, ","html":"<span class='verse-line'>{}</span>"},"ja450:10.4":{"pli":"Samena dinnassa na agghameti; ","html":"<span class='verse-line'>{}</span>"},"ja450:10.5":{"pli":"Evaṁ sataṁ sahassānaṁ sahassayāginaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja450:10.6":{"pli":"Kalampi nāgghanti tathāvidhassa te”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja450:11.1":{"pli":"Bilārakosiyajātakaṁ dvādasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja451":{"ja451:0.1":{"pli":"Jātaka ","html":"<article id='ja451'><header><ul><li class='division'>{}</li>"},"ja451:0.2":{"pli":"Dasakanipāta ","html":"<li>{}</li>"},"ja451:0.3":{"pli":"Catudvāravagga ","html":"<li>{}</li></ul>"},"ja451:0.4":{"pli":"13. Cakkavākajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja451:1.1":{"pli":"“Vaṇṇavā abhirūposi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja451:1.2":{"pli":"ghano sañjātarohito; ","html":"<span class='verse-line'>{}</span>"},"ja451:1.3":{"pli":"Cakkavāka surūposi, ","html":"<span class='verse-line'>{}</span>"},"ja451:1.4":{"pli":"vippasannamukhindriyo. ","html":"<span class='verse-line'>{}</span></p>"},"ja451:2.1":{"pli":"Pāṭhīnaṁ pāvusaṁ macchaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja451:2.2":{"pli":"balajaṁ muñjarohitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja451:2.3":{"pli":"Gaṅgāya tīre nisinno, ","html":"<span class='verse-line'>{}</span>"},"ja451:2.4":{"pli":"evaṁ bhuñjasi bhojanaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja451:3.1":{"pli":"“Na vāhametaṁ bhuñjāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja451:3.2":{"pli":"Jaṅgalānodakāni vā; ","html":"<span class='verse-line'>{}</span>"},"ja451:3.3":{"pli":"Aññatra sevālapaṇakā, ","html":"<span class='verse-line'>{}</span>"},"ja451:3.4":{"pli":"Etaṁ me samma bhojanaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja451:4.1":{"pli":"“Na vāhametaṁ saddahāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja451:4.2":{"pli":"cakkavākassa bhojanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja451:4.3":{"pli":"Ahampi samma bhuñjāmi, ","html":"<span class='verse-line'>{}</span>"},"ja451:4.4":{"pli":"gāme loṇiyateliyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja451:5.1":{"pli":"Manussesu kataṁ bhattaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja451:5.2":{"pli":"suciṁ maṁsūpasecanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja451:5.3":{"pli":"Na ca me tādiso vaṇṇo, ","html":"<span class='verse-line'>{}</span>"},"ja451:5.4":{"pli":"cakkavāka yathā tuvaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja451:6.1":{"pli":"“Sampassaṁ attani veraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja451:6.2":{"pli":"hiṁsayaṁ mānusiṁ pajaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja451:6.3":{"pli":"Utrasto ghasasī bhīto, ","html":"<span class='verse-line'>{}</span>"},"ja451:6.4":{"pli":"tena vaṇṇo tavediso. ","html":"<span class='verse-line'>{}</span></p>"},"ja451:7.1":{"pli":"Sabbalokaviruddhosi, ","html":"<p><span class='verse-line'>{}</span>"},"ja451:7.2":{"pli":"dhaṅka pāpena kammunā; ","html":"<span class='verse-line'>{}</span>"},"ja451:7.3":{"pli":"Laddho piṇḍo na pīṇeti, ","html":"<span class='verse-line'>{}</span>"},"ja451:7.4":{"pli":"tena vaṇṇo tavediso. ","html":"<span class='verse-line'>{}</span></p>"},"ja451:8.1":{"pli":"Ahampi samma bhuñjāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja451:8.2":{"pli":"ahiṁsaṁ sabbapāṇinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja451:8.3":{"pli":"Appossukko nirāsaṅkī, ","html":"<span class='verse-line'>{}</span>"},"ja451:8.4":{"pli":"asoko akutobhayo. ","html":"<span class='verse-line'>{}</span></p>"},"ja451:9.1":{"pli":"So karassu ānubhāvaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja451:9.2":{"pli":"vītivattassu sīliyaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja451:9.3":{"pli":"Ahiṁsāya cara loke, ","html":"<span class='verse-line'>{}</span>"},"ja451:9.4":{"pli":"piyo hohisi maṁmiva. ","html":"<span class='verse-line'>{}</span></p>"},"ja451:10.1":{"pli":"Yo na hanti na ghāteti, ","html":"<p><span class='verse-line'>{}</span>"},"ja451:10.2":{"pli":"na jināti na jāpaye; ","html":"<span class='verse-line'>{}</span>"},"ja451:10.3":{"pli":"Mettaṁso sabbabhūtesu, ","html":"<span class='verse-line'>{}</span>"},"ja451:10.4":{"pli":"veraṁ tassa na kenacī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja451:11.1":{"pli":"Cakkavākajātakaṁ terasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja452":{"ja452:0.1":{"pli":"Jātaka ","html":"<article id='ja452'><header><ul><li class='division'>{}</li>"},"ja452:0.2":{"pli":"Dasakanipāta ","html":"<li>{}</li>"},"ja452:0.3":{"pli":"Catudvāravagga ","html":"<li>{}</li></ul>"},"ja452:0.4":{"pli":"14. Bhūripaññajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja452:1.1":{"pli":"“Saccaṁ kira tvaṁ api bhūripañña, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja452:1.2":{"pli":"Yā tādisī sīri dhitī matī ca; ","html":"<span class='verse-line'>{}</span>"},"ja452:1.3":{"pli":"Na tāyatebhāvavasūpanitaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja452:1.4":{"pli":"Yo yavakaṁ bhuñjasi appasūpaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja452:2.1":{"pli":"“Sukhaṁ dukkhena paripācayanto, ","html":"<p><span class='verse-line'>{}</span>"},"ja452:2.2":{"pli":"Kālā kālaṁ vicinaṁ chandachanno; ","html":"<span class='verse-line'>{}</span>"},"ja452:2.3":{"pli":"Atthassa dvārāni avāpuranto, ","html":"<span class='verse-line'>{}</span>"},"ja452:2.4":{"pli":"Tenāhaṁ tussāmi yavodanena. ","html":"<span class='verse-line'>{}</span></p>"},"ja452:3.1":{"pli":"Kālañca ñatvā abhijīhanāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja452:3.2":{"pli":"Mantehi atthaṁ paripācayitvā; ","html":"<span class='verse-line'>{}</span>"},"ja452:3.3":{"pli":"Vijambhissaṁ sīhavijambhitāni, ","html":"<span class='verse-line'>{}</span>"},"ja452:3.4":{"pli":"Tāyiddhiyā dakkhasi maṁ punāpi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja452:4.1":{"pli":"“Sukhīpi heke na karonti pāpaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja452:4.2":{"pli":"Avaṇṇasaṁsaggabhayā puneke; ","html":"<span class='verse-line'>{}</span>"},"ja452:4.3":{"pli":"Pahū samāno vipulatthacintī, ","html":"<span class='verse-line'>{}</span>"},"ja452:4.4":{"pli":"Kiṅkāraṇā me na karosi dukkhaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja452:5.1":{"pli":"“Na paṇḍitā attasukhassa hetu, ","html":"<p><span class='verse-line'>{}</span>"},"ja452:5.2":{"pli":"Pāpāni kammāni samācaranti; ","html":"<span class='verse-line'>{}</span>"},"ja452:5.3":{"pli":"Dukkhena phuṭṭhā khalitāpi santā, ","html":"<span class='verse-line'>{}</span>"},"ja452:5.4":{"pli":"Chandā ca dosā na jahanti dhammaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja452:6.1":{"pli":"“Yena kenaci vaṇṇena, ","html":"<p><span class='verse-line'>{}</span>"},"ja452:6.2":{"pli":"mudunā dāruṇena vā; ","html":"<span class='verse-line'>{}</span>"},"ja452:6.3":{"pli":"Uddhare dīnamattānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja452:6.4":{"pli":"pacchā dhammaṁ samācare”. ","html":"<span class='verse-line'>{}</span></p>"},"ja452:7.1":{"pli":"“Yassa rukkhassa chāyāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja452:7.2":{"pli":"nisīdeyya sayeyya vā; ","html":"<span class='verse-line'>{}</span>"},"ja452:7.3":{"pli":"Na tassa sākhaṁ bhañjeyya, ","html":"<span class='verse-line'>{}</span>"},"ja452:7.4":{"pli":"mittadubbho hi pāpako. ","html":"<span class='verse-line'>{}</span></p>"},"ja452:8.1":{"pli":"Yassāpi dhammaṁ puriso vijaññā, ","html":"<p><span class='verse-line'>{}</span>"},"ja452:8.2":{"pli":"Ye cassa kaṅkhaṁ vinayanti santo; ","html":"<span class='verse-line'>{}</span>"},"ja452:8.3":{"pli":"Taṁ hissa dīpañca parāyanañca, ","html":"<span class='verse-line'>{}</span>"},"ja452:8.4":{"pli":"Na tena mettiṁ jarayetha pañño”. ","html":"<span class='verse-line'>{}</span></p>"},"ja452:9.1":{"pli":"“Alaso gihī kāmabhogī na sādhu, ","html":"<p><span class='verse-line'>{}</span>"},"ja452:9.2":{"pli":"Asaññato pabbajito na sādhu; ","html":"<span class='verse-line'>{}</span>"},"ja452:9.3":{"pli":"Rājā na sādhu anisammakārī, ","html":"<span class='verse-line'>{}</span>"},"ja452:9.4":{"pli":"Yo paṇḍito kodhano taṁ na sādhu. ","html":"<span class='verse-line'>{}</span></p>"},"ja452:10.1":{"pli":"Nisamma khattiyo kayirā, ","html":"<p><span class='verse-line'>{}</span>"},"ja452:10.2":{"pli":"nānisamma disampati; ","html":"<span class='verse-line'>{}</span>"},"ja452:10.3":{"pli":"Nisammakārino rāja, ","html":"<span class='verse-line'>{}</span>"},"ja452:10.4":{"pli":"yaso kitti ca vaḍḍhatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja452:11.1":{"pli":"Bhūripaññajātakaṁ cuddasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja453":{"ja453:0.1":{"pli":"Jātaka ","html":"<article id='ja453'><header><ul><li class='division'>{}</li>"},"ja453:0.2":{"pli":"Dasakanipāta ","html":"<li>{}</li>"},"ja453:0.3":{"pli":"Catudvāravagga ","html":"<li>{}</li></ul>"},"ja453:0.4":{"pli":"15. Mahāmaṅgalajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja453:1.1":{"pli":"“Kiṁsu naro jappamadhiccakāle, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja453:1.2":{"pli":"Kaṁ vā vijjaṁ katamaṁ vā sutānaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja453:1.3":{"pli":"So macco asmiñca paramhi loke, ","html":"<span class='verse-line'>{}</span>"},"ja453:1.4":{"pli":"Kathaṁ karo sotthānena gutto”. ","html":"<span class='verse-line'>{}</span></p>"},"ja453:2.1":{"pli":"“Yassa devā pitaro ca sabbe, ","html":"<p><span class='verse-line'>{}</span>"},"ja453:2.2":{"pli":"Sarīsapā sabbabhūtāni cāpi; ","html":"<span class='verse-line'>{}</span>"},"ja453:2.3":{"pli":"Mettāya niccaṁ apacitāni honti, ","html":"<span class='verse-line'>{}</span>"},"ja453:2.4":{"pli":"Bhūtesu ve sotthānaṁ tadāhu”. ","html":"<span class='verse-line'>{}</span></p>"},"ja453:3.1":{"pli":"“Yo sabbalokassa nivātavutti, ","html":"<p><span class='verse-line'>{}</span>"},"ja453:3.2":{"pli":"Itthīpumānaṁ sahadārakānaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja453:3.3":{"pli":"Khantā duruttānamappaṭikūlavādī, ","html":"<span class='verse-line'>{}</span>"},"ja453:3.4":{"pli":"Adhivāsanaṁ sotthānaṁ tadāhu. ","html":"<span class='verse-line'>{}</span></p>"},"ja453:4.1":{"pli":"Yo nāvajānāti sahāyamitte, ","html":"<p><span class='verse-line'>{}</span>"},"ja453:4.2":{"pli":"Sippena kulyāhi dhanena jaccā; ","html":"<span class='verse-line'>{}</span>"},"ja453:4.3":{"pli":"Rucipañño atthakāle matīmā, ","html":"<span class='verse-line'>{}</span>"},"ja453:4.4":{"pli":"Sahāyesu ve sotthānaṁ tadāhu. ","html":"<span class='verse-line'>{}</span></p>"},"ja453:5.1":{"pli":"Mittāni ve yassa bhavanti santo, ","html":"<p><span class='verse-line'>{}</span>"},"ja453:5.2":{"pli":"Saṁvissatthā avisaṁvādakassa; ","html":"<span class='verse-line'>{}</span>"},"ja453:5.3":{"pli":"Na mittadubbhī saṁvibhāgī dhanena, ","html":"<span class='verse-line'>{}</span>"},"ja453:5.4":{"pli":"Mittesu ve sotthānaṁ tadāhu. ","html":"<span class='verse-line'>{}</span></p>"},"ja453:6.1":{"pli":"Yassa bhariyā tulyavayā samaggā, ","html":"<p><span class='verse-line'>{}</span>"},"ja453:6.2":{"pli":"Anubbatā dhammakāmā pajātā; ","html":"<span class='verse-line'>{}</span>"},"ja453:6.3":{"pli":"Koliniyā sīlavatī patibbatā, ","html":"<span class='verse-line'>{}</span>"},"ja453:6.4":{"pli":"Dāresu ve sotthānaṁ tadāhu. ","html":"<span class='verse-line'>{}</span></p>"},"ja453:7.1":{"pli":"Yassa rājā bhūtapati yasassī, ","html":"<p><span class='verse-line'>{}</span>"},"ja453:7.2":{"pli":"Jānāti soceyyaṁ parakkamañca; ","html":"<span class='verse-line'>{}</span>"},"ja453:7.3":{"pli":"Advejjhatā suhadayaṁ mamanti, ","html":"<span class='verse-line'>{}</span>"},"ja453:7.4":{"pli":"Rājūsu ve sotthānaṁ tadāhu. ","html":"<span class='verse-line'>{}</span></p>"},"ja453:8.1":{"pli":"Annañca pānañca dadāti saddho, ","html":"<p><span class='verse-line'>{}</span>"},"ja453:8.2":{"pli":"Mālañca gandhañca vilepanañca; ","html":"<span class='verse-line'>{}</span>"},"ja453:8.3":{"pli":"Pasannacitto anumodamāno, ","html":"<span class='verse-line'>{}</span>"},"ja453:8.4":{"pli":"Saggesu ve sotthānaṁ tadāhu. ","html":"<span class='verse-line'>{}</span></p>"},"ja453:9.1":{"pli":"Yamariyadhammena punanti vuddhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja453:9.2":{"pli":"Ārādhitā samacariyāya santo; ","html":"<span class='verse-line'>{}</span>"},"ja453:9.3":{"pli":"Bahussutā isayo sīlavanto, ","html":"<span class='verse-line'>{}</span>"},"ja453:9.4":{"pli":"Arahantamajjhe sotthānaṁ tadāhu. ","html":"<span class='verse-line'>{}</span></p>"},"ja453:10.1":{"pli":"Etāni kho sotthānāni loke, ","html":"<p><span class='verse-line'>{}</span>"},"ja453:10.2":{"pli":"Viññuppasatthāni sukhudrayāni; ","html":"<span class='verse-line'>{}</span>"},"ja453:10.3":{"pli":"Tānīdha sevetha naro sapañño, ","html":"<span class='verse-line'>{}</span>"},"ja453:10.4":{"pli":"Na hi maṅgale kiñcanamatthi saccan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja453:11.1":{"pli":"Mahāmaṅgalajātakaṁ pannarasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja454":{"ja454:0.1":{"pli":"Jātaka ","html":"<article id='ja454'><header><ul><li class='division'>{}</li>"},"ja454:0.2":{"pli":"Dasakanipāta ","html":"<li>{}</li>"},"ja454:0.3":{"pli":"Catudvāravagga ","html":"<li>{}</li></ul>"},"ja454:0.4":{"pli":"16. Ghaṭapaṇḍitajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja454:1.1":{"pli":"“Uṭṭhehi kaṇha kiṁ sesi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja454:1.2":{"pli":"Ko attho supanena te; ","html":"<span class='verse-line'>{}</span>"},"ja454:1.3":{"pli":"Yopi tuyhaṁ sako bhātā, ","html":"<span class='verse-line'>{}</span>"},"ja454:1.4":{"pli":"Hadayaṁ cakkhu ca dakkhiṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja454:1.5":{"pli":"Tassa vātā balīyanti, ","html":"<span class='verse-line'>{}</span>"},"ja454:1.6":{"pli":"Ghaṭo jappati kesava”. ","html":"<span class='verse-line'>{}</span></p>"},"ja454:2.1":{"pli":"“Tassa taṁ vacanaṁ sutvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja454:2.2":{"pli":"rohiṇeyyassa kesavo; ","html":"<span class='verse-line'>{}</span>"},"ja454:2.3":{"pli":"Taramānarūpo vuṭṭhāsi, ","html":"<span class='verse-line'>{}</span>"},"ja454:2.4":{"pli":"bhātusokena aṭṭito”. ","html":"<span class='verse-line'>{}</span></p>"},"ja454:3.1":{"pli":"“Kiṁ nu ummattarūpova, ","html":"<p><span class='verse-line'>{}</span>"},"ja454:3.2":{"pli":"kevalaṁ dvārakaṁ imaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja454:3.3":{"pli":"Saso sasoti lapasi, ","html":"<span class='verse-line'>{}</span>"},"ja454:3.4":{"pli":"ko nu te sasamāhari”. ","html":"<span class='verse-line'>{}</span></p>"},"ja454:4.1":{"pli":"“Sovaṇṇamayaṁ maṇīmayaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja454:4.2":{"pli":"Lohamayaṁ atha rūpiyāmayaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja454:4.3":{"pli":"Saṅkhasilāpavāḷamayaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja454:4.4":{"pli":"Kārayissāmi te sasaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja454:5.1":{"pli":"“Santi aññepi sasakā, ","html":"<p><span class='verse-line'>{}</span>"},"ja454:5.2":{"pli":"araññe vanagocarā; ","html":"<span class='verse-line'>{}</span>"},"ja454:5.3":{"pli":"Tepi te ānayissāmi, ","html":"<span class='verse-line'>{}</span>"},"ja454:5.4":{"pli":"kīdisaṁ sasamicchasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja454:6.1":{"pli":"“Na cāhamete icchāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja454:6.2":{"pli":"ye sasā pathavissitā; ","html":"<span class='verse-line'>{}</span>"},"ja454:6.3":{"pli":"Candato sasamicchāmi, ","html":"<span class='verse-line'>{}</span>"},"ja454:6.4":{"pli":"taṁ me ohara kesava”. ","html":"<span class='verse-line'>{}</span></p>"},"ja454:7.1":{"pli":"“So nūna madhuraṁ ñāti, ","html":"<p><span class='verse-line'>{}</span>"},"ja454:7.2":{"pli":"jīvitaṁ vijahissasi; ","html":"<span class='verse-line'>{}</span>"},"ja454:7.3":{"pli":"Apatthiyaṁ yo patthayasi, ","html":"<span class='verse-line'>{}</span>"},"ja454:7.4":{"pli":"candato sasamicchasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja454:8.1":{"pli":"“Evañce kaṇha jānāsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja454:8.2":{"pli":"yadaññamanusāsasi; ","html":"<span class='verse-line'>{}</span>"},"ja454:8.3":{"pli":"Kasmā pure mataṁ puttaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja454:8.4":{"pli":"ajjāpi manusocasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja454:9.1":{"pli":"“Yaṁ na labbhā manussena, ","html":"<p><span class='verse-line'>{}</span>"},"ja454:9.2":{"pli":"amanussena vā puna; ","html":"<span class='verse-line'>{}</span>"},"ja454:9.3":{"pli":"Jāto me mā marī putto, ","html":"<span class='verse-line'>{}</span>"},"ja454:9.4":{"pli":"kuto labbhā alabbhiyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja454:10.1":{"pli":"Na mantā mūlabhesajjā, ","html":"<p><span class='verse-line'>{}</span>"},"ja454:10.2":{"pli":"osadhehi dhanena vā; ","html":"<span class='verse-line'>{}</span>"},"ja454:10.3":{"pli":"Sakkā ānayituṁ kaṇha, ","html":"<span class='verse-line'>{}</span>"},"ja454:10.4":{"pli":"yaṁ petamanusocasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja454:11.1":{"pli":"“Yassa etādisā assu, ","html":"<p><span class='verse-line'>{}</span>"},"ja454:11.2":{"pli":"amaccā purisapaṇḍitā; ","html":"<span class='verse-line'>{}</span>"},"ja454:11.3":{"pli":"Yathā nijjhāpaye ajja, ","html":"<span class='verse-line'>{}</span>"},"ja454:11.4":{"pli":"ghaṭo purisapaṇḍito. ","html":"<span class='verse-line'>{}</span></p>"},"ja454:12.1":{"pli":"Ādittaṁ vata maṁ santaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja454:12.2":{"pli":"ghatasittaṁva pāvakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja454:12.3":{"pli":"Vārinā viya osiñcaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja454:12.4":{"pli":"sabbaṁ nibbāpaye daraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja454:13.1":{"pli":"Abbahī vata me sallaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja454:13.2":{"pli":"yamāsi hadayassitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja454:13.3":{"pli":"Yo me sokaparetassa, ","html":"<span class='verse-line'>{}</span>"},"ja454:13.4":{"pli":"puttasokaṁ apānudi. ","html":"<span class='verse-line'>{}</span></p>"},"ja454:14.1":{"pli":"Sohaṁ abbūḷhasallosmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja454:14.2":{"pli":"vītasoko anāvilo; ","html":"<span class='verse-line'>{}</span>"},"ja454:14.3":{"pli":"Na socāmi na rodāmi, ","html":"<span class='verse-line'>{}</span>"},"ja454:14.4":{"pli":"tava sutvāna māṇava”. ","html":"<span class='verse-line'>{}</span></p>"},"ja454:15.1":{"pli":"“Evaṁ karonti sappaññā, ","html":"<p><span class='verse-line'>{}</span>"},"ja454:15.2":{"pli":"Ye honti anukampakā; ","html":"<span class='verse-line'>{}</span>"},"ja454:15.3":{"pli":"Nivattayanti sokamhā, ","html":"<span class='verse-line'>{}</span>"},"ja454:15.4":{"pli":"Ghaṭo jeṭṭhaṁva bhātaran”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja454:16.1":{"pli":"Ghaṭapaṇḍitajātakaṁ soḷasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja454:17.1":{"pli":"Dasakanipātaṁ niṭṭhitaṁ. ","html":"<p class='endsection'>{}</p>"},"ja454:18.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja454:19.1":{"pli":"Daḷha kaṇha dhanañjaya saṅkhavaro, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja454:19.2":{"pli":"Raja sattaha kassa ca takkalinā; ","html":"<span class='verse-line'>{}</span>"},"ja454:19.3":{"pli":"Dhammaṁ kukkuṭa kuṇḍali bhojanadā, ","html":"<span class='verse-line'>{}</span>"},"ja454:19.4":{"pli":"Cakkavāka subhūrisa sotthi ghaṭoti. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}}}