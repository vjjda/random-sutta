? ","html":"{}"},"kv6.10:4.3":{"pli":"Āmantā. ","html":"{}"},"kv6.10:4.4":{"pli":"Nanu passati abhikkamantaṁ paṭikkamantaṁ ālokentaṁ vilokentaṁ samiñjentaṁ pasārentanti? ","html":"{}"},"kv6.10:4.5":{"pli":"Āmantā. ","html":"{}"},"kv6.10:4.6":{"pli":"Hañci passati abhikkamantaṁ paṭikkamantaṁ ālokentaṁ vilokentaṁ samiñjentaṁ pasārentaṁ, tena vata re vattabbe—","html":"{}"},"kv6.10:4.7":{"pli":"“kāyakammaṁ sanidassanan”ti. ","html":"{}</p>"},"kv6.10:4.8":{"pli":"Kāyakammaṁ sanidassanantikathā niṭṭhitā. ","html":"<p class='endsutta'>{}<br>"},"kv6.10:4.9":{"pli":"Chaṭṭho vaggo. ","html":"{}</p>"},"kv6.10:4.10":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"kv6.10:5.1":{"pli":"Niyamo asaṅkhato, paṭiccasamuppādo asaṅkhato, cattāri saccāni asaṅkhatāni, cattāro āruppā asaṅkhatā, nirodhasamāpatti asaṅkhatā, ākāso asaṅkhato, ākāso sanidassano, cattāro mahābhūtā, pañcindriyāni, tatheva kāyakammanti. ","html":"<p class='uddana'>{}</p></article>"}},"kv6.2":{"kv6.2:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv6.2'><header><ul><li class='division'>{}</li>"},"kv6.2:0.2":{"pli":"Niyāmapaṇṇāsaka ","html":"<li>{}</li>"},"kv6.2:0.3":{"pli":"Chaṭṭhavagga ","html":"<li>{}</li></ul>"},"kv6.2:0.4":{"pli":"Paṭiccasamuppādakathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv6.2:1.1":{"pli":"Paṭiccasamuppādo asaṅkhatoti? ","html":"<p data-doxy='orthodox'>{}"},"kv6.2:1.2":{"pli":"Āmantā. ","html":"{}"},"kv6.2:1.3":{"pli":"Nibbānaṁ tāṇaṁ leṇaṁ saraṇaṁ parāyanaṁ accutaṁ amatanti? ","html":"{}"},"kv6.2:1.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv6.2:1.5":{"pli":"paṭiccasamuppādo asaṅkhato, nibbānaṁ asaṅkhatanti? ","html":"{}"},"kv6.2:1.6":{"pli":"Āmantā. ","html":"{}"},"kv6.2:1.7":{"pli":"Dve asaṅkhatānīti? ","html":"{}"},"kv6.2:1.8":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv6.2:1.9":{"pli":"dve asaṅkhatānīti? ","html":"{}"},"kv6.2:1.10":{"pli":"Āmantā. ","html":"{}"},"kv6.2:1.11":{"pli":"Dve tāṇāni dve leṇāni dve saraṇāni dve parāyanāni dve accutān