{"tha-ap37":{"tha-ap37:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap37'><header><ul><li class='division'>{}</li>"},"tha-ap37:0.2":{"pli":"Kuṇḍadhānavagga ","html":"<li>{}</li></ul>"},"tha-ap37:0.3":{"pli":"Mogharājattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap37:1.1":{"pli":"“Atthadassī tu bhagavā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap37:1.2":{"pli":"sayambhū aparājito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:1.3":{"pli":"Bhikkhusaṅghaparibyūḷho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:1.4":{"pli":"rathiyaṁ paṭipajjatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap37:2.1":{"pli":"Sissehi samparivuto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap37:2.2":{"pli":"gharamhā abhinikkhamiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:2.3":{"pli":"Nikkhamitvānahaṁ tattha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:2.4":{"pli":"addasaṁ lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap37:3.1":{"pli":"Abhivādiya sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap37:3.2":{"pli":"sire katvāna añjaliṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:3.3":{"pli":"Sakaṁ cittaṁ pasādetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:3.4":{"pli":"santhaviṁ lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap37:4.1":{"pli":"Yāvatā rūpino sattā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap37:4.2":{"pli":"arūpī vā asaññino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:4.3":{"pli":"Sabbe te tava ñāṇamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:4.4":{"pli":"anto honti samogadhā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap37:5.1":{"pli":"Sukhumacchikajālena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap37:5.2":{"pli":"udakaṁ yo parikkhipe; ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:5.3":{"pli":"Ye keci udake pāṇā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:5.4":{"pli":"antojāle bhavanti te. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap37:6.1":{"pli":"Yesañca cetanā atthi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap37:6.2":{"pli":"rūpino ca arūpino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:6.3":{"pli":"Sabbe te tava ñāṇamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:6.4":{"pli":"anto honti samogadhā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap37:7.1":{"pli":"Samuddharasimaṁ lokaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap37:7.2":{"pli":"andhakārasamākulaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:7.3":{"pli":"Tava dhammaṁ suṇitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:7.4":{"pli":"kaṅkhāsotaṁ taranti te. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap37:8.1":{"pli":"Avijjānivute loke, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap37:8.2":{"pli":"andhakārena otthaṭe; ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:8.3":{"pli":"Tava ñāṇamhi jotante, ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:8.4":{"pli":"andhakārā padhaṁsitā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap37:9.1":{"pli":"Tuvaṁ cakkhūsi sabbesaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap37:9.2":{"pli":"mahātamapanūdano; ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:9.3":{"pli":"Tava dhammaṁ suṇitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:9.4":{"pli":"nibbāyati bahujjano. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap37:10.1":{"pli":"Puṭakaṁ pūrayitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap37:10.2":{"pli":"madhukhuddamaneḷakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:10.3":{"pli":"Ubho hatthehi paggayha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:10.4":{"pli":"upanesiṁ mahesino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap37:11.1":{"pli":"Paṭiggaṇhi mahāvīro, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap37:11.2":{"pli":"sahatthena mahā isi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:11.3":{"pli":"Bhuñjitvā tañca sabbaññū, ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:11.4":{"pli":"vehāsaṁ nabhamuggami. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap37:12.1":{"pli":"Antalikkhe ṭhito satthā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap37:12.2":{"pli":"atthadassī narāsabho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:12.3":{"pli":"Mama cittaṁ pasādento, ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:12.4":{"pli":"imā gāthā abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap37:13.1":{"pli":"‘Yenidaṁ thavitaṁ ñāṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap37:13.2":{"pli":"buddhaseṭṭho ca thomito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:13.3":{"pli":"Tena cittappasādena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:13.4":{"pli":"duggatiṁ so na gacchati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap37:14.1":{"pli":"Catuddasañcakkhattuṁ so, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap37:14.2":{"pli":"devarajjaṁ karissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:14.3":{"pli":"Pathabyā rajjaṁ aṭṭhasataṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:14.4":{"pli":"vasudhaṁ āvasissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap37:15.1":{"pli":"Pañceva satakkhattuñca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap37:15.2":{"pli":"cakkavattī bhavissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:15.3":{"pli":"Padesarajjaṁ asaṅkheyyaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:15.4":{"pli":"mahiyā kārayissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap37:16.1":{"pli":"Ajjhāyako mantadharo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap37:16.2":{"pli":"tiṇṇaṁ vedāna pāragū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:16.3":{"pli":"Gotamassa bhagavato, ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:16.4":{"pli":"sāsane pabbajissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap37:17.1":{"pli":"Gambhīraṁ nipuṇaṁ atthaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap37:17.2":{"pli":"ñāṇena vicinissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:17.3":{"pli":"Mogharājāti nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:17.4":{"pli":"hessati satthu sāvako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap37:18.1":{"pli":"Tīhi vijjāhi sampannaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap37:18.2":{"pli":"katakiccamanāsavaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:18.3":{"pli":"Gotamo satthavāhaggo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:18.4":{"pli":"etadagge ṭhapessati’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap37:19.1":{"pli":"Hitvā mānusakaṁ yogaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap37:19.2":{"pli":"chetvāna bhavabandhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:19.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:19.4":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap37:20.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap37:20.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap37:20.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap37:21.1":{"pli":"Itthaṁ sudaṁ āyasmā mogharājo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap37:22.1":{"pli":"Mogharājattherassāpadānaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></ar