le>"}},"tha-ap371":{"tha-ap371:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap371'><header><ul><li class='division'>{}</li>"},"tha-ap371:0.2":{"pli":"Mandāravapupphiyavagga ","html":"<li>{}</li></ul>"},"tha-ap371:0.3":{"pli":"Timirapupphiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap371:1.1":{"pli":"“Candabhāgānadītīre, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap371:1.2":{"pli":"anusotaṁ vajāmahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap371:1.3":{"pli":"Addasaṁ virajaṁ buddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap371:1.4":{"pli":"sālarājaṁva phullitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap371:2.1":{"pli":"Pasannacitto sumano, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap371:2.2":{"pli":"paccekamunimuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap371:2.3":{"pli":"Gahetvā timiraṁ pupphaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap371:2.4":{"pli":"matthake okiriṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap371:3.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap371:3.2":{"pli":"yaṁ pupphamabhipūjayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap371:3.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap371:3.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap371:4.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap371:4.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap371:4.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap371:5.1":{"pli":"Itthaṁ sudaṁ āyasmā timirapupphiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap371:6.1":{"pli":"Timirapupphiyattherassāpadānaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap372":{"tha-ap372:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap372'><header><ul><li class='division'>{}</li>"},"tha-ap372:0.2":{"pli":"Mandāravapupphiyavagga ","html":"<li>{}</li></ul>"},"tha-ap372:0.3":{"pli":"10 Saḷalapupphiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap372:1.1":{"pli":"“Candabhāgānadītīre, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap372:1.2":{"pli":"ahosiṁ kinnaro tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap372:1.3":{"pli":"Tatthaddasaṁ devadevaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap372:1.4":{"pli":"caṅkamantaṁ narāsabhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap372:2.1":{"pli":"Ocinitvāna saḷalaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap372:2.2":{"pli":"pupphaṁ buddhassadāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap372:2.3":{"pli":"Upasiṅghi mahāvīro, ","html":"<span class='verse-line'>{}</span>"},"tha-ap372:2.4":{"pli":"saḷalaṁ devagandhikaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap372:3.1":{"pli":"Paṭiggahetvā sambuddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap372:3.2":{"pli":"vipassī lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap372:3.3":{"pli":"Upasiṅghi mahāvīro, ","html":"<span class='verse-line'>{}</span>"},"tha-ap372:3.4":{"pli":"pekkhamānassa me sato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap372:4.1":{"pli":"Pasannacitto sumano, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap372:4.2":{"pli":"vanditvā dvipaduttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap372:4.3":{"pli":"Añjaliṁ paggahetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap372:4.4":{"pli":"puna pabbatamāruhiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap372:5.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap372:5.2":{"pli":"yaṁ pupphamabhipūjayiṁ; ","html":"<s