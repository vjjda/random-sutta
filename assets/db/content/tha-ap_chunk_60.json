ap78:8.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap78:8.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap78:8.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap78:9.1":{"pli":"Itthaṁ sudaṁ āyasmā tiṇasantharadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap78:10.1":{"pli":"Tiṇasantharadāyakattherassāpadānaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap79":{"tha-ap79:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap79'><header><ul><li class='division'>{}</li>"},"tha-ap79:0.2":{"pli":"Nāgasamālavagga ","html":"<li>{}</li></ul>"},"tha-ap79:0.3":{"pli":"Sūcidāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap79:1.1":{"pli":"“Tiṁsakappasahassamhi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap79:1.2":{"pli":"sambuddho lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap79:1.3":{"pli":"Sumedho nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap79:1.4":{"pli":"bāttiṁsavaralakkhaṇo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap79:2.1":{"pli":"Tassa kañcanavaṇṇassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap79:2.2":{"pli":"dvipadindassa tādino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap79:2.3":{"pli":"Pañca sūcī mayā dinnā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap79:2.4":{"pli":"sibbanatthāya cīvaraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap79:3.1":{"pli":"Teneva sūcidānena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap79:3.2":{"pli":"nipuṇatthavipassakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap79:3.3":{"pli":"Tikkhaṁ lahuñca phāsuñca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap79:3.4":{"pli":"ñāṇaṁ me udapajjatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap79:4.1":{"pli":"Kilesā jhāpitā may