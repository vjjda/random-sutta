":"“Aṅgārajātā pathavī, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap459:1.2":{"pli":"kukkuḷānugatā mahī; ","html":"<span class='verse-line'>{}</span>"},"tha-ap459:1.3":{"pli":"Padumuttaro bhagavā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap459:1.4":{"pli":"abbhokāsamhi caṅkami. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap459:2.1":{"pli":"Paṇḍaraṁ chattamādāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap459:2.2":{"pli":"addhānaṁ paṭipajjahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap459:2.3":{"pli":"Tattha disvāna sambuddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap459:2.4":{"pli":"vitti me upapajjatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap459:3.1":{"pli":"Marīciyotthaṭā bhūmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap459:3.2":{"pli":"aṅgārāva mahī ayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap459:3.3":{"pli":"Upahanti mahāvātā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap459:3.4":{"pli":"sarīrassāsukhepanā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap459:4.1":{"pli":"Sītaṁ uṇhaṁ vihanantaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap459:4.2":{"pli":"vātātapanivāraṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap459:4.3":{"pli":"Paṭiggaṇha imaṁ chattaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap459:4.4":{"pli":"phassayissāmi nibbutiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap459:5.1":{"pli":"Anukampako kāruṇiko, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap459:5.2":{"pli":"padumuttaro mahāyaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap459:5.3":{"pli":"Mama saṅkappamaññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap459:5.4":{"pli":"paṭiggaṇhi tadā jino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap459:6.1":{"pli":"Tiṁsa kappāni devindo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap459:6.2":{"pli":"devarajjamakārayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap459:6.3":{"pli":"Satānaṁ pañcakkhattuñca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap459:6.4":{"pli":"cakkavattī ahosahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap459:7.1":{"pli":"Padesarajjaṁ vipulaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap459:7.2":{"pli":"gaṇanāto asaṅkhiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap459:7.3":{"pli":"Anubhomi sakaṁ kammaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap459:7.4":{"pli":"pubbe sukatamattano. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap459:8.1":{"pli":"Ayaṁ me pacchimā jāti, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap459:8.2":{"pli":"carimo vattate bhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap459:8.3":{"pli":"Ajjāpi setacchattaṁ me, ","html":"<span class='verse-line'>{}</span>"},"tha-ap459:8.4":{"pli":"sabbakālaṁ dharīyati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap459:9.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap459:9.2":{"pli":"yaṁ chattamadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap459:9.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap459:9.4":{"pli":"chattadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap459:10.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap459:10.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap459:10.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap459:11.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap459:11.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap459:11.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap459:12.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap459:12.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap459:12.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap459:13.1":{"pli":"Itthaṁ sudaṁ āyasmā ekachattiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap459:14.1":{"pli":"Ekachattiyattherassāpadānaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}