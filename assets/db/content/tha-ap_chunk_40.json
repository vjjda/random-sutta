,"html":"<span class='verse-line'>{}</span></p>"},"tha-ap450:9.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap450:9.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap450:9.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap450:10.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap450:10.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap450:10.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap450:11.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap450:11.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap450:11.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap450:12.1":{"pli":"Itthaṁ sudaṁ āyasmā pādapīṭhiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap450:13.1":{"pli":"Pādapīṭhiyattherassāpadānaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap451":{"tha-ap451:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap451'><header><ul><li class='division'>{}</li>"},"tha-ap451:0.2":{"pli":"Vibhītakavagga ","html":"<li>{}</li></ul>"},"tha-ap451:0.3":{"pli":"9 Vedikārakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap451:1.1":{"pli":"“Padumuttarassa bhagavato, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap451:1.2":{"pli":"Bodhiyā pādaputtame; ","html":"<span class='verse-line'>{}</span>"},"tha-ap451:1.3":{"pli":"Vedikaṁ sukataṁ katvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap451:1.4":{"pli":"Sakaṁ cittaṁ pasādayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap451:2.1":{"pli":"Atoḷārāni bhaṇḍāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap451:2.2":{"pli":"katāni akatāni ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap451:2.3":{"pli":"Antalikkhā pavassanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap451:2.4":{"pli":"vedikāya idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap451:3.1":{"pli":"Ubhato byūḷhasaṅgāme, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap451:3.2":{"pli":"pakkhandanto bhayānake; ","html":"<span class='verse-line'>{}</span>"},"tha-ap451:3.3":{"pli":"Bhayabheravaṁ na passāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap451:3.4":{"pli":"vedikāya idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap451:4.1":{"pli":"Mama saṅkappamaññāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap451:4.2":{"pli":"byamhaṁ nibbattate subhaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap451:4.3":{"pli":"Sayanāni mahagghāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap451:4.4":{"pli":"vedikāya idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap451:5.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap451:5.2":{"pli":"yaṁ vedikamakārayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap451:5.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap451:5.4":{"pli":"vedikāya idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap451:6.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap451:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap451:6.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap451:7.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap451:7.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap451:7.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap451:8.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap451:8.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap451:8.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap451:9.1":{"pli":"Itthaṁ sudaṁ āyasmā vedikārako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap451:10.1":{"pli":"Vedikārakattherassāpadānaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap452":{"tha-ap452:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap452'><header><ul><li class='division'>{}</li>"},"tha-ap452:0.2":{"pli":"Vibhītakavagga ","html":"<li>{}</li></ul>"},"tha-ap452:0.3":{"pli":"10 Bodhigharadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap452:1.1":{"pli":"“Siddhatthassa bhagavato, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap452:1.2":{"pli":"dvipadindassa tādino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap452:1.3":{"pli":"Pasannacitto sumano, ","html":"<span class='verse-line'>{}</span>"},"tha-ap452:1.4":{"pli":"bodhigharamakārayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap452:2.1":{"pli":"Tusitaṁ upapannomhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap452:2.2":{"pli":"vasāmi ratane ghare; ","html":"<span class='verse-line'>{}</span>"},"tha-ap452:2.3":{"pli":"Na me sītaṁ vā uṇhaṁ vā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap452:2.4":{"pli":"vāto gatte na samphuse. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap452:3.1":{"pli":"Pañcasaṭṭhimhito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap452:3.2":{"pli":"cakkavattī ahosahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap452:3.3":{"pli":"Kāsikaṁ nāma nagaraṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap452:3.4":{"pli":"vissakammena māpitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap452:4.1":{"pli":"Dasayojanaāyāmaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap452:4.2":{"pli":"aṭṭhayojanavitthataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap452:4.3":{"pli":"Na tamhi nagare atthi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap452:4.4":{"pli":"kaṭṭhaṁ vallī ca mattikā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap452:5.1":{"pli":"Tiriyaṁ yojanaṁ āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap452:5.2":{"pli":"addhayojanavitthataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap452:5.3":{"pli":"Maṅgalo nāma pāsādo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap452:5.4":{"pli":"vissakammena māpito. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap452:6.1":{"pli":"Cullāsītisahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap452:6.2":{"pli":"thambhā soṇṇamayā ahuṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap452:6.3":{"pli":"Maṇimayā ca niyyūhā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap452:6.4":{"pli":"chadanaṁ rūpiyaṁ ahu. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap452:7.1":{"pli":"Sabbasoṇṇamayaṁ gharaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap452:7.2":{"pli":"vissakammena māpitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap452:7.3":{"pli":"Ajjhāvutthaṁ mayā etaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap452:7.4":{"pli":"gharadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap452:8.1":{"pli":"Te sabbe anubhotvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap452:8.2":{"pli":"devamānusake bhave; ","html":"<span class='verse-line'>{}</span>"},"tha-ap452:8.3":{"pli":"Ajjhapattomhi nibbānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap452:8.4":{"pli":"santipadamanuttaraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap452:9.1":{"pli":"Tiṁsakappasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap452:9.2":{"pli":"bodhigharamakārayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap452:9.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap452:9.4":{"pli":"gharadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap452:10.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap452:10.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap452:10.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap452:11.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap452:11.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap452:11.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap452:12.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap452:12.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap452:12.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap452:13.1":{"pli":"Itthaṁ sudaṁ āyasmā bodhigharadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap452:14.1":{"pli":"Bodhigharadāyakattherassāpadānaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap452:15.1":{"pli":"Vibhītakavaggo pañcacattālīsamo. ","html":"<p class='endsection'>{}</p>"},"tha-ap452:16.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"tha-ap452:17.1":{"pli":"Vibhītakī kolaphalī, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"tha-ap452:17.2":{"pli":"billabhallātakappado; ","html":"<span class='verse-line'>{}</span>"},"tha-ap452:17.3":{"pli":"Uttalambaṭakī ceva, ","html":"<span class='verse-line'>{}</span>"},"tha-ap452:17.4":{"pli":"āsanī pādapīṭhako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap452:18.1":{"pli":"Vediko bodhighariko, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap452:18.2":{"pli":"gāthāyo gaṇitāpi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap452:18.3":{"pli":"Ekūnāsītikā sabbā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap452:18.4":{"pli":"asmiṁ vagge pakittitā. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"tha-ap453":{"tha-ap453:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap453'><header><ul><li class='division'>{}</li>"},"tha-ap453:0.2":{"pli":"Jagatidāyakavagga ","html":"<li>{}</li></ul>"},"tha-ap453:0.3":{"pli":"Jagatidāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap453:1.1":{"pli":"“Dhammadassissa munino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap453:1.2":{"pli":"bodhiyā pādaputtame; ","html":"<span class='verse-line'>{}</span>"},"tha-ap453:1.3":{"pli":"Pasannacitto sumano, ","html":"<span class='verse-line'>{}</span>"},"tha-ap453:1.4":{"pli":"jagatiṁ kārayiṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap453:2.1":{"pli":"Darito pabbatato vā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap453:2.2":{"pli":"rukkhato patito ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap453:2.3":{"pli":"Cuto patiṭṭhaṁ vindāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap453:2.4":{"pli":"jagatiyā idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap453:3.1":{"pli":"Na me corā vihesanti, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap453:3.2":{"pli":"nātimaññanti khattiyā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap453:3.3":{"pli":"Sabbāmittetikkamāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap453:3.4":{"pli":"jagatiyā idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap453:4.1":{"pli":"Yaṁ yaṁ yonupapajjāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap453:4.2":{"pli":"devattaṁ atha mānusaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap453:4.3":{"pli":"Sabbattha pūjito homi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap453:4.4":{"pli":"jagatiyā idaṁ phalaṁ. ","html":"<span class='verse-lin