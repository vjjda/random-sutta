l":"<span class='verse-line'>{}</span></p>"},"tha-ap45:11.1":{"pli":"Catusattatikkhattuṁ so, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap45:11.2":{"pli":"devarajjaṁ karissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap45:11.3":{"pli":"Anubhossati sampattiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap45:11.4":{"pli":"accharāhi purakkhato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap45:12.1":{"pli":"Padesarajjaṁ sahassaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap45:12.2":{"pli":"vasudhaṁ āvasissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap45:12.3":{"pli":"Ekapaññāsakkhattuñca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap45:12.4":{"pli":"cakkavattī bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap45:13.1":{"pli":"Sabbāsu bhavayonīsu, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap45:13.2":{"pli":"uccākulī bhavissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap45:13.3":{"pli":"So ca pacchā pabbajitvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap45:13.4":{"pli":"sukkamūlena codito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap45:13.5":{"pli":"Bhaddiyo nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap45:13.6":{"pli":"hessati satthu sāvako’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap45:14.1":{"pli":"Vivekamanuyuttomhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap45:14.2":{"pli":"pantasenanivāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap45:14.3":{"pli":"Phalañcādhigataṁ sabbaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap45:14.4":{"pli":"cattaklesomhi ajjahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap45:15.1":{"pli":"Mama sabbaṁ abhiññāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap45:15.2":{"pli":"sabbaññū lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap45:15.3":{"pli":"Bhikkhusaṅghe nisīditvā, ","html":"