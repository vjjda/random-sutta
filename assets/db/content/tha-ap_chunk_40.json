āna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap45:1.1":{"pli":"“Padumuttarasambuddhaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap45:1.2":{"pli":"mettacittaṁ mahāmuniṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap45:1.3":{"pli":"Upeti janatā sabbā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap45:1.4":{"pli":"sabbalokagganāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap45:2.1":{"pli":"Sattukañca baddhakañca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap45:2.2":{"pli":"āmisaṁ pānabhojanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap45:2.3":{"pli":"Dadanti satthuno sabbe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap45:2.4":{"pli":"puññakkhette anuttare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap45:3.1":{"pli":"Ahampi dānaṁ dassāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap45:3.2":{"pli":"devadevassa tādino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap45:3.3":{"pli":"Buddhaseṭṭhaṁ nimantetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap45:3.4":{"pli":"saṅghampi ca anuttaraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap45:4.1":{"pli":"Uyyojitā mayā cete, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap45:4.2":{"pli":"nimantesuṁ tathāgataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap45:4.3":{"pli":"Kevalaṁ bhikkhusaṅghañca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap45:4.4":{"pli":"puññakkhettaṁ anuttaraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap45:5.1":{"pli":"Satasahassapallaṅkaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap45:5.2":{"pli":"sovaṇṇaṁ gonakatthataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap45:5.3":{"pli":"Tūlikāpaṭalikāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap45:5.4":{"pli":"khomakappāsikehi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap45:5.5":{"pli":"Mahārahaṁ pa