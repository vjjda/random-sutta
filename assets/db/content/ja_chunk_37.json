{"ja527":{"ja527:0.1":{"pli":"Jātaka ","html":"<article id='ja527'><header><ul><li class='division'>{}</li>"},"ja527:0.2":{"pli":"Paṇṇāsanipāta ","html":"<li>{}</li>"},"ja527:0.3":{"pli":"Niḷinikāvagga ","html":"<li>{}</li></ul>"},"ja527:0.4":{"pli":"2 Ummādantījātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja527:1.1":{"pli":"“Nivesanaṁ kassa nudaṁ sunanda, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja527:1.2":{"pli":"Pākārena paṇḍumayena guttaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja527:1.3":{"pli":"Kā dissati aggisikhāva dūre, ","html":"<span class='verse-line'>{}</span>"},"ja527:1.4":{"pli":"Vehāyasaṁ pabbataggeva acci. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:2.1":{"pli":"Dhītā nvayaṁ kassa sunanda hoti, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:2.2":{"pli":"Suṇisā nvayaṁ kassa athopi bhariyā; ","html":"<span class='verse-line'>{}</span>"},"ja527:2.3":{"pli":"Akkhāhi me khippamidheva puṭṭho, ","html":"<span class='verse-line'>{}</span>"},"ja527:2.4":{"pli":"Avāvaṭā yadi vā atthi bhattā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:3.1":{"pli":"“Ahañhi jānāmi janinda etaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:3.2":{"pli":"Matyā ca petyā ca athopi assā; ","html":"<span class='verse-line'>{}</span>"},"ja527:3.3":{"pli":"Taveva so puriso bhūmipāla, ","html":"<span class='verse-line'>{}</span>"},"ja527:3.4":{"pli":"Rattindivaṁ appamatto tavatthe. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:4.1":{"pli":"Iddho ca phīto ca suvaḍḍhito ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:4.2":{"pli":"Amacco ca te aññataro janinda; ","html":"<span class='verse-line'>{}</span>"},"ja527:4.3":{"pli":"Tassesā bhariyābhipārakassa, ","html":"<span class='verse-line'>{}</span>"},"ja527:4.4":{"pli":"Ummādantī nāmadheyyena rāja”. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:5.1":{"pli":"“Ambho ambho nāmamidaṁ imissā, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:5.2":{"pli":"Matyā ca petyā ca kataṁ susādhu; ","html":"<span class='verse-line'>{}</span>"},"ja527:5.3":{"pli":"Tadā hi mayhaṁ avalokayantī, ","html":"<span class='verse-line'>{}</span>"},"ja527:5.4":{"pli":"Ummattakaṁ ummadantī akāsi. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:6.1":{"pli":"Yā puṇṇamāse migamandalocanā, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:6.2":{"pli":"Upāvisi puṇḍarīkattacaṅgī; ","html":"<span class='verse-line'>{}</span>"},"ja527:6.3":{"pli":"Dve puṇṇamāyo tadahū amaññahaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja527:6.4":{"pli":"Disvāna pārāvatarattavāsiniṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:7.1":{"pli":"Aḷārapamhehi subhehi vaggubhi, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:7.2":{"pli":"Palobhayantī maṁ yadā udikkhati; ","html":"<span class='verse-line'>{}</span>"},"ja527:7.3":{"pli":"Vijambhamānā harateva me mano, ","html":"<span class='verse-line'>{}</span>"},"ja527:7.4":{"pli":"Jātā vane kimpurisīva pabbate. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:8.1":{"pli":"Tadā hi brahatī sāmā, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:8.2":{"pli":"āmuttamaṇikuṇḍalā; ","html":"<span class='verse-line'>{}</span>"},"ja527:8.3":{"pli":"Ekaccavasanā nārī, ","html":"<span class='verse-line'>{}</span>"},"ja527:8.4":{"pli":"migī bhantāvudikkhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:9.1":{"pli":"Kadāssu maṁ tambanakhā sulomā, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:9.2":{"pli":"Bāhāmudū candanasāralittā; ","html":"<span class='verse-line'>{}</span>"},"ja527:9.3":{"pli":"Vaṭṭaṅgulī sannatadhīrakuttiyā, ","html":"<span class='verse-line'>{}</span>"},"ja527:9.4":{"pli":"Nārī upaññissati sīsato subhā. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:10.1":{"pli":"Kadāssu maṁ kañcanajāluracchadā, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:10.2":{"pli":"Dhītā tirīṭissa vilaggamajjhā; ","html":"<span class='verse-line'>{}</span>"},"ja527:10.3":{"pli":"Mudūhi bāhāhi palissajissati, ","html":"<span class='verse-line'>{}</span>"},"ja527:10.4":{"pli":"Brahāvane jātadumaṁva māluvā. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:11.1":{"pli":"Kadāssu lākhārasarattasucchavī, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:11.2":{"pli":"Bindutthanī puṇḍarīkattacaṅgī; ","html":"<span class='verse-line'>{}</span>"},"ja527:11.3":{"pli":"Mukhaṁ mukhena upanāmayissati, ","html":"<span class='verse-line'>{}</span>"},"ja527:11.4":{"pli":"Soṇḍova soṇḍassa surāya thālaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:12.1":{"pli":"Yadāddasaṁ taṁ tiṭṭhantiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:12.2":{"pli":"Sabbabhaddaṁ manoramaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja527:12.3":{"pli":"Tato sakassa cittassa, ","html":"<span class='verse-line'>{}</span>"},"ja527:12.4":{"pli":"Nāvabodhāmi kañcinaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:13.1":{"pli":"Ummādantimahaṁ daṭṭhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:13.2":{"pli":"āmuttamaṇikuṇḍalaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja527:13.3":{"pli":"Na supāmi divārattiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja527:13.4":{"pli":"sahassaṁva parājito. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:14.1":{"pli":"Sakko ce me varaṁ dajjā, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:14.2":{"pli":"so ca labbhetha me varo; ","html":"<span class='verse-line'>{}</span>"},"ja527:14.3":{"pli":"Ekarattaṁ dvirattaṁ vā, ","html":"<span class='verse-line'>{}</span>"},"ja527:14.4":{"pli":"bhaveyyaṁ abhipārako; ","html":"<span class='verse-line'>{}</span>"},"ja527:14.5":{"pli":"Ummādantyā ramitvāna, ","html":"<span class='verse-line'>{}</span>"},"ja527:14.6":{"pli":"sivirājā tato siyaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:15.1":{"pli":"“Bhūtāni me bhūtapatī namassato, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:15.2":{"pli":"Āgamma yakkho idametadabravi; ","html":"<span class='verse-line'>{}</span>"},"ja527:15.3":{"pli":"Rañño mano ummadantyā niviṭṭho, ","html":"<span class='verse-line'>{}</span>"},"ja527:15.4":{"pli":"Dadāmi te taṁ paricārayassu”. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:16.1":{"pli":"“Puññā ca dhaṁse amaro na camhi, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:16.2":{"pli":"Jano ca me pāpamidañca jaññā; ","html":"<span class='verse-line'>{}</span>"},"ja527:16.3":{"pli":"Bhuso ca tyassa manaso vighāto, ","html":"<span class='verse-line'>{}</span>"},"ja527:16.4":{"pli":"Datvā piyaṁ ummadantiṁ adaṭṭhā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:17.1":{"pli":"“Janinda nāññatra tayā mayā vā, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:17.2":{"pli":"Sabbāpi kammassa katassa jaññā; ","html":"<span class='verse-line'>{}</span>"},"ja527:17.3":{"pli":"Yaṁ te mayā ummadantī padinnā, ","html":"<span class='verse-line'>{}</span>"},"ja527:17.4":{"pli":"Bhusehi rājā vanathaṁ sajāhi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:18.1":{"pli":"“Yo pāpakaṁ kamma karaṁ manusso, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:18.2":{"pli":"So maññati māyida maññiṁsu aññe; ","html":"<span class='verse-line'>{}</span>"},"ja527:18.3":{"pli":"Passanti bhūtāni karontametaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja527:18.4":{"pli":"Yuttā ca ye honti narā pathabyā. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:19.1":{"pli":"Añño nu te koci naro pathabyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:19.2":{"pli":"Saddheyya lokasmi na me piyāti; ","html":"<span class='verse-line'>{}</span>"},"ja527:19.3":{"pli":"Bhuso ca tyassa manaso vighāto, ","html":"<span class='verse-line'>{}</span>"},"ja527:19.4":{"pli":"Datvā piyaṁ ummadantiṁ adaṭṭhā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:20.1":{"pli":"“Addhā piyā mayha janinda esā, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:20.2":{"pli":"Na sā mamaṁ appiyā bhūmipāla; ","html":"<span class='verse-line'>{}</span>"},"ja527:20.3":{"pli":"Gaccheva tvaṁ ummadantiṁ bhadante, ","html":"<span class='verse-line'>{}</span>"},"ja527:20.4":{"pli":"Sīhova selassa guhaṁ upeti”. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:21.1":{"pli":"“Na pīḷitā attadukhena dhīrā, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:21.2":{"pli":"Sukhapphalaṁ kamma pariccajanti; ","html":"<span class='verse-line'>{}</span>"},"ja527:21.3":{"pli":"Sammohitā vāpi sukhena mattā, ","html":"<span class='verse-line'>{}</span>"},"ja527:21.4":{"pli":"Na pāpakammañca samācaranti”. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:22.1":{"pli":"“Tuvañhi mātā ca pitā ca mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:22.2":{"pli":"Bhattā patī posako devatā ca; ","html":"<span class='verse-line'>{}</span>"},"ja527:22.3":{"pli":"Dāso ahaṁ tuyha saputtadāro, ","html":"<span class='verse-line'>{}</span>"},"ja527:22.4":{"pli":"Yathāsukhaṁ sāmi karohi kāmaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:23.1":{"pli":"“Yo issaromhīti karoti pāpaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:23.2":{"pli":"Katvā ca so nuttasate paresaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja527:23.3":{"pli":"Na tena so jīvati dīghamāyu, ","html":"<span class='verse-line'>{}</span>"},"ja527:23.4":{"pli":"Devāpi pāpena samekkhare naṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:24.1":{"pli":"Aññātakaṁ sāmikehī padinnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:24.2":{"pli":"Dhamme ṭhitā ye paṭicchanti dānaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja527:24.3":{"pli":"Paṭicchakā dāyakā cāpi tattha, ","html":"<span class='verse-line'>{}</span>"},"ja527:24.4":{"pli":"Sukhapphalaññeva karonti kammaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:25.1":{"pli":"Añño nu te koci naro pathabyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:25.2":{"pli":"Saddheyya lokasmi na me piyāti; ","html":"<span class='verse-line'>{}</span>"},"ja527:25.3":{"pli":"Bhuso ca tyassa manaso vighāto, ","html":"<span class='verse-line'>{}</span>"},"ja527:25.4":{"pli":"Datvā piyaṁ ummadantiṁ adaṭṭhā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:26.1":{"pli":"“Addhā piyā mayha janinda esā, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:26.2":{"pli":"Na sā mamaṁ appiyā bhūmipāla; ","html":"<span class='verse-line'>{}</span>"},"ja527:26.3":{"pli":"Yaṁ te mayā ummadantī padinnā, ","html":"<span class='verse-line'>{}</span>"},"ja527:26.4":{"pli":"Bhusehi rājā vanathaṁ sajāhi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:27.1":{"pli":"“Yo attadukkhena parassa dukkhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:27.2":{"pli":"Sukhena vā attasukhaṁ dahāti; ","html":"<span class='verse-line'>{}</span>"},"ja527:27.3":{"pli":"Yathevidaṁ mayha tathā paresaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja527:27.4":{"pli":"Yo evaṁ jānāti sa vedi dhammaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:28.1":{"pli":"Añño nu te koci naro pathabyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:28.2":{"pli":"Saddheyya lokasmi na me piyāti; ","html":"<span class='verse-line'>{}</span>"},"ja527:28.3":{"pli":"Bhuso ca tyassa manaso vighāto, ","html":"<span class='verse-line'>{}</span>"},"ja527:28.4":{"pli":"Datvā piyaṁ ummadantiṁ adaṭṭhā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:29.1":{"pli":"“Janinda jānāsi piyā mamesā, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:29.2":{"pli":"Na sā mamaṁ appiyā bhūmipāla; ","html":"<span class='verse-line'>{}</span>"},"ja527:29.3":{"pli":"Piyena te dammi piyaṁ janinda, ","html":"<span class='verse-line'>{}</span>"},"ja527:29.4":{"pli":"Piyadāyino deva piyaṁ labhanti”. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:30.1":{"pli":"“So nūnāhaṁ vadhissāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:30.2":{"pli":"attānaṁ kāmahetukaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja527:30.3":{"pli":"Na hi dhammaṁ adhammena, ","html":"<span class='verse-line'>{}</span>"},"ja527:30.4":{"pli":"ahaṁ vadhitumussahe”. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:31.1":{"pli":"“Sace tuvaṁ mayha satiṁ janinda, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:31.2":{"pli":"Na kāmayāsi naravīra seṭṭha; ","html":"<span class='verse-line'>{}</span>"},"ja527:31.3":{"pli":"Cajāmi naṁ sabbajanassa sibyā, ","html":"<span class='verse-line'>{}</span>"},"ja527:31.4":{"pli":"Mayā pamuttaṁ tato avhayesi naṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:32.1":{"pli":"“Adūsiyañce abhipāraka tvaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:32.2":{"pli":"Cajāsi katte ahitāya tyassa; ","html":"<span class='verse-line'>{}</span>"},"ja527:32.3":{"pli":"Mahā ca te upavādopi assa, ","html":"<span class='verse-line'>{}</span>"},"ja527:32.4":{"pli":"Na cāpi tyassa nagaramhi pakkho”. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:33.1":{"pli":"“Ahaṁ sahissaṁ upavādametaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:33.2":{"pli":"Nindaṁ pasaṁsaṁ garahañca sabbaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja527:33.3":{"pli":"Mametamāgacchatu bhūmipāla, ","html":"<span class='verse-line'>{}</span>"},"ja527:33.4":{"pli":"Yathāsukhaṁ sivi karohi kāmaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:34.1":{"pli":"“Yo neva nindaṁ na panappasaṁsaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:34.2":{"pli":"Ādiyati garahaṁ nopi pūjaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja527:34.3":{"pli":"Sirī ca lakkhī ca apeti tamhā, ","html":"<span class='verse-line'>{}</span>"},"ja527:34.4":{"pli":"Āpo suvuṭṭhīva yathā thalamhā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:35.1":{"pli":"“Yaṁ kiñci dukkhañca sukhañca etto, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:35.2":{"pli":"Dhammātisārañca manovighātaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja527:35.3":{"pli":"Urasā ahaṁ paccuttarissāmi sabbaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja527:35.4":{"pli":"Pathavī yathā thāvarānaṁ tasānaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:36.1":{"pli":"“Dhammātisārañca manovighātaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:36.2":{"pli":"Dukkhañca nicchāmi ahaṁ paresaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja527:36.3":{"pli":"Ekovimaṁ hārayissāmi bhāraṁ, ","html":"<span class='verse-line'>{}</span>"},"ja527:36.4":{"pli":"Dhamme ṭhito kiñci ahāpayanto”. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:37.1":{"pli":"“Saggūpagaṁ puññakammaṁ janinda, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:37.2":{"pli":"Mā me tuvaṁ antarāyaṁ akāsi; ","html":"<span class='verse-line'>{}</span>"},"ja527:37.3":{"pli":"Dadāmi te ummadantiṁ pasanno, ","html":"<span class='verse-line'>{}</span>"},"ja527:37.4":{"pli":"Rājāva yaññe dhanaṁ brāhmaṇānaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:38.1":{"pli":"“Addhā tuvaṁ katte hitesi mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:38.2":{"pli":"Sakhā mamaṁ ummadantī tuvañca; ","html":"<span class='verse-line'>{}</span>"},"ja527:38.3":{"pli":"Nindeyyu devā pitaro ca sabbe, ","html":"<span class='verse-line'>{}</span>"},"ja527:38.4":{"pli":"Pāpañca passaṁ abhisamparāyaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:39.1":{"pli":"“Na hetadhammaṁ sivirāja vajjuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:39.2":{"pli":"Sanegamā jānapadā ca sabbe; ","html":"<span class='verse-line'>{}</span>"},"ja527:39.3":{"pli":"Yaṁ te mayā ummadantī padinnā, ","html":"<span class='verse-line'>{}</span>"},"ja527:39.4":{"pli":"Bhusehi rājā vanathaṁ sajāhi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:40.1":{"pli":"“Addhā tuvaṁ katte hitesi mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:40.2":{"pli":"Sakhā mamaṁ ummadantī tuvañca; ","html":"<span class='verse-line'>{}</span>"},"ja527:40.3":{"pli":"Satañca dhammāni sukittitāni, ","html":"<span class='verse-line'>{}</span>"},"ja527:40.4":{"pli":"Samuddavelāva duraccayāni”. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:41.1":{"pli":"“Āhuneyyo mesi hitānukampī, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:41.2":{"pli":"Dhātā vidhātā casi kāmapālo; ","html":"<span class='verse-line'>{}</span>"},"ja527:41.3":{"pli":"Tayī hutā rāja mahapphalā hi, ","html":"<span class='verse-line'>{}</span>"},"ja527:41.4":{"pli":"Kāmena me ummadantiṁ paṭiccha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:42.1":{"pli":"“Addhā hi sabbaṁ abhipāraka tvaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:42.2":{"pli":"Dhammaṁ acārī mama kattuputta; ","html":"<span class='verse-line'>{}</span>"},"ja527:42.3":{"pli":"Añño nu te ko idha sotthikattā, ","html":"<span class='verse-line'>{}</span>"},"ja527:42.4":{"pli":"Dvipado naro aruṇe jīvaloke”. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:43.1":{"pli":"“Tuvaṁ nu seṭṭho tvamanuttarosi, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:43.2":{"pli":"Tvaṁ dhammagutto dhammavidū sumedho; ","html":"<span class='verse-line'>{}</span>"},"ja527:43.3":{"pli":"So dhammagutto cirameva jīva, ","html":"<span class='verse-line'>{}</span>"},"ja527:43.4":{"pli":"Dhammañca me desaya dhammapāla”. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:44.1":{"pli":"“Tadiṅgha abhipāraka, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:44.2":{"pli":"suṇohi vacanaṁ mama; ","html":"<span class='verse-line'>{}</span>"},"ja527:44.3":{"pli":"Dhammaṁ te desayissāmi, ","html":"<span class='verse-line'>{}</span>"},"ja527:44.4":{"pli":"sataṁ āsevitaṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:45.1":{"pli":"Sādhu dhammaruci rājā, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:45.2":{"pli":"sādhu paññāṇavā naro; ","html":"<span class='verse-line'>{}</span>"},"ja527:45.3":{"pli":"Sādhu mittānamaddubbho, ","html":"<span class='verse-line'>{}</span>"},"ja527:45.4":{"pli":"pāpassākaraṇaṁ sukhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:46.1":{"pli":"Akkodhanassa vijite, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:46.2":{"pli":"ṭhitadhammassa rājino; ","html":"<span class='verse-line'>{}</span>"},"ja527:46.3":{"pli":"Sukhaṁ manussā āsetha, ","html":"<span class='verse-line'>{}</span>"},"ja527:46.4":{"pli":"sītacchāyāya saṅghare. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:47.1":{"pli":"Na cāhametaṁ abhirocayāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:47.2":{"pli":"Kammaṁ asamekkhakataṁ asādhu; ","html":"<span class='verse-line'>{}</span>"},"ja527:47.3":{"pli":"Ye vāpi ñatvāna sayaṁ karonti, ","html":"<span class='verse-line'>{}</span>"},"ja527:47.4":{"pli":"Upamā imā mayhaṁ tuvaṁ suṇohi. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:48.1":{"pli":"Gavañce taramānānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:48.2":{"pli":"jimhaṁ gacchati puṅgavo; ","html":"<span class='verse-line'>{}</span>"},"ja527:48.3":{"pli":"Sabbā tā jimhaṁ gacchanti, ","html":"<span class='verse-line'>{}</span>"},"ja527:48.4":{"pli":"nette jimhaṁ gate sati. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:49.1":{"pli":"Evameva manussesu, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:49.2":{"pli":"yo hoti seṭṭhasammato; ","html":"<span class='verse-line'>{}</span>"},"ja527:49.3":{"pli":"So ce adhammaṁ carati, ","html":"<span class='verse-line'>{}</span>"},"ja527:49.4":{"pli":"pageva itarā pajā; ","html":"<span class='verse-line'>{}</span>"},"ja527:49.5":{"pli":"Sabbaṁ raṭṭhaṁ dukhaṁ seti, ","html":"<span class='verse-line'>{}</span>"},"ja527:49.6":{"pli":"rājā ce hoti adhammiko. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:50.1":{"pli":"Gavañce taramānānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:50.2":{"pli":"ujuṁ gacchati puṅgavo; ","html":"<span class='verse-line'>{}</span>"},"ja527:50.3":{"pli":"Sabbā gāvī ujuṁ yanti, ","html":"<span class='verse-line'>{}</span>"},"ja527:50.4":{"pli":"nette ujuṁ gate sati. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:51.1":{"pli":"Evameva manussesu, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:51.2":{"pli":"yo hoti seṭṭhasammato; ","html":"<span class='verse-line'>{}</span>"},"ja527:51.3":{"pli":"So sace dhammaṁ carati, ","html":"<span class='verse-line'>{}</span>"},"ja527:51.4":{"pli":"pageva itarā pajā; ","html":"<span class='verse-line'>{}</span>"},"ja527:51.5":{"pli":"Sabbaṁ raṭṭhaṁ sukhaṁ seti, ","html":"<span class='verse-line'>{}</span>"},"ja527:51.6":{"pli":"rājā ce hoti dhammiko. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:52.1":{"pli":"Na cāpāhaṁ adhammena, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:52.2":{"pli":"amarattamabhipatthaye; ","html":"<span class='verse-line'>{}</span>"},"ja527:52.3":{"pli":"Imaṁ vā pathaviṁ sabbaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja527:52.4":{"pli":"vijetuṁ abhipāraka. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:53.1":{"pli":"Yañhi kiñci manussesu, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:53.2":{"pli":"ratanaṁ idha vijjati; ","html":"<span class='verse-line'>{}</span>"},"ja527:53.3":{"pli":"Gāvo dāso hiraññañca, ","html":"<span class='verse-line'>{}</span>"},"ja527:53.4":{"pli":"vatthiyaṁ haricandanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:54.1":{"pli":"Assitthiyo ratanaṁ maṇikañca, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:54.2":{"pli":"Yañcāpi me candasūriyā abhipālayanti; ","html":"<span class='verse-line'>{}</span>"},"ja527:54.3":{"pli":"Na tassa hetu visamaṁ careyyaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja527:54.4":{"pli":"Majjhe sivīnaṁ usabhomhi jāto. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:55.1":{"pli":"Netā hitā uggato raṭṭhapālo, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:55.2":{"pli":"Dhammaṁ sivīnaṁ apacāyamāno; ","html":"<span class='verse-line'>{}</span>"},"ja527:55.3":{"pli":"So dhammamevānuvicintayanto, ","html":"<span class='verse-line'>{}</span>"},"ja527:55.4":{"pli":"Tasmā sake cittavase na vatto”. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:56.1":{"pli":"“Addhā tuvaṁ mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:56.2":{"pli":"niccaṁ abyasanaṁ sivaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja527:56.3":{"pli":"Karissasi ciraṁ rajjaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja527:56.4":{"pli":"paññā hi tava tādisī. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:57.1":{"pli":"Etaṁ te anumodāma, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:57.2":{"pli":"yaṁ dhammaṁ nappamajjasi; ","html":"<span class='verse-line'>{}</span>"},"ja527:57.3":{"pli":"Dhammaṁ pamajja khattiyo, ","html":"<span class='verse-line'>{}</span>"},"ja527:57.4":{"pli":"raṭṭhā cavati issaro. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:58.1":{"pli":"Dhammaṁ cara mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:58.2":{"pli":"mātāpitūsu khattiya; ","html":"<span class='verse-line'>{}</span>"},"ja527:58.3":{"pli":"Idha dhammaṁ caritvāna, ","html":"<span class='verse-line'>{}</span>"},"ja527:58.4":{"pli":"rāja saggaṁ gamissasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:59.1":{"pli":"Dhammaṁ cara mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:59.2":{"pli":"puttadāresu khattiya; ","html":"<span class='verse-line'>{}</span>"},"ja527:59.3":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span></p>"},"ja527:60.1":{"pli":"Dhammaṁ cara mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:60.2":{"pli":"mittāmaccesu khattiya; ","html":"<span class='verse-line'>{}</span>"},"ja527:60.3":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span></p>"},"ja527:61.1":{"pli":"Dhammaṁ cara mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:61.2":{"pli":"vāhanesu balesu ca; ","html":"<span class='verse-line'>{}</span>"},"ja527:61.3":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span></p>"},"ja527:62.1":{"pli":"Dhammaṁ cara mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:62.2":{"pli":"gāmesu nigamesu ca; ","html":"<span class='verse-line'>{}</span>"},"ja527:62.3":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span></p>"},"ja527:63.1":{"pli":"Dhammaṁ cara mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:63.2":{"pli":"raṭṭhesu janapadesu ca; ","html":"<span class='verse-line'>{}</span>"},"ja527:63.3":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span></p>"},"ja527:64.1":{"pli":"Dhammaṁ cara mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:64.2":{"pli":"samaṇabrāhmaṇesu ca; ","html":"<span class='verse-line'>{}</span>"},"ja527:64.3":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span></p>"},"ja527:65.1":{"pli":"Dhammaṁ cara mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:65.2":{"pli":"migapakkhīsu khattiya; ","html":"<span class='verse-line'>{}</span>"},"ja527:65.3":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span></p>"},"ja527:66.1":{"pli":"Dhammaṁ cara mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:66.2":{"pli":"dhammo ciṇṇo sukhāvaho; ","html":"<span class='verse-line'>{}</span>"},"ja527:66.3":{"pli":"Idha dhammaṁ caritvāna, ","html":"<span class='verse-line'>{}</span>"},"ja527:66.4":{"pli":"rāja saggaṁ gamissasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja527:67.1":{"pli":"Dhammaṁ cara mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja527:67.2":{"pli":"saindā devā sabrahmakā; ","html":"<span class='verse-line'>{}</span>"},"ja527:67.3":{"pli":"Suciṇṇena divaṁ pattā, ","html":"<span class='verse-line'>{}</span>"},"ja527:67.4":{"pli":"mā dhammaṁ rāja pāmado”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja527:68.1":{"pli":"Ummādantījātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}