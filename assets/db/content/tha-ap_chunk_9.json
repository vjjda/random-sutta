><span class='verse-line'>{}</span>"},"tha-ap205:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap205:5.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap205:6.1":{"pli":"Itthaṁ sudaṁ āyasmā kiṅkaṇipupphiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap205:7.1":{"pli":"Kiṅkaṇipupphiyattherassāpadānaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}