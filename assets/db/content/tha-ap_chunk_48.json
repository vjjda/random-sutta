{"tha-ap519":{"tha-ap519:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap519'><header><ul><li class='division'>{}</li>"},"tha-ap519:0.2":{"pli":"Phaladāyakavagga ","html":"<li>{}</li></ul>"},"tha-ap519:0.3":{"pli":"Kuṭajapupphiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap519:1.1":{"pli":"“Himavantassāvidūre, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap519:1.2":{"pli":"vasalo nāma pabbato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap519:1.3":{"pli":"Buddho sudassano nāma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap519:1.4":{"pli":"vasate pabbatantare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap519:2.1":{"pli":"Pupphaṁ hemavantaṁ gayha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap519:2.2":{"pli":"vehāsaṁ agamāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap519:2.3":{"pli":"Tatthaddasāsiṁ sambuddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap519:2.4":{"pli":"oghatiṇṇamanāsavaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap519:3.1":{"pli":"Pupphaṁ kuṭajamādāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap519:3.2":{"pli":"sire katvāna añjaliṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap519:3.3":{"pli":"Buddhassa abhiropesiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap519:3.4":{"pli":"sayambhussa mahesino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap519:4.1":{"pli":"Ekatiṁse ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap519:4.2":{"pli":"yaṁ pupphamabhipūjayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap519:4.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap519:4.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap519:5.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap519:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap519:5.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap519:6.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap519:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap519:6.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap519:7.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap519:7.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap519:7.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap519:8.1":{"pli":"Itthaṁ sudaṁ āyasmā kuṭajapupphiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap519:9.1":{"pli":"Kuṭajapupphiyattherassāpadānaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap52":{"tha-ap52:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap52'><header><ul><li class='division'>{}</li>"},"tha-ap52:0.2":{"pli":"Upālivagga ","html":"<li>{}</li></ul>"},"tha-ap52:0.3":{"pli":"Cundattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap52:1.1":{"pli":"“Siddhatthassa bhagavato, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap52:1.2":{"pli":"lokajeṭṭhassa tādino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:1.3":{"pli":"Agghiyaṁ kārayitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:1.4":{"pli":"jātipupphehi chādayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap52:2.1":{"pli":"Niṭṭhāpetvāna taṁ pupphaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap52:2.2":{"pli":"buddhassa upanāmayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:2.3":{"pli":"Pupphāvasesaṁ paggayha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:2.4":{"pli":"buddhassa abhiropayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap52:3.1":{"pli":"Kañcanagghiyasaṅkāsaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap52:3.2":{"pli":"buddhaṁ lokagganāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:3.3":{"pli":"Pasannacitto sumano, ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:3.4":{"pli":"pupphagghiyamupānayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap52:4.1":{"pli":"Vitiṇṇakaṅkho sambuddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap52:4.2":{"pli":"tiṇṇoghehi purakkhato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:4.3":{"pli":"Bhikkhusaṅghe nisīditvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:4.4":{"pli":"imā gāthā abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap52:5.1":{"pli":"‘Dibbagandhaṁ pavāyantaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap52:5.2":{"pli":"yo me pupphagghiyaṁ adā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:5.3":{"pli":"Tamahaṁ kittayissāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:5.4":{"pli":"suṇātha mama bhāsato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap52:6.1":{"pli":"Ito cuto ayaṁ poso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap52:6.2":{"pli":"devasaṅghapurakkhato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:6.3":{"pli":"Jātipupphehi parikiṇṇo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:6.4":{"pli":"devalokaṁ gamissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap52:7.1":{"pli":"Ubbiddhaṁ bhavanaṁ tassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap52:7.2":{"pli":"Sovaṇṇañca maṇīmayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:7.3":{"pli":"Byamhaṁ pātubhavissati, ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:7.4":{"pli":"Puññakammappabhāvitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap52:8.1":{"pli":"Catusattatikkhattuṁ so, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap52:8.2":{"pli":"devarajjaṁ karissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:8.3":{"pli":"Anubhossati sampattiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:8.4":{"pli":"accharāhi purakkhato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap52:9.1":{"pli":"Pathabyā rajjaṁ tisataṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap52:9.2":{"pli":"vasudhaṁ āvasissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:9.3":{"pli":"Pañcasattatikkhattuñca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:9.4":{"pli":"cakkavattī bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap52:10.1":{"pli":"Dujjayo nāma nāmena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap52:10.2":{"pli":"hessati manujādhipo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:10.3":{"pli":"Anubhotvāna taṁ puññaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:10.4":{"pli":"sakakammaṁ apassito. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap52:11.1":{"pli":"Vinipātaṁ agantvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap52:11.2":{"pli":"manussattaṁ gamissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:11.3":{"pli":"Hiraññaṁ tassa nicitaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:11.4":{"pli":"koṭisatamanappakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap52:12.1":{"pli":"Nibbattissati yonimhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap52:12.2":{"pli":"brāhmaṇe so bhavissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:12.3":{"pli":"Vaṅgantassa suto dhīmā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:12.4":{"pli":"sāriyā oraso piyo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap52:13.1":{"pli":"So ca pacchā pabbajitvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap52:13.2":{"pli":"aṅgīrasassa sāsane; ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:13.3":{"pli":"Cūḷacundoti nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:13.4":{"pli":"hessati satthu sāvako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap52:14.1":{"pli":"Sāmaṇerova so santo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap52:14.2":{"pli":"khīṇāsavo bhavissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:14.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:14.4":{"pli":"nibbāyissatināsavo’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap52:15.1":{"pli":"Upaṭṭhahiṁ mahāvīraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap52:15.2":{"pli":"aññe ca pesale bahū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:15.3":{"pli":"Bhātaraṁ me cupaṭṭhāsiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:15.4":{"pli":"uttamatthassa pattiyā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap52:16.1":{"pli":"Bhātaraṁ me upaṭṭhitvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap52:16.2":{"pli":"dhātuṁ pattamhi ohiya; ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:16.3":{"pli":"Sambuddhaṁ upanāmesiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:16.4":{"pli":"lokajeṭṭhaṁ narāsabhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap52:17.1":{"pli":"Ubho hatthehi paggayha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap52:17.2":{"pli":"buddho loke sadevake; ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:17.3":{"pli":"Sandassayanto taṁ dhātuṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:17.4":{"pli":"kittayi aggasāvakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap52:18.1":{"pli":"Cittañca suvimuttaṁ me, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap52:18.2":{"pli":"saddhā mayhaṁ patiṭṭhitā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:18.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:18.4":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap52:19.1":{"pli":"Paṭisambhidānuppattā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap52:19.2":{"pli":"Vimokkhāpi ca phassitā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:19.3":{"pli":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:19.4":{"pli":"Kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap52:20.1":{"pli":"Itthaṁ sudaṁ āyasmā cundo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap52:21.1":{"pli":"Cundattherassāpadānaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap52:22.1":{"pli":"Upālivaggo pañcamo. ","html":"<p class='endsection'>{}</p>"},"tha-ap52:23.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"tha-ap52:24.1":{"pli":"Upāli soṇo bhaddiyo, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"tha-ap52:24.2":{"pli":"sanniṭṭhāpakahatthiyo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:24.3":{"pli":"Chadanaṁ seyyacaṅkamaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:24.4":{"pli":"subhaddo cundasavhayo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:24.5":{"pli":"Gāthāsataṁ satālīsaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap52:24.6":{"pli":"catasso ca taduttari. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"tha-ap520":{"tha-ap520:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap520'><header><ul><li class='division'>{}</li>"},"tha-ap520:0.2":{"pli":"Phaladāyakavagga ","html":"<li>{}</li></ul>"},"tha-ap520:0.3":{"pli":"Ghosasaññakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap520:1.1":{"pli":"“Migaluddo pure āsiṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap520:1.2":{"pli":"araññe vipine ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap520:1.3":{"pli":"Addasaṁ virajaṁ buddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap520:1.4":{"pli":"devasaṅghapurakkhataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap520:2.1":{"pli":"Catusaccaṁ pakāsentaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap520:2.2":{"pli":"desentaṁ amataṁ padaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap520:2.3":{"pli":"Assosiṁ madhuraṁ dhammaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap520:2.4":{"pli":"sikhino lokabandhuno. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap520:3.1":{"pli":"Ghose cittaṁ pasādesiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap520:3.2":{"pli":"asamappaṭipuggale; ","html":"<span class='verse-line'>{}</span>"},"tha-ap520:3.3":{"pli":"Tattha cittaṁ pasādetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap520:3.4":{"pli":"uttariṁ duttaraṁ bhavaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap520:4.1":{"pli":"Ekatiṁse ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap520:4.2":{"pli":"yaṁ saññamalabhiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap520:4.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap520:4.4":{"pli":"ghosasaññāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap520:5.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap520:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap520:5.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap520:6.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap520:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap520:6.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap520:7.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap520:7.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap520:7.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap520:8.1":{"pli":"Itthaṁ sudaṁ āyasmā ghosasaññako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap520:9.1":{"pli":"Ghosasaññakattherassāpadānaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap521":{"tha-ap521:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap521'><header><ul><li class='division'>{}</li>"},"tha-ap521:0.2":{"pli":"Phaladāyakavagga ","html":"<li>{}</li></ul>"},"tha-ap521:0.3":{"pli":"Sabbaphaladāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap521:1.1":{"pli":"“Varuṇo nāma nāmena, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap521:1.2":{"pli":"brāhmaṇo mantapāragū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:1.3":{"pli":"Chaḍḍetvā dasa puttāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:1.4":{"pli":"vanamajjhogahiṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap521:2.1":{"pli":"Assamaṁ sukataṁ katvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap521:2.2":{"pli":"suvibhattaṁ manoramaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:2.3":{"pli":"Paṇṇasālaṁ karitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:2.4":{"pli":"vasāmi vipine ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap521:3.1":{"pli":"Padumuttaro lokavidū, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap521:3.2":{"pli":"āhutīnaṁ paṭiggaho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:3.3":{"pli":"Mamuddharitukāmo so, ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:3.4":{"pli":"āgacchi mama assamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap521:4.1":{"pli":"Yāvatā vanasaṇḍamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap521:4.2":{"pli":"obhāso vipulo ahu; ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:4.3":{"pli":"Buddhassa ānubhāvena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:4.4":{"pli":"pajjalī vipinaṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap521:5.1":{"pli":"Disvāna taṁ pāṭihīraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap521:5.2":{"pli":"buddhaseṭṭhassa tādino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:5.3":{"pli":"Pattapuṭaṁ gahetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:5.4":{"pli":"phalena pūjayiṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap521:6.1":{"pli":"Upagantvāna sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap521:6.2":{"pli":"sahakhārimadāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:6.3":{"pli":"Anukampāya me buddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:6.4":{"pli":"idaṁ vacanamabravi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap521:7.1":{"pli":"‘Khāribhāraṁ gahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap521:7.2":{"pli":"pacchato ehi me tuvaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:7.3":{"pli":"Paribhutte ca saṅghamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:7.4":{"pli":"puññaṁ tava bhavissati’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap521:8.1":{"pli":"Puṭakantaṁ gahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap521:8.2":{"pli":"bhikkhusaṅghassadāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:8.3":{"pli":"Tattha cittaṁ pasādetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:8.4":{"pli":"tusitaṁ upapajjahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap521:9.1":{"pli":"Tattha dibbehi naccehi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap521:9.2":{"pli":"gītehi vāditehi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:9.3":{"pli":"Puññakammena saṁyuttaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:9.4":{"pli":"anubhomi sadā sukhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap521:10.1":{"pli":"Yaṁ yaṁ yonupapajjāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap521:10.2":{"pli":"devattaṁ atha mānusaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:10.3":{"pli":"Bhoge me ūnatā natthi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:10.4":{"pli":"phaladānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap521:11.1":{"pli":"Yāvatā caturo dīpā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap521:11.2":{"pli":"sasamuddā sapabbatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:11.3":{"pli":"Phalaṁ buddhassa datvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:11.4":{"pli":"issaraṁ kārayāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap521:12.1":{"pli":"Yāvatā me pakkhigaṇā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap521:12.2":{"pli":"ākāse uppatanti ce; ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:12.3":{"pli":"Tepi maṁ vasamanventi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:12.4":{"pli":"phaladānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap521:13.1":{"pli":"Yāvatā vanasaṇḍamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap521:13.2":{"pli":"yakkhā bhūtā ca rakkhasā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:13.3":{"pli":"Kumbhaṇḍā garuḷā cāpi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:13.4":{"pli":"pāricariyaṁ upenti me. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap521:14.1":{"pli":"Kummā soṇā madhukārā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap521:14.2":{"pli":"ḍaṁsā ca makasā ubho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:14.3":{"pli":"Tepi maṁ vasamanventi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:14.4":{"pli":"phaladānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap521:15.1":{"pli":"Supaṇṇā nāma sakuṇā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap521:15.2":{"pli":"pakkhijātā mahabbalā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:15.3":{"pli":"Tepi maṁ saraṇaṁ yanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:15.4":{"pli":"phaladānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap521:16.1":{"pli":"Yepi dīghāyukā nāgā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap521:16.2":{"pli":"iddhimanto mahāyasā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:16.3":{"pli":"Tepi maṁ vasamanventi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:16.4":{"pli":"phaladānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap521:17.1":{"pli":"Sīhā byagghā ca dīpī ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap521:17.2":{"pli":"acchakokataracchakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:17.3":{"pli":"Tepi maṁ vasamanventi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:17.4":{"pli":"phaladānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap521:18.1":{"pli":"Osadhītiṇavāsī ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap521:18.2":{"pli":"ye ca ākāsavāsino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:18.3":{"pli":"Sabbe maṁ saraṇaṁ yanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:18.4":{"pli":"phaladānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap521:19.1":{"pli":"Sududdasaṁ sunipuṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap521:19.2":{"pli":"gambhīraṁ suppakāsitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:19.3":{"pli":"Phassayitvā viharāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:19.4":{"pli":"phaladānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap521:20.1":{"pli":"Vimokkhe aṭṭha phusitvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap521:20.2":{"pli":"viharāmi anāsavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:20.3":{"pli":"Ātāpī nipako cāhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:20.4":{"pli":"phaladānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap521:21.1":{"pli":"Ye phalaṭṭhā buddhaputtā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap521:21.2":{"pli":"khīṇadosā mahāyasā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:21.3":{"pli":"Ahamaññataro tesaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:21.4":{"pli":"phaladānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap521:22.1":{"pli":"Abhiññāpāramiṁ gantvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap521:22.2":{"pli":"sukkamūlena codito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:22.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:22.4":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap521:23.1":{"pli":"Tevijjā iddhipattā ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap521:23.2":{"pli":"buddhaputtā mahāyasā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:23.3":{"pli":"Dibbasotasamāpannā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:23.4":{"pli":"tesaṁ aññataro ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap521:24.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap521:24.2":{"pli":"yaṁ phalaṁ adadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:24.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:24.4":{"pli":"phaladānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap521:25.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap521:25.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:25.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap521:26.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap521:26.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:26.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap521:27.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap521:27.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap521:27.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap521:28.1":{"pli":"Itthaṁ sudaṁ āyasmā sabbaphaladāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap521:29.1":{"pli":"Sabbaphaladāyakattherassāpadānaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap522":{"tha-ap522:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap522'><header><ul><li class='division'>{}</li>"},"tha-ap522:0.2":{"pli":"Phaladāyakavagga ","html":"<li>{}</li></ul>"},"tha-ap522:0.3":{"pli":"10 Padumadhārikattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap522:1.1":{"pli":"“Himavantassāvidūre, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap522:1.2":{"pli":"romaso nāma pabbato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap522:1.3":{"pli":"Buddhopi sambhavo nāma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap522:1.4":{"pli":"abbhokāse vasī tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap522:2.1":{"pli":"Bhavanā nikkhamitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap522:2.2":{"pli":"padumaṁ dhārayiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap522:2.3":{"pli":"Ekāhaṁ dhārayitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap522:2.4":{"pli":"bhavanaṁ punarāgamiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap522:3.1":{"pli":"Ekatiṁse ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap522:3.2":{"pli":"yaṁ buddhamabhipūjayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap522:3.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap522:3.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap522:4.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap522:4.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap522:4.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap522:5.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap522:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap522:5.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap522:6.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap522:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap522:6.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap522:7.1":{"pli":"Itthaṁ sudaṁ āyasmā padumadhāriko thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap522:8.1":{"pli":"Padumadhārikattherassāpadānaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap522:9.1":{"pli":"Phaladāyakavaggo dvepaññāsamo. ","html":"<p class='endsection'>{}</p>"},"tha-ap522:10.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"tha-ap522:11.1":{"pli":"Kurañciyaṁ kapitthañca, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"tha-ap522:11.2":{"pli":"kosambamatha ketakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap522:11.3":{"pli":"Nāgapupphajjunañceva, ","html":"<span class='verse-line'>{}</span>"},"tha-ap522:11.4":{"pli":"kuṭajī ghosasaññako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap522:12.1":{"pli":"Thero ca sabbaphalado, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap522:12.2":{"pli":"tathā padumadhāriko; ","html":"<span class='verse-line'>{}</span>"},"tha-ap522:12.3":{"pli":"Asīti cettha gāthāyo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap522:12.4":{"pli":"tisso gāthā taduttari. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"tha-ap523":{"tha-ap523:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap523'><header><ul><li class='division'>{}</li>"},"tha-ap523:0.2":{"pli":"Tiṇadāyakavagga ","html":"<li>{}</li></ul>"},"tha-ap523:0.3":{"pli":"Tiṇamuṭṭhidāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap523:1.1":{"pli":"“Himavantassāvidūre, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap523:1.2":{"pli":"lambako nāma pabbato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap523:1.3":{"pli":"Tattheva tisso sambuddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap523:1.4":{"pli":"abbhokāsamhi caṅkami. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap523:2.1":{"pli":"Migaluddo pure āsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap523:2.2":{"pli":"araññe kānane ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap523:2.3":{"pli":"Disvāna taṁ devadevaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap523:2.4":{"pli":"tiṇamuṭṭhimadāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap523:3.1":{"pli":"Nisīdanatthaṁ buddhassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap523:3.2":{"pli":"datvā cittaṁ pasādayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap523:3.3":{"pli":"Sambuddhaṁ abhivādetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap523:3.4":{"pli":"pakkāmiṁ uttarāmukho. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap523:4.1":{"pli":"Aciraṁ gatamattassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap523:4.2":{"pli":"migarājā apothayi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap523:4.3":{"pli":"Sīhena pothito santo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap523:4.4":{"pli":"tattha kālaṅkato ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap523:5.1":{"pli":"Āsanne me kataṁ kammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap523:5.2":{"pli":"buddhaseṭṭhe anāsave; ","html":"<span class='verse-line'>{}</span>"},"tha-ap523:5.3":{"pli":"Sumutto saravegova, ","html":"<span class='verse-line'>{}</span>"},"tha-ap523:5.4":{"pli":"devalokamagañchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap523:6.1":{"pli":"Yūpo tattha subho āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap523:6.2":{"pli":"puññakammābhinimmito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap523:6.3":{"pli":"Sahassakaṇḍo satabheṇḍu, ","html":"<span class='verse-line'>{}</span>"},"tha-ap523:6.4":{"pli":"dhajālu haritāmayo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap523:7.1":{"pli":"Pabhā niddhāvate tassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap523:7.2":{"pli":"sataraṁsīva uggato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap523:7.3":{"pli":"Ākiṇṇo devakaññāhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap523:7.4":{"pli":"āmodiṁ kāmakāmihaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap523:8.1":{"pli":"Devalokā cavitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap523:8.2":{"pli":"sukkamūlena codito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap523:8.3":{"pli":"Āgantvāna manussattaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap523:8.4":{"pli":"pattomhi āsavakkhayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap523:9.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap523:9.2":{"pli":"nisīdanamadāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap523:9.3":{"pli":"D