>{}</span>"},"tha-ap527:2.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap527:2.4":{"pli":"supaṭassa idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap527:3.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap527:3.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap527:3.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap527:4.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap527:4.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap527:4.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap527:5.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap527:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap527:5.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap527:6.1":{"pli":"Itthaṁ sudaṁ āyasmā supaṭadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap527:7.1":{"pli":"Supaṭadāyakattherassāpadānaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap528":{"tha-ap528:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap528'><header><ul><li class='division'>{}</li>"},"tha-ap528:0.2":{"pli":"Tiṇadāyakavagga ","html":"<li>{}</li></ul>"},"tha-ap528:0.3":{"pli":"Daṇḍadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap528:1.1":{"pli":"“Kānanaṁ vanamogayha, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap528:1.2":{"pli":"veḷuṁ chetvānahaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap528:1.3":{"pli":"Ālambaṇaṁ karitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap528:1.4":{"pli":"saṅghassa adadiṁ bahuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap528:2.1":{"pli":"Tena cittappasādena