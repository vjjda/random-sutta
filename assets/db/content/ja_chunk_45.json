{"ja535":{"ja535:0.1":{"pli":"Jātaka ","html":"<article id='ja535'><header><ul><li class='division'>{}</li>"},"ja535:0.2":{"pli":"Asītinipāta ","html":"<li>{}</li>"},"ja535:0.3":{"pli":"Cūḷahaṁsavagga ","html":"<li>{}</li></ul>"},"ja535:0.4":{"pli":"3. Sudhābhojanajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja535:1.1":{"pli":"“Neva kiṇāmi napi vikkiṇāmi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja535:1.2":{"pli":"Na cāpi me sannicayo ca atthi; ","html":"<span class='verse-line'>{}</span>"},"ja535:1.3":{"pli":"Sukiccharūpaṁ vatidaṁ parittaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja535:1.4":{"pli":"Patthodano nālamayaṁ duvinnaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:2.1":{"pli":"“Appamhā appakaṁ dajjā, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:2.2":{"pli":"anumajjhato majjhakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja535:2.3":{"pli":"Bahumhā bahukaṁ dajjā, ","html":"<span class='verse-line'>{}</span>"},"ja535:2.4":{"pli":"adānaṁ nupapajjati. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:3.1":{"pli":"Taṁ taṁ vadāmi kosiya, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:3.2":{"pli":"dehi dānāni bhuñja ca; ","html":"<span class='verse-line'>{}</span>"},"ja535:3.3":{"pli":"Ariyamaggaṁ samārūha, ","html":"<span class='verse-line'>{}</span>"},"ja535:3.4":{"pli":"nekāsī labhate sukhaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:4.1":{"pli":"“Moghañcassa hutaṁ hoti, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:4.2":{"pli":"moghañcāpi samīhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja535:4.3":{"pli":"Atithismiṁ yo nisinnasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja535:4.4":{"pli":"eko bhuñjati bhojanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:5.1":{"pli":"Taṁ taṁ vadāmi kosiya, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:5.2":{"pli":"dehi dānāni bhuñja ca; ","html":"<span class='verse-line'>{}</span>"},"ja535:5.3":{"pli":"Ariyamaggaṁ samārūha, ","html":"<span class='verse-line'>{}</span>"},"ja535:5.4":{"pli":"nekāsī labhate sukhaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:6.1":{"pli":"“Saccañcassa hutaṁ hoti, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:6.2":{"pli":"saccañcāpi samīhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja535:6.3":{"pli":"Atithismiṁ yo nisinnasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja535:6.4":{"pli":"neko bhuñjati bhojanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:7.1":{"pli":"Taṁ taṁ vadāmi kosiya, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:7.2":{"pli":"dehi dānāni bhuñja ca; ","html":"<span class='verse-line'>{}</span>"},"ja535:7.3":{"pli":"Ariyamaggaṁ samārūha, ","html":"<span class='verse-line'>{}</span>"},"ja535:7.4":{"pli":"nekāsī labhate sukhaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:8.1":{"pli":"“Sarañca juhati poso, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:8.2":{"pli":"bahukāya gayāya ca; ","html":"<span class='verse-line'>{}</span>"},"ja535:8.3":{"pli":"Doṇe timbarutitthasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja535:8.4":{"pli":"sīghasote mahāvahe. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:9.1":{"pli":"Atra cassa hutaṁ hoti, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:9.2":{"pli":"atra cassa samīhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja535:9.3":{"pli":"Atithismiṁ yo nisinnasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja535:9.4":{"pli":"neko bhuñjati bhojanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:10.1":{"pli":"Taṁ taṁ vadāmi kosiya, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:10.2":{"pli":"dehi dānāni bhuñja ca; ","html":"<span class='verse-line'>{}</span>"},"ja535:10.3":{"pli":"Ariyamaggaṁ samārūha, ","html":"<span class='verse-line'>{}</span>"},"ja535:10.4":{"pli":"nekāsī labhate sukhaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:11.1":{"pli":"“Baḷisañhi so nigilati, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:11.2":{"pli":"dīghasuttaṁ sabandhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja535:11.3":{"pli":"Atithismiṁ yo nisinnasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja535:11.4":{"pli":"eko bhuñjati bhojanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:12.1":{"pli":"Taṁ taṁ vadāmi kosiya, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:12.2":{"pli":"dehi dānāni bhuñja ca; ","html":"<span class='verse-line'>{}</span>"},"ja535:12.3":{"pli":"Ariyamaggaṁ samārūha, ","html":"<span class='verse-line'>{}</span>"},"ja535:12.4":{"pli":"nekāsī labhate sukhaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:13.1":{"pli":"“Uḷāravaṇṇā vata brāhmaṇā ime, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:13.2":{"pli":"Ayañca vo sunakho kissa hetu; ","html":"<span class='verse-line'>{}</span>"},"ja535:13.3":{"pli":"Uccāvacaṁ vaṇṇanibhaṁ vikubbati, ","html":"<span class='verse-line'>{}</span>"},"ja535:13.4":{"pli":"Akkhātha no brāhmaṇā ke nu tumhe”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:14.1":{"pli":"“Cando ca suriyo ca ubho idhāgatā, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:14.2":{"pli":"Ayaṁ pana mātali devasārathi; ","html":"<span class='verse-line'>{}</span>"},"ja535:14.3":{"pli":"Sakkohamasmi tidasānamindo, ","html":"<span class='verse-line'>{}</span>"},"ja535:14.4":{"pli":"Eso ca kho pañcasikhoti vuccati. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:15.1":{"pli":"Pāṇissarā mudiṅgā ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:15.2":{"pli":"murajālambarāni ca; ","html":"<span class='verse-line'>{}</span>"},"ja535:15.3":{"pli":"Suttamenaṁ pabodhenti, ","html":"<span class='verse-line'>{}</span>"},"ja535:15.4":{"pli":"paṭibuddho ca nandati. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:16.1":{"pli":"Ye kecime maccharino kadariyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:16.2":{"pli":"Paribhāsakā samaṇabrāhmaṇānaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja535:16.3":{"pli":"Idheva nikkhippa sarīradehaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja535:16.4":{"pli":"Kāyassa bhedā nirayaṁ vajanti. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:17.1":{"pli":"Ye kecime suggatimāsamānā, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:17.2":{"pli":"Dhamme ṭhitā saṁyame saṁvibhāge; ","html":"<span class='verse-line'>{}</span>"},"ja535:17.3":{"pli":"Idheva nikkhippa sarīradehaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja535:17.4":{"pli":"Kāyassa bhedā sugatiṁ vajanti. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:18.1":{"pli":"Tvaṁ nosi ñāti purimāsu jātisu, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:18.2":{"pli":"So maccharī rosako pāpadhammo; ","html":"<span class='verse-line'>{}</span>"},"ja535:18.3":{"pli":"Taveva atthāya idhāgatamhā, ","html":"<span class='verse-line'>{}</span>"},"ja535:18.4":{"pli":"Mā pāpadhammo nirayaṁ gamittha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:19.1":{"pli":"“Addhā maṁ vo hitakāmā, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:19.2":{"pli":"yaṁ maṁ samanusāsatha; ","html":"<span class='verse-line'>{}</span>"},"ja535:19.3":{"pli":"Sohaṁ tathā karissāmi, ","html":"<span class='verse-line'>{}</span>"},"ja535:19.4":{"pli":"sabbaṁ vuttaṁ hitesibhi. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:20.1":{"pli":"Esāhamajjeva upāramāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:20.2":{"pli":"Na cāpihaṁ kiñci kareyya pāpaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja535:20.3":{"pli":"Na cāpi me kiñci adeyyamatthi, ","html":"<span class='verse-line'>{}</span>"},"ja535:20.4":{"pli":"Na cāpidatvā udakaṁ pivāmi. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:21.1":{"pli":"Evañca me dadato sabbakālaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:21.2":{"pli":"Bhogā ime vāsava khīyissanti; ","html":"<span class='verse-line'>{}</span>"},"ja535:21.3":{"pli":"Tato ahaṁ pabbajissāmi sakka, ","html":"<span class='verse-line'>{}</span>"},"ja535:21.4":{"pli":"Hitvāna kāmāni yathodhikāni”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:22.1":{"pli":"Naguttame girivare gandhamādane, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:22.2":{"pli":"Modanti tā devavarābhipālitā; ","html":"<span class='verse-line'>{}</span>"},"ja535:22.3":{"pli":"Athāgamā isivaro sabbalokagū, ","html":"<span class='verse-line'>{}</span>"},"ja535:22.4":{"pli":"Supupphitaṁ dumavarasākhamādiya. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:23.1":{"pli":"Suciṁ sugandhaṁ tidasehi sakkataṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:23.2":{"pli":"Pupphuttamaṁ amaravarehi sevitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja535:23.3":{"pli":"Aladdha maccehi va dānavehi vā, ","html":"<span class='verse-line'>{}</span>"},"ja535:23.4":{"pli":"Aññatra devehi tadārahaṁ hidaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:24.1":{"pli":"Tato catasso kanakattacūpamā, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:24.2":{"pli":"Uṭṭhāya nāriyo pamadādhipā muniṁ; ","html":"<span class='verse-line'>{}</span>"},"ja535:24.3":{"pli":"Āsā ca saddhā ca sirī tato hirī, ","html":"<span class='verse-line'>{}</span>"},"ja535:24.4":{"pli":"Iccabravuṁ nāradadeva brāhmaṇaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:25.1":{"pli":"“Sace anuddiṭṭhaṁ tayā mahāmuni, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:25.2":{"pli":"Pupphaṁ imaṁ pārichattassa brahme; ","html":"<span class='verse-line'>{}</span>"},"ja535:25.3":{"pli":"Dadāhi no sabbā gati te ijjhatu, ","html":"<span class='verse-line'>{}</span>"},"ja535:25.4":{"pli":"Tuvampi no hohi yatheva vāsavo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:26.1":{"pli":"Taṁ yācamānābhisamekkha nārado, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:26.2":{"pli":"Iccabravī saṅkalahaṁ udīrayi; ","html":"<span class='verse-line'>{}</span>"},"ja535:26.3":{"pli":"“Na mayhamatthatthi imehi koci naṁ, ","html":"<span class='verse-line'>{}</span>"},"ja535:26.4":{"pli":"Yāyeva vo seyyasi sā piḷandhatha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:27.1":{"pli":"“Tvaṁ nottamevābhisamekkha nārada, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:27.2":{"pli":"Yassicchasi tassā anuppavecchasu; ","html":"<span class='verse-line'>{}</span>"},"ja535:27.3":{"pli":"Yassā hi no nārada tvaṁ padassasi, ","html":"<span class='verse-line'>{}</span>"},"ja535:27.4":{"pli":"Sāyeva no hehiti seṭṭhasammatā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:28.1":{"pli":"“Akallametaṁ vacanaṁ sugatte, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:28.2":{"pli":"Ko brāhmaṇo saṅkalahaṁ udīraye; ","html":"<span class='verse-line'>{}</span>"},"ja535:28.3":{"pli":"Gantvāna bhūtādhipameva pucchatha, ","html":"<span class='verse-line'>{}</span>"},"ja535:28.4":{"pli":"Sace na jānātha idhuttamādhamaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:29.1":{"pli":"Tā nāradena paramappakopitā, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:29.2":{"pli":"Udīritā vaṇṇamadena mattā; ","html":"<span class='verse-line'>{}</span>"},"ja535:29.3":{"pli":"Sakāse gantvāna sahassacakkhuno, ","html":"<span class='verse-line'>{}</span>"},"ja535:29.4":{"pli":"“Pucchiṁsu bhūtādhipaṁ kā nu seyyasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:30.1":{"pli":"Tā disvā āyattamanā purindado, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:30.2":{"pli":"Iccabravī devavaro katañjalī; ","html":"<span class='verse-line'>{}</span>"},"ja535:30.3":{"pli":"“Sabbāva vo hotha sugatte sādisī, ","html":"<span class='verse-line'>{}</span>"},"ja535:30.4":{"pli":"Ko neva bhadde kalahaṁ udīrayi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:31.1":{"pli":"“Yo sabbalokaccarito mahāmuni, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:31.2":{"pli":"Dhamme ṭhito nārado saccanikkamo; ","html":"<span class='verse-line'>{}</span>"},"ja535:31.3":{"pli":"So nobravi girivare gandhamādane, ","html":"<span class='verse-line'>{}</span>"},"ja535:31.4":{"pli":"Gantvāna bhūtādhipameva pucchatha; ","html":"<span class='verse-line'>{}</span>"},"ja535:31.5":{"pli":"Sace na jānātha idhuttamādhamaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:32.1":{"pli":"“Asu brahāraññacaro mahāmuni, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:32.2":{"pli":"Nādatvā bhattaṁ varagatte bhuñjati; ","html":"<span class='verse-line'>{}</span>"},"ja535:32.3":{"pli":"Viceyya dānāni dadāti kosiyo, ","html":"<span class='verse-line'>{}</span>"},"ja535:32.4":{"pli":"Yassā hi so dassati sāva seyyasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:33.1":{"pli":"“Asū hi yo sammati dakkhiṇaṁ disaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:33.2":{"pli":"Gaṅgāya tīre himavantapassani; ","html":"<span class='verse-line'>{}</span>"},"ja535:33.3":{"pli":"Sa kosiyo dullabhapānabhojano, ","html":"<span class='verse-line'>{}</span>"},"ja535:33.4":{"pli":"Tassa sudhaṁ pāpaya devasārathi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:34.1":{"pli":"Sa mātalī devavarena pesito, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:34.2":{"pli":"Sahassayuttaṁ abhiruyha sandanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja535:34.3":{"pli":"Sukhippameva upagamma assamaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja535:34.4":{"pli":"Adissamāno munino sudhaṁ adā. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:35.1":{"pli":"“Udaggihuttaṁ upatiṭṭhato hi me, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:35.2":{"pli":"Pabhaṅkaraṁ lokatamonuduttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja535:35.3":{"pli":"Sabbāni bhūtāni adhicca vāsavo, ","html":"<span class='verse-line'>{}</span>"},"ja535:35.4":{"pli":"Ko neva me pāṇisu kiṁ sudhodahi. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:36.1":{"pli":"Saṅkhūpamaṁ setamatulyadassanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:36.2":{"pli":"Suciṁ sugandhaṁ piyarūpamabbhutaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja535:36.3":{"pli":"Adiṭṭhapubbaṁ mama jātu cakkhubhi, ","html":"<span class='verse-line'>{}</span>"},"ja535:36.4":{"pli":"Kā devatā pāṇisu kiṁ sudhodahi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:37.1":{"pli":"“Ahaṁ mahindena mahesi pesito, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:37.2":{"pli":"Sudhābhihāsiṁ turito mahāmuni; ","html":"<span class='verse-line'>{}</span>"},"ja535:37.3":{"pli":"Jānāsi maṁ mātali devasārathi, ","html":"<span class='verse-line'>{}</span>"},"ja535:37.4":{"pli":"Bhuñjassu bhattuttama mābhivārayi. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:38.1":{"pli":"Bhuttā ca sā dvādasa hanti pāpake, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:38.2":{"pli":"Khudaṁ pipāsaṁ aratiṁ daraklamaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja535:38.3":{"pli":"Kodhūpanāhañca vivādapesuṇaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja535:38.4":{"pli":"Sītuṇha tandiñca rasuttamaṁ idaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:39.1":{"pli":"“Na kappatī mātali mayha bhuñjituṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:39.2":{"pli":"Pubbe adatvā iti me vatuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja535:39.3":{"pli":"Na cāpi ekāsnamarīyapūjitaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja535:39.4":{"pli":"Asaṁvibhāgī ca sukhaṁ na vindati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:40.1":{"pli":"“Thīghātakā ye cime pāradārikā, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:40.2":{"pli":"Mittadduno ye ca sapanti subbate; ","html":"<span class='verse-line'>{}</span>"},"ja535:40.3":{"pli":"Sabbe ca te maccharipañcamādhamā, ","html":"<span class='verse-line'>{}</span>"},"ja535:40.4":{"pli":"Tasmā adatvā udakampi nāsniye. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:41.1":{"pli":"Sohitthiyā vā purisassa vā pana, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:41.2":{"pli":"Dassāmi dānaṁ vidusampavaṇṇitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja535:41.3":{"pli":"Saddhā vadaññū idha vītamaccharā, ","html":"<span class='verse-line'>{}</span>"},"ja535:41.4":{"pli":"Bhavanti hete sucisaccasammatā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:42.1":{"pli":"Ato matā devavarena pesitā, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:42.2":{"pli":"Kaññā catasso kanakattacūpamā; ","html":"<span class='verse-line'>{}</span>"},"ja535:42.3":{"pli":"Āsā ca saddhā ca sirī tato hirī, ","html":"<span class='verse-line'>{}</span>"},"ja535:42.4":{"pli":"Taṁ assamaṁ āgamu yattha kosiyo. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:43.1":{"pli":"Tā disvā sabbo paramappamodito, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:43.2":{"pli":"Subhena vaṇṇena sikhārivaggino; ","html":"<span class='verse-line'>{}</span>"},"ja535:43.3":{"pli":"Kaññā catasso caturo catuddisā, ","html":"<span class='verse-line'>{}</span>"},"ja535:43.4":{"pli":"Iccabravī mātalino ca sammukhā. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:44.1":{"pli":"“Purimaṁ disaṁ kā tvaṁ pabhāsi devate, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:44.2":{"pli":"Alaṅkatā tāravarāva osadhī; ","html":"<span class='verse-line'>{}</span>"},"ja535:44.3":{"pli":"Pucchāmi taṁ kañcanavelliviggahe, ","html":"<span class='verse-line'>{}</span>"},"ja535:44.4":{"pli":"Ācikkha me tvaṁ katamāsi devatā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:45.1":{"pli":"“Sirāha devī manujebhi pūjitā, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:45.2":{"pli":"Apāpasattūpanisevinī sadā; ","html":"<span class='verse-line'>{}</span>"},"ja535:45.3":{"pli":"Sudhāvivādena tavantimāgatā, ","html":"<span class='verse-line'>{}</span>"},"ja535:45.4":{"pli":"Taṁ maṁ sudhāya varapañña bhājaya. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:46.1":{"pli":"Yassāhamicchāmi sudhaṁ mahāmuni, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:46.2":{"pli":"So sabbakāmehi naro pamodati; ","html":"<span class='verse-line'>{}</span>"},"ja535:46.3":{"pli":"Sirīti maṁ jānahi jūhatuttama, ","html":"<span class='verse-line'>{}</span>"},"ja535:46.4":{"pli":"Taṁ maṁ sudhāya varapañña bhājaya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:47.1":{"pli":"“Sippena vijjācaraṇena buddhiyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:47.2":{"pli":"Narā upetā paguṇā sakammunā; ","html":"<span class='verse-line'>{}</span>"},"ja535:47.3":{"pli":"Tayā vihīnā na labhanti kiñcanaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja535:47.4":{"pli":"Tayidaṁ na sādhu yadidaṁ tayā kataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:48.1":{"pli":"Passāmi posaṁ alasaṁ mahagghasaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:48.2":{"pli":"Sudukkulīnampi arūpimaṁ naraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja535:48.3":{"pli":"Tayānugutto siri jātimāmapi, ","html":"<span class='verse-line'>{}</span>"},"ja535:48.4":{"pli":"Peseti dāsaṁ viya bhogavā sukhī. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:49.1":{"pli":"Taṁ taṁ asaccaṁ avibhajjaseviniṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:49.2":{"pli":"Jānāmi mūḷhaṁ vidurānupātiniṁ; ","html":"<span class='verse-line'>{}</span>"},"ja535:49.3":{"pli":"Na tādisī arahati āsanūdakaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja535:49.4":{"pli":"Kuto sudhā gaccha na mayha ruccasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:50.1":{"pli":"“Kā sukkadāṭhā paṭimukkakuṇḍalā, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:50.2":{"pli":"Cittaṅgadā kambuvimaṭṭhadhārinī; ","html":"<span class='verse-line'>{}</span>"},"ja535:50.3":{"pli":"Osittavaṇṇaṁ paridayha sobhasi, ","html":"<span class='verse-line'>{}</span>"},"ja535:50.4":{"pli":"Kusaggirattaṁ apiḷayha mañjariṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:51.1":{"pli":"Migīva bhantā saracāpadhārinā, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:51.2":{"pli":"Virādhitā mandamiva udikkhasi; ","html":"<span class='verse-line'>{}</span>"},"ja535:51.3":{"pli":"Ko te dutīyo idha mandalocane, ","html":"<span class='verse-line'>{}</span>"},"ja535:51.4":{"pli":"Na bhāyasi ekikā kānane vane”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:52.1":{"pli":"“Na me dutīyo idha matthi kosiya, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:52.2":{"pli":"Masakkasārappabhavamhi devatā; ","html":"<span class='verse-line'>{}</span>"},"ja535:52.3":{"pli":"Āsā sudhāsāya tavantimāgatā, ","html":"<span class='verse-line'>{}</span>"},"ja535:52.4":{"pli":"Taṁ maṁ sudhāya varapañña bhājaya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:53.1":{"pli":"“Āsāya yanti vāṇijā dhanesino, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:53.2":{"pli":"Nāvaṁ samāruyha parenti aṇṇave; ","html":"<span class='verse-line'>{}</span>"},"ja535:53.3":{"pli":"Te tattha sīdanti athopi ekadā, ","html":"<span class='verse-line'>{}</span>"},"ja535:53.4":{"pli":"Jīnādhanā enti vinaṭṭhapābhatā. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:54.1":{"pli":"Āsāya khettāni kasanti kassakā, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:54.2":{"pli":"Vapanti bījāni karontupāyaso; ","html":"<span class='verse-line'>{}</span>"},"ja535:54.3":{"pli":"Ītīnipātena avuṭṭhitāya vā, ","html":"<span class='verse-line'>{}</span>"},"ja535:54.4":{"pli":"Na kiñci vindanti tato phalāgamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:55.1":{"pli":"Athattakārāni karonti bhattusu, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:55.2":{"pli":"Āsaṁ purakkhatvā narā sukhesino; ","html":"<span class='verse-line'>{}</span>"},"ja535:55.3":{"pli":"Te bhatturatthā atigāḷhitā puna, ","html":"<span class='verse-line'>{}</span>"},"ja535:55.4":{"pli":"Disā panassanti aladdha kiñcanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:56.1":{"pli":"Hitvāna dhaññañca dhanañca ñātake, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:56.2":{"pli":"Āsāya saggādhimanā sukhesino; ","html":"<span class='verse-line'>{}</span>"},"ja535:56.3":{"pli":"Tapanti lūkhampi tapaṁ cirantaraṁ, ","html":"<span class='verse-line'>{}</span>"},"ja535:56.4":{"pli":"Kumaggamāruyha parenti duggatiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:57.1":{"pli":"Āsā visaṁvādikasammatā ime, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:57.2":{"pli":"Āse sudhāsaṁ vinayassu attani; ","html":"<span class='verse-line'>{}</span>"},"ja535:57.3":{"pli":"Na tādisī arahati āsanūdakaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja535:57.4":{"pli":"Kuto sudhā gaccha na mayha ruccasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:58.1":{"pli":"“Daddallamānā yasasā yasassinī, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:58.2":{"pli":"Jighaññanāmavhayanaṁ disaṁ pati; ","html":"<span class='verse-line'>{}</span>"},"ja535:58.3":{"pli":"Pucchāmi taṁ kañcanavelliviggahe, ","html":"<span class='verse-line'>{}</span>"},"ja535:58.4":{"pli":"Ācikkha me tvaṁ katamāsi devatā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:59.1":{"pli":"“Saddhāha devī manujehi pūjitā, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:59.2":{"pli":"Apāpasattūpanisevinī sadā; ","html":"<span class='verse-line'>{}</span>"},"ja535:59.3":{"pli":"Sudhāvivādena tavantimāgatā, ","html":"<span class='verse-line'>{}</span>"},"ja535:59.4":{"pli":"Taṁ maṁ sudhāya varapañña bhājaya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:60.1":{"pli":"“Dānaṁ damaṁ cāgamathopi saṁyamaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:60.2":{"pli":"Ādāya saddhāya karonti hekadā; ","html":"<span class='verse-line'>{}</span>"},"ja535:60.3":{"pli":"Theyyaṁ musā kūṭamathopi pesuṇaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja535:60.4":{"pli":"Karonti heke puna viccutā tayā. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:61.1":{"pli":"Bhariyāsu poso sadisīsu pekkhavā, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:61.2":{"pli":"Sīlūpapannāsu patibbatāsupi; ","html":"<span class='verse-line'>{}</span>"},"ja535:61.3":{"pli":"Vinetvāna chandaṁ kulitthiyāsupi, ","html":"<span class='verse-line'>{}</span>"},"ja535:61.4":{"pli":"Karoti saddhaṁ puna kumbhadāsiyā. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:62.1":{"pli":"Tvameva saddhe paradārasevinī, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:62.2":{"pli":"Pāpaṁ karosi kusalampi riñcasi; ","html":"<span class='verse-line'>{}</span>"},"ja535:62.3":{"pli":"Na tādisī arahati āsanūdakaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja535:62.4":{"pli":"Kuto sudhā gaccha na mayha ruccasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:63.1":{"pli":"“Jighaññarattiṁ aruṇasmimūhate, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:63.2":{"pli":"Yā dissati uttamarūpavaṇṇinī; ","html":"<span class='verse-line'>{}</span>"},"ja535:63.3":{"pli":"Tathūpamā maṁ paṭibhāsi devate, ","html":"<span class='verse-line'>{}</span>"},"ja535:63.4":{"pli":"Ācikkha me tvaṁ katamāsi accharā. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:64.1":{"pli":"Kālā nidāgheriva aggijāriva, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:64.2":{"pli":"Anileritā lohitapattamālinī; ","html":"<span class='verse-line'>{}</span>"},"ja535:64.3":{"pli":"Kā tiṭṭhasi mandamigāvalokayaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja535:64.4":{"pli":"Bhāsesamānāva giraṁ na muñcasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:65.1":{"pli":"“Hirāha devī manujehi pūjitā, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:65.2":{"pli":"Apāpasattūpanisevinī sadā; ","html":"<span class='verse-line'>{}</span>"},"ja535:65.3":{"pli":"Sudhāvivādena tavantimāgatā, ","html":"<span class='verse-line'>{}</span>"},"ja535:65.4":{"pli":"Sāhaṁ na sakkomi sudhampi yācituṁ; ","html":"<span class='verse-line'>{}</span>"},"ja535:65.5":{"pli":"Kopīnarūpā viya yācanitthiyā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:66.1":{"pli":"“Dhammena ñāyena sugatte lacchasi, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:66.2":{"pli":"Eso hi dhammo na hi yācanā sudhā; ","html":"<span class='verse-line'>{}</span>"},"ja535:66.3":{"pli":"Taṁ taṁ ayācantimahaṁ nimantaye, ","html":"<span class='verse-line'>{}</span>"},"ja535:66.4":{"pli":"Sudhāya yañcicchasi tampi dammi te. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:67.1":{"pli":"Sā tvaṁ mayā ajja sakamhi assame, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:67.2":{"pli":"Nimantitā kañcanavelliviggahe; ","html":"<span class='verse-line'>{}</span>"},"ja535:67.3":{"pli":"Tuvañhi me sabbarasehi pūjiyā, ","html":"<span class='verse-line'>{}</span>"},"ja535:67.4":{"pli":"Taṁ pūjayitvāna sudhampi asniye”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:68.1":{"pli":"Sā kosiyenānumatā jutīmatā, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:68.2":{"pli":"Addhā hiri rammaṁ pāvisi yassamaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja535:68.3":{"pli":"Udakavantaṁ phalamariyapūjitaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja535:68.4":{"pli":"Apāpasattūpanisevitaṁ sadā. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:69.1":{"pli":"Rukkhaggahānā bahukettha pupphitā, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:69.2":{"pli":"Ambā piyālā panasā ca kiṁsukā; ","html":"<span class='verse-line'>{}</span>"},"ja535:69.3":{"pli":"Sobhañjanā loddamathopi padmakā, ","html":"<span class='verse-line'>{}</span>"},"ja535:69.4":{"pli":"Kekā ca bhaṅgā tilakā supupphitā. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:70.1":{"pli":"Sālā karerī bahukettha jambuyo, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:70.2":{"pli":"Assatthanigrodhamadhukavetasā; ","html":"<span class='verse-line'>{}</span>"},"ja535:70.3":{"pli":"Uddālakā pāṭali sinduvārakā, ","html":"<span class='verse-line'>{}</span>"},"ja535:70.4":{"pli":"Manuññagandhā mucalindaketakā. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:71.1":{"pli":"Hareṇukā veḷukā keṇu tindukā, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:71.2":{"pli":"Sāmākanīvāramathopi cīnakā; ","html":"<span class='verse-line'>{}</span>"},"ja535:71.3":{"pli":"Mocā kadalī bahukettha sāliyo, ","html":"<span class='verse-line'>{}</span>"},"ja535:71.4":{"pli":"Pavīhayo ābhūjino ca taṇḍulā. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:72.1":{"pli":"Tassevuttarapassena, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:72.2":{"pli":"jātā pokkharaṇī sivā; ","html":"<span class='verse-line'>{}</span>"},"ja535:72.3":{"pli":"Akakkasā apabbhārā, ","html":"<span class='verse-line'>{}</span>"},"ja535:72.4":{"pli":"sādhu appaṭigandhikā. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:73.1":{"pli":"Tattha macchā sanniratā, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:73.2":{"pli":"khemino bahubhojanā; ","html":"<span class='verse-line'>{}</span>"},"ja535:73.3":{"pli":"Siṅgū savaṅkā saṅkulā, ","html":"<span class='verse-line'>{}</span>"},"ja535:73.4":{"pli":"satavaṅkā ca rohitā; ","html":"<span class='verse-line'>{}</span>"},"ja535:73.5":{"pli":"Āḷigaggarakākiṇṇā, ","html":"<span class='verse-line'>{}</span>"},"ja535:73.6":{"pli":"pāṭhīnā kākamacchakā. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:74.1":{"pli":"Tattha pakkhī sanniratā, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:74.2":{"pli":"khemino bahubhojanā; ","html":"<span class='verse-line'>{}</span>"},"ja535:74.3":{"pli":"Haṁsā koñcā mayūrā ca, ","html":"<span class='verse-line'>{}</span>"},"ja535:74.4":{"pli":"cakkavākā ca kukkuhā; ","html":"<span class='verse-line'>{}</span>"},"ja535:74.5":{"pli":"Kuṇālakā bahū citrā, ","html":"<span class='verse-line'>{}</span>"},"ja535:74.6":{"pli":"sikhaṇḍī jīvajīvakā. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:75.1":{"pli":"Tattha pānāya māyanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:75.2":{"pli":"nānā migagaṇā bahū; ","html":"<span class='verse-line'>{}</span>"},"ja535:75.3":{"pli":"Sīhā byagghā varāhā ca, ","html":"<span class='verse-line'>{}</span>"},"ja535:75.4":{"pli":"acchakokataracchayo. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:76.1":{"pli":"Palāsādā gavajā ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:76.2":{"pli":"mahiṁsā rohitā rurū; ","html":"<span class='verse-line'>{}</span>"},"ja535:76.3":{"pli":"Eṇeyyā ca varāhā ca, ","html":"<span class='verse-line'>{}</span>"},"ja535:76.4":{"pli":"gaṇino nīkasūkarā; ","html":"<span class='verse-line'>{}</span>"},"ja535:76.5":{"pli":"Kadalimigā bahukettha, ","html":"<span class='verse-line'>{}</span>"},"ja535:76.6":{"pli":"biḷārā sasakaṇṇikā. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:77.1":{"pli":"Chamāgirī pupphavicitrasanthatā, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:77.2":{"pli":"Dijābhighuṭṭhā dijasaṅghasevitā. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:78.1":{"pli":"Sā suttacā nīladumābhilambitā, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:78.2":{"pli":"Vijju mahāmegharivānupajjatha; ","html":"<span class='verse-line'>{}</span>"},"ja535:78.3":{"pli":"Tassā susambandhasiraṁ kusāmayaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja535:78.4":{"pli":"Suciṁ sugandhaṁ ajinūpasevitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja535:78.5":{"pli":"Atricca kocchaṁ hirimetadabravi, ","html":"<span class='verse-line'>{}</span>"},"ja535:78.6":{"pli":"“Nisīda kalyāṇi sukhayidamāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:79.1":{"pli":"Tassā tadā kocchagatāya kosiyo, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:79.2":{"pli":"Yadicchamānāya jaṭājinandharo; ","html":"<span class='verse-line'>{}</span>"},"ja535:79.3":{"pli":"Navehi pattehi sayaṁ sahūdakaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja535:79.4":{"pli":"Sudhābhihāsī turito mahāmuni. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:80.1":{"pli":"Sā taṁ paṭiggayha ubhohi pāṇibhi, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:80.2":{"pli":"Iccabravi attamanā jaṭādharaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja535:80.3":{"pli":"“Handāhaṁ etarahi pūjitā tayā, ","html":"<span class='verse-line'>{}</span>"},"ja535:80.4":{"pli":"Gaccheyyaṁ brahme tidivaṁ jitāvinī”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:81.1":{"pli":"Sā kosiyenānumatā jutīmatā, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:81.2":{"pli":"Udīritā vaṇṇamadena mattā; ","html":"<span class='verse-line'>{}</span>"},"ja535:81.3":{"pli":"Sakāse gantvāna sahassacakkhuno, ","html":"<span class='verse-line'>{}</span>"},"ja535:81.4":{"pli":"“Ayaṁ sudhā vāsava dehi me jayaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:82.1":{"pli":"Tamena sakkopi tadā apūjayi, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:82.2":{"pli":"Sahindadevā surakaññamuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja535:82.3":{"pli":"Sā pañjalī devamanussapūjitā, ","html":"<span class='verse-line'>{}</span>"},"ja535:82.4":{"pli":"Navamhi kocchamhi yadā upāvisi. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:83.1":{"pli":"Tameva saṁsī punadeva mātaliṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:83.2":{"pli":"Sahassanetto tidasānamindo; ","html":"<span class='verse-line'>{}</span>"},"ja535:83.3":{"pli":"“Gantvāna vākyaṁ mama brūhi kosiyaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja535:83.4":{"pli":"‘Āsāya saddhā siriyā ca kosiya; ","html":"<span class='verse-line'>{}</span>"},"ja535:83.5":{"pli":"Hirī sudhaṁ kena malattha hetunā’”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:84.1":{"pli":"Taṁ suplavatthaṁ udatārayī rathaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:84.2":{"pli":"Daddallamānaṁ upakāriyasādisaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja535:84.3":{"pli":"Jambonadīsaṁ tapaneyyasannibhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja535:84.4":{"pli":"Alaṅkataṁ kañcanacittasannibhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:85.1":{"pli":"Suvaṇṇacandettha bahū nipātitā, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:85.2":{"pli":"Hatthī gavāssā kikibyagghadīpiyo; ","html":"<span class='verse-line'>{}</span>"},"ja535:85.3":{"pli":"Eṇeyyakā laṅghamayettha pakkhino, ","html":"<span class='verse-line'>{}</span>"},"ja535:85.4":{"pli":"Migettha veḷuriyamayā yudhā yutā. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:86.1":{"pli":"Tatthassarājaharayo ayojayuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:86.2":{"pli":"Dasasatāni susunāgasādise; ","html":"<span class='verse-line'>{}</span>"},"ja535:86.3":{"pli":"Alaṅkate kañcanajāluracchade, ","html":"<span class='verse-line'>{}</span>"},"ja535:86.4":{"pli":"Āveḷine saddagame asaṅgite. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:87.1":{"pli":"Taṁ yānaseṭṭhaṁ abhiruyha mātali, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:87.2":{"pli":"Disā imāyo abhinādayittha; ","html":"<span class='verse-line'>{}</span>"},"ja535:87.3":{"pli":"Nabhañca selañca vanappatiniñca, ","html":"<span class='verse-line'>{}</span>"},"ja535:87.4":{"pli":"Sasāgaraṁ pabyathayittha mediniṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:88.1":{"pli":"Sa khippameva upagamma assamaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:88.2":{"pli":"Pāvāramekaṁsakato katañjalī; ","html":"<span class='verse-line'>{}</span>"},"ja535:88.3":{"pli":"Bahussutaṁ vuddhaṁ vinītavantaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja535:88.4":{"pli":"Iccabravī mātali devabrāhmaṇaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:89.1":{"pli":"“Indassa vākyaṁ nisāmehi kosiya, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:89.2":{"pli":"Dūto ahaṁ pucchati taṁ purindado; ","html":"<span class='verse-line'>{}</span>"},"ja535:89.3":{"pli":"‘Āsāya saddhā siriyā ca kosiya, ","html":"<span class='verse-line'>{}</span>"},"ja535:89.4":{"pli":"Hirī sudhaṁ kena malattha hetunā’”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:90.1":{"pli":"“Andhā sirī maṁ paṭibhāti mātali, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:90.2":{"pli":"Saddhā aniccā pana devasārathi; ","html":"<span class='verse-line'>{}</span>"},"ja535:90.3":{"pli":"Āsā visaṁvādikasammatā hi me, ","html":"<span class='verse-line'>{}</span>"},"ja535:90.4":{"pli":"Hirī ca ariyamhi guṇe patiṭṭhitā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:91.1":{"pli":"“Kumāriyo yācimā gottarakkhitā, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:91.2":{"pli":"Jiṇṇā ca yā yā ca sabhattuitthiyo; ","html":"<span class='verse-line'>{}</span>"},"ja535:91.3":{"pli":"Tā chandarāgaṁ purisesu uggataṁ, ","html":"<span class='verse-line'>{}</span>"},"ja535:91.4":{"pli":"Hiriyā nivārenti sacittamattano. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:92.1":{"pli":"Saṅgāmasīse sarasattisaṁyute, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:92.2":{"pli":"Parājitānaṁ patataṁ palāyinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja535:92.3":{"pli":"Hiriyā nivattanti jahitva jīvitaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja535:92.4":{"pli":"Te sampaṭicchanti punā hirīmanā. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:93.1":{"pli":"Velā yathā sāgaravegavārinī, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:93.2":{"pli":"Hirāya hi pāpajanaṁ nivārinī; ","html":"<span class='verse-line'>{}</span>"},"ja535:93.3":{"pli":"Taṁ sabbaloke hirimariyapūjitaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja535:93.4":{"pli":"Indassa taṁ vedaya devasārathi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:94.1":{"pli":"“Ko te imaṁ kosiya diṭṭhimodahi, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:94.2":{"pli":"Brahmā mahindo atha vā pajāpati; ","html":"<span class='verse-line'>{}</span>"},"ja535:94.3":{"pli":"Hirāya devesu hi seṭṭhasammatā, ","html":"<span class='verse-line'>{}</span>"},"ja535:94.4":{"pli":"Dhītā mahindassa mahesi jāyatha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:95.1":{"pli":"“Handehi dāni tidivaṁ apakkama, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:95.2":{"pli":"Rathaṁ samāruyha mamāyitaṁ imaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja535:95.3":{"pli":"Indo ca taṁ indasagotta kaṅkhati, ","html":"<span class='verse-line'>{}</span>"},"ja535:95.4":{"pli":"Ajjeva tvaṁ indasahabyataṁ vaja”. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:96.1":{"pli":"“Evaṁ visujjhanti apāpakammino, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:96.2":{"pli":"Atho suciṇṇassa phalaṁ na nassati; ","html":"<span class='verse-line'>{}</span>"},"ja535:96.3":{"pli":"Ye keci maddakkhu sudhāya bhojanaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja535:96.4":{"pli":"Sabbeva te indasahabyataṁ gatā. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:97.1":{"pli":"Hirī uppalavaṇṇāsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:97.2":{"pli":"kosiyo dānapati bhikkhu; ","html":"<span class='verse-line'>{}</span>"},"ja535:97.3":{"pli":"Anuruddho pañcasikho, ","html":"<span class='verse-line'>{}</span>"},"ja535:97.4":{"pli":"ānando āsi mātali. ","html":"<span class='verse-line'>{}</span></p>"},"ja535:98.1":{"pli":"Sūriyo kassapo bhikkhu, ","html":"<p><span class='verse-line'>{}</span>"},"ja535:98.2":{"pli":"moggallānosi candimā; ","html":"<span class='verse-line'>{}</span>"},"ja535:98.3":{"pli":"Nārado sāriputtosi, ","html":"<span class='verse-line'>{}</span>"},"ja535:98.4":{"pli":"sambuddho āsi vāsavo”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja535:99.1":{"pli":"Sudhābhojanajātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}