.6":{"pli":"“natthi puthujjanassa ñāṇan”ti. ","html":"{}</p>"},"kv20.2:3.1":{"pli":"Puthujjano dutiyaṁ jhānaṁ …pe… ","html":"<p data-doxy='orthodox'>{}"},"kv20.2:3.2":{"pli":"tatiyaṁ jhānaṁ …pe… ","html":"{}"},"kv20.2:3.3":{"pli":"catutthaṁ jhānaṁ …pe… ","html":"{}"},"kv20.2:3.4":{"pli":"ākāsānañcāyatanaṁ samāpajjeyya, ","html":"{}"},"kv20.2:3.5":{"pli":"viññāṇañcāyatanaṁ ākiñcaññāyatanaṁ nevasaññānāsaññāyatanaṁ samāpajjeyya, ","html":"{}"},"kv20.2:3.6":{"pli":"puthujjano dānaṁ dadeyya …pe… ","html":"{}"},"kv20.2:3.7":{"pli":"cīvaraṁ dadeyya, ","html":"{}"},"kv20.2:3.8":{"pli":"piṇḍapātaṁ dadeyya, ","html":"{}"},"kv20.2:3.9":{"pli":"senāsanaṁ dadeyya, ","html":"{}"},"kv20.2:3.10":{"pli":"gilānapaccayabhesajjaparikkhāraṁ dadeyyāti? ","html":"{}"},"kv20.2:3.11":{"pli":"Āmantā. ","html":"{}"},"kv20.2:3.12":{"pli":"Hañci puthujjano gilānapaccayabhesajjaparikkhāraṁ dadeyya, no ca vata re vattabbe—","html":"{}"},"kv20.2:3.13":{"pli":"“natthi puthujjanassa ñāṇan”ti. ","html":"{}</p>"},"kv20.2:4.1":{"pli":"Atthi puthujjanassa ñāṇanti? ","html":"<p data-doxy='heterodox'>{}"},"kv20.2:4.2":{"pli":"Āmantā. ","html":"{}"},"kv20.2:4.3":{"pli":"Puthujjano tena ñāṇena dukkhaṁ parijānāti, samudayaṁ pajahati, nirodhaṁ sacchikaroti, maggaṁ bhāvetīti? ","html":"{}"},"kv20.2:4.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv20.2:4.5":{"pli":"Ñāṇakathā niṭṭhitā. ","html":"<p class='endsutta'>{}</p></article>"}},"kv20.3":{"kv20.3:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv20.3'><header><ul><li class='division'>{}</li>"},"kv20.3:0.2":{"pli":"Mahāpaṇṇāsaka ","html":"<li>{}</li>"},"kv20.3:0.3":{"pli":"Vīsatimavagga ","html":"<li>{}</li></ul>"},"kv20.3:0.4":{"pli":"Nirayapālakathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv20.3:1.1":{"pli":"Natthi nirayesu nirayapālāti? ","html":"<p data-doxy='orthodox'>{}"},"kv20.3:1.2":{"pli":"Āmantā. ","html":"{}"},"kv20.3:1.3":{"pli":"Natthi nirayesu kammakāraṇāti? ","html":"{}"},"kv20.3:1.4":{"pli":"Na hevaṁ vattabbe …pe… ","