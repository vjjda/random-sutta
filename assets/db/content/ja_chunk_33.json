{"ja520":{"ja520:0.1":{"pli":"Jātaka ","html":"<article id='ja520'><header><ul><li class='division'>{}</li>"},"ja520:0.2":{"pli":"Tiṁsanipāta ","html":"<li>{}</li>"},"ja520:0.3":{"pli":"Kiṁchandavagga ","html":"<li>{}</li></ul>"},"ja520:0.4":{"pli":"10. Gandhatindukajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja520:1.1":{"pli":"“Appamādo amataṁ padaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja520:1.2":{"pli":"Pamādo maccuno padaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja520:1.3":{"pli":"Appamattā na mīyanti, ","html":"<span class='verse-line'>{}</span>"},"ja520:1.4":{"pli":"Ye pamattā yathā matā. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:2.1":{"pli":"Madā pamādo jāyetha, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:2.2":{"pli":"pamādā jāyate khayo; ","html":"<span class='verse-line'>{}</span>"},"ja520:2.3":{"pli":"Khayā padosā jāyanti, ","html":"<span class='verse-line'>{}</span>"},"ja520:2.4":{"pli":"mā pamādo bharatūsabha. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:3.1":{"pli":"Bahū hi khattiyā jīnā, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:3.2":{"pli":"atthaṁ raṭṭhaṁ pamādino; ","html":"<span class='verse-line'>{}</span>"},"ja520:3.3":{"pli":"Athopi gāmino gāmā, ","html":"<span class='verse-line'>{}</span>"},"ja520:3.4":{"pli":"anagārā agārino. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:4.1":{"pli":"Khattiyassa pamattassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:4.2":{"pli":"raṭṭhasmiṁ raṭṭhavaḍḍhana; ","html":"<span class='verse-line'>{}</span>"},"ja520:4.3":{"pli":"Sabbe bhogā vinassanti, ","html":"<span class='verse-line'>{}</span>"},"ja520:4.4":{"pli":"rañño taṁ vuccate aghaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:5.1":{"pli":"Nesa dhammo mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:5.2":{"pli":"ativelaṁ pamajjasi; ","html":"<span class='verse-line'>{}</span>"},"ja520:5.3":{"pli":"Iddhaṁ phītaṁ janapadaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja520:5.4":{"pli":"corā viddhaṁsayanti naṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:6.1":{"pli":"Na te puttā bhavissanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:6.2":{"pli":"na hiraññaṁ na dhāniyaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja520:6.3":{"pli":"Raṭṭhe viluppamānamhi, ","html":"<span class='verse-line'>{}</span>"},"ja520:6.4":{"pli":"sabbabhogehi jiyyasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:7.1":{"pli":"Sabbabhogā parijiṇṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:7.2":{"pli":"rājānaṁ vāpi khattiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja520:7.3":{"pli":"Ñātimittā suhajjā ca, ","html":"<span class='verse-line'>{}</span>"},"ja520:7.4":{"pli":"na taṁ maññanti māniyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:8.1":{"pli":"Hatthārohā anikaṭṭhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:8.2":{"pli":"rathikā pattikārakā; ","html":"<span class='verse-line'>{}</span>"},"ja520:8.3":{"pli":"Tamevamupajīvantā, ","html":"<span class='verse-line'>{}</span>"},"ja520:8.4":{"pli":"na taṁ maññanti māniyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:9.1":{"pli":"Asaṁvihitakammantaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:9.2":{"pli":"bālaṁ dummantimantinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja520:9.3":{"pli":"Sirī jahati dummedhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja520:9.4":{"pli":"jiṇṇaṁva urago tacaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:10.1":{"pli":"Susaṁvihitakammantaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:10.2":{"pli":"kāluṭṭhāyiṁ atanditaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja520:10.3":{"pli":"Sabbe bhogābhivaḍḍhanti, ","html":"<span class='verse-line'>{}</span>"},"ja520:10.4":{"pli":"gāvo sausabhāmiva. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:11.1":{"pli":"Upassutiṁ mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:11.2":{"pli":"raṭṭhe janapade cara; ","html":"<span class='verse-line'>{}</span>"},"ja520:11.3":{"pli":"Tattha disvā ca sutvā ca, ","html":"<span class='verse-line'>{}</span>"},"ja520:11.4":{"pli":"tato taṁ paṭipajjasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:12.1":{"pli":"“Evaṁ vedetu pañcālo, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:12.2":{"pli":"saṅgāme saramappito; ","html":"<span class='verse-line'>{}</span>"},"ja520:12.3":{"pli":"Yathāhamajja vedemi, ","html":"<span class='verse-line'>{}</span>"},"ja520:12.4":{"pli":"kaṇṭakena samappito”. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:13.1":{"pli":"“Jiṇṇo dubbalacakkhūsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:13.2":{"pli":"na rūpaṁ sādhu passasi; ","html":"<span class='verse-line'>{}</span>"},"ja520:13.3":{"pli":"Kiṁ tattha brahmadattassa, ","html":"<span class='verse-line'>{}</span>"},"ja520:13.4":{"pli":"yaṁ taṁ maggeyya kaṇṭako”. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:14.1":{"pli":"“Bahvettha brahmadattassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:14.2":{"pli":"Sohaṁ maggasmi brāhmaṇa; ","html":"<span class='verse-line'>{}</span>"},"ja520:14.3":{"pli":"Arakkhitā jānapadā, ","html":"<span class='verse-line'>{}</span>"},"ja520:14.4":{"pli":"Adhammabalinā hatā. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:15.1":{"pli":"Rattiñhi corā khādanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:15.2":{"pli":"divā khādanti tuṇḍiyā; ","html":"<span class='verse-line'>{}</span>"},"ja520:15.3":{"pli":"Raṭṭhasmiṁ kūṭarājassa, ","html":"<span class='verse-line'>{}</span>"},"ja520:15.4":{"pli":"bahu adhammiko jano. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:16.1":{"pli":"Etādise bhaye jāte, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:16.2":{"pli":"bhayaṭṭā tāta māṇavā; ","html":"<span class='verse-line'>{}</span>"},"ja520:16.3":{"pli":"Nillenakāni kubbanti, ","html":"<span class='verse-line'>{}</span>"},"ja520:16.4":{"pli":"vane āhatva kaṇṭakaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:17.1":{"pli":"“Kadāssu nāmayaṁ rājā, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:17.2":{"pli":"brahmadatto marissati; ","html":"<span class='verse-line'>{}</span>"},"ja520:17.3":{"pli":"Yassa raṭṭhamhi jiyyanti, ","html":"<span class='verse-line'>{}</span>"},"ja520:17.4":{"pli":"appatikā kumārikā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:18.1":{"pli":"“Dubbhāsitañhi te jammi, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:18.2":{"pli":"anatthapadakovide; ","html":"<span class='verse-line'>{}</span>"},"ja520:18.3":{"pli":"Kuhiṁ rājā kumārīnaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja520:18.4":{"pli":"bhattāraṁ pariyesati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:19.1":{"pli":"“Na me dubbhāsitaṁ brahme, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:19.2":{"pli":"kovidatthapadā ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja520:19.3":{"pli":"Arakkhitā jānapadā, ","html":"<span class='verse-line'>{}</span>"},"ja520:19.4":{"pli":"adhammabalinā hatā. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:20.1":{"pli":"Rattiñhi corā khādanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:20.2":{"pli":"divā khādanti tuṇḍiyā; ","html":"<span class='verse-line'>{}</span>"},"ja520:20.3":{"pli":"Raṭṭhasmiṁ kūṭarājassa, ","html":"<span class='verse-line'>{}</span>"},"ja520:20.4":{"pli":"bahu adhammiko jano; ","html":"<span class='verse-line'>{}</span>"},"ja520:20.5":{"pli":"Dujjīve dubbhare dāre, ","html":"<span class='verse-line'>{}</span>"},"ja520:20.6":{"pli":"kuto bhattā kumāriyo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:21.1":{"pli":"“Evaṁ sayatu pañcālo, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:21.2":{"pli":"saṅgāme sattiyā hato; ","html":"<span class='verse-line'>{}</span>"},"ja520:21.3":{"pli":"Yathāyaṁ kapaṇo seti, ","html":"<span class='verse-line'>{}</span>"},"ja520:21.4":{"pli":"hato phālena sāliyo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:22.1":{"pli":"“Adhammena tuvaṁ jamma, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:22.2":{"pli":"brahmadattassa kujjhasi; ","html":"<span class='verse-line'>{}</span>"},"ja520:22.3":{"pli":"Yo tvaṁ sapasi rājānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja520:22.4":{"pli":"aparajjhitvāna attano”. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:23.1":{"pli":"“Dhammena brahmadattassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:23.2":{"pli":"ahaṁ kujjhāmi brāhmaṇa; ","html":"<span class='verse-line'>{}</span>"},"ja520:23.3":{"pli":"Arakkhitā jānapadā, ","html":"<span class='verse-line'>{}</span>"},"ja520:23.4":{"pli":"adhammabalinā hatā. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:24.1":{"pli":"Rattiñhi corā khādanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:24.2":{"pli":"divā khādanti tuṇḍiyā; ","html":"<span class='verse-line'>{}</span>"},"ja520:24.3":{"pli":"Raṭṭhasmiṁ kūṭarājassa, ","html":"<span class='verse-line'>{}</span>"},"ja520:24.4":{"pli":"bahu adhammiko jano. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:25.1":{"pli":"Sā nūna puna re pakkā, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:25.2":{"pli":"vikāle bhattamāhari; ","html":"<span class='verse-line'>{}</span>"},"ja520:25.3":{"pli":"Bhattahāriṁ apekkhanto, ","html":"<span class='verse-line'>{}</span>"},"ja520:25.4":{"pli":"hato phālena sāliyo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:26.1":{"pli":"“Evaṁ haññatu pañcālo, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:26.2":{"pli":"saṅgāme asinā hato; ","html":"<span class='verse-line'>{}</span>"},"ja520:26.3":{"pli":"Yathāhamajja pahato, ","html":"<span class='verse-line'>{}</span>"},"ja520:26.4":{"pli":"khīrañca me pavaṭṭitaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:27.1":{"pli":"“Yaṁ pasu khīraṁ chaḍḍeti, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:27.2":{"pli":"pasupālaṁ vihiṁsati; ","html":"<span class='verse-line'>{}</span>"},"ja520:27.3":{"pli":"Kiṁ tattha brahmadattassa, ","html":"<span class='verse-line'>{}</span>"},"ja520:27.4":{"pli":"yaṁ no garahate bhavaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:28.1":{"pli":"“Gārayho brahme pañcālo, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:28.2":{"pli":"brahmadattassa rājino; ","html":"<span class='verse-line'>{}</span>"},"ja520:28.3":{"pli":"Arakkhitā jānapadā, ","html":"<span class='verse-line'>{}</span>"},"ja520:28.4":{"pli":"adhammabalinā hatā. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:29.1":{"pli":"Rattiñhi corā khādanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:29.2":{"pli":"divā khādanti tuṇḍiyā; ","html":"<span class='verse-line'>{}</span>"},"ja520:29.3":{"pli":"Raṭṭhasmiṁ kūṭarājassa, ","html":"<span class='verse-line'>{}</span>"},"ja520:29.4":{"pli":"bahu adhammiko jano. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:30.1":{"pli":"Caṇḍā aṭanakā gāvī, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:30.2":{"pli":"yaṁ pure na duhāmase; ","html":"<span class='verse-line'>{}</span>"},"ja520:30.3":{"pli":"Taṁ dāni ajja dohāma, ","html":"<span class='verse-line'>{}</span>"},"ja520:30.4":{"pli":"khīrakāmehupaddutā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:31.1":{"pli":"“Evaṁ kandatu pañcālo, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:31.2":{"pli":"viputto vippasukkhatu; ","html":"<span class='verse-line'>{}</span>"},"ja520:31.3":{"pli":"Yathāyaṁ kapaṇā gāvī, ","html":"<span class='verse-line'>{}</span>"},"ja520:31.4":{"pli":"viputtā paridhāvati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:32.1":{"pli":"“Yaṁ pasu pasupālassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:32.2":{"pli":"sambhameyya raveyya vā; ","html":"<span class='verse-line'>{}</span>"},"ja520:32.3":{"pli":"Ko nīdha aparādhatthi, ","html":"<span class='verse-line'>{}</span>"},"ja520:32.4":{"pli":"brahmadattassa rājino”. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:33.1":{"pli":"“Aparādho mahābrahme, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:33.2":{"pli":"brahmadattassa rājino; ","html":"<span class='verse-line'>{}</span>"},"ja520:33.3":{"pli":"Arakkhitā jānapadā, ","html":"<span class='verse-line'>{}</span>"},"ja520:33.4":{"pli":"adhammabalinā hatā. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:34.1":{"pli":"Rattiñhi corā khādanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:34.2":{"pli":"divā khādanti tuṇḍiyā; ","html":"<span class='verse-line'>{}</span>"},"ja520:34.3":{"pli":"Raṭṭhasmiṁ kūṭarājassa, ","html":"<span class='verse-line'>{}</span>"},"ja520:34.4":{"pli":"bahu adhammiko jano; ","html":"<span class='verse-line'>{}</span>"},"ja520:34.5":{"pli":"Kathaṁ no asikosatthā, ","html":"<span class='verse-line'>{}</span>"},"ja520:34.6":{"pli":"khīrapā haññate pajā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:35.1":{"pli":"“Evaṁ khajjatu pañcālo, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:35.2":{"pli":"hato yuddhe saputtako; ","html":"<span class='verse-line'>{}</span>"},"ja520:35.3":{"pli":"Yathāhamajja khajjāmi, ","html":"<span class='verse-line'>{}</span>"},"ja520:35.4":{"pli":"gāmikehi araññajo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:36.1":{"pli":"“Na sabbabhūtesu vidhenti rakkhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:36.2":{"pli":"Rājāno maṇḍūka manussaloke; ","html":"<span class='verse-line'>{}</span>"},"ja520:36.3":{"pli":"Nettāvatā rājā adhammacārī, ","html":"<span class='verse-line'>{}</span>"},"ja520:36.4":{"pli":"Yaṁ tādisaṁ jīvamadeyyu dhaṅkā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:37.1":{"pli":"“Adhammarūpo vata brahmacārī, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:37.2":{"pli":"Anuppiyaṁ bhāsasi khattiyassa; ","html":"<span class='verse-line'>{}</span>"},"ja520:37.3":{"pli":"Viluppamānāya puthuppajāya, ","html":"<span class='verse-line'>{}</span>"},"ja520:37.4":{"pli":"Pūjesi rājaṁ paramappamādaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja520:38.1":{"pli":"Sace idaṁ brahme surajjakaṁ siyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja520:38.2":{"pli":"Phītaṁ raṭṭhaṁ muditaṁ vippasannaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja520:38.3":{"pli":"Bhutvā baliṁ aggapiṇḍañca kākā, ","html":"<span class='verse-line'>{}</span>"},"ja520:38.4":{"pli":"Na mādisaṁ jīvamadeyyu dhaṅkā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja520:39.1":{"pli":"Gandhatindukajātakaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja520:40.1":{"pli":"Tiṁsanipātaṁ niṭṭhitaṁ. ","html":"<p class='endsection'>{}</p>"},"ja520:41.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja520:42.1":{"pli":"Kiṁchanda kumbha jayaddisa chaddanta, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja520:42.2":{"pli":"Atha paṇḍitasambhava sirakapi; ","html":"<span class='verse-line'>{}</span>"},"ja520:42.3":{"pli":"Dakarakkhasa paṇḍaranāgavaro, ","html":"<span class='verse-line'>{}</span>"},"ja520:42.4":{"pli":"Atha sambula tindukadevasutoti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja520:43.1":{"pli":"Jātakapāḷiyā paṭhamo bhāgo niṭṭhito. ","html":"<p class='endbook'>{}</p></article>"}},"ja521":{"ja521:0.1":{"pli":"Jātaka ","html":"<article id='ja521'><header><ul><li class='division'>{}</li>"},"ja521:0.2":{"pli":"Cattālīsanipāta ","html":"<li>{}</li>"},"ja521:0.3":{"pli":"Tesakuṇavagga ","html":"<li>{}</li></ul>"},"ja521:0.4":{"pli":"1. Tesakuṇajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja521:1.1":{"pli":"Namo tassa Bhagavato Arahato Sammāsambuddhassa. ","html":"<p class='namo'>{}</p>"},"ja521:2.1":{"pli":"“Vessantaraṁ taṁ pucchāmi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja521:2.2":{"pli":"sakuṇa bhaddamatthu te; ","html":"<span class='verse-line'>{}</span>"},"ja521:2.3":{"pli":"Rajjaṁ kāretukāmena, ","html":"<span class='verse-line'>{}</span>"},"ja521:2.4":{"pli":"kiṁ su kiccaṁ kataṁ varaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:3.1":{"pli":"“Cirassaṁ vata maṁ tāto, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:3.2":{"pli":"kaṁso bārāṇasiggaho; ","html":"<span class='verse-line'>{}</span>"},"ja521:3.3":{"pli":"Pamatto appamattaṁ maṁ, ","html":"<span class='verse-line'>{}</span>"},"ja521:3.4":{"pli":"pitā puttaṁ acodayi. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:4.1":{"pli":"Paṭhameneva vitathaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:4.2":{"pli":"kodhaṁ hāsaṁ nivāraye; ","html":"<span class='verse-line'>{}</span>"},"ja521:4.3":{"pli":"Tato kiccāni kāreyya, ","html":"<span class='verse-line'>{}</span>"},"ja521:4.4":{"pli":"taṁ vataṁ āhu khattiya. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:5.1":{"pli":"Yaṁ tvaṁ tāta tapokammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:5.2":{"pli":"Pubbe katamasaṁsayaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja521:5.3":{"pli":"Ratto duṭṭho ca yaṁ kayirā, ","html":"<span class='verse-line'>{}</span>"},"ja521:5.4":{"pli":"Na taṁ kayirā tato puna. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:6.1":{"pli":"Khattiyassa pamattassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:6.2":{"pli":"raṭṭhasmiṁ raṭṭhavaḍḍhana; ","html":"<span class='verse-line'>{}</span>"},"ja521:6.3":{"pli":"Sabbe bhogā vinassanti, ","html":"<span class='verse-line'>{}</span>"},"ja521:6.4":{"pli":"rañño taṁ vuccate aghaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:7.1":{"pli":"Sirī tāta alakkhī ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:7.2":{"pli":"pucchitā etadabravuṁ; ","html":"<span class='verse-line'>{}</span>"},"ja521:7.3":{"pli":"Uṭṭhānavīriye pose, ","html":"<span class='verse-line'>{}</span>"},"ja521:7.4":{"pli":"ramāhaṁ anusūyake. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:8.1":{"pli":"Usūyake duhadaye, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:8.2":{"pli":"purise kammadussake; ","html":"<span class='verse-line'>{}</span>"},"ja521:8.3":{"pli":"Kāḷakaṇṇī mahārāja, ","html":"<span class='verse-line'>{}</span>"},"ja521:8.4":{"pli":"ramati cakkabhañjanī. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:9.1":{"pli":"So tvaṁ sabbesu suhadayo, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:9.2":{"pli":"sabbesaṁ rakkhito bhava; ","html":"<span class='verse-line'>{}</span>"},"ja521:9.3":{"pli":"Alakkhiṁ nuda mahārāja, ","html":"<span class='verse-line'>{}</span>"},"ja521:9.4":{"pli":"lakkhyā bhava nivesanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:10.1":{"pli":"Sa lakkhīdhitisampanno, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:10.2":{"pli":"puriso hi mahaggato; ","html":"<span class='verse-line'>{}</span>"},"ja521:10.3":{"pli":"Amittānaṁ kāsipati, ","html":"<span class='verse-line'>{}</span>"},"ja521:10.4":{"pli":"mūlaṁ aggañca chindati. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:11.1":{"pli":"Sakkopi hi bhūtapati, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:11.2":{"pli":"uṭṭhāne nappamajjati; ","html":"<span class='verse-line'>{}</span>"},"ja521:11.3":{"pli":"Sa kalyāṇe dhitiṁ katvā, ","html":"<span class='verse-line'>{}</span>"},"ja521:11.4":{"pli":"uṭṭhāne kurute mano. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:12.1":{"pli":"Gandhabbā pitaro devā, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:12.2":{"pli":"sājīvā honti tādino; ","html":"<span class='verse-line'>{}</span>"},"ja521:12.3":{"pli":"Uṭṭhāhato appamajjato, ","html":"<span class='verse-line'>{}</span>"},"ja521:12.4":{"pli":"anutiṭṭhanti devatā. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:13.1":{"pli":"So appamatto akkuddho, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:13.2":{"pli":"tāta kiccāni kāraya; ","html":"<span class='verse-line'>{}</span>"},"ja521:13.3":{"pli":"Vāyamassu ca kiccesu, ","html":"<span class='verse-line'>{}</span>"},"ja521:13.4":{"pli":"nālaso vindate sukhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:14.1":{"pli":"Tattheva te vattapadā, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:14.2":{"pli":"esāva anusāsanī; ","html":"<span class='verse-line'>{}</span>"},"ja521:14.3":{"pli":"Alaṁ mitte sukhāpetuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja521:14.4":{"pli":"amittānaṁ dukhāya ca”. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:15.1":{"pli":"“Sakkhisi tvaṁ kuṇḍalini, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:15.2":{"pli":"maññasi khattabandhuni; ","html":"<span class='verse-line'>{}</span>"},"ja521:15.3":{"pli":"Rajjaṁ kāretukāmena, ","html":"<span class='verse-line'>{}</span>"},"ja521:15.4":{"pli":"kiṁ su kiccaṁ kataṁ varaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:16.1":{"pli":"“Dveva tāta padakāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:16.2":{"pli":"yattha sabbaṁ patiṭṭhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja521:16.3":{"pli":"Aladdhassa ca yo lābho, ","html":"<span class='verse-line'>{}</span>"},"ja521:16.4":{"pli":"laddhassa cānurakkhaṇā. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:17.1":{"pli":"Amacce tāta jānāhi, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:17.2":{"pli":"dhīre atthassa kovide; ","html":"<span class='verse-line'>{}</span>"},"ja521:17.3":{"pli":"Anakkhākitave tāta, ","html":"<span class='verse-line'>{}</span>"},"ja521:17.4":{"pli":"asoṇḍe avināsake. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:18.1":{"pli":"Yo ca taṁ tāta rakkheyya, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:18.2":{"pli":"dhanaṁ yañceva te siyā; ","html":"<span class='verse-line'>{}</span>"},"ja521:18.3":{"pli":"Sūtova rathaṁ saṅgaṇhe, ","html":"<span class='verse-line'>{}</span>"},"ja521:18.4":{"pli":"so te kiccāni kāraye. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:19.1":{"pli":"Susaṅgahitantajano, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:19.2":{"pli":"sayaṁ vittaṁ avekkhiya; ","html":"<span class='verse-line'>{}</span>"},"ja521:19.3":{"pli":"Nidhiñca iṇadānañca, ","html":"<span class='verse-line'>{}</span>"},"ja521:19.4":{"pli":"na kare parapattiyā. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:20.1":{"pli":"Sayaṁ āyaṁ vayaṁ jaññā, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:20.2":{"pli":"sayaṁ jaññā katākataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja521:20.3":{"pli":"Niggaṇhe niggahārahaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja521:20.4":{"pli":"paggaṇhe paggahārahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:21.1":{"pli":"Sayaṁ jānapadaṁ atthaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:21.2":{"pli":"anusāsa rathesabha; ","html":"<span class='verse-line'>{}</span>"},"ja521:21.3":{"pli":"Mā te adhammikā yuttā, ","html":"<span class='verse-line'>{}</span>"},"ja521:21.4":{"pli":"dhanaṁ raṭṭhañca nāsayuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:22.1":{"pli":"Mā ca vegena kiccāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:22.2":{"pli":"karosi kārayesi vā; ","html":"<span class='verse-line'>{}</span>"},"ja521:22.3":{"pli":"Vegasā hi kataṁ kammaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja521:22.4":{"pli":"mando pacchānutappati. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:23.1":{"pli":"Mā te adhisare muñca, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:23.2":{"pli":"subāḷhamadhikopitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja521:23.3":{"pli":"Kodhasā hi bahū phītā, ","html":"<span class='verse-line'>{}</span>"},"ja521:23.4":{"pli":"kulā akulataṁ gatā. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:24.1":{"pli":"Mā tāta issaromhīti, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:24.2":{"pli":"anatthāya patārayi; ","html":"<span class='verse-line'>{}</span>"},"ja521:24.3":{"pli":"Itthīnaṁ purisānañca, ","html":"<span class='verse-line'>{}</span>"},"ja521:24.4":{"pli":"mā te āsi dukhudrayo. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:25.1":{"pli":"Apetalomahaṁsassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:25.2":{"pli":"rañño kāmānusārino; ","html":"<span class='verse-line'>{}</span>"},"ja521:25.3":{"pli":"Sabbe bhogā vinassanti, ","html":"<span class='verse-line'>{}</span>"},"ja521:25.4":{"pli":"rañño taṁ vuccate aghaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:26.1":{"pli":"Tattheva te vattapadā, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:26.2":{"pli":"esāva anusāsanī; ","html":"<span class='verse-line'>{}</span>"},"ja521:26.3":{"pli":"Dakkhassudāni puññakaro, ","html":"<span class='verse-line'>{}</span>"},"ja521:26.4":{"pli":"asoṇḍo avināsako; ","html":"<span class='verse-line'>{}</span>"},"ja521:26.5":{"pli":"Sīlavāssu mahārāja, ","html":"<span class='verse-line'>{}</span>"},"ja521:26.6":{"pli":"dussīlo vinipātiko”. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:27.1":{"pli":"“Apucchimha kosiyagottaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:27.2":{"pli":"kuṇḍaliniṁ tatheva ca; ","html":"<span class='verse-line'>{}</span>"},"ja521:27.3":{"pli":"Tvaṁ dāni vadehi jambuka, ","html":"<span class='verse-line'>{}</span>"},"ja521:27.4":{"pli":"balānaṁ balamuttamaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:28.1":{"pli":"“Balaṁ pañcavidhaṁ loke, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:28.2":{"pli":"purisasmiṁ mahaggate; ","html":"<span class='verse-line'>{}</span>"},"ja521:28.3":{"pli":"Tattha bāhubalaṁ nāma, ","html":"<span class='verse-line'>{}</span>"},"ja521:28.4":{"pli":"carimaṁ vuccate balaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:29.1":{"pli":"Bhogabalañca dīghāvu, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:29.2":{"pli":"dutiyaṁ vuccate balaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja521:29.3":{"pli":"Amaccabalañca dīghāvu, ","html":"<span class='verse-line'>{}</span>"},"ja521:29.4":{"pli":"tatiyaṁ vuccate balaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:30.1":{"pli":"Abhijaccabalaṁ ceva, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:30.2":{"pli":"taṁ catutthaṁ asaṁsayaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja521:30.3":{"pli":"Yāni cetāni sabbāni, ","html":"<span class='verse-line'>{}</span>"},"ja521:30.4":{"pli":"adhigaṇhāti paṇḍito. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:31.1":{"pli":"Taṁ balānaṁ balaṁ seṭṭhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:31.2":{"pli":"aggaṁ paññābalaṁ balaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja521:31.3":{"pli":"Paññābalenupatthaddho, ","html":"<span class='verse-line'>{}</span>"},"ja521:31.4":{"pli":"atthaṁ vindati paṇḍito. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:32.1":{"pli":"Api ce labhati mando, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:32.2":{"pli":"phītaṁ dharaṇimuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja521:32.3":{"pli":"Akāmassa pasayhaṁ vā, ","html":"<span class='verse-line'>{}</span>"},"ja521:32.4":{"pli":"añño taṁ paṭipajjati. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:33.1":{"pli":"Abhijātopi ce hoti, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:33.2":{"pli":"rajjaṁ laddhāna khattiyo; ","html":"<span class='verse-line'>{}</span>"},"ja521:33.3":{"pli":"Duppañño hi kāsipati, ","html":"<span class='verse-line'>{}</span>"},"ja521:33.4":{"pli":"sabbenapi na jīvati. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:34.1":{"pli":"Paññāva sutaṁ vinicchinī, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:34.2":{"pli":"Paññā kitti silokavaḍḍhanī; ","html":"<span class='verse-line'>{}</span>"},"ja521:34.3":{"pli":"Paññāsahito naro idha, ","html":"<span class='verse-line'>{}</span>"},"ja521:34.4":{"pli":"Api dukkhe sukhāni vindati. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:35.1":{"pli":"Paññañca kho asussūsaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:35.2":{"pli":"na koci adhigacchati; ","html":"<span class='verse-line'>{}</span>"},"ja521:35.3":{"pli":"Bahussutaṁ anāgamma, ","html":"<span class='verse-line'>{}</span>"},"ja521:35.4":{"pli":"dhammaṭṭhaṁ avinibbhujaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:36.1":{"pli":"Yo ca dhammavibhaṅgaññū, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:36.2":{"pli":"kāluṭṭhāyī matandito; ","html":"<span class='verse-line'>{}</span>"},"ja521:36.3":{"pli":"Anuṭṭhahati kālena, ","html":"<span class='verse-line'>{}</span>"},"ja521:36.4":{"pli":"kammaphalaṁ tassijjhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:37.1":{"pli":"Anāyatanasīlassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:37.2":{"pli":"anāyatanasevino; ","html":"<span class='verse-line'>{}</span>"},"ja521:37.3":{"pli":"Na nibbindiyakārissa, ","html":"<span class='verse-line'>{}</span>"},"ja521:37.4":{"pli":"sammadattho vipaccati. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:38.1":{"pli":"Ajjhattañca payuttassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:38.2":{"pli":"tathāyatanasevino; ","html":"<span class='verse-line'>{}</span>"},"ja521:38.3":{"pli":"Anibbindiyakārissa, ","html":"<span class='verse-line'>{}</span>"},"ja521:38.4":{"pli":"sammadattho vipaccati. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:39.1":{"pli":"Yogappayogasaṅkhātaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:39.2":{"pli":"sambhatassānurakkhaṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja521:39.3":{"pli":"Tāni tvaṁ tāta sevassu, ","html":"<span class='verse-line'>{}</span>"},"ja521:39.4":{"pli":"mā akammāya randhayi; ","html":"<span class='verse-line'>{}</span>"},"ja521:39.5":{"pli":"Akammunā hi dummedho, ","html":"<span class='verse-line'>{}</span>"},"ja521:39.6":{"pli":"naḷāgāraṁva sīdati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:40.1":{"pli":"“Dhammaṁ cara mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:40.2":{"pli":"mātāpitūsu khattiya; ","html":"<span class='verse-line'>{}</span>"},"ja521:40.3":{"pli":"Idha dhammaṁ caritvāna, ","html":"<span class='verse-line'>{}</span>"},"ja521:40.4":{"pli":"rāja saggaṁ gamissasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:41.1":{"pli":"Dhammaṁ cara mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:41.2":{"pli":"puttadāresu khattiya; ","html":"<span class='verse-line'>{}</span>"},"ja521:41.3":{"pli":"Idha dhammaṁ caritvāna, ","html":"<span class='verse-line'>{}</span>"},"ja521:41.4":{"pli":"rāja saggaṁ gamissasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:42.1":{"pli":"Dhammaṁ cara mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:42.2":{"pli":"mittāmaccesu khattiya; ","html":"<span class='verse-line'>{}</span>"},"ja521:42.3":{"pli":"Idha dhammaṁ caritvāna, ","html":"<span class='verse-line'>{}</span>"},"ja521:42.4":{"pli":"rāja saggaṁ gamissasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:43.1":{"pli":"Dhammaṁ cara mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:43.2":{"pli":"vāhanesu balesu ca; ","html":"<span class='verse-line'>{}</span>"},"ja521:43.3":{"pli":"Idha dhammaṁ caritvāna, ","html":"<span class='verse-line'>{}</span>"},"ja521:43.4":{"pli":"rāja saggaṁ gamissasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:44.1":{"pli":"Dhammaṁ cara mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:44.2":{"pli":"gāmesu nigamesu ca; ","html":"<span class='verse-line'>{}</span>"},"ja521:44.3":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span></p>"},"ja521:45.1":{"pli":"Dhammaṁ cara mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:45.2":{"pli":"raṭṭhesu janapadesu ca; ","html":"<span class='verse-line'>{}</span>"},"ja521:45.3":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span></p>"},"ja521:46.1":{"pli":"Dhammaṁ cara mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:46.2":{"pli":"samaṇabrāhmaṇesu ca; ","html":"<span class='verse-line'>{}</span>"},"ja521:46.3":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span></p>"},"ja521:47.1":{"pli":"Dhammaṁ cara mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:47.2":{"pli":"migapakkhīsu khattiya; ","html":"<span class='verse-line'>{}</span>"},"ja521:47.3":{"pli":"Idha dhammaṁ caritvāna, ","html":"<span class='verse-line'>{}</span>"},"ja521:47.4":{"pli":"rāja saggaṁ gamissasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:48.1":{"pli":"Dhammaṁ cara mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:48.2":{"pli":"dhammo ciṇṇo sukhāvaho; ","html":"<span class='verse-line'>{}</span>"},"ja521:48.3":{"pli":"Idha dhammaṁ caritvāna, ","html":"<span class='verse-line'>{}</span>"},"ja521:48.4":{"pli":"rāja saggaṁ gamissasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:49.1":{"pli":"Dhammaṁ cara mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:49.2":{"pli":"Saindā devā sabrahmakā; ","html":"<span class='verse-line'>{}</span>"},"ja521:49.3":{"pli":"Suciṇṇena divaṁ pattā, ","html":"<span class='verse-line'>{}</span>"},"ja521:49.4":{"pli":"Mā dhammaṁ rāja pāmado. ","html":"<span class='verse-line'>{}</span></p>"},"ja521:50.1":{"pli":"Tattheva te vattapadā, ","html":"<p><span class='verse-line'>{}</span>"},"ja521:50.2":{"pli":"Esāva anusāsanī; ","html":"<span class='verse-line'>{}</span>"},"ja521:50.3":{"pli":"Sappaññasevī kalyāṇī, ","html":"<span class='verse-line'>{}</span>"},"ja521:50.4":{"pli":"Samattaṁ sāma taṁ vidū”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja521:51.1":{"pli":"Tesakuṇajātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}