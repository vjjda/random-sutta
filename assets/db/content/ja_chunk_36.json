{"ja526":{"ja526:0.1":{"pli":"Jātaka ","html":"<article id='ja526'><header><ul><li class='division'>{}</li>"},"ja526:0.2":{"pli":"Paṇṇāsanipāta ","html":"<li>{}</li>"},"ja526:0.3":{"pli":"Niḷinikāvagga ","html":"<li>{}</li></ul>"},"ja526:0.4":{"pli":"1 Niḷinikājātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja526:1.1":{"pli":"“Uddayhate janapado, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja526:1.2":{"pli":"raṭṭhañcāpi vinassati; ","html":"<span class='verse-line'>{}</span>"},"ja526:1.3":{"pli":"Ehi niḷinike gaccha, ","html":"<span class='verse-line'>{}</span>"},"ja526:1.4":{"pli":"taṁ me brāhmaṇamānaya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:2.1":{"pli":"“Nāhaṁ dukkhakkhamā rāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:2.2":{"pli":"nāhaṁ addhānakovidā; ","html":"<span class='verse-line'>{}</span>"},"ja526:2.3":{"pli":"Kathaṁ ahaṁ gamissāmi, ","html":"<span class='verse-line'>{}</span>"},"ja526:2.4":{"pli":"vanaṁ kuñjarasevitaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:3.1":{"pli":"“Phītaṁ janapadaṁ gantvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:3.2":{"pli":"hatthinā ca rathena ca; ","html":"<span class='verse-line'>{}</span>"},"ja526:3.3":{"pli":"Dārusaṅghāṭayānena, ","html":"<span class='verse-line'>{}</span>"},"ja526:3.4":{"pli":"evaṁ gaccha niḷinike. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:4.1":{"pli":"Hatthiassarathe pattī, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:4.2":{"pli":"gacchevādāya khattiye; ","html":"<span class='verse-line'>{}</span>"},"ja526:4.3":{"pli":"Taveva vaṇṇarūpena, ","html":"<span class='verse-line'>{}</span>"},"ja526:4.4":{"pli":"vasaṁ tamānayissasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:5.1":{"pli":"“Kadalīdhajapaññāṇo, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:5.2":{"pli":"ābhujīparivārito; ","html":"<span class='verse-line'>{}</span>"},"ja526:5.3":{"pli":"Eso padissati rammo, ","html":"<span class='verse-line'>{}</span>"},"ja526:5.4":{"pli":"isisiṅgassa assamo. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:6.1":{"pli":"Eso aggissa saṅkhāto, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:6.2":{"pli":"eso dhūmo padissati; ","html":"<span class='verse-line'>{}</span>"},"ja526:6.3":{"pli":"Maññe no aggiṁ hāpeti, ","html":"<span class='verse-line'>{}</span>"},"ja526:6.4":{"pli":"isisiṅgo mahiddhiko”. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:7.1":{"pli":"“Tañca disvāna āyantiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:7.2":{"pli":"āmuttamaṇikuṇḍalaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja526:7.3":{"pli":"Isisiṅgo pāvisi bhīto, ","html":"<span class='verse-line'>{}</span>"},"ja526:7.4":{"pli":"assamaṁ paṇṇachādanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:8.1":{"pli":"Assamassa ca sā dvāre, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:8.2":{"pli":"geṇḍukenassa kīḷati; ","html":"<span class='verse-line'>{}</span>"},"ja526:8.3":{"pli":"Vidaṁsayantī aṅgāni, ","html":"<span class='verse-line'>{}</span>"},"ja526:8.4":{"pli":"guyhaṁ pakāsitāni ca. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:9.1":{"pli":"Tañca disvāna kīḷantiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:9.2":{"pli":"paṇṇasālagato jaṭī; ","html":"<span class='verse-line'>{}</span>"},"ja526:9.3":{"pli":"Assamā nikkhamitvāna, ","html":"<span class='verse-line'>{}</span>"},"ja526:9.4":{"pli":"idaṁ vacanamabravi. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:10.1":{"pli":"Ambho ko nāma so rukkho, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:10.2":{"pli":"yassa tevaṅgataṁ phalaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja526:10.3":{"pli":"Dūrepi khittaṁ pacceti, ","html":"<span class='verse-line'>{}</span>"},"ja526:10.4":{"pli":"na taṁ ohāya gacchati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:11.1":{"pli":"“Assamassa mama brahme, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:11.2":{"pli":"samīpe gandhamādane; ","html":"<span class='verse-line'>{}</span>"},"ja526:11.3":{"pli":"Bahavo tādisā rukkhā, ","html":"<span class='verse-line'>{}</span>"},"ja526:11.4":{"pli":"yassa tevaṅgataṁ phalaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja526:11.5":{"pli":"Dūrepi khittaṁ pacceti, ","html":"<span class='verse-line'>{}</span>"},"ja526:11.6":{"pli":"na maṁ ohāya gacchati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:12.1":{"pli":"“Etū bhavaṁ assamimaṁ adetu, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:12.2":{"pli":"Pajjañca bhakkhañca paṭiccha dammi; ","html":"<span class='verse-line'>{}</span>"},"ja526:12.3":{"pli":"Idamāsanaṁ atra bhavaṁ nisīdatu, ","html":"<span class='verse-line'>{}</span>"},"ja526:12.4":{"pli":"Ito bhavaṁ mūlaphalāni bhuñjatu. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:13.1":{"pli":"Kiṁ te idaṁ ūrūnamantarasmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:13.2":{"pli":"Supicchitaṁ kaṇharivappakāsati; ","html":"<span class='verse-line'>{}</span>"},"ja526:13.3":{"pli":"Akkhāhi me pucchito etamatthaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja526:13.4":{"pli":"Kose nu te uttamaṅgaṁ paviṭṭhaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:14.1":{"pli":"“Ahaṁ vane mūlaphalesanaṁ caraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:14.2":{"pli":"Āsādayiṁ acchaṁ sughorarūpaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja526:14.3":{"pli":"So maṁ patitvā sahasājjhapatto, ","html":"<span class='verse-line'>{}</span>"},"ja526:14.4":{"pli":"Panujja maṁ abbahi uttamaṅgaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:15.1":{"pli":"Svāyaṁ vaṇo khajjati kaṇḍuvāyati, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:15.2":{"pli":"Sabbañca kālaṁ na labhāmi sātaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja526:15.3":{"pli":"Paho bhavaṁ kaṇḍumimaṁ vinetuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja526:15.4":{"pli":"Kurutaṁ bhavaṁ yācito brāhmaṇatthaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:16.1":{"pli":"“Gambhīrarūpo te vaṇo salohito, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:16.2":{"pli":"Apūtiko vaṇagandho mahā ca; ","html":"<span class='verse-line'>{}</span>"},"ja526:16.3":{"pli":"Karomi te kiñci kasāyayogaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja526:16.4":{"pli":"Yathā bhavaṁ paramasukhī bhaveyya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:17.1":{"pli":"“Na mantayogā na kasāyayogā, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:17.2":{"pli":"Na osadhā brahmacāri kamanti; ","html":"<span class='verse-line'>{}</span>"},"ja526:17.3":{"pli":"Yaṁ te mudu tena vinehi kaṇḍuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja526:17.4":{"pli":"Yathā ahaṁ paramasukhī bhaveyyaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:18.1":{"pli":"“Ito nu bhoto katamena assamo, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:18.2":{"pli":"Kacci bhavaṁ abhiramasi araññe; ","html":"<span class='verse-line'>{}</span>"},"ja526:18.3":{"pli":"Kacci nu te mūlaphalaṁ pahūtaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja526:18.4":{"pli":"Kacci bhavantaṁ na vihiṁsanti vāḷā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:19.1":{"pli":"“Ito ujuṁ uttarāyaṁ disāyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:19.2":{"pli":"Khemānadī himavatā pabhāvī; ","html":"<span class='verse-line'>{}</span>"},"ja526:19.3":{"pli":"Tassā tīre assamo mayha rammo, ","html":"<span class='verse-line'>{}</span>"},"ja526:19.4":{"pli":"Aho bhavaṁ assamaṁ mayhaṁ passe. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:20.1":{"pli":"Ambā ca sālā tilakā ca jambuyo, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:20.2":{"pli":"Uddālakā pāṭaliyo ca phullā; ","html":"<span class='verse-line'>{}</span>"},"ja526:20.3":{"pli":"Samantato kimpurisābhigītaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja526:20.4":{"pli":"Aho bhavaṁ assamaṁ mayhaṁ passe. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:21.1":{"pli":"Tālā ca mūlā ca phalā ca mettha, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:21.2":{"pli":"Vaṇṇena gandhena upetarūpaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja526:21.3":{"pli":"Taṁ bhūmibhāgehi upetarūpaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja526:21.4":{"pli":"Aho bhavaṁ assamaṁ mayhaṁ passe. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:22.1":{"pli":"Phalā ca mūlā ca pahūtamettha, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:22.2":{"pli":"Vaṇṇena gandhena rasenupetā; ","html":"<span class='verse-line'>{}</span>"},"ja526:22.3":{"pli":"Āyanti ca luddakā taṁ padesaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja526:22.4":{"pli":"Mā me tato mūlaphalaṁ ahāsuṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:23.1":{"pli":"“Pitā mamaṁ mūlaphalesanaṁ gato, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:23.2":{"pli":"Idāni āgacchati sāyakāle; ","html":"<span class='verse-line'>{}</span>"},"ja526:23.3":{"pli":"Ubhova gacchāmase assamaṁ taṁ, ","html":"<span class='verse-line'>{}</span>"},"ja526:23.4":{"pli":"Yāva pitā mūlaphalato etu”. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:24.1":{"pli":"“Aññe bahū isayo sādhurūpā, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:24.2":{"pli":"Rājīsayo anumagge vasanti; ","html":"<span class='verse-line'>{}</span>"},"ja526:24.3":{"pli":"Teyeva pucchesi mamassamaṁ taṁ, ","html":"<span class='verse-line'>{}</span>"},"ja526:24.4":{"pli":"Te taṁ nayissanti mamaṁ sakāse”. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:25.1":{"pli":"“Na te kaṭṭhāni bhinnāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:25.2":{"pli":"na te udakamābhataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja526:25.3":{"pli":"Aggīpi te na hāpito, ","html":"<span class='verse-line'>{}</span>"},"ja526:25.4":{"pli":"kiṁ nu mandova jhāyasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:26.1":{"pli":"Bhinnāni kaṭṭhāni huto ca aggi, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:26.2":{"pli":"Tapanīpi te samitā brahmacārī; ","html":"<span class='verse-line'>{}</span>"},"ja526:26.3":{"pli":"Pīṭhañca mayhaṁ udakañca hoti, ","html":"<span class='verse-line'>{}</span>"},"ja526:26.4":{"pli":"Ramasi tuvaṁ brahmabhūto puratthā. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:27.1":{"pli":"Abhinnakaṭṭhosi anābhatodako, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:27.2":{"pli":"Ahāpitaggīsi asiddhabhojano; ","html":"<span class='verse-line'>{}</span>"},"ja526:27.3":{"pli":"Na me tuvaṁ ālapasī mamajja, ","html":"<span class='verse-line'>{}</span>"},"ja526:27.4":{"pli":"Naṭṭhaṁ nu kiṁ cetasikañca dukkhaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:28.1":{"pli":"“Idhāgamā jaṭilo brahmacārī, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:28.2":{"pli":"Sudassaneyyo sutanū vineti; ","html":"<span class='verse-line'>{}</span>"},"ja526:28.3":{"pli":"Nevātidīgho na panātirasso, ","html":"<span class='verse-line'>{}</span>"},"ja526:28.4":{"pli":"Sukaṇhakaṇhacchadanehi bhoto. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:29.1":{"pli":"Amassujāto apurāṇavaṇṇī, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:29.2":{"pli":"Ādhārarūpañca panassa kaṇṭhe; ","html":"<span class='verse-line'>{}</span>"},"ja526:29.3":{"pli":"Dve yamā gaṇḍā ure sujātā, ","html":"<span class='verse-line'>{}</span>"},"ja526:29.4":{"pli":"Suvaṇṇatindukanibhā pabhassarā. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:30.1":{"pli":"Mukhañca tassa bhusadassaneyyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:30.2":{"pli":"Kaṇṇesu lambanti ca kuñcitaggā; ","html":"<span class='verse-line'>{}</span>"},"ja526:30.3":{"pli":"Te jotare carato māṇavassa, ","html":"<span class='verse-line'>{}</span>"},"ja526:30.4":{"pli":"Suttañca yaṁ saṁyamanaṁ jaṭānaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:31.1":{"pli":"Aññā ca tassa saṁyamāni catasso, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:31.2":{"pli":"Nīlā pītā lohitikā ca setā; ","html":"<span class='verse-line'>{}</span>"},"ja526:31.3":{"pli":"Tā piṁsare carato māṇavassa, ","html":"<span class='verse-line'>{}</span>"},"ja526:31.4":{"pli":"Tiriṭisaṅghāriva pāvusamhi. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:32.1":{"pli":"Na mikhalaṁ muñjamayaṁ dhāreti, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:32.2":{"pli":"Na santhare no pana pabbajassa; ","html":"<span class='verse-line'>{}</span>"},"ja526:32.3":{"pli":"Tā jotare jaghanantare vilaggā, ","html":"<span class='verse-line'>{}</span>"},"ja526:32.4":{"pli":"Sateratā vijjurivantalikkhe. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:33.1":{"pli":"Akhīlakāni ca avaṇṭakāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:33.2":{"pli":"Heṭṭhā nabhyā kaṭisamohitāni; ","html":"<span class='verse-line'>{}</span>"},"ja526:33.3":{"pli":"Aghaṭṭitā niccakīḷaṁ karonti, ","html":"<span class='verse-line'>{}</span>"},"ja526:33.4":{"pli":"Haṁ tāta kiṁrukkhaphalāni tāni. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:34.1":{"pli":"Jaṭā ca tassa bhusadassaneyyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:34.2":{"pli":"Parosataṁ vellitaggā sugandhā; ","html":"<span class='verse-line'>{}</span>"},"ja526:34.3":{"pli":"Dvedhā siro sādhu vibhattarūpo, ","html":"<span class='verse-line'>{}</span>"},"ja526:34.4":{"pli":"Aho nu kho mayha tathā jaṭāssu. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:35.1":{"pli":"Yadā ca so pakirati tā jaṭāyo, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:35.2":{"pli":"Vaṇṇena gandhena upetarūpā; ","html":"<span class='verse-line'>{}</span>"},"ja526:35.3":{"pli":"Nīluppalaṁ vātasameritaṁva, ","html":"<span class='verse-line'>{}</span>"},"ja526:35.4":{"pli":"Tatheva saṁvāti panassamo ayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:36.1":{"pli":"Paṅko ca tassa bhusadassaneyyo, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:36.2":{"pli":"Netādiso yādiso mayhaṁ kāye; ","html":"<span class='verse-line'>{}</span>"},"ja526:36.3":{"pli":"So vāyatī erito mālutena, ","html":"<span class='verse-line'>{}</span>"},"ja526:36.4":{"pli":"Vanaṁ yathā aggagimhe suphullaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:37.1":{"pli":"Nihanti so rukkhaphalaṁ pathabyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:37.2":{"pli":"Sucittarūpaṁ ruciraṁ dassaneyyaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja526:37.3":{"pli":"Khittañca tassa punareti hatthaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja526:37.4":{"pli":"Haṁ tāta kiṁrukkhaphalaṁ nu kho taṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:38.1":{"pli":"Dantā ca tassa bhusadassaneyyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:38.2":{"pli":"Suddhā samā saṅkhavarūpapannā; ","html":"<span class='verse-line'>{}</span>"},"ja526:38.3":{"pli":"Mano pasādenti vivariyamānā, ","html":"<span class='verse-line'>{}</span>"},"ja526:38.4":{"pli":"Na hi nūna so sākamakhādi tehi. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:39.1":{"pli":"Akakkasaṁ aggaḷitaṁ muhuṁ muduṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:39.2":{"pli":"Ujuṁ anuddhataṁ acapalamassa bhāsitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja526:39.3":{"pli":"Rudaṁ manuññaṁ karavīkasussaraṁ, ","html":"<span class='verse-line'>{}</span>"},"ja526:39.4":{"pli":"Hadayaṅgamaṁ rañjayateva me mano. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:40.1":{"pli":"Bindussaro nātivisaṭṭhavākyo, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:40.2":{"pli":"Na nūna sajjhāyamatippayutto; ","html":"<span class='verse-line'>{}</span>"},"ja526:40.3":{"pli":"Icchāmi bho taṁ punadeva daṭṭhuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja526:40.4":{"pli":"Mitto hi me māṇavohu puratthā. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:41.1":{"pli":"Susandhi sabbattha vimaṭṭhimaṁ vaṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:41.2":{"pli":"Puthū sujātaṁ kharapattasannitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja526:41.3":{"pli":"Teneva maṁ uttariyāna māṇavo, ","html":"<span class='verse-line'>{}</span>"},"ja526:41.4":{"pli":"Vivaritaṁ ūruṁ jaghanena piḷayi. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:42.1":{"pli":"Tapanti ābhanti virocare ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:42.2":{"pli":"Sateratā vijjurivantalikkhe; ","html":"<span class='verse-line'>{}</span>"},"ja526:42.3":{"pli":"Bāhā mudū añjanalomasādisā, ","html":"<span class='verse-line'>{}</span>"},"ja526:42.4":{"pli":"Vicitravaṭṭaṅgulikāssa sobhare. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:43.1":{"pli":"Akakkasaṅgo na ca dīghalomo, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:43.2":{"pli":"Nakhāssa dīghā api lohitaggā; ","html":"<span class='verse-line'>{}</span>"},"ja526:43.3":{"pli":"Mudūhi bāhāhi palissajanto, ","html":"<span class='verse-line'>{}</span>"},"ja526:43.4":{"pli":"Kalyāṇarūpo ramayaṁ upaṭṭhahi. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:44.1":{"pli":"Dumassa tūlūpanibhā pabhassarā, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:44.2":{"pli":"Suvaṇṇakambutalavaṭṭasucchavi; ","html":"<span class='verse-line'>{}</span>"},"ja526:44.3":{"pli":"Hatthā mudū tehi maṁ samphusitvā, ","html":"<span class='verse-line'>{}</span>"},"ja526:44.4":{"pli":"Ito gato tena maṁ dahanti tāta. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:45.1":{"pli":"Na nūna so khārividhaṁ ahāsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:45.2":{"pli":"Na nūna so kaṭṭhāni sayaṁ abhañji; ","html":"<span class='verse-line'>{}</span>"},"ja526:45.3":{"pli":"Na nūna so hanti dume kuṭhāriyā, ","html":"<span class='verse-line'>{}</span>"},"ja526:45.4":{"pli":"Na hissa hatthesu khilāni atthi. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:46.1":{"pli":"Accho ca kho tassa vaṇaṁ akāsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:46.2":{"pli":"So maṁbravi sukhitaṁ maṁ karohi; ","html":"<span class='verse-line'>{}</span>"},"ja526:46.3":{"pli":"Tāhaṁ kariṁ tena mamāsi sokhyaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja526:46.4":{"pli":"So cabravi ‘sukhitosmī’ti brahme. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:47.1":{"pli":"Ayañca te māluvapaṇṇasanthatā, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:47.2":{"pli":"Vikiṇṇarūpāva mayā ca tena ca; ","html":"<span class='verse-line'>{}</span>"},"ja526:47.3":{"pli":"Kilantarūpā udake ramitvā, ","html":"<span class='verse-line'>{}</span>"},"ja526:47.4":{"pli":"Punappunaṁ paṇṇakuṭiṁ vajāma. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:48.1":{"pli":"Na majja mantā paṭibhanti tāta, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:48.2":{"pli":"Na aggihuttaṁ napi yaññatantaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja526:48.3":{"pli":"Na cāpi te mūlaphalāni bhuñje, ","html":"<span class='verse-line'>{}</span>"},"ja526:48.4":{"pli":"Yāva na passāmi taṁ brahmacāriṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:49.1":{"pli":"Addhā pajānāsi tuvampi tāta, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:49.2":{"pli":"Yassaṁ disaṁ vasate brahmacārī; ","html":"<span class='verse-line'>{}</span>"},"ja526:49.3":{"pli":"Taṁ maṁ disaṁ pāpaya tāta khippaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja526:49.4":{"pli":"Mā te ahaṁ amarimassamamhi. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:50.1":{"pli":"Vicitraphullaṁ hi vanaṁ sutaṁ mayā, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:50.2":{"pli":"Dijābhighuṭṭhaṁ dijasaṅghasevitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja526:50.3":{"pli":"Taṁ maṁ vanaṁ pāpaya tāta khippaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja526:50.4":{"pli":"Purā te pāṇaṁ vijahāmi assame”. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:51.1":{"pli":"“Imasmāhaṁ jotirase vanamhi, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:51.2":{"pli":"Gandhabbadevaccharasaṅghasevite; ","html":"<span class='verse-line'>{}</span>"},"ja526:51.3":{"pli":"Isīnamāvāse sanantanamhi, ","html":"<span class='verse-line'>{}</span>"},"ja526:51.4":{"pli":"Netādisaṁ aratiṁ pāpuṇetha. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:52.1":{"pli":"Bhavanti mittāni atho na honti, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:52.2":{"pli":"Ñātīsu mittesu karonti pemaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja526:52.3":{"pli":"Ayañca jammo kissa vā niviṭṭho, ","html":"<span class='verse-line'>{}</span>"},"ja526:52.4":{"pli":"Yo neva jānāti kutomhi āgato. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:53.1":{"pli":"Saṁvāsena hi mittāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:53.2":{"pli":"sandhīyanti punappunaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja526:53.3":{"pli":"Sveva mitto asaṅgantu, ","html":"<span class='verse-line'>{}</span>"},"ja526:53.4":{"pli":"asaṁvāsena jīrati. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:54.1":{"pli":"Sace tuvaṁ dakkhasi brahmacāriṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:54.2":{"pli":"Sace tuvaṁ sallape brahmacārinā; ","html":"<span class='verse-line'>{}</span>"},"ja526:54.3":{"pli":"Sampannasassaṁva mahodakena, ","html":"<span class='verse-line'>{}</span>"},"ja526:54.4":{"pli":"Tapoguṇaṁ khippamimaṁ pahissasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:55.1":{"pli":"Punapi ce dakkhasi brahmacāriṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:55.2":{"pli":"Punapi ce sallape brahmacārinā; ","html":"<span class='verse-line'>{}</span>"},"ja526:55.3":{"pli":"Sampannasassaṁva mahodakena, ","html":"<span class='verse-line'>{}</span>"},"ja526:55.4":{"pli":"Usmāgataṁ khippamimaṁ pahissasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja526:56.1":{"pli":"Bhūtāni hetāni caranti tāta, ","html":"<p><span class='verse-line'>{}</span>"},"ja526:56.2":{"pli":"Virūparūpena manussaloke; ","html":"<span class='verse-line'>{}</span>"},"ja526:56.3":{"pli":"Na tāni sevetha naro sapañño, ","html":"<span class='verse-line'>{}</span>"},"ja526:56.4":{"pli":"Āsajja naṁ nassati brahmacārī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja526:57.1":{"pli":"Niḷinikājātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}