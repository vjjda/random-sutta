{"kv7.5":{"kv7.5:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv7.5'><header><ul><li class='division'>{}</li>"},"kv7.5:0.2":{"pli":"Mahāpaṇṇāsaka ","html":"<li>{}</li>"},"kv7.5:0.3":{"pli":"Sattamavagga ","html":"<li>{}</li></ul>"},"kv7.5:0.4":{"pli":"Paribhogamayapuññakathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv7.5:1.1":{"pli":"Paribhogamayaṁ puññaṁ vaḍḍhatīti? ","html":"<p data-doxy='orthodox'>{}"},"kv7.5:1.2":{"pli":"Āmantā. ","html":"{}"},"kv7.5:1.3":{"pli":"Paribhogamayo phasso vaḍḍhati, vedanā vaḍḍhati, saññā vaḍḍhati, cetanā vaḍḍhati, cittaṁ vaḍḍhati, saddhā vaḍḍhati, vīriyaṁ vaḍḍhati, sati vaḍḍhati, samādhi vaḍḍhati, paññā vaḍḍhatīti? ","html":"{}"},"kv7.5:1.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv7.5:2.1":{"pli":"Paribhogamayaṁ puññaṁ vaḍḍhatīti? ","html":"<p data-doxy='orthodox'>{}"},"kv7.5:2.2":{"pli":"Āmantā. ","html":"{}"},"kv7.5:2.3":{"pli":"Latā viya vaḍḍhati, māluvā viya vaḍḍhati, rukkho viya vaḍḍhati, tiṇaṁ viya vaḍḍhati, muñjapuñjo viya vaḍḍhatīti? ","html":"{}"},"kv7.5:2.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv7.5:3.1":{"pli":"Paribhogamayaṁ puññaṁ vaḍḍhatīti? ","html":"<p data-doxy='orthodox'>{}"},"kv7.5:3.2":{"pli":"Āmantā. ","html":"{}"},"kv7.5:3.3":{"pli":"Dāyako dānaṁ datvā na samannāharati, hoti puññanti? ","html":"{}"},"kv7.5:3.4":{"pli":"Āmantā. ","html":"{}"},"kv7.5:3.5":{"pli":"Anāvaṭṭentassa hoti … ","html":"{}"},"kv7.5:3.6":{"pli":"anābhogassa hoti … ","html":"{}"},"kv7.5:3.7":{"pli":"asamannāharantassa hoti … ","html":"{}"},"kv7.5:3.8":{"pli":"amanasikarontassa hoti … ","html":"{}"},"kv7.5:3.9":{"pli":"acetayantassa hoti … ","html":"{}"},"kv7.5:3.10":{"pli":"apatthayantassa hoti … appaṇidahantassa hotīti? ","html":"{}"},"kv7.5:3.11":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv7.5:3.12":{"pli":"nanu āvaṭṭentassa hoti … ","html":"{}"},"kv7.5:3.13":{"pli":"ābhogassa hoti … ","html":"{}"},"kv7.5:3.14":{"pli":"samannāharantassa hoti … ","html":"{}"},"kv7.5:3.15":{"pli":"manasikarontassa hoti … ","html":"{}"},"kv7.5:3.16":{"pli":"cetayantassa hoti … ","html":"{}"},"kv7.5:3.17":{"pli":"patthayantassa hoti … paṇidahantassa hotīti? ","html":"{}"},"kv7.5:3.18":{"pli":"Āmantā. ","html":"{}"},"kv7.5:3.19":{"pli":"Hañci āvaṭṭentassa hoti … ","html":"{}"},"kv7.5:3.20":{"pli":"ābhogassa hoti … ","html":"{}"},"kv7.5:3.21":{"pli":"samannāharantassa hoti … ","html":"{}"},"kv7.5:3.22":{"pli":"manasikarontassa hoti … ","html":"{}"},"kv7.5:3.23":{"pli":"cetayantassa hoti … ","html":"{}"},"kv7.5:3.24":{"pli":"patthayantassa hoti … paṇidahantassa hoti, no ca vata re vattabbe—","html":"{}"},"kv7.5:3.25":{"pli":"“paribhogamayaṁ puññaṁ vaḍḍhatī”ti. ","html":"{}</p>"},"kv7.5:4.1":{"pli":"Paribhogamayaṁ puññaṁ vaḍḍhatīti? ","html":"<p data-doxy='orthodox'>{}"},"kv7.5:4.2":{"pli":"Āmantā. ","html":"{}"},"kv7.5:4.3":{"pli":"Dāyako dānaṁ datvā kāmavitakkaṁ vitakketi, byāpādavitakkaṁ vitakketi, vihiṁsāvitakkaṁ vitakketi, hoti puññanti? ","html":"{}"},"kv7.5:4.4":{"pli":"Āmantā. ","html":"{}"},"kv7.5:4.5":{"pli":"Dvinnaṁ phassānaṁ …pe… ","html":"{}"},"kv7.5:4.6":{"pli":"dvinnaṁ cittānaṁ samodhānaṁ hotīti? ","html":"{}"},"kv7.5:4.7":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv7.5:4.8":{"pli":"dvinnaṁ phassānaṁ …pe… ","html":"{}"},"kv7.5:4.9":{"pli":"dvinnaṁ cittānaṁ samodhānaṁ hotīti? ","html":"{}"},"kv7.5:4.10":{"pli":"Āmantā. ","html":"{}"},"kv7.5:4.11":{"pli":"Kusalākusalā sāvajjānavajjā hīnapaṇītā kaṇhasukkasappaṭibhāgā dhammā sammukhībhāvaṁ āgacchantīti? ","html":"{}"},"kv7.5:4.12":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv7.5:4.13":{"pli":"kusalākusalā sāvajjānavajjā hīnapaṇītā kaṇhasukkasappaṭibhāgā dhammā sammukhībhāvaṁ āgacchantīti? ","html":"{}"},"kv7.5:4.14":{"pli":"Āmantā. ","html":"{}"},"kv7.5:4.15":{"pli":"Nanu vuttaṁ bhagavatā—","html":"{}"},"kv7.5:4.16":{"pli":"“cattārimāni, bhikkhave, suvidūravidūrāni. ","html":"{}"},"kv7.5:4.17":{"pli":"Katamāni cattāri? ","html":"{}"},"kv7.5:4.18":{"pli":"Nabhañca, bhikkhave, pathavī ca—","html":"{}"},"kv7.5:4.19":{"pli":"idaṁ paṭhamaṁ suvidūravidūraṁ. ","html":"{}"},"kv7.5:4.20":{"pli":"Orimañca, bhikkhave, tīraṁ samuddassa pārimañca tīraṁ—","html":"{}"},"kv7.5:4.21":{"pli":"idaṁ dutiyaṁ suvidūravidūraṁ. ","html":"{}"},"kv7.5:4.22":{"pli":"Yato ca, bhikkhave, verocano abbhudeti yattha ca atthameti—","html":"{}"},"kv7.5:4.23":{"pli":"idaṁ tatiyaṁ suvidūravidūraṁ. ","html":"{}"},"kv7.5:4.24":{"pli":"Satañca, bhikkhave, dhammo asatañca dhammo—","html":"{}"},"kv7.5:4.25":{"pli":"idaṁ catutthaṁ suvidūravidūraṁ. ","html":"{}"},"kv7.5:4.26":{"pli":"Imāni kho, bhikkhave, cattāri suvidūravidūrānīti. ","html":"{}</p>"},"kv7.5:5.1":{"pli":"Nabhañca dūre pathavī ca dūre, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"kv7.5:5.2":{"pli":"Pāraṁ samuddassa tadāhu dūre; ","html":"<span class='verse-line'>{}</span>"},"kv7.5:5.3":{"pli":"Yato ca verocano abbhudeti, ","html":"<span class='verse-line'>{}</span>"},"kv7.5:5.4":{"pli":"Pabhaṅkaro yattha ca atthameti; ","html":"<span class='verse-line'>{}</span>"},"kv7.5:5.5":{"pli":"Tato have dūrataraṁ vadanti, ","html":"<span class='verse-line'>{}</span>"},"kv7.5:5.6":{"pli":"Satañca dhammaṁ asatañca dhammaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"kv7.5:6.1":{"pli":"Abyāyiko hoti sataṁ samāgamo, ","html":"<p><span class='verse-line'>{}</span>"},"kv7.5:6.2":{"pli":"Yāvampi tiṭṭheyya tatheva hoti; ","html":"<span class='verse-line'>{}</span>"},"kv7.5:6.3":{"pli":"Khippañhi veti asataṁ samāgamo, ","html":"<span class='verse-line'>{}</span>"},"kv7.5:6.4":{"pli":"Tasmā sataṁ dhammo asabbhi ārakā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"kv7.5:7.1":{"pli":"Attheva suttantoti? ","html":"<p>{}"},"kv7.5:7.2":{"pli":"Āmantā. ","html":"{}"},"kv7.5:7.3":{"pli":"Tena hi na vattabbaṁ—","html":"{}"},"kv7.5:7.4":{"pli":"“kusalākusalā sāvajjānavajjā hīnapaṇītā kaṇhasukkasappaṭibhāgā dhammā sammukhībhāvaṁ āgacchantī”ti. ","html":"{}</p>"},"kv7.5:8.1":{"pli":"Na vattabbaṁ—","html":"<p data-doxy='heterodox'>{}"},"kv7.5:8.2":{"pli":"“paribhogamayaṁ puññaṁ vaḍḍhatī”ti? ","html":"{}"},"kv7.5:8.3":{"pli":"Āmantā. ","html":"{}"},"kv7.5:8.4":{"pli":"Nanu vuttaṁ bhagavatā—","html":"{}</p>"},"kv7.5:9.1":{"pli":"“Ārāmaropā vanaropā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"kv7.5:9.2":{"pli":"ye janā setukārakā; ","html":"<span class='verse-line'>{}</span>"},"kv7.5:9.3":{"pli":"Papañca udapānañca, ","html":"<span class='verse-line'>{}</span>"},"kv7.5:9.4":{"pli":"ye dadanti upassayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"kv7.5:10.1":{"pli":"Tesaṁ divā ca ratto ca, ","html":"<p><span class='verse-line'>{}</span>"},"kv7.5:10.2":{"pli":"sadā puññaṁ pavaḍḍhati; ","html":"<span class='verse-line'>{}</span>"},"kv7.5:10.3":{"pli":"Dhammaṭṭhā sīlasampannā, ","html":"<span class='verse-line'>{}</span>"},"kv7.5:10.4":{"pli":"te janā saggagāmino”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"kv7.5:11.1":{"pli":"Attheva suttantoti? ","html":"<p>{}"},"kv7.5:11.2":{"pli":"Āmantā. ","html":"{}"},"kv7.5:11.3":{"pli":"Tena hi paribhogamayaṁ puññaṁ vaḍḍhatīti. ","html":"{}</p>"},"kv7.5:12.1":{"pli":"Na vattabbaṁ—","html":"<p data-doxy='heterodox'>{}"},"kv7.5:12.2":{"pli":"“paribhogamayaṁ puññaṁ vaḍḍhatī”ti? ","html":"{}"},"kv7.5:12.3":{"pli":"Āmantā. ","html":"{}"},"kv7.5:12.4":{"pli":"Nanu vuttaṁ bhagavatā—","html":"{}"},"kv7.5:12.5":{"pli":"“cattārome, bhikkhave, puññābhisandā kusalābhisandā sukhassāhārā sovaggikā sukhavipākā saggasaṁvattanikā iṭṭhāya kantāya manāpāya hitāya sukhāya saṁvattanti. ","html":"{}"},"kv7.5:12.6":{"pli":"Katame cattāro? ","html":"{}"},"kv7.5:12.7":{"pli":"Yassa, bhikkhave, bhikkhu cīvaraṁ paribhuñjamāno appamāṇaṁ cetosamādhiṁ upasampajja viharati, appamāṇo tassa puññābhisando kusalābhisando sukhassāhāro sovaggiko sukhavipāko saggasaṁvattaniko iṭṭhāya kantāya manāpāya hitāya sukhāya saṁvattati. ","html":"{}"},"kv7.5:12.8":{"pli":"Yassa, bhikkhave, bhikkhu piṇḍapātaṁ paribhuñjamāno …pe… ","html":"{}"},"kv7.5:12.9":{"pli":"senāsanaṁ paribhuñjamāno …pe… ","html":"{}"},"kv7.5:12.10":{"pli":"gilānapaccayabhesajjaparikkhāraṁ paribhuñjamāno appamāṇaṁ cetosamādhiṁ upasampajja viharati, appamāṇo tassa puññābhisando kusalābhisando sukhassāhāro sovaggiko sukhavipāko saggasaṁvattaniko iṭṭhāya kantāya manāpāya hitāya sukhāya saṁvattati. ","html":"{}"},"kv7.5:12.11":{"pli":"Ime kho, bhikkhave, cattāro puññābhisandā kusalābhisandā sukhassāhārā sovaggikā sukhavipākā saggasaṁvattanikā iṭṭhāya kantāya manāpāya hitāya sukhāya saṁvattantī”ti. ","html":"{}"},"kv7.5:12.12":{"pli":"Attheva suttantoti? ","html":"{}"},"kv7.5:12.13":{"pli":"Āmantā. ","html":"{}"},"kv7.5:12.14":{"pli":"Tena hi paribhogamayaṁ puññaṁ vaḍḍhatīti. ","html":"{}</p>"},"kv7.5:13.1":{"pli":"Paribhogamayaṁ puññaṁ vaḍḍhatīti? ","html":"<p data-doxy='orthodox'>{}"},"kv7.5:13.2":{"pli":"Āmantā. ","html":"{}"},"kv7.5:13.3":{"pli":"Dāyako dānaṁ deti, paṭiggāhako paṭiggahetvā na paribhuñjati chaḍḍeti vissajjeti, hoti puññanti? ","html":"{}"},"kv7.5:13.4":{"pli":"Āmantā. ","html":"{}"},"kv7.5:13.5":{"pli":"Hañci dāyako dānaṁ deti, paṭiggāhako paṭiggahetvā na paribhuñjati chaḍḍeti vissajjeti, hoti puññaṁ; ","html":"{}"},"kv7.5:13.6":{"pli":"no ca vata re vattabbe—","html":"{}"},"kv7.5:13.7":{"pli":"“paribhogamayaṁ puññaṁ vaḍḍhatī”ti. ","html":"{}</p>"},"kv7.5:14.1":{"pli":"Paribhogamayaṁ puññaṁ vaḍḍhatīti? ","html":"<p data-doxy='orthodox'>{}"},"kv7.5:14.2":{"pli":"Āmantā. ","html":"{}"},"kv7.5:14.3":{"pli":"Dāyako dānaṁ deti, paṭiggāhake paṭiggahite rājāno vā haranti, corā vā haranti, aggi vā dahati, udakaṁ vā vahati, appiyā vā dāyādā haranti, hoti puññanti? ","html":"{}"},"kv7.5:14.4":{"pli":"Āmantā. ","html":"{}"},"kv7.5:14.5":{"pli":"Hañci dāyako dānaṁ deti, paṭiggāhake paṭiggahite rājāno vā haranti, corā vā haranti, aggi vā dahati, udakaṁ vā vahati, appiyā vā dāyādā haranti, hoti puññaṁ; ","html":"{}"},"kv7.5:14.6":{"pli":"no ca vata re vattabbe—","html":"{}"},"kv7.5:14.7":{"pli":"“paribhogamayaṁ puññaṁ vaḍḍhatī”ti. ","html":"{}</p>"},"kv7.5:14.8":{"pli":"Paribhogamayapuññakathā niṭṭhitā. ","html":"<p class='endsutta'>{}</p></article>"}},"kv7.6":{"kv7.6:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv7.6'><header><ul><li class='division'>{}</li>"},"kv7.6:0.2":{"pli":"Mahāpaṇṇāsaka ","html":"<li>{}</li>"},"kv7.6:0.3":{"pli":"Sattamavagga ","html":"<li>{}</li></ul>"},"kv7.6:0.4":{"pli":"Itodinnakathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv7.6:1.1":{"pli":"Ito dinnena tattha yāpentīti? ","html":"<p data-doxy='orthodox'>{}"},"kv7.6:1.2":{"pli":"Āmantā. ","html":"{}"},"kv7.6:1.3":{"pli":"Ito cīvaraṁ denti taṁ cīvaraṁ tattha paribhuñjantīti? ","html":"{}"},"kv7.6:1.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv7.6:1.5":{"pli":"ito piṇḍapātaṁ denti, ito senāsanaṁ denti, ito gilānapaccayabhesajjaparikkhāraṁ denti, ito khādanīyaṁ denti, ito bhojanīyaṁ denti, ito pānīyaṁ denti; ","html":"{}"},"kv7.6:1.6":{"pli":"taṁ pānīyaṁ tattha paribhuñjantīti? ","html":"{}"},"kv7.6:1.7":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv7.6:2.1":{"pli":"Ito dinnena tattha yāpentīti? ","html":"<p data-doxy='orthodox'>{}"},"kv7.6:2.2":{"pli":"Āmantā. ","html":"{}"},"kv7.6:2.3":{"pli":"Añño aññassa kārako parakataṁ sukhadukkhaṁ añño karoti, añño paṭisaṁvedetīti? ","html":"{}"},"kv7.6:2.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv7.6:3.1":{"pli":"Na vattabbaṁ—","html":"<p data-doxy='heterodox'>{}"},"kv7.6:3.2":{"pli":"“ito dinnena tattha yāpentī”ti? ","html":"{}"},"kv7.6:3.3":{"pli":"Āmantā. ","html":"{}"},"kv7.6:3.4":{"pli":"Nanu petā attano atthāya dānaṁ dentaṁ anumodenti, cittaṁ pasādenti, pītiṁ uppādenti, somanassaṁ paṭilabhantīti? ","html":"{}"},"kv7.6:3.5":{"pli":"Āmantā. ","html":"{}"},"kv7.6:3.6":{"pli":"Hañci petā attano atthāya dānaṁ dentaṁ anumodenti, cittaṁ pasādenti, pītiṁ uppādenti, somanassaṁ paṭilabhanti; ","html":"{}"},"kv7.6:3.7":{"pli":"tena vata re vattabbe—","html":"{}"},"kv7.6:3.8":{"pli":"“ito dinnena tattha yāpentī”ti. ","html":"{}</p>"},"kv7.6:4.1":{"pli":"Na vattabbaṁ—","html":"<p data-doxy='heterodox'>{}"},"kv7.6:4.2":{"pli":"“ito dinnena tattha yāpentī”ti? ","html":"{}"},"kv7.6:4.3":{"pli":"Āmantā. ","html":"{}"},"kv7.6:4.4":{"pli":"Nanu vuttaṁ bhagavatā—","html":"{}</p>"},"kv7.6:5.1":{"pli":"“Unname udakaṁ vuṭṭhaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"kv7.6:5.2":{"pli":"yathāninnaṁ pavattati; ","html":"<span class='verse-line'>{}</span>"},"kv7.6:5.3":{"pli":"Evameva ito dinnaṁ, ","html":"<span class='verse-line'>{}</span>"},"kv7.6:5.4":{"pli":"petānaṁ upakappati. ","html":"<span class='verse-line'>{}</span></p>"},"kv7.6:6.1":{"pli":"Yathā vārivahā pūrā, ","html":"<p><span class='verse-line'>{}</span>"},"kv7.6:6.2":{"pli":"paripūrenti sāgaraṁ; ","html":"<span class='verse-line'>{}</span>"},"kv7.6:6.3":{"pli":"Evameva ito dinnaṁ, ","html":"<span class='verse-line'>{}</span>"},"kv7.6:6.4":{"pli":"petānaṁ upakappati. ","html":"<span class='verse-line'>{}</span></p>"},"kv7.6:7.1":{"pli":"Na hi tattha kasī atthi, ","html":"<p><span class='verse-line'>{}</span>"},"kv7.6:7.2":{"pli":"gorakkhettha na vijjati; ","html":"<span class='verse-line'>{}</span>"},"kv7.6:7.3":{"pli":"Vaṇijjā tādisī natthi, ","html":"<span class='verse-line'>{}</span>"},"kv7.6:7.4":{"pli":"hiraññena kayākayaṁ; ","html":"<span class='verse-line'>{}</span>"},"kv7.6:7.5":{"pli":"Ito dinnena yāpenti, ","html":"<span class='verse-line'>{}</span>"},"kv7.6:7.6":{"pli":"petā kālaṅkatā tahin”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"kv7.6:8.1":{"pli":"Attheva suttantoti? ","html":"<p>{}"},"kv7.6:8.2":{"pli":"Āmantā. ","html":"{}"},"kv7.6:8.3":{"pli":"Tena hi ito dinnena tattha yāpentīti. ","html":"{}</p>"},"kv7.6:9.1":{"pli":"Na vattabbaṁ—","html":"<p data-doxy='heterodox'>{}"},"kv7.6:9.2":{"pli":"“ito dinnena tattha yāpentī”ti? ","html":"{}"},"kv7.6:9.3":{"pli":"Āmantā. ","html":"{}"},"kv7.6:9.4":{"pli":"Nanu vuttaṁ bhagavatā—","html":"{}"},"kv7.6:9.5":{"pli":"“pañcimāni, bhikkhave, ṭhānāni sampassantā mātāpitaro puttaṁ icchanti kule jāyamānaṁ. ","html":"{}"},"kv7.6:9.6":{"pli":"Katamāni pañca? ","html":"{}"},"kv7.6:9.7":{"pli":"Bhaṭo vā no bharissati, kiccaṁ vā no karissati, kulavaṁso ciraṁ ṭhassati, dāyajjaṁ paṭipajjissati, atha vā pana petānaṁ kālaṅkatānaṁ dakkhiṇaṁ anuppadassati—","html":"{}"},"kv7.6:9.8":{"pli":"imāni kho, bhikkhave, pañca ṭhānāni sampassantā mātāpitaro puttaṁ icchanti kule jāyamānanti. ","html":"{}</p>"},"kv7.6:10.1":{"pli":"Pañca ṭhānāni sampassaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"kv7.6:10.2":{"pli":"puttaṁ icchanti paṇḍitā; ","html":"<span class='verse-line'>{}</span>"},"kv7.6:10.3":{"pli":"Bhaṭo vā no bharissati, ","html":"<span class='verse-line'>{}</span>"},"kv7.6:10.4":{"pli":"kiccaṁ vā no karissati. ","html":"<span class='verse-line'>{}</span></p>"},"kv7.6:11.1":{"pli":"Kulavaṁso ciraṁ tiṭṭhe, ","html":"<p><span class='verse-line'>{}</span>"},"kv7.6:11.2":{"pli":"dāyajjaṁ paṭipajjati; ","html":"<span class='verse-line'>{}</span>"},"kv7.6:11.3":{"pli":"Atha vā pana petānaṁ, ","html":"<span class='verse-line'>{}</span>"},"kv7.6:11.4":{"pli":"dakkhiṇaṁ anuppadassati. ","html":"<span class='verse-line'>{}</span></p>"},"kv7.6:12.1":{"pli":"Ṭhānānetāni sampassaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"kv7.6:12.2":{"pli":"puttaṁ icchanti paṇḍitā; ","html":"<span class='verse-line'>{}</span>"},"kv7.6:12.3":{"pli":"Tasmā santo sappurisā, ","html":"<span class='verse-line'>{}</span>"},"kv7.6:12.4":{"pli":"kataññū katavedino. ","html":"<span class='verse-line'>{}</span></p>"},"kv7.6:13.1":{"pli":"Bharanti mātāpitaro, ","html":"<p><span class='verse-line'>{}</span>"},"kv7.6:13.2":{"pli":"pubbe katamanussaraṁ; ","html":"<span class='verse-line'>{}</span>"},"kv7.6:13.3":{"pli":"Karonti tesaṁ kiccāni, ","html":"<span class='verse-line'>{}</span>"},"kv7.6:13.4":{"pli":"yathā taṁ pubbakārinaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"kv7.6:14.1":{"pli":"Ovādakārī bhaṭaposī, ","html":"<p><span class='verse-line'>{}</span>"},"kv7.6:14.2":{"pli":"kulavaṁsaṁ ahāpayaṁ; ","html":"<span class='verse-line'>{}</span>"},"kv7.6:14.3":{"pli":"Saddho sīlena sampanno, ","html":"<span class='verse-line'>{}</span>"},"kv7.6:14.4":{"pli":"putto hoti pasaṁsiyo”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"kv7.6:15.1":{"pli":"Attheva suttantoti? ","html":"<p>{}"},"kv7.6:15.2":{"pli":"Āmantā. ","html":"{}"},"kv7.6:15.3":{"pli":"Tena hi ito dinnena tattha yāpentīti. ","html":"{}</p>"},"kv7.6:15.4":{"pli":"Ito dinnakathā niṭṭhitā. ","html":"<p class='endsutta'>{}</p></article>"}},"kv7.7":{"kv7.7:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv7.7'><header><ul><li class='division'>{}</li>"},"kv7.7:0.2":{"pli":"Mahāpaṇṇāsaka ","html":"<li>{}</li>"},"kv7.7:0.3":{"pli":"Sattamavagga ","html":"<li>{}</li></ul>"},"kv7.7:0.4":{"pli":"Pathavīkammavipākotikathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv7.7:1.1":{"pli":"Pathavī kammavipākoti? ","html":"<p data-doxy='orthodox'>{}"},"kv7.7:1.2":{"pli":"Āmantā. ","html":"{}"},"kv7.7:1.3":{"pli":"Sukhavedaniyā dukkhavedaniyā adukkhamasukhavedaniyā, sukhāya vedanāya sampayuttā, dukkhāya vedanāya sampayuttā, adukkhamasukhāya vedanāya sampayuttā, phassena sampayuttā, vedanāya sampayuttā, saññāya sampayuttā, cetanāya sampayuttā, cittena sampayuttā, sārammaṇā; ","html":"{}"},"kv7.7:1.4":{"pli":"atthi tāya āvaṭṭanā ābhogo samannāhāro manasikāro cetanā patthanā paṇidhīti? ","html":"{}"},"kv7.7:1.5":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv7.7:1.6":{"pli":"nanu na sukhavedaniyā na dukkhavedaniyā na adukkhamasukhavedaniyā, na sukhāya vedanāya sampayuttā, na dukkhāya vedanāya sampayuttā, na adukkhamasukhāya vedanāya sampayuttā, na phassena sampayuttā, na vedanāya sampayuttā, na saññāya sampayuttā, na cetanāya sampayuttā, na cittena sampayuttā, anārammaṇā; ","html":"{}"},"kv7.7:1.7":{"pli":"natthi tāya āvaṭṭanā ābhogo samannāhāro manasikāro cetanā patthanā paṇidhīti? ","html":"{}"},"kv7.7:1.8":{"pli":"Āmantā. ","html":"{}"},"kv7.7:1.9":{"pli":"Hañci na sukhavedaniyā na dukkhavedaniyā …pe… ","html":"{}"},"kv7.7:1.10":{"pli":"anārammaṇā; ","html":"{}"},"kv7.7:1.11":{"pli":"natthi tāya āvaṭṭanā …pe… paṇidhi, no ca vata re vattabbe—","html":"{}"},"kv7.7:1.12":{"pli":"“pathavī kammavipāko”ti. ","html":"{}</p>"},"kv7.7:2.1":{"pli":"Phasso kammavipāko, phasso sukhavedaniyo dukkhavedaniyo adukkhamasukhavedaniyo sukhāya vedanāya sampayutto dukkhāya …pe… adukkhamasukhāya vedanāya sampayutto phassena sampayutto vedanāya sampayutto saññāya sampayutto cetanāya sampayutto cittena sampayutto sārammaṇo; ","html":"<p data-doxy='orthodox'>{}"},"kv7.7:2.2":{"pli":"atthi tassa āvaṭṭanā …pe… paṇidhīti? ","html":"{}"},"kv7.7:2.3":{"pli":"Āmantā. ","html":"{}"},"kv7.7:2.4":{"pli":"Pathavī kammavipāko, pathavī sukhavedaniyā dukkhavedaniyā adukkhamasukhavedaniyā sukhāya vedanāya sampayuttā dukkhāya …pe… adukkhamasukhāya vedanāya sampayuttā phassena sampayuttā vedanāya sampayuttā saññāya sampayuttā cetanāya sampayuttā cittena sampayuttā sārammaṇā; ","html":"{}"},"kv7.7:2.5":{"pli":"atthi tāya āvaṭṭanā ābhogo samannāhāro manasikāro cetanā patthanā paṇidhīti? ","html":"{}"},"kv7.7:2.6":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv7.7:2.7":{"pli":"pathavī kammavipāko, pathavī na sukhavedaniyā na dukkhavedaniyā …pe… anārammaṇā; ","html":"{}"},"kv7.7:2.8":{"pli":"natthi tāya āvaṭṭanā …pe… paṇidhīti? ","html":"{}"},"kv7.7:2.9":{"pli":"Āmantā. ","html":"{}"},"kv7.7:2.10":{"pli":"Phasso kammavipāko, phasso na sukhavedaniyo na dukkhavedaniyo …pe… anārammaṇo; ","html":"{}"},"kv7.7:2.11":{"pli":"natthi tassa āvaṭṭanā …pe… paṇidhīti? ","html":"{}"},"kv7.7:2.12":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv7.7:3.1":{"pli":"Pathavī kammavipākoti? ","html":"<p data-doxy='orthodox'>{}"},"kv7.7:3.2":{"pli":"Āmantā. ","html":"{}"},"kv7.7:3.3":{"pli":"Pathavī paggahaniggahupagā chedanabhedanupagāti? ","html":"{}"},"kv7.7:3.4":{"pli":"Āmantā. ","html":"{}"},"kv7.7:3.5":{"pli":"Kammavipāko paggahaniggahupago chedanabhedanupagoti? ","html":"{}"},"kv7.7:3.6":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv7.7:4.1":{"pli":"Labbhā pathavī ketuṁ vikketuṁ āṭhapetuṁ ocinituṁ vicinitunti? ","html":"<p data-doxy='orthodox'>{}"},"kv7.7:4.2":{"pli":"Āmantā. ","html":"{}"},"kv7.7:4.3":{"pli":"Labbhā kammavipāko ketuṁ vikketuṁ āṭhapetuṁ ocinituṁ vicinitunti? ","html":"{}"},"kv7.7:4.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv7.7:5.1":{"pli":"Pathavī paresaṁ sādhāraṇāti? ","html":"<p data-doxy='orthodox'>{}"},"kv7.7:5.2":{"pli":"Āmantā. ","html":"{}"},"kv7.7:5.3":{"pli":"Kammavipāko paresaṁ sādhāraṇoti? ","html":"{}"},"kv7.7:5.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv7.7:6.1":{"pli":"Kammavipāko paresaṁ sādhāraṇoti? ","html":"<p>{}"},"kv7.7:6.2":{"pli":"Āmantā. ","html":"{}"},"kv7.7:6.3":{"pli":"Nanu vuttaṁ bhagavatā—","html":"{}</p>"},"kv7.7:7.1":{"pli":"“Asādhāraṇamaññesaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"kv7.7:7.2":{"pli":"acoraharaṇo nidhi; ","html":"<span class='verse-line'>{}</span>"},"kv7.7:7.3":{"pli":"Kayirātha macco puññāni, ","html":"<span class='verse-line'>{}</span>"},"kv7.7:7.4":{"pli":"sace sucaritaṁ care”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"kv7.7:8.1":{"pli":"Attheva suttantoti? ","html":"<p>{}"},"kv7.7:8.2":{"pli":"Āmantā. ","html":"{}"},"kv7.7:8.3":{"pli":"Tena hi na vattabbaṁ—","html":"{}"},"kv7.7:8.4":{"pli":"“kammavipāko paresaṁ sādhāraṇo”ti. ","html":"{}</p>"},"kv7.7:9.1":{"pli":"Pathavī kammavipākoti? ","html":"<p data-doxy='orthodox'>{}"},"kv7.7:9.2":{"pli":"Āmantā. ","html":"{}"},"kv7.7:9.3":{"pli":"Paṭhamaṁ pathavī saṇṭhāti, pacchā sattā uppajjantīti? ","html":"{}"},"kv7.7:9.4":{"pli":"Āmantā. ","html":"{}"},"kv7.7:9.5":{"pli":"Paṭhamaṁ vipāko uppajjati, pacchā vipākapaṭilābhāya kammaṁ karontīti? ","html":"{}"},"kv7.7:9.6":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv7.7:10.1":{"pli":"Pathavī sabbasattānaṁ kammavipākoti? ","html":"<p data-doxy='orthodox'>{}"},"kv7.7:10.2":{"pli":"Āmantā. ","html":"{}"},"kv7.7:10.3":{"pli":"Sabbe sattā pathaviṁ paribhuñjantīti? ","html":"{}"},"kv7.7:10.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv7.7:10.5":{"pli":"sabbe sattā pathaviṁ paribhuñjantīti? ","html":"{}"},"kv7.7:10.6":{"pli":"Āmantā. ","html":"{}"},"kv7.7:10.7":{"pli":"Atthi keci pathaviṁ aparibhuñjitvā parinibbāyantīti? ","html":"{}"},"kv7.7:10.8":{"pli":"Āmantā. ","html":"{}"},"kv7.7:10.9":{"pli":"Atthi keci kammavipākaṁ akhepetvā parinibbāyantīti? ","html":"{}"},"kv7.7:10.10":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv7.7:11.1":{"pli":"Pathavī cakkavattisattassa kammavipākoti? ","html":"<p data-doxy='orthodox'>{}"},"kv7.7:11.2":{"pli":"Āmantā. ","html":"{}"},"kv7.7:11.3":{"pli":"Aññe sattā pathaviṁ paribhuñjantīti? ","html":"{}"},"kv7.7:11.4":{"pli":"Āmantā. ","html":"{}"},"kv7.7:11.5":{"pli":"Cakkavattisattassa kammavipākaṁ aññe sattā paribhuñjantīti? ","html":"{}"},"kv7.7:11.6":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv7.7:11.7":{"pli":"cakkavattisattassa kammavipākaṁ aññe sattā paribhuñjantīti? ","html":"{}"},"kv7.7:11.8":{"pli":"Āmantā. ","html":"{}"},"kv7.7:11.9":{"pli":"Cakkavattisattassa phassaṁ vedanaṁ saññaṁ cetanaṁ cittaṁ saddhaṁ vīriyaṁ satiṁ samādhiṁ paññaṁ aññe sattā paribhuñjantīti? ","html":"{}"},"kv7.7:11.10":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv7.7:12.1":{"pli":"Na vattabbaṁ—","html":"<p data-doxy='heterodox'>{}"},"kv7.7:12.2":{"pli":"“pathavī kammavipāko”ti? ","html":"{}"},"kv7.7:12.3":{"pli":"Āmantā. ","html":"{}"},"kv7.7:12.4":{"pli":"Nanu atthi issariyasaṁvattaniyaṁ kammaṁ adhipaccasaṁvattaniyaṁ kammanti? ","html":"{}"},"kv7.7:12.5":{"pli":"Āmantā. ","html":"{}"},"kv7.7:12.6":{"pli":"Hañci atthi issariyasaṁvattaniyaṁ kammaṁ adhipaccasaṁvattaniyaṁ kammaṁ, tena vata re vattabbe—","html":"{}"},"kv7.7:12.7":{"pli":"“pathavī kammavipāko”ti. ","html":"{}</p>"},"kv7.7:12.8":{"pli