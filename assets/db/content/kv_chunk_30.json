.8":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv7.8:3.1":{"pli":"Jarāmaraṇaṁ vipāko, jarāmaraṇaṁ na sukhavedaniyaṁ na dukkhavedaniyaṁ …pe… anārammaṇaṁ; ","html":"<p data-doxy='orthodox'>{}"},"kv7.8:3.2":{"pli":"natthi tassa āvaṭṭanā …pe… paṇidhīti? ","html":"{}"},"kv7.8:3.3":{"pli":"Āmantā. ","html":"{}"},"kv7.8:3.4":{"pli":"Phasso vipāko, phasso na sukhavedaniyo na dukkhavedaniyo …pe… anārammaṇo; ","html":"{}"},"kv7.8:3.5":{"pli":"natthi tassa āvaṭṭanā …pe… paṇidhīti? ","html":"{}"},"kv7.8:3.6":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv7.8:4.1":{"pli":"Akusalānaṁ dhammānaṁ jarāmaraṇaṁ, akusalānaṁ dhammānaṁ vipākoti? ","html":"<p data-doxy='orthodox'>{}"},"kv7.8:4.2":{"pli":"Āmantā. ","html":"{}"},"kv7.8:4.3":{"pli":"Kusalānaṁ dhammānaṁ jarāmaraṇaṁ, kusalānaṁ dhammānaṁ vipākoti? ","html":"{}"},"kv7.8:4.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv7.8:5.1":{"pli":"Kusalānaṁ dhammānaṁ jarāmaraṇaṁ, na vattabbaṁ—","html":"<p data-doxy='orthodox'>{}"},"kv7.8:5.2":{"pli":"“kusalānaṁ dhammānaṁ vipāko”ti? ","html":"{}"},"kv7.8:5.3":{"pli":"Āmantā. ","html":"{}"},"kv7.8:5.4":{"pli":"Akusalānaṁ dhammānaṁ jarāmaraṇaṁ, na vattabbaṁ—","html":"{}"},"kv7.8:5.5":{"pli":"“akusalānaṁ dhammānaṁ vipāko”ti? ","html":"{}"},"kv7.8:5.6":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv7.8:6.1":{"pli":"Kusalānaṁ dhammānaṁ jarāmaraṇaṁ, akusalānaṁ dhammānaṁ vipākoti? ","html":"<p data-doxy='orthodox'>{}"},"kv7.8:6.2":{"pli":"Āmantā. ","html":"{}"},"kv7.8:6.3":{"pli":"Akusalānaṁ dhammānaṁ jarāmaraṇaṁ, kusalānaṁ dhammānaṁ vipākoti? ","html":"{}"},"kv7.8:6.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv7.8:7.1":{"pli":"Akusalānaṁ dhammānaṁ jarāmaraṇaṁ, na vattabbaṁ—","html":"<p data-doxy='orthodox'>{}"},"kv7.8:7.2":{"pli":"“kusalānaṁ dhammānaṁ vipāko”ti? ","html":"{}"},"kv7.8:7.3":{"pli":"Āmantā. ","html":"{}"},"kv7.8:7.4":{"pli":"Kusalānaṁ dhammānaṁ jarāmaraṇaṁ, na vattabbaṁ—","html":"{}"},"kv7.8:7.5":{"pli":"“akusalānaṁ dhammānaṁ vipāko”ti? ","h