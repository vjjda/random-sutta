{"sn14.16":{"sn14.16:0.1":{"pli":"Saṁyutta Nikāya 14.16 ","eng":"Linked Discourses 14.16 ","html":"<article id='sn14.16'><header><ul><li class='division'>{}</li>"},"sn14.16:0.2":{"pli":"2. Dutiyavagga ","eng":"Chapter Two ","html":"<li>{}</li></ul>"},"sn14.16:0.3":{"pli":"Sagāthāsutta ","eng":"With Verses ","html":"<h1 class='sutta-title'>{}</h1></header>"},"sn14.16:1.1":{"pli":"Sāvatthiyaṁ viharati. ","eng":"At Sāvatthī. ","html":"<p>{}</p>"},"sn14.16:1.2":{"pli":"“Dhātusova, bhikkhave, sattā saṁsandanti samenti. ","eng":"“Mendicants, sentient beings join together and converge because of an element. ","html":"<p>{}"},"sn14.16:1.3":{"pli":"Hīnādhimuttikā hīnādhimuttikehi saddhiṁ saṁsandanti samenti. ","eng":"Those who have inferior convictions join together and converge with those who have inferior convictions. ","html":"{}"},"sn14.16:1.4":{"pli":"Atītampi kho, bhikkhave, addhānaṁ dhātusova sattā saṁsandiṁsu samiṁsu. ","eng":"In the past … ","html":"{}"},"sn14.16:1.5":{"pli":"Hīnādhimuttikā hīnādhimuttikehi saddhiṁ saṁsandiṁsu samiṁsu. ","html":"{}</p>"},"sn14.16:2.1":{"pli":"Anāgatampi kho, bhikkhave, addhānaṁ dhātusova sattā saṁsandissanti samessanti. ","eng":"In the future … ","html":"<p>{}"},"sn14.16:2.2":{"pli":"Hīnādhimuttikā hīnādhimuttikehi saddhiṁ saṁsandissanti samessanti. ","html":"{}</p>"},"sn14.16:3.1":{"pli":"Etarahipi kho, bhikkhave, paccuppannaṁ addhānaṁ dhātusova sattā saṁsandanti samenti. ","eng":"At present, too, sentient beings join together and converge because of an element. ","html":"<p>{}"},"sn14.16:3.2":{"pli":"Hīnādhimuttikā hīnādhimuttikehi saddhiṁ saṁsandanti samenti. ","eng":"Those who have inferior convictions join together and converge with those who have inferior convictions. ","html":"{}</p>"},"sn14.16:4.1":{"pli":"Seyyathāpi, bhikkhave, gūtho gūthena saṁsandati sameti; ","eng":"It’s like how dung joins together with dung, ","html":"<p>{}"},"sn14.16:4.2":{"pli":"muttaṁ muttena saṁsandati sameti; ","eng":"urine with urine, ","html":"{}"},"sn14.16:4.3":{"pli":"kheḷo kheḷena saṁsandati sameti; ","eng":"spit with spit, ","html":"{}"},"sn14.16:4.4":{"pli":"pubbo pubbena saṁsandati sameti; ","eng":"pus with pus, ","html":"{}"},"sn14.16:4.5":{"pli":"lohitaṁ lohitena saṁsandati sameti; ","eng":"and blood with blood. ","html":"{}"},"sn14.16:4.6":{"pli":"evameva kho, bhikkhave, dhātusova sattā saṁsandanti samenti. ","eng":"In the same way, sentient beings join together and converge because of an element. ","html":"{}"},"sn14.16:4.7":{"pli":"Hīnādhimuttikā hīnādhimuttikehi saddhiṁ saṁsandanti samenti. ","eng":"Those who have inferior convictions join together and converge with those who have inferior convictions. ","html":"{}"},"sn14.16:4.8":{"pli":"Atītampi kho addhānaṁ …pe… ","eng":"In the past … ","html":"{}"},"sn14.16:4.9":{"pli":"anāgatampi kho addhānaṁ …pe… ","eng":"In the future … ","html":"{}"},"sn14.16:4.10":{"pli":"etarahipi kho paccuppannaṁ addhānaṁ dhātusova sattā saṁsandanti samenti. ","eng":"At present, too, sentient beings join together and converge because of an element. ","html":"{}"},"sn14.16:4.11":{"pli":"Hīnādhimuttikā hīnādhimuttikehi saddhiṁ saṁsandanti samenti. ","eng":"Those who have inferior convictions join together and converge with those who have inferior convictions. ","html":"{}</p>"},"sn14.16:5.1":{"pli":"Dhātusova, bhikkhave, sattā saṁsandanti samenti. ","eng":"Sentient beings join together and converge because of an element. ","html":"<p>{}"},"sn14.16:5.2":{"pli":"Kalyāṇādhimuttikā kalyāṇādhimuttikehi saddhiṁ saṁsandanti samenti. ","eng":"Those who have good convictions join together and converge with those who have good convictions. ","html":"{}"},"sn14.16:5.3":{"pli":"Atītampi kho, bhikkhave, addhānaṁ dhātusova sattā saṁsandiṁsu samiṁsu. ","eng":"In the past … ","html":"{}"},"sn14.16:5.4":{"pli":"Kalyāṇādhimuttikā kalyāṇādhimuttikehi saddhiṁ saṁsandiṁsu samiṁsu. ","html":"{}</p>"},"sn14.16:6.1":{"pli":"Anāgatampi kho, bhikkhave, addhānaṁ …pe… ","eng":"In the future … ","html":"<p>{}"},"sn14.16:6.2":{"pli":"etarahipi kho, bhikkhave, paccuppannaṁ addhānaṁ dhātusova sattā saṁsandanti samenti. ","eng":"At present, too, sentient beings join together and converge because of an element. ","html":"{}"},"sn14.16:6.3":{"pli":"Kalyāṇādhimuttikā kalyāṇādhimuttikehi saddhiṁ saṁsandanti samenti. ","eng":"Those who have good convictions join together and converge with those who have good convictions. ","html":"{}</p>"},"sn14.16:7.1":{"pli":"Seyyathāpi, bhikkhave, khīraṁ khīrena saṁsandati sameti; ","eng":"It’s like how milk joins together with milk, ","html":"<p>{}"},"sn14.16:7.2":{"pli":"telaṁ telena saṁsandati sameti; ","eng":"oil with oil, ","html":"{}"},"sn14.16:7.3":{"pli":"sappi sappinā saṁsandati sameti; ","eng":"ghee with ghee, ","html":"{}"},"sn14.16:7.4":{"pli":"madhu madhunā saṁsandati sameti; ","eng":"honey with honey, ","html":"{}"},"sn14.16:7.5":{"pli":"phāṇitaṁ phāṇitena saṁsandati sameti; ","eng":"and molasses with molasses. ","html":"{}"},"sn14.16:7.6":{"pli":"evameva kho, bhikkhave, dhātusova sattā saṁsandanti samenti. ","eng":"In the same way, sentient beings join together and converge because of an element. ","html":"{}"},"sn14.16:7.7":{"pli":"Kalyāṇādhimuttikā kalyāṇādhimuttikehi saddhiṁ saṁsandanti samenti. ","eng":"Those who have good convictions join together and converge with those who have good convictions. ","html":"{}"},"sn14.16:7.8":{"pli":"Atītampi kho addhānaṁ … ","eng":"In the past … ","html":"{}"},"sn14.16:7.9":{"pli":"anāgatampi kho addhānaṁ … ","eng":"In the future … ","html":"{}"},"sn14.16:7.10":{"pli":"etarahipi kho paccuppannaṁ addhānaṁ dhātusova sattā saṁsandanti samenti. ","eng":"At present, too, sentient beings join together and converge because of an element. ","html":"{}"},"sn14.16:7.11":{"pli":"Kalyāṇādhimuttikā kalyāṇādhimuttikehi saddhiṁ saṁsandanti samentī”ti. ","eng":"Those who have good convictions join together and converge with those who have good convictions.” ","html":"{}</p>"},"sn14.16:8.1":{"pli":"Idamavoca bhagavā. ","eng":"That is what the Buddha said. ","html":"<p>{}"},"sn14.16:8.2":{"pli":"Idaṁ vatvāna sugato athāparaṁ etadavoca satthā: ","eng":"Then the Holy One, the Teacher, went on to say: ","html":"{}</p>"},"sn14.16:9.1":{"pli":"“Saṁsaggā vanatho jāto, ","eng":"“Socializing creates a snarl; ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>","comm":"These verses appear in a similar context at <a href='index.html?q=iti78#6.1'>Iti 78:6.1</a>. "},"sn14.16:9.2":{"pli":"asaṁsaggena chijjati; ","eng":"they’re cut off by being aloof. ","html":"<span class='verse-line'>{}</span>"},"sn14.16:9.3":{"pli":"Parittaṁ dārumāruyha, ","eng":"If you’re lost in the middle of a great sea, ","html":"<span class='verse-line'>{}</span>"},"sn14.16:9.4":{"pli":"yathā sīde mahaṇṇave. ","eng":"and you clamber up on a little log, you’ll sink. ","html":"<span class='verse-line'>{}</span></p>"},"sn14.16:10.1":{"pli":"Evaṁ kusītamāgamma, ","eng":"So too, a person who lives well ","html":"<p><span class='verse-line'>{}</span>"},"sn14.16:10.2":{"pli":"sādhujīvipi sīdati; ","eng":"sinks by relying on a lazy person. ","html":"<span class='verse-line'>{}</span>"},"sn14.16:10.3":{"pli":"Tasmā taṁ parivajjeyya, ","eng":"Hence you should avoid such ","html":"<span class='verse-line'>{}</span>"},"sn14.16:10.4":{"pli":"kusītaṁ hīnavīriyaṁ. ","eng":"a lazy person who lacks energy. ","html":"<span class='verse-line'>{}</span></p>"},"sn14.16:11.1":{"pli":"Pavivittehi ariyehi, ","eng":"Dwell with the noble ones ","html":"<p><span class='verse-line'>{}</span>"},"sn14.16:11.2":{"pli":"pahitattehi jhāyīhi; ","eng":"who are secluded and determined ","html":"<span class='verse-line'>{}</span>"},"sn14.16:11.3":{"pli":"Niccaṁ āraddhavīriyehi, ","eng":"and always energetic; ","html":"<span class='verse-line'>{}</span>"},"sn14.16:11.4":{"pli":"paṇḍitehi sahāvase”ti. ","eng":"the astute who practice absorption.” ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"sn14.16:11.5":{"pli":"Chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"sn14.17":{"sn14.17:0.1":{"pli":"Saṁyutta Nikāya 14.17 ","eng":"Linked Discourses 14.17 ","html":"<article id='sn14.17'><header><ul><li class='division'>{}</li>"},"sn14.17:0.2":{"pli":"2. Dutiyavagga ","eng":"Chapter Two ","html":"<li>{}</li></ul>"},"sn14.17:0.3":{"pli":"Assaddhasaṁsandanasutta ","eng":"Faithless ","html":"<h1 class='sutta-title'>{}</h1></header>"},"sn14.17:1.1":{"pli":"Sāvatthiyaṁ viharati. ","eng":"At Sāvatthī. ","html":"<p>{}</p>"},"sn14.17:1.2":{"pli":"“Dhātusova, bhikkhave, sattā saṁsandanti samenti. ","eng":"“Mendicants, sentient beings join together and converge because of an element: ","html":"<p>{}"},"sn14.17:1.3":{"pli":"Assaddhā assaddhehi saddhiṁ saṁsandanti samenti; ","eng":"the faithless with the faithless, ","html":"{}"},"sn14.17:1.4":{"pli":"ahirikā ahirikehi saddhiṁ saṁsandanti samenti; ","eng":"the unconscientious with the unconscientious, ","html":"{}"},"sn14.17:1.5":{"pli":"anottappino anottappīhi saddhiṁ saṁsandanti samenti; ","eng":"the imprudent with the imprudent, ","html":"{}"},"sn14.17:1.6":{"pli":"appassutā appassutehi saddhiṁ saṁsandanti samenti; ","eng":"the unlearned with the unlearned, ","html":"{}"},"sn14.17:1.7":{"pli":"kusītā kusītehi saddhiṁ saṁsandanti samenti; ","eng":"the lazy with the lazy, ","html":"{}"},"sn14.17:1.8":{"pli":"muṭṭhassatino muṭṭhassatīhi saddhiṁ saṁsandanti samenti; ","eng":"the unmindful with the unmindful, ","html":"{}"},"sn14.17:1.9":{"pli":"duppaññā duppaññehi saddhiṁ saṁsandanti samenti. ","eng":"and the witless with the witless. ","html":"{}</p>"},"sn14.17:2.1":{"pli":"Atītampi kho, bhikkhave, addhānaṁ dhātusova sattā saṁsandiṁsu samiṁsu. ","eng":"In the past, too, sentient beings came together and converged because of an element. … ","html":"<p>{}"},"sn14.17:2.2":{"pli":"Assaddhā assaddhehi saddhiṁ saṁsandiṁsu samiṁsu; ","html":"{}"},"sn14.17:2.3":{"pli":"ahirikā ahirikehi saddhiṁ saṁsandiṁsu samiṁsu; ","html":"{}"},"sn14.17:2.4":{"pli":"anottappino anottappīhi saddhiṁ saṁsandiṁsu samiṁsu; ","html":"{}"},"sn14.17:2.5":{"pli":"appassutā appassutehi saddhiṁ saṁsandiṁsu samiṁsu; ","html":"{}"},"sn14.17:2.6":{"pli":"kusītā kusītehi saddhiṁ saṁsandiṁsu samiṁsu; ","html":"{}"},"sn14.17:2.7":{"pli":"muṭṭhassatino muṭṭhassatīhi saddhiṁ saṁsandiṁsu samiṁsu; ","html":"{}"},"sn14.17:2.8":{"pli":"duppaññā duppaññehi saddhiṁ saṁsandiṁsu samiṁsu. ","html":"{}</p>"},"sn14.17:3.1":{"pli":"Anāgatampi kho, bhikkhave, addhānaṁ dhātusova sattā saṁsandissanti samessanti. ","eng":"In the future, too, sentient beings will join together and converge because of an element. … ","html":"<p>{}"},"sn14.17:3.2":{"pli":"Assaddhā assaddhehi saddhiṁ saṁsandissanti samessanti; ","html":"{}"},"sn14.17:3.3":{"pli":"ahirikā ahirikehi saddhiṁ saṁsandissanti samessanti; ","html":"{}"},"sn14.17:3.4":{"pli":"anottappino anottappīhi saddhiṁ …pe… ","html":"{}"},"sn14.17:3.5":{"pli":"appassutā appassutehi saddhiṁ …pe… ","html":"{}"},"sn14.17:3.6":{"pli":"kusītā kusītehi saddhiṁ …pe… ","html":"{}"},"sn14.17:3.7":{"pli":"muṭṭhassatino muṭṭhassatīhi saddhiṁ …pe… ","html":"{}"},"sn14.17:3.8":{"pli":"duppaññā duppaññehi saddhiṁ saṁsandissanti samessanti. ","html":"{}</p>"},"sn14.17:4.1":{"pli":"Etarahipi kho, bhikkhave, paccuppannaṁ addhānaṁ dhātusova sattā saṁsandanti samenti. ","eng":"At present, too, sentient beings join together and converge because of an element. … ","html":"<p>{}"},"sn14.17:4.2":{"pli":"Assaddhā assaddhehi saddhiṁ saṁsandanti samenti; ","html":"{}"},"sn14.17:4.3":{"pli":"ahirikā ahirikehi saddhiṁ …pe… ","html":"{}"},"sn14.17:4.4":{"pli":"anottappino anottappīhi saddhiṁ …pe… ","html":"{}"},"sn14.17:4.5":{"pli":"appassutā appassutehi saddhiṁ …pe… ","html":"{}"},"sn14.17:4.6":{"pli":"kusītā kusītehi saddhiṁ …pe… ","html":"{}"},"sn14.17:4.7":{"pli":"muṭṭhassatino muṭṭhassatīhi saddhiṁ saṁsandanti samenti; ","html":"{}"},"sn14.17:4.8":{"pli":"duppaññā duppaññehi saddhiṁ saṁsandanti samenti. ","html":"{}</p>"},"sn14.17:5.1":{"pli":"Dhātusova, bhikkhave, sattā saṁsandanti samenti. ","eng":"Sentient beings join together and converge because of an element: ","html":"<p>{}"},"sn14.17:5.2":{"pli":"Saddhā saddhehi saddhiṁ saṁsandanti samenti; ","eng":"the faithful with the faithful, ","html":"{}"},"sn14.17:5.3":{"pli":"hirimanā hirimanehi saddhiṁ saṁsandanti samenti; ","eng":"the conscientious with the conscientious, ","html":"{}"},"sn14.17:5.4":{"pli":"ottappino ottappīhi saddhiṁ saṁsandanti samenti; ","eng":"the prudent with the prudent, ","html":"{}"},"sn14.17:5.5":{"pli":"bahussutā bahussutehi saddhiṁ saṁsandanti samenti; ","eng":"the learned with the learned, ","html":"{}"},"sn14.17:5.6":{"pli":"āraddhavīriyā āraddhavīriyehi saddhiṁ saṁsandanti samenti; ","eng":"the energetic with the energetic, ","html":"{}"},"sn14.17:5.7":{"pli":"upaṭṭhitassatino upaṭṭhitassatīhi saddhiṁ saṁsandanti samenti; ","eng":"the mindful with the mindful, ","html":"{}"},"sn14.17:5.8":{"pli":"paññavanto paññavantehi saddhiṁ saṁsandanti samenti. ","eng":"and the wise with the wise. ","html":"{}"},"sn14.17:5.9":{"pli":"Atītampi kho, bhikkhave, addhānaṁ …pe… ","eng":"In the past … ","html":"{}"},"sn14.17:5.10":{"pli":"anāgatampi kho, bhikkhave …pe… ","eng":"In the future … ","html":"{}"},"sn14.17:5.11":{"pli":"etarahipi kho, bhikkhave, paccuppannaṁ addhānaṁ dhātusova sattā saṁsandanti samenti. ","eng":"At present, too, sentient beings join together and converge because of an element. …” ","html":"{}"},"sn14.17:5.12":{"pli":"Saddhā saddhehi saddhiṁ …pe… ","html":"{}"},"sn14.17:5.13":{"pli":"paññavanto paññavantehi saddhiṁ saṁsandanti samentī”ti. ","html":"{}</p>"},"sn14.17:5.14":{"pli":"Sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"sn14.18":{"sn14.18:0.1":{"pli":"Saṁyutta Nikāya 14.18 ","eng":"Linked Discourses 14.18 ","html":"<article id='sn14.18'><header><ul><li class='division'>{}</li>"},"sn14.18:0.2":{"pli":"2. Dutiyavagga ","eng":"Chapter Two ","html":"<li>{}</li></ul>"