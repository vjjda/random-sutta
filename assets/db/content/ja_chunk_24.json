{"ja493":{"ja493:0.1":{"pli":"Jātaka ","html":"<article id='ja493'><header><ul><li class='division'>{}</li>"},"ja493:0.2":{"pli":"Pakiṇṇakanipāta ","html":"<li>{}</li>"},"ja493:0.3":{"pli":"Sālikedāravagga ","html":"<li>{}</li></ul>"},"ja493:0.4":{"pli":"10. Mahāvāṇijajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja493:1.1":{"pli":"Vāṇijā samitiṁ katvā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja493:1.2":{"pli":"nānāraṭṭhato āgatā; ","html":"<span class='verse-line'>{}</span>"},"ja493:1.3":{"pli":"Dhanāharā pakkamiṁsu, ","html":"<span class='verse-line'>{}</span>"},"ja493:1.4":{"pli":"ekaṁ katvāna gāmaṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja493:2.1":{"pli":"Te taṁ kantāramāgamma, ","html":"<p><span class='verse-line'>{}</span>"},"ja493:2.2":{"pli":"appabhakkhaṁ anodakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja493:2.3":{"pli":"Mahānigrodhamaddakkhuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja493:2.4":{"pli":"sītacchāyaṁ manoramaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja493:3.1":{"pli":"Te ca tattha nisīditvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja493:3.2":{"pli":"tassa rukkhassa chāyayā; ","html":"<span class='verse-line'>{}</span>"},"ja493:3.3":{"pli":"Vāṇijā samacintesuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja493:3.4":{"pli":"bālā mohena pārutā. ","html":"<span class='verse-line'>{}</span></p>"},"ja493:4.1":{"pli":"Allāyate ayaṁ rukkho, ","html":"<p><span class='verse-line'>{}</span>"},"ja493:4.2":{"pli":"api vārīva sandati; ","html":"<span class='verse-line'>{}</span>"},"ja493:4.3":{"pli":"Iṅghassa purimaṁ sākhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja493:4.4":{"pli":"mayaṁ chindāma vāṇijā. ","html":"<span class='verse-line'>{}</span></p>"},"ja493:5.1":{"pli":"Sā ca chinnāva pagghari, ","html":"<p><span class='verse-line'>{}</span>"},"ja493:5.2":{"pli":"acchaṁ vāriṁ anāvilaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja493:5.3":{"pli":"Te tattha nhatvā pivitvā, ","html":"<span class='verse-line'>{}</span>"},"ja493:5.4":{"pli":"yāvaticchiṁsu vāṇijā. ","html":"<span class='verse-line'>{}</span></p>"},"ja493:6.1":{"pli":"Dutiyaṁ samacintesuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja493:6.2":{"pli":"bālā mohena pārutā; ","html":"<span class='verse-line'>{}</span>"},"ja493:6.3":{"pli":"Iṅghassa dakkhiṇaṁ sākhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja493:6.4":{"pli":"mayaṁ chindāma vāṇijā. ","html":"<span class='verse-line'>{}</span></p>"},"ja493:7.1":{"pli":"Sā ca chinnāva pagghari, ","html":"<p><span class='verse-line'>{}</span>"},"ja493:7.2":{"pli":"sālimaṁsodanaṁ bahuṁ; ","html":"<span class='verse-line'>{}</span>"},"ja493:7.3":{"pli":"Appodavaṇṇe kummāse, ","html":"<span class='verse-line'>{}</span>"},"ja493:7.4":{"pli":"siṅgiṁ vidalasūpiyo. ","html":"<span class='verse-line'>{}</span></p>"},"ja493:8.1":{"pli":"Te tattha bhutvā khāditvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja493:8.2":{"pli":"yāvaticchiṁsu vāṇijā; ","html":"<span class='verse-line'>{}</span>"},"ja493:8.3":{"pli":"Tatiyaṁ samacintesuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja493:8.4":{"pli":"bālā mohena pārutā; ","html":"<span class='verse-line'>{}</span>"},"ja493:8.5":{"pli":"Iṅghassa pacchimaṁ sākhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja493:8.6":{"pli":"mayaṁ chindāma vāṇijā. ","html":"<span class='verse-line'>{}</span></p>"},"ja493:9.1":{"pli":"Sā ca chinnāva pagghari, ","html":"<p><span class='verse-line'>{}</span>"},"ja493:9.2":{"pli":"nāriyo samalaṅkatā; ","html":"<span class='verse-line'>{}</span>"},"ja493:9.3":{"pli":"Vicitravatthābharaṇā, ","html":"<span class='verse-line'>{}</span>"},"ja493:9.4":{"pli":"āmuttamaṇikuṇḍalā. ","html":"<span class='verse-line'>{}</span></p>"},"ja493:10.1":{"pli":"Api su vāṇijā ekā, ","html":"<p><span class='verse-line'>{}</span>"},"ja493:10.2":{"pli":"nāriyo paṇṇavīsati; ","html":"<span class='verse-line'>{}</span>"},"ja493:10.3":{"pli":"Samantā parivāriṁsu, ","html":"<span class='verse-line'>{}</span>"},"ja493:10.4":{"pli":"tassa rukkhassa chāyayā. ","html":"<span class='verse-line'>{}</span></p>"},"ja493:11.1":{"pli":"Te tāhi paricāretvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja493:11.2":{"pli":"yāvaticchiṁsu vāṇijā; ","html":"<span class='verse-line'>{}</span>"},"ja493:11.3":{"pli":"Catutthaṁ samacintesuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja493:11.4":{"pli":"bālā mohena pārutā; ","html":"<span class='verse-line'>{}</span>"},"ja493:11.5":{"pli":"Iṅghassa uttaraṁ sākhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja493:11.6":{"pli":"mayaṁ chindāma vāṇijā. ","html":"<span class='verse-line'>{}</span></p>"},"ja493:12.1":{"pli":"Sā ca chinnāva pagghari, ","html":"<p><span class='verse-line'>{}</span>"},"ja493:12.2":{"pli":"muttā veḷuriyā bahū; ","html":"<span class='verse-line'>{}</span>"},"ja493:12.3":{"pli":"Rajataṁ jātarūpañca, ","html":"<span class='verse-line'>{}</span>"},"ja493:12.4":{"pli":"kuttiyo paṭiyāni ca. ","html":"<span class='verse-line'>{}</span></p>"},"ja493:13.1":{"pli":"Kāsikāni ca vatthāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja493:13.2":{"pli":"uddiyāni ca kambalā; ","html":"<span class='verse-line'>{}</span>"},"ja493:13.3":{"pli":"Te tattha bhāre bandhitvā, ","html":"<span class='verse-line'>{}</span>"},"ja493:13.4":{"pli":"yāvaticchiṁsu vāṇijā. ","html":"<span class='verse-line'>{}</span></p>"},"ja493:14.1":{"pli":"Pañcamaṁ samacintesuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja493:14.2":{"pli":"bālā mohena pārutā; ","html":"<span class='verse-line'>{}</span>"},"ja493:14.3":{"pli":"Iṅghassa mūlaṁ chindāma, ","html":"<span class='verse-line'>{}</span>"},"ja493:14.4":{"pli":"api bhiyyo labhāmase. ","html":"<span class='verse-line'>{}</span></p>"},"ja493:15.1":{"pli":"Athuṭṭhahi satthavāho, ","html":"<p><span class='verse-line'>{}</span>"},"ja493:15.2":{"pli":"yācamāno katañjalī; ","html":"<span class='verse-line'>{}</span>"},"ja493:15.3":{"pli":"Nigrodho kiṁ parajjhati, ","html":"<span class='verse-line'>{}</span>"},"ja493:15.4":{"pli":"vāṇijā bhaddamatthu te. ","html":"<span class='verse-line'>{}</span></p>"},"ja493:16.1":{"pli":"Vāridā purimā sākhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja493:16.2":{"pli":"annapānañca dakkhiṇā; ","html":"<span class='verse-line'>{}</span>"},"ja493:16.3":{"pli":"Nāridā pacchimā sākhā, ","html":"<span class='verse-line'>{}</span>"},"ja493:16.4":{"pli":"sabbakāme ca uttarā; ","html":"<span class='verse-line'>{}</span>"},"ja493:16.5":{"pli":"Nigrodho kiṁ parajjhati, ","html":"<span class='verse-line'>{}</span>"},"ja493:16.6":{"pli":"vāṇijā bhaddamatthu te. ","html":"<span class='verse-line'>{}</span></p>"},"ja493:17.1":{"pli":"Yassa rukkhassa chāyāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja493:17.2":{"pli":"nisīdeyya sayeyya vā; ","html":"<span class='verse-line'>{}</span>"},"ja493:17.3":{"pli":"Na tassa sākhaṁ bhañjeyya, ","html":"<span class='verse-line'>{}</span>"},"ja493:17.4":{"pli":"mittadubbho hi pāpako. ","html":"<span class='verse-line'>{}</span></p>"},"ja493:18.1":{"pli":"Te ca tassānādiyitvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja493:18.2":{"pli":"ekassa vacanaṁ bahū; ","html":"<span class='verse-line'>{}</span>"},"ja493:18.3":{"pli":"Nisitāhi kuṭhārīhi, ","html":"<span class='verse-line'>{}</span>"},"ja493:18.4":{"pli":"mūlato naṁ upakkamuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja493:19.1":{"pli":"Tato nāgā nikkhamiṁsu, ","html":"<p><span class='verse-line'>{}</span>"},"ja493:19.2":{"pli":"sannaddhā paṇṇavīsati; ","html":"<span class='verse-line'>{}</span>"},"ja493:19.3":{"pli":"Dhanuggahānaṁ tisatā, ","html":"<span class='verse-line'>{}</span>"},"ja493:19.4":{"pli":"chasahassā ca vammino. ","html":"<span class='verse-line'>{}</span></p>"},"ja493:20.1":{"pli":"“Ete hanatha bandhatha, ","html":"<p><span class='verse-line'>{}</span>"},"ja493:20.2":{"pli":"Mā vo muñcittha jīvitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja493:20.3":{"pli":"Ṭhapetvā satthavāhaṁva, ","html":"<span class='verse-line'>{}</span>"},"ja493:20.4":{"pli":"Sabbe bhasmaṁ karotha ne”. ","html":"<span class='verse-line'>{}</span></p>"},"ja493:21.1":{"pli":"“Tasmā hi paṇḍito poso, ","html":"<p><span class='verse-line'>{}</span>"},"ja493:21.2":{"pli":"sampassaṁ atthamattano; ","html":"<span class='verse-line'>{}</span>"},"ja493:21.3":{"pli":"Lobhassa na vasaṁ gacche, ","html":"<span class='verse-line'>{}</span>"},"ja493:21.4":{"pli":"haneyyārisakaṁ manaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja493:22.1":{"pli":"Evamādīnavaṁ ñatvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja493:22.2":{"pli":"taṇhā dukkhassa sambhavaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja493:22.3":{"pli":"Vītataṇho anādāno, ","html":"<span class='verse-line'>{}</span>"},"ja493:22.4":{"pli":"sato bhikkhu paribbaje”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja493:23.1":{"pli":"Mahāvāṇijajātakaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja494":{"ja494:0.1":{"pli":"Jātaka ","html":"<article id='ja494'><header><ul><li class='division'>{}</li>"},"ja494:0.2":{"pli":"Pakiṇṇakanipāta ","html":"<li>{}</li>"},"ja494:0.3":{"pli":"Sālikedāravagga ","html":"<li>{}</li></ul>"},"ja494:0.4":{"pli":"11. Sādhinajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja494:1.1":{"pli":"“Abbhuto vata lokasmiṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja494:1.2":{"pli":"uppajji lomahaṁsano; ","html":"<span class='verse-line'>{}</span>"},"ja494:1.3":{"pli":"Dibbo ratho pāturahu, ","html":"<span class='verse-line'>{}</span>"},"ja494:1.4":{"pli":"vedehassa yasassino”. ","html":"<span class='verse-line'>{}</span></p>"},"ja494:2.1":{"pli":"Devaputto mahiddhiko, ","html":"<p><span class='verse-line'>{}</span>"},"ja494:2.2":{"pli":"mātali devasārathi; ","html":"<span class='verse-line'>{}</span>"},"ja494:2.3":{"pli":"Nimantayittha rājānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja494:2.4":{"pli":"vedehaṁ mithilaggahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja494:3.1":{"pli":"“Ehimaṁ rathamāruyha, ","html":"<p><span class='verse-line'>{}</span>"},"ja494:3.2":{"pli":"rājaseṭṭha disampati; ","html":"<span class='verse-line'>{}</span>"},"ja494:3.3":{"pli":"Devā dassanakāmā te, ","html":"<span class='verse-line'>{}</span>"},"ja494:3.4":{"pli":"tāvatiṁsā saindakā; ","html":"<span class='verse-line'>{}</span>"},"ja494:3.5":{"pli":"Saramānā hi te devā, ","html":"<span class='verse-line'>{}</span>"},"ja494:3.6":{"pli":"sudhammāyaṁ samacchare”. ","html":"<span class='verse-line'>{}</span></p>"},"ja494:4.1":{"pli":"Tato ca rājā sādhino, ","html":"<p><span class='verse-line'>{}</span>"},"ja494:4.2":{"pli":"vedeho mithilaggaho; ","html":"<span class='verse-line'>{}</span>"},"ja494:4.3":{"pli":"Sahassayuttamāruyha, ","html":"<span class='verse-line'>{}</span>"},"ja494:4.4":{"pli":"agā devāna santike; ","html":"<span class='verse-line'>{}</span>"},"ja494:4.5":{"pli":"Taṁ devā paṭinandiṁsu, ","html":"<span class='verse-line'>{}</span>"},"ja494:4.6":{"pli":"disvā rājānamāgataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja494:5.1":{"pli":"“Svāgataṁ te mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja494:5.2":{"pli":"atho te adurāgataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja494:5.3":{"pli":"Nisīda dāni rājīsi, ","html":"<span class='verse-line'>{}</span>"},"ja494:5.4":{"pli":"devarājassa santike”. ","html":"<span class='verse-line'>{}</span></p>"},"ja494:6.1":{"pli":"Sakkopi paṭinandittha, ","html":"<p><span class='verse-line'>{}</span>"},"ja494:6.2":{"pli":"vedehaṁ mithilaggahaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja494:6.3":{"pli":"Nimantayittha kāmehi, ","html":"<span class='verse-line'>{}</span>"},"ja494:6.4":{"pli":"āsanena ca vāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"ja494:7.1":{"pli":"“Sādhu khosi anuppatto, ","html":"<p><span class='verse-line'>{}</span>"},"ja494:7.2":{"pli":"āvāsaṁ vasavattinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja494:7.3":{"pli":"Vasa devesu rājīsi, ","html":"<span class='verse-line'>{}</span>"},"ja494:7.4":{"pli":"sabbakāmasamiddhisu; ","html":"<span class='verse-line'>{}</span>"},"ja494:7.5":{"pli":"Tāvatiṁsesu devesu, ","html":"<span class='verse-line'>{}</span>"},"ja494:7.6":{"pli":"bhuñja kāme amānuse”. ","html":"<span class='verse-line'>{}</span></p>"},"ja494:8.1":{"pli":"“Ahaṁ pure saggagato ramāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja494:8.2":{"pli":"Naccehi gītehi ca vāditehi; ","html":"<span class='verse-line'>{}</span>"},"ja494:8.3":{"pli":"So dāni ajja na ramāmi sagge, ","html":"<span class='verse-line'>{}</span>"},"ja494:8.4":{"pli":"Āyuṁ nu khīṇo maraṇaṁ nu santike; ","html":"<span class='verse-line'>{}</span>"},"ja494:8.5":{"pli":"Udāhu mūḷhosmi janindaseṭṭha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja494:9.1":{"pli":"“Na tāyu khīṇaṁ maraṇañca dūre, ","html":"<p><span class='verse-line'>{}</span>"},"ja494:9.2":{"pli":"Na cāpi mūḷho naravīraseṭṭha; ","html":"<span class='verse-line'>{}</span>"},"ja494:9.3":{"pli":"Tuyhañca puññāni parittakāni, ","html":"<span class='verse-line'>{}</span>"},"ja494:9.4":{"pli":"Yesaṁ vipākaṁ idha vedayittho. ","html":"<span class='verse-line'>{}</span></p>"},"ja494:10.1":{"pli":"Vasa devānubhāvena, ","html":"<p><span class='verse-line'>{}</span>"},"ja494:10.2":{"pli":"rājaseṭṭha disampati; ","html":"<span class='verse-line'>{}</span>"},"ja494:10.3":{"pli":"Tāvatiṁsesu devesu, ","html":"<span class='verse-line'>{}</span>"},"ja494:10.4":{"pli":"bhuñja kāme amānuse”. ","html":"<span class='verse-line'>{}</span></p>"},"ja494:11.1":{"pli":"“Yathā yācitakaṁ yānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja494:11.2":{"pli":"yathā yācitakaṁ dhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja494:11.3":{"pli":"Evaṁsampadamevetaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja494:11.4":{"pli":"yaṁ parato dānapaccayā. ","html":"<span class='verse-line'>{}</span></p>"},"ja494:12.1":{"pli":"Na cāhametamicchāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja494:12.2":{"pli":"yaṁ parato dānapaccayā; ","html":"<span class='verse-line'>{}</span>"},"ja494:12.3":{"pli":"Sayaṅkatāni puññāni, ","html":"<span class='verse-line'>{}</span>"},"ja494:12.4":{"pli":"taṁ me āveṇikaṁ dhanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja494:13.1":{"pli":"Sohaṁ gantvā manussesu, ","html":"<p><span class='verse-line'>{}</span>"},"ja494:13.2":{"pli":"kāhāmi kusalaṁ bahuṁ; ","html":"<span class='verse-line'>{}</span>"},"ja494:13.3":{"pli":"Dānena samacariyāya, ","html":"<span class='verse-line'>{}</span>"},"ja494:13.4":{"pli":"saṁyamena damena ca; ","html":"<span class='verse-line'>{}</span>"},"ja494:13.5":{"pli":"Yaṁ katvā sukhito hoti, ","html":"<span class='verse-line'>{}</span>"},"ja494:13.6":{"pli":"na ca pacchānutappati. ","html":"<span class='verse-line'>{}</span></p>"},"ja494:14.1":{"pli":"Imāni tāni khettāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja494:14.2":{"pli":"imaṁ nikkhaṁ sukuṇḍalaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja494:14.3":{"pli":"Imā tā haritānūpā, ","html":"<span class='verse-line'>{}</span>"},"ja494:14.4":{"pli":"imā najjo savantiyo. ","html":"<span class='verse-line'>{}</span></p>"},"ja494:15.1":{"pli":"Imā tā pokkharaṇī rammā, ","html":"<p><span class='verse-line'>{}</span>"},"ja494:15.2":{"pli":"cakkavākapakūjitā; ","html":"<span class='verse-line'>{}</span>"},"ja494:15.3":{"pli":"Mandālakehi sañchannā, ","html":"<span class='verse-line'>{}</span>"},"ja494:15.4":{"pli":"padumuppalakehi ca; ","html":"<span class='verse-line'>{}</span>"},"ja494:15.5":{"pli":"Yassimāni mamāyiṁsu, ","html":"<span class='verse-line'>{}</span>"},"ja494:15.6":{"pli":"kiṁ nu te disataṁ gatā. ","html":"<span class='verse-line'>{}</span></p>"},"ja494:16.1":{"pli":"Tānīdha khettāni so bhūmibhāgo, ","html":"<p><span class='verse-line'>{}</span>"},"ja494:16.2":{"pli":"Teyeva ārāmavanūpacārā; ","html":"<span class='verse-line'>{}</span>"},"ja494:16.3":{"pli":"Tameva mayhaṁ janataṁ apassato, ","html":"<span class='verse-line'>{}</span>"},"ja494:16.4":{"pli":"Suññaṁva me nārada khāyate disā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja494:17.1":{"pli":"“Diṭṭhā mayā vimānāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja494:17.2":{"pli":"obhāsentā catuddisā; ","html":"<span class='verse-line'>{}</span>"},"ja494:17.3":{"pli":"Sammukhā devarājassa, ","html":"<span class='verse-line'>{}</span>"},"ja494:17.4":{"pli":"tidasānañca sammukhā. ","html":"<span class='verse-line'>{}</span></p>"},"ja494:18.1":{"pli":"Vutthaṁ me bhavanaṁ dibyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja494:18.2":{"pli":"Bhuttā kāmā amānusā; ","html":"<span class='verse-line'>{}</span>"},"ja494:18.3":{"pli":"Tāvatiṁsesu devesu, ","html":"<span class='verse-line'>{}</span>"},"ja494:18.4":{"pli":"Sabbakāmasamiddhisu. ","html":"<span class='verse-line'>{}</span></p>"},"ja494:19.1":{"pli":"Sohaṁ etādisaṁ hitvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja494:19.2":{"pli":"puññāyamhi idhāgato; ","html":"<span class='verse-line'>{}</span>"},"ja494:19.3":{"pli":"Dhammameva carissāmi, ","html":"<span class='verse-line'>{}</span>"},"ja494:19.4":{"pli":"nāhaṁ rajjena atthiko. ","html":"<span class='verse-line'>{}</span></p>"},"ja494:20.1":{"pli":"Adaṇḍāvacaraṁ maggaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja494:20.2":{"pli":"sammāsambuddhadesitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja494:20.3":{"pli":"Taṁ maggaṁ paṭipajjissaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja494:20.4":{"pli":"yena gacchanti subbatā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja494:21.1":{"pli":"Sādhinajātakaṁ ekādasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja495":{"ja495:0.1"