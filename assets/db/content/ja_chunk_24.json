>{}</span></p>"},"ja495:35.1":{"pli":"Samā gopanisādehi, ","html":"<p data-counter='81'><span class='verse-line'>{}</span>"},"ja495:35.2":{"pli":"tepi vuccanti brāhmaṇā; ","html":"<span class='verse-line'>{}</span>"},"ja495:35.3":{"pli":"Akkhātā te mahārāja, ","html":"<span class='verse-line'>{}</span>"},"ja495:35.4":{"pli":"tādise nipatāmase”. ","html":"<span class='verse-line'>{}</span></p>"},"ja495:36.1":{"pli":"“Apetā te ca brahmaññā, ","html":"<p><span class='verse-line'>{}</span>"},"ja495:36.2":{"pli":"(iti rājā korabyo) ","html":"<span class='speaker'>{}</span>"},"ja495:36.3":{"pli":"Na te vuccanti brāhmaṇā; ","html":"<span class='verse-line'>{}</span>"},"ja495:36.4":{"pli":"Aññe vidhura pariyesa, ","html":"<span class='verse-line'>{}</span>"},"ja495:36.5":{"pli":"Sīlavante bahussute. ","html":"<span class='verse-line'>{}</span></p>"},"ja495:37.1":{"pli":"Virate methunā dhammā, ","html":"<p><span class='verse-line'>{}</span>"},"ja495:37.2":{"pli":"ye me bhuñjeyyu bhojanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja495:37.3":{"pli":"Dakkhiṇaṁ samma dassāma, ","html":"<span class='verse-line'>{}</span>"},"ja495:37.4":{"pli":"yattha dinnaṁ mahapphalaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja495:38.1":{"pli":"“Araññe kuṭikaṁ katvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja495:38.2":{"pli":"kūṭāni kārayanti te; ","html":"<span class='verse-line'>{}</span>"},"ja495:38.3":{"pli":"Sasabiḷāre bādhenti, ","html":"<span class='verse-line'>{}</span>"},"ja495:38.4":{"pli":"āgodhā macchakacchapaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja495:39.1":{"pli":"Te luddakasamā rāja, ","html":"<p data-counter='91'><span class='verse-line'>{}</span>"},"ja495:39.2":{"pli":"tepi vuccanti brāhmaṇā; ","html":"<span class='verse-line'>{}</span>"},"ja495:39.3":{"pli":"Akkhātā te mahārāja, ","html":"<span class='verse-line'>{}</span>"},"ja495:39.4":{"pli":"tādise nipatāmase”. ","html":"<span class='verse-line'>{}</span></p>"},"ja495:40.1":{"pli":"“Apetā te ca brahmaññā, ","html":"<p><span class='verse-line'>{}</span>"},"ja495:40.2":{"pli":"(iti rājā korabyo) ","html":"<span class='speaker'>{}</span>"},"ja495:40.3":{"pli":"Na te vuccanti brāhmaṇā; ","html":"<span class='verse-line'>{}</span>"},"ja495:40.4":{"pli":"Aññe vidhura pariyesa, ","html":"<span class='verse-line'>{}</span>"},"ja495:40.5":{"pli":"Sīlavante bahussute. ","html":"<span class='verse-line'>{}</span></p>"},"ja495:41.1":{"pli":"Virate methunā dhammā, ","html":"<p><span class='verse-line'>{}</span>"},"ja495:41.2":{"pli":"ye me bhuñjeyyu bhojanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja495:41.3":{"pli":"Dakkhiṇaṁ samma dassāma, ","html":"<span class='verse-line'>{}</span>"},"ja495:41.4":{"pli":"yattha dinnaṁ mahapphalaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja495:42.1":{"pli":"“Aññe dhanassa kāmā hi, ","html":"<p><span class='verse-line'>{}</span>"},"ja495:42.2":{"pli":"heṭṭhāmañce pasakkitā; ","html":"<span class='verse-line'>{}</span>"},"ja495:42.3":{"pli":"Rājāno upari nhāyanti, ","html":"<span class='verse-line'>{}</span>"},"ja495:42.4":{"pli":"somayāge upaṭṭhite. ","html":"<span class='verse-line'>{}</span></p>"},"ja495:43.1":{"pli":"Malamajjakasamā rāja, ","html":"<p data-counter='101'><span class='verse-line'>{}</span>"},"ja495:43.2":{"pli":"Tepi vuccanti brāhmaṇā; ","html":"<span class='verse-line'>{}</span>"},"ja495:43.3":{"pli":"Akkhātā te mahārāja, ","html":"<span class='verse-line'>{}</span>"},"ja495:43.4":{"pli":"Tādise nipatāmase”. ","html":"<span class='verse-line'>{}</span></p>"},"ja495:44.1":{"pli":"“Apetā te ca brahmaññā, ","html":"<p><span class='verse-line'>{}</span>"},"ja495:44.2":{"pli":"(iti rājā korabyo) ","html":"<span class='speaker'>{}</span>"},"ja495:44.3":{"pli":"Na te vuccanti brāhmaṇā; ","html":"<span class='verse-line'>{}</span>"},"ja495:44.4":{"pli":"Aññe vidhura pariyesa, ","html":"<span class='verse-line'>{}</span>"},"ja495:44.5":{"pli":"Sīlavante bahussute. ","html":"<span class='verse-line'>{}</span></p>"},"ja495:45.1":{"pli":"Virate methunā dhammā, ","html":"<p><span class='verse-line'>{}</span>"},"ja495:45.2":{"pli":"ye me bhuñjeyyu bhojanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja495:45.3":{"pli":"Dakkhiṇaṁ samma dassāma, ","html":"<span class='verse-line'>{}</span>"},"ja495:45.4":{"pli":"yattha dinnaṁ mahapphalaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja495:46.1":{"pli":"“Atthi kho brāhmaṇā deva, ","html":"<p><span class='verse-line'>{}</span>"},"ja495:46.2":{"pli":"sīlavanto bahussutā; ","html":"<span class='verse-line'>{}</span>"},"ja495:46.3":{"pli":"Viratā methunā dhammā, ","html":"<span class='verse-line'>{}</span>"},"ja495:46.4":{"pli":"ye te bhuñjeyyu bhojanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja495:47.1":{"pli":"Ekañca bhattaṁ bhuñjanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja495:47.2":{"pli":"na ca majjaṁ pivanti te; ","html":"<span class='verse-line'>{}</span>"},"ja495:47.3":{"pli":"Akkhātā te mahārāja, ","html":"<span class='verse-line'>{}</span>"},"ja495:47.4":{"pli":"tādise nipatāmase”. ","html":"<span class='verse-line'>{}</span></p>"},"ja495:48.1":{"pli":"“Ete kho brāhmaṇā vidhura, ","html":"<p><span class='verse-line'>{}</span>"},"ja495:48.2":{"pli":"Sīlavanto bahussutā; ","html":"<span class='verse-line'>{}</span>"},"ja495:48.3":{"pli":"Ete vidhura pariyesa, ","html":"<span class='verse-line'>{}</span>"},"ja495:48.4":{"pli":"Khippañca ne nimantayā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja495:49.1":{"pli":"Dasabrāhmaṇajātakaṁ dvādasamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja496":{"ja496:0.1":{"pli":"Jātaka ","html":"<article id='ja496'><header><ul><li class='division'>{}</li>"},"ja496:0.2":{"pli":"Pakiṇṇakanipāta ","html":"<li>{}</li>"},"ja496:0.3":{"pli":"Sālikedāravagga ","html":"<li>{}</li></ul>"},"ja496:0.4":{"pli":"13. Bhikkhāparamparajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja496:1.1":{"pli":"“Sukhumālarūpaṁ disvā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja496:1.2":{"pli":"raṭṭhā vivanamāgataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja496:1.3":{"pli":"Kūṭāgāravarūpetaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja496:1.4":{"pli":"mahāsayanamupāsitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja496:2.1":{"pli":"Tassa te pemakenāhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja496:2.2":{"pli":"adāsiṁ vaḍḍhamodanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja496:2.3":{"pli":"Sālīnaṁ vicitaṁ bhattaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja496:2.4":{"pli":"suciṁ maṁsūpasecanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja496:3.1":{"pli":"Taṁ tvaṁ bhattaṁ paṭiggayha, ","html":"<p><span class='verse-line'>{}</span>"},"ja496:3.2":{"pli":"brāhmaṇassa adāsayi; ","html":"<span class='verse-line'>{}</span>"},"ja496:3.3":{"pli":"Attānaṁ anasitvāna, ","html":"<span class='verse-line'>{}</span>"},"ja496:3.4":{"pli":"koyaṁ dhammo namatthu te”. ","html":"<span class='verse-line'>{}</span></p>"},"ja496:4.1":{"pli":"“Ācariyo brāhmaṇo mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja496:4.2":{"pli":"kiccākiccesu byāvaṭo; ","html":"<span class='verse-line'>{}</span>"},"ja496:4.3":{"pli":"Garu ca āmantanīyo ca, ","html":"<span class='verse-line'>{}</span>"},"ja496:4.4":{"pli":"dātumarahāmi bhojanaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja496:5.1":{"pli":"“Brāhmaṇaṁ dāni pucchāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja496:5.2":{"pli":"gotamaṁ rājapūjitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja496:5.3":{"pli":"Rājā te bhattaṁ pādāsi, ","html":"<span class='verse-line'>{}</span>"},"ja496:5.4":{"pli":"suciṁ maṁsūpasecanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja496:6.1":{"pli":"Taṁ tvaṁ bhattaṁ paṭiggayha, ","html":"<p><span class='verse-line'>{}</span>"},"ja496:6.2":{"pli":"isissa bhojanaṁ adā; ","html":"<span class='verse-line'>{}</span>"},"ja496:6.3":{"pli":"Akhettaññūsi dānassa, ","html":"<span class='verse-line'>{}</span>"},"ja496:6.4":{"pli":"koyaṁ dhammo namatthu te”. ","html":"<span class='verse-line'>{}</span></p>"},"ja496:7.1":{"pli":"“Bharāmi puttadāre ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja496:7.2":{"pli":"gharesu gadhito ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja496:7.3":{"pli":"Bhuñje mānusake kāme, ","html":"<span class='verse-line'>{}</span>"},"ja496:7.4":{"pli":"anusāsāmi rājino. ","html":"<span class='verse-line'>{}</span></p>"},"ja496:8.1":{"pli":"Āraññikassa isino, ","html":"<p><span class='verse-line'>{}</span>"},"ja496:8.2":{"pli":"cirarattaṁ tapassino; ","html":"<span class='verse-line'>{}</span>"},"ja496:8.3":{"pli":"Vuḍḍhassa bhāvitattassa, ","html":"<span class='verse-line'>{}</span>"},"ja496:8.4":{"pli":"dātumarahāmi bhojanaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja496:9.1":{"pli":"“Isiñca dāni pucchāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja496:9.2":{"pli":"kisaṁ dhamanisanthataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja496:9.3":{"pli":"Parūḷhakacchanakhalomaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja496:9.4":{"pli":"paṅkadantaṁ rajassiraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja496:10.1":{"pli":"Eko araññe viharasi, ","html":"<p><span class='verse-line'>{}</span>"},"ja496:10.2":{"pli":"nāvakaṅkhasi jīvitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja496:10.3":{"pli":"Bhikkhu kena tayā seyyo, ","html":"<span class='verse-line'>{}</span>"},"ja496:10.4":{"pli":"yassa tvaṁ bhojanaṁ adā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja496:11.1":{"pli":"“Khaṇantālukalambāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja496:11.2":{"pli":"bilālitakkalāni ca; ","html":"<span class='verse-line'>{}</span>"},"ja496:11.3":{"pli":"Dhunaṁ sāmākanīvāraṁ, ","html":"<span class='verse-line'>{}</span>"},"ja496:11.4":{"pli":"saṅghāriyaṁ pasāriyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja496:12.1":{"pli":"Sākaṁ bhisaṁ madhuṁ maṁsaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja496:12.2":{"pli":"Badarāmalakāni ca; ","html":"<span class='verse-line'>{}</span>"},"ja496:12.3":{"pli":"Tāni āharitvā bhuñjāmi, ","html":"<span class='verse-line'>{}</span>"},"ja496:12.4":{"pli":"Atthi me so pariggaho. ","html":"<span class='verse-line'>{}</span></p>"},"ja496:13.1":{"pli":"Pacanto apacantassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja496:13.2":{"pli":"amamassa sakiñcano; ","html":"<span class='verse-line'>{}</span>"},"ja496:13.3":{"pli":"Anādānassa sādāno, ","html":"<span class='verse-line'>{}</span>"},"ja496:13.4":{"pli":"dātumarahāmi bhojanaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja496:14.1":{"pli":"“Bhikkhuñca dāni pucchāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja496:14.2":{"pli":"tuṇhīmāsīna subbataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja496:14.3":{"pli":"Isi te bhattaṁ pādāsi, ","html":"<span class='verse-line'>{}</span>"},"ja496:14.4":{"pli":"suciṁ maṁsūpasecanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja496:15.1":{"pli":"Taṁ tvaṁ bhattaṁ paṭiggayha, ","html":"<p><span class='verse-line'>{}</span>"},"ja496:15.2":{"pli":"tuṇhī bhuñjasi ekako; ","html":"<span class='verse-line'>{}</span>"},"ja496:15.3":{"pli":"Nāññaṁ kañci nimantesi, ","html":"<span class='verse-line'>{}</span>"},"ja496:15.4":{"pli":"koyaṁ dhammo namatthu te”. ","html":"<span class='verse-line'>{}</span></p>"},"ja496:16.1":{"pli":"“Na pacāmi na pācemi, ","html":"<p><span class='verse-line'>{}</span>"},"ja496:16.2":{"pli":"na chindāmi na chedaye; ","html":"<span class='verse-line'>{}</span>"},"ja496:16.3":{"pli":"Taṁ maṁ akiñcanaṁ ñatvā, ","html":"<span class='verse-line'>{}</span>"},"ja496:16.4":{"pli":"sabbapāpehi ārataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja496:17.1":{"pli":"Vāmena bhikkhamādāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja496:17.2":{"pli":"dakkhiṇena kamaṇḍaluṁ; ","html":"<span class='verse-line'>{}</span>"},"ja496:17.3":{"pli":"Isi me bhattaṁ pādāsi, ","html":"<span class='verse-line'>{}</span>"},"ja496:17.4":{"pli":"suciṁ maṁsūpasecanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja496:18.1":{"pli":"Ete hi dātumarahanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja496:18.2":{"pli":"samamā sapariggahā; ","html":"<span class='verse-line'>{}</span>"},"ja496:18.3":{"pli":"Paccanīkamahaṁ maññe, ","html":"<span class='verse-line'>{}</span>"},"ja496:18.4":{"pli":"yo dātāraṁ nimantaye”. ","html":"<span class='verse-line'>{}</span></p>"},"ja496:19.1":{"pli":"“Atthāya vata me ajja, ","html":"<p><span class='verse-line'>{}</span>"},"ja496:19.2":{"pli":"idhāgacchi rathesabho; ","html":"<span class='verse-line'>{}</span>"},"ja496:19.3":{"pli":"Sohaṁ ajja pajānāmi, ","html":"<span class='verse-line'>{}</span>"},"ja496:19.4":{"pli":"yattha dinnaṁ mahapphalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja496:20.1":{"pli":"Raṭṭhesu giddhā rājāno, ","html":"<p><span class='verse-line'>{}</span>"},"ja496:20.2":{"pli":"Kiccākiccesu brāhmaṇā; ","html":"<span class='verse-line'>{}</span>"},"ja496:20.3":{"pli":"Isī mūlaphale giddhā, ","html":"<span class='verse-line'>{}</span>"},"ja496:20.4":{"pli":"Vippamuttā ca bhikkhavo”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja496:21.1":{"pli":"Bhikkhāparamparajātakaṁ terasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja496:22.1":{"pli":"Pakiṇṇakanipātaṁ niṭṭhitaṁ. ","html":"<p class='endsection'>{}</p>"},"ja496:23.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja496:24.1":{"pli":"Suva kinnara mukka kharājinaso, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja496:24.2":{"pli":"Bhisajāta mahesi kapotavaro; ","html":"<span class='verse-line'>{}</span>"},"ja496:24.3":{"pli":"Atha mora satacchaka vāṇijako, ","html":"<span class='verse-line'>{}</span>"},"ja496:24.4":{"pli":"Atha rāja sabrāhmaṇa bhikkhaparanti. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}}}