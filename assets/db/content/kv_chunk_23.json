{"kv23.5":{"kv23.5:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv23.5'><header><ul><li class='division'>{}</li>"},"kv23.5:0.2":{"pli":"Mahāpaṇṇāsaka ","html":"<li>{}</li>"},"kv23.5:0.3":{"pli":"Tevīsatimavagga ","html":"<li>{}</li></ul>"},"kv23.5:0.4":{"pli":"Aparinipphannakathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv23.5:1.1":{"pli":"Rūpaṁ aparinipphannanti? ","html":"<p data-doxy='orthodox'>{}"},"kv23.5:1.2":{"pli":"Āmantā. ","html":"{}"},"kv23.5:1.3":{"pli":"Rūpaṁ na aniccaṁ na saṅkhataṁ na paṭiccasamuppannaṁ na khayadhammaṁ na vayadhammaṁ na virāgadhammaṁ na nirodhadhammaṁ na vipariṇāmadhammanti? ","html":"{}"},"kv23.5:1.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv23.5:1.5":{"pli":"nanu rūpaṁ aniccaṁ saṅkhataṁ paṭiccasamuppannaṁ khayadhammaṁ vayadhammaṁ virāgadhammaṁ nirodhadhammaṁ vipariṇāmadhammanti? ","html":"{}"},"kv23.5:1.6":{"pli":"Āmantā. ","html":"{}"},"kv23.5:1.7":{"pli":"Hañci rūpaṁ aniccaṁ saṅkhataṁ …pe… ","html":"{}"},"kv23.5:1.8":{"pli":"vipariṇāmadhammaṁ, no ca vata re vattabbe—","html":"{}"},"kv23.5:1.9":{"pli":"“rūpaṁ aparinipphannan”ti. ","html":"{}</p>"},"kv23.5:2.1":{"pli":"Dukkhaññeva parinipphannanti? ","html":"<p data-doxy='orthodox'>{}"},"kv23.5:2.2":{"pli":"Āmantā. ","html":"{}"},"kv23.5:2.3":{"pli":"Nanu yadaniccaṁ taṁ dukkhaṁ vuttaṁ bhagavatā—","html":"{}"},"kv23.5:2.4":{"pli":"“rūpaṁ aniccan”ti? ","html":"{}"},"kv23.5:2.5":{"pli":"Āmantā. ","html":"{}"},"kv23.5:2.6":{"pli":"Hañci yadaniccaṁ taṁ dukkhaṁ vuttaṁ bhagavatā—","html":"{}"},"kv23.5:2.7":{"pli":"“rūpaṁ aniccaṁ”, no ca vata re vattabbe—","html":"{}"},"kv23.5:2.8":{"pli":"“dukkhaññeva parinipphannan”ti …pe…. ","html":"{}</p>"},"kv23.5:3.1":{"pli":"Vedanā …pe… ","html":"<p data-doxy='orthodox'>{}"},"kv23.5:3.2":{"pli":"saññā … ","html":"{}"},"kv23.5:3.3":{"pli":"saṅkhārā … ","html":"{}"},"kv23.5:3.4":{"pli":"viññāṇaṁ … ","html":"{}"},"kv23.5:3.5":{"pli":"cakkhāyatanaṁ …pe… ","html":"{}"},"kv23.5:3.6":{"pli":"dhammāyatanaṁ … ","html":"{}"},"kv23.5:3.7":{"pli":"cakkhudhātu … ","html":"{}"},"kv23.5:3.8":{"pli":"dhammadhātu … ","html":"{}"},"kv23.5:3.9":{"pli":"cakkhundriyaṁ …pe… ","html":"{}"},"kv23.5:3.10":{"pli":"aññātāvindriyaṁ aparinipphannanti? ","html":"{}"},"kv23.5:3.11":{"pli":"Āmantā. ","html":"{}"},"kv23.5:3.12":{"pli":"Aññātāvindriyaṁ na aniccaṁ …pe… ","html":"{}"},"kv23.5:3.13":{"pli":"na vipariṇāmadhammanti? ","html":"{}"},"kv23.5:3.14":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv23.5:3.15":{"pli":"nanu aññātāvindriyaṁ aniccaṁ saṅkhataṁ …pe… vipariṇāmadhammanti? ","html":"{}"},"kv23.5:3.16":{"pli":"Āmantā. ","html":"{}"},"kv23.5:3.17":{"pli":"Hañci aññātāvindriyaṁ aniccaṁ saṅkhataṁ paṭiccasamuppannaṁ khayadhammaṁ vayadhammaṁ virāgadhammaṁ nirodhadhammaṁ vipariṇāmadhammaṁ, no ca vata re vattabbe—","html":"{}"},"kv23.5:3.18":{"pli":"“aññātāvindriyaṁ aparinipphannan”ti. ","html":"{}</p>"},"kv23.5:4.1":{"pli":"Dukkhaññeva parinipphannanti? ","html":"<p data-doxy='orthodox'>{}"},"kv23.5:4.2":{"pli":"Āmantā. ","html":"{}"},"kv23.5:4.3":{"pli":"Nanu yadaniccaṁ taṁ dukkhaṁ vuttaṁ bhagavatā—","html":"{}"},"kv23.5:4.4":{"pli":"“aññātāvindriyaṁ aniccan”ti? ","html":"{}"},"kv23.5:4.5":{"pli":"Āmantā. ","html":"{}"},"kv23.5:4.6":{"pli":"Hañci yadaniccaṁ taṁ dukkhaṁ vuttaṁ bhagavatā—","html":"{}"},"kv23.5:4.7":{"pli":"“aññātāvindriyaṁ aniccaṁ”, no ca vata re vattabbe—","html":"{}"},"kv23.5:4.8":{"pli":"“dukkhaññeva parinipphannan”ti. ","html":"{}</p>"},"kv23.5:4.9":{"pli":"Aparinipphannakathā niṭṭhitā. ","html":"<p class='endsutta'>{}<br>"},"kv23.5:4.10":{"pli":"Tevīsatimo vaggo. ","html":"{}</p>"},"kv23.5:4.11":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"kv23.5:5.1":{"pli":"Ekādhippāyena methuno dhammo paṭisevitabbo, arahantānaṁ vaṇṇena amanussā methunaṁ dhammaṁ paṭisevanti, bodhisatto issariyakāmakārikāhetu vinipātaṁ gacchati, gabbhaseyyaṁ okkamati, dukkarakārikaṁ akāsi, aparantapaṁ akāsi, aññaṁ satthāraṁ uddisi, atthi na rāgo rāgapatirūpako, atthi na doso dosapatirūpako, atthi na moho mohapatirūpako atthi na kileso kilesapatirūpako, rūpaṁ aparinipphannaṁ aññātāvindriyaṁ aparinipphannanti. ","html":"<p class='uddana'>{}</p>"},"kv23.5:5.2":{"pli":"Khuddako aḍḍhapaṇṇāsako. ","html":"<p class='endsutta'>{}</p>"},"kv23.5:5.3":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"kv23.5:6.1":{"pli":"Navaṁ, nibbuti, ekādhippāyoti. ","html":"<p class='uddana'>{}</p>"},"kv23.5:6.2":{"pli":"Paṇṇāsakuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"kv23.5:7.1":{"pli":"Mahāniyāmo anusayā, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"kv23.5:7.2":{"pli":"niggaho khuddakapañcamo; ","html":"<span class='verse-line'>{}</span>"},"kv23.5:7.3":{"pli":"Parappavādamaddanā, ","html":"<span class='verse-line'>{}</span>"},"kv23.5:7.4":{"pli":"suttamūlasamāhitā; ","html":"<span class='verse-line'>{}</span>"},"kv23.5:7.5":{"pli":"Ujjotanā satthusamaye, ","html":"<span class='verse-line'>{}</span>"},"kv23.5:7.6":{"pli":"kathāvatthupakaraṇeti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"kv23.5:7.7":{"pli":"Pañcattiṁsabhāṇavāraṁ ","html":"<p class='endsection'>{}</p>"},"kv23.5:7.8":{"pli":"kathāvatthupakaraṇaṁ niṭṭhitaṁ. ","html":"<p class='endbook'>{}</p></article>"}},"kv3.1":{"kv3.1:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv3.1'><header><ul><li class='division'>{}</li>"},"kv3.1:0.2":{"pli":"Mahāpaṇṇāsaka ","html":"<li>{}</li>"},"kv3.1:0.3":{"pli":"Tatiyavagga ","html":"<li>{}</li></ul>"},"kv3.1:0.4":{"pli":"Balakathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv3.1:1.1":{"pli":"Tathāgatabalaṁ sāvakasādhāraṇanti? ","html":"<p data-doxy='orthodox'>{}"},"kv3.1:1.2":{"pli":"Āmantā. ","html":"{}"},"kv3.1:1.3":{"pli":"Tathāgatabalaṁ sāvakabalaṁ, sāvakabalaṁ tathāgatabalanti? ","html":"{}"},"kv3.1:1.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}</p>"},"kv3.1:2.1":{"pli":"Tathāgatabalaṁ sāvakasādhāraṇanti? ","html":"<p data-doxy='orthodox'>{}"},"kv3.1:2.2":{"pli":"Āmantā. ","html":"{}"},"kv3.1:2.3":{"pli":"Taññeva tathāgatabalaṁ taṁ sāvakabalaṁ, taññeva sāvakabalaṁ taṁ tathāgatabalanti? ","html":"{}"},"kv3.1:2.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv3.1:3.1":{"pli":"Tathāgatabalaṁ sāvakasādhāraṇanti? ","html":"<p data-doxy='orthodox'>{}"},"kv3.1:3.2":{"pli":"Āmantā. ","html":"{}"},"kv3.1:3.3":{"pli":"Yādisaṁ tathāgatabalaṁ tādisaṁ sāvakabalaṁ, yādisaṁ sāvakabalaṁ tādisaṁ tathāgatabalanti? ","html":"{}"},"kv3.1:3.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv3.1:4.1":{"pli":"Tathāgatabalaṁ sāvakasādhāraṇanti? ","html":"<p data-doxy='orthodox'>{}"},"kv3.1:4.2":{"pli":"Āmantā. ","html":"{}"},"kv3.1:4.3":{"pli":"Yādiso tathāgatassa pubbayogo pubbacariyā dhammakkhānaṁ dhammadesanā tādiso sāvakassa pubbayogo pubbacariyā dhammakkhānaṁ dhammadesanāti? ","html":"{}"},"kv3.1:4.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv3.1:5.1":{"pli":"Tathāgatabalaṁ sāvakasādhāraṇanti? ","html":"<p data-doxy='orthodox'>{}"},"kv3.1:5.2":{"pli":"Āmantā. ","html":"{}"},"kv3.1:5.3":{"pli":"Tathāgato jino satthā sammāsambuddho sabbaññū sabbadassāvī dhammassāmī dhammappaṭisaraṇoti? ","html":"{}"},"kv3.1:5.4":{"pli":"Āmantā. ","html":"{}"},"kv3.1:5.5":{"pli":"Sāvako jino satthā sammāsambuddho sabbaññū sabbadassāvī dhammassāmī dhammappaṭisaraṇoti? ","html":"{}"},"kv3.1:5.6":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv3.1:6.1":{"pli":"Tathāgatabalaṁ sāvakasādhāraṇanti? ","html":"<p data-doxy='orthodox'>{}"},"kv3.1:6.2":{"pli":"Āmantā. ","html":"{}"},"kv3.1:6.3":{"pli":"Tathāgato anuppannassa maggassa uppādetā asañjātassa maggassa sañjanetā anakkhātassa maggassa akkhātā maggaññū maggavidū maggakovidoti? ","html":"{}"},"kv3.1:6.4":{"pli":"Āmantā. ","html":"{}"},"kv3.1:6.5":{"pli":"Sāvako anuppannassa maggassa uppādetā asañjātassa maggassa sañjanetā anakkhātassa maggassa akkhātā maggaññū maggavidū maggakovidoti? ","html":"{}"},"kv3.1:6.6":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv3.1:7.1":{"pli":"Indriyaparopariyattaṁ yathābhūtaṁ ñāṇaṁ tathāgatabalaṁ sāvakasādhāraṇanti? ","html":"<p data-doxy='orthodox'>{}"},"kv3.1:7.2":{"pli":"Āmantā. ","html":"{}"},"kv3.1:7.3":{"pli":"Sāvako sabbaññū sabbadassāvīti? ","html":"{}"},"kv3.1:7.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv3.1:8.1":{"pli":"Sāvako ṭhānāṭhānaṁ jānātīti? ","html":"<p data-doxy='heterodox'>{}"},"kv3.1:8.2":{"pli":"Āmantā. ","html":"{}"},"kv3.1:8.3":{"pli":"Hañci sāvako ṭhānāṭhānaṁ jānāti, tena vata re vattabbe—","html":"{}"},"kv3.1:8.4":{"pli":"“ṭhānāṭhānaṁ yathābhūtaṁ ñāṇaṁ tathāgatabalaṁ sāvakasādhāraṇan”ti. ","html":"{}</p>"},"kv3.1:9.1":{"pli":"Sāvako atītānāgatapaccuppannānaṁ kammasamādānānaṁ ṭhānaso hetuso vipākaṁ jānātīti? ","html":"<p data-doxy='heterodox'>{}"},"kv3.1:9.2":{"pli":"Āmantā. ","html":"{}"},"kv3.1:9.3":{"pli":"Hañci sāvako atītānāgatapaccuppannānaṁ kammasamādānānaṁ ṭhānaso hetuso vipākaṁ jānāti, tena vata re vattabbe—","html":"{}"},"kv3.1:9.4":{"pli":"“atītānāgatapaccuppannānaṁ kammasamādānānaṁ ṭhānaso hetuso vipākaṁ yathābhūtaṁ ñāṇaṁ tathāgatabalaṁ sāvakasādhāraṇan”ti. ","html":"{}</p>"},"kv3.1:10.1":{"pli":"Sāvako sabbatthagāminiṁ paṭipadaṁ jānātīti? ","html":"<p data-doxy='heterodox'>{}"},"kv3.1:10.2":{"pli":"Āmantā. ","html":"{}"},"kv3.1:10.3":{"pli":"Hañci sāvako sabbatthagāminiṁ paṭipadaṁ jānāti, tena vata re vattabbe—","html":"{}"},"kv3.1:10.4":{"pli":"“sabbatthagāminiṁ paṭipadaṁ yathābhūtaṁ ñāṇaṁ tathāgatabalaṁ sāvakasādhāraṇan”ti. ","html":"{}</p>"},"kv3.1:11.1":{"pli":"Sāvako anekadhātuṁ nānādhātuṁ lokaṁ jānātīti? ","html":"<p data-doxy='heterodox'>{}"},"kv3.1:11.2":{"pli":"Āmantā. ","html":"{}"},"kv3.1:11.3":{"pli":"Hañci sāvako anekadhātuṁ nānādhātuṁ lokaṁ jānāti, tena vata re vattabbe—","html":"{}"},"kv3.1:11.4":{"pli":"“anekadhātuṁ nānādhātuṁ lokaṁ yathābhūtaṁ ñāṇaṁ tathāgatabalaṁ sāvakasādhāraṇan”ti. ","html":"{}</p>"},"kv3.1:12.1":{"pli":"Sāvako sattānaṁ nānādhimuttikataṁ jānātīti? ","html":"<p data-doxy='heterodox'>{}"},"kv3.1:12.2":{"pli":"Āmantā. ","html":"{}"},"kv3.1:12.3":{"pli":"