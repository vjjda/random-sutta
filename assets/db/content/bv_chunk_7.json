='verse-line'>{}</span>"},"bv29:2.4":{"pli":"eko ca allakappake. ","html":"<span class='verse-line'>{}</span></p>"},"bv29:3.1":{"pli":"Eko ca rāmagāmamhi, ","html":"<p><span class='verse-line'>{}</span>"},"bv29:3.2":{"pli":"eko ca veṭhadīpake; ","html":"<span class='verse-line'>{}</span>"},"bv29:3.3":{"pli":"Eko pāveyyake malle, ","html":"<span class='verse-line'>{}</span>"},"bv29:3.4":{"pli":"eko ca kosinārake. ","html":"<span class='verse-line'>{}</span></p>"},"bv29:4.1":{"pli":"Kumbhassa thūpaṁ kāresi, ","html":"<p><span class='verse-line'>{}</span>"},"bv29:4.2":{"pli":"brāhmaṇo doṇasavhayo; ","html":"<span class='verse-line'>{}</span>"},"bv29:4.3":{"pli":"Aṅgārathūpaṁ kāresuṁ, ","html":"<span class='verse-line'>{}</span>"},"bv29:4.4":{"pli":"moriyā tuṭṭhamānasā. ","html":"<span class='verse-line'>{}</span></p>"},"bv29:5.1":{"pli":"Aṭṭha sārīrikā thūpā, ","html":"<p><span class='verse-line'>{}</span>"},"bv29:5.2":{"pli":"navamo kumbhacetiyo; ","html":"<span class='verse-line'>{}</span>"},"bv29:5.3":{"pli":"Aṅgārathūpo dasamo, ","html":"<span class='verse-line'>{}</span>"},"bv29:5.4":{"pli":"tadāyeva patiṭṭhito. ","html":"<span class='verse-line'>{}</span></p>"},"bv29:6.1":{"pli":"Uṇhīsaṁ catasso dāṭhā, ","html":"<p><span class='verse-line'>{}</span>"},"bv29:6.2":{"pli":"akkhakā dve ca dhātuyo; ","html":"<span class='verse-line'>{}</span>"},"bv29:6.3":{"pli":"Asambhinnā imā satta, ","html":"<span class='verse-line'>{}</span>"},"bv29:6.4":{"pli":"sesā bhinnāva dhātuyo. ","html":"<span class='verse-line'>{}</span></p>"},"bv29:7.1":{"pli":"Mahantā muggamattā ca, ","html":"<p><span class='verse-line'>{}</span>"},"bv29:7.2":{"pli":"majjhimā bhinnataṇḍulā; ","html":"<span class='verse-line'>{}</span>"},"bv29:7.3":{"pli":"Khuddakā sāsapamattā ca, ","html":"<span class='verse-line'>{}</span>"},"bv29:7.4":{"pli":"nānāvaṇṇā ca dhātuyo. ","html":"<span class='verse-line'>{}</span></p>"},"bv29:8.1":{"pli":"Mahantā suvaṇṇavaṇṇā ca, ","html":"<p><span class='verse-line'>{}</span>"},"bv29:8.2":{"pli":"muttavaṇṇā ca majjhimā; ","html":"<span class='verse-line'>{}</span>"},"bv29:8.3":{"pli":"Khuddakā makulavaṇṇā ca, ","html":"<span class='verse-line'>{}</span>"},"bv29:8.4":{"pli":"soḷasadoṇamattikā. ","html":"<span class='verse-line'>{}</span></p>"},"bv29:9.1":{"pli":"Mahantā pañca nāḷiyo, ","html":"<p><span class='verse-line'>{}</span>"},"bv29:9.2":{"pli":"nāḷiyo pañca majjhimā; ","html":"<span class='verse-line'>{}</span>"},"bv29:9.3":{"pli":"Khuddakā cha nāḷī ceva, ","html":"<span class='verse-line'>{}</span>"},"bv29:9.4":{"pli":"etā sabbāpi dhātuyo. ","html":"<span class='verse-line'>{}</span></p>"},"bv29:10.1":{"pli":"Uṇhīsaṁ sīhaḷe dīpe, ","html":"<p><span class='verse-line'>{}</span>"},"bv29:10.2":{"pli":"brahmaloke ca vāmakaṁ; ","html":"<span class='verse-line'>{}</span>"},"bv29:10.3":{"pli":"Sīhaḷe dakkhiṇakkhañca, ","html":"<span class='verse-line'>{}</span>"},"bv29:10.4":{"pli":"sabbāpetā patiṭṭhitā. ","html":"<span class='verse-line'>{}</span></p>"},"bv29:11.1":{"pli":"Ekā dāṭhā tidasapure, ","html":"<p><span class='verse-line'>{}</span>"},"bv29:11.2":{"pli":"ekā nāgapure ahu; ","html":"<span class='verse-line'>{}</span>"},"bv29:11.3":{"pli":"Ekā gandhāravisaye, ","html":"<span class='verse-line'>{}</span>"},"bv29:11.4":{"pli":"ekā kaliṅgarājino. ","html":"<span class='verse-line'>{}</span></p>"},"bv29:12.1":{"pli":"Cattālīsasamā dantā, ","html":"<p><span class='verse-line'>{}</span>"},"bv29:12.2":{"pli":"kesā lomā ca sabbaso; ","html":"<span class='verse-line'>{}</span>"},"bv29:12.3":{"pli":"Devā hariṁsu ekekaṁ, ","html":"<span class='verse-line'>{}</span>"},"bv29:12.4":{"pli":"cakkavāḷaparamparā. ","html":"<span class='verse-line'>{}</span></p>"},"bv29:13.1":{"pli":"Vajirāyaṁ bhagavato, ","html":"<p><span class='verse-line'>{}</span>"},"bv29:13.2":{"pli":"Patto daṇḍañca cīvaraṁ; ","html":"<span class='verse-line'>{}</span>"},"bv29:13.3":{"pli":"Nivāsanaṁ kulaghare, ","html":"<span class='verse-line'>{}</span>"},"bv29:13.4":{"pli":"Paccattharaṇaṁ kapilavhaye. ","html":"<span class='verse-line'>{}</span></p>"},"bv29:14.1":{"pli":"Pāṭaliputtapuramhi, ","html":"<p><span class='verse-line'>{}</span>"},"bv29:14.2":{"pli":"karaṇaṁ kāyabandhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"bv29:14.3":{"pli":"Campāyudakasāṭiyaṁ, ","html":"<span class='verse-line'>{}</span>"},"bv29:14.4":{"pli":"uṇṇalomañca kosale. ","html":"<span class='verse-line'>{}</span></p>"},"bv29:15.1":{"pli":"Kāsāvaṁ brahmaloke ca, ","html":"<p><span class='verse-line'>{}</span>"},"bv29:15.2":{"pli":"veṭhanaṁ tidase pure; ","html":"<span class='verse-line'>{}</span>"},"bv29:15.3":{"pli":"Nisīdanaṁ avantīsu, ","html":"<span class='verse-line'>{}</span>"},"bv29:15.4":{"pli":"raṭṭhe attharaṇaṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"bv29:16.1":{"pli":"Araṇī ca mithilāyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"bv29:16.2":{"pli":"videhe parisāvanaṁ; ","html":"<span class='verse-line'>{}</span>"},"bv29:16.3":{"pli":"Vāsi sūcigharañcāpi, ","html":"<span class='verse-line'>{}</span>"},"bv29:16.4":{"pli":"indapatthapure tadā. ","html":"<span class='verse-line'>{}</span></p>"},"bv29:17.1":{"pli":"Parikkhārā avasesā, ","html":"<p><span class='verse-line'>{}</span>"},"bv29:17.2":{"pli":"janapade aparantake; ","html":"<span class='verse-line'>{}</span>"},"bv29:17.3":{"pli":"Paribhuttāni muninā, ","html":"<span class='verse-line'>{}</span>"},"bv29:17.4":{"pli":"akaṁsu manujā tadā. ","html":"<span class='verse-line'>{}</span></p>"},"bv29:18.1":{"pli":"Dhātuvitthārikaṁ āsi, ","html":"<p data-counter='10701'><span class='verse-line'>{}</span>"},"bv29:18.2":{"pli":"Gotamassa mahesino; ","html":"<span class='verse-line'>{}</span>"},"bv29:18.3":{"pli":"Pāṇīnaṁ anukampāya, ","html":"<span class='verse-line'>{}</span>"},"bv29:18.4":{"pli":"Ahu porāṇikaṁ tadāti. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"bv3":{"bv3:0.1":{"pli":"Buddhavaṁsa ","html":"<article id='bv3'><header><ul><li class='division'>{}</li></ul>"},"bv3:0.2":{"pli":"3. Dīpaṅkarabuddhavaṁsa ","html":"<h1 class='sutta-title'>{}</h1></header>"},"bv3:1.1":{"pli":"“Tadā te bhojayitvāna, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"bv3:1.2":{"pli":"sasaṅghaṁ lokanāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"bv3:1.3":{"pli":"Upagacchuṁ saraṇaṁ tassa, ","html":"<span class='verse-line'>{}</span>"},"bv3:1.4":{"pli":"dīpaṅkarassa satthuno. ","html":"<span class='verse-line'>{}</span></p>"},"bv3:2.1":{"pli":"Saraṇāgamane kañci, ","html":"<p><span class='verse-line'>{}</span>"},"bv3:2.2":{"pli":"nivesesi tathāgato; ","html":"<span class='verse-line'>{}</span>"},"bv3:2.3":{"pli":"Kañci pañcasu sīlesu, ","html":"<span class='verse-line'>{}</span>"},"bv3:2.4":{"pli":"sīle dasavidhe paraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"bv3:3.1":{"pli":"Kassaci deti sāmaññaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"bv3:3.2":{"pli":"caturo phalamuttame; ","html":"<span class='verse-line'>{}</span>"},"bv3:3.3":{"pli":"Kassaci asame dhamme, ","html":"<span class='verse-line'>{}</span>"},"bv3:3.4":{"pli":"deti so paṭisambhidā. ","html":"<span class='verse-line'>{}</span></p>"},"bv3:4.1":{"pli":"Kassaci varasamāpattiyo, ","html":"<p><span class='verse-line'>{}</span>"},"bv3:4.2":{"pli":"Aṭṭha deti narāsabho; ","html":"<span class='verse-line'>{}</span>"},"bv3:4.3":{"pli":"Tisso kassaci vijjāyo, ","html":"<span class='verse-line'>{}</span>"},"bv3:4.4":{"pli":"Chaḷabhiññā pavecchati. ","html":"<span class='verse-line'>{}</span></p>"},"bv3:5.1":{"pli":"Tena yogena janakāyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"bv3:5.2":{"pli":"ovadati mahāmuni; ","html":"<span class='verse-line'>{}</span>"},"bv3:5.3":{"pli":"Tena vitthārikaṁ āsi, ","html":"<span class='verse-line'>{}</span>"},"bv3:5.4":{"pli":"lokanāthassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"bv3:6.1":{"pli":"Mahāhanusabhakkhandho, ","html":"<p><span class='verse-line'>{}</span>"},"bv3:6.2":{"pli":"dīpaṅkarassa nāmako; ","html":"<span class='verse-line'>{}</span>"},"bv3:6.3":{"pli":"Bahū jane tārayati, ","html":"<span class='verse-line'>{}</span>"},"bv3:6.4":{"pli":"parimoceti duggatiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"bv3:7.1":{"pli":"Bodhaneyyaṁ janaṁ disvā, ","html":"<p><span class='verse-line'>{}</span>"},"bv3:7.2":{"pli":"satasahassepi yojane; ","html":"<span class='verse-line'>{}</span>"},"bv3:7.3":{"pli":"Khaṇena upagantvāna, ","html":"<span class='verse-line'>{}</span>"},"bv3:7.4":{"pli":"bodheti taṁ mahāmuni. ","html":"<span class='verse-line'>{}</span></p>"},"bv3:8.1":{"pli":"Paṭhamābhisamaye buddho, ","html":"<p><span class='verse-line'>{}</span>"},"bv3:8.2":{"pli":"koṭisatamabodhayi; ","html":"<span class='verse-line'>{}</span>"},"bv3:8.3":{"pli":"Dutiyābhisamaye nātho, ","html":"<span class='verse-line'>{}</span>"},"bv3:8.4":{"pli":"navutikoṭimabodhayi. ","html":"<span class='verse-line'>{}</span></p>"},"bv3:9.1":{"pli":"Yadā ca devabhavanamhi, ","html":"<p><span class='verse-line'>{}</span>"},"bv3:9.2":{"pli":"buddho dhammamadesayi; ","html":"<span class='verse-line'>{}</span>"},"bv3:9.3":{"pli":"Navutikoṭisahassānaṁ, ","html":"<span class='verse-line'>{}</span>"},"bv3:9.4":{"pli":"tatiyābhisamayo ahu. ","html":"<span class='verse-line'>{}</span></p>"},"bv3:10.1":{"pli":"Sannipātā tayo āsuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"bv3:10.2":{"pli":"dīpaṅkarassa satthuno; ","html":"<span class='verse-line'>{}</span>"},"bv3:10.3":{"pli":"Koṭisatasahassānaṁ, ","html":"<span class='verse-line'>{}</span>"},"bv3:10.4":{"pli":"paṭhamo āsi samāgamo. ","html":"<span class='verse-line'>{}</span></p>"},"bv3:11.1":{"pli":"Puna nāradakūṭamhi, ","html":"<p><span class='verse-line'>{}</span>"},"bv3:11.2":{"pli":"pavivekagate jine; ","html":"<span class='verse-line'>{}</span>"},"bv3:11.3":{"pli":"Khīṇāsavā vītamalā, ","html":"<span class='verse-line'>{}</span>"},"bv3:11.4":{"pli":"samiṁsu satakoṭiyo. ","html":"<span class='verse-line'>{}</span></p>"},"bv3:12.1":{"pli":"Yamhi kāle mahāvīro, ","html":"<p><span class='verse-line'>{}</span>"},"bv3:12.2":{"pli":"sudassanasiluccaye; ","html":"<span class='verse-line'>{}</span>"},"bv3:12.3":{"pli":"Navakoṭisahassehi, ","html":"<span class='verse-line'>{}</span>"},"bv3:12.4":{"pli":"pavāresi mahāmuni. ","html":"<span class='verse-line'>{}</span></p>"},"bv3:13.1":{"pli":"Dasavīsasahassānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"bv3:13.2":{"pli":"dhammābhisamayo ahu; ","html":"<span class='verse-line'>{}</span>"},"bv3:13.3":{"pli":"Ekadvinnaṁ abhisamayā, ","html":"<span class='verse-line'>{}</span>"},"bv3:13.4":{"pli":"gaṇanāto asaṅkhiyā. ","html":"<span class='verse-line'>{}</span></p>"},"bv3:14.1":{"pli":"Vitthārikaṁ bāhujaññaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"bv3:14.2":{"pli":"iddhaṁ phītaṁ ahū tadā; ","html":"<span class='verse-line'>{}</span>"},"bv3:14.3":{"pli":"Dīpaṅkarassa bhagavato, ","html":"<span class='verse-line'>{}</span>"},"bv3:14.4":{"pli":"sāsanaṁ suvisodhitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"bv3:15.1":{"pli":"Cattāri satasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"bv3:15.2":{"pli":"chaḷabhiññā mahiddhikā; ","html":"<span class='verse-line'>{}</span>"},"bv3:15.3":{"pli":"Dīpaṅkaraṁ lokaviduṁ, ","html":"<span class='verse-line'>{}</span>"},"bv3:15.4":{"pli":"parivārenti sabbadā. ","html":"<span class='verse-line'>{}</span></p>"},"bv3:16.1":{"pli":"Ye keci tena samayena, ","html":"<p><span class='verse-line'>{}</span>"},"bv3:16.2":{"pli":"jahanti mānusaṁ bhavaṁ; ","html":"<span class='verse-line'>{}</span>"},"bv3:16.3":{"pli":"Apattamānasā sekhā, ","html":"<span class='verse-line'>{}</span>"},"bv3:16.4":{"pli":"garahitā bhavanti te. ","html":"<span class='verse-line'>{}</span></p>"},"bv3:17.1":{"pli":"Supupphitaṁ pāvacanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"bv3:17.2":{"pli":"arahantehi tādihi; ","html":"<span class='verse-line'>{}</span>"},"bv3:17.3":{"pli":"Khīṇāsavehi vimalehi, ","html":"<span class='verse-line'>{}</span>"},"bv3:17.4":{"pli":"upasobhati sabbadā. ","html":"<span class='verse-line'>{}</span></p>"},"bv3:18.1":{"pli":"Nagaraṁ rammavatī nāma, ","html":"<p><span class='verse-line'>{}</span>"},"bv3:18.2":{"pli":"sudevo nāma khattiyo; ","html":"<span class='verse-line'>{}</span>"},"bv3:18.3":{"pli":"Sumedhā nāma janikā, ","html":"<span class='verse-line'>{}</span>"},"bv3:18.4":{"pli":"dīpaṅkarassa satthuno. ","html":"<span class='verse-line'>{}</span></p>"},"bv3:19.1":{"pli":"Dasavassasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"bv3:19.2":{"pli":"agāraṁ ajjha so vasi; ","html":"<span class='verse-line'>{}</span>"},"bv3:19.3":{"pli":"Haṁsā koñcā mayūrā ca, ","html":"<span class='verse-line'>{}</span>"},"bv3:19.4":{"pli":"tayo pāsādamuttamā. ","html":"<span class='verse-line'>{}</span></p>"},"bv3:20.1":{"pli":"Tīṇi satasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"bv3:20.2":{"pli":"nāriyo samalaṅkatā; ","html":"<span class='verse-line'>{}</span>"},"bv3:20.3":{"pli":"Padumā nāma sā nārī, ","html":"<span class='verse-line'>{}</span>"},"bv3:20.4":{"pli":"usabhakkhandho atrajo. ","html":"<span class='verse-line'>{}</span></p>"},"bv3:21.1":{"pli":"Nimitte caturo disvā, ","html":"<p><span class='verse-line'>{}</span>"},"bv3:21.2":{"pli":"hatthiyānena nikkhami; ","html":"<span class='verse-line'>{}</span>"},"bv3:21.3":{"pli":"Anūnadasamāsāni, ","html":"<span class='verse-line'>{}</span>"},"bv3:21.4":{"pli":"padhāne padahī jino. ","html":"<span class='verse-line'>{}</span></p>"},"bv3:22.1":{"pli":"Padhānacāraṁ caritvāna, ","html":"<p><span class='verse-line'>{}</span>"},"bv3:22.2":{"pli":"abujjhi mānasaṁ muni; ","html":"<span class='verse-line'>{}</span>"},"bv3:22.3":{"pli":"Brahmunā yācito santo, ","html":"<span class='verse-line'>{}</span>"},"bv3:22.4":{"pli":"dīpaṅkaro mahāmuni. ","html":"<span class='verse-line'>{}</span></p>"},"bv3:23.1":{"pli":"Vatti cakkaṁ mahāvīro, ","html":"<p><span class='verse-line'>{}</span>"},"bv3:23.2":{"pli":"nandārāme sirīghare; ","html":"<span class='verse-line'>{}</span>"},"bv3:23.3":{"pli":"Nisinno sirīsamūlamhi, ","html":"<span class='verse-line'>{}</span>"},"bv3:23.4":{"pli":"akā titthiyamaddanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"bv3:24.1":{"pli":"Sumaṅgalo ca tisso ca, ","html":"<p><span class='verse-line'>{}</span>"},"bv3:24.2":{"pli":"ahesuṁ aggasāvakā; ","html":"<span class='verse-line'>{}</span>"},"bv3:24.3":{"pli":"Sāgato nāmupaṭṭhāko, ","html":"<span class='verse-line'>{}</span>"},"bv3:24.4":{"pli":"dīpaṅkarassa satthuno. ","html":"<span class='verse-line'>{}</span></p>"},"bv3:25.1":{"pli":"Nandā ceva sunandā ca, ","html":"<p><span class='verse-line'>{}</span>"},"bv3:25.2":{"pli":"ahesuṁ aggasāvikā; ","html":"<span class='verse-line'>{}</span>"},"bv3:25.3":{"pli":"Bodhi tassa bhagavato, ","html":"<span class='verse-line'>{}</span>"},"bv3:25.4":{"pli":"pipphalīti pavuccati. ","html":"<span class='verse-line'>{}</span></p>"},"bv3:26.1":{"pli":"Tapussabhallikā nāma, ","html":"<p><span class='verse-line'>{}</span>"},"bv3:26.2":{"pli":"ahesuṁ aggupaṭṭhakā; ","html":"<span class='verse-line'>{}</span>"},"bv3:26.3":{"pli":"Sirimā koṇā upaṭṭhikā, ","html":"<span class='verse-line'>{}</span>"},"bv3:26.4":{"pli":"dīpaṅkarassa satthuno. ","html":"<span class='verse-line'>{}</span></p>"},"bv3:27.1":{"pli":"Asītihatthamubbedho, ","html":"<p><span class='verse-line'>{}</span>"},"bv3:27.2":{"pli":"dīpaṅkaro mahāmuni; ","html":"<span class='verse-line'>{}</span>"},"bv3:27.3":{"pli":"Sobhati dīparukkhova, ","html":"<span class='verse-line'>{}</span>"},"bv3:27.4":{"pli":"sālarājāva phullito. ","html":"<span class='verse-line'>{}</span></p>"},"bv3:28.1":{"pli":"Satasahassavassāni, ","html":"<p><span class='verse-line'>{}</span>"},"bv3:28.2":{"pli":"āyu tassa mahesino; ","html":"<span class='verse-line'>{}</span>"},"bv3:28.3":{"pli":"Tāvatā tiṭṭhamāno so, ","html":"<span class='verse-line'>{}</span>"},"bv3:28.4":{"pli":"tāresi janataṁ bahuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"bv3:29.1":{"pli":"Jotayitvāna saddhammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"bv3:29.2":{"pli":"santāretvā mahājanaṁ; ","html":"<span class='verse-line'>{}</span>"},"bv3:29.3":{"pli":"Jalitvā aggikkhandhova, ","html":"<span class='verse-line'>{}</span>"},"bv3:29.4":{"pli":"nibbuto so sasāvako. ","html":"<span class='verse-line'>{}</span></p>"},"bv3:30.1":{"pli":"Sā ca iddhi so ca yaso, ","html":"<p><span class='verse-line'>{}</span>"},"bv3:30.2":{"pli":"Tāni ca pādesu cakkaratanāni; ","html":"<span class='verse-line'>{}</span>"},"bv3:30.3":{"pli":"Sabbaṁ tamantarahitaṁ, ","html":"<span class='verse-line'>{}</span>"},"bv3:30.4":{"pli":"Nanu rittā sabbasaṅkhārā. ","html":"<span class='verse-line'>{}</span></p>"},"bv3:31.1":{"pli":"Dīpaṅkaro jino satthā, ","html":"<p data-counter='2991'><span class='verse-line'>{}</span>"},"bv3:31.2":{"pli":"Nandārāmamhi nibbuto; ","html":"<span class='verse-line'>{}</span>"},"bv3:31.3":{"pli":"Tatthevassa jinathūpo, ","html":"<span class='verse-line'>{}</span>"},"bv3:31.4":{"pli":"Chattiṁsubbedhayojano”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"bv3:32.1":{"pli":"Dīpaṅkarassa bhagavato vaṁso paṭhamo. ","html":"<p class='endsutta'>{}</p></article>"}}}