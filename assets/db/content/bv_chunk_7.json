ss='verse-line'>{}</span>"},"bv28:1.5":{"pli":"Dīpaṅkaro ca sambuddho, ","html":"<span class='verse-line'>{}</span>"},"bv28:1.6":{"pli":"ekakappamhi te jinā. ","html":"<span class='verse-line'>{}</span></p>"},"bv28:2.1":{"pli":"Dīpaṅkarassa aparena, ","html":"<p><span class='verse-line'>{}</span>"},"bv28:2.2":{"pli":"koṇḍañño nāma nāyako; ","html":"<span class='verse-line'>{}</span>"},"bv28:2.3":{"pli":"Ekova ekakappamhi, ","html":"<span class='verse-line'>{}</span>"},"bv28:2.4":{"pli":"tāresi janataṁ bahuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"bv28:3.1":{"pli":"Dīpaṅkarassa bhagavato, ","html":"<p><span class='verse-line'>{}</span>"},"bv28:3.2":{"pli":"koṇḍaññassa ca satthuno; ","html":"<span class='verse-line'>{}</span>"},"bv28:3.3":{"pli":"Etesaṁ antarā kappā, ","html":"<span class='verse-line'>{}</span>"},"bv28:3.4":{"pli":"gaṇanāto asaṅkhiyā. ","html":"<span class='verse-line'>{}</span></p>"},"bv28:4.1":{"pli":"Koṇḍaññassa aparena, ","html":"<p><span class='verse-line'>{}</span>"},"bv28:4.2":{"pli":"maṅgalo nāma nāyako; ","html":"<span class='verse-line'>{}</span>"},"bv28:4.3":{"pli":"Tesampi antarā kappā, ","html":"<span class='verse-line'>{}</span>"},"bv28:4.4":{"pli":"gaṇanāto asaṅkhiyā. ","html":"<span class='verse-line'>{}</span></p>"},"bv28:5.1":{"pli":"Maṅgalo ca sumano ca, ","html":"<p><span class='verse-line'>{}</span>"},"bv28:5.2":{"pli":"revato sobhito muni; ","html":"<span class='verse-line'>{}</span>"},"bv28:5.3":{"pli":"Tepi buddhā ekakappe, ","html":"<span class='verse-line'>{}</span>"},"bv28:5.4":{"pli":"cakkhumanto pabhaṅkarā. ","html":"<span class='verse-line'>{}</span></p>"},"bv28:6.1":{"pli":"Sobhitassa aparena, ","html":"<p><span class='verse-line'>{}</span>"},"bv28:6.2":{"pli":"anomadassī mahāyaso; ","html":"<span class='verse-line'>{}</span>"},"bv28:6.3":{"pli":"Tesampi antarā kappā, ","html":"<span class='verse-line'>{}</span>"},"bv28:6.4":{"pli":"gaṇanāto asaṅkhiyā. ","html":"<span class='verse-line'>{}</span></p>"},"bv28