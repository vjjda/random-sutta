"html":"<span class='verse-line'>{}</span>"},"bv28:12.4":{"pli":"dhammadassī ca nāyakā. ","html":"<span class='verse-line'>{}</span></p>"},"bv28:13.1":{"pli":"Orato ca sujātassa, ","html":"<p><span class='verse-line'>{}</span>"},"bv28:13.2":{"pli":"sambuddhā dvipaduttamā; ","html":"<span class='verse-line'>{}</span>"},"bv28:13.3":{"pli":"Ekakappamhi te buddhā, ","html":"<span class='verse-line'>{}</span>"},"bv28:13.4":{"pli":"loke appaṭipuggalā. ","html":"<span class='verse-line'>{}</span></p>"},"bv28:14.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"bv28:14.2":{"pli":"eko āsi mahāmuni; ","html":"<span class='verse-line'>{}</span>"},"bv28:14.3":{"pli":"Siddhattho so lokavidū, ","html":"<span class='verse-line'>{}</span>"},"bv28:14.4":{"pli":"sallakatto anuttaro. ","html":"<span class='verse-line'>{}</span></p>"},"bv28:15.1":{"pli":"Dvenavute ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"bv28:15.2":{"pli":"duve āsuṁ vināyakā; ","html":"<span class='verse-line'>{}</span>"},"bv28:15.3":{"pli":"Tisso phusso ca sambuddhā, ","html":"<span class='verse-line'>{}</span>"},"bv28:15.4":{"pli":"asamā appaṭipuggalā. ","html":"<span class='verse-line'>{}</span></p>"},"bv28:16.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"bv28:16.2":{"pli":"vipassī nāma nāyako; ","html":"<span class='verse-line'>{}</span>"},"bv28:16.3":{"pli":"Sopi buddho kāruṇiko, ","html":"<span class='verse-line'>{}</span>"},"bv28:16.4":{"pli":"satte mocesi bandhanā. ","html":"<span class='verse-line'>{}</span></p>"},"bv28:17.1":{"pli":"Ekatiṁse ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"bv28:17.2":{"pli":"duve āsuṁ vināyakā; ","html":"<span class='verse-line'>{}</span>"},"bv28:17.3":{"pli":"Sikhī ca vessabhū ceva, ","html":"<span class='verse-line'>{}</span>"},"bv28:17.4":{"pli":"asamā appaṭipuggalā. ","html":"<span class='verse-line'>{}</span></p>"},"bv28:18.1":{"pli":"Imamhi bhaddake kappe, ","html":"<p>