{"bv27":{"bv27:0.1":{"pli":"Buddhavaṁsa ","html":"<article id='bv27'><header><ul><li class='division'>{}</li></ul>"},"bv27:0.2":{"pli":"27. Gotamabuddhavaṁsa ","html":"<h1 class='sutta-title'>{}</h1></header>"},"bv27:1.1":{"pli":"“Ahametarahi sambuddho, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"bv27:1.2":{"pli":"gotamo sakyavaḍḍhano; ","html":"<span class='verse-line'>{}</span>"},"bv27:1.3":{"pli":"Padhānaṁ padahitvāna, ","html":"<span class='verse-line'>{}</span>"},"bv27:1.4":{"pli":"patto sambodhimuttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"bv27:2.1":{"pli":"Brahmunā yācito santo, ","html":"<p><span class='verse-line'>{}</span>"},"bv27:2.2":{"pli":"dhammacakkaṁ pavattayiṁ; ","html":"<span class='verse-line'>{}</span>"},"bv27:2.3":{"pli":"Aṭṭhārasannaṁ koṭīnaṁ, ","html":"<span class='verse-line'>{}</span>"},"bv27:2.4":{"pli":"paṭhamābhisamayo ahu. ","html":"<span class='verse-line'>{}</span></p>"},"bv27:3.1":{"pli":"Tato parañca desente, ","html":"<p><span class='verse-line'>{}</span>"},"bv27:3.2":{"pli":"naradevasamāgame; ","html":"<span class='verse-line'>{}</span>"},"bv27:3.3":{"pli":"Gaṇanāya na vattabbo, ","html":"<span class='verse-line'>{}</span>"},"bv27:3.4":{"pli":"dutiyābhisamayo ahu. ","html":"<span class='verse-line'>{}</span></p>"},"bv27:4.1":{"pli":"Idhevāhaṁ etarahi, ","html":"<p><span class='verse-line'>{}</span>"},"bv27:4.2":{"pli":"ovadiṁ mama atrajaṁ; ","html":"<span class='verse-line'>{}</span>"},"bv27:4.3":{"pli":"Gaṇanāya na vattabbo, ","html":"<span class='verse-line'>{}</span>"},"bv27:4.4":{"pli":"tatiyābhisamayo ahu. ","html":"<span class='verse-line'>{}</span></p>"},"bv27:5.1":{"pli":"Ekosi sannipāto me, ","html":"<p><span class='verse-line'>{}</span>"},"bv27:5.2":{"pli":"sāvakānaṁ mahesinaṁ; ","html":"<span class='verse-line'>{}</span>"},"bv27:5.3":{"pli":"Aḍḍhateḷasasatānaṁ, ","html":"<span class='verse-line'>{}</span>"},"bv27:5.4":{"pli":"bhikkhūnāsi samāgamo. ","html":"<span class='ve