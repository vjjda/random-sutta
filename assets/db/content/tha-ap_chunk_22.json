{"tha-ap336":{"tha-ap336:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap336'><header><ul><li class='division'>{}</li>"},"tha-ap336:0.2":{"pli":"Gandhodakavagga ","html":"<li>{}</li></ul>"},"tha-ap336:0.3":{"pli":"Ekadussadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap336:1.1":{"pli":"“Nagare haṁsavatiyā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap336:1.2":{"pli":"ahosiṁ tiṇahārako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:1.3":{"pli":"Tiṇahārena jīvāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:1.4":{"pli":"tena posemi dārake. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap336:2.1":{"pli":"Padumuttaro nāma jino, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap336:2.2":{"pli":"sabbadhammāna pāragū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:2.3":{"pli":"Tamandhakāraṁ nāsetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:2.4":{"pli":"uppajji lokanāyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap336:3.1":{"pli":"Sake ghare nisīditvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap336:3.2":{"pli":"evaṁ cintesahaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:3.3":{"pli":"‘Buddho loke samuppanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:3.4":{"pli":"deyyadhammo ca natthi me. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap336:4.1":{"pli":"Idaṁ me sāṭakaṁ ekaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap336:4.2":{"pli":"natthi me koci dāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:4.3":{"pli":"Dukkho nirayasamphasso, ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:4.4":{"pli":"ropayissāmi dakkhiṇaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap336:5.1":{"pli":"Evāhaṁ cintayitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap336:5.2":{"pli":"sakaṁ cittaṁ pasādayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:5.3":{"pli":"Ekaṁ dussaṁ gahetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:5.4":{"pli":"buddhaseṭṭhassadāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap336:6.1":{"pli":"Ekaṁ dussaṁ daditvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap336:6.2":{"pli":"ukkuṭṭhiṁ sampavattayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:6.3":{"pli":"Yadi buddho tuvaṁ vīra, ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:6.4":{"pli":"tārehi maṁ mahāmuni. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap336:7.1":{"pli":"Padumuttaro lokavidū, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap336:7.2":{"pli":"āhutīnaṁ paṭiggaho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:7.3":{"pli":"Mama dānaṁ pakittento, ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:7.4":{"pli":"akā me anumodanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap336:8.1":{"pli":"‘Iminā ekadussena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap336:8.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:8.3":{"pli":"Kappasatasahassāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:8.4":{"pli":"vinipātaṁ na gacchati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap336:9.1":{"pli":"Chattiṁsakkhattuṁ devindo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap336:9.2":{"pli":"devarajjaṁ karissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:9.3":{"pli":"Tettiṁsakkhattuṁ rājā ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:9.4":{"pli":"cakkavattī bhavissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:9.5":{"pli":"Padesarajjaṁ vipulaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:9.6":{"pli":"gaṇanāto asaṅkhiyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap336:10.1":{"pli":"Devaloke manusse vā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap336:10.2":{"pli":"saṁsaranto tuvaṁ bhave; ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:10.3":{"pli":"Rūpavā guṇasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:10.4":{"pli":"anavakkantadehavā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:10.5":{"pli":"Akkhobhaṁ amitaṁ dussaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:10.6":{"pli":"labhissati yadicchakaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap336:11.1":{"pli":"Idaṁ vatvāna sambuddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap336:11.2":{"pli":"jalajuttamanāmako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:11.3":{"pli":"Nabhaṁ abbhuggamī dhīro, ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:11.4":{"pli":"haṁsarājāva ambare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap336:12.1":{"pli":"Yaṁ yaṁ yonupapajjāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap336:12.2":{"pli":"devattaṁ atha mānusaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:12.3":{"pli":"Bhoge me ūnatā natthi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:12.4":{"pli":"ekadussassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap336:13.1":{"pli":"Paduddhāre paduddhāre, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap336:13.2":{"pli":"dussaṁ nibbattate mamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:13.3":{"pli":"Heṭṭhā dussamhi tiṭṭhāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:13.4":{"pli":"upari chadanaṁ mama. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap336:14.1":{"pli":"Cakkavāḷamupādāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap336:14.2":{"pli":"sakānanaṁ sapabbataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:14.3":{"pli":"Icchamāno cahaṁ ajja, ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:14.4":{"pli":"dussehi chādayeyyahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap336:15.1":{"pli":"Teneva ekadussena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap336:15.2":{"pli":"saṁsaranto bhavābhave; ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:15.3":{"pli":"Suvaṇṇavaṇṇo hutvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:15.4":{"pli":"saṁsarāmi bhavābhave. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap336:16.1":{"pli":"Vipākaṁ ekadussassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap336:16.2":{"pli":"najjhagaṁ katthacikkhayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:16.3":{"pli":"Ayaṁ me antimā jāti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:16.4":{"pli":"vipaccati idhāpi me. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap336:17.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap336:17.2":{"pli":"yaṁ dussamadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:17.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:17.4":{"pli":"ekadussassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap336:18.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap336:18.2":{"pli":"bhavā sabbe samūhatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:18.3":{"pli":"Nāgova bandhanaṁ chetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:18.4":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap336:19.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap336:19.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap336:19.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap336:20.1":{"pli":"Itthaṁ sudaṁ āyasmā ekadussadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap336:21.1":{"pli":"Ekadussadāyakattherassāpadānaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap337":{"tha-ap337:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap337'><header><ul><li class='division'>{}</li>"},"tha-ap337:0.2":{"pli":"Gandhodakavagga ","html":"<li>{}</li></ul>"},"tha-ap337:0.3":{"pli":"5 Phusitakampiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap337:1.1":{"pli":"“Vipassī nāma sambuddho, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap337:1.2":{"pli":"lokajeṭṭho narāsabho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap337:1.3":{"pli":"Khīṇāsavehi sahito, ","html":"<span class='verse-line'>{}</span>"},"tha-ap337:1.4":{"pli":"saṅghārāme vasī tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap337:2.1":{"pli":"Ārāmadvārā nikkhamma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap337:2.2":{"pli":"vipassī lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap337:2.3":{"pli":"Saha satasahassehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap337:2.4":{"pli":"aṭṭha khīṇāsavehi so. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap337:3.1":{"pli":"Ajinena nivatthohaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap337:3.2":{"pli":"vākacīradharopi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap337:3.3":{"pli":"Kusumodakamādāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap337:3.4":{"pli":"sambuddhaṁ upasaṅkamiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap337:4.1":{"pli":"Sakaṁ cittaṁ pasādetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap337:4.2":{"pli":"vedajāto katañjalī; ","html":"<span class='verse-line'>{}</span>"},"tha-ap337:4.3":{"pli":"Kusumodakamādāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap337:4.4":{"pli":"buddhamabbhukkiriṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap337:5.1":{"pli":"Tena kammena sambuddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap337:5.2":{"pli":"jalajuttamanāmako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap337:5.3":{"pli":"Mama kammaṁ pakittetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap337:5.4":{"pli":"agamā yena patthitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap337:6.1":{"pli":"Phusitā pañcasahassā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap337:6.2":{"pli":"yehi pūjesahaṁ jinaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap337:6.3":{"pli":"Aḍḍhateyyasahassehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap337:6.4":{"pli":"devarajjaṁ akārayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap337:7.1":{"pli":"Aḍḍhateyyasahassehi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap337:7.2":{"pli":"cakkavattī ahosahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap337:7.3":{"pli":"Avasesena kammena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap337:7.4":{"pli":"arahattamapāpuṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap337:8.1":{"pli":"Devarājā yadā homi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap337:8.2":{"pli":"manujādhipatī yadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap337:8.3":{"pli":"Tameva nāmadheyyaṁ me, ","html":"<span class='verse-line'>{}</span>"},"tha-ap337:8.4":{"pli":"phusito nāma homahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap337:9.1":{"pli":"Devabhūtassa santassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap337:9.2":{"pli":"athāpi mānusassa vā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap337:9.3":{"pli":"Samantā byāmato mayhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap337:9.4":{"pli":"phusitaṁva pavassati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap337:10.1":{"pli":"Bhavā ugghāṭitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap337:10.2":{"pli":"kilesā jhāpitā mama; ","html":"<span class='verse-line'>{}</span>"},"tha-ap337:10.3":{"pli":"Sabbāsavaparikkhīṇo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap337:10.4":{"pli":"phusitassa idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap337:11.1":{"pli":"Candanasseva me kāyā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap337:11.2":{"pli":"tathā gandho pavāyati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap337:11.3":{"pli":"Sarīrato mama gandho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap337:11.4":{"pli":"aḍḍhakose pavāyati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap337:12.1":{"pli":"Dibbagandhaṁ sampavantaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap337:12.2":{"pli":"puññakammasamaṅginaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap337:12.3":{"pli":"Gandhaṁ ghatvāna jānanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap337:12.4":{"pli":"phusito āgato idha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap337:13.1":{"pli":"Sākhāpalāsakaṭṭhāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap337:13.2":{"pli":"tiṇānipi ca sabbaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap337:13.3":{"pli":"Mama saṅkappamaññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap337:13.4":{"pli":"gandho sampajjate khaṇe. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap337:14.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap337:14.2":{"pli":"candanaṁ abhipūjayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap337:14.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap337:14.4":{"pli":"phusitassa idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap337:15.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap337:15.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap337:15.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap337:16.1":{"pli":"Itthaṁ sudaṁ āyasmā phusitakampiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap337:17.1":{"pli":"Phusitakampiyattherassāpadānaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap338":{"tha-ap338:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap338'><header><ul><li class='division'>{}</li>"},"tha-ap338:0.2":{"pli":"Gandhodakavagga ","html":"<li>{}</li></ul>"},"tha-ap338:0.3":{"pli":"Pabhaṅkarattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap338:1.1":{"pli":"“Padumuttarabhagavato, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap338:1.2":{"pli":"lokajeṭṭhassa tādino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:1.3":{"pli":"Vipine cetiyaṁ āsi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:1.4":{"pli":"vāḷamigasamākule. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap338:2.1":{"pli":"Na koci visahi gantuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap338:2.2":{"pli":"cetiyaṁ abhivandituṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:2.3":{"pli":"Tiṇakaṭṭhalatonaddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:2.4":{"pli":"paluggaṁ āsi cetiyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap338:3.1":{"pli":"Vanakammiko tadā āsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap338:3.2":{"pli":"pitumātumatenahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:3.3":{"pli":"Addasaṁ vipine thūpaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:3.4":{"pli":"luggaṁ tiṇalatākulaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap338:4.1":{"pli":"Disvānāhaṁ buddhathūpaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap338:4.2":{"pli":"garucittaṁ upaṭṭhahiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:4.3":{"pli":"Buddhaseṭṭhassa thūpoyaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:4.4":{"pli":"paluggo acchatī vane. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap338:5.1":{"pli":"Nacchannaṁ nappatirūpaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap338:5.2":{"pli":"jānantassa guṇāguṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:5.3":{"pli":"Buddhathūpaṁ asodhetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:5.4":{"pli":"aññaṁ kammaṁ payojaye. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap338:6.1":{"pli":"Tiṇakaṭṭhañca valliñca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap338:6.2":{"pli":"sodhayitvāna cetiye; ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:6.3":{"pli":"Vanditvā aṭṭha vārāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:6.4":{"pli":"paṭikuṭiko agacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap338:7.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap338:7.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:7.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:7.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap338:8.1":{"pli":"Tattha me sukataṁ byamhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap338:8.2":{"pli":"sovaṇṇaṁ sapabhassaraṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:8.3":{"pli":"Saṭṭhiyojanamubbiddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:8.4":{"pli":"tiṁsayojanavitthataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap338:9.1":{"pli":"Tisatāni ca vārāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap338:9.2":{"pli":"devarajjamakārayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:9.3":{"pli":"Pañcavīsatikkhattuñca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:9.4":{"pli":"cakkavattī ahosahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap338:10.1":{"pli":"Bhavābhave saṁsaranto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap338:10.2":{"pli":"mahābhogaṁ labhāmahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:10.3":{"pli":"Bhoge me ūnatā natthi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:10.4":{"pli":"sodhanāya idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap338:11.1":{"pli":"Sivikā hatthikhandhena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap338:11.2":{"pli":"vipine gacchato mama; ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:11.3":{"pli":"Yaṁ yaṁ disāhaṁ gacchāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:11.4":{"pli":"saraṇaṁ sampate vanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap338:12.1":{"pli":"Khāṇuṁ vā kaṇṭakaṁ vāpi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap338:12.2":{"pli":"nāhaṁ passāmi cakkhunā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:12.3":{"pli":"Puññakammena saṁyutto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:12.4":{"pli":"sayamevāpanīyare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap338:13.1":{"pli":"Kuṭṭhaṁ gaṇḍo kilāso ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap338:13.2":{"pli":"apamāro vitacchikā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:13.3":{"pli":"Daddu kacchu ca me natthi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:13.4":{"pli":"sodhanāya idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap338:14.1":{"pli":"Aññampi me acchariyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap338:14.2":{"pli":"buddhathūpassa sodhane; ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:14.3":{"pli":"Nābhijānāmi me kāye, ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:14.4":{"pli":"jātaṁ piḷakabindukaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap338:15.1":{"pli":"Aññampi me acchariyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap338:15.2":{"pli":"buddhathūpamhi sodhite; ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:15.3":{"pli":"Duve bhave saṁsarāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:15.4":{"pli":"devatte atha mānuse. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap338:16.1":{"pli":"Aññampi me acchariyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap338:16.2":{"pli":"buddhathūpamhi sodhite; ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:16.3":{"pli":"Suvaṇṇavaṇṇo sabbattha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:16.4":{"pli":"sappabhāso bhavāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap338:17.1":{"pli":"Aññampi me acchariyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap338:17.2":{"pli":"buddhathūpamhi sodhite; ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:17.3":{"pli":"Amanāpaṁ vivajjati, ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:17.4":{"pli":"manāpaṁ upatiṭṭhati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap338:18.1":{"pli":"Aññampi me acchariyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap338:18.2":{"pli":"buddhathūpamhi sodhite; ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:18.3":{"pli":"Visuddhaṁ hoti me cittaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:18.4":{"pli":"ekaggaṁ susamāhitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap338:19.1":{"pli":"Aññampi me acchariyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap338:19.2":{"pli":"buddhathūpamhi sodhite; ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:19.3":{"pli":"Ekāsane nisīditvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:19.4":{"pli":"arahattamapāpuṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap338:20.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap338:20.2":{"pli":"yaṁ kammamakariṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:20.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:20.4":{"pli":"sodhanāya idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap338:21.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap338:21.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap338:21.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap338:22.1":{"pli":"Itthaṁ sudaṁ āyasmā pabhaṅkaro thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap338:23.1":{"pli":"Pabhaṅkarattherassāpadānaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap339":{"tha-ap339:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap339'><header><ul><li class='division'>{}</li>"},"tha-ap339:0.2":{"pli":"Gandhodakavagga ","html":"<li>{}</li></ul>"},"tha-ap339:0.3":{"pli":"Tiṇakuṭidāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap339:1.1":{"pli":"“Nagare bandhumatiyā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap339:1.2":{"pli":"ahosiṁ parakammiko; ","html":"<span class='verse-line'>{}</span>"},"tha-ap339:1.3":{"pli":"Parakammāyane yutto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap339:1.4":{"pli":"parabhattaṁ apassito. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap339:2.1":{"pli":"Rahogato nisīditvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap339:2.2":{"pli":"evaṁ cintesahaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap339:2.3":{"pli":"Buddho loke samuppanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap339:2.4":{"pli":"adhikāro ca natthi me. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap339:3.1":{"pli":"Kālo me gatiṁ sodhetuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap339:3.2":{"pli":"khaṇo me paṭipādito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap339:3.3":{"pli":"Dukkho nirayasamphasso, ","html":"<span class='verse-line'>{}</span>"},"tha-ap339:3.4":{"pli":"apuññānañhi pāṇinaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap339:4.1":{"pli":"Evāhaṁ cintayitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap339:4.2":{"pli":"kammasāmiṁ upāgamiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap339:4.3":{"pli":"Ekāhaṁ kammaṁ yācitvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap339:4.4":{"pli":"vipinaṁ pāvisiṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap339:5.1":{"pli":"Tiṇakaṭṭhañca valliñca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap339:5.2":{"pli":"āharitvānahaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap339:5.3":{"pli":"Tidaṇḍake ṭhapetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap339:5.4":{"pli":"akaṁ tiṇakuṭiṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap339:6.1":{"pli":"Saṅghassatthāya kuṭikaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap339:6.2":{"pli":"niyyādetvāna taṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap339:6.3":{"pli":"Tadaheyeva āgantvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap339:6.4":{"pli":"kammasāmiṁ upāgamiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap339:7.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap339:7.2":{"pli":"tāvatiṁsamagacchahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap339:7.3":{"pli":"Tattha me sukataṁ byamhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap339:7.4":{"pli":"kuṭikāya sunimmitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap339:8.1":{"pli":"Sahassakaṇḍaṁ satabheṇḍu, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap339:8.2":{"pli":"dhajālu haritāmayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap339:8.3":{"pli":"Satasahassaniyyūhā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap339:8.4":{"pli":"byamhe pātubhaviṁsu me. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap339:9.1":{"pli":"Yaṁ yaṁ yonupapajjāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap339:9.2":{"pli":"devattaṁ atha mānusaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap339:9.3":{"pli":"Mama saṅkappamaññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap339:9.4":{"pli":"pāsādo upatiṭṭhati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap339:10.1":{"pli":"Bhayaṁ vā chambhitattaṁ vā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap339:10.2":{"pli":"lomahaṁso na vijjati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap339:10.3":{"pli":"Tāsaṁ mama na jānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap339:10.4":{"pli":"tiṇakuṭikāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap339:11.1":{"pli":"Sīhabyagghā ca dīpī ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap339:11.2":{"pli":"acchakokataracchakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap339:11.3":{"pli":"Sabbe maṁ parivajjenti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap339:11.4":{"pli":"tiṇakuṭikāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap339:12.1":{"pli":"Sarīsapā ca bhūtā ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap339:12.2":{"pli":"ahī kumbhaṇḍarakkhasā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap339:12.3":{"pli":"Tepi maṁ parivajjenti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap339:12.4":{"pli":"tiṇakuṭikāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap339:13.1":{"pli":"Na pāpasupinassāpi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap339:13.2":{"pli":"sarāmi dassanaṁ mama; ","html":"<span class='verse-line'>{}</span>"},"tha-ap339:13.3":{"pli":"Upaṭṭhitā sati mayhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap339:13.4":{"pli":"tiṇakuṭikāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap339:14.1":{"pli":"Tāyeva tiṇakuṭikāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap339:14.2":{"pli":"anubhotvāna sampadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap339:14.3":{"pli":"Gotamassa bhagavato, ","html":"<span class='verse-line'>{}</span>"},"tha-ap339:14.4":{"pli":"dhammaṁ sacchikariṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap339:15.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap339:15.2":{"pli":"yaṁ kammamakariṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap339:15.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap339:15.4":{"pli":"tiṇakuṭikāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap339:16.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap339:16.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap339:16.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap339:17.1":{"pli":"Itthaṁ sudaṁ āyasmā tiṇakuṭidāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap339:18.1":{"pli":"Tiṇakuṭidāyakattherassāpadānaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap34":{"tha-ap34:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap34'><header><ul><li class='division'>{}</li>"},"tha-ap34:0.2":{"pli":"Kuṇḍadhānavagga ","html":"<li>{}</li></ul>"},"tha-ap34:0.3":{"pli":"Sāgatattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap34:1.1":{"pli":"“Sobhito nāma nāmena, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap34:1.2":{"pli":"ahosiṁ brāhmaṇo tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap34:1.3":{"pli":"Purakkhato sasissehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap34:1.4":{"pli":"ārāmaṁ agamāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap34:2.1":{"pli":"Bhagavā tamhi samaye, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap34:2.2":{"pli":"bhikkhusaṅghapurakkhato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap34:2.3":{"pli":"Ārāmadvārā nikkhamma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap34:2.4":{"pli":"aṭṭhāsi purisuttamo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap34:3.1":{"pli":"Tamaddasāsiṁ sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap34:3.2":{"pli":"dantaṁ dantapurakkhataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap34:3.3":{"pli":"Sakaṁ cittaṁ pasādetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap34:3.4":{"pli":"santhaviṁ lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap34:4.1":{"pli":"Ye keci pādapā sabbe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap34:4.2":{"pli":"mahiyā te virūhare; ","html":"<span class='verse-line'>{}</span>"},"tha-ap34:4.3":{"pli":"Buddhimanto tathā sattā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap34:4.4":{"pli":"ruhanti jinasāsane. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap34:5.1":{"pli":"Satthavāhosi sappañño, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap34:5.2":{"pli":"mahesi bahuke jane; ","html":"<span class='verse-line'>{}</span>"},"tha-ap34:5.3":{"pli":"Vipathā uddharitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap34:5.4":{"pli":"pathaṁ ācikkhase tuvaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap34:6.1":{"pli":"Danto dantaparikiṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap34:6.2":{"pli":"jhāyī jhānaratehi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap34:6.3":{"pli":"Ātāpī pahitattehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap34:6.4":{"pli":"upasantehi tādibhi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap34:7.1":{"pli":"Alaṅkato parisāhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap34:7.2":{"pli":"puññañāṇehi sobhati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap34:7.3":{"pli":"Pabhā niddhāvate tuyhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap34:7.4":{"pli":"sūriyodayane yathā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap34:8.1":{"pli":"Pasannacittaṁ disvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap34:8.2":{"pli":"mahesī padumuttaro; ","html":"<span class='verse-line'>{}</span>"},"tha-ap34:8.3":{"pli":"Bhikkhusaṅghe ṭhito satthā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap34:8.4":{"pli":"imā gāthā abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap34:9.1":{"pli":"‘Yo so hāsaṁ janetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap34:9.2":{"pli":"mamaṁ kittesi brāhmaṇo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap34:9.3":{"pli":"Kappānaṁ satasahassaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap34:9.4":{"pli":"devaloke ramissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap34:10.1":{"pli":"Tusitā hi cavitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap34:10.2":{"pli":"sukkamūlena codito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap34:10.3":{"pli":"Gotamassa bhagavato, ","html":"<span class='verse-line'>{}</span>"},"tha-ap34:10.4":{"pli":"sāsane pabbajissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap34:11.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap34:11.2":{"pli":"arahattaṁ labhissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap34:11.3":{"pli":"Sāgato nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap34:11.4":{"pli":"hessati satthu sāvako’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap34:12.1":{"pli":"Pabbajitvāna kāyena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap34:12.2":{"pli":"pāpakammaṁ vivajjayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap34:12.3":{"pli":"Vacīduccaritaṁ hitvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap34:12.4":{"pli":"ājīvaṁ parisodhayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap34:13.1":{"pli":"Evaṁ viharamānohaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap34:13.2":{"pli":"tejodhātūsu kovido; ","html":"<span class='verse-line'>{}</span>"},"tha-ap34:13.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap34:13.4":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap34:14.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap34:14.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap34:14.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap34:15.1":{"pli":"Itthaṁ sudaṁ āyasmā sāgato thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap34:16.1":{"pli":"Sāgatattherassāpadānaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap340":{"tha-ap340:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap340'><header><ul><li class='division'>{}</li>"},"tha-ap340:0.2":{"pli":"Gandhodakavagga ","html":"<li>{}</li></ul>"},"tha-ap340:0.3":{"pli":"Uttareyyadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap340:1.1":{"pli":"“Nagare haṁsavatiyā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap340:1.2":{"pli":"ahosiṁ brāhmaṇo tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:1.3":{"pli":"Ajjhāyako mantadharo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:1.4":{"pli":"tiṇṇaṁ vedāna pāragū. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap340:2.1":{"pli":"Purakkhato sasissehi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap340:2.2":{"pli":"jātimā ca susikkhito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:2.3":{"pli":"Toyābhisecanatthāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:2.4":{"pli":"nagarā nikkhamiṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap340:3.1":{"pli":"Padumuttaro nāma jino, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap340:3.2":{"pli":"sabbadhammāna pāragū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:3.3":{"pli":"Khīṇāsavasahassehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:3.4":{"pli":"pāvisī nagaraṁ jino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap340:4.1":{"pli":"Sucārurūpaṁ disvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap340:4.2":{"pli":"āneñjakāritaṁ viya; ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:4.3":{"pli":"Parivutaṁ arahantehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:4.4":{"pli":"disvā cittaṁ pasādayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap340:5.1":{"pli":"Sirasmiṁ añjaliṁ katvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap340:5.2":{"pli":"namassitvāna subbataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:5.3":{"pli":"Pasannacitto sumano, ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:5.4":{"pli":"uttarīyamadāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap340:6.1":{"pli":"Ubho hatthehi paggayha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap340:6.2":{"pli":"sāṭakaṁ ukkhipiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:6.3":{"pli":"Yāvatā buddhaparisā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:6.4":{"pli":"tāva chādesi sāṭako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap340:7.1":{"pli":"Piṇḍacāraṁ carantassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap340:7.2":{"pli":"mahābhikkhugaṇādino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:7.3":{"pli":"Chadaṁ karonto aṭṭhāsi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:7.4":{"pli":"hāsayanto mamaṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap340:8.1":{"pli":"Gharato nikkhamantassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap340:8.2":{"pli":"sayambhū aggapuggalo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:8.3":{"pli":"Vīthiyaṁva ṭhito satthā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:8.4":{"pli":"akā me anumodanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap340:9.1":{"pli":"Pasannacitto sumano, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap340:9.2":{"pli":"yo me adāsi sāṭakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:9.3":{"pli":"Tamahaṁ kittayissāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:9.4":{"pli":"suṇotha mama bhāsato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap340:10.1":{"pli":"‘Tiṁsakappasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap340:10.2":{"pli":"devaloke ramissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:10.3":{"pli":"Paññāsakkhattuṁ devindo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:10.4":{"pli":"devarajjaṁ karissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap340:11.1":{"pli":"Devaloke vasantassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap340:11.2":{"pli":"puññakammasamaṅgino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:11.3":{"pli":"Samantā yojanasataṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:11.4":{"pli":"dussacchannaṁ bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap340:12.1":{"pli":"Chattiṁsakkhattuṁ rājā ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap340:12.2":{"pli":"cakkavattī bhavissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:12.3":{"pli":"Padesarajjaṁ vipulaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:12.4":{"pli":"gaṇanāto asaṅkhiyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap340:13.1":{"pli":"Bhave saṁsaramānassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap340:13.2":{"pli":"puññakammasamaṅgino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:13.3":{"pli":"Manasā patthitaṁ sabbaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:13.4":{"pli":"nibbattissati tāvade. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap340:14.1":{"pli":"Koseyyakambaliyāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap340:14.2":{"pli":"khomakappāsikāni ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:14.3":{"pli":"Mahagghāni ca dussāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:14.4":{"pli":"paṭilacchatiyaṁ naro. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap340:15.1":{"pli":"Manasā patthitaṁ sabbaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap340:15.2":{"pli":"paṭilacchatiyaṁ naro; ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:15.3":{"pli":"Ekadussassa vipākaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:15.4":{"pli":"anubhossati sabbadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap340:16.1":{"pli":"So pacchā pabbajitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap340:16.2":{"pli":"sukkamūlena codito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:16.3":{"pli":"Gotamassa bhagavato, ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:16.4":{"pli":"dhammaṁ sacchikarissati’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap340:17.1":{"pli":"Aho me sukataṁ kammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap340:17.2":{"pli":"sabbaññussa mahesino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:17.3":{"pli":"Ekāhaṁ sāṭakaṁ datvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:17.4":{"pli":"pattomhi amataṁ padaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap340:18.1":{"pli":"Maṇḍape rukkhamūle vā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap340:18.2":{"pli":"vasato suññake ghare; ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:18.3":{"pli":"Dhāreti dussachadanaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:18.4":{"pli":"samantā byāmato mama. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap340:19.1":{"pli":"Aviññattaṁ nivāsemi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap340:19.2":{"pli":"cīvaraṁ paccayañcahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:19.3":{"pli":"Lābhī annassa pānassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:19.4":{"pli":"uttareyyassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap340:20.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap340:20.2":{"pli":"yaṁ kammamakariṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:20.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:20.4":{"pli":"vatthadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap340:21.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap340:21.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap340:21.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap340:22.1":{"pli":"Itthaṁ sudaṁ āyasmā uttareyyadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap340:23.1":{"pli":"Uttareyyadāyakattherassāpadānaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}