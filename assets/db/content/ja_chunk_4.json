{"ja230":{"ja230:0.1":{"pli":"Jātaka ","html":"<article id='ja230'><header><ul><li class='division'>{}</li>"},"ja230:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja230:0.3":{"pli":"Kāsāvavagga ","html":"<li>{}</li></ul>"},"ja230:0.4":{"pli":"10. Dutiyapalāyitajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja230:1.1":{"pli":"“Dhajamaparimitaṁ anantapāraṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja230:1.2":{"pli":"Duppasahaṁ dhaṅkehi sāgaraṁva; ","html":"<span class='verse-line'>{}</span>"},"ja230:1.3":{"pli":"Girimiva anilena duppasayho, ","html":"<span class='verse-line'>{}</span>"},"ja230:1.4":{"pli":"Duppasaho ahamajjatādisena”. ","html":"<span class='verse-line'>{}</span></p>"},"ja230:2.1":{"pli":"“Mā bāliyaṁ vilapi na hissa tādisaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja230:2.2":{"pli":"Viḍayhase na hi labhase nisedhakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja230:2.3":{"pli":"Āsajjasi gajamiva ekacārinaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja230:2.4":{"pli":"Yo taṁ padā naḷamiva pothayissatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja230:3.1":{"pli":"Dutiyapalāyitajātakaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja230:3.2":{"pli":"Kāsāvavaggo aṭṭhamo. ","html":"<p class='endvagga'>{}</p>"},"ja230:4.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja230:5.1":{"pli":"Varavatthavaco dumakhīṇaphalaṁ, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja230:5.2":{"pli":"Caturodhammavaraṁ purisuttama; ","html":"<span class='verse-line'>{}</span>"},"ja230:5.3":{"pli":"Dhaṅkamagadhā ca tayogirināma, ","html":"<span class='verse-line'>{}</span>"},"ja230:5.4":{"pli":"Gajaggavaro dhajavarena dasāti. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"ja231":{"ja231:0.1":{"pli":"Jātaka ","html":"<article id='ja231'><header><ul><li class='division'>{}</li>"},"ja231:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja231:0.3":{"pli":"Upāhanavagga ","html":"<li>{}</li></ul>"},"ja231:0.4":{"pli":"1. Upāhanajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja231:1.1":{"pli":"“Yathāpi kītā purisassupāhanā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja231:1.2":{"pli":"Sukhassa atthāya dukhaṁ udabbahe; ","html":"<span class='verse-line'>{}</span>"},"ja231:1.3":{"pli":"Ghammābhitattā thalasā papīḷitā, ","html":"<span class='verse-line'>{}</span>"},"ja231:1.4":{"pli":"Tasseva pāde purisassa khādare. ","html":"<span class='verse-line'>{}</span></p>"},"ja231:2.1":{"pli":"Evameva yo dukkulīno anariyo, ","html":"<p><span class='verse-line'>{}</span>"},"ja231:2.2":{"pli":"Tammāka vijjañca sutañca ādiya; ","html":"<span class='verse-line'>{}</span>"},"ja231:2.3":{"pli":"Tameva so tattha sutena khādati, ","html":"<span class='verse-line'>{}</span>"},"ja231:2.4":{"pli":"Anariyo vuccati dupāhanūpamo”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja231:3.1":{"pli":"Upāhanajātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja232":{"ja232:0.1":{"pli":"Jātaka ","html":"<article id='ja232'><header><ul><li class='division'>{}</li>"},"ja232:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja232:0.3":{"pli":"Upāhanavagga ","html":"<li>{}</li></ul>"},"ja232:0.4":{"pli":"2. Vīṇāguṇajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja232:1.1":{"pli":"“Ekacintito yamattho, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja232:1.2":{"pli":"bālo apariṇāyako; ","html":"<span class='verse-line'>{}</span>"},"ja232:1.3":{"pli":"Na hi khujjena vāmena, ","html":"<span class='verse-line'>{}</span>"},"ja232:1.4":{"pli":"bhoti saṅgantumarahasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja232:2.1":{"pli":"“Purisūsabhaṁ maññamānā, ","html":"<p><span class='verse-line'>{}</span>"},"ja232:2.2":{"pli":"ahaṁ khujjamakāmayiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja232:2.3":{"pli":"Soyaṁ saṅkuṭito seti, ","html":"<span class='verse-line'>{}</span>"},"ja232:2.4":{"pli":"chinnatanti yathā viṇā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja232:3.1":{"pli":"Vīṇāguṇajātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja233":{"ja233:0.1":{"pli":"Jātaka ","html":"<article id='ja233'><header><ul><li class='division'>{}</li>"},"ja233:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja233:0.3":{"pli":"Upāhanavagga ","html":"<li>{}</li></ul>"},"ja233:0.4":{"pli":"3. Vikaṇṇajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja233:1.1":{"pli":"“Kāmaṁ yahiṁ icchasi tena gaccha, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja233:1.2":{"pli":"Viddhosi mammamhi vikaṇṇakena; ","html":"<span class='verse-line'>{}</span>"},"ja233:1.3":{"pli":"Hatosi bhattena suvāditena, ","html":"<span class='verse-line'>{}</span>"},"ja233:1.4":{"pli":"Lolo ca macche anubandhamāno”. ","html":"<span class='verse-line'>{}</span></p>"},"ja233:2.1":{"pli":"“Evampi lokāmisaṁ opatanto, ","html":"<p><span class='verse-line'>{}</span>"},"ja233:2.2":{"pli":"Vihaññatī cittavasānuvattī; ","html":"<span class='verse-line'>{}</span>"},"ja233:2.3":{"pli":"So haññatī ñātisakhāna majjhe, ","html":"<span class='verse-line'>{}</span>"},"ja233:2.4":{"pli":"Macchānugo soriva suṁsumāro”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja233:3.1":{"pli":"Vikaṇṇajātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja234":{"ja234:0.1":{"pli":"Jātaka ","html":"<article id='ja234'><header><ul><li class='division'>{}</li>"},"ja234:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja234:0.3":{"pli":"Upāhanavagga ","html":"<li>{}</li></ul>"},"ja234:0.4":{"pli":"4. Asitābhūjātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja234:1.1":{"pli":"“Tvameva dānimakara, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja234:1.2":{"pli":"Yaṁ kāmo byagamā tayi; ","html":"<span class='verse-line'>{}</span>"},"ja234:1.3":{"pli":"Soyaṁ appaṭisandhiko, ","html":"<span class='verse-line'>{}</span>"},"ja234:1.4":{"pli":"Kharachinnaṁva renukaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja234:2.1":{"pli":"“Atricchaṁ atilobhena, ","html":"<p><span class='verse-line'>{}</span>"},"ja234:2.2":{"pli":"atilobhamadena ca; ","html":"<span class='verse-line'>{}</span>"},"ja234:2.3":{"pli":"Evaṁ hāyati atthamhā, ","html":"<span class='verse-line'>{}</span>"},"ja234:2.4":{"pli":"ahaṁva asitābhuyā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja234:3.1":{"pli":"Asitābhūjātakaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja235":{"ja235:0.1":{"pli":"Jātaka ","html":"<article id='ja235'><header><ul><li class='division'>{}</li>"},"ja235:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja235:0.3":{"pli":"Upāhanavagga ","html":"<li>{}</li></ul>"},"ja235:0.4":{"pli":"5. Vacchanakhajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja235:1.1":{"pli":"“Sukhā gharā vacchanakha, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja235:1.2":{"pli":"sahiraññā sabhojanā; ","html":"<span class='verse-line'>{}</span>"},"ja235:1.3":{"pli":"Yattha bhutvā pivitvā ca, ","html":"<span class='verse-line'>{}</span>"},"ja235:1.4":{"pli":"sayeyyātha anussuko”. ","html":"<span class='verse-line'>{}</span></p>"},"ja235:2.1":{"pli":"“Gharā nānīhamānassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja235:2.2":{"pli":"Gharā nābhaṇato musā; ","html":"<span class='verse-line'>{}</span>"},"ja235:2.3":{"pli":"Gharā nādinnadaṇḍassa, ","html":"<span class='verse-line'>{}</span>"},"ja235:2.4":{"pli":"Paresaṁ anikubbato; ","html":"<span class='verse-line'>{}</span>"},"ja235:2.5":{"pli":"Evaṁ chiddaṁ durabhisambhavaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja235:2.6":{"pli":"Ko gharaṁ paṭipajjatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja235:3.1":{"pli":"Vacchanakhajātakaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja236":{"ja236:0.1":{"pli":"Jātaka ","html":"<article id='ja236'><header><ul><li class='division'>{}</li>"},"ja236:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja236:0.3":{"pli":"Upāhanavagga ","html":"<li>{}</li></ul>"},"ja236:0.4":{"pli":"6. Bakajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja236:1.1":{"pli":"“Bhaddako vatayaṁ pakkhī, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja236:1.2":{"pli":"dijo kumudasannibho; ","html":"<span class='verse-line'>{}</span>"},"ja236:1.3":{"pli":"Vūpasantehi pakkhehi, ","html":"<span class='verse-line'>{}</span>"},"ja236:1.4":{"pli":"mandamandova jhāyati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja236:2.1":{"pli":"“Nāssa sīlaṁ vijānātha, ","html":"<p><span class='verse-line'>{}</span>"},"ja236:2.2":{"pli":"anaññāya pasaṁsatha; ","html":"<span class='verse-line'>{}</span>"},"ja236:2.3":{"pli":"Amhe dijo na pāleti, ","html":"<span class='verse-line'>{}</span>"},"ja236:2.4":{"pli":"tena pakkhī na phandatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja236:3.1":{"pli":"Bakajātakaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja237":{"ja237:0.1":{"pli":"Jātaka ","html":"<article id='ja237'><header><ul><li class='division'>{}</li>"},"ja237:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja237:0.3":{"pli":"Upāhanavagga ","html":"<li>{}</li></ul>"},"ja237:0.4":{"pli":"7. Sāketajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja237:1.1":{"pli":"“Ko nu kho bhagavā hetu, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja237:1.2":{"pli":"ekacce idha puggale; ","html":"<span class='verse-line'>{}</span>"},"ja237:1.3":{"pli":"Atīva hadayaṁ nibbāti, ","html":"<span class='verse-line'>{}</span>"},"ja237:1.4":{"pli":"cittañcāpi pasīdati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja237:2.1":{"pli":"“Pubbeva sannivāsena, ","html":"<p><span class='verse-line'>{}</span>"},"ja237:2.2":{"pli":"paccuppannahitena vā; ","html":"<span class='verse-line'>{}</span>"},"ja237:2.3":{"pli":"Evaṁ taṁ jāyate pemaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja237:2.4":{"pli":"uppalaṁva yathodake”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja237:3.1":{"pli":"Sāketajātakaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja238":{"ja238:0.1":{"pli":"Jātaka ","html":"<article id='ja238'><header><ul><li class='division'>{}</li>"},"ja238:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja238:0.3":{"pli":"Upāhanavagga ","html":"<li>{}</li></ul>"},"ja238:0.4":{"pli":"8. Ekapadajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja238:1.1":{"pli":"“Iṅgha ekapadaṁ tāta, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja238:1.2":{"pli":"anekatthapadassitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja238:1.3":{"pli":"Kiñci saṅgāhikaṁ brūsi, ","html":"<span class='verse-line'>{}</span>"},"ja238:1.4":{"pli":"yenatthe sādhayemase”. ","html":"<span class='verse-line'>{}</span></p>"},"ja238:2.1":{"pli":"“Dakkheyyekapadaṁ tāta, ","html":"<p><span class='verse-line'>{}</span>"},"ja238:2.2":{"pli":"anekatthapadassitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja238:2.3":{"pli":"Tañca sīlena saññuttaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja238:2.4":{"pli":"khantiyā upapāditaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja238:2.5":{"pli":"Alaṁ mitte sukhāpetuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja238:2.6":{"pli":"amittānaṁ dukhāya cā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja238:3.1":{"pli":"Ekapadajātakaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja239":{"ja239:0.1":{"pli":"Jātaka ","html":"<article id='ja239'><header><ul><li class='division'>{}</li>"},"ja239:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja239:0.3":{"pli":"Upāhanavagga ","html":"<li>{}</li></ul>"},"ja239:0.4":{"pli":"9. Haritamaṇḍūkajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja239:1.1":{"pli":"“Āsīvisampi maṁ santaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja239:1.2":{"pli":"Paviṭṭhaṁ kumināmukhaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja239:1.3":{"pli":"Ruccate haritāmātā, ","html":"<span class='verse-line'>{}</span>"},"ja239:1.4":{"pli":"Yaṁ maṁ khādanti macchakā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja239:2.1":{"pli":"“Vilumpateva puriso, ","html":"<p><span class='verse-line'>{}</span>"},"ja239:2.2":{"pli":"yāvassa upakappati; ","html":"<span class='verse-line'>{}</span>"},"ja239:2.3":{"pli":"Yadā caññe vilumpanti, ","html":"<span class='verse-line'>{}</span>"},"ja239:2.4":{"pli":"so vilutto vilumpatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja239:3.1":{"pli":"Haritamaṇḍūkajātakaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja24":{"ja24:0.1":{"pli":"Jātaka ","eng":"Stories of Past Lives 24 ","html":"<article id='ja24'><header><ul><li class='division'>{}</li>"},"ja24:0.2":{"pli":"Ekakanipāta ","eng":"The Book of the Ones ","html":"<li>{}</li>"},"ja24:0.3":{"pli":"Kuruṅgavagga ","eng":"The Four-horned Antelope ","html":"<li>{}</li></ul>"},"ja24:0.4":{"pli":"4. Ājaññajātaka ","eng":"The Thoroughbred: a past life story ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja24:1.1":{"pli":"“Yadā yadā yattha yadā, ","eng":"Whenever whenever, wherever whenever, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>","comm":"Similar to the previous story, a warhorse declares its determination to go on. "},"ja24:1.2":{"pli":"yattha yattha yadā yadā; ","eng":"wherever wherever, whenever whenever: ","html":"<span class='verse-line'>{}</span>"},"ja24:1.3":{"pli":"Ājañño kurute vegaṁ, ","eng":"the thoroughbred drives onward, ","html":"<span class='verse-line'>{}</span>"},"ja24:1.4":{"pli":"hāyanti tattha vāḷavā”ti. ","eng":"while the geldings fade right there. ","html":"<span class='verse-line'>{}</span></p></blockquote>","comm":"<i lang='pi' translate='no'>Vāḷavā</i> is masculine nominative plural (commentary: <i lang='pi' translate='no'>khaḷuṅkassā hāyanti</i>). It is a secondary derivation, glossed with <i lang='pi' translate='no'>vaḷavasaṅkhātā</i>, “reckoned as a mare”; cf. Sanskrit <i lang='pi' translate='no'>vāḍaba</i>. "},"ja24:2.1":{"pli":"Ājaññajātakaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja240":{"ja240:0.1":{"pli":"Jātaka ","html":"<article id='ja240'><header><ul><li class='division'>{}</li>"},"ja240:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja240:0.3":{"pli":"Upāhanavagga ","html":"<li>{}</li></ul>"},"ja240:0.4":{"pli":"10. Mahāpiṅgalajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja240:1.1":{"pli":"“Sabbo jano hiṁsito piṅgalena, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja240:1.2":{"pli":"Tasmiṁ mate paccayā vedayanti; ","html":"<span class='verse-line'>{}</span>"},"ja240:1.3":{"pli":"Piyo nu te āsi akaṇhanetto, ","html":"<span class='verse-line'>{}</span>"},"ja240:1.4":{"pli":"Kasmā nu tvaṁ rodasi dvārapāla”. ","html":"<span class='verse-line'>{}</span></p>"},"ja240:2.1":{"pli":"“Na me piyo āsi akaṇhanetto, ","html":"<p><span class='verse-line'>{}</span>"},"ja240:2.2":{"pli":"Bhāyāmi paccāgamanāya tassa; ","html":"<span class='verse-line'>{}</span>"},"ja240:2.3":{"pli":"Ito gato hiṁseyya maccurājaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja240:2.4":{"pli":"So hiṁsito āneyya puna idha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja240:3.1":{"pli":"“Daḍḍho vāhasahassehi, ","html":"<p><span class='verse-line'>{}</span>"},"ja240:3.2":{"pli":"sitto ghaṭasatehi so; ","html":"<span class='verse-line'>{}</span>"},"ja240:3.3":{"pli":"Parikkhatā ca sā bhūmi, ","html":"<span class='verse-line'>{}</span>"},"ja240:3.4":{"pli":"mā bhāyi nāgamissatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja240:4.1":{"pli":"Mahāpiṅgalajātakaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja240:4.2":{"pli":"Upāhanavaggo navamo. ","html":"<p class='endvagga'>{}</p>"},"ja240:5.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja240:6.1":{"pli":"Varupāhana khujja vikaṇṇakako, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja240:6.2":{"pli":"Asitābhuya pañcamavacchanakho; ","html":"<span class='verse-line'>{}</span>"},"ja240:6.3":{"pli":"Dija pemavaruttamaekapadaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja240:6.4":{"pli":"Kumināmukha piṅgalakena dasāti. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"ja241":{"ja241:0.1":{"pli":"Jātaka ","html":"<article id='ja241'><header><ul><li class='division'>{}</li>"},"ja241:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja241:0.3":{"pli":"Siṅgālavagga ","html":"<li>{}</li></ul>"},"ja241:0.4":{"pli":"1. Sabbadāṭhijātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja241:1.1":{"pli":"“Siṅgālo mānathaddho ca, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja241:1.2":{"pli":"parivārena atthiko; ","html":"<span class='verse-line'>{}</span>"},"ja241:1.3":{"pli":"Pāpuṇi mahatiṁ bhūmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja241:1.4":{"pli":"rājāsi sabbadāṭhinaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja241:2.1":{"pli":"Evameva manussesu, ","html":"<p><span class='verse-line'>{}</span>"},"ja241:2.2":{"pli":"yo hoti parivāravā; ","html":"<span class='verse-line'>{}</span>"},"ja241:2.3":{"pli":"So hi tattha mahā hoti, ","html":"<span class='verse-line'>{}</span>"},"ja241:2.4":{"pli":"siṅgālo viya dāṭhinan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja241:3.1":{"pli":"Sabbadāṭhijātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja242":{"ja242:0.1":{"pli":"Jātaka ","html":"<article id='ja242'><header><ul><li class='division'>{}</li>"},"ja242:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja242:0.3":{"pli":"Siṅgālavagga ","html":"<li>{}</li></ul>"},"ja242:0.4":{"pli":"2. Sunakhajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja242:1.1":{"pli":"“Bālo vatāyaṁ sunakho, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja242:1.2":{"pli":"yo varattaṁ na khādati; ","html":"<span class='verse-line'>{}</span>"},"ja242:1.3":{"pli":"Bandhanā ca pamuñceyya, ","html":"<span class='verse-line'>{}</span>"},"ja242:1.4":{"pli":"asito ca gharaṁ vaje”. ","html":"<span class='verse-line'>{}</span></p>"},"ja242:2.1":{"pli":"“Aṭṭhitaṁ me manasmiṁ me, ","html":"<p><span class='verse-line'>{}</span>"},"ja242:2.2":{"pli":"atho me hadaye kataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja242:2.3":{"pli":"Kālañca paṭikaṅkhāmi, ","html":"<span class='verse-line'>{}</span>"},"ja242:2.4":{"pli":"yāva passupatū jano”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja242:3.1":{"pli":"Sunakhajātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja243":{"ja243:0.1":{"pli":"Jātaka ","html":"<article id='ja243'><header><ul><li class='division'>{}</li>"},"ja243:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja243:0.3":{"pli":"Siṅgālavagga ","html":"<li>{}</li></ul>"},"ja243:0.4":{"pli":"3. Guttilajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja243:1.1":{"pli":"“Sattatantiṁ sumadhuraṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja243:1.2":{"pli":"rāmaṇeyyaṁ avācayiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja243:1.3":{"pli":"So maṁ raṅgamhi avheti, ","html":"<span class='verse-line'>{}</span>"},"ja243:1.4":{"pli":"saraṇaṁ me hohi kosiya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja243:2.1":{"pli":"“Ahaṁ taṁ saraṇaṁ samma, ","html":"<p><span class='verse-line'>{}</span>"},"ja243:2.2":{"pli":"Ahamācariyapūjako; ","html":"<span class='verse-line'>{}</span>"},"ja243:2.3":{"pli":"Na taṁ jayissati sisso, ","html":"<span class='verse-line'>{}</span>"},"ja243:2.4":{"pli":"Sissamācariya jessasī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja243:3.1":{"pli":"Guttilajātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja244":{"ja244:0.1":{"pli":"Jātaka ","html":"<article id='ja244'><header><ul><li class='division'>{}</li>"},"ja244:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja244:0.3":{"pli":"Siṅgālavagga ","html":"<li>{}</li></ul>"},"ja244:0.4":{"pli":"4. Vigaticchajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja244:1.1":{"pli":"“Yaṁ passati na taṁ icchati, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja244:1.2":{"pli":"Yañca na passati taṁ kiricchati; ","html":"<span class='verse-line'>{}</span>"},"ja244:1.3":{"pli":"Maññāmi ciraṁ carissati, ","html":"<span class='verse-line'>{}</span>"},"ja244:1.4":{"pli":"Na hi taṁ lacchati yaṁ sa icchati. ","html":"<span class='verse-line'>{}</span></p>"},"ja244:2.1":{"pli":"Yaṁ labhati na tena tussati, ","html":"<p><span class='verse-line'>{}</span>"},"ja244:2.2":{"pli":"Yañca pattheti laddhaṁ hīḷeti; ","html":"<span class='verse-line'>{}</span>"},"ja244:2.3":{"pli":"Icchā hi anantagocarā, ","html":"<span class='verse-line'>{}</span>"},"ja244:2.4":{"pli":"Vigaticchāna namo karomase”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja244:3.1":{"pli":"Vigaticchajātakaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja245":{"ja245:0.1":{"pli":"Jātaka ","html":"<article id='ja245'><header><ul><li class='division'>{}</li>"},"ja245:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja245:0.3":{"pli":"Siṅgālavagga ","html":"<li>{}</li></ul>"},"ja245:0.4":{"pli":"5. Mūlapariyāyajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja245:1.1":{"pli":"“Kālo ghasati bhūtāni, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja245:1.2":{"pli":"sabbāneva sahattanā; ","html":"<span class='verse-line'>{}</span>"},"ja245:1.3":{"pli":"Yo ca kālaghaso bhūto, ","html":"<span class='verse-line'>{}</span>"},"ja245:1.4":{"pli":"sa bhūtapacaniṁ paci”. ","html":"<span class='verse-line'>{}</span></p>"},"ja245:2.1":{"pli":"“Bahūni narasīsāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja245:2.2":{"pli":"lomasāni brahāni ca; ","html":"<span class='verse-line'>{}</span>"},"ja245:2.3":{"pli":"Gīvāsu paṭimukkāni, ","html":"<span class='verse-line'>{}</span>"},"ja245:2.4":{"pli":"kocidevettha kaṇṇavā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja245:3.1":{"pli":"Mūlapariyāyajātakaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja246":{"ja246:0.1":{"pli":"Jātaka ","html":"<article id='ja246'><header><ul><li class='division'>{}</li>"},"ja246:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja246:0.3":{"pli":"Siṅgālavagga ","html":"<li>{}</li></ul>"},"ja246:0.4":{"pli":"6. Bālovādajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja246:1.1":{"pli":"“Hantvā chetvā vadhitvā ca, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja246:1.2":{"pli":"deti dānaṁ asaññato; ","html":"<span class='verse-line'>{}</span>"},"ja246:1.3":{"pli":"Edisaṁ bhattaṁ bhuñjamāno, ","html":"<span class='verse-line'>{}</span>"},"ja246:1.4":{"pli":"sa pāpena upalippati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja246:2.1":{"pli":"“Puttadārampi ce hantvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja246:2.2":{"pli":"Deti dānaṁ asaññato; ","html":"<span class='verse-line'>{}</span>"},"ja246:2.3":{"pli":"Bhuñjamānopi sappañño, ","html":"<span class='verse-line'>{}</span>"},"ja246:2.4":{"pli":"Na pāpena upalippatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja246:3.1":{"pli":"Bālovādajātakaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja247":{"ja247:0.1":{"pli":"Jātaka ","html":"<article id='ja247'><header><ul><li class='division'>{}</li>"},"ja247:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja247:0.3":{"pli":"Siṅgālavagga ","html":"<li>{}</li></ul>"},"ja247:0.4":{"pli":"7. Pādañjalījātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja247:1.1":{"pli":"“Addhā pādañjalī sabbe, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja247:1.2":{"pli":"paññāya atirocati; ","html":"<span class='verse-line'>{}</span>"},"ja247:1.3":{"pli":"Tathā hi oṭṭhaṁ bhañjati, ","html":"<span class='verse-line'>{}</span>"},"ja247:1.4":{"pli":"uttariṁ nūna passati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja247:2.1":{"pli":"“Nāyaṁ dhammaṁ adhammaṁ vā, ","html":"<p><span class='verse-line'>{}</span>"},"ja247:2.2":{"pli":"Atthānatthañca bujjhati; ","html":"<span class='verse-line'>{}</span>"},"ja247:2.3":{"pli":"Aññatra oṭṭhanibbhogā, ","html":"<span class='verse-line'>{}</span>"},"ja247:2.4":{"pli":"Nāyaṁ jānāti kiñcanan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja247:3.1":{"pli":"Pādañjalījātakaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja248":{"ja248:0.1":{"pli":"Jātaka ","html":"<article id='ja248'><header><ul><li class='division'>{}</li>"},"ja248:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja248:0.3":{"pli":"Siṅgālavagga ","html":"<li>{}</li></ul>"},"ja248:0.4":{"pli":"8. Kiṁsukopamajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja248:1.1":{"pli":"“Sabbehi kiṁsuko diṭṭho, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja248:1.2":{"pli":"kinnvettha vicikicchatha; ","html":"<span class='verse-line'>{}</span>"},"ja248:1.3":{"pli":"Na hi sabbesu ṭhānesu, ","html":"<span class='verse-line'>{}</span>"},"ja248:1.4":{"pli":"sārathī paripucchito”. ","html":"<span class='verse-line'>{}</span></p>"},"ja248:2.1":{"pli":"“Evaṁ sabbehi ñāṇehi, ","html":"<p><span class='verse-line'>{}</span>"},"ja248:2.2":{"pli":"yesaṁ dhammā ajānitā; ","html":"<span class='verse-line'>{}</span>"},"ja248:2.3":{"pli":"Te ve dhammesu kaṅkhanti, ","html":"<span class='verse-line'>{}</span>"},"ja248:2.4":{"pli":"kiṁsukasmiṁva bhātaro”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja248:3.1":{"pli":"Kiṁsukopamajātakaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja249":{"ja249:0.1":{"pli":"Jātaka ","html":"<article id='ja249'><header><ul><li class='division'>{}</li>"},"ja249:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja249:0.3":{"pli":"Siṅgālavagga ","html":"<li>{}</li></ul>"},"ja249:0.4":{"pli":"9. Sālakajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja249:1.1":{"pli":"“Ekaputtako bhavissasi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja249:1.2":{"pli":"Tvañca no hessasi issaro kule; ","html":"<span class='verse-line'>{}</span>"},"ja249:1.3":{"pli":"Oroha dumasmā sālaka, ","html":"<span class='verse-line'>{}</span>"},"ja249:1.4":{"pli":"Ehi dāni gharakaṁ vajemase”. ","html":"<span class='verse-line'>{}</span></p>"},"ja249:2.1":{"pli":"“Nanu maṁ suhadayoti maññasi, ","html":"<p><span class='verse-line'>{}</span>"},"ja249:2.2":{"pli":"Yañca maṁ hanasi veḷuyaṭṭhiyā; ","html":"<span class='verse-line'>{}</span>"},"ja249:2.3":{"pli":"Pakkambavane ramāmase, ","html":"<span class='verse-line'>{}</span>"},"ja249:2.4":{"pli":"Gaccha tvaṁ gharakaṁ yathāsukhan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja249:3.1":{"pli":"Sālakajātakaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja25":{"ja25:0.1":{"pli":"Jātaka ","eng":"Stories of Past Lives 25 ","html":"<article id='ja25'><header><ul><li class='division'>{}</li>"},"ja25:0.2":{"pli":"Ekakanipāta ","eng":"The Book of the Ones ","html":"<li>{}</li>"},"ja25:0.3":{"pli":"Kuruṅgavagga ","eng":"The Four-horned Antelope ","html":"<li>{}</li></ul>"},"ja25:0.4":{"pli":"5. Titthajātaka ","eng":"Fords: a past life story ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja25:1.1":{"pli":"“Aññamaññehi titthehi, ","eng":"At one ford or another ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>","comm":"When a fussy horse refuses to drink at one ford, the canny keeper realizes he needs to be taken somewhere else. "},"ja25:1.2":{"pli":"assaṁ pāyehi sārathi; ","eng":"lead the horse to drink, rider. ","html":"<span class='verse-line'>{}</span>"},"ja25:1.3":{"pli":"Accāsanassa puriso, ","eng":"For man who overeats, ","html":"<span class='verse-line'>{}</span>","comm":"<i lang='pi' translate='no'>Accāsana</i> is <i lang='pi' translate='no'>ati</i> + <i lang='pi' translate='no'>asana</i>, “over-eat”. "},"ja25:1.4":{"pli":"pāyāsassapi tappatī”ti. ","eng":"even milk-rice is a torment. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja25:2.1":{"pli":"Titthajātakaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja250":{"ja250:0.1":{"pli":"Jātaka ","html":"<article id='ja250'><header><ul><li class='division'>{}</li>"},"ja250:0.2":{"pli":"Dukanipāta ","html":"<li>{}</li>"},"ja250:0.3":{"pli":"Siṅgālavagga ","html":"<li>{}</li></ul>"},"ja250:0.4":{"pli":"10. Kapijātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja250:1.1":{"pli":"“Ayaṁ isī upasamasaṁyame rato, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja250:1.2":{"pli":"Sa tiṭṭhati sisirabhayena aṭṭito; ","html":"<span class='verse-line'>{}</span>"},"ja250:1.3":{"pli":"Handa ayaṁ pavisatumaṁ agārakaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja250:1.4":{"pli":"Vinetu sītaṁ darathañca kevalaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja250:2.1":{"pli":"“Nāyaṁ isī upasamasaṁyame rato, ","html":"<p><span class='verse-line'>{}</span>"},"ja250:2.2":{"pli":"Kapī ayaṁ dumavarasākhagocaro; ","html":"<span class='verse-line'>{}</span>"},"ja250:2.3":{"pli":"So dūsako rosako cāpi jammo, ","html":"<span class='verse-line'>{}</span>"},"ja250:2.4":{"pli":"Sacevajemampi dūseyyagāran”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja250:3.1":{"pli":"Kapijātakaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja250:3.2":{"pli":"Siṅgālavaggo dasamo. ","html":"<p class='endvagga'>{}</p>"},"ja250:4.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja250:5.1":{"pli":"Atha rājā siṅgālavaro sunakho, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja250:5.2":{"pli":"Tathā kosiya icchati kālaghaso; ","html":"<span class='verse-line'>{}</span>"},"ja250:5.3":{"pli":"Atha dānavaroṭṭhapi sārathinā, ","html":"<span class='verse-line'>{}</span>"},"ja250:5.4":{"pli":"Punambavanañca sisirakapi dasāti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja250:6.1":{"pli":"Atha vagguddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja250:7.1":{"pli":"Daḷhañca vaggaṁ aparena santhavaṁ, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja250:7.2":{"pli":"Kalyāṇavaggāsadiso ca rūhakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja250:7.3":{"pli":"Nataṁdaḷha bīraṇathambhakaṁ puna, ","html":"<span class='verse-line'>{}</span>"},"ja250:7.4":{"pli":"Kāsāvupāhana siṅgālakena dasāti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja250:8.1":{"pli":"Dukanipātaṁ niṭṭhitaṁ. ","html":"<p class='endsection'>{}</p></article>"}},"ja251":{"ja251:0.1":{"pli":"Jātaka ","html":"<article id='ja251'><header><ul><li class='division'>{}</li>"},"ja251:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja251:0.3":{"pli":"Saṅkappavagga ","html":"<li>{}</li></ul>"},"ja251:0.4":{"pli":"1. Saṅkapparāgajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja251:1.1":{"pli":"“Saṅkapparāgadhotena, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja251:1.2":{"pli":"vitakkanisitena ca; ","html":"<span class='verse-line'>{}</span>"},"ja251:1.3":{"pli":"Nālaṅkatena bhadrena, ","html":"<span class='verse-line'>{}</span>"},"ja251:1.4":{"pli":"usukārākatena ca. ","html":"<span class='verse-line'>{}</span></p>"},"ja251:2.1":{"pli":"Na kaṇṇāyatamuttena, ","html":"<p><span class='verse-line'>{}</span>"},"ja251:2.2":{"pli":"nāpi morūpasevinā; ","html":"<span class='verse-line'>{}</span>"},"ja251:2.3":{"pli":"Tenamhi hadaye viddho, ","html":"<span class='verse-line'>{}</span>"},"ja251:2.4":{"pli":"sabbaṅgaparidāhinā. ","html":"<span class='verse-line'>{}</span></p>"},"ja251:3.1":{"pli":"Āvedhañca na passāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja251:3.2":{"pli":"Yato ruhiramassave; ","html":"<span class='verse-line'>{}</span>"},"ja251:3.3":{"pli":"Yāva ayoniso cittaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja251:3.4":{"pli":"Sayaṁ me dukkhamābhatan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja251:4.1":{"pli":"Saṅkapparāgajātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja252":{"ja252:0.1":{"pli":"Jātaka ","html":"<article id='ja252'><header><ul><li class='division'>{}</li>"},"ja252:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja252:0.3":{"pli":"Saṅkappavagga ","html":"<li>{}</li></ul>"},"ja252:0.4":{"pli":"2. Tilamuṭṭhijātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja252:1.1":{"pli":"“Ajjāpi me taṁ manasi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja252:1.2":{"pli":"yaṁ maṁ tvaṁ tilamuṭṭhiyā; ","html":"<span class='verse-line'>{}</span>"},"ja252:1.3":{"pli":"Bāhāya maṁ gahetvāna, ","html":"<span class='verse-line'>{}</span>"},"ja252:1.4":{"pli":"laṭṭhiyā anutāḷayi. ","html":"<span class='verse-line'>{}</span></p>"},"ja252:2.1":{"pli":"Nanu jīvite na ramasi, ","html":"<p><span class='verse-line'>{}</span>"},"ja252:2.2":{"pli":"yenāsi brāhmaṇāgato; ","html":"<span class='verse-line'>{}</span>"},"ja252:2.3":{"pli":"Yaṁ maṁ bāhā gahetvāna, ","html":"<span class='verse-line'>{}</span>"},"ja252:2.4":{"pli":"tikkhattuṁ anutāḷayi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja252:3.1":{"pli":"“Ariyo anariyaṁ kubbantaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja252:3.2":{"pli":"Yo daṇḍena nisedhati; ","html":"<span class='verse-line'>{}</span>"},"ja252:3.3":{"pli":"Sāsanaṁ taṁ na taṁ veraṁ, ","html":"<span class='verse-line'>{}</span>"},"ja252:3.4":{"pli":"Iti naṁ paṇḍitā vidū”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja252:4.1":{"pli":"Tilamuṭṭhijātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja253":{"ja253:0.1":{"pli":"Jātaka ","html":"<article id='ja253'><header><ul><li class='division'>{}</li>"},"ja253:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja253:0.3":{"pli":"Saṅkappavagga ","html":"<li>{}</li></ul>"},"ja253:0.4":{"pli":"3. Maṇikaṇṭhajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja253:1.1":{"pli":"“Mamannapānaṁ vipulaṁ uḷāraṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja253:1.2":{"pli":"Uppajjatīmassa maṇissa hetu; ","html":"<span class='verse-line'>{}</span>"},"ja253:1.3":{"pli":"Taṁ te na dassaṁ atiyācakosi, ","html":"<span class='verse-line'>{}</span>"},"ja253:1.4":{"pli":"Na cāpi te assamamāgamissaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja253:2.1":{"pli":"Susū yathā sakkharadhotapāṇī, ","html":"<p><span class='verse-line'>{}</span>"},"ja253:2.2":{"pli":"Tāsesi maṁ selaṁ yācamāno; ","html":"<span class='verse-line'>{}</span>"},"ja253:2.3":{"pli":"Taṁ te na dassaṁ atiyācakosi, ","html":"<span class='verse-line'>{}</span>"},"ja253:2.4":{"pli":"Na cāpi te assamamāgamissaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja253:3.1":{"pli":"“Na taṁ yāce yassa piyaṁ jigīse, ","html":"<p><span class='verse-line'>{}</span>"},"ja253:3.2":{"pli":"Desso hoti atiyācanāya; ","html":"<span class='verse-line'>{}</span>"},"ja253:3.3":{"pli":"Nāgo maṇiṁ yācito brāhmaṇena, ","html":"<span class='verse-line'>{}</span>"},"ja253:3.4":{"pli":"Adassanaṁyeva tadajjhagamā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja253:4.1":{"pli":"Maṇikaṇṭhajātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja254":{"ja254:0.1":{"pli":"Jātaka ","html":"<article id='ja254'><header><ul><li class='division'>{}</li>"},"ja254:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja254:0.3":{"pli":"Saṅkappavagga ","html":"<li>{}</li></ul>"},"ja254:0.4":{"pli":"4. Kuṇḍakakucchisindhavajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja254:1.1":{"pli":"“Bhutvā tiṇaparighāsaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja254:1.2":{"pli":"bhutvā ācāmakuṇḍakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja254:1.3":{"pli":"Etaṁ te bhojanaṁ āsi, ","html":"<span class='verse-line'>{}</span>"},"ja254:1.4":{"pli":"kasmā dāni na bhuñjasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja254:2.1":{"pli":"“Yattha posaṁ na jānanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja254:2.2":{"pli":"jātiyā vinayena vā; ","html":"<span class='verse-line'>{}</span>"},"ja254:2.3":{"pli":"Bahuṁ tattha mahābrahme, ","html":"<span class='verse-line'>{}</span>"},"ja254:2.4":{"pli":"api ācāmakuṇḍakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja254:3.1":{"pli":"Tvañca kho maṁ pajānāsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja254:3.2":{"pli":"yādisāyaṁ hayuttamo; ","html":"<span class='verse-line'>{}</span>"},"ja254:3.3":{"pli":"Jānanto jānamāgamma, ","html":"<span class='verse-line'>{}</span>"},"ja254:3.4":{"pli":"na te bhakkhāmi kuṇḍakan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja254:4.1":{"pli":"Kuṇḍakakucchisindhavajātakaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja255":{"ja255:0.1":{"pli":"Jātaka ","html":"<article id='ja255'><header><ul><li class='division'>{}</li>"},"ja255:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja255:0.3":{"pli":"Saṅkappavagga ","html":"<li>{}</li></ul>"},"ja255:0.4":{"pli":"5. Sukajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja255:1.1":{"pli":"“Yāva so mattamaññāsi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja255:1.2":{"pli":"bhojanasmiṁ vihaṅgamo; ","html":"<span class='verse-line'>{}</span>"},"ja255:1.3":{"pli":"Tāva addhānamāpādi, ","html":"<span class='verse-line'>{}</span>"},"ja255:1.4":{"pli":"mātarañca aposayi. ","html":"<span class='verse-line'>{}</span></p>"},"ja255:2.1":{"pli":"Yato ca kho bahutaraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja255:2.2":{"pli":"bhojanaṁ ajjhavāhari; ","html":"<span class='verse-line'>{}</span>"},"ja255:2.3":{"pli":"Tato tattheva saṁsīdi, ","html":"<span class='verse-line'>{}</span>"},"ja255:2.4":{"pli":"amattaññū hi so ahu. ","html":"<span class='verse-line'>{}</span></p>"},"ja255:3.1":{"pli":"Tasmā mattaññutā sādhu, ","html":"<p><span class='verse-line'>{}</span>"},"ja255:3.2":{"pli":"bhojanasmiṁ agiddhatā; ","html":"<span class='verse-line'>{}</span>"},"ja255:3.3":{"pli":"Amattaññū hi sīdanti, ","html":"<span class='verse-line'>{}</span>"},"ja255:3.4":{"pli":"mattaññū ca na sīdare”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja255:4.1":{"pli":"Sukajātakaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja256":{"ja256:0.1":{"pli":"Jātaka ","html":"<article id='ja256'><header><ul><li class='division'>{}</li>"},"ja256:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja256:0.3":{"pli":"Saṅkappavagga ","html":"<li>{}</li></ul>"},"ja256:0.4":{"pli":"6. Jarūdapānajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja256:1.1":{"pli":"“Jarūdapānaṁ khaṇamānā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja256:1.2":{"pli":"vāṇijā udakatthikā; ","html":"<span class='verse-line'>{}</span>"},"ja256:1.3":{"pli":"Ajjhagamuṁ ayasaṁ lohaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja256:1.4":{"pli":"tipusīsañca vāṇijā; ","html":"<span class='verse-line'>{}</span>"},"ja256:1.5":{"pli":"Rajataṁ jātarūpañca, ","html":"<span class='verse-line'>{}</span>"},"ja256:1.6":{"pli":"muttā veḷuriyā bahū. ","html":"<span class='verse-line'>{}</span></p>"},"ja256:2.1":{"pli":"Te ca tena asantuṭṭhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja256:2.2":{"pli":"bhiyyo bhiyyo akhāṇisuṁ; ","html":"<span class='verse-line'>{}</span>"},"ja256:2.3":{"pli":"Te tatthāsīviso ghoro, ","html":"<span class='verse-line'>{}</span>"},"ja256:2.4":{"pli":"tejassī tejasā hani. ","html":"<span class='verse-line'>{}</span></p>"},"ja256:3.1":{"pli":"Tasmā khaṇe nātikhaṇe, ","html":"<p><span class='verse-line'>{}</span>"},"ja256:3.2":{"pli":"Atikhātaṁ hi pāpakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja256:3.3":{"pli":"Khātena ca dhanaṁ laddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja256:3.4":{"pli":"Atikhātena nāsitan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja256:4.1":{"pli":"Jarūdapānajātakaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja257":{"ja257:0.1":{"pli":"Jātaka ","html":"<article id='ja257'><header><ul><li class='division'>{}</li>"},"ja257:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja257:0.3":{"pli":"Saṅkappavagga ","html":"<li>{}</li></ul>"},"ja257:0.4":{"pli":"7. Gāmaṇicandajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja257:1.1":{"pli":"“Nāyaṁ gharānaṁ kusalo, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja257:1.2":{"pli":"lolo ayaṁ valīmukho; ","html":"<span class='verse-line'>{}</span>"},"ja257:1.3":{"pli":"Kataṁ kataṁ kho dūseyya, ","html":"<span class='verse-line'>{}</span>"},"ja257:1.4":{"pli":"evaṁdhammamidaṁ kulaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja257:2.1":{"pli":"Nayidaṁ cittavato lomaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja257:2.2":{"pli":"nāyaṁ assāsiko migo; ","html":"<span class='verse-line'>{}</span>"},"ja257:2.3":{"pli":"Siṭṭhaṁ me janasandhena, ","html":"<span class='verse-line'>{}</span>"},"ja257:2.4":{"pli":"nāyaṁ kiñci vijānati. ","html":"<span class='verse-line'>{}</span></p>"},"ja257:3.1":{"pli":"Na mātaraṁ pitaraṁ vā, ","html":"<p><span class='verse-line'>{}</span>"},"ja257:3.2":{"pli":"bhātaraṁ bhaginiṁ sakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja257:3.3":{"pli":"Bhareyya tādiso poso, ","html":"<span class='verse-line'>{}</span>"},"ja257:3.4":{"pli":"siṭṭhaṁ dasarathena me”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja257:4.1":{"pli":"Gāmaṇicanda jātakaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja258":{"ja258:0.1":{"pli":"Jātaka ","html":"<article id='ja258'><header><ul><li class='division'>{}</li>"},"ja258:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja258:0.3":{"pli":"Saṅkappavagga ","html":"<li>{}</li></ul>"},"ja258:0.4":{"pli":"8. Mandhātujātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja258:1.1":{"pli":"“Yāvatā candimasūriyā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja258:1.2":{"pli":"Pariharanti disā bhanti virocanā; ","html":"<span class='verse-line'>{}</span>"},"ja258:1.3":{"pli":"Sabbeva dāsā mandhātu, ","html":"<span class='verse-line'>{}</span>"},"ja258:1.4":{"pli":"Ye pāṇā pathavissitā. ","html":"<span class='verse-line'>{}</span></p>"},"ja258:2.1":{"pli":"Na kahāpaṇavassena, ","html":"<p><span class='verse-line'>{}</span>"},"ja258:2.2":{"pli":"titti kāmesu vijjati; ","html":"<span class='verse-line'>{}</span>"},"ja258:2.3":{"pli":"Appassādā dukhā kāmā, ","html":"<span class='verse-line'>{}</span>"},"ja258:2.4":{"pli":"iti viññāya paṇḍito. ","html":"<span class='verse-line'>{}</span></p>"},"ja258:3.1":{"pli":"Api dibbesu kāmesu, ","html":"<p><span class='verse-line'>{}</span>"},"ja258:3.2":{"pli":"ratiṁ so nādhigacchati; ","html":"<span class='verse-line'>{}</span>"},"ja258:3.3":{"pli":"Taṇhakkhayarato hoti, ","html":"<span class='verse-line'>{}</span>"},"ja258:3.4":{"pli":"sammāsambuddhasāvako”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja258:4.1":{"pli":"Mandhātujātakaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja259":{"ja259:0.1":{"pli":"Jātaka ","html":"<article id='ja259'><header><ul><li class='division'>{}</li>"},"ja259:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja259:0.3":{"pli":"Saṅkappavagga ","html":"<li>{}</li></ul>"},"ja259:0.4":{"pli":"9. Tirīṭavacchajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja259:1.1":{"pli":"“Nayimassa vijjāmayamatthi kiñci, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja259:1.2":{"pli":"Na bandhavo no pana te sahāyo; ","html":"<span class='verse-line'>{}</span>"},"ja259:1.3":{"pli":"Atha kena vaṇṇena tirīṭavaccho, ","html":"<span class='verse-line'>{}</span>"},"ja259:1.4":{"pli":"Tedaṇḍiko bhuñjati aggapiṇḍaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja259:2.1":{"pli":"“Āpāsu me yuddhaparājitassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja259:2.2":{"pli":"Ekassa katvā vivanasmi ghore; ","html":"<span class='verse-line'>{}</span>"},"ja259:2.3":{"pli":"Pasārayī kicchagatassa pāṇiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja259:2.4":{"pli":"Tenūdatāriṁ dukhasampareto. ","html":"<span class='verse-line'>{}</span></p>"},"ja259:3.1":{"pli":"Etassa kiccena idhānupatto, ","html":"<p><span class='verse-line'>{}</span>"},"ja259:3.2":{"pli":"Vesāyino visayā jīvaloke; ","html":"<span class='verse-line'>{}</span>"},"ja259:3.3":{"pli":"Lābhāraho tāta tirīṭavaccho, ","html":"<span class='verse-line'>{}</span>"},"ja259:3.4":{"pli":"Dethassa bhogaṁ yajathañca yaññan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja259:4.1":{"pli":"Tirīṭavacchajātakaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}