{"tha-ap533":{"tha-ap533:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap533'><header><ul><li class='division'>{}</li>"},"tha-ap533:0.2":{"pli":"Kaccāyanavagga ","html":"<li>{}</li></ul>"},"tha-ap533:0.3":{"pli":"1 Mahākaccāyanattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap533:1.1":{"pli":"“Padumuttaro nāma jino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap533:1.2":{"pli":"anejo ajitaṁ jayo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:1.3":{"pli":"Satasahasse kappānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:1.4":{"pli":"ito uppajji nāyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap533:2.1":{"pli":"Vīro kamalapattakkho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap533:2.2":{"pli":"sasaṅkavimalānano; ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:2.3":{"pli":"Kanakācalasaṅkāso, ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:2.4":{"pli":"ravidittisamappabho. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap533:3.1":{"pli":"Sattanettamanohārī, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap533:3.2":{"pli":"varalakkhaṇabhūsito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:3.3":{"pli":"Sabbavākyapathātīto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:3.4":{"pli":"manujāmarasakkato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap533:4.1":{"pli":"Sambuddho bodhayaṁ satte, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap533:4.2":{"pli":"vāgīso madhurassaro; ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:4.3":{"pli":"Karuṇānibandhasantāno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:4.4":{"pli":"parisāsu visārado. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap533:5.1":{"pli":"Deseti madhuraṁ dhammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap533:5.2":{"pli":"catusaccūpasaṁhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:5.3":{"pli":"Nimugge mohapaṅkamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:5.4":{"pli":"samuddharati pāṇine. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap533:6.1":{"pli":"Tadā ekacaro hutvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap533:6.2":{"pli":"tāpaso himavālayo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:6.3":{"pli":"Nabhasā mānusaṁ lokaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:6.4":{"pli":"gacchanto jinamaddasaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap533:7.1":{"pli":"Upecca santikaṁ tassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap533:7.2":{"pli":"assosiṁ dhammadesanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:7.3":{"pli":"Vaṇṇayantassa vīrassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:7.4":{"pli":"sāvakassa mahāguṇaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap533:8.1":{"pli":"‘Saṅkhittena mayā vuttaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap533:8.2":{"pli":"vitthārena pakāsayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:8.3":{"pli":"Parisaṁ mañca toseti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:8.4":{"pli":"yathā kaccāyano ayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap533:9.1":{"pli":"Nāhaṁ evamidhekaccaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap533:9.2":{"pli":"aññaṁ passāmi sāvakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:9.3":{"pli":"Tasmātadagge esaggo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:9.4":{"pli":"evaṁ dhāretha bhikkhavo’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap533:10.1":{"pli":"Tadāhaṁ vimhito hutvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap533:10.2":{"pli":"sutvā vākyaṁ manoramaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:10.3":{"pli":"Himavantaṁ gamitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:10.4":{"pli":"āhitvā pupphasañcayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap533:11.1":{"pli":"Pūjetvā lokasaraṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap533:11.2":{"pli":"taṁ ṭhānamabhipatthayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:11.3":{"pli":"Tadā mamāsayaṁ ñatvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:11.4":{"pli":"byākāsi sa raṇañjaho. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap533:12.1":{"pli":"‘Passathetaṁ isivaraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap533:12.2":{"pli":"niddhantakanakattacaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:12.3":{"pli":"Uddhaggalomaṁ pīṇaṁsaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:12.4":{"pli":"acalaṁ pañjaliṁ ṭhitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap533:13.1":{"pli":"Hāsaṁ supuṇṇanayanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap533:13.2":{"pli":"buddhavaṇṇagatāsayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:13.3":{"pli":"Dhammajaṁ uggahadayaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:13.4":{"pli":"amatāsittasannibhaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap533:14.1":{"pli":"Kaccānassa guṇaṁ sutvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap533:14.2":{"pli":"taṁ ṭhānaṁ patthayaṁ ṭhito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:14.3":{"pli":"Anāgatamhi addhāne, ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:14.4":{"pli":"gotamassa mahāmune. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap533:15.1":{"pli":"Tassa dhammesu dāyādo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap533:15.2":{"pli":"oraso dhammanimmito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:15.3":{"pli":"Kaccāno nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:15.4":{"pli":"hessati satthu sāvako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap533:16.1":{"pli":"Bahussuto mahāñāṇī, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap533:16.2":{"pli":"adhippāyavidū mune; ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:16.3":{"pli":"Pāpuṇissati taṁ ṭhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:16.4":{"pli":"yathāyaṁ byākato mayā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap533:17.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap533:17.2":{"pli":"yaṁ kammamakariṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:17.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:17.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap533:18.1":{"pli":"Duve bhave saṁsarāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap533:18.2":{"pli":"devatte atha mānuse; ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:18.3":{"pli":"Aññaṁ gatiṁ na gacchāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:18.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap533:19.1":{"pli":"Duve kule pajāyāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap533:19.2":{"pli":"khattiye atha brāhmaṇe; ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:19.3":{"pli":"Nīce kule na jāyāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:19.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap533:20.1":{"pli":"Pacchime ca bhave dāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap533:20.2":{"pli":"jāto ujjeniyaṁ pure; ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:20.3":{"pli":"Pajjotassa ca caṇḍassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:20.4":{"pli":"purohitadijādhino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap533:21.1":{"pli":"Putto tiriṭivacchassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap533:21.2":{"pli":"nipuṇo vedapāragū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:21.3":{"pli":"Mātā ca candimā nāma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:21.4":{"pli":"kaccānohaṁ varattaco. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap533:22.1":{"pli":"Vīmaṁsanatthaṁ buddhassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap533:22.2":{"pli":"bhūmipālena pesito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:22.3":{"pli":"Disvā mokkhapuradvāraṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:22.4":{"pli":"nāyakaṁ guṇasañcayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap533:23.1":{"pli":"Sutvā ca vimalaṁ vākyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap533:23.2":{"pli":"gatipaṅkavisosanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:23.3":{"pli":"Pāpuṇiṁ amataṁ santaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:23.4":{"pli":"sesehi saha sattahi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap533:24.1":{"pli":"Adhippāyavidū jāto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap533:24.2":{"pli":"sugatassa mahāmate; ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:24.3":{"pli":"Ṭhapito etadagge ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:24.4":{"pli":"susamiddhamanoratho. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap533:25.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap533:25.2":{"pli":"bhavā sabbe samūhatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:25.3":{"pli":"Nāgova bandhanaṁ chetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:25.4":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap533:26.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap533:26.2":{"pli":"mama buddhassa santike; ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:26.3":{"pli":"Tisso vijjā anuppattā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:26.4":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap533:27.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap533:27.2":{"pli":"vimokkhāpi ca aṭṭhime; ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:27.3":{"pli":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap533:27.4":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap533:28.1":{"pli":"Itthaṁ sudaṁ āyasmā mahākaccāyano thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap533:29.1":{"pli":"Mahākaccāyanattherassāpadānaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap534":{"tha-ap534:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap534'><header><ul><li class='division'>{}</li>"},"tha-ap534:0.2":{"pli":"Kaccāyanavagga ","html":"<li>{}</li></ul>"},"tha-ap534:0.3":{"pli":"Vakkalittheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap534:1.1":{"pli":"“Ito satasahassamhi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap534:1.2":{"pli":"kappe uppajji nāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:1.3":{"pli":"Anomanāmo amito, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:1.4":{"pli":"nāmena padumuttaro. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:2.1":{"pli":"Padumākāravadano, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:2.2":{"pli":"padumāmalasucchavī; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:2.3":{"pli":"Lokenānupalittova, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:2.4":{"pli":"toyena padumaṁ yathā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:3.1":{"pli":"Vīro padumapattakkho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:3.2":{"pli":"kanto ca padumaṁ yathā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:3.3":{"pli":"Padumuttaragandhova, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:3.4":{"pli":"tasmā so padumuttaro. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:4.1":{"pli":"Lokajeṭṭho ca nimmāno, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:4.2":{"pli":"andhānaṁ nayanūpamo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:4.3":{"pli":"Santaveso guṇanidhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:4.4":{"pli":"karuṇāmatisāgaro. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:5.1":{"pli":"Sa kadāci mahāvīro, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:5.2":{"pli":"brahmāsurasuraccito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:5.3":{"pli":"Sadevamanujākiṇṇe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:5.4":{"pli":"janamajjhe jinuttamo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:6.1":{"pli":"Vadanena sugandhena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:6.2":{"pli":"madhurena rutena ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:6.3":{"pli":"Rañjayaṁ parisaṁ sabbaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:6.4":{"pli":"santhavī sāvakaṁ sakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:7.1":{"pli":"Saddhādhimutto sumati, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:7.2":{"pli":"mama dassanalālaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:7.3":{"pli":"Natthi etādiso añño, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:7.4":{"pli":"yathāyaṁ bhikkhu vakkali. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:8.1":{"pli":"Tadāhaṁ haṁsavatiyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:8.2":{"pli":"nagare brāhmaṇatrajo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:8.3":{"pli":"Hutvā sutvā ca taṁ vākyaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:8.4":{"pli":"taṁ ṭhānamabhirocayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:9.1":{"pli":"Sasāvakaṁ taṁ vimalaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:9.2":{"pli":"nimantetvā tathāgataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:9.3":{"pli":"Sattāhaṁ bhojayitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:9.4":{"pli":"dussehacchādayiṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:10.1":{"pli":"Nipacca sirasā tassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:10.2":{"pli":"anantaguṇasāgare; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:10.3":{"pli":"Nimuggo pītisampuṇṇo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:10.4":{"pli":"idaṁ vacanamabraviṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:11.1":{"pli":"‘Yo so tayā santhavito, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:11.2":{"pli":"ito sattamake muni; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:11.3":{"pli":"Bhikkhu saddhāvataṁ aggo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:11.4":{"pli":"tādiso homahaṁ mune’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:12.1":{"pli":"Evaṁ vutte, mahāvīro, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:12.2":{"pli":"anāvaraṇadassano; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:12.3":{"pli":"Imaṁ vākyaṁ udīresi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:12.4":{"pli":"parisāya mahāmuni. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:13.1":{"pli":"‘Passathetaṁ māṇavakaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:13.2":{"pli":"pītamaṭṭhanivāsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:13.3":{"pli":"Hemayaññopacitaṅgaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:13.4":{"pli":"jananettamanoharaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:14.1":{"pli":"Eso anāgataddhāne, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:14.2":{"pli":"gotamassa mahesino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:14.3":{"pli":"Aggo saddhādhimuttānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:14.4":{"pli":"sāvakoyaṁ bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:15.1":{"pli":"Devabhūto manusso vā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:15.2":{"pli":"sabbasantāpavajjito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:15.3":{"pli":"Sabbabhogaparibyūḷho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:15.4":{"pli":"sukhito saṁsarissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:16.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:16.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:16.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:16.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:17.1":{"pli":"Tassa dhammesu dāyādo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:17.2":{"pli":"oraso dhammanimmito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:17.3":{"pli":"Vakkali nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:17.4":{"pli":"hessati satthu sāvako’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:18.1":{"pli":"Tena kammavisesena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:18.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:18.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:18.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:19.1":{"pli":"Sabbattha sukhito hutvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:19.2":{"pli":"saṁsaranto bhavābhave; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:19.3":{"pli":"Sāvatthiyaṁ pure jāto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:19.4":{"pli":"kule aññatare ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:20.1":{"pli":"Nonītasukhumālaṁ maṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:20.2":{"pli":"jātapallavakomalaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:20.3":{"pli":"Mandaṁ uttānasayanaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:20.4":{"pli":"pisācībhayatajjitā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:21.1":{"pli":"Pādamūle mahesissa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:21.2":{"pli":"sāyesuṁ dīnamānasā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:21.3":{"pli":"‘Imaṁ dadāma te nātha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:21.4":{"pli":"saraṇaṁ hohi nāyaka’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:22.1":{"pli":"Tadā paṭiggahi so maṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:22.2":{"pli":"bhītānaṁ saraṇo muni; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:22.3":{"pli":"Jālinā cakkaṅkitena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:22.4":{"pli":"mudukomalapāṇinā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:23.1":{"pli":"Tadā pabhuti tenāhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:23.2":{"pli":"arakkheyyena rakkhito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:23.3":{"pli":"Sabbaveravinimutto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:23.4":{"pli":"sukhena parivuddhito. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:24.1":{"pli":"Sugatena vinā bhūto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:24.2":{"pli":"ukkaṇṭhāmi muhuttakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:24.3":{"pli":"Jātiyā sattavassohaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:24.4":{"pli":"pabbajiṁ anagāriyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:25.1":{"pli":"Sabbapāramisambhūtaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:25.2":{"pli":"nīlakkhinayanaṁ varaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:25.3":{"pli":"Rūpaṁ sabbasubhākiṇṇaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:25.4":{"pli":"atitto viharāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:26.1":{"pli":"Buddharūparatiṁ ñatvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:26.2":{"pli":"tadā ovadi maṁ jino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:26.3":{"pli":"‘Alaṁ vakkali kiṁ rūpe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:26.4":{"pli":"ramase bālanandite. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:27.1":{"pli":"Yo hi passati saddhammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:27.2":{"pli":"so maṁ passati paṇḍito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:27.3":{"pli":"Apassamāno saddhammaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:27.4":{"pli":"maṁ passampi na passati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:28.1":{"pli":"Anantādīnavo kāyo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:28.2":{"pli":"visarukkhasamūpamo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:28.3":{"pli":"Āvāso sabbarogānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:28.4":{"pli":"puñjo dukkhassa kevalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:29.1":{"pli":"Nibbindiya tato rūpe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:29.2":{"pli":"khandhānaṁ udayabbayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:29.3":{"pli":"Passa upakkilesānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:29.4":{"pli":"sukhenantaṁ gamissasi’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:30.1":{"pli":"Evaṁ tenānusiṭṭhohaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:30.2":{"pli":"nāyakena hitesinā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:30.3":{"pli":"Gijjhakūṭaṁ samāruyha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:30.4":{"pli":"jhāyāmi girikandare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:31.1":{"pli":"Ṭhito pabbatapādamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:31.2":{"pli":"assāsayi mahāmuni; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:31.3":{"pli":"Vakkalīti jino vācaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:31.4":{"pli":"taṁ sutvā mudito ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:32.1":{"pli":"Pakkhandiṁ selapabbhāre, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:32.2":{"pli":"anekasataporise; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:32.3":{"pli":"Tadā buddhānubhāvena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:32.4":{"pli":"sukheneva mahiṁ gato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:33.1":{"pli":"Punopi dhammaṁ deseti, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:33.2":{"pli":"khandhānaṁ udayabbayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:33.3":{"pli":"Tamahaṁ dhammamaññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:33.4":{"pli":"arahattamapāpuṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:34.1":{"pli":"Sumahāparisamajjhe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:34.2":{"pli":"tadā maṁ caraṇantago; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:34.3":{"pli":"Aggaṁ saddhādhimuttānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:34.4":{"pli":"paññapesi mahāmati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:35.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:35.2":{"pli":"yaṁ kammamakariṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:35.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:35.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:36.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:36.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:36.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:37.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:37.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:37.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap534:38.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap534:38.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap534:38.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap534:39.1":{"pli":"Itthaṁ sudaṁ āyasmā vakkalitthero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap534:40.1":{"pli":"Vakkalittherassāpadānaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap535":{"tha-ap535:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap535'><header><ul><li class='division'>{}</li>"},"tha-ap535:0.2":{"pli":"Kaccāyanavagga ","html":"<li>{}</li></ul>"},"tha-ap535:0.3":{"pli":"Mahākappinattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap535:1.1":{"pli":"“Padumuttaro nāma jino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap535:1.2":{"pli":"sabbadhammāna pāragū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:1.3":{"pli":"Udito ajaṭākāse, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:1.4":{"pli":"ravīva saradambare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:2.1":{"pli":"Vacanābhāya bodheti, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:2.2":{"pli":"veneyyapadumāni so; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:2.3":{"pli":"Kilesapaṅkaṁ soseti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:2.4":{"pli":"matiraṁsīhi nāyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:3.1":{"pli":"Titthiyānaṁ yase hanti, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:3.2":{"pli":"khajjotābhā yathā ravi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:3.3":{"pli":"Saccatthābhaṁ pakāseti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:3.4":{"pli":"ratanaṁva divākaro. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:4.1":{"pli":"Guṇānaṁ āyatibhūto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:4.2":{"pli":"ratanānaṁva sāgaro; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:4.3":{"pli":"Pajjunnoriva bhūtāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:4.4":{"pli":"dhammameghena vassati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:5.1":{"pli":"Akkhadasso tadā āsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:5.2":{"pli":"nagare haṁsasavhaye; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:5.3":{"pli":"Upecca dhammamassosiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:5.4":{"pli":"jalajuttamanāmino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:6.1":{"pli":"Ovādakassa bhikkhūnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:6.2":{"pli":"sāvakassa katāvino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:6.3":{"pli":"Guṇaṁ pakāsayantassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:6.4":{"pli":"tappayantassa me manaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:7.1":{"pli":"Sutvā patīto sumano, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:7.2":{"pli":"nimantetvā tathāgataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:7.3":{"pli":"Sasissaṁ bhojayitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:7.4":{"pli":"taṁ ṭhānamabhipatthayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:8.1":{"pli":"Tadā haṁsasamabhāgo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:8.2":{"pli":"haṁsadundubhinissano; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:8.3":{"pli":"‘Passathetaṁ mahāmattaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:8.4":{"pli":"vinicchayavisāradaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:9.1":{"pli":"Patitaṁ pādamūle me, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:9.2":{"pli":"samuggatatanūruhaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:9.3":{"pli":"Jīmūtavaṇṇaṁ pīṇaṁsaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:9.4":{"pli":"pasannanayanānanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:10.1":{"pli":"Parivārena mahatā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:10.2":{"pli":"rājayuttaṁ mahāyasaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:10.3":{"pli":"Eso katāvino ṭhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:10.4":{"pli":"pattheti muditāsayo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:11.1":{"pli":"Iminā paṇipātena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:11.2":{"pli":"cāgena paṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:11.3":{"pli":"Kappasatasahassāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:11.4":{"pli":"nupapajjati duggatiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:12.1":{"pli":"Devesu devasobhaggaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:12.2":{"pli":"manussesu mahantataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:12.3":{"pli":"Anubhotvāna sesena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:12.4":{"pli":"nibbānaṁ pāpuṇissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:13.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:13.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:13.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:13.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:14.1":{"pli":"Tassa dhammesu dāyādo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:14.2":{"pli":"oraso dhammanimmito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:14.3":{"pli":"Kappino nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:14.4":{"pli":"hessati satthu sāvako’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:15.1":{"pli":"Tatohaṁ sukataṁ kāraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:15.2":{"pli":"katvāna jinasāsane; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:15.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:15.4":{"pli":"tusitaṁ agamāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:16.1":{"pli":"Devamānusarajjāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:16.2":{"pli":"sataso anusāsiya; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:16.3":{"pli":"Bārāṇasiyamāsanne, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:16.4":{"pli":"jāto keniyajātiyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:17.1":{"pli":"Sahassaparivārena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:17.2":{"pli":"sapajāpatiko ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:17.3":{"pli":"Pañca paccekabuddhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:17.4":{"pli":"satāni samupaṭṭhahiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:18.1":{"pli":"Temāsaṁ bhojayitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:18.2":{"pli":"pacchādamha ticīvaraṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:18.3":{"pli":"Tato cutā mayaṁ sabbe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:18.4":{"pli":"ahumha tidasūpagā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:19.1":{"pli":"Puno sabbe manussattaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:19.2":{"pli":"agamimha tato cutā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:19.3":{"pli":"Kukkuṭamhi pure jātā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:19.4":{"pli":"himavantassa passato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:20.1":{"pli":"Kappino nāmahaṁ āsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:20.2":{"pli":"rājaputto mahāyaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:20.3":{"pli":"Sesāmaccakule jātā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:20.4":{"pli":"mameva parivārayuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:21.1":{"pli":"Mahārajjasukhaṁ patto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:21.2":{"pli":"sabbakāmasamiddhimā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:21.3":{"pli":"Vāṇijehi samakkhātaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:21.4":{"pli":"buddhuppādamahaṁ suṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:22.1":{"pli":"‘Buddho loke samuppanno, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:22.2":{"pli":"asamo ekapuggalo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:22.3":{"pli":"So pakāseti saddhammaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:22.4":{"pli":"amataṁ sukhamuttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:23.1":{"pli":"Suyuttā tassa sissā ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:23.2":{"pli":"sumuttā ca anāsavā’; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:23.3":{"pli":"Sutvā nesaṁ suvacanaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:23.4":{"pli":"sakkaritvāna vāṇije. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:24.1":{"pli":"Pahāya rajjaṁ sāmacco, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:24.2":{"pli":"nikkhamiṁ buddhamāmako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:24.3":{"pli":"Nadiṁ disvā mahācandaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:24.4":{"pli":"pūritaṁ samatittikaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:25.1":{"pli":"Appatiṭṭhaṁ anālambaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:25.2":{"pli":"duttaraṁ sīghavāhiniṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:25.3":{"pli":"Guṇaṁ saritvā buddhassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:25.4":{"pli":"sotthinā samatikkamiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:26.1":{"pli":"‘Bhavasotaṁ sace buddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:26.2":{"pli":"tiṇṇo lokantagū vidū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:26.3":{"pli":"Etena saccavajjena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:26.4":{"pli":"gamanaṁ me samijjhatu. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:27.1":{"pli":"Yadi santigamo maggo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:27.2":{"pli":"mokkho caccantikaṁ sukhaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:27.3":{"pli":"Etena saccavajjena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:27.4":{"pli":"gamanaṁ me samijjhatu. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:28.1":{"pli":"Saṅgho ce tiṇṇakantāro, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:28.2":{"pli":"puññakkhetto anuttaro; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:28.3":{"pli":"Etena saccavajjena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:28.4":{"pli":"gamanaṁ me samijjhatu’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:29.1":{"pli":"Saha kate saccavare, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:29.2":{"pli":"maggā apagataṁ jalaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:29.3":{"pli":"Tato sukhena uttiṇṇo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:29.4":{"pli":"nadītīre manorame. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:30.1":{"pli":"Nisinnaṁ addasaṁ buddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:30.2":{"pli":"udentaṁva pabhaṅkaraṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:30.3":{"pli":"Jalantaṁ hemaselaṁva, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:30.4":{"pli":"dīparukkhaṁva jotitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:31.1":{"pli":"Sasiṁva tārāsahitaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:31.2":{"pli":"sāvakehi purakkhataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:31.3":{"pli":"Vāsavaṁ viya vassantaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:31.4":{"pli":"desanājaladantaraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:32.1":{"pli":"Vanditvāna sahāmacco, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:32.2":{"pli":"ekamantamupāvisiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:32.3":{"pli":"Tato no āsayaṁ ñatvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:32.4":{"pli":"buddho dhammamadesayi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:33.1":{"pli":"Sutvāna dhammaṁ vimalaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:33.2":{"pli":"avocumha mayaṁ jinaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:33.3":{"pli":"‘Pabbājehi mahāvīra, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:33.4":{"pli":"nibbindāmha mayaṁ bhave’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:34.1":{"pli":"‘Svākkhāto bhikkhave dhammo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:34.2":{"pli":"dukkhantakaraṇāya vo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:34.3":{"pli":"Caratha brahmacariyaṁ’, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:34.4":{"pli":"iccāha munisattamo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:35.1":{"pli":"Saha vācāya sabbepi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:35.2":{"pli":"bhikkhuvesadharā mayaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:35.3":{"pli":"Ahumha upasampannā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:35.4":{"pli":"sotāpannā ca sāsane. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:36.1":{"pli":"Tato jetavanaṁ gantvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:36.2":{"pli":"anusāsi vināyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:36.3":{"pli":"Anusiṭṭho jinenāhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:36.4":{"pli":"arahattamapāpuṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:37.1":{"pli":"Tato bhikkhusahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:37.2":{"pli":"anusāsimahaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:37.3":{"pli":"Mamānusāsanakarā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:37.4":{"pli":"tepi āsuṁ anāsavā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:38.1":{"pli":"Jino tasmiṁ guṇe tuṭṭho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:38.2":{"pli":"etadagge ṭhapesi maṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:38.3":{"pli":"Bhikkhuovādakānaggo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:38.4":{"pli":"kappinoti mahājane. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:39.1":{"pli":"Satasahasse kataṁ kammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:39.2":{"pli":"phalaṁ dassesi me idha; ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:39.3":{"pli":"Pamutto saravegova, ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:39.4":{"pli":"kilese jhāpayiṁ mama. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:40.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:40.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:40.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:41.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:41.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:41.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap535:42.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap535:42.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap535:42.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap535:43.1":{"pli":"Itthaṁ sudaṁ āyasmā mahākappino thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap535:44.1":{"pli":"Mahākappinattherassāpadānaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}