{}"},"kv13.6:4.6":{"pli":"Attheva suttantoti? ","html":"{}"},"kv13.6:4.7":{"pli":"Āmantā. ","html":"{}"},"kv13.6:4.8":{"pli":"Tena hi na vattabbaṁ—","html":"{}"},"kv13.6:4.9":{"pli":"“sammukhībhūto saṁyojanaṁ jahatī”ti. ","html":"{}</p>"},"kv13.6:5.1":{"pli":"Na vattabbaṁ—","html":"<p data-doxy='heterodox'>{}"},"kv13.6:5.2":{"pli":"“sammukhībhūto saṁyojanaṁ jahatī”ti? ","html":"{}"},"kv13.6:5.3":{"pli":"Āmantā. ","html":"{}"},"kv13.6:5.4":{"pli":"Nanu vuttaṁ bhagavatā—","html":"{}"},"kv13.6:5.5":{"pli":"“tassa evaṁ jānato evaṁ passato kāmāsavāpi cittaṁ vimuccati …pe… ","html":"{}"},"kv13.6:5.6":{"pli":"avijjāsavāpi cittaṁ vimuccatī”ti. ","html":"{}"},"kv13.6:5.7":{"pli":"Attheva suttantoti? ","html":"{}"},"kv13.6:5.8":{"pli":"Āmantā. ","html":"{}"},"kv13.6:5.9":{"pli":"Tena hi sammukhībhūto saṁyojanaṁ jahatīti. ","html":"{}</p>"},"kv13.6:5.10":{"pli":"Sammukhībhūtakathā niṭṭhitā. ","html":"<p class='endsutta'>{}</p></article>"}},"kv13.7":{"kv13.7:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv13.7'><header><ul><li class='division'>{}</li>"},"kv13.7:0.2":{"pli":"Mahāpaṇṇāsaka ","html":"<li>{}</li>"},"kv13.7:0.3":{"pli":"Terasamavagga ","html":"<li>{}</li></ul>"},"kv13.7:0.4":{"pli":"Samāpannoassādetikathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv13.7:1.1":{"pli":"Samāpanno assādeti, jhānanikanti jhānārammaṇāti? ","html":"<p data-doxy='orthodox'>{}"},"kv13.7:1.2":{"pli":"Āmantā. ","html":"{}"},"kv13.7:1.3":{"pli":"Taṁ jhānaṁ tassa jhānassa ārammaṇanti? ","html":"{}"},"kv13.7:1.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv13.7:1.5":{"pli":"taṁ jhānaṁ tassa jhānassa ārammaṇanti? ","html":"{}"},"kv13.7:1.6":{"pli":"Āmantā. ","html":"{}"},"kv13.7:1.7":{"pli":"Tena phassena taṁ phassaṁ phusati, tāya vedanāya taṁ vedanaṁ vedeti, tāya saññāya taṁ saññaṁ sañjānāti, tāya cetanāya taṁ cetanaṁ ceteti, tena cittena taṁ cittaṁ cinteti, tena vitakkena taṁ vitakkaṁ vitakketi, tena vicārena taṁ vicāraṁ vicāreti, tāya pītiyā taṁ pītiṁ piyāyati, tāya satiyā taṁ satiṁ sarati, tāya paññāya taṁ paññaṁ pajānātīti? ","html":"{}"},"kv13.7:1.8":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv13.7:2.1":{"pli":"Jhānanikanti cittasampayuttā, jhānaṁ cittasampayuttanti? ","html":"<p data-doxy='orthodox'>{}"},"kv13.7:2.2":{"pli":"Āmantā. ","html":"{}"},"kv13.7:2.3":{"pli":"Dvinnaṁ phassānaṁ …pe… ","html":"{}"},"kv13.7:2.4":{"pli":"dvinnaṁ cittānaṁ samodhānaṁ hotīti? ","html":"{}"},"kv13.7:2.5":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv13.7:3.1":{"pli":"Jhānanikanti akusalaṁ, jhānaṁ kusalanti? ","html":"<p data-doxy='orthodox'>{}"},"kv13.7:3.2":{"pli":"Āmantā. ","html":"{}"},"kv13.7:3.3":{"pli":"Kusalākusalā sāvajjānavajjā hīnapaṇītā kaṇhasukkasappaṭibhāgā dhammā sammukhībhāvaṁ āgacchantīti? ","html":"{}"},"kv13.7:3.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv13.7:4.1":{"pli":"Kusalākusalā sāvajjānavajjā hīnapaṇītā kaṇhasukkasappaṭibhāgā dhammā sammukhībhāvaṁ āgacchantīti? ","html":"<p data-doxy='orthodox'>{}"},"kv13.7:4.2":{"pli":"Āmantā. ","html":"{}"},"kv13.7:4.3":{"pli":"Nanu vuttaṁ bhagavatā—","html":"{}"},"kv13.7:4.4":{"pli":"“cattārimāni, bhikkhave, suvidūravidūrāni. ","html":"{}"},"kv13.7:4.5":{"pli":"Katamāni cattāri? ","html":"{}"},"kv13.7:4.6":{"pli":"Nabhañca, bhikkhave, pathavī ca—","html":"{}"},"kv13.7:4.7":{"pli":"idaṁ paṭhamaṁ suvidūravidūraṁ …pe… tasmā sataṁ dhammo asabbhi ārakā”ti. ","html":"{}"},"kv13.7:4.8":{"pli":"Attheva suttantoti? ","html":"{}"},"kv13.7:4.9":{"pli":"Āmantā. ","html":"{}"},"kv13.7:4.10":{"pli":"Tena hi na vattabbaṁ—","html":"{}"},"kv13.7:4.11":{"pli":"“kusalākusalā sāvajjānavajjā hīnapaṇītā kaṇhasukkasappaṭibhāgā dhammā sammukhībhāvaṁ āgacchantī”ti. ","html":"{}</p>"},"kv13.7:5.1":{"pli":"Na vattabbaṁ—","html":"<p data-doxy='heterodox'>{}"},"kv13.7:5.2":{"pli":"“samāpanno assādeti, jhānanikanti jhānārammaṇā”ti? ","html":"{}"},"kv13.7:5.3":{"pli":"Āmantā. ","html":"{}"},"kv13.7:5.4":{"pli":"Nanu vuttaṁ bhagavatā—","html":"{}"},"kv13.7:5.5":{"pli":"“idha, bhikkhave, bhikkhu vivicceva kāmehi vivicca akusalehi dhammehi paṭhamaṁ jhānaṁ upasampajja viharati, so taṁ assādeti taṁ nikāmeti tena ca vittiṁ āpajjati; ","html":"{}"},"kv13.7:5.6":{"pli":"vitakkavicārānaṁ vūpasamā …pe… dutiyaṁ jhānaṁ …pe… ","html":"{}"},"kv13.7:5.7":{"pli":"tatiyaṁ jhānaṁ …pe… ","html":"{}"},"kv13.7:5.8":{"pli":"catutthaṁ jhānaṁ upasampajja viharati, so taṁ assādeti taṁ nikāmeti tena ca vittiṁ āpajjatī”ti. ","html":"{}"},"kv13.7:5.9":{"pli":"Attheva suttantoti? ","html":"{}"},"kv13.7:5.10":{"pli":"Āmantā. ","html":"{}"},"kv13.7:5.11":{"pli":"Tena hi samāpanno assādeti, jhānanikanti jhānārammaṇāti. ","html":"{}</p>"},"kv13.7:5.12":{"pli":"Samāpanno assādetikathā niṭṭhitā. ","html":"<p class='endsutta'>{}</p></article>"}},"kv13.8":{"kv13.8:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv13.8'><header><ul><li class='division'>{}</li>"},"kv13.8:0.2":{"pli":"Mahāpaṇṇāsaka ","html":"<li>{}</li>"},"kv13.8:0.3":{"pli":"Terasamavagga ","html":"<li>{}</li></ul>"},"kv13.8:0.4":{"pli":"Asātarāgakathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv13.8:1.1":{"pli":"Atthi asātarāgoti? ","html":"<p data-doxy='orthodox'>{}"},"kv13.8:1.2":{"pli":"Āmantā. ","html":"{}"},"kv13.8:1.3":{"pli":"Dukkhābhinandino sattā, atthi keci dukkhaṁ patthenti pihenti esanti gavesanti pariyesanti, dukkhaṁ ajjhosāya tiṭṭhantīti? ","html":"{}"},"kv13.8:1.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv13.8:1.5":{"pli":"nanu sukhābhinandino sattā, atthi keci sukhaṁ patthenti pihenti esanti gavesanti pariyesanti, sukhaṁ ajjhosāya tiṭṭhantīti? ","html":"{}"},"kv13.8:1.6":{"pli":"Āmantā. ","html":"{}"},"kv13.8:1.7":{"pli":"Hañci sukhābhinandino sattā, atthi keci sukhaṁ patthenti pihenti esanti gavesanti pariyesanti, sukhaṁ ajjhosāya tiṭṭhanti, no ca vata re vattabbe—","html":"{}"},"kv13.8:1.8":{"pli":"“atthi asātarāgo”ti. ","html":"{}</p>"},"kv13.8:2.1":{"pli":"Atthi asātarāgoti? ","html":"<p data-doxy='orthodox'>{}"},"kv13.8:2.2":{"pli":"Āmantā. ","html":"{}"},"kv13.8:2.3":{"pli":"Dukkhāya vedanāya rāgānusayo anuseti, sukhāya vedanāya paṭighānusayo anusetīti? ","html":"{}"},"kv13.8:2.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv13.8:2.5":{"pli":"nanu sukhāya vedanāya rāgānusayo anuseti, dukkhāya vedanāya paṭighānusayo anusetīti? ","html":"{}"},"kv13.8:2.6":{"pli":"Āmantā. ","html":"{}"},"kv13.8:2.7":{"pli":"Hañci sukhāya vedanāya rāgānusayo anuseti, dukkhāya vedanāya paṭighānusayo anuseti, no ca vata re vattabbe—","html":"{}"},"kv13.8:2.8":{"pli":"“atthi asātarāgo”ti. ","html":"{}</p>"},"kv13.8:3.1":{"pli":"Na vattabbaṁ—","html":"<p data-doxy='heterodox'>{}"},"kv13.8:3.2":{"pli":"“atthi asātarāgo”ti? ","html":"{}"},"kv13.8:3.3":{"pli":"Āmantā. ","html":"{}"},"kv13.8:3.4":{"pli":"Nanu vuttaṁ bhagavatā—","html":"{}"},"kv13.8:3.5":{"pli":"“so evaṁ anurodhavirodhaṁ samāpanno yaṁ kiñci vedanaṁ vedayati sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā, so taṁ vedanaṁ abhinandati abhivadati ajjhosāya tiṭṭhatī”ti. ","html":"{}"},"kv13.8:3.6":{"pli":"Attheva suttantoti? ","html":"{}"},"kv13.8:3.7":{"pli":"Āmantā. ","html":"{}"},"kv13.8:3.8":{"pli":"Tena hi atthi asātarāgoti. ","html":"{}</p>"},"kv13.8:3.9":{"pli":"Asātarāgakathā niṭṭhitā. ","html":"<p class='endsutta'>{}</p></article>"}},"kv13.9":{"kv13.9:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv13.9'><header><ul><li class='division'>{}</li>"},"kv13.9:0.2":{"pli":"Mahāpaṇṇāsaka ","html":"<li>{}</li>"},"kv13.9:0.3":{"pli":"Terasamavagga ","html":"<li>{}</li></ul>"},"kv13.9:0.4":{"pli":"Dhammataṇhāabyākatātikathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv13.9:1.1":{"pli":"Dhammataṇhā abyākatāti? ","html":"<p data-doxy='orthodox'>{}"},"kv13.9:1.2":{"pli":"Āmantā. ","html":"{}"},"kv13.9:1.3":{"pli":"Vipākābyākatā kiriyābyākatā rūpaṁ nibbānaṁ cakkhāyatanaṁ …pe… ","html":"{}"},"kv13.9:1.4":{"pli":"phoṭṭhabbāyatananti? ","html":"{}"},"kv13.9:1.5":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv13.9:2.1":{"pli":"Dhammataṇhā abyākatāti? ","html":"<p data-doxy='orthodox'>{}"},"kv13.9:2.