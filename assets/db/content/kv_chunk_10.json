"kv13.10:3.3":{"pli":"Nanu taṇhā dukkhasamudayo vutto bhagavatāti? ","html":"{}"},"kv13.10:3.4":{"pli":"Āmantā. ","html":"{}"},"kv13.10:3.5":{"pli":"Hañci taṇhā dukkhasamudayo vutto bhagavatā, no ca vata re vattabbe—","html":"{}"},"kv13.10:3.6":{"pli":"“dhammataṇhā na dukkhasamudayo”ti. ","html":"{}"},"kv13.10:3.7":{"pli":"Dhammataṇhā na dukkhasamudayoti? ","html":"{}"},"kv13.10:3.8":{"pli":"Āmantā. ","html":"{}"},"kv13.10:3.9":{"pli":"Nanu lobho dukkhasamudayo vutto bhagavatā, dhammataṇhā lobhoti? ","html":"{}"},"kv13.10:3.10":{"pli":"Āmantā. ","html":"{}"},"kv13.10:3.11":{"pli":"Hañci lobho dukkhasamudayo vutto bhagavatā, dhammataṇhā lobho, no ca vata re vattabbe—","html":"{}"},"kv13.10:3.12":{"pli":"“dhammataṇhā na dukkhasamudayo”ti. ","html":"{}</p>"},"kv13.10:4.1":{"pli":"Dhammataṇhā lobho, na dukkhasamudayoti? ","html":"<p data-doxy='orthodox'>{}"},"kv13.10:4.2":{"pli":"Āmantā. ","html":"{}"},"kv13.10:4.3":{"pli":"Rūpataṇhā lobho, na dukkhasamudayoti? ","html":"{}"},"kv13.10:4.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv13.10:4.5":{"pli":"dhammataṇhā lobho, na dukkhasamudayoti? ","html":"{}"},"kv13.10:4.6":{"pli":"Āmantā. ","html":"{}"},"kv13.10:4.7":{"pli":"Saddataṇhā …pe… ","html":"{}"},"kv13.10:4.8":{"pli":"gandhataṇhā …pe… ","html":"{}"},"kv13.10:4.9":{"pli":"rasataṇhā …pe… ","html":"{}"},"kv13.10:4.10":{"pli":"phoṭṭhabbataṇhā lobho, na dukkhasamudayoti? ","html":"{}"},"kv13.10:4.11":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv13.10:5.1":{"pli":"Rūpataṇhā lobho dukkhasamudayoti? ","html":"<p data-doxy='orthodox'>{}"},"kv13.10:5.2":{"pli":"Āmantā. ","html":"{}"},"kv13.10:5.3":{"pli":"Dhammataṇhā lobho dukkhasamudayoti? ","html":"{}"},"kv13.10:5.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv13.10:5.5":{"pli":"saddataṇhā …pe… ","html":"{}"},"kv13.10:5.6":{"pli":"phoṭṭhabbataṇhā lobho dukkhasamudayoti? ","html":"{}"},"kv13.10:5.7":{"pli":"Āmantā. ","html":"{}"},"kv13.10:5.8":{"pli":"Dhammataṇhā lobho dukkhasamudayoti? ","html":"{}"},"kv13.10:5.9":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv13.10:6.1":{"pli":"Dhammataṇhā na dukkhasamudayoti? ","html":"<p data-doxy='orthodox'>{}"},"kv13.10:6.2":{"pli":"Āmantā. ","html":"{}"},"kv13.10:6.3":{"pli":"Nanu vuttaṁ bhagavatā—","html":"{}"},"kv13.10:6.4":{"pli":"“yāyaṁ taṇhā ponobbhavikā nandīrāgasahagatā tatratatrābhinandinī, seyyathidaṁ—","html":"{}"},"kv13.10:6.5":{"pli":"kāmataṇhā, bhavataṇhā, vibhavataṇhā”ti. ","html":"{}"},"kv13.10:6.6":{"pli":"Attheva suttantoti? ","html":"{}"},"kv13.10:6.7":{"pli":"Āmantā. ","html":"{}"},"kv13.10:6.8":{"pli":"Tena hi na vattabbaṁ—","html":"{}"},"kv13.10:6.9":{"pli":"“dhammataṇhā na dukkhasamudayo”ti. ","html":"{}</p>"},"kv13.10:7.1":{"pli":"Na vattabbaṁ—","html":"<p data-doxy='heterodox'>{}"},"kv13.10:7.2":{"pli":"“dhammataṇhā na dukkhasamudayo”ti? ","html":"{}"},"kv13.10:7.3":{"pli":"Āmantā. ","html":"{}"},"kv13.10:7.4":{"pli":"Nanu sā dhammataṇhāti? ","html":"{}"},"kv13.10:7.5":{"pli":"Āmantā. ","html":"{}"},"kv13.10:7.6":{"pli":"Hañci sā dhammataṇhā, tena vata re vattabbe—","html":"{}"},"kv13.10:7.7":{"pli":"“dhammataṇhā na dukkhasamudayo”ti. ","html":"{}</p>"},"kv13.10:7.8":{"pli":"Dhammataṇhā na dukkhasamudayotikathā niṭṭhitā. ","html":"<p class='endsutta'>{}<br>"},"kv13.10:7.9":{"pli":"Terasamo vaggo. ","html":"{}</p>"},"kv13.10:7.10":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"kv13.10:8.1":{"pli":"Kappaṭṭho kappaṁ tiṭṭheyya, kappaṭṭho kusalaṁ cittaṁ na paṭilabheyya, anantarāpayutto puggalo sammattaniyāmaṁ okkameyya, niyato niyāmaṁ okkamati, nivuto nīvaraṇaṁ jahati, sammukhībhūto saṁyojanaṁ jahati, jhānanikanti, asātarāgo, dhammataṇhā abyākatā, dhammataṇhā na dukkhasamudayoti. ","html":"<p class='uddana'>{}</p></article>"}},"kv13.2":{"kv13.2:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv13.2'><header><ul><li class='division'>{}</li>"},"kv13.2:0.2":{"pli":"Mahāpaṇṇāsaka ","html":"<li>{}</li>"},"kv13.2:0.3":{"pli":"Terasamavagga ","html":"<li>{}</li></ul>"},"kv13.2:0.4":{"pli":"