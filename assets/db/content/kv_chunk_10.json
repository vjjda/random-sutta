li":"“dhammataṇhā abyākatā”ti. ","html":"{}</p>"},"kv13.9:9.8":{"pli":"Dhammataṇhā abyākatātikathā niṭṭhitā. ","html":"<p class='endsutta'>{}</p></article>"}},"kv14.1":{"kv14.1:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv14.1'><header><ul><li class='division'>{}</li>"},"kv14.1:0.2":{"pli":"Anusayapaṇṇāsaka ","html":"<li>{}</li>"},"kv14.1:0.3":{"pli":"Cuddasamavagga ","html":"<li>{}</li></ul>"},"kv14.1:0.4":{"pli":"Kusalākusalapaṭisandahanakathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv14.1:1.1":{"pli":"Akusalamūlaṁ paṭisandahati kusalamūlanti? ","html":"<p>{}"},"kv14.1:1.2":{"pli":"Āmantā. ","html":"{}"},"kv14.1:1.3":{"pli":"Yā akusalassa uppādāya āvaṭṭanā …pe… paṇidhi, sāva kusalassa uppādāya āvaṭṭanā …pe… paṇidhīti? ","html":"{}"},"kv14.1:1.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv14.1:2.1":{"pli":"Akusalamūlaṁ paṭisandahati kusalamūlaṁ, na vattabbaṁ—","html":"<p data-doxy='orthodox'>{}"},"kv14.1:2.2":{"pli":"“yā akusalassa uppādāya āvaṭṭanā …pe… paṇidhi, sāva kusalassa uppādāya āvaṭṭanā …pe… paṇidhī”ti? ","html":"{}"},"kv14.1:2.3":{"pli":"Āmantā. ","html":"{}"},"kv14.1:2.4":{"pli":"Kusalaṁ anāvaṭṭentassa uppajjati …pe… appaṇidahantassa uppajjatīti? ","html":"{}"},"kv14.1:2.5":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv14.1:2.6":{"pli":"nanu kusalaṁ āvaṭṭentassa uppajjati …pe… paṇidahantassa uppajjatīti? ","html":"{}"},"kv14.1:2.7":{"pli":"Āmantā. ","html":"{}"},"kv14.1:2.8":{"pli":"Hañci kusalaṁ āvaṭṭentassa uppajjati …pe… paṇidahantassa uppajjati, no ca vata re vattabbe—","html":"{}"},"kv14.1:2.9":{"pli":"“akusalamūlaṁ paṭisandahati kusalamūlan”ti. ","html":"{}</p>"},"kv14.1:3.1":{"pli":"Akusalamūlaṁ paṭisandahati kusalamūlanti? ","html":"<p data-doxy='orthodox'>{}"},"kv14.1:3.2":{"pli":"Āmantā. ","html":"{}"},"kv14.1:3.3":{"pli":"Akusalamūlaṁ ayoniso manasikaroto uppajjatīti? ","html":"{}"},"kv14.1:3.4":{"pli":"Āmantā. ","html":"{}"},"kv14.1:3.5":{"pli":"Kusalaṁ ayoniso manasikaroto uppajjatīti? ","html":"{}"},"kv14.1:3.6":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv14.1:3.7":{"pli":"nanu kusalaṁ yoniso manasikaroto uppajjatīti? ","html":"{}"},"kv14.1:3.8":{"pli":"Āmantā. ","html":"{}"},"kv14.1:3.9":{"pli":"Hañci kusalaṁ yoniso manasikaroto uppajjati, no ca vata re vattabbe—","html":"{}"},"kv14.1:3.10":{"pli":"“akusalamūlaṁ paṭisandahati kusalamūlan”ti. ","html":"{}</p>"},"kv14.1:4.1":{"pli":"Akusalamūlaṁ paṭisandahati kusalamūlanti? ","html":"<p data-doxy='orthodox'>{}"},"kv14.1:4.2":{"pli":"Āmantā. ","html":"{}"},"kv14.1:4.3":{"pli":"Kāmasaññāya anantarā nekkhammasaññā uppajjati, byāpādasaññāya anantarā abyāpādasaññā uppajjati, vihiṁsāsaññāya anantarā avihiṁsāsaññā uppajjati, byāpādassa anantarā mettā uppajjati, vihiṁsāya anantarā karuṇā uppajjati, aratiyā anantarā muditā uppajjati, paṭighassa anantarā upekkhā uppajjatīti? ","html":"{}"},"kv14.1:4.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv14.1:5.1":{"pli":"Kusalamūlaṁ paṭisandahati akusalamūlanti? ","html":"<p data-doxy='orthodox'>{}"},"kv14.1:5.2":{"pli":"Āmantā. ","html":"{}"},"kv14.1:5.3":{"pli":"Yā kusalassa uppādāya āvaṭṭanā …pe… paṇidhi, sāva akusalassa uppādāya āvaṭṭanā …pe… paṇidhīti? ","html":"{}"},"kv14.1:5.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv14.1:6.1":{"pli":"Kusalamūlaṁ paṭisandahati akusalamūlaṁ, na vattabbaṁ—","html":"<p data-doxy='orthodox'>{}"},"kv14.1:6.2":{"pli":"“yā kusalassa uppādāya āvaṭṭanā …pe… paṇidhi, sāva akusalassa uppādāya āvaṭṭanā …pe… paṇidhī”ti? ","html":"{}"},"kv14.1:6.3":{"pli":"Āmantā. ","html":"{}"},"kv14.1:6.4":{"pli":"Akusalaṁ anāvaṭṭentassa uppajjati …pe… appaṇidahantassa uppajjatīti? ","html":"{}"},"kv14.1:6.5":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv14.1:6.6":{"pli":"nanu akusalaṁ āvaṭṭentassa uppajjati …pe… paṇidahantassa uppajjatīti? ","html":"{}"},"kv14.1:6.7":{"pli":"Āmantā. ","html":"{}"},"kv14.1:6.8":{"pli":"Hañci akusalaṁ āvaṭṭentassa uppajjati …pe… paṇidahantassa uppajjati, no ca vata re vattabbe—","html":"{}"},"kv14.1:6.9":{"pli":"“kusalamūlaṁ paṭisandahati akusalamūlan”ti. ","html":"{}</p>"},"kv14.1:7.1":{"pli":"Kusalamūlaṁ paṭisandahati akusalamūlanti? ","html":"<p data-doxy='orthodox'>{}"},"kv14.1:7.2":{"pli":"Āmantā. ","html":"{}"},"kv14.1:7.3":{"pli":"Kusalaṁ yoniso manasikaroto uppajjatīti? ","html":"{}"},"kv14.1:7.4":{"pli":"Āmantā. ","html":"{}"},"kv14.1:7.5":{"pli":"Akusalaṁ yoniso manasikaroto uppajjatīti? ","html":"{}"},"kv14.1:7.6":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv14.1:7.7":{"pli":"nanu akusalaṁ ayoniso manasikaroto uppajjatīti? ","html":"{}"},"kv14.1:7.8":{"pli":"Āmantā. ","html":"{}"},"kv14.1:7.9":{"pli":"Hañci akusalaṁ ayoniso manasikaroto uppajjati, no ca vata re vattabbe—","html":"{}"},"kv14.1:7.10":{"pli":"“kusalamūlaṁ paṭisandahati akusalamūlan”ti. ","html":"{}</p>"},"kv14.1:8.1":{"pli":"Kusalamūlaṁ paṭisandahati akusalamūlanti? ","html":"<p data-doxy='orthodox'>{}"},"kv14.1:8.2":{"pli":"Āmantā. ","html":"{}"},"kv14.1:8.3":{"pli":"Nekkhammasaññāya anantarā kāmasaññā uppajjati, abyāpādasaññāya anantarā byāpādasaññā uppajjati, avihiṁsāsaññāya anantarā vihiṁsāsaññā uppajjati, mettāya anantarā byāpādo uppajjati, karuṇāya anantarā vihiṁsā uppajjati, muditāya anantarā arati uppajjati, upekkhāya anantarā paṭighaṁ uppajjatīti? ","html":"{}"},"kv14.1:8.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv14.1:9.1":{"pli":"Na vattabbaṁ—","html":"<p data-doxy='heterodox'>{}"},"kv14.1:9.2":{"pli":"“akusalamūlaṁ paṭisandahati kusalamūlaṁ, kusalamūlaṁ paṭisandahati akusalamūlan”ti? ","html":"{}"},"kv14.1:9.3":{"pli":"Āmantā. ","html":"{}"},"kv14.1:9.4":{"pli":"Nanu yasmiññeva vatthusmiṁ rajjati tasmiññeva vatthusmiṁ virajjati, yasmiññeva vatthusmiṁ virajjati tasmiññeva vatthusmiṁ rajjatīti? ","html":"{}"},"kv14.1:9.5":{"pli":"Āmantā. ","html":"{}"},"kv14.1:9.6":{"pli":"Hañci yasmiññeva vatthusmiṁ rajjati tasmiññeva vatthusmiṁ virajjati, yasmiññeva vatthusmiṁ virajjati tasmiññeva vatthusmiṁ rajjati, tena vata re vattabbe—","html":"{}"},"kv14.1:9.7":{"pli":"“akusalamūlaṁ paṭisandahati kusalamūlaṁ, kusalamūlaṁ paṭisandahati akusalamūlan”ti. ","html":"{}</p>"},"kv14.1:9.8":{"pli":"Kusalākusalapaṭisandahanakathā niṭṭhitā. ","html":"<p class='endsutta'>{}</p></article>"}}}