{"vv50":{"vv50:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv50'><header><ul><li class='division'>{}</li>"},"vv50:0.2":{"pli":"Itthivimāna ","html":"<li>{}</li>"},"vv50:0.3":{"pli":"Mañjiṭṭhakavagga ","html":"<li>{}</li></ul>"},"vv50:0.4":{"pli":"12. Rajjumālāvimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv50:1.1":{"pli":"“Abhikkantena vaṇṇena, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv50:1.2":{"pli":"yā tvaṁ tiṭṭhasi devate; ","html":"<span class='verse-line'>{}</span>"},"vv50:1.3":{"pli":"Hatthapāde ca viggayha, ","html":"<span class='verse-line'>{}</span>"},"vv50:1.4":{"pli":"naccasi suppavādite. ","html":"<span class='verse-line'>{}</span></p>"},"vv50:2.1":{"pli":"Tassā te naccamānāya, ","html":"<p><span class='verse-line'>{}</span>"},"vv50:2.2":{"pli":"aṅgamaṅgehi sabbaso; ","html":"<span class='verse-line'>{}</span>"},"vv50:2.3":{"pli":"Dibbā saddā niccharanti, ","html":"<span class='verse-line'>{}</span>"},"vv50:2.4":{"pli":"savanīyā manoramā. ","html":"<span class='verse-line'>{}</span></p>"},"vv50:3.1":{"pli":"Tassā te naccamānāya, ","html":"<p><span class='verse-line'>{}</span>"},"vv50:3.2":{"pli":"aṅgamaṅgehi sabbaso; ","html":"<span class='verse-line'>{}</span>"},"vv50:3.3":{"pli":"Dibbā gandhā pavāyanti, ","html":"<span class='verse-line'>{}</span>"},"vv50:3.4":{"pli":"sucigandhā manoramā. ","html":"<span class='verse-line'>{}</span></p>"},"vv50:4.1":{"pli":"Vivattamānā kāyena, ","html":"<p><span class='verse-line'>{}</span>"},"vv50:4.2":{"pli":"yā veṇīsu piḷandhanā; ","html":"<span class='verse-line'>{}</span>"},"vv50:4.3":{"pli":"Tesaṁ suyyati nigghoso, ","html":"<span class='verse-line'>{}</span>"},"vv50:4.4":{"pli":"tūriye pañcaṅgike yathā. ","html":"<span class='verse-line'>{}</span></p>"},"vv50:5.1":{"pli":"Vaṭaṁsakā vātadhutā, ","html":"<p><span class='verse-line'>{}</span>"},"vv50:5.2":{"pli":"vātena sampakampitā; ","html":"<span class='verse-line'>{}</span>"},"vv50:5.3":{"pli":"Tesaṁ suyyati nigghoso, ","html":"<span class='verse-line'>{}</span>"},"vv50:5.4":{"pli":"tūriye pañcaṅgike yathā. ","html":"<span class='verse-line'>{}</span></p>"},"vv50:6.1":{"pli":"Yāpi te sirasmiṁ mālā, ","html":"<p><span class='verse-line'>{}</span>"},"vv50:6.2":{"pli":"sucigandhā manoramā; ","html":"<span class='verse-line'>{}</span>"},"vv50:6.3":{"pli":"Vāti gandho disā sabbā, ","html":"<span class='verse-line'>{}</span>"},"vv50:6.4":{"pli":"rukkho mañjūsako yathā. ","html":"<span class='verse-line'>{}</span></p>"},"vv50:7.1":{"pli":"Ghāyase taṁ sucigandhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv50:7.2":{"pli":"rūpaṁ passasi amānusaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv50:7.3":{"pli":"Devate pucchitācikkha, ","html":"<span class='verse-line'>{}</span>"},"vv50:7.4":{"pli":"kissa kammassidaṁ phalan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv50:8.1":{"pli":"“Dāsī ahaṁ pure āsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv50:8.2":{"pli":"gayāyaṁ brāhmaṇassahaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv50:8.3":{"pli":"Appapuññā alakkhikā, ","html":"<span class='verse-line'>{}</span>"},"vv50:8.4":{"pli":"rajjumālāti maṁ viduṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv50:9.1":{"pli":"Akkosānaṁ vadhānañca, ","html":"<p><span class='verse-line'>{}</span>"},"vv50:9.2":{"pli":"tajjanāya ca uggatā; ","html":"<span class='verse-line'>{}</span>"},"vv50:9.3":{"pli":"Kuṭaṁ gahetvā nikkhamma, ","html":"<span class='verse-line'>{}</span>"},"vv50:9.4":{"pli":"agañchiṁ udahāriyā. ","html":"<span class='verse-line'>{}</span></p>"},"vv50:10.1":{"pli":"Vipathe kuṭaṁ nikkhipitvā, ","html":"<p><span class='verse-line'>{}</span>"},"vv50:10.2":{"pli":"vanasaṇḍaṁ upāgamiṁ; ","html":"<span class='verse-line'>{}</span>"},"vv50:10.3":{"pli":"Idhevāhaṁ marissāmi, ","html":"<span class='verse-line'>{}</span>"},"vv50:10.4":{"pli":"ko attho jīvitena me. ","html":"<span class='verse-line'>{}</span></p>"},"vv50:11.1":{"pli":"Daḷhaṁ pāsaṁ karitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"vv50:11.2":{"pli":"āsumbhitvāna pādape; ","html":"<span class='verse-line'>{}</span>"},"vv50:11.3":{"pli":"Tato disā vilokesiṁ, ","html":"<span class='verse-line'>{}</span>"},"vv50:11.4":{"pli":"‘ko nu kho vanamassito’. ","html":"<span class='verse-line'>{}</span></p>"},"vv50:12.1":{"pli":"Tatthaddasāsiṁ sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv50:12.2":{"pli":"sabbalokahitaṁ muniṁ; ","html":"<span class='verse-line'>{}</span>"},"vv50:12.3":{"pli":"Nisinnaṁ rukkhamūlasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"vv50:12.4":{"pli":"jhāyantaṁ akutobhayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv50:13.1":{"pli":"Tassā me ahu saṁvego, ","html":"<p><span class='verse-line'>{}</span>"},"vv50:13.2":{"pli":"abbhuto lomahaṁsano; ","html":"<span class='verse-line'>{}</span>"},"vv50:13.3":{"pli":"Ko nu kho vanamassito, ","html":"<span class='verse-line'>{}</span>"},"vv50:13.4":{"pli":"manusso udāhu devatā. ","html":"<span class='verse-line'>{}</span></p>"},"vv50:14.1":{"pli":"Pāsādikaṁ pasādanīyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv50:14.2":{"pli":"vanā nibbanamāgataṁ; ","html":"<span class='verse-line'>{}</span>"},"vv50:14.3":{"pli":"Disvā mano me pasīdi, ","html":"<span class='verse-line'>{}</span>"},"vv50:14.4":{"pli":"nāyaṁ yādisakīdiso. ","html":"<span class='verse-line'>{}</span></p>"},"vv50:15.1":{"pli":"Guttindriyo jhānarato, ","html":"<p><span class='verse-line'>{}</span>"},"vv50:15.2":{"pli":"abahiggatamānaso; ","html":"<span class='verse-line'>{}</span>"},"vv50:15.3":{"pli":"Hito sabbassa lokassa, ","html":"<span class='verse-line'>{}</span>"},"vv50:15.4":{"pli":"buddho ayaṁ bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"vv50:16.1":{"pli":"Bhayabheravo durāsado, ","html":"<p><span class='verse-line'>{}</span>"},"vv50:16.2":{"pli":"sīhova guhamassito; ","html":"<span class='verse-line'>{}</span>"},"vv50:16.3":{"pli":"Dullabhāyaṁ dassanāya, ","html":"<span class='verse-line'>{}</span>"},"vv50:16.4":{"pli":"pupphaṁ odumbaraṁ yathā. ","html":"<span class='verse-line'>{}</span></p>"},"vv50:17.1":{"pli":"So maṁ mudūhi vācāhi, ","html":"<p><span class='verse-line'>{}</span>"},"vv50:17.2":{"pli":"ālapitvā tathāgato; ","html":"<span class='verse-line'>{}</span>"},"vv50:17.3":{"pli":"Rajjumāleti maṁvoca, ","html":"<span class='verse-line'>{}</span>"},"vv50:17.4":{"pli":"saraṇaṁ gaccha tathāgataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv50:18.1":{"pli":"Tāhaṁ giraṁ suṇitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"vv50:18.2":{"pli":"nelaṁ atthavatiṁ suciṁ; ","html":"<span class='verse-line'>{}</span>"},"vv50:18.3":{"pli":"Saṇhaṁ muduñca vagguñca, ","html":"<span class='verse-line'>{}</span>"},"vv50:18.4":{"pli":"sabbasokāpanūdanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv50:19.1":{"pli":"Kallacittañca maṁ ñatvā, ","html":"<p><span class='verse-line'>{}</span>"},"vv50:19.2":{"pli":"pasannaṁ suddhamānasaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv50:19.3":{"pli":"Hito sabbassa lokassa, ","html":"<span class='verse-line'>{}</span>"},"vv50:19.4":{"pli":"anusāsi tathāgato. ","html":"<span class='verse-line'>{}</span></p>"},"vv50:20.1":{"pli":"Idaṁ dukkhanti maṁvoca, ","html":"<p><span class='verse-line'>{}</span>"},"vv50:20.2":{"pli":"Ayaṁ dukkhassa sambhavo; ","html":"<span class='verse-line'>{}</span>"},"vv50:20.3":{"pli":"Dukkha nirodho maggo ca, ","html":"<span class='verse-line'>{}</span>"},"vv50:20.4":{"pli":"Añjaso amatogadho. ","html":"<span class='verse-line'>{}</span></p>"},"vv50:21.1":{"pli":"Anukampakassa kusalassa, ","html":"<p><span class='verse-line'>{}</span>"},"vv50:21.2":{"pli":"Ovādamhi ahaṁ ṭhitā; ","html":"<span class='verse-line'>{}</span>"},"vv50:21.3":{"pli":"Ajjhagā amataṁ santiṁ, ","html":"<span class='verse-line'>{}</span>"},"vv50:21.4":{"pli":"Nibbānaṁ padamaccutaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv50:22.1":{"pli":"Sāhaṁ avaṭṭhitāpemā, ","html":"<p><span class='verse-line'>{}</span>"},"vv50:22.2":{"pli":"dassane avikampinī; ","html":"<span class='verse-line'>{}</span>"},"vv50:22.3":{"pli":"Mūlajātāya saddhāya, ","html":"<span class='verse-line'>{}</span>"},"vv50:22.4":{"pli":"dhītā buddhassa orasā. ","html":"<span class='verse-line'>{}</span></p>"},"vv50:23.1":{"pli":"Sāhaṁ ramāmi kīḷāmi, ","html":"<p><span class='verse-line'>{}</span>"},"vv50:23.2":{"pli":"modāmi akutobhayā; ","html":"<span class='verse-line'>{}</span>"},"vv50:23.3":{"pli":"Dibbamālaṁ dhārayāmi, ","html":"<span class='verse-line'>{}</span>"},"vv50:23.4":{"pli":"pivāmi madhumaddavaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv50:24.1":{"pli":"Saṭṭhitūriyasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"vv50:24.2":{"pli":"paṭibodhaṁ karonti me; ","html":"<span class='verse-line'>{}</span>"},"vv50:24.3":{"pli":"Āḷambo gaggaro bhīmo, ","html":"<span class='verse-line'>{}</span>"},"vv50:24.4":{"pli":"sādhuvādī ca saṁsayo. ","html":"<span class='verse-line'>{}</span></p>"},"vv50:25.1":{"pli":"Pokkharo ca suphasso ca, ","html":"<p><span class='verse-line'>{}</span>"},"vv50:25.2":{"pli":"vīṇāmokkhā ca nāriyo; ","html":"<span class='verse-line'>{}</span>"},"vv50:25.3":{"pli":"Nandā ceva sunandā ca, ","html":"<span class='verse-line'>{}</span>"},"vv50:25.4":{"pli":"soṇadinnā sucimhitā. ","html":"<span class='verse-line'>{}</span></p>"},"vv50:26.1":{"pli":"Alambusā missakesī ca, ","html":"<p><span class='verse-line'>{}</span>"},"vv50:26.2":{"pli":"puṇḍarīkātidāruṇī; ","html":"<span class='verse-line'>{}</span>"},"vv50:26.3":{"pli":"Eṇīphassā suphassā ca, ","html":"<span class='verse-line'>{}</span>"},"vv50:26.4":{"pli":"subhaddā muduvādinī. ","html":"<span class='verse-line'>{}</span></p>"},"vv50:27.1":{"pli":"Etā caññā ca seyyāse, ","html":"<p><span class='verse-line'>{}</span>"},"vv50:27.2":{"pli":"accharānaṁ pabodhikā; ","html":"<span class='verse-line'>{}</span>"},"vv50:27.3":{"pli":"Tā maṁ kālenupāgantvā, ","html":"<span class='verse-line'>{}</span>"},"vv50:27.4":{"pli":"abhibhāsanti devatā. ","html":"<span class='verse-line'>{}</span></p>"},"vv50:28.1":{"pli":"Handa naccāma gāyāma, ","html":"<p><span class='verse-line'>{}</span>"},"vv50:28.2":{"pli":"handa taṁ ramayāmase; ","html":"<span class='verse-line'>{}</span>"},"vv50:28.3":{"pli":"Nayidaṁ akatapuññānaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv50:28.4":{"pli":"katapuññānamevidaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv50:29.1":{"pli":"Asokaṁ nandanaṁ rammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv50:29.2":{"pli":"tidasānaṁ mahāvanaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv50:29.3":{"pli":"Sukhaṁ akatapuññānaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv50:29.4":{"pli":"idha natthi parattha ca. ","html":"<span class='verse-line'>{}</span></p>"},"vv50:30.1":{"pli":"Sukhañca katapuññānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv50:30.2":{"pli":"idha ceva parattha ca; ","html":"<span class='verse-line'>{}</span>"},"vv50:30.3":{"pli":"Tesaṁ sahabyakāmānaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv50:30.4":{"pli":"kattabbaṁ kusalaṁ bahuṁ; ","html":"<span class='verse-line'>{}</span>"},"vv50:30.5":{"pli":"Katapuññā hi modanti, ","html":"<span class='verse-line'>{}</span>"},"vv50:30.6":{"pli":"sagge bhogasamaṅgino. ","html":"<span class='verse-line'>{}</span></p>"},"vv50:31.1":{"pli":"Bahūnaṁ vata atthāya, ","html":"<p><span class='verse-line'>{}</span>"},"vv50:31.2":{"pli":"uppajjanti tathāgatā; ","html":"<span class='verse-line'>{}</span>"},"vv50:31.3":{"pli":"Dakkhiṇeyyā manussānaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv50:31.4":{"pli":"puññakhettānamākarā; ","html":"<span class='verse-line'>{}</span>"},"vv50:31.5":{"pli":"Yattha kāraṁ karitvāna, ","html":"<span class='verse-line'>{}</span>"},"vv50:31.6":{"pli":"sagge modanti dāyakā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv50:32.1":{"pli":"Rajjumālāvimānaṁ dvādasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"vv50:33.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"vv50:34.1":{"pli":"Mañjiṭṭhā pabhassarā nāgā, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"vv50:34.2":{"pli":"Alomākañjikadāyikā; ","html":"<span class='verse-line'>{}</span>"},"vv50:34.3":{"pli":"Vihāracaturitthambā, ","html":"<span class='verse-line'>{}</span>"},"vv50:34.4":{"pli":"Pītā ucchuvandanarajjumālā ca; ","html":"<span class='verse-line'>{}</span>"},"vv50:34.5":{"pli":"Vaggo tena pavuccatīti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv50:35.1":{"pli":"Mañjiṭṭhakavaggo catuttho. ","html":"<p class='endsutta'>{}</p>"},"vv50:36.1":{"pli":"Itthivimānaṁ samattaṁ. ","html":"<p class='endsection'>{}</p></article>"}},"vv51":{"vv51:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv51'><header><ul><li class='division'>{}</li>"},"vv51:0.2":{"pli":"Purisavimāna ","html":"<li>{}</li>"},"vv51:0.3":{"pli":"Mahārathavagga ","html":"<li>{}</li></ul>"},"vv51:0.4":{"pli":"1. Maṇḍūkadevaputtavimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv51:1.1":{"pli":"“Ko me vandati pādāni, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv51:1.2":{"pli":"iddhiyā yasasā jalaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv51:1.3":{"pli":"Abhikkantena vaṇṇena, ","html":"<span class='verse-line'>{}</span>"},"vv51:1.4":{"pli":"sabbā obhāsayaṁ disā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv51:2.1":{"pli":"“Maṇḍūkohaṁ pure āsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv51:2.2":{"pli":"udake vārigocaro; ","html":"<span class='verse-line'>{}</span>"},"vv51:2.3":{"pli":"Tava dhammaṁ suṇantassa, ","html":"<span class='verse-line'>{}</span>"},"vv51:2.4":{"pli":"avadhī vacchapālako. ","html":"<span class='verse-line'>{}</span></p>"},"vv51:3.1":{"pli":"Muhuttaṁ cittapasādassa, ","html":"<p><span class='verse-line'>{}</span>"},"vv51:3.2":{"pli":"iddhiṁ passa yasañca me; ","html":"<span class='verse-line'>{}</span>"},"vv51:3.3":{"pli":"Ānubhāvañca me passa, ","html":"<span class='verse-line'>{}</span>"},"vv51:3.4":{"pli":"vaṇṇaṁ passa jutiñca me. ","html":"<span class='verse-line'>{}</span></p>"},"vv51:4.1":{"pli":"Ye ca te dīghamaddhānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv51:4.2":{"pli":"dhammaṁ assosuṁ gotama; ","html":"<span class='verse-line'>{}</span>"},"vv51:4.3":{"pli":"Pattā te acalaṭṭhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv51:4.4":{"pli":"yattha gantvā na socare”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv51:5.1":{"pli":"Maṇḍūkadevaputtavimānaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"vv52":{"vv52:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv52'><header><ul><li class='division'>{}</li>"},"vv52:0.2":{"pli":"Purisavimāna ","html":"<li>{}</li>"},"vv52:0.3":{"pli":"Mahārathavagga ","html":"<li>{}</li></ul>"},"vv52:0.4":{"pli":"2. Revatīvimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv52:1.1":{"pli":"“Cirappavāsiṁ purisaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv52:1.2":{"pli":"dūrato sotthimāgataṁ; ","html":"<span class='verse-line'>{}</span>"},"vv52:1.3":{"pli":"Ñātimittā suhajjā ca, ","html":"<span class='verse-line'>{}</span>"},"vv52:1.4":{"pli":"abhinandanti āgataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv52:2.1":{"pli":"Tatheva katapuññampi, ","html":"<p><span class='verse-line'>{}</span>"},"vv52:2.2":{"pli":"asmā lokā paraṁ gataṁ; ","html":"<span class='verse-line'>{}</span>"},"vv52:2.3":{"pli":"Puññāni paṭigaṇhanti, ","html":"<span class='verse-line'>{}</span>"},"vv52:2.4":{"pli":"piyaṁ ñātīva āgataṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"vv52:3.1":{"pli":"“Uṭṭhehi revate supāpadhamme, ","html":"<p><span class='verse-line'>{}</span>"},"vv52:3.2":{"pli":"Apārutadvāre adānasīle; ","html":"<span class='verse-line'>{}</span>"},"vv52:3.3":{"pli":"Nessāma taṁ yattha thunanti duggatā, ","html":"<span class='verse-line'>{}</span>"},"vv52:3.4":{"pli":"Samappitā nerayikā dukkhenā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv52:4.1":{"pli":"Icceva vatvāna yamassa dūtā, ","html":"<p><span class='verse-line'>{}</span>"},"vv52:4.2":{"pli":"Te dve yakkhā lohitakkhā brahantā; ","html":"<span class='verse-line'>{}</span>"},"vv52:4.3":{"pli":"Paccekabāhāsu gahetvā revataṁ, ","html":"<span class='verse-line'>{}</span>"},"vv52:4.4":{"pli":"Pakkāmayuṁ devagaṇassa santike. ","html":"<span class='verse-line'>{}</span></p>"},"vv52:5.1":{"pli":"“Ādiccavaṇṇaṁ ruciraṁ pabhassaraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv52:5.2":{"pli":"Byamhaṁ subhaṁ kañcanajālachannaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv52:5.3":{"pli":"Kassetamākiṇṇajanaṁ vimānaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv52:5.4":{"pli":"Suriyassa raṁsīriva jotamānaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv52:6.1":{"pli":"Nārīgaṇā candanasāralittā, ","html":"<p><span class='verse-line'>{}</span>"},"vv52:6.2":{"pli":"Ubhato vimānaṁ upasobhayanti; ","html":"<span class='verse-line'>{}</span>"},"vv52:6.3":{"pli":"Taṁ dissati suriyasamānavaṇṇaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv52:6.4":{"pli":"Ko modati saggapatto vimāne”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv52:7.1":{"pli":"“Bārāṇasiyaṁ nandiyo nāmāsi, ","html":"<p><span class='verse-line'>{}</span>"},"vv52:7.2":{"pli":"Upāsako amaccharī dānapati vadaññū; ","html":"<span class='verse-line'>{}</span>"},"vv52:7.3":{"pli":"Tassetamākiṇṇajanaṁ vimānaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv52:7.4":{"pli":"Suriyassa raṁsīriva jotamānaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv52:8.1":{"pli":"Nārīgaṇā candanasāralittā, ","html":"<p><span class='verse-line'>{}</span>"},"vv52:8.2":{"pli":"Ubhato vimānaṁ upasobhayanti; ","html":"<span class='verse-line'>{}</span>"},"vv52:8.3":{"pli":"Taṁ dissati suriyasamānavaṇṇaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv52:8.4":{"pli":"So modati saggapatto vimāne”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv52:9.1":{"pli":"“Nandiyassāhaṁ bhariyā, ","html":"<p><span class='verse-line'>{}</span>"},"vv52:9.2":{"pli":"Agārinī sabbakulassa issarā; ","html":"<span class='verse-line'>{}</span>"},"vv52:9.3":{"pli":"Bhattu vimāne ramissāmi dānahaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv52:9.4":{"pli":"Na patthaye nirayaṁ dassanāyā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv52:10.1":{"pli":"“Eso te nirayo supāpadhamme, ","html":"<p><span class='verse-line'>{}</span>"},"vv52:10.2":{"pli":"Puññaṁ tayā akataṁ jīvaloke; ","html":"<span class='verse-line'>{}</span>"},"vv52:10.3":{"pli":"Na hi maccharī rosako pāpadhammo, ","html":"<span class='verse-line'>{}</span>"},"vv52:10.4":{"pli":"Saggūpagānaṁ labhati sahabyatan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv52:11.1":{"pli":"“Kiṁ nu gūthañca muttañca, ","html":"<p><span class='verse-line'>{}</span>"},"vv52:11.2":{"pli":"asucī paṭidissati; ","html":"<span class='verse-line'>{}</span>"},"vv52:11.3":{"pli":"Duggandhaṁ kimidaṁ mīḷhaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv52:11.4":{"pli":"kimetaṁ upavāyatī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv52:12.1":{"pli":"“Esa saṁsavako nāma, ","html":"<p><span class='verse-line'>{}</span>"},"vv52:12.2":{"pli":"gambhīro sataporiso; ","html":"<span class='verse-line'>{}</span>"},"vv52:12.3":{"pli":"Yattha vassasahassāni, ","html":"<span class='verse-line'>{}</span>"},"vv52:12.4":{"pli":"tuvaṁ paccasi revate”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv52:13.1":{"pli":"“Kiṁ nu kāyena vācāya, ","html":"<p><span class='verse-line'>{}</span>"},"vv52:13.2":{"pli":"manasā dukkaṭaṁ kataṁ; ","html":"<span class='verse-line'>{}</span>"},"vv52:13.3":{"pli":"Kena saṁsavako laddho, ","html":"<span class='verse-line'>{}</span>"},"vv52:13.4":{"pli":"gambhīro sataporiso”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv52:14.1":{"pli":"“Samaṇe brāhmaṇe cāpi, ","html":"<p><span class='verse-line'>{}</span>"},"vv52:14.2":{"pli":"aññe vāpi vanibbake; ","html":"<span class='verse-line'>{}</span>"},"vv52:14.3":{"pli":"Musāvādena vañcesi, ","html":"<span class='verse-line'>{}</span>"},"vv52:14.4":{"pli":"taṁ pāpaṁ pakataṁ tayā. ","html":"<span class='verse-line'>{}</span></p>"},"vv52:15.1":{"pli":"Tena saṁsavako laddho, ","html":"<p><span class='verse-line'>{}</span>"},"vv52:15.2":{"pli":"gambhīro sataporiso; ","html":"<span class='verse-line'>{}</span>"},"vv52:15.3":{"pli":"Tattha vassasahassāni, ","html":"<span class='verse-line'>{}</span>"},"vv52:15.4":{"pli":"tuvaṁ paccasi revate. ","html":"<span class='verse-line'>{}</span></p>"},"vv52:16.1":{"pli":"Hatthepi chindanti athopi pāde, ","html":"<p><span class='verse-line'>{}</span>"},"vv52:16.2":{"pli":"Kaṇṇepi chindanti athopi nāsaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv52:16.3":{"pli":"Athopi kākoḷagaṇā samecca, ","html":"<span class='verse-line'>{}</span>"},"vv52:16.4":{"pli":"Saṅgamma khādanti viphandamānan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv52:17.1":{"pli":"“Sādhu kho maṁ paṭinetha, ","html":"<p><span class='verse-line'>{}</span>"},"vv52:17.2":{"pli":"kāhāmi kusalaṁ bahuṁ; ","html":"<span class='verse-line'>{}</span>"},"vv52:17.3":{"pli":"Dānena samacariyāya, ","html":"<span class='verse-line'>{}</span>"},"vv52:17.4":{"pli":"saṁyamena damena ca; ","html":"<span class='verse-line'>{}</span>"},"vv52:17.5":{"pli":"Yaṁ katvā sukhitā honti, ","html":"<span class='verse-line'>{}</span>"},"vv52:17.6":{"pli":"na ca pacchānutappare”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv52:18.1":{"pli":"“Pure tuvaṁ pamajjitvā, ","html":"<p><span class='verse-line'>{}</span>"},"vv52:18.2":{"pli":"idāni paridevasi; ","html":"<span class='verse-line'>{}</span>"},"vv52:18.3":{"pli":"Sayaṁ katānaṁ kammānaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv52:18.4":{"pli":"vipākaṁ anubhossasī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv52:19.1":{"pli":"“Ko devalokato manussalokaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv52:19.2":{"pli":"Gantvāna puṭṭho me evaṁ vadeyya; ","html":"<span class='verse-line'>{}</span>"},"vv52:19.3":{"pli":"‘Nikkhittadaṇḍesu dadātha dānaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv52:19.4":{"pli":"Acchādanaṁ seyyamathannapānaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv52:19.5":{"pli":"Na hi maccharī rosako pāpadhammo, ","html":"<span class='verse-line'>{}</span>"},"vv52:19.6":{"pli":"Saggūpagānaṁ labhati sahabyataṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"vv52:20.1":{"pli":"Sāhaṁ nūna ito gantvā, ","html":"<p><span class='verse-line'>{}</span>"},"vv52:20.2":{"pli":"yoniṁ laddhāna mānusiṁ; ","html":"<span class='verse-line'>{}</span>"},"vv52:20.3":{"pli":"Vadaññū sīlasampannā, ","html":"<span class='verse-line'>{}</span>"},"vv52:20.4":{"pli":"kāhāmi kusalaṁ bahuṁ; ","html":"<span class='verse-line'>{}</span>"},"vv52:20.5":{"pli":"Dānena samacariyāya, ","html":"<span class='verse-line'>{}</span>"},"vv52:20.6":{"pli":"saṁyamena damena ca. ","html":"<span class='verse-line'>{}</span></p>"},"vv52:21.1":{"pli":"Ārāmāni ca ropissaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv52:21.2":{"pli":"dugge saṅkamanāni ca; ","html":"<span class='verse-line'>{}</span>"},"vv52:21.3":{"pli":"Papañca udapānañca, ","html":"<span class='verse-line'>{}</span>"},"vv52:21.4":{"pli":"vippasannena cetasā. ","html":"<span class='verse-line'>{}</span></p>"},"vv52:22.1":{"pli":"Cātuddasiṁ pañcadasiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv52:22.2":{"pli":"yā ca pakkhassa aṭṭhamī; ","html":"<span class='verse-line'>{}</span>"},"vv52:22.3":{"pli":"Pāṭihāriyapakkhañca, ","html":"<span class='verse-line'>{}</span>"},"vv52:22.4":{"pli":"aṭṭhaṅgasusamāgataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv52:23.1":{"pli":"Uposathaṁ upavasissaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv52:23.2":{"pli":"sadā sīlesu saṁvutā; ","html":"<span class='verse-line'>{}</span>"},"vv52:23.3":{"pli":"Na ca dāne pamajjissaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv52:23.4":{"pli":"sāmaṁ diṭṭhamidaṁ mayā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv52:24.1":{"pli":"Iccevaṁ vippalapantiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv52:24.2":{"pli":"phandamānaṁ tato tato; ","html":"<span class='verse-line'>{}</span>"},"vv52:24.3":{"pli":"Khipiṁsu niraye ghore, ","html":"<span class='verse-line'>{}</span>"},"vv52:24.4":{"pli":"uddhampādaṁ avaṁsiraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv52:25.1":{"pli":"“Ahaṁ pure maccharinī ahosiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv52:25.2":{"pli":"Paribhāsikā samaṇabrāhmaṇānaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv52:25.3":{"pli":"Vitathena ca sāmikaṁ vañcayitvā, ","html":"<span class='verse-line'>{}</span>"},"vv52:25.4":{"pli":"Paccāmahaṁ niraye ghorarūpe”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv52:26.1":{"pli":"Revatīvimānaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"vv53":{"vv53:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv53'><header><ul><li class='division'>{}</li>"},"vv53:0.2":{"pli":"Purisavimāna ","html":"<li>{}</li>"},"vv53:0.3":{"pli":"Mahārathavagga ","html":"<li>{}</li></ul>"},"vv53:0.4":{"pli":"3. Chattamāṇavakavimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv53:1.1":{"pli":"“Yo vadataṁ pavaro manujesu, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv53:1.2":{"pli":"Sakyamunī bhagavā katakicco; ","html":"<span class='verse-line'>{}</span>"},"vv53:1.3":{"pli":"Pāragato balaviriyasamaṅgī, ","html":"<span class='verse-line'>{}</span>"},"vv53:1.4":{"pli":"Taṁ sugataṁ saraṇatthamupehi. ","html":"<span class='verse-line'>{}</span></p>"},"vv53:2.1":{"pli":"Rāgavirāgamanejamasokaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv53:2.2":{"pli":"Dhammamasaṅkhatamappaṭikūlaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv53:2.3":{"pli":"Madhuramimaṁ paguṇaṁ suvibhattaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv53:2.4":{"pli":"Dhammamimaṁ saraṇatthamupehi. ","html":"<span class='verse-line'>{}</span></p>"},"vv53:3.1":{"pli":"Yattha ca dinna mahapphalamāhu, ","html":"<p><span class='verse-line'>{}</span>"},"vv53:3.2":{"pli":"Catūsu sucīsu purisayugesu; ","html":"<span class='verse-line'>{}</span>"},"vv53:3.3":{"pli":"Aṭṭha ca puggaladhammadasā te, ","html":"<span class='verse-line'>{}</span>"},"vv53:3.4":{"pli":"Saṅghamimaṁ saraṇatthamupehi. ","html":"<span class='verse-line'>{}</span></p>"},"vv53:4.1":{"pli":"Na tathā tapati nabhe sūriyo, ","html":"<p><span class='verse-line'>{}</span>"},"vv53:4.2":{"pli":"Cando ca na bhāsati na phusso; ","html":"<span class='verse-line'>{}</span>"},"vv53:4.3":{"pli":"Yathā atulamidaṁ mahappabhāsaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv53:4.4":{"pli":"Ko nu tvaṁ tidivā mahiṁ upāgā. ","html":"<span class='verse-line'>{}</span></p>"},"vv53:5.1":{"pli":"Chindati raṁsī pabhaṅkarassa, ","html":"<p><span class='verse-line'>{}</span>"},"vv53:5.2":{"pli":"Sādhikavīsatiyojanāni ābhā; ","html":"<span class='verse-line'>{}</span>"},"vv53:5.3":{"pli":"Rattimapi yathā divaṁ karoti, ","html":"<span class='verse-line'>{}</span>"},"vv53:5.4":{"pli":"Parisuddhaṁ vimalaṁ subhaṁ vimānaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv53:6.1":{"pli":"Bahupadumavicitrapuṇḍarīkaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv53:6.2":{"pli":"Vokiṇṇaṁ kusumehi nekacittaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv53:6.3":{"pli":"Arajavirajahemajālachannaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv53:6.4":{"pli":"Ākāse tapati yathāpi sūriyo. ","html":"<span class='verse-line'>{}</span></p>"},"vv53:7.1":{"pli":"Rattambarapītavāsasāhi, ","html":"<p><span class='verse-line'>{}</span>"},"vv53:7.2":{"pli":"Agarupiyaṅgucandanussadāhi; ","html":"<span class='verse-line'>{}</span>"},"vv53:7.3":{"pli":"Kañcanatanusannibhattacāhi, ","html":"<span class='verse-line'>{}</span>"},"vv53:7.4":{"pli":"Paripūraṁ gaganaṁva tārakāhi. ","html":"<span class='verse-line'>{}</span></p>"},"vv53:8.1":{"pli":"Naranāriyo bahuketthanekavaṇṇā, ","html":"<p><span class='verse-line'>{}</span>"},"vv53:8.2":{"pli":"Kusumavibhūsitābharaṇettha sumanā; ","html":"<span class='verse-line'>{}</span>"},"vv53:8.3":{"pli":"Anilapamuñcitā pavanti surabhiṁ, ","html":"<span class='verse-line'>{}</span>"},"vv53:8.4":{"pli":"Tapaniyavitatā suvaṇṇachannā. ","html":"<span class='verse-line'>{}</span></p>"},"vv53:9.1":{"pli":"Kissa saṁyamassa ayaṁ vipāko, ","html":"<p><span class='verse-line'>{}</span>"},"vv53:9.2":{"pli":"Kenāsi kammaphalenidhūpapanno; ","html":"<span class='verse-line'>{}</span>"},"vv53:9.3":{"pli":"Yathā ca te adhigatamidaṁ vimānaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv53:9.4":{"pli":"Tadanupadaṁ avacāsi iṅgha puṭṭho”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv53:10.1":{"pli":"“Sayamidha pathe samecca māṇavena, ","html":"<p><span class='verse-line'>{}</span>"},"vv53:10.2":{"pli":"Satthānusāsi anukampamāno; ","html":"<span class='verse-line'>{}</span>"},"vv53:10.3":{"pli":"Tava ratanavarassa dhammaṁ sutvā, ","html":"<span class='verse-line'>{}</span>"},"vv53:10.4":{"pli":"Karissāmīti ca bravittha chatto. ","html":"<span class='verse-line'>{}</span></p>"},"vv53:11.1":{"pli":"Jinavarapavaraṁ upehi saraṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv53:11.2":{"pli":"Dhammañcāpi tatheva bhikkhusaṅghaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv53:11.3":{"pli":"Noti paṭhamaṁ avocahaṁ bhante, ","html":"<span class='verse-line'>{}</span>"},"vv53:11.4":{"pli":"Pacchā te vacanaṁ tathevakāsiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv53:12.1":{"pli":"Mā ca pāṇavadhaṁ vividhaṁ carassu asuciṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv53:12.2":{"pli":"Na hi pāṇesu asaññataṁ avaṇṇayiṁsu sappaññā; ","html":"<span class='verse-line'>{}</span>"},"vv53:12.3":{"pli":"Noti paṭhamaṁ avocahaṁ bhante, ","html":"<span class='verse-line'>{}</span>"},"vv53:12.4":{"pli":"Pacchā te vacanaṁ tathevakāsiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv53:13.1":{"pli":"Mā ca parajanassa rakkhitampi, ","html":"<p><span class='verse-line'>{}</span>"},"vv53:13.2":{"pli":"Ādātabbamamaññitho adinnaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv53:13.3":{"pli":"Noti paṭhamaṁ avocahaṁ bhante, ","html":"<span class='verse-line'>{}</span>"},"vv53:13.4":{"pli":"Pacchā te vacanaṁ tathevakāsiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv53:14.1":{"pli":"Mā ca parajanassa rakkhitāyo, ","html":"<p><span class='verse-line'>{}</span>"},"vv53:14.2":{"pli":"Parabhariyā agamā anariyametaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv53:14.3":{"pli":"Noti paṭhamaṁ avocahaṁ bhante, ","html":"<span class='verse-line'>{}</span>"},"vv53:14.4":{"pli":"Pacchā te vacanaṁ tathevakāsiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv53:15.1":{"pli":"Mā ca vitathaṁ aññathā abhāṇi, ","html":"<p><span class='verse-line'>{}</span>"},"vv53:15.2":{"pli":"Na hi musāvādaṁ avaṇṇayiṁsu sappaññā; ","html":"<span class='verse-line'>{}</span>"},"vv53:15.3":{"pli":"Noti paṭhamaṁ avocahaṁ bhante, ","html":"<span class='verse-line'>{}</span>"},"vv53:15.4":{"pli":"Pacchā te vacanaṁ tathevakāsiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv53:16.1":{"pli":"Yena ca purisassa apeti saññā, ","html":"<p><span class='verse-line'>{}</span>"},"vv53:16.2":{"pli":"Taṁ majjaṁ parivajjayassu sabbaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv53:16.3":{"pli":"Noti paṭhamaṁ avocahaṁ bhante, ","html":"<span class='verse-line'>{}</span>"},"vv53:16.4":{"pli":"Pacchā te vacanaṁ tathevakāsiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv53:17.1":{"pli":"Svāhaṁ idha pañca sikkhā karitvā, ","html":"<p><span class='verse-line'>{}</span>"},"vv53:17.2":{"pli":"Paṭipajjitvā tathāgatassa dhamme; ","html":"<span class='verse-line'>{}</span>"},"vv53:17.3":{"pli":"Dvepathamagamāsiṁ coramajjhe, ","html":"<span class='verse-line'>{}</span>"},"vv53:17.4":{"pli":"Te maṁ tattha vadhiṁsu bhogahetu. ","html":"<span class='verse-line'>{}</span></p>"},"vv53:18.1":{"pli":"Ettakamidaṁ anussarāmi kusalaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv53:18.2":{"pli":"Tato paraṁ na me vijjati aññaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv53:18.3":{"pli":"Tena sucaritena kammunāhaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv53:18.4":{"pli":"Uppanno tidivesu kāmakāmī. ","html":"<span class='verse-line'>{}</span></p>"},"vv53:19.1":{"pli":"Passa khaṇamuhuttasaññamassa, ","html":"<p><span class='verse-line'>{}</span>"},"vv53:19.2":{"pli":"Anudhammappaṭipattiyā vipākaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv53:19.3":{"pli":"Jalamiva yasasā samekkhamānā, ","html":"<span class='verse-line'>{}</span>"},"vv53:19.4":{"pli":"Bahukā maṁ pihayanti hīnakammā. ","html":"<span class='verse-line'>{}</span></p>"},"vv53:20.1":{"pli":"Passa katipayāya desanāya, ","html":"<p><span class='verse-line'>{}</span>"},"vv53:20.2":{"pli":"Sugatiñcamhi gato sukhañca patto; ","html":"<span class='verse-line'>{}</span>"},"vv53:20.3":{"pli":"Ye ca te satataṁ suṇanti dhammaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv53:20.4":{"pli":"Maññe te amataṁ phusanti khemaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv53:21.1":{"pli":"Appampi kataṁ mahāvipākaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv53:21.2":{"pli":"Vipulaṁ hoti tathāgatassa dhamme; ","html":"<span class='verse-line'>{}</span>"},"vv53:21.3":{"pli":"Passa katapuññatāya chatto, ","html":"<span class='verse-line'>{}</span>"},"vv53:21.4":{"pli":"Obhāseti pathaviṁ yathāpi sūriyo. ","html":"<span class='verse-line'>{}</span></p>"},"vv53:22.1":{"pli":"Kimidaṁ kusalaṁ kimācarema, ","html":"<p><span class='verse-line'>{}</span>"},"vv53:22.2":{"pli":"Icceke hi samecca mantayanti; ","html":"<span class='verse-line'>{}</span>"},"vv53:22.3":{"pli":"Te mayaṁ punareva laddha mānusattaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv53:22.4":{"pli":"Paṭipannā viharemu sīlavanto. ","html":"<span class='verse-line'>{}</span></p>"},"vv53:23.1":{"pli":"Bahukāro anukampako ca satthā, ","html":"<p><span class='verse-line'>{}</span>"},"vv53:23.2":{"pli":"Iti me sati agamā divā divassa; ","html":"<span class='verse-line'>{}</span>"},"vv53:23.3":{"pli":"Svāhaṁ upagatomhi saccanāmaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv53:23.4":{"pli":"Anukampassu punapi suṇemu dhammaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv53:24.1":{"pli":"Ye cidha pajahanti kāmarāgaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"vv53:24.2":{"pli":"Bhavarāgānusayañca pahāya mohaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv53:24.3":{"pli":"Na ca te punamupenti gabbhaseyyaṁ, ","html":"<span class='verse-line'>{}</span>"},"vv53:24.4":{"pli":"Parinibbānagatā hi sītibhūtā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv53:25.1":{"pli":"Chattamāṇavakavimānaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"vv54":{"vv54:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv54'><header><ul><li class='division'>{}</li>"},"vv54:0.2":{"pli":"Purisavimāna ","html":"<li>{}</li>"},"vv54:0.3":{"pli":"Mahārathavagga ","html":"<li>{}</li></ul>"},"vv54:0.4":{"pli":"4. Kakkaṭakarasadāyakavimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv54:1.1":{"pli":"“Uccamidaṁ maṇithūṇaṁ vimānaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv54:1.2":{"pli":"Samantato dvādasa yojanāni; ","html":"<span class='verse-line'>{}</span>"},"vv54:1.3":{"pli":"Kūṭāgārā sattasatā uḷārā, ","html":"<span class='verse-line'>{}</span>"},"vv54:1.4":{"pli":"Veḷuriyathambhā rucakatthatā subhā. ","html":"<span class='verse-line'>{}</span></p>"},"vv54:2.1":{"pli":"Tatthacchasi pivasi khādasi ca, ","html":"<p><span class='verse-line'>{}</span>"},"vv54:2.2":{"pli":"Dibbā ca vīṇā pavadanti vagguṁ; ","html":"<span class='verse-line'>{}</span>"},"vv54:2.3":{"pli":"Dibbā rasā kāmaguṇettha pañca, ","html":"<span class='verse-line'>{}</span>"},"vv54:2.4":{"pli":"Nāriyo ca naccanti suvaṇṇachannā. ","html":"<span class='verse-line'>{}</span></p>"},"vv54:3.1":{"pli":"Kena tetādiso vaṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"vv54:3.2":{"pli":"kena te idha mijjhati; ","html":"<span class='verse-line'>{}</span>"},"vv54:3.3":{"pli":"Uppajjanti ca te bhogā, ","html":"<span class='verse-line'>{}</span>"},"vv54:3.4":{"pli":"ye keci manaso piyā. ","html":"<span class='verse-line'>{}</span></p>"},"vv54:4.1":{"pli":"Pucchāmi taṁ deva mahānubhāva, ","html":"<p><span class='verse-line'>{}</span>"},"vv54:4.2":{"pli":"Manussabhūto kimakāsi puññaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv54:4.3":{"pli":"Kenāsi evaṁ jalitānubhāvo, ","html":"<span class='verse-line'>{}</span>"},"vv54:4.4":{"pli":"Vaṇṇo ca te sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv54:5.1":{"pli":"So devaputto attamano, ","html":"<p><span class='verse-line'>{}</span>"},"vv54:5.2":{"pli":"moggallānena pucchito; ","html":"<span class='verse-line'>{}</span>"},"vv54:5.3":{"pli":"Pañhaṁ puṭṭho viyākāsi, ","html":"<span class='verse-line'>{}</span>"},"vv54:5.4":{"pli":"yassa kammassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv54:6.1":{"pli":"“Satisamuppādakaro, ","html":"<p><span class='verse-line'>{}</span>"},"vv54:6.2":{"pli":"dvāre kakkaṭako ṭhito; ","html":"<span class='verse-line'>{}</span>"},"vv54:6.3":{"pli":"Niṭṭhito jātarūpassa, ","html":"<span class='verse-line'>{}</span>"},"vv54:6.4":{"pli":"sobhati dasapādako. ","html":"<span class='verse-line'>{}</span></p>"},"vv54:7.1":{"pli":"Tena metādiso vaṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"vv54:7.2":{"pli":"tena me idha mijjhati; ","html":"<span class='verse-line'>{}</span>"},"vv54:7.3":{"pli":"Uppajjanti ca me bhogā, ","html":"<span class='verse-line'>{}</span>"},"vv54:7.4":{"pli":"ye keci manaso piyā. ","html":"<span class='verse-line'>{}</span></p>"},"vv54:8.1":{"pli":"Akkhāmi te bhikkhu mahānubhāva, ","html":"<p><span class='verse-line'>{}</span>"},"vv54:8.2":{"pli":"Manussabhūto yamakāsi puññaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv54:8.3":{"pli":"Tenamhi evaṁ jalitānubhāvo, ","html":"<span class='verse-line'>{}</span>"},"vv54:8.4":{"pli":"Vaṇṇo ca me sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv54:9.1":{"pli":"Kakkaṭakarasadāyakavimānaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p>"},"vv54:10.1":{"pli":"(Anantaraṁ pañcavimānaṁ yathā kakkaṭakarasadāyakavimānaṁ tathā vitthāretabbaṁ.) ","html":"<p>{}</p></article>"}},"vv55":{"vv55:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv55'><header><ul><li class='division'>{}</li>"},"vv55:0.2":{"pli":"Purisavimāna ","html":"<li>{}</li>"},"vv55:0.3":{"pli":"Mahārathavagga ","html":"<li>{}</li></ul>"},"vv55:0.4":{"pli":"5. Dvārapālavimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv55:1.1":{"pli":"“Uccamidaṁ maṇithūṇaṁ vimānaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv55:1.2":{"pli":"Samantato dvādasa yojanāni; ","html":"<span class='verse-line'>{}</span>"},"vv55:1.3":{"pli":"Kūṭāgārā sattasatā uḷārā, ","html":"<span class='verse-line'>{}</span>"},"vv55:1.4":{"pli":"Veḷuriyathambhā rucakatthatā subhā. ","html":"<span class='verse-line'>{}</span></p>"},"vv55:2.1":{"pli":"Tatthacchasi pivasi khādasi ca, ","html":"<p><span class='verse-line'>{}</span>"},"vv55:2.2":{"pli":"Dibbā ca vīṇā pavadanti vagguṁ; ","html":"<span class='verse-line'>{}</span>"},"vv55:2.3":{"pli":"Dibbā rasā kāmaguṇettha pañca, ","html":"<span class='verse-line'>{}</span>"},"vv55:2.4":{"pli":"Nāriyo ca naccanti suvaṇṇachannā. ","html":"<span class='verse-line'>{}</span></p>"},"vv55:3.1":{"pli":"Kena tetādiso vaṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"vv55:3.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"vv55:3.3":{"pli":"Vaṇṇo ca te sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv55:4.1":{"pli":"So devaputto attamano, ","html":"<p><span class='verse-line'>{}</span>"},"vv55:4.2":{"pli":"moggallānena pucchito; ","html":"<span class='verse-line'>{}</span>"},"vv55:4.3":{"pli":"Pañhaṁ puṭṭho viyākāsi, ","html":"<span class='verse-line'>{}</span>"},"vv55:4.4":{"pli":"yassa kammassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv55:5.1":{"pli":"“Dibbaṁ mamaṁ vassasahassamāyu, ","html":"<p><span class='verse-line'>{}</span>"},"vv55:5.2":{"pli":"Vācābhigītaṁ manasā pavattitaṁ; ","html":"<span class='verse-line'>{}</span>"},"vv55:5.3":{"pli":"Ettāvatā ṭhassati puññakammo, ","html":"<span class='verse-line'>{}</span>"},"vv55:5.4":{"pli":"Dibbehi kāmehi samaṅgibhūto. ","html":"<span class='verse-line'>{}</span></p>"},"vv55:6.1":{"pli":"Tena metādiso vaṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"vv55:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"vv55:6.3":{"pli":"Vaṇṇo ca me sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv55:7.1":{"pli":"Dvārapālavimānaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"vv56":{"vv56:0.1":{"pli":"Vimānavatthu ","html":"<article id='vv56'><header><ul><li class='division'>{}</li>"},"vv56:0.2":{"pli":"Purisavimāna ","html":"<li>{}</li>"},"vv56:0.3":{"pli":"Mahārathavagga ","html":"<li>{}</li></ul>"},"vv56:0.4":{"pli":"6. Paṭhamakaraṇīyavimānavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"vv56:1.1":{"pli":"“Uccamidaṁ maṇithūṇaṁ vimānaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"vv56:1.2":{"pli":"Samantato dvādasa yojanāni; ","html":"<span class='verse-line'>{}</span>"},"vv56:1.3":{"pli":"Kūṭāgārā sattasatā uḷārā, ","html":"<span class='verse-line'>{}</span>"},"vv56:1.4":{"pli":"Veḷuriyathambhā rucakatthatā subhā. ","html":"<span class='verse-line'>{}</span></p>"},"vv56:2.1":{"pli":"Tatthacchasi pivasi khādasi ca, ","html":"<p><span class='verse-line'>{}</span>"},"vv56:2.2":{"pli":"Dibbā ca vīṇā pavadanti vagguṁ; ","html":"<span class='verse-line'>{}</span>"},"vv56:2.3":{"pli":"Dibbā rasā kāmaguṇettha pañca, ","html":"<span class='verse-line'>{}</span>"},"vv56:2.4":{"pli":"Nāriyo ca naccanti suvaṇṇachannā. ","html":"<span class='verse-line'>{}</span></p>"},"vv56:3.1":{"pli":"Kena tetādiso vaṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"vv56:3.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"vv56:3.3":{"pli":"Vaṇṇo ca te sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"vv56:4.1":{"pli":"So devaputto attamano, ","html":"<p><span class='verse-line'>{}</span>"},"vv56:4.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"vv56:4.3":{"pli":"yassa kammassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv56:5.1":{"pli":"“Karaṇīyāni puññāni, ","html":"<p><span class='verse-line'>{}</span>"},"vv56:5.2":{"pli":"paṇḍitena vijānatā; ","html":"<span class='verse-line'>{}</span>"},"vv56:5.3":{"pli":"Sammaggatesu buddhesu, ","html":"<span class='verse-line'>{}</span>"},"vv56:5.4":{"pli":"yattha dinnaṁ mahapphalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv56:6.1":{"pli":"Atthāya vata me buddho, ","html":"<p><span class='verse-line'>{}</span>"},"vv56:6.2":{"pli":"araññā gāmamāgato; ","html":"<span class='verse-line'>{}</span>"},"vv56:6.3":{"pli":"Tattha cittaṁ pasādetvā, ","html":"<span class='verse-line'>{}</span>"},"vv56:6.4":{"pli":"tāvatiṁsūpago ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"vv56:7.1":{"pli":"Tena metādiso vaṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"vv56:7.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"vv56:7.3":{"pli":"Vaṇṇo ca me sabbadisā pabhāsatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"vv56:8.1":{"pli":"Paṭhamakaraṇīyavimānaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}