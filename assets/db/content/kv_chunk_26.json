}</li>"},"kv4.7:0.2":{"pli":"Mahāpaṇṇāsaka ","html":"<li>{}</li>"},"kv4.7:0.3":{"pli":"Catutthavagga ","html":"<li>{}</li></ul>"},"kv4.7:0.4":{"pli":"Lakkhaṇakathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv4.7:1.1":{"pli":"Lakkhaṇasamannāgato bodhisattoti? ","html":"<p data-doxy='orthodox'>{}"},"kv4.7:1.2":{"pli":"Āmantā. ","html":"{}"},"kv4.7:1.3":{"pli":"Padesalakkhaṇehi samannāgato padesabodhisattoti? ","html":"{}"},"kv4.7:1.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv4.7:2.1":{"pli":"Lakkhaṇasamannāgato bodhisattoti? ","html":"<p data-doxy='orthodox'>{}"},"kv4.7:2.2":{"pli":"Āmantā. ","html":"{}"},"kv4.7:2.3":{"pli":"Tibhāgalakkhaṇehi samannāgato tibhāgabodhisattoti? ","html":"{}"},"kv4.7:2.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv4.7:3.1":{"pli":"Lakkhaṇasamannāgato bodhisattoti? ","html":"<p data-doxy='orthodox'>{}"},"kv4.7:3.2":{"pli":"Āmantā. ","html":"{}"},"kv4.7:3.3":{"pli":"Upaḍḍhalakkhaṇehi samannāgato upaḍḍhabodhisattoti? ","html":"{}"},"kv4.7:3.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv4.7:4.1":{"pli":"Lakkhaṇasamannāgato bodhisattoti? ","html":"<p data-doxy='orthodox'>{}"},"kv4.7:4.2":{"pli":"Āmantā. ","html":"{}"},"kv4.7:4.3":{"pli":"Cakkavattisatto lakkhaṇasamannāgato, cakkavattisatto bodhisattoti? ","html":"{}"},"kv4.7:4.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv4.7:5.1":{"pli":"Cakkavattisatto lakkhaṇasamannāgato, cakkavattisatto bodhisattoti? ","html":"<p data-doxy='orthodox'>{}"},"kv4.7:5.2":{"pli":"Āmantā. ","html":"{}"},"kv4.7:5.3":{"pli":"Yādiso bodhisattassa pubbayogo pubbacariyā dhammakkhānaṁ dhammadesanā, tādiso cakkavattisattassa pubbayogo pubbacariyā dhammakkhānaṁ dhammadesanāti? ","html":"{}"},"kv4.7:5.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv4.7:6.1":{"pli":"Yathā bodhisattassa jāyamānassa devā paṭhamaṁ paṭiggaṇhanti pacchā manussā, evamevaṁ cakkavattisattassa jāyamānassa devā paṭhamaṁ paṭiggaṇhanti pacchā manussāti? ","html":"<p data-doxy='orthodox'>{}"},"kv4.7:6.2":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv4.7:7.1":{"pli":"Yathā bodhisattassa jāyamānassa cattāro naṁ devaputtā paṭiggahetvā mātu purato ṭhapenti—","html":"<p data-doxy='orthodox'>{}"},"kv4.7:7.2":{"pli":"“attamanā, devi, hohi. ","html":"{}"},"kv4.7:7.3":{"pli":"Mahesakkho te putto uppanno”ti, evamevaṁ cakkavattisattassa jāyamānassa cattāro naṁ devaputtā paṭiggahetvā mātu purato ṭhapenti—","html":"{}"},"kv4.7:7.4":{"pli":"“attamanā, devi, hohi. ","html":"{}"},"kv4.7:7.5":{"pli":"Mahesakkho te putto uppanno”ti? ","html":"{}"},"kv4.7:7.6":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv4.7:8.1":{"pli":"Yathā bodhisattassa jāyamānassa dve udakassa dhārā antalikkhā pātubhavanti—","html":"<p data-doxy='orthodox'>{}"},"kv4.7:8.2":{"pli":"ekā sītassa, ekā uṇhassa—","html":"{}"},"kv4.7:8.3":{"pli":"yena bodhisattassa udakakiccaṁ karonti mātu ca, evamevaṁ cakkavattisattassa jāyamānassa dve udakassa dhārā antalikkhā pātubhavanti—","html":"{}"},"kv4.7:8.4":{"pli":"ekā sītassa, ekā uṇhassa—","html":"{}"},"kv4.7:8.5":{"pli":"yena cakkavattisattassa udakakiccaṁ karonti mātu cāti? ","html":"{}"},"kv4.7:8.6":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv4.7:9.1":{"pli":"Yathā sampatijāto bodhisatto samehi pādehi patiṭṭhahitvā uttarena abhimukho sattapadavītihārena gacchati setamhi chatte anudhāriyamāne, sabbā ca disā viloketi, āsabhiñca vācaṁ bhāsati—","html":"<p data-doxy='orthodox'>{}"},"kv4.7:9.2":{"pli":"“aggohamasmi lokassa, jeṭṭhohamasmi lokassa, seṭṭhohamasmi lokassa, ayamantimā jāti, natthi dāni punabbhavo”ti, evamevaṁ sampatijāto cakkavattisatto samehi pādehi patiṭṭhahitvā uttarena abhimukho sattapadavītihārena gacchati setamhi chatte anudhāriyamāne, sabbā ca disā viloketi, āsabhiñca vācaṁ bhāsati—","html":"{}"},"kv4.7:9.3":{"pli":"“aggohamasmi lokassa, jeṭṭhohamasmi lokassa, seṭṭhohamasmi lokassa, ayamantimā jāti, natthi dāni punabbhavo”ti? ","html":"{}"},"kv4.7:9.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv4.7:10.1":{"pli":"Yathā bodhisattassa jāyamānassa mahato ālokassa mahato obhāsassa mahato bhūmicālassa pātubhāvo hoti, evamevaṁ cakkavattisattassa jāyamānassa mahato ālokassa mahato obhāsassa mahato bhūmicālassa pātubhāvo hotīti? ","html":"<p data-doxy='orthodox'>{}"},"kv4.7:10.2":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv4.7:11.1":{"pli":"Yathā bodhisattassa pakatikāyo samantā byāmaṁ obhāsati, evamevaṁ cakkavattisattassa pakatikāyo samantā byāmaṁ obhāsatīti? ","html":"<p data-doxy='orthodox'>{}"},"kv4.7:11.2":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv4.7:12.1":{"pli":"Yathā bodhisatto mahāsupinaṁ passati, evamevaṁ cakkavattisatto mahāsupinaṁ passatīti? ","html":"<p data-doxy='orthodox'>{}"},"kv4.7:12.2":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv4.7:13.1":{"pli":"Na vattabbaṁ—","html":"<p data-doxy='heterodox'>{}"},"kv4.7:13.2":{"pli":"“lakkhaṇasamannāgato bodhisatto”ti? ","html":"{}"},"kv4.7:13.3":{"pli":"Āmantā. ","html":"{}"},"kv4.7:13.4":{"pli":"Nanu vuttaṁ bhagavatā—","html":"{}"},"kv4.7:13.5":{"pli":"“dvattiṁsimāni, bhikkhave, mahāpurisassa mahāpurisalakkhaṇāni, yehi samannāgatassa mahāpurisassa dveva gatiyo bhavanti anaññā. ","html":"{}"},"kv4.7:13.6":{"pli":"Sace agāraṁ ajjhāvasati, rājā hoti cakkavattī dhammiko dhammarājā cāturanto vijitāvī janapadatthāvariyappatto sattaratanasamannāgato. ","html":"{}"},"kv4.7:13.7":{"pli":"Tassimāni satta ratanāni bhavanti, seyyathidaṁ—","html":"{}"},"kv4.7:13.8":{"pli":"cakkaratanaṁ, hatthiratanaṁ, assaratanaṁ, maṇiratanaṁ, itthiratanaṁ, gahapatiratanaṁ, pariṇāyakaratanameva sattamaṁ. ","html":"{}"},"kv4.7:13.9":{"pli":"Parosahassaṁ kho panassa puttā bhavanti sūrā vīraṅgarūpā parasenappamaddanā. ","html":"{}"},"kv4.7:13.10":{"pli":"So imaṁ pathaviṁ sāgarapariyantaṁ adaṇḍena asatthena dhammena abhivijiya ajjhāvasati. ","html":"{}"},"kv4.7:13.11":{"pli":"Sace kho pana agārasmā anagāriyaṁ pabbajati, arahaṁ hoti sammāsambuddho loke vivaṭṭacchado”ti. ","html":"{}"},"kv4.7:13.12":{"pli":"Attheva suttantoti? ","html":"{}"},"kv4.7:13.13":{"pli":"Āmantā. ","html":"{}"},"kv4.7:13.14":{"pli":"Tena hi lakkhaṇasamannāgato bodhisattoti. ","html":"{}</p>"},"kv4.7:13.15":{"pli":"Lakkhaṇakathā niṭṭhitā. ","html":"<p class='endsutta'>{}</p></article>"}}}