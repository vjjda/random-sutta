{"ja381":{"ja381:0.1":{"pli":"Jātaka ","html":"<article id='ja381'><header><ul><li class='division'>{}</li>"},"ja381:0.2":{"pli":"Chakkanipāta ","html":"<li>{}</li>"},"ja381:0.3":{"pli":"Avāriyavagga ","html":"<li>{}</li></ul>"},"ja381:0.4":{"pli":"6. Migālopajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja381:1.1":{"pli":"“Na me rucci migālopa, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja381:1.2":{"pli":"yassa te tādisī gatī; ","html":"<span class='verse-line'>{}</span>"},"ja381:1.3":{"pli":"Atuccaṁ tāta patasi, ","html":"<span class='verse-line'>{}</span>"},"ja381:1.4":{"pli":"abhūmiṁ tāta sevasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja381:2.1":{"pli":"Catukkaṇṇaṁva kedāraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja381:2.2":{"pli":"yadā te pathavī siyā; ","html":"<span class='verse-line'>{}</span>"},"ja381:2.3":{"pli":"Tato tāta nivattassu, ","html":"<span class='verse-line'>{}</span>"},"ja381:2.4":{"pli":"māssu etto paraṁ gami”. ","html":"<span class='verse-line'>{}</span></p>"},"ja381:3.1":{"pli":"“Santi aññepi sakuṇā, ","html":"<p><span class='verse-line'>{}</span>"},"ja381:3.2":{"pli":"pattayānā vihaṅgamā; ","html":"<span class='verse-line'>{}</span>"},"ja381:3.3":{"pli":"Akkhittā vātavegena, ","html":"<span class='verse-line'>{}</span>"},"ja381:3.4":{"pli":"naṭṭhā te sassatīsamā. ","html":"<span class='verse-line'>{}</span></p>"},"ja381:4.1":{"pli":"Akatvā apanandassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja381:4.2":{"pli":"pitu vuddhassa sāsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja381:4.3":{"pli":"Kālavāte atikkamma, ","html":"<span class='verse-line'>{}</span>"},"ja381:4.4":{"pli":"verambhānaṁ vasaṁ agā. ","html":"<span class='verse-line'>{}</span></p>"},"ja381:5.1":{"pli":"Tassa puttā ca dārā ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja381:5.2":{"pli":"ye caññe anujīvino; ","html":"<span class='verse-line'>{}</span>"},"ja381:5.3":{"pli":"Sabbe byasanamāpāduṁ, ","html":"<span class='verse-line'>{}</span>"},"ja381:5.4":{"pli":"anovādakare dije. ","html":"<span class='verse-line'>{}</span></p>"},"ja381:6.1":{"pli":"Evampi idha vuddhānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja381:6.2":{"pli":"yo vākyaṁ nāvabujjhati; ","html":"<span class='verse-line'>{}</span>"},"ja381:6.3":{"pli":"Atisīmacaro ditto, ","html":"<span class='verse-line'>{}</span>"},"ja381:6.4":{"pli":"gijjhovātītasāsano; ","html":"<span class='verse-line'>{}</span>"},"ja381:6.5":{"pli":"Sabbe byasanaṁ papponti, ","html":"<span class='verse-line'>{}</span>"},"ja381:6.6":{"pli":"akatvā vuddhasāsanan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja381:7.1":{"pli":"Migālopajātakaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja382":{"ja382:0.1":{"pli":"Jātaka ","html":"<article id='ja382'><header><ul><li class='division'>{}</li>"},"ja382:0.2":{"pli":"Chakkanipāta ","html":"<li>{}</li>"},"ja382:0.3":{"pli":"Avāriyavagga ","html":"<li>{}</li></ul>"},"ja382:0.4":{"pli":"7. Sirikāḷakaṇṇijātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja382:1.1":{"pli":"“Kā nu kāḷena vaṇṇena, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja382:1.2":{"pli":"na cāpi piyadassanā; ","html":"<span class='verse-line'>{}</span>"},"ja382:1.3":{"pli":"Kā vā tvaṁ kassa vā dhītā, ","html":"<span class='verse-line'>{}</span>"},"ja382:1.4":{"pli":"kathaṁ jānemu taṁ mayaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja382:2.1":{"pli":"“Mahārājassahaṁ dhītā, ","html":"<p><span class='verse-line'>{}</span>"},"ja382:2.2":{"pli":"virūpakkhassa caṇḍiyā; ","html":"<span class='verse-line'>{}</span>"},"ja382:2.3":{"pli":"Ahaṁ kāḷī alakkhikā, ","html":"<span class='verse-line'>{}</span>"},"ja382:2.4":{"pli":"kāḷakaṇṇīti maṁ vidū; ","html":"<span class='verse-line'>{}</span>"},"ja382:2.5":{"pli":"Okāsaṁ yācito dehi, ","html":"<span class='verse-line'>{}</span>"},"ja382:2.6":{"pli":"vasemu tava santike”. ","html":"<span class='verse-line'>{}</span></p>"},"ja382:3.1":{"pli":"“Kiṁsīle kiṁsamācāre, ","html":"<p><span class='verse-line'>{}</span>"},"ja382:3.2":{"pli":"Purise nivisase tuvaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja382:3.3":{"pli":"Puṭṭhā me kāḷi akkhāhi, ","html":"<span class='verse-line'>{}</span>"},"ja382:3.4":{"pli":"Kathaṁ jānemu taṁ mayaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja382:4.1":{"pli":"“Makkhī paḷāsī sārambhī, ","html":"<p><span class='verse-line'>{}</span>"},"ja382:4.2":{"pli":"issukī maccharī saṭho; ","html":"<span class='verse-line'>{}</span>"},"ja382:4.3":{"pli":"So mayhaṁ puriso kanto, ","html":"<span class='verse-line'>{}</span>"},"ja382:4.4":{"pli":"laddhaṁ yassa vinassati. ","html":"<span class='verse-line'>{}</span></p>"},"ja382:5.1":{"pli":"Kodhano upanāhī ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja382:5.2":{"pli":"pisuṇo ca vibhedako; ","html":"<span class='verse-line'>{}</span>"},"ja382:5.3":{"pli":"Kaṇḍakavāco pharuso, ","html":"<span class='verse-line'>{}</span>"},"ja382:5.4":{"pli":"so me kantataro tato. ","html":"<span class='verse-line'>{}</span></p>"},"ja382:6.1":{"pli":"Ajja suveti puriso, ","html":"<p><span class='verse-line'>{}</span>"},"ja382:6.2":{"pli":"sadatthaṁ nāvabujjhati; ","html":"<span class='verse-line'>{}</span>"},"ja382:6.3":{"pli":"Ovajjamāno kuppati, ","html":"<span class='verse-line'>{}</span>"},"ja382:6.4":{"pli":"seyyaṁ so atimaññati. ","html":"<span class='verse-line'>{}</span></p>"},"ja382:7.1":{"pli":"Davappaluddho puriso, ","html":"<p><span class='verse-line'>{}</span>"},"ja382:7.2":{"pli":"sabbamittehi dhaṁsati; ","html":"<span class='verse-line'>{}</span>"},"ja382:7.3":{"pli":"So mayhaṁ puriso kanto, ","html":"<span class='verse-line'>{}</span>"},"ja382:7.4":{"pli":"tasmiṁ homi anāmayā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja382:8.1":{"pli":"“Apehi etto tvaṁ kāḷi, ","html":"<p><span class='verse-line'>{}</span>"},"ja382:8.2":{"pli":"netaṁ amhesu vijjati; ","html":"<span class='verse-line'>{}</span>"},"ja382:8.3":{"pli":"Aññaṁ janapadaṁ gaccha, ","html":"<span class='verse-line'>{}</span>"},"ja382:8.4":{"pli":"nigame rājadhāniyo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja382:9.1":{"pli":"“Ahampi kho taṁ jānāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja382:9.2":{"pli":"netaṁ tumhesu vijjati; ","html":"<span class='verse-line'>{}</span>"},"ja382:9.3":{"pli":"Santi loke alakkhikā, ","html":"<span class='verse-line'>{}</span>"},"ja382:9.4":{"pli":"saṅgharanti bahuṁ dhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja382:9.5":{"pli":"Ahaṁ devo ca me bhātā, ","html":"<span class='verse-line'>{}</span>"},"ja382:9.6":{"pli":"ubho naṁ vidhamāmase”. ","html":"<span class='verse-line'>{}</span></p>"},"ja382:10.1":{"pli":"“Kā nu dibbena vaṇṇena, ","html":"<p><span class='verse-line'>{}</span>"},"ja382:10.2":{"pli":"pathabyā supatiṭṭhitā; ","html":"<span class='verse-line'>{}</span>"},"ja382:10.3":{"pli":"Kā vā tvaṁ kassa vā dhītā, ","html":"<span class='verse-line'>{}</span>"},"ja382:10.4":{"pli":"kathaṁ jānemu taṁ mayaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja382:11.1":{"pli":"“Mahārājassahaṁ dhītā, ","html":"<p><span class='verse-line'>{}</span>"},"ja382:11.2":{"pli":"dhataraṭṭhassa sirīmato; ","html":"<span class='verse-line'>{}</span>"},"ja382:11.3":{"pli":"Ahaṁ sirī ca lakkhī ca, ","html":"<span class='verse-line'>{}</span>"},"ja382:11.4":{"pli":"bhūripaññāti maṁ vidū; ","html":"<span class='verse-line'>{}</span>"},"ja382:11.5":{"pli":"Okāsaṁ yācito dehi, ","html":"<span class='verse-line'>{}</span>"},"ja382:11.6":{"pli":"vasemu tava santike”. ","html":"<span class='verse-line'>{}</span></p>"},"ja382:12.1":{"pli":"“Kiṁsīle kiṁsamācāre, ","html":"<p><span class='verse-line'>{}</span>"},"ja382:12.2":{"pli":"Purise nivisase tuvaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja382:12.3":{"pli":"Puṭṭhā me lakkhi akkhāhi, ","html":"<span class='verse-line'>{}</span>"},"ja382:12.4":{"pli":"Kathaṁ jānemu taṁ mayaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja382:13.1":{"pli":"“Yo cāpi sīte atha vāpi uṇhe, ","html":"<p><span class='verse-line'>{}</span>"},"ja382:13.2":{"pli":"Vātātape ḍaṁsasarīsape ca; ","html":"<span class='verse-line'>{}</span>"},"ja382:13.3":{"pli":"Khudhaṁ pipāsaṁ abhibhuyya sabbaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja382:13.4":{"pli":"Rattindivaṁ yo satataṁ niyutto. ","html":"<span class='verse-line'>{}</span></p>"},"ja382:14.1":{"pli":"Kālāgatañca na hāpeti atthaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja382:14.2":{"pli":"So me manāpo nivise ca tamhi; ","html":"<span class='verse-line'>{}</span>"},"ja382:14.3":{"pli":"Akkodhano mittavā cāgavā ca, ","html":"<span class='verse-line'>{}</span>"},"ja382:14.4":{"pli":"Sīlūpapanno asaṭhojubhūto. ","html":"<span class='verse-line'>{}</span></p>"},"ja382:15.1":{"pli":"Saṅgāhako sakhilo saṇhavāco, ","html":"<p><span class='verse-line'>{}</span>"},"ja382:15.2":{"pli":"Mahattapattopi nivātavutti; ","html":"<span class='verse-line'>{}</span>"},"ja382:15.3":{"pli":"Tasmiṁhaṁ pose vipulā bhavāmi, ","html":"<span class='verse-line'>{}</span>"},"ja382:15.4":{"pli":"Ūmi samuddassa yathāpi vaṇṇaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja382:16.1":{"pli":"Yo cāpi mitte atha vā amitte, ","html":"<p><span class='verse-line'>{}</span>"},"ja382:16.2":{"pli":"Seṭṭhe sarikkhe atha vāpi hīne; ","html":"<span class='verse-line'>{}</span>"},"ja382:16.3":{"pli":"Atthaṁ carantaṁ atha vā anatthaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja382:16.4":{"pli":"Āvī raho saṅgahameva vatte. ","html":"<span class='verse-line'>{}</span></p>"},"ja382:17.1":{"pli":"Vācaṁ na vajjā pharusaṁ kadāci, ","html":"<p><span class='verse-line'>{}</span>"},"ja382:17.2":{"pli":"Matassa jīvassa ca tassa homi; ","html":"<span class='verse-line'>{}</span>"},"ja382:17.3":{"pli":"Etesaṁ yo aññataraṁ labhitvā, ","html":"<span class='verse-line'>{}</span>"},"ja382:17.4":{"pli":"Kantā sirī majjati appapañño; ","html":"<span class='verse-line'>{}</span>"},"ja382:17.5":{"pli":"Taṁ dittarūpaṁ visamaṁ carantaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja382:17.6":{"pli":"Karīsaṭhānaṁva vivajjayāmi. ","html":"<span class='verse-line'>{}</span></p>"},"ja382:18.1":{"pli":"Attanā kurute lakkhiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja382:18.2":{"pli":"alakkhiṁ kurutattanā; ","html":"<span class='verse-line'>{}</span>"},"ja382:18.3":{"pli":"Na hi lakkhiṁ alakkhiṁ vā, ","html":"<span class='verse-line'>{}</span>"},"ja382:18.4":{"pli":"añño aññassa kārako”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja382:19.1":{"pli":"Sirikāḷakaṇṇijātakaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja383":{"ja383:0.1":{"pli":"Jātaka ","html":"<article id='ja383'><header><ul><li class='division'>{}</li>"},"ja383:0.2":{"pli":"Chakkanipāta ","html":"<li>{}</li>"},"ja383:0.3":{"pli":"Avāriyavagga ","html":"<li>{}</li></ul>"},"ja383:0.4":{"pli":"8. Kukkuṭajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja383:1.1":{"pli":"“Sucittapattachadana, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja383:1.2":{"pli":"tambacūḷa vihaṅgama; ","html":"<span class='verse-line'>{}</span>"},"ja383:1.3":{"pli":"Oroha dumasākhāya, ","html":"<span class='verse-line'>{}</span>"},"ja383:1.4":{"pli":"mudhā bhariyā bhavāmi te”. ","html":"<span class='verse-line'>{}</span></p>"},"ja383:2.1":{"pli":"“Catuppadī tvaṁ kalyāṇi, ","html":"<p><span class='verse-line'>{}</span>"},"ja383:2.2":{"pli":"dvipadāhaṁ manorame; ","html":"<span class='verse-line'>{}</span>"},"ja383:2.3":{"pli":"Migī pakkhī asaññuttā, ","html":"<span class='verse-line'>{}</span>"},"ja383:2.4":{"pli":"aññaṁ pariyesa sāmikaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja383:3.1":{"pli":"“Komārikā te hessāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja383:3.2":{"pli":"Mañjukā piyabhāṇinī; ","html":"<span class='verse-line'>{}</span>"},"ja383:3.3":{"pli":"Vinda maṁ ariyena vedena, ","html":"<span class='verse-line'>{}</span>"},"ja383:3.4":{"pli":"Sāvaya maṁ yadicchasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja383:4.1":{"pli":"“Kuṇapādini lohitape, ","html":"<p><span class='verse-line'>{}</span>"},"ja383:4.2":{"pli":"cori kukkuṭapothini; ","html":"<span class='verse-line'>{}</span>"},"ja383:4.3":{"pli":"Na tvaṁ ariyena vedena, ","html":"<span class='verse-line'>{}</span>"},"ja383:4.4":{"pli":"mamaṁ bhattāramicchasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja383:5.1":{"pli":"“Evampi caturā nārī, ","html":"<p><span class='verse-line'>{}</span>"},"ja383:5.2":{"pli":"disvāna sadhanaṁ naraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja383:5.3":{"pli":"Nenti saṇhāhi vācāhi, ","html":"<span class='verse-line'>{}</span>"},"ja383:5.4":{"pli":"biḷārī viya kukkuṭaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja383:6.1":{"pli":"Yo ca uppatitaṁ atthaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja383:6.2":{"pli":"na khippamanubujjhati; ","html":"<span class='verse-line'>{}</span>"},"ja383:6.3":{"pli":"Amittavasamanveti, ","html":"<span class='verse-line'>{}</span>"},"ja383:6.4":{"pli":"pacchā ca anutappati. ","html":"<span class='verse-line'>{}</span></p>"},"ja383:7.1":{"pli":"Yo ca uppatitaṁ atthaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja383:7.2":{"pli":"khippameva nibodhati; ","html":"<span class='verse-line'>{}</span>"},"ja383:7.3":{"pli":"Muccate sattusambādhā, ","html":"<span class='verse-line'>{}</span>"},"ja383:7.4":{"pli":"kukkuṭova biḷāriyā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja383:8.1":{"pli":"Kukkuṭajātakaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja384":{"ja384:0.1":{"pli":"Jātaka ","html":"<article id='ja384'><header><ul><li class='division'>{}</li>"},"ja384:0.2":{"pli":"Chakkanipāta ","html":"<li>{}</li>"},"ja384:0.3":{"pli":"Avāriyavagga ","html":"<li>{}</li></ul>"},"ja384:0.4":{"pli":"9. Dhammadhajajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja384:1.1":{"pli":"“Dhammaṁ caratha ñātayo, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja384:1.2":{"pli":"Dhammaṁ caratha bhaddaṁ vo; ","html":"<span class='verse-line'>{}</span>"},"ja384:1.3":{"pli":"Dhammacārī sukhaṁ seti, ","html":"<span class='verse-line'>{}</span>"},"ja384:1.4":{"pli":"Asmiṁ loke paramhi ca”. ","html":"<span class='verse-line'>{}</span></p>"},"ja384:2.1":{"pli":"“Bhaddako vatayaṁ pakkhī, ","html":"<p><span class='verse-line'>{}</span>"},"ja384:2.2":{"pli":"dijo paramadhammiko; ","html":"<span class='verse-line'>{}</span>"},"ja384:2.3":{"pli":"Ekapādena tiṭṭhanto, ","html":"<span class='verse-line'>{}</span>"},"ja384:2.4":{"pli":"dhammamevānusāsati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja384:3.1":{"pli":"“Nāssa sīlaṁ vijānātha, ","html":"<p><span class='verse-line'>{}</span>"},"ja384:3.2":{"pli":"anaññāya pasaṁsatha; ","html":"<span class='verse-line'>{}</span>"},"ja384:3.3":{"pli":"Bhutvā aṇḍañca potañca, ","html":"<span class='verse-line'>{}</span>"},"ja384:3.4":{"pli":"dhammo dhammoti bhāsati. ","html":"<span class='verse-line'>{}</span></p>"},"ja384:4.1":{"pli":"Aññaṁ bhaṇati vācāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja384:4.2":{"pli":"aññaṁ kāyena kubbati; ","html":"<span class='verse-line'>{}</span>"},"ja384:4.3":{"pli":"Vācāya no ca kāyena, ","html":"<span class='verse-line'>{}</span>"},"ja384:4.4":{"pli":"na taṁ dhammaṁ adhiṭṭhito. ","html":"<span class='verse-line'>{}</span></p>"},"ja384:5.1":{"pli":"Vācāya sakhilo manoviduggo, ","html":"<p><span class='verse-line'>{}</span>"},"ja384:5.2":{"pli":"Channo kūpasayova kaṇhasappo; ","html":"<span class='verse-line'>{}</span>"},"ja384:5.3":{"pli":"Dhammadhajo gāmanigamāsu sādhu, ","html":"<span class='verse-line'>{}</span>"},"ja384:5.4":{"pli":"Dujjāno purisena bālisena. ","html":"<span class='verse-line'>{}</span></p>"},"ja384:6.1":{"pli":"Imaṁ tuṇḍehi pakkhehi, ","html":"<p><span class='verse-line'>{}</span>"},"ja384:6.2":{"pli":"pādā cimaṁ viheṭhatha; ","html":"<span class='verse-line'>{}</span>"},"ja384:6.3":{"pli":"Chavañhimaṁ vināsetha, ","html":"<span class='verse-line'>{}</span>"},"ja384:6.4":{"pli":"nāyaṁ saṁvāsanāraho”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja384:7.1":{"pli":"Dhammadhajajātakaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja385":{"ja385:0.1":{"pli":"Jātaka ","html":"<article id='ja385'><header><ul><li class='division'>{}</li>"},"ja385:0.2":{"pli":"Chakkanipāta ","html":"<li>{}</li>"},"ja385:0.3":{"pli":"Avāriyavagga ","html":"<li>{}</li></ul>"},"ja385:0.4":{"pli":"10. Nandiyamigarājajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja385:1.1":{"pli":"“Sace brāhmaṇa gacchesi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja385:1.2":{"pli":"sākete ajjunaṁ vanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja385:1.3":{"pli":"Vajjāsi nandiyaṁ nāma, ","html":"<span class='verse-line'>{}</span>"},"ja385:1.4":{"pli":"puttaṁ asmākamorasaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja385:1.5":{"pli":"Mātā pitā ca te vuddhā, ","html":"<span class='verse-line'>{}</span>"},"ja385:1.6":{"pli":"te taṁ icchanti passituṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja385:2.1":{"pli":"“Bhuttā mayā nivāpāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja385:2.2":{"pli":"Rājino pānabhojanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja385:2.3":{"pli":"Taṁ rājapiṇḍaṁ avabhottuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja385:2.4":{"pli":"Nāhaṁ brāhmaṇa mussahe”. ","html":"<span class='verse-line'>{}</span></p>"},"ja385:3.1":{"pli":"“Odahissāmahaṁ passaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja385:3.2":{"pli":"khurappānissa rājino; ","html":"<span class='verse-line'>{}</span>"},"ja385:3.3":{"pli":"Tadāhaṁ sukhito mutto, ","html":"<span class='verse-line'>{}</span>"},"ja385:3.4":{"pli":"api passeyya mātaraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja385:4.1":{"pli":"Migarājā pure āsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja385:4.2":{"pli":"kosalassa niketane; ","html":"<span class='verse-line'>{}</span>"},"ja385:4.3":{"pli":"Nandiyo nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"ja385:4.4":{"pli":"abhirūpo catuppado. ","html":"<span class='verse-line'>{}</span></p>"},"ja385:5.1":{"pli":"Taṁ maṁ vadhitumāgacchi, ","html":"<p><span class='verse-line'>{}</span>"},"ja385:5.2":{"pli":"dāyasmiṁ ajjune vane; ","html":"<span class='verse-line'>{}</span>"},"ja385:5.3":{"pli":"Dhanuṁ advejjhaṁ katvāna, ","html":"<span class='verse-line'>{}</span>"},"ja385:5.4":{"pli":"usuṁ sannayha kosalo. ","html":"<span class='verse-line'>{}</span></p>"},"ja385:6.1":{"pli":"Tassāhaṁ odahiṁ passaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja385:6.2":{"pli":"khurappānissa rājino; ","html":"<span class='verse-line'>{}</span>"},"ja385:6.3":{"pli":"Tadāhaṁ sukhito mutto, ","html":"<span class='verse-line'>{}</span>"},"ja385:6.4":{"pli":"mātaraṁ daṭṭhumāgato”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja385:7.1":{"pli":"Nandiyamigarājajātakaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja385:7.2":{"pli":"Avāriyavaggo paṭhamo. ","html":"<p class='endvagga'>{}</p>"},"ja385:8.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja385:9.1":{"pli":"Atha kujjharathesabha ketuvaro, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja385:9.2":{"pli":"Sadarīmukha neru latā ca puna; ","html":"<span class='verse-line'>{}</span>"},"ja385:9.3":{"pli":"Apananda sirī ca sucittavaro, ","html":"<span class='verse-line'>{}</span>"},"ja385:9.4":{"pli":"Atha dhammika nandimigena dasāti. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"ja386":{"ja386:0.1":{"pli":"Jātaka ","html":"<article id='ja386'><header><ul><li class='division'>{}</li>"},"ja386:0.2":{"pli":"Chakkanipāta ","html":"<li>{}</li>"},"ja386:0.3":{"pli":"Kharaputtavagga ","html":"<li>{}</li></ul>"},"ja386:0.4":{"pli":"1. Kharaputtajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja386:1.1":{"pli":"“Saccaṁ kirevamāhaṁsu, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja386:1.2":{"pli":"vastaṁ bāloti paṇḍitā; ","html":"<span class='verse-line'>{}</span>"},"ja386:1.3":{"pli":"Passa bālo rahokammaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja386:1.4":{"pli":"āvikubbaṁ na bujjhati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja386:2.1":{"pli":"“Tvaṁ khopi samma bālosi, ","html":"<p><span class='verse-line'>{}</span>"},"ja386:2.2":{"pli":"kharaputta vijānahi; ","html":"<span class='verse-line'>{}</span>"},"ja386:2.3":{"pli":"Rajjuyā hi parikkhitto, ","html":"<span class='verse-line'>{}</span>"},"ja386:2.4":{"pli":"vaṅkoṭṭho ohitomukho. ","html":"<span class='verse-line'>{}</span></p>"},"ja386:3.1":{"pli":"Aparampi samma te bālyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja386:3.2":{"pli":"yo mutto na palāyasi; ","html":"<span class='verse-line'>{}</span>"},"ja386:3.3":{"pli":"So ca bālataro samma, ","html":"<span class='verse-line'>{}</span>"},"ja386:3.4":{"pli":"yaṁ tvaṁ vahasi senakaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja386:4.1":{"pli":"“Yannu samma ahaṁ bālo, ","html":"<p><span class='verse-line'>{}</span>"},"ja386:4.2":{"pli":"ajarāja vijānahi; ","html":"<span class='verse-line'>{}</span>"},"ja386:4.3":{"pli":"Atha kena senako bālo, ","html":"<span class='verse-line'>{}</span>"},"ja386:4.4":{"pli":"taṁ me akkhāhi pucchito”. ","html":"<span class='verse-line'>{}</span></p>"},"ja386:5.1":{"pli":"“Uttamatthaṁ labhitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"ja386:5.2":{"pli":"bhariyāya yo padassati; ","html":"<span class='verse-line'>{}</span>"},"ja386:5.3":{"pli":"Tena jahissatattānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja386:5.4":{"pli":"sā cevassa na hessati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja386:6.1":{"pli":"“Na ve piyammeti janinda tādiso, ","html":"<p><span class='verse-line'>{}</span>"},"ja386:6.2":{"pli":"Attaṁ niraṅkatvā piyāni sevati; ","html":"<span class='verse-line'>{}</span>"},"ja386:6.3":{"pli":"Attāva seyyo paramā ca seyyo, ","html":"<span class='verse-line'>{}</span>"},"ja386:6.4":{"pli":"Labbhā piyā ocitatthena pacchā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja386:7.1":{"pli":"Kharaputtajātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja387":{"ja387:0.1":{"pli":"Jātaka ","html":"<article id='ja387'><header><ul><li class='division'>{}</li>"},"ja387:0.2":{"pli":"Chakkanipāta ","html":"<li>{}</li>"},"ja387:0.3":{"pli":"Kharaputtavagga ","html":"<li>{}</li></ul>"},"ja387:0.4":{"pli":"2. Sūcijātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja387:1.1":{"pli":"“Akakkasaṁ apharusaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja387:1.2":{"pli":"kharadhotaṁ supāsiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja387:1.3":{"pli":"Sukhumaṁ tikhiṇaggañca, ","html":"<span class='verse-line'>{}</span>"},"ja387:1.4":{"pli":"ko sūciṁ ketumicchati. ","html":"<span class='verse-line'>{}</span></p>"},"ja387:2.1":{"pli":"Sumajjañca supāsañca, ","html":"<p><span class='verse-line'>{}</span>"},"ja387:2.2":{"pli":"anupubbaṁ suvaṭṭitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja387:2.3":{"pli":"Ghanaghātimaṁ paṭithaddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja387:2.4":{"pli":"ko sūciṁ ketumicchati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja387:3.1":{"pli":"“Ito dāni patāyanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja387:3.2":{"pli":"sūciyo baḷisāni ca; ","html":"<span class='verse-line'>{}</span>"},"ja387:3.3":{"pli":"Koyaṁ kammāragāmasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja387:3.4":{"pli":"sūciṁ vikketumicchati. ","html":"<span class='verse-line'>{}</span></p>"},"ja387:4.1":{"pli":"Ito satthāni gacchanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja387:4.2":{"pli":"Kammantā vividhā puthū; ","html":"<span class='verse-line'>{}</span>"},"ja387:4.3":{"pli":"Koyaṁ kammāragāmasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja387:4.4":{"pli":"Sūciṁ vikketumicchati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja387:5.1":{"pli":"“Sūciṁ kammāragāmasmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja387:5.2":{"pli":"vikketabbā pajānatā; ","html":"<span class='verse-line'>{}</span>"},"ja387:5.3":{"pli":"Ācariyāva jānanti, ","html":"<span class='verse-line'>{}</span>"},"ja387:5.4":{"pli":"kammaṁ sukatadukkaṭaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja387:6.1":{"pli":"Imañce te pitā bhadde, ","html":"<p><span class='verse-line'>{}</span>"},"ja387:6.2":{"pli":"Sūciṁ jaññā mayā kataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja387:6.3":{"pli":"Tayā ca maṁ nimanteyya, ","html":"<span class='verse-line'>{}</span>"},"ja387:6.4":{"pli":"Yañcatthaññaṁ ghare dhanan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja387:7.1":{"pli":"Sūcijātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja388":{"ja388:0.1":{"pli":"Jātaka ","html":"<article id='ja388'><header><ul><li class='division'>{}</li>"},"ja388:0.2":{"pli":"Chakkanipāta ","html":"<li>{}</li>"},"ja388:0.3":{"pli":"Kharaputtavagga ","html":"<li>{}</li></ul>"},"ja388:0.4":{"pli":"3. Tuṇḍilajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja388:1.1":{"pli":"“Navachannake dāni diyyati, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja388:1.2":{"pli":"Puṇṇāyaṁ doṇi suvāminī ṭhitā; ","html":"<span class='verse-line'>{}</span>"},"ja388:1.3":{"pli":"Bahuke jane pāsapāṇike, ","html":"<span class='verse-line'>{}</span>"},"ja388:1.4":{"pli":"No ca kho me paṭibhāti bhuñjituṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja388:2.1":{"pli":"“Tasasi bhamasi leṇamicchasi, ","html":"<p><span class='verse-line'>{}</span>"},"ja388:2.2":{"pli":"Attāṇosi kuhiṁ gamissasi; ","html":"<span class='verse-line'>{}</span>"},"ja388:2.3":{"pli":"Appossukko bhuñja tuṇḍila, ","html":"<span class='verse-line'>{}</span>"},"ja388:2.4":{"pli":"Maṁsatthāya hi positāmhase. ","html":"<span class='verse-line'>{}</span></p>"},"ja388:3.1":{"pli":"Ogaha rahadaṁ akaddamaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja388:3.2":{"pli":"Sabbaṁ sedamalaṁ pavāhaya; ","html":"<span class='verse-line'>{}</span>"},"ja388:3.3":{"pli":"Gaṇhāhi navaṁ vilepanaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja388:3.4":{"pli":"Yassa gandho na kadāci chijjati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja388:4.1":{"pli":"“Katamo rahado akaddamo, ","html":"<p><span class='verse-line'>{}</span>"},"ja388:4.2":{"pli":"Kiṁsu sedamalanti vuccati; ","html":"<span class='verse-line'>{}</span>"},"ja388:4.3":{"pli":"Katamañca navaṁ vilepanaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja388:4.4":{"pli":"Yassa gandho na kadāci chijjati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja388:5.1":{"pli":"“Dhammo rahado akaddamo, ","html":"<p><span class='verse-line'>{}</span>"},"ja388:5.2":{"pli":"Pāpaṁ sedamalanti vuccati; ","html":"<span class='verse-line'>{}</span>"},"ja388:5.3":{"pli":"Sīlañca navaṁ vilepanaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja388:5.4":{"pli":"Tassa gandho na kadāci chijjati. ","html":"<span class='verse-line'>{}</span></p>"},"ja388:6.1":{"pli":"Nandanti sarīraghātino, ","html":"<p><span class='verse-line'>{}</span>"},"ja388:6.2":{"pli":"Na ca nandanti sarīradhārino; ","html":"<span class='verse-line'>{}</span>"},"ja388:6.3":{"pli":"Puṇṇāya ca puṇṇamāsiyā, ","html":"<span class='verse-line'>{}</span>"},"ja388:6.4":{"pli":"Ramamānāva jahanti jīvitan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja388:7.1":{"pli":"Tuṇḍilajātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja389":{"ja389:0.1":{"pli":"Jātaka ","html":"<article id='ja389'><header><ul><li class='division'>{}</li>"},"ja389:0.2":{"pli":"Chakkanipāta ","html":"<li>{}</li>"},"ja389:0.3":{"pli":"Kharaputtavagga ","html":"<li>{}</li></ul>"},"ja389:0.4":{"pli":"4. Suvaṇṇakakkaṭajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja389:1.1":{"pli":"“Siṅgīmigo āyatacakkhunetto, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja389:1.2":{"pli":"Aṭṭhittaco vārisayo alomo; ","html":"<span class='verse-line'>{}</span>"},"ja389:1.3":{"pli":"Tenābhibhūto kapaṇaṁ rudāmi, ","html":"<span class='verse-line'>{}</span>"},"ja389:1.4":{"pli":"Hare sakhā kissa nu maṁ jahāsi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja389:2.1":{"pli":"So passasanto mahatā phaṇena, ","html":"<p><span class='verse-line'>{}</span>"},"ja389:2.2":{"pli":"Bhujaṅgamo kakkaṭamajjhapatto; ","html":"<span class='verse-line'>{}</span>"},"ja389:2.3":{"pli":"Sakhā sakhāraṁ paritāyamāno, ","html":"<span class='verse-line'>{}</span>"},"ja389:2.4":{"pli":"Bhujaṅgamaṁ kakkaṭako gahesi. ","html":"<span class='verse-line'>{}</span></p>"},"ja389:3.1":{"pli":"“Na vāyasaṁ no pana kaṇhasappaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja389:3.2":{"pli":"Ghāsatthiko kakkaṭako adeyya; ","html":"<span class='verse-line'>{}</span>"},"ja389:3.3":{"pli":"Pucchāmi taṁ āyatacakkhunetta, ","html":"<span class='verse-line'>{}</span>"},"ja389:3.4":{"pli":"Atha kissa hetumha ubho gahītā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja389:4.1":{"pli":"“Ayaṁ puriso mama atthakāmo, ","html":"<p><span class='verse-line'>{}</span>"},"ja389:4.2":{"pli":"Yo maṁ gahetvāna dakāya neti; ","html":"<span class='verse-line'>{}</span>"},"ja389:4.3":{"pli":"Tasmiṁ mate dukkhamanappakaṁ me, ","html":"<span class='verse-line'>{}</span>"},"ja389:4.4":{"pli":"Ahañca eso ca ubho na homa. ","html":"<span class='verse-line'>{}</span></p>"},"ja389:5.1":{"pli":"Mamañca disvāna pavaddhakāyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja389:5.2":{"pli":"Sabbo jano hiṁsitumeva micche; ","html":"<span class='verse-line'>{}</span>"},"ja389:5.3":{"pli":"Sāduñca thūlañca muduñca maṁsaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja389:5.4":{"pli":"Kākāpi maṁ disvāna viheṭhayeyyuṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja389:6.1":{"pli":"“Sacetassa hetumha ubho gahītā, ","html":"<p><span class='verse-line'>{}</span>"},"ja389:6.2":{"pli":"Uṭṭhātu poso visamāvamāmi; ","html":"<span class='verse-line'>{}</span>"},"ja389:6.3":{"pli":"Mamañca kākañca pamuñca khippaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja389:6.4":{"pli":"Pure visaṁ gāḷhamupeti maccaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja389:7.1":{"pli":"“Sappaṁ pamokkhāmi na tāva kākaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja389:7.2":{"pli":"Paṭibandhako hohiti tāva kāko; ","html":"<span class='verse-line'>{}</span>"},"ja389:7.3":{"pli":"Purisañca disvāna sukhiṁ arogaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja389:7.4":{"pli":"Kākaṁ pamokkhāmi yatheva sappaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja389:8.1":{"pli":"“Kāko tadā devadatto ahosi, ","html":"<p><span class='verse-line'>{}</span>"},"ja389:8.2":{"pli":"Māro pana kaṇhasappo ahosi; ","html":"<span class='verse-line'>{}</span>"},"ja389:8.3":{"pli":"Ānandabhaddo kakkaṭako ahosi, ","html":"<span class='verse-line'>{}</span>"},"ja389:8.4":{"pli":"Ahaṁ tadā brāhmaṇo homi satthā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja389:9.1":{"pli":"Suvaṇṇakakkaṭajātakaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja39":{"ja39:0.1":{"pli":"Jātaka ","eng":"Stories of Past Lives 39 ","html":"<article id='ja39'><header><ul><li class='division'>{}</li>"},"ja39:0.2":{"pli":"Ekakanipāta ","eng":"The Book of the Ones ","html":"<li>{}</li>"},"ja39:0.3":{"pli":"Kulāvakavagga ","eng":"Nests ","html":"<li>{}</li></ul>"},"ja39:0.4":{"pli":"9. Nandajātaka ","eng":"Nanda: a past life story ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja39:1.1":{"pli":"“Maññe sovaṇṇayo rāsi, ","eng":"I suspect the heap of gold ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>","comm":"Before his death, the father entrusted only his servant Nanda with the location of his buried wealth, fearing that his young wife would waste the money on a new man rather than give it to his true heir, her son. But when the servant arrived at the location with the heir, out of conceit he started cursing rather than reveal the treasure. The verse records the advice given to the son by his father’s old friend. "},"ja39:1.2":{"pli":"soṇṇamālā ca nandako; ","eng":"and golden chains ","html":"<span class='verse-line'>{}</span>"},"ja39:1.3":{"pli":"Yattha dāso āmajāto, ","eng":"is where the house-born slave Nandaka ","html":"<span class='verse-line'>{}</span>","comm":"<i lang='pi' translate='no'>Āma</i> is from Vedic <i lang='pi' translate='no'>amā</i> (“house”), but is explained by the commentary as “with consent”. "},"ja39:1.4":{"pli":"ṭhito thullāni gajjatī”ti. ","eng":"stands yelling curses. ","html":"<span class='verse-line'>{}</span></p></blockquote>","comm":"The commentary hints at the real motivation for Nanda’s odd behavior. Having been with the father since birth, he is called <i lang='pi' translate='no'>tāta</i> (“my dear”) and <i lang='pi' translate='no'>mātula</i> (“uncle”), as if he were the master’s brother. He reveals what he really thinks of his master’s young wife and her son in his curse, “You bastard son of a slave girl” (<i lang='pi' translate='no'>are dāsiputta ceṭaka</i>; Agnipurāṇa 366.46 lists <i lang='pi' translate='no'>ceṭaka</i> with <i lang='pi' translate='no'>dāsera</i>, “slaveson”). There is no question of punishment for his insolence, but the tone shifts, as he is called “slave” (<i lang='pi' translate='no'>dāsa</i>) and bluntly ordered to carry the treasure home. "},"ja39:2.1":{"pli":"Nandajātakaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja390":{"ja390:0.1":{"pli":"Jātaka ","html":"<article id='ja390'><header><ul><li class='division'>{}</li>"},"ja390:0.2":{"pli":"Chakkanipāta ","html":"<li>{}</li>"},"ja390:0.3":{"pli":"Kharaputtavagga ","html":"<li>{}</li></ul>"},"ja390:0.4":{"pli":"5. Mayhakajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja390:1.1":{"pli":"“Sakuṇo mayhako nāma, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja390:1.2":{"pli":"girisānudarīcaro; ","html":"<span class='verse-line'>{}</span>"},"ja390:1.3":{"pli":"Pakkaṁ pipphalimāruyha, ","html":"<span class='verse-line'>{}</span>"},"ja390:1.4":{"pli":"mayhaṁ mayhanti kandati. ","html":"<span class='verse-line'>{}</span></p>"},"ja390:2.1":{"pli":"Tassevaṁ vilapantassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja390:2.2":{"pli":"dijasaṅghā samāgatā; ","html":"<span class='verse-line'>{}</span>"},"ja390:2.3":{"pli":"Bhutvāna pipphaliṁ yanti, ","html":"<span class='verse-line'>{}</span>"},"ja390:2.4":{"pli":"vilapatveva so dijo. ","html":"<span class='verse-line'>{}</span></p>"},"ja390:3.1":{"pli":"Evameva idhekacco, ","html":"<p><span class='verse-line'>{}</span>"},"ja390:3.2":{"pli":"saṅgharitvā bahuṁ dhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja390:3.3":{"pli":"Nevattano na ñātīnaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja390:3.4":{"pli":"yathodhiṁ paṭipajjati. ","html":"<span class='verse-line'>{}</span></p>"},"ja390:4.1":{"pli":"Na so acchādanaṁ bhattaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja390:4.2":{"pli":"na mālaṁ na vilepanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja390:4.3":{"pli":"Anubhoti sakiṁ kiñci, ","html":"<span class='verse-line'>{}</span>"},"ja390:4.4":{"pli":"na saṅgaṇhāti ñātake. ","html":"<span class='verse-line'>{}</span></p>"},"ja390:5.1":{"pli":"Tassevaṁ vilapantassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja390:5.2":{"pli":"mayhaṁ mayhanti rakkhato; ","html":"<span class='verse-line'>{}</span>"},"ja390:5.3":{"pli":"Rājāno atha vā corā, ","html":"<span class='verse-line'>{}</span>"},"ja390:5.4":{"pli":"dāyādā ye va appiyā; ","html":"<span class='verse-line'>{}</span>"},"ja390:5.5":{"pli":"Dhanamādāya gacchanti, ","html":"<span class='verse-line'>{}</span>"},"ja390:5.6":{"pli":"vilapatveva so naro. ","html":"<span class='verse-line'>{}</span></p>"},"ja390:6.1":{"pli":"Dhīro bhoge adhigamma, ","html":"<p><span class='verse-line'>{}</span>"},"ja390:6.2":{"pli":"saṅgaṇhāti ca ñātake; ","html":"<span class='verse-line'>{}</span>"},"ja390:6.3":{"pli":"Tena so kittiṁ pappoti, ","html":"<span class='verse-line'>{}</span>"},"ja390:6.4":{"pli":"pecca sagge pamodatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja390:7.1":{"pli":"Mayhakajātakaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja391":{"ja391:0.1":{"pli":"Jātaka ","html":"<article id='ja391'><header><ul><li class='division'>{}</li>"},"ja391:0.2":{"pli":"Chakkanipāta ","html":"<li>{}</li>"},"ja391:0.3":{"pli":"Kharaputtavagga ","html":"<li>{}</li></ul>"},"ja391:0.4":{"pli":"6. Vijjādharajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja391:1.1":{"pli":"“Dubbaṇṇarūpaṁ tuvamariyavaṇṇī, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja391:1.2":{"pli":"Purakkhatvā pañjaliko namassasi; ","html":"<span class='verse-line'>{}</span>"},"ja391:1.3":{"pli":"Seyyo nu te so udavā sarikkho, ","html":"<span class='verse-line'>{}</span>"},"ja391:1.4":{"pli":"Nāmaṁ parassattano cāpi brūhi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja391:2.1":{"pli":"“Na nāmagottaṁ gaṇhanti rāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja391:2.2":{"pli":"Sammaggatānujjugatāna devā; ","html":"<span class='verse-line'>{}</span>"},"ja391:2.3":{"pli":"Ahañca te nāmadheyyaṁ vadāmi, ","html":"<span class='verse-line'>{}</span>"},"ja391:2.4":{"pli":"Sakkohamasmī tidasānamindo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja391:3.1":{"pli":"“Yo disvā bhikkhuṁ caraṇūpapannaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja391:3.2":{"pli":"Purakkhatvā pañjaliko namassati; ","html":"<span class='verse-line'>{}</span>"},"ja391:3.3":{"pli":"Pucchāmi taṁ devarājetamatthaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja391:3.4":{"pli":"Ito cuto kiṁ labhate sukhaṁ so”. ","html":"<span class='verse-line'>{}</span></p>"},"ja391:4.1":{"pli":"“Yo disvā bhikkhuṁ caraṇūpapannaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja391:4.2":{"pli":"Purakkhatvā pañjaliko namassati; ","html":"<span class='verse-line'>{}</span>"},"ja391:4.3":{"pli":"Diṭṭheva dhamme labhate pasaṁsaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja391:4.4":{"pli":"Saggañca so yāti sarīrabhedā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja391:5.1":{"pli":"“Lakkhī vata me udapādi ajja, ","html":"<p><span class='verse-line'>{}</span>"},"ja391:5.2":{"pli":"Yaṁ vāsavaṁ bhūtapatiddasāma; ","html":"<span class='verse-line'>{}</span>"},"ja391:5.3":{"pli":"Bhikkhuñca disvāna tuvañca sakka, ","html":"<span class='verse-line'>{}</span>"},"ja391:5.4":{"pli":"Kāhāmi puññāni anappakāni”. ","html":"<span class='verse-line'>{}</span></p>"},"ja391:6.1":{"pli":"“Addhā have sevitabbā sapaññā, ","html":"<p><span class='verse-line'>{}</span>"},"ja391:6.2":{"pli":"Bahussutā ye bahuṭhānacintino; ","html":"<span class='verse-line'>{}</span>"},"ja391:6.3":{"pli":"Bhikkhuñca disvāna mamañca rāja, ","html":"<span class='verse-line'>{}</span>"},"ja391:6.4":{"pli":"Karohi puññāni anappakāni”. ","html":"<span class='verse-line'>{}</span></p>"},"ja391:7.1":{"pli":"“Akkodhano niccapasannacitto, ","html":"<p><span class='verse-line'>{}</span>"},"ja391:7.2":{"pli":"Sabbātithīyācayogo bhavitvā; ","html":"<span class='verse-line'>{}</span>"},"ja391:7.3":{"pli":"Nihacca mānaṁ abhivādayissaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja391:7.4":{"pli":"Sutvāna devinda subhāsitānī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja391:8.1":{"pli":"Vijjādharajātakaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja392":{"ja392:0.1":{"pli":"Jātaka ","html":"<article id='ja392'><header><ul><li class='division'>{}</li>"},"ja392:0.2":{"pli":"Chakkanipāta ","html":"<li>{}</li>"},"ja392:0.3":{"pli":"Kharaputtavagga ","html":"<li>{}</li></ul>"},"ja392:0.4":{"pli":"7. Siṅghapupphajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja392:1.1":{"pli":"“Yametaṁ vārijaṁ pupphaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja392:1.2":{"pli":"Adinnaṁ upasiṅghasi; ","html":"<span class='verse-line'>{}</span>"},"ja392:1.3":{"pli":"Ekaṅgametaṁ theyyānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja392:1.4":{"pli":"Gandhathenosi mārisa”. ","html":"<span class='verse-line'>{}</span></p>"},"ja392:2.1":{"pli":"“Na harāmi na bhañjāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja392:2.2":{"pli":"ārā siṅghāmi vārijaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja392:2.3":{"pli":"Atha kena nu vaṇṇena, ","html":"<span class='verse-line'>{}</span>"},"ja392:2.4":{"pli":"gandhathenoti vuccati. ","html":"<span class='verse-line'>{}</span></p>"},"ja392:3.1":{"pli":"Yoyaṁ bhisāni khaṇati, ","html":"<p><span class='verse-line'>{}</span>"},"ja392:3.2":{"pli":"puṇḍarīkāni bhañjati; ","html":"<span class='verse-line'>{}</span>"},"ja392:3.3":{"pli":"Evaṁ ākiṇṇakammanto, ","html":"<span class='verse-line'>{}</span>"},"ja392:3.4":{"pli":"kasmā eso na vuccati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja392:4.1":{"pli":"“Ākiṇṇaluddo puriso, ","html":"<p><span class='verse-line'>{}</span>"},"ja392:4.2":{"pli":"dhāticelaṁva makkhito; ","html":"<span class='verse-line'>{}</span>"},"ja392:4.3":{"pli":"Tasmiṁ me vacanaṁ natthi, ","html":"<span class='verse-line'>{}</span>"},"ja392:4.4":{"pli":"tañcārahāmi vattave. ","html":"<span class='verse-line'>{}</span></p>"},"ja392:5.1":{"pli":"Anaṅgaṇassa posassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja392:5.2":{"pli":"niccaṁ sucigavesino; ","html":"<span class='verse-line'>{}</span>"},"ja392:5.3":{"pli":"Vālaggamattaṁ pāpassa, ","html":"<span class='verse-line'>{}</span>"},"ja392:5.4":{"pli":"abbhāmattaṁva khāyati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja392:6.1":{"pli":"“Addhā maṁ yakkha jānāsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja392:6.2":{"pli":"atho maṁ anukampasi; ","html":"<span class='verse-line'>{}</span>"},"ja392:6.3":{"pli":"Punapi yakkha vajjāsi, ","html":"<span class='verse-line'>{}</span>"},"ja392:6.4":{"pli":"yadā passasi edisaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja392:7.1":{"pli":"“Neva taṁ upajīvāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja392:7.2":{"pli":"napi te bhatakāmhase; ","html":"<span class='verse-line'>{}</span>"},"ja392:7.3":{"pli":"Tvameva bhikkhu jāneyya, ","html":"<span class='verse-line'>{}</span>"},"ja392:7.4":{"pli":"yena gaccheyya suggatin”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja392:8.1":{"pli":"Siṅghapupphajātakaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja393":{"ja393:0.1":{"pli":"Jātaka ","html":"<article id='ja393'><header><ul><li class='division'>{}</li>"},"ja393:0.2":{"pli":"Chakkanipāta ","html":"<li>{}</li>"},"ja393:0.3":{"pli":"Kharaputtavagga ","html":"<li>{}</li></ul>"},"ja393:0.4":{"pli":"8. Vighāsādajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja393:1.1":{"pli":"“Susukhaṁ vata jīvanti, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja393:1.2":{"pli":"ye janā vighāsādino; ","html":"<span class='verse-line'>{}</span>"},"ja393:1.3":{"pli":"Diṭṭheva dhamme pāsaṁsā, ","html":"<span class='verse-line'>{}</span>"},"ja393:1.4":{"pli":"samparāye ca suggatī”. ","html":"<span class='verse-line'>{}</span></p>"},"ja393:2.1":{"pli":"“Sukassa bhāsamānassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja393:2.2":{"pli":"na nisāmetha paṇḍitā; ","html":"<span class='verse-line'>{}</span>"},"ja393:2.3":{"pli":"Idaṁ suṇātha sodariyā, ","html":"<span class='verse-line'>{}</span>"},"ja393:2.4":{"pli":"amhevāyaṁ pasaṁsati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja393:3.1":{"pli":"“Nāhaṁ tumhe pasaṁsāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja393:3.2":{"pli":"kuṇapādā suṇātha me; ","html":"<span class='verse-line'>{}</span>"},"ja393:3.3":{"pli":"Ucchiṭṭhabhojino tumhe, ","html":"<span class='verse-line'>{}</span>"},"ja393:3.4":{"pli":"na tumhe vighāsādino”. ","html":"<span class='verse-line'>{}</span></p>"},"ja393:4.1":{"pli":"“Sattavassā pabbajitā, ","html":"<p><span class='verse-line'>{}</span>"},"ja393:4.2":{"pli":"mejjhāraññe sikhaṇḍino; ","html":"<span class='verse-line'>{}</span>"},"ja393:4.3":{"pli":"Vighāseneva yāpentā, ","html":"<span class='verse-line'>{}</span>"},"ja393:4.4":{"pli":"mayañce bhoto gārayhā; ","html":"<span class='verse-line'>{}</span>"},"ja393:4.5":{"pli":"Ke nu bhoto pasaṁsiyā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja393:5.1":{"pli":"“Tumhe sīhānaṁ byagghānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja393:5.2":{"pli":"vāḷānañcāvasiṭṭhakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja393:5.3":{"pli":"Ucchiṭṭheneva yāpentā, ","html":"<span class='verse-line'>{}</span>"},"ja393:5.4":{"pli":"maññivho vighāsādino. ","html":"<span class='verse-line'>{}</span></p>"},"ja393:6.1":{"pli":"Ye brāhmaṇassa samaṇassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja393:6.2":{"pli":"aññassa vā vanibbino; ","html":"<span class='verse-line'>{}</span>"},"ja393:6.3":{"pli":"Datvāva sesaṁ bhuñjanti, ","html":"<span class='verse-line'>{}</span>"},"ja393:6.4":{"pli":"te janā vighāsādino”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja393:7.1":{"pli":"Vighāsādajātakaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}