{"thag21.1":{"thag21.1:0.1":{"pli":"Theragāthā 21.1 ","eng":"Verses of the Senior Monks 21.1 ","html":"<article id='thag21.1'><header><ul><li class='division'>{}</li>"},"thag21.1:0.2":{"pli":"Mahānipāta ","eng":"The Great Book ","html":"<li>{}</li>"},"thag21.1:0.3":{"pli":"Paṭhamavagga ","eng":"Chapter One ","html":"<li>{}</li></ul>"},"thag21.1:0.4":{"pli":"Vaṅgīsattheragāthā ","eng":"Vaṅgīsa ","html":"<h1 class='sutta-title'>{}</h1></header>"},"thag21.1:1.1":{"pli":"“Nikkhantaṁ vata maṁ santaṁ, ","eng":"“Now that I’ve gone forth ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"thag21.1:1.2":{"pli":"agārasmānagāriyaṁ; ","eng":"from the lay life to homelessness, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:1.3":{"pli":"Vitakkā upadhāvanti, ","eng":"I’m overrun ","html":"<span class='verse-line'>{}</span>"},"thag21.1:1.4":{"pli":"pagabbhā kaṇhato ime. ","eng":"by the rude thoughts of the Dark One. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:2.1":{"pli":"Uggaputtā mahissāsā, ","eng":"Even if a thousand mighty princes and great archers, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:2.2":{"pli":"sikkhitā daḷhadhammino; ","eng":"well trained, with strong bows, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:2.3":{"pli":"Samantā parikireyyuṁ, ","eng":"were to completely surround me; ","html":"<span class='verse-line'>{}</span>"},"thag21.1:2.4":{"pli":"sahassaṁ apalāyinaṁ. ","eng":"I would never flee. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:3.1":{"pli":"Sacepi ettakā bhiyyo, ","eng":"And even if women come, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:3.2":{"pli":"āgamissanti itthiyo; ","eng":"many more than that, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:3.3":{"pli":"Neva maṁ byādhayissanti, ","eng":"they won’t bother me, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:3.4":{"pli":"dhamme samhi patiṭṭhito. ","eng":"for I stand firm in the teaching. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:4.1":{"pli":"Sakkhī hi me sutaṁ etaṁ, ","eng":"I heard this with my own ears ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:4.2":{"pli":"buddhassādiccabandhuno; ","eng":"from the Buddha, kinsman of the Sun, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:4.3":{"pli":"Nibbānagamanaṁ maggaṁ, ","eng":"about the path going to extinguishment; ","html":"<span class='verse-line'>{}</span>"},"thag21.1:4.4":{"pli":"tattha me nirato mano. ","eng":"that’s what delights my mind. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:5.1":{"pli":"Evañce maṁ viharantaṁ, ","eng":"Wicked One, if you come near me ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:5.2":{"pli":"pāpima upagacchasi; ","eng":"as I meditate like this, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:5.3":{"pli":"Tathā maccu karissāmi, ","eng":"I’ll make sure that you, Death, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:5.4":{"pli":"na me maggampi dakkhasi. ","eng":"won’t even see the path I take.” ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:6.1":{"pli":"Aratiñca ratiñca pahāya, ","eng":"“Giving up desire and discontent, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:6.2":{"pli":"Sabbaso gehasitañca vitakkaṁ; ","eng":"along with all thought of domestic life, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:6.3":{"pli":"Vanathaṁ na kareyya kuhiñci, ","eng":"they wouldn’t get snarled in anything; ","html":"<span class='verse-line'>{}</span>"},"thag21.1:6.4":{"pli":"Nibbanatho avanatho sa bhikkhu. ","eng":"unsnarled, free of snarls: that’s a real mendicant. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:7.1":{"pli":"Yamidha pathaviñca vehāsaṁ, ","eng":"Whatever here is included in form—","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:7.2":{"pli":"Rūpagataṁ jagatogadhaṁ kiñci; ","eng":"on earth, in the sky, or in planet’s deep—","html":"<span class='verse-line'>{}</span>"},"thag21.1:7.3":{"pli":"Parijīyati sabbamaniccaṁ, ","eng":"wears out, it is all impermanent: ","html":"<span class='verse-line'>{}</span>"},"thag21.1:7.4":{"pli":"Evaṁ samecca caranti mutattā. ","eng":"the self-examined live having comprehended this. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:8.1":{"pli":"Upadhīsu janā gadhitāse, ","eng":"People are bound to their attachments, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:8.2":{"pli":"Diṭṭhasute paṭighe ca mute ca; ","eng":"to impingement of the seen and heard, <j>and to what is thought. ","html":"<span class='verse-line'>{}</span>"},"thag21.1:8.3":{"pli":"Ettha vinodaya chandamanejo, ","eng":"Unstirred, dispel desire for these things; ","html":"<span class='verse-line'>{}</span>"},"thag21.1:8.4":{"pli":"Yo hettha na limpati muni tamāhu. ","eng":"for one called ‘a sage’ does not cling to them. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:9.1":{"pli":"Atha saṭṭhisitā savitakkā, ","eng":"Trapped in the sixty wrong views, <j>full of their own opinions, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:9.2":{"pli":"Puthujjanatāya adhammā niviṭṭhā; ","eng":"ordinary people are fixed in wrong principles. ","html":"<span class='verse-line'>{}</span>"},"thag21.1:9.3":{"pli":"Na ca vaggagatassa kuhiñci, ","eng":"But that mendicant wouldn’t join a sect, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:9.4":{"pli":"No pana duṭṭhullagāhī sa bhikkhu. ","eng":"still less would they utter lewd speech. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:10.1":{"pli":"Dabbo cirarattasamāhito, ","eng":"Clever, long serene, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:10.2":{"pli":"Akuhako nipako apihālu; ","eng":"free of deceit, alert, without envy, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:10.3":{"pli":"Santaṁ padaṁ ajjhagamā muni, ","eng":"the sage has reached the state of peace; ","html":"<span class='verse-line'>{}</span>"},"thag21.1:10.4":{"pli":"Paṭicca parinibbuto kaṅkhati kālaṁ. ","eng":"quenched, he awaits his time.” ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:11.1":{"pli":"Mānaṁ pajahassu gotama, ","eng":"“Give up conceit, Gotama! ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:11.2":{"pli":"Mānapathañca jahassu asesaṁ; ","eng":"Completely abandon the different kinds of conceit! ","html":"<span class='verse-line'>{}</span>"},"thag21.1:11.3":{"pli":"Mānapathamhi sa mucchito, ","eng":"Besotted with the different kinds of conceit, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:11.4":{"pli":"Vippaṭisārīhuvā cirarattaṁ. ","eng":"you’ve had regrets for a long time. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:12.1":{"pli":"Makkhena makkhitā pajā, ","eng":"Smeared by smears and slain by conceit, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:12.2":{"pli":"Mānahatā nirayaṁ papatanti; ","eng":"people fall into hell. ","html":"<span class='verse-line'>{}</span>"},"thag21.1:12.3":{"pli":"Socanti janā cirarattaṁ, ","eng":"When people slain by conceit are reborn in hell, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:12.4":{"pli":"Mānahatā nirayaṁ upapannā. ","eng":"they grieve for a long time. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:13.1":{"pli":"Na hi socati bhikkhu kadāci, ","eng":"But a mendicant who practices rightly, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:13.2":{"pli":"Maggajino sammā paṭipanno; ","eng":"a path-victor, never grieves. ","html":"<span class='verse-line'>{}</span>"},"thag21.1:13.3":{"pli":"Kittiñca sukhañcānubhoti, ","eng":"They enjoy happiness and a good reputation, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:13.4":{"pli":"Dhammadasoti tamāhu tathattaṁ. ","eng":"and they rightly call him a ‘Seer of Truth’. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:14.1":{"pli":"Tasmā akhilo idha padhānavā, ","eng":"So being not hard-hearted, but energetic, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:14.2":{"pli":"Nīvaraṇāni pahāya visuddho; ","eng":"with hindrances given up, pure; ","html":"<span class='verse-line'>{}</span>"},"thag21.1:14.3":{"pli":"Mānañca pahāya asesaṁ, ","eng":"and having completely given up conceit, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:14.4":{"pli":"Vijjāyantakaro samitāvī”. ","eng":"the one who makes an end with knowledge is assuaged.” ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:15.1":{"pli":"“Kāmarāgena ḍayhāmi, ","eng":"“I’ve got a burning desire for pleasure; ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:15.2":{"pli":"cittaṁ me pariḍayhati; ","eng":"my mind is on fire! ","html":"<span class='verse-line'>{}</span>"},"thag21.1:15.3":{"pli":"Sādhu nibbāpanaṁ brūhi, ","eng":"Please, out of compassion, Gotama, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:15.4":{"pli":"anukampāya gotama”. ","eng":"tell me how to quench the flames.” ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:16.1":{"pli":"“Saññāya vipariyesā, ","eng":"“Your mind is on fire ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:16.2":{"pli":"cittaṁ te pariḍayhati; ","eng":"because of a perversion of perception. ","html":"<span class='verse-line'>{}</span>"},"thag21.1:16.3":{"pli":"Nimittaṁ parivajjehi, ","eng":"Turn away from the sign ","html":"<span class='verse-line'>{}</span>"},"thag21.1:16.4":{"pli":"subhaṁ rāgūpasaṁhitaṁ. (…) ","eng":"that’s attractive, provoking lust. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:17.1":{"pli":"Asubhāya cittaṁ bhāvehi, ","eng":"With your mind unified and serene, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:17.2":{"pli":"ekaggaṁ susamāhitaṁ; ","eng":"meditate on the ugly aspects of the body. ","html":"<span class='verse-line'>{}</span>"},"thag21.1:17.3":{"pli":"Sati kāyagatā tyatthu, ","eng":"With mindfulness immersed in the body, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:17.4":{"pli":"nibbidābahulo bhava. ","eng":"be full of disillusionment. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:18.1":{"pli":"Animittañca bhāvehi, ","eng":"Meditate on the signless, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:18.2":{"pli":"mānānusayamujjaha; ","eng":"give up the tendency to conceit; ","html":"<span class='verse-line'>{}</span>"},"thag21.1:18.3":{"pli":"Tato mānābhisamayā, ","eng":"and when you comprehend conceit, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:18.4":{"pli":"upasanto carissasi”. ","eng":"you will live at peace.” ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:19.1":{"pli":"“Tameva vācaṁ bhāseyya, ","eng":"“Speak only such words ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:19.2":{"pli":"yāyattānaṁ na tāpaye; ","eng":"that do not hurt yourself ","html":"<span class='verse-line'>{}</span>"},"thag21.1:19.3":{"pli":"Pare ca na vihiṁseyya, ","eng":"nor harm others; ","html":"<span class='verse-line'>{}</span>"},"thag21.1:19.4":{"pli":"sā ve vācā subhāsitā. ","eng":"such speech is truly well spoken. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:20.1":{"pli":"Piyavācameva bhāseyya, ","eng":"Speak only pleasing words, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:20.2":{"pli":"yā vācā paṭinanditā; ","eng":"words gladly welcomed. ","html":"<span class='verse-line'>{}</span>"},"thag21.1:20.3":{"pli":"Yaṁ anādāya pāpāni, ","eng":"Pleasing words are those ","html":"<span class='verse-line'>{}</span>"},"thag21.1:20.4":{"pli":"paresaṁ bhāsate piyaṁ. ","eng":"that bring nothing bad to others. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:21.1":{"pli":"Saccaṁ ve amatā vācā, ","eng":"Truth itself is undying speech: ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:21.2":{"pli":"esa dhammo sanantano; ","eng":"this is an ancient teaching. ","html":"<span class='verse-line'>{}</span>"},"thag21.1:21.3":{"pli":"Sacce atthe ca dhamme ca, ","eng":"Good people say that the teaching and meaning ","html":"<span class='verse-line'>{}</span>"},"thag21.1:21.4":{"pli":"āhu santo patiṭṭhitā. ","eng":"are grounded in truth. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:22.1":{"pli":"Yaṁ buddho bhāsati vācaṁ, ","eng":"The words spoken by the Buddha ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:22.2":{"pli":"khemaṁ nibbānapattiyā; ","eng":"for finding the sanctuary, extinguishment, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:22.3":{"pli":"Dukkhassantakiriyāya, ","eng":"for making an end of suffering: ","html":"<span class='verse-line'>{}</span>"},"thag21.1:22.4":{"pli":"sā ve vācānamuttamā”. ","eng":"this really is the best kind of speech.” ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:23.1":{"pli":"“Gambhīrapañño medhāvī, ","eng":"“Deep in wisdom, intelligent, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:23.2":{"pli":"maggāmaggassa kovido; ","eng":"expert in the path and what is not the path; ","html":"<span class='verse-line'>{}</span>"},"thag21.1:23.3":{"pli":"Sāriputto mahāpañño, ","eng":"Sāriputta, so greatly wise, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:23.4":{"pli":"dhammaṁ deseti bhikkhunaṁ. ","eng":"teaches Dhamma to the mendicants. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:24.1":{"pli":"Saṅkhittenapi deseti, ","eng":"He teaches in brief, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:24.2":{"pli":"vitthārenapi bhāsati; ","eng":"or he speaks at length. ","html":"<span class='verse-line'>{}</span>"},"thag21.1:24.3":{"pli":"Sālikāyiva nigghoso, ","eng":"His call, like a myna bird, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:24.4":{"pli":"paṭibhānaṁ udiyyati. ","eng":"overflows with inspiration. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:25.1":{"pli":"Tassa taṁ desayantassa, ","eng":"While he teaches ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:25.2":{"pli":"suṇanti madhuraṁ giraṁ; ","eng":"the mendicants listen to his sweet voice, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:25.3":{"pli":"Sarena rajanīyena, ","eng":"sounding attractive, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:25.4":{"pli":"savanīyena vaggunā; ","eng":"clear and graceful. ","html":"<span class='verse-line'>{}</span>"},"thag21.1:25.5":{"pli":"Udaggacittā muditā, ","eng":"They listen joyfully, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:25.6":{"pli":"sotaṁ odhenti bhikkhavo”. ","eng":"their hearts elated.” ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:26.1":{"pli":"“Ajja pannarase visuddhiyā, ","eng":"“Today, on the fifteenth day sabbath, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:26.2":{"pli":"Bhikkhū pañcasatā samāgatā; ","eng":"five hundred monks have gathered together <j>to purify their precepts. ","html":"<span class='verse-line'>{}</span>"},"thag21.1:26.3":{"pli":"Saṁyojanabandhanacchidā, ","eng":"These untroubled sages <j>have cut off their fetters and bonds, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:26.4":{"pli":"Anīghā khīṇapunabbhavā isī. ","eng":"they will not be reborn again. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:27.1":{"pli":"Cakkavattī yathā rājā, ","eng":"Just as a wheel-rolling monarch ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:27.2":{"pli":"amaccaparivārito; ","eng":"surrounded by ministers ","html":"<span class='verse-line'>{}</span>"},"thag21.1:27.3":{"pli":"Samantā anupariyeti, ","eng":"travels all around this ","html":"<span class='verse-line'>{}</span>"},"thag21.1:27.4":{"pli":"sāgarantaṁ mahiṁ imaṁ. ","eng":"land that’s girt by sea. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:28.1":{"pli":"Evaṁ vijitasaṅgāmaṁ, ","eng":"So disciples with the three knowledges, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:28.2":{"pli":"satthavāhaṁ anuttaraṁ; ","eng":"conquerors of death, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:28.3":{"pli":"Sāvakā payirupāsanti, ","eng":"revere the winner of the battle, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:28.4":{"pli":"tevijjā maccuhāyino. ","eng":"the unsurpassed caravan leader. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:29.1":{"pli":"Sabbe bhagavato puttā, ","eng":"All are sons of the Blessed One—","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:29.2":{"pli":"palāpettha na vijjati; ","eng":"there is no rubbish here. ","html":"<span class='verse-line'>{}</span>"},"thag21.1:29.3":{"pli":"Taṇhāsallassa hantāraṁ, ","eng":"I bow to the Kinsman of the Sun, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:29.4":{"pli":"vande ādiccabandhunaṁ. ","eng":"destroyer of the dart of craving.” ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:30.1":{"pli":"Parosahassaṁ bhikkhūnaṁ, ","eng":"“Over a thousand mendicants ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:30.2":{"pli":"sugataṁ payirupāsati; ","eng":"revere the Holy One ","html":"<span class='verse-line'>{}</span>"},"thag21.1:30.3":{"pli":"Desentaṁ virajaṁ dhammaṁ, ","eng":"as he teaches the immaculate Dhamma, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:30.4":{"pli":"nibbānaṁ akutobhayaṁ. ","eng":"extinguishment, fearing nothing from any quarter. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:31.1":{"pli":"Suṇanti dhammaṁ vimalaṁ, ","eng":"They listen to the immaculate Dhamma ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:31.2":{"pli":"sammāsambuddhadesitaṁ; ","eng":"taught by the fully awakened Buddha; ","html":"<span class='verse-line'>{}</span>"},"thag21.1:31.3":{"pli":"Sobhati vata sambuddho, ","eng":"the Buddha is so brilliant, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:31.4":{"pli":"bhikkhusaṅghapurakkhato. ","eng":"at the fore of the mendicant Saṅgha. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:32.1":{"pli":"‘Nāganāmo’si bhagavā, ","eng":"Blessed One, your name is ‘Giant’, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:32.2":{"pli":"isīnaṁ isisattamo; ","eng":"seventh of the seers. ","html":"<span class='verse-line'>{}</span>","comm":"The idea of the seven seers, long proverbial in Vedic culture, was adapted for Gotama in <a href='index.html?q=dn14'>DN 14</a>, where he is the seventh recorded Buddha in the lineage starting with Vipassī. Various texts and commentaries also allow the sense, “best of seers”. "},"thag21.1:32.3":{"pli":"Mahāmeghova hutvāna, ","eng":"You are like a great cloud ","html":"<span class='verse-line'>{}</span>"},"thag21.1:32.4":{"pli":"sāvake abhivassasi. ","eng":"that rains on your disciples. ","html":"<span class='verse-line'>{}</span></p>","comm":"In a cold northern climate this sounds unappealing, but in the heat the generous rain is a cool blessing. "},"thag21.1:33.1":{"pli":"Divā vihārā nikkhamma, ","eng":"I’ve left my day’s meditation, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:33.2":{"pli":"satthudassanakamyatā; ","eng":"out of desire to see the teacher. ","html":"<span class='verse-line'>{}</span>"},"thag21.1:33.3":{"pli":"Sāvako te mahāvīra, ","eng":"Great hero, your disciple Vaṅgīsa ","html":"<span class='verse-line'>{}</span>"},"thag21.1:33.4":{"pli":"pāde vandati vaṅgiso”. ","eng":"bows at your feet.” ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:34.1":{"pli":"“Ummaggapathaṁ mārassa, ","eng":"“Having overcome Māra’s wrong path, ","html":"<p><span class='verse-line'>{}</span>","comm":"The “wrong path” (<i lang='pi' translate='no'>ummagga</i>) is one that takes you to the wrong destination (<a href='index.html?q=mn107#14.26'>MN 107:14.26</a>). "},"thag21.1:34.2":{"pli":"Abhibhuyya carati pabhijja khīlāni; ","eng":"you wander with hard-heartedness dissolved. ","html":"<span class='verse-line'>{}</span>","comm":"<a href='index.html?q=sn8.8#8.2'>SN 8.8:8.2</a> has the second person <i lang='pi' translate='no'>carasi</i>, and it seems reasonable to assume that Vaṅgīsa is continuing to address the Buddha directly. | From the same place accept the reading <i lang='pi' translate='no'>khila</i> rather than <i lang='pi' translate='no'>khīla</i>. "},"thag21.1:34.3":{"pli":"Taṁ passatha bandhapamuñcakaraṁ, ","eng":"See him, the liberator from bonds, ","html":"<span class='verse-line'>{}</span>","comm":"Here Vaṅgīsa turns to address the monks directly. "},"thag21.1:34.4":{"pli":"Asitaṁva bhāgaso pavibhajja. ","eng":"dissecting the unattached section by section. ","html":"<span class='verse-line'>{}</span></p>","comm":"For <i lang='pi' translate='no'>asitaṁ bhāgaso pavibhajaṁ</i>, compare the similar phrase <i lang='pi' translate='no'>vibhatto bhāgaso mito</i>, which refers to the neatly ordered sections of hell (<a href='index.html?q=mn130#16.4'>MN 130:16.4</a>) or the suburbs (<a href='index.html?q=snp2.7#23.2'>Snp 2.7:23.2</a>). Vaṅgīsa is referring to the Buddha’s skill in breaking down complex or obscure matters and presenting them systematically. "},"thag21.1:35.1":{"pli":"Oghassa hi nitaraṇatthaṁ, ","eng":"You have explained in many ways ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:35.2":{"pli":"Anekavihitaṁ maggaṁ akkhāsi; ","eng":"the path to cross the flood. ","html":"<span class='verse-line'>{}</span>"},"thag21.1:35.3":{"pli":"Tasmiñca amate akkhāte, ","eng":"The Seers of Truth stand unfaltering ","html":"<span class='verse-line'>{}</span>","comm":"These lines follow Bodhi’s reading at <a href='index.html?q=sn8.8#9.3'>SN 8.8:9.3</a>. "},"thag21.1:35.4":{"pli":"Dhammadasā ṭhitā asaṁhīrā. ","eng":"in the freedom from death you’ve explained. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:36.1":{"pli":"Pajjotakaro ativijjha, ","eng":"As the bringer of light who has pierced the truth, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:36.2":{"pli":"Sabbaṭhitīnaṁ atikkamamaddasa; ","eng":"you’ve seen what lies beyond all planes. ","html":"<span class='verse-line'>{}</span>","comm":"<i lang='pi' translate='no'>Ṭhiti</i> is <i lang='pi' translate='no'>viññāṇaṭṭhiti</i> (“planes of consciousness”), i.e. seven realms in which consciousness can be reborn (<a href='index.html?q=an7.44'>AN 7.44</a>, <a href='index.html?q=dn15#33.1'>DN 15:33.1</a>, <a href='index.html?q=dn33#1.8.11'>DN 33:1.8.11</a>). This is a subtle allusion to the Buddha’s practice under his former teacher Āḷāra Kālāma, where he learned up to the highest “plane of consciousness”, namely the dimension of nothingness. In <a href='index.html?q=snp5.15#3.1'>Snp 5.15:3.1</a> he speaks of how he understood that attainment and went beyond it. | Not to be confused with the four “grounds for consciousness”, i.e. the first four aggregates, as insight does <em>not</em> consist in going beyond these to consciousness (<a href='index.html?q=dn33#1.11.122'>DN 33:1.11.122</a>, <a href='index.html?q=sn22.54#1.11'>SN 22.54:1.11</a>). "},"thag21.1:36.3":{"pli":"Ñatvā ca sacchikatvā ca, ","eng":"When you saw and realized this for yourself, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:36.4":{"pli":"Aggaṁ so desayi dasaddhānaṁ. ","eng":"you taught it first to the group of five. ","html":"<span class='verse-line'>{}</span></p>","comm":"Vaṅgīsa continues to invoke the Buddha’s life story by alluding to the first teaching, Rolling Forth the Wheel of Dhamma (<a href='index.html?q=sn56.11'>SN 56.11</a>). After leaving behind those who taught rebirth in the “planes of consciousness”, the Buddha realized Awakening and proceeded to Varanasi to teach the group of five. This anticipates the next verses, which feature one of the five. "},"thag21.1:37.1":{"pli":"Evaṁ sudesite dhamme, ","eng":"When the Dhamma has been so well taught, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:37.2":{"pli":"Ko pamādo vijānataṁ dhammaṁ; ","eng":"how could those who know it be negligent? ","html":"<span class='verse-line'>{}</span>"},"thag21.1:37.3":{"pli":"Tasmā hi tassa bhagavato sāsane, ","eng":"That’s why, being diligent, we should always train ","html":"<span class='verse-line'>{}</span>"},"thag21.1:37.4":{"pli":"Appamatto sadā namassamanusikkhe”. ","eng":"respectfully in the Buddha’s teaching.” ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:38.1":{"pli":"“Buddhānubuddho yo thero, ","eng":"“The senior monk  awakened after the Buddha, ","html":"<p><span class='verse-line'>{}</span>","comm":"Spoken at <a href='index.html?q=sn8.9#3.1'>SN 8.9:3.1</a>, while the first two lines are included in Koṇḍañña’s verses at <a href='index.html?q=thag21.1#38.1'>Thag 21.1:38.1</a>. "},"thag21.1:38.2":{"pli":"koṇḍañño tibbanikkamo; ","eng":"Koṇḍañña, is keenly energetic. ","html":"<span class='verse-line'>{}</span>","comm":"Koṇḍañña was the first person to realize the Dhamma after the Buddha (<a href='index.html?q=sn56.11#14.3'>SN 56.11:14.3</a>). He features rarely in the early texts, but the Buddha once saw him meditating (<a href='index.html?q=ud7.6'>Ud 7.6</a>), and praised him as the senior mendicant (<a href='index.html?q=an1.188#1.1'>AN 1.188:1.1</a>). "},"thag21.1:38.3":{"pli":"Lābhī sukhavihārānaṁ, ","eng":"He regularly gains ","html":"<span class='verse-line'>{}</span>"},"thag21.1:38.4":{"pli":"vivekānaṁ abhiṇhaso. ","eng":"the blissful meditations of seclusion. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:39.1":{"pli":"Yaṁ sāvakena pattabbaṁ, ","eng":"Whatever can be attained by a disciple ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:39.2":{"pli":"satthu sāsanakārinā; ","eng":"who does the Teacher’s bidding, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:39.3":{"pli":"Sabbassa taṁ anuppattaṁ, ","eng":"he has attained it all, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:39.4":{"pli":"appamattassa sikkhato. ","eng":"through diligently training himself. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:40.1":{"pli":"Mahānubhāvo tevijjo, ","eng":"With great power and the three knowledges, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:40.2":{"pli":"cetopariyakovido; ","eng":"expert in encompassing the minds of others, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:40.3":{"pli":"Koṇḍañño buddhadāyādo, ","eng":"Koṇḍañña, the heir to the Buddha, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:40.4":{"pli":"pāde vandati satthuno”. ","eng":"bows at the Teacher’s feet.” ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:41.1":{"pli":"“Nagassa passe āsīnaṁ, ","eng":"“As the sage, who has gone beyond suffering, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:41.2":{"pli":"muniṁ dukkhassa pāraguṁ; ","eng":"sits upon the mountain slope, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:41.3":{"pli":"Sāvakā payirupāsanti, ","eng":"he is revered by disciples with the three knowledges, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:41.4":{"pli":"tevijjā maccuhāyino. ","eng":"conquerors of death. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:42.1":{"pli":"Cetasā anupariyeti, ","eng":"Moggallāna, of great psychic power, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:42.2":{"pli":"moggallāno mahiddhiko; ","eng":"encompasses with his mind, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:42.3":{"pli":"Cittaṁ nesaṁ samanvesaṁ, ","eng":"scrutinizing their minds, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:42.4":{"pli":"vippamuttaṁ nirūpadhiṁ. ","eng":"liberated, free of attachments. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:43.1":{"pli":"Evaṁ sabbaṅgasampannaṁ, ","eng":"That is how those endowed <j>with many fine qualities ","html":"<p><span class='verse-line'>{}</span>","comm":"Emend <i lang='pi' translate='no'>anekākārasampannaṁ</i> to <i lang='pi' translate='no'>anekākārasampannā</i> per Bodhi’s <em>Connected Discourses</em>, note 527. "},"thag21.1:43.2":{"pli":"muniṁ dukkhassa pāraguṁ; ","eng":"revere Gotama, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:43.3":{"pli":"Anekākārasampannaṁ, ","eng":"the sage gone beyond suffering, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:43.4":{"pli":"payirupāsanti gotamaṁ”. ","eng":"perfect in every respect.” ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:44.1":{"pli":"“Cando yathā vigatavalāhake nabhe, ","eng":"“Like the moon on a cloudless night, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:44.2":{"pli":"Virocati vītamalova bhāṇumā; ","eng":"like the shining immaculate sun, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:44.3":{"pli":"Evampi aṅgīrasa tvaṁ mahāmuni, ","eng":"so too Aṅgīrasa, O great sage, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:44.4":{"pli":"Atirocasi yasasā sabbalokaṁ”. ","eng":"your glory outshines the entire world.” ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:45.1":{"pli":"“Kāveyyamattā vicarimha pubbe, ","eng":"“We used to wander, drunk on poetry, ","html":"<p><span class='verse-line'>{}</span>","comm":"This verse is plural, presumably referring to a troupe of wandering bards. | For “drunk on poetry” see <a href='index.html?q=sn4.13#2.1'>SN 4.13:2.1</a> and note. "},"thag21.1:45.2":{"pli":"Gāmā gāmaṁ purā puraṁ; ","eng":"from village to village, town to town. ","html":"<span class='verse-line'>{}</span>"},"thag21.1:45.3":{"pli":"Athaddasāma sambuddhaṁ, ","eng":"Then we saw the Buddha, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:45.4":{"pli":"Sabbadhammāna pāraguṁ. ","eng":"who has gone beyond all things. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:46.1":{"pli":"So me dhammamadesesi, ","eng":"He, the sage gone beyond suffering, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:46.2":{"pli":"muni dukkhassa pāragū; ","eng":"taught me the Dhamma. ","html":"<span class='verse-line'>{}</span>"},"thag21.1:46.3":{"pli":"Dhammaṁ sutvā pasīdimha, ","eng":"When we heard the Dhamma, <j>we became confident—","html":"<span class='verse-line'>{}</span>"},"thag21.1:46.4":{"pli":"saddhā no udapajjatha. ","eng":"faith arose in us. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:47.1":{"pli":"Tassāhaṁ vacanaṁ sutvā, ","eng":"Hearing him speak of ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:47.2":{"pli":"khandhe āyatanāni ca; ","eng":"the aggregates, the sense-fields, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:47.3":{"pli":"Dhātuyo ca viditvāna, ","eng":"and the elements, I understood; ","html":"<span class='verse-line'>{}</span>"},"thag21.1:47.4":{"pli":"pabbajiṁ anagāriyaṁ. ","eng":"and then I went forth to homelessness. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:48.1":{"pli":"Bahūnaṁ vata atthāya, ","eng":"It is for the benefit of many ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:48.2":{"pli":"uppajjanti tathāgatā; ","eng":"that the Realized Ones arise—","html":"<span class='verse-line'>{}</span>"},"thag21.1:48.3":{"pli":"Itthīnaṁ purisānañca, ","eng":"the men and women ","html":"<span class='verse-line'>{}</span>"},"thag21.1:48.4":{"pli":"ye te sāsanakārakā. ","eng":"who follow his instructions. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:49.1":{"pli":"Tesaṁ kho vata atthāya, ","eng":"It is truly for their benefit ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:49.2":{"pli":"bodhimajjhagamā muni; ","eng":"that the sage realized awakening—","html":"<span class='verse-line'>{}</span>"},"thag21.1:49.3":{"pli":"Bhikkhūnaṁ bhikkhunīnañca, ","eng":"for the monks and for the nuns ","html":"<span class='verse-line'>{}</span>"},"thag21.1:49.4":{"pli":"ye nirāmagataddasā. ","eng":"who see that they’ve reached certainty. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:50.1":{"pli":"Sudesitā cakkhumatā, ","eng":"The Clear-eyed One, the Buddha, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:50.2":{"pli":"buddhenādiccabandhunā; ","eng":"the Kinsman of the Sun, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:50.3":{"pli":"Cattāri ariyasaccāni, ","eng":"has well taught the four noble truths ","html":"<span class='verse-line'>{}</span>"},"thag21.1:50.4":{"pli":"anukampāya pāṇinaṁ. ","eng":"out of sympathy for living creatures. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:51.1":{"pli":"Dukkhaṁ dukkhasamuppādaṁ, ","eng":"Suffering, suffering’s origin, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:51.2":{"pli":"Dukkhassa ca atikkamaṁ; ","eng":"suffering’s transcendence, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:51.3":{"pli":"Ariyaṁ caṭṭhaṅgikaṁ maggaṁ, ","eng":"and the noble eightfold path ","html":"<span class='verse-line'>{}</span>"},"thag21.1:51.4":{"pli":"Dukkhūpasamagāminaṁ. ","eng":"that leads to the stilling of suffering. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:52.1":{"pli":"Evamete tathā vuttā, ","eng":"As these things were taught, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:52.2":{"pli":"diṭṭhā me te yathā tathā; ","eng":"so I have seen them. ","html":"<span class='verse-line'>{}</span>"},"thag21.1:52.3":{"pli":"Sadattho me anuppatto, ","eng":"I’ve realized my heart’s goal, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:52.4":{"pli":"kataṁ buddhassa sāsanaṁ. ","eng":"and fulfilled the Buddha’s instructions. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:53.1":{"pli":"Svāgataṁ vata me āsi, ","eng":"It was so welcome for me ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:53.2":{"pli":"mama buddhassa santike; ","eng":"to be in the presence of the Buddha. ","html":"<span class='verse-line'>{}</span>"},"thag21.1:53.3":{"pli":"Suvibhattesu dhammesu, ","eng":"Of the well-explained teachings, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:53.4":{"pli":"yaṁ seṭṭhaṁ tadupāgamiṁ. ","eng":"I arrived at the best. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:54.1":{"pli":"Abhiññāpāramippatto, ","eng":"I’ve realized the perfection of direct knowledge; ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:54.2":{"pli":"sotadhātu visodhitā; ","eng":"my clairaudience is purified; ","html":"<span class='verse-line'>{}</span>"},"thag21.1:54.3":{"pli":"Tevijjo iddhipattomhi, ","eng":"I am master of three knowledges, <j>attained in psychic power, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:54.4":{"pli":"cetopariyakovido”. ","eng":"I’m expert at reading the minds of others.” ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:55.1":{"pli":"“Pucchāmi satthāramanomapaññaṁ, ","eng":"“I ask the teacher unrivaled in wisdom, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:55.2":{"pli":"Diṭṭheva dhamme yo vicikicchānaṁ chettā; ","eng":"who has cut off all doubts in this very life: ","html":"<span class='verse-line'>{}</span>"},"thag21.1:55.3":{"pli":"Aggāḷave kālamakāsi bhikkhu, ","eng":"a monk has died at Āḷavī’s premier shrine, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:55.4":{"pli":"Ñāto yasassī abhinibbutatto. ","eng":"who was well-known, famous, and quenched. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:56.1":{"pli":"Nigrodhakappo iti tassa nāmaṁ, ","eng":"Nigrodhakappa was his name; ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:56.2":{"pli":"Tayā kataṁ bhagavā brāhmaṇassa; ","eng":"it was given to that brahmin by you, Blessed One. ","html":"<span class='verse-line'>{}</span>"},"thag21.1:56.3":{"pli":"So taṁ namassaṁ acari mutyapekho, ","eng":"He wandered in your honor, yearning for freedom, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:56.4":{"pli":"Āraddhavīriyo daḷhadhammadassī. ","eng":"energetic, a resolute Seer of Truth. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:57.1":{"pli":"Taṁ sāvakaṁ sakka mayampi sabbe, ","eng":"O Sakyan, All-seer, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:57.2":{"pli":"Aññātumicchāma samantacakkhu; ","eng":"we all wish to know about that disciple. ","html":"<span class='verse-line'>{}</span>"},"thag21.1:57.3":{"pli":"Samavaṭṭhitā no savanāya sotā, ","eng":"Our ears are eager to hear, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:57.4":{"pli":"Tuvaṁ no satthā tvamanuttarosi. ","eng":"for you are the most excellent teacher. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:58.1":{"pli":"Chinda no vicikicchaṁ brūhi metaṁ, ","eng":"Cut off our doubt, declare this to us; ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:58.2":{"pli":"Parinibbutaṁ vedaya bhūripañña; ","eng":"your wisdom is vast, tell us of his quenching! ","html":"<span class='verse-line'>{}</span>"},"thag21.1:58.3":{"pli":"Majjheva no bhāsa samantacakkhu, ","eng":"All-seer, speak among us, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:58.4":{"pli":"Sakkova devāna sahassanetto. ","eng":"like the thousand-eyed Sakka <j>in the midst of the gods! ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:59.1":{"pli":"Ye keci ganthā idha mohamaggā, ","eng":"Whatever ties there are, or paths to delusion, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:59.2":{"pli":"Aññāṇapakkhā vicikicchaṭhānā; ","eng":"or things on the side of unknowing, <j>or that are bases of doubt ","html":"<span class='verse-line'>{}</span>"},"thag21.1:59.3":{"pli":"Tathāgataṁ patvā na te bhavanti, ","eng":"vanish on reaching a Realized One, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:59.4":{"pli":"Cakkhuñhi etaṁ paramaṁ narānaṁ. ","eng":"for his eye is the best of all people’s. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:60.1":{"pli":"No ce hi jātu puriso kilese, ","eng":"If no man were ever to disperse corruptions, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:60.2":{"pli":"Vāto yathā abbhaghanaṁ vihāne; ","eng":"like the wind dispersing the stormclouds, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:60.3":{"pli":"Tamovassa nivuto sabbaloko, ","eng":"darkness would veil the whole world; ","html":"<span class='verse-line'>{}</span>"},"thag21.1:60.4":{"pli":"Jotimantopi na pabhāseyyuṁ. ","eng":"not even brilliant men would shine. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:61.1":{"pli":"Dhīrā ca pajjotakarā bhavanti, ","eng":"The attentive are bringers of light; ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:61.2":{"pli":"Taṁ taṁ ahaṁ vīra tatheva maññe; ","eng":"my hero, that is what I think of you. ","html":"<span class='verse-line'>{}</span>"},"thag21.1:61.3":{"pli":"Vipassinaṁ jānamupāgamimha, ","eng":"We’ve come for your discernment and knowledge: ","html":"<span class='verse-line'>{}</span>"},"thag21.1:61.4":{"pli":"Parisāsu no āvikarohi kappaṁ. ","eng":"here in this assembly, declare to us about Kappāyana. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:62.1":{"pli":"Khippaṁ giraṁ eraya vaggu vagguṁ, ","eng":"Swiftly send forth your sweet, sweet voice, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:62.2":{"pli":"Haṁsova paggayha saṇikaṁ nikūja; ","eng":"like a goose stretching its neck, gently honking, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:62.3":{"pli":"Bindussarena suvikappitena, ","eng":"lucid-flowing, with lovely tone: ","html":"<span class='verse-line'>{}</span>"},"thag21.1:62.4":{"pli":"Sabbeva te ujjugatā suṇoma. ","eng":"alert, we all listen to you. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:63.1":{"pli":"Pahīnajātimaraṇaṁ asesaṁ, ","eng":"You have entirely abandoned birth and death; ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:63.2":{"pli":"Niggayha dhonaṁ vadessāmi dhammaṁ; ","eng":"restrained and pure, speak the Dhamma! ","html":"<span class='verse-line'>{}</span>"},"thag21.1:63.3":{"pli":"Na kāmakāro hi puthujjanānaṁ, ","eng":"For ordinary people <j>have no wish-granter, ","html":"<span class='verse-line'>{}</span>","comm":"<i lang='pi' translate='no'>Kāmakāro</i>: “wish-granter”. Ordinary people cannot simply get what they want. "},"thag21.1:63.4":{"pli":"Saṅkheyyakāro ca tathāgatānaṁ. ","eng":"but Realized Ones <j>have a comprehensibility-granter. ","html":"<span class='verse-line'>{}</span></p>","comm":"<i lang='pi' translate='no'>Saṅkheyyakāro</i>: “comprehensibility-granter”. <i lang='pi' translate='no'>Saṅkheyya</i> is “calculable, comprehensible”, not “after comprehension”. The Buddha has a gift for explaining things in a way that makes them comprehensible. "},"thag21.1:64.1":{"pli":"Sampannaveyyākaraṇaṁ tavedaṁ, ","eng":"Your answer is definitive, and we will adopt it, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:64.2":{"pli":"Samujjupaññassa samuggahītaṁ; ","eng":"for you have perfect understanding. ","html":"<span class='verse-line'>{}</span>"},"thag21.1:64.3":{"pli":"Ayamañjali pacchimo suppaṇāmito, ","eng":"We raise our joined palms one last time, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:64.4":{"pli":"Mā mohayī jānamanomapañña. ","eng":"one of unrivaled wisdom, <j>don’t deliberately confuse us. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:65.1":{"pli":"Paroparaṁ ariyadhammaṁ viditvā, ","eng":"Knowing the teaching of the noble ones <j>from top to bottom, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:65.2":{"pli":"Mā mohayī jānamanomavīriya; ","eng":"one of unrivaled energy, <j>don’t deliberately confuse us. ","html":"<span class='verse-line'>{}</span>"},"thag21.1:65.3":{"pli":"Vāriṁ yathā ghammani ghammatatto, ","eng":"Like a man in the baking summer sun <j>would long for water, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:65.4":{"pli":"Vācābhikaṅkhāmi sutaṁ pavassa. ","eng":"I long for your voice, so let the sound rain forth. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:66.1":{"pli":"Yadatthikaṁ brahmacariyaṁ acarī, ","eng":"Surely Kappāyana did not <j>lead the spiritual life in vain? ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:66.2":{"pli":"Kappāyano kaccissataṁ amoghaṁ; ","eng":"Did he realize quenching, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:66.3":{"pli":"Nibbāyi so ādu saupādiseso, ","eng":"or did he still have a residue? ","html":"<span class='verse-line'>{}</span>"},"thag21.1:66.4":{"pli":"Yathā vimutto ahu taṁ suṇoma”. ","eng":"Let us hear what kind of liberation he had!” ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:67.1":{"pli":"“Acchecchi taṇhaṁ idha nāmarūpe, ","eng":"“He cut off craving for name and form right here,” ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:67.2":{"pli":"(iti bhagavā) ","eng":"said the Buddha, ","html":"<span class='speaker'>{}</span>"},"thag21.1:67.3":{"pli":"Kaṇhassa sotaṁ dīgharattānusayitaṁ; ","eng":"“the river of darkness that had long lain within him. ","html":"<span class='verse-line'>{}</span>"},"thag21.1:67.4":{"pli":"Atāri jātiṁ maraṇaṁ asesaṁ, ","eng":"He has entirely crossed over birth and death.” ","html":"<span class='verse-line'>{}</span>"},"thag21.1:67.5":{"pli":"Iccabravi bhagavā pañcaseṭṭho”. ","eng":"So declared the Blessed One, the leader of the five. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:68.1":{"pli":"“Esa sutvā pasīdāmi, ","eng":"“Now that I have heard your words, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:68.2":{"pli":"vaco te isisattama; ","eng":"seventh of seers, I am confident. ","html":"<span class='verse-line'>{}</span>"},"thag21.1:68.3":{"pli":"Amoghaṁ kira me puṭṭhaṁ, ","eng":"My question, it seems, was not in vain, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:68.4":{"pli":"na maṁ vañcesi brāhmaṇo. ","eng":"the brahmin did not deceive me. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:69.1":{"pli":"Yathā vādī tathā kārī, ","eng":"As he spoke, so he acted; ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:69.2":{"pli":"ahu buddhassa sāvako; ","eng":"he was a disciple of the Buddha. ","html":"<span class='verse-line'>{}</span>"},"thag21.1:69.3":{"pli":"Acchecchi maccuno jālaṁ, ","eng":"He cut the net of death the deceiver, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:69.4":{"pli":"tataṁ māyāvino daḷhaṁ. ","eng":"so extended and strong. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:70.1":{"pli":"Addasa bhagavā ādiṁ, ","eng":"Blessed One, Kappāyana saw ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:70.2":{"pli":"upādānassa kappiyo; ","eng":"the starting point of grasping. ","html":"<span class='verse-line'>{}</span>"},"thag21.1:70.3":{"pli":"Accagā vata kappāno, ","eng":"He has indeed gone far beyond ","html":"<span class='verse-line'>{}</span>"},"thag21.1:70.4":{"pli":"maccudheyyaṁ suduttaraṁ. ","eng":"Death’s dominion so hard to pass. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:71.1":{"pli":"Taṁ devadevaṁ vandāmi, ","eng":"God of gods, best of men, I bow to you, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:71.2":{"pli":"puttaṁ te dvipaduttama; ","eng":"and to your son, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:71.3":{"pli":"Anujātaṁ mahāvīraṁ, ","eng":"who followed your example, a great hero; ","html":"<span class='verse-line'>{}</span>"},"thag21.1:71.4":{"pli":"nāgaṁ nāgassa orasan”ti. ","eng":"a giant, true-born son of a giant.” ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"thag21.1:71.5":{"pli":"Itthaṁ sudaṁ āyasmā vaṅgīso thero gāthāyo abhāsitthāti. ","eng":"That is how these verses were recited by the senior venerable Vaṅgīsa. ","html":"<p class='endsutta'>{}</p>"},"thag21.1:71.6":{"pli":"Mahānipāto niṭṭhito. ","eng":"The Great Book is Finished ","html":"<p class='endbook'>{}</p>"},"thag21.1:72.0":{"pli":"Tatruddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"thag21.1:72.1":{"pli":"Sattatimhi nipātamhi, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"thag21.1:72.2":{"pli":"vaṅgīso paṭibhāṇavā; ","html":"<span class='verse-line'>{}</span>"},"thag21.1:72.3":{"pli":"Ekova thero natthañño, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:72.4":{"pli":"gāthāyo ekasattatīti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"thag21.1:72.5":{"pli":"Niṭṭhitā theragāthāyo. ","html":"<p class='endsutta'>{}</p>"},"thag21.1:73.0":{"pli":"Tatruddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"thag21.1:73.1":{"pli":"Sahassaṁ honti tā gāthā, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"thag21.1:73.2":{"pli":"tīṇi saṭṭhisatāni ca; ","html":"<span class='verse-line'>{}</span>"},"thag21.1:73.3":{"pli":"Therā ca dve satā saṭṭhi, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:73.4":{"pli":"cattāro ca pakāsitā. ","html":"<span class='verse-line'>{}</span></p>"},"thag21.1:74.1":{"pli":"Sīhanādaṁ naditvāna, ","html":"<p><span class='verse-line'>{}</span>"},"thag21.1:74.2":{"pli":"buddhaputtā anāsavā; ","html":"<span class='verse-line'>{}</span>"},"thag21.1:74.3":{"pli":"Khemantaṁ pāpuṇitvāna, ","html":"<span class='verse-line'>{}</span>"},"thag21.1:74.4":{"pli":"aggikhandhāva nibbutāti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"thag21.1:74.5":{"pli":"Theragāthāpāḷi niṭṭhitā. ","eng":"The Verses of the Senior Monks are finished. ","html":"<p class='endbook''>{}</p></article>"}}}