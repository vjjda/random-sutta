{"pv37":{"pv37:0.1":{"pli":"Petavatthu ","html":"<article id='pv37'><header><ul><li class='division'>{}</li>"},"pv37:0.2":{"pli":"Mahāvagga ","html":"<li>{}</li></ul>"},"pv37:0.3":{"pli":"2. Serīsakapetavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv37:1.1":{"pli":"“Suṇotha yakkhassa vāṇijāna ca, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv37:1.2":{"pli":"Samāgamo yattha tadā ahosi; ","html":"<span class='verse-line'>{}</span>"},"pv37:1.3":{"pli":"Yathā kathaṁ itaritarena cāpi, ","html":"<span class='verse-line'>{}</span>"},"pv37:1.4":{"pli":"Subhāsitaṁ tañca suṇātha sabbe. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:2.1":{"pli":"Yo so ahu rājā pāyāsi nāma, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:2.2":{"pli":"Bhummānaṁ sahabyagato yasassī; ","html":"<span class='verse-line'>{}</span>"},"pv37:2.3":{"pli":"So modamānova sake vimāne, ","html":"<span class='verse-line'>{}</span>"},"pv37:2.4":{"pli":"Amānuso mānuse ajjhabhāsī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:3.1":{"pli":"“Vaṅke araññe amanussaṭṭhāne, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:3.2":{"pli":"Kantāre appodake appabhakkhe; ","html":"<span class='verse-line'>{}</span>"},"pv37:3.3":{"pli":"Suduggame vaṇṇupathassa majjhe, ","html":"<span class='verse-line'>{}</span>"},"pv37:3.4":{"pli":"Vaṅkambhayā naṭṭhamanā manussā. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:4.1":{"pli":"Nayidha phalā mūlamayā ca santi, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:4.2":{"pli":"Upādānaṁ natthi kutodha bhakkho; ","html":"<span class='verse-line'>{}</span>"},"pv37:4.3":{"pli":"Aññatra paṁsūhi ca vālukāhi ca, ","html":"<span class='verse-line'>{}</span>"},"pv37:4.4":{"pli":"Tatāhi uṇhāhi ca dāruṇāhi ca. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:5.1":{"pli":"Ujjaṅgalaṁ tattamivaṁ kapālaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:5.2":{"pli":"Anāyasaṁ paralokena tulyaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv37:5.3":{"pli":"Luddānamāvāsamidaṁ purāṇaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv37:5.4":{"pli":"Bhūmippadeso abhisattarūpo. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:6.1":{"pli":"Atha tumhe kena vaṇṇena, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:6.2":{"pli":"Kimāsamānā imaṁ padesaṁ hi; ","html":"<span class='verse-line'>{}</span>"},"pv37:6.3":{"pli":"Anupaviṭṭhā sahasā samacca, ","html":"<span class='verse-line'>{}</span>"},"pv37:6.4":{"pli":"Lobhā bhayā atha vā sampamūḷhā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:7.1":{"pli":"“Magadhesu aṅgesu ca satthavāhā, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:7.2":{"pli":"Āropayitvā paṇiyaṁ puthuttaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv37:7.3":{"pli":"Te yāmase sindhusovīrabhūmiṁ, ","html":"<span class='verse-line'>{}</span>"},"pv37:7.4":{"pli":"Dhanatthikā uddayaṁ patthayānā. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:8.1":{"pli":"Divā pipāsaṁ nadhivāsayantā, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:8.2":{"pli":"Yoggānukampañca samekkhamānā; ","html":"<span class='verse-line'>{}</span>"},"pv37:8.3":{"pli":"Etena vegena āyāma sabbe, ","html":"<span class='verse-line'>{}</span>"},"pv37:8.4":{"pli":"Rattiṁ maggaṁ paṭipannā vikāle. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:9.1":{"pli":"Te duppayātā aparaddhamaggā, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:9.2":{"pli":"Andhākulā vippanaṭṭhā araññe; ","html":"<span class='verse-line'>{}</span>"},"pv37:9.3":{"pli":"Suduggame vaṇṇupathassa majjhe, ","html":"<span class='verse-line'>{}</span>"},"pv37:9.4":{"pli":"Disaṁ na jānāma pamūḷhacittā. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:10.1":{"pli":"Idañca disvāna adiṭṭhapubbaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:10.2":{"pli":"Vimānaseṭṭhañca tavañca yakkha; ","html":"<span class='verse-line'>{}</span>"},"pv37:10.3":{"pli":"Tatuttariṁ jīvitamāsamānā, ","html":"<span class='verse-line'>{}</span>"},"pv37:10.4":{"pli":"Disvā patītā sumanā udaggā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:11.1":{"pli":"“Pāraṁ samuddassa imañca vaṇṇuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:11.2":{"pli":"Vettācaraṁ saṅkupathañca maggaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv37:11.3":{"pli":"Nadiyo pana pabbatānañca duggā, ","html":"<span class='verse-line'>{}</span>"},"pv37:11.4":{"pli":"Puthuddisā gacchatha bhogahetu. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:12.1":{"pli":"Pakkhandiyāna vijitaṁ paresaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:12.2":{"pli":"Verajjake mānuse pekkhamānā; ","html":"<span class='verse-line'>{}</span>"},"pv37:12.3":{"pli":"Yaṁ vo sutaṁ vā atha vāpi diṭṭhaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv37:12.4":{"pli":"Accherakaṁ taṁ vo suṇoma tātā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:13.1":{"pli":"“Itopi accherataraṁ kumāra, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:13.2":{"pli":"Na no sutaṁ vā atha vāpi diṭṭhaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv37:13.3":{"pli":"Atītamānussakameva sabbaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv37:13.4":{"pli":"Disvā na tappāma anomavaṇṇaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:14.1":{"pli":"Vehāyasaṁ pokkharañño savanti, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:14.2":{"pli":"Pahūtamalyā bahupuṇḍarīkā; ","html":"<span class='verse-line'>{}</span>"},"pv37:14.3":{"pli":"Dumā cime niccaphalūpapannā, ","html":"<span class='verse-line'>{}</span>"},"pv37:14.4":{"pli":"Atīva gandhā surabhiṁ pavāyanti. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:15.1":{"pli":"Veḷūriyathambhā satamussitāse, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:15.2":{"pli":"Silāpavāḷassa ca āyataṁsā; ","html":"<span class='verse-line'>{}</span>"},"pv37:15.3":{"pli":"Masāragallā sahalohitaṅgā, ","html":"<span class='verse-line'>{}</span>"},"pv37:15.4":{"pli":"Thambhā ime jotirasāmayāse. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:16.1":{"pli":"Sahassathambhaṁ atulānubhāvaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:16.2":{"pli":"Tesūpari sādhumidaṁ vimānaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv37:16.3":{"pli":"Ratanantaraṁ kañcanavedimissaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv37:16.4":{"pli":"Tapanīyapaṭṭehi ca sādhuchannaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:17.1":{"pli":"Jambonaduttattamidaṁ sumaṭṭho, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:17.2":{"pli":"Pāsādasopānaphalūpapanno; ","html":"<span class='verse-line'>{}</span>"},"pv37:17.3":{"pli":"Daḷho ca vaggu ca susaṅgato ca, ","html":"<span class='verse-line'>{}</span>"},"pv37:17.4":{"pli":"Atīva nijjhānakhamo manuñño. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:18.1":{"pli":"Ratanantarasmiṁ bahuannapānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:18.2":{"pli":"Parivārito accharāsaṅgaṇena; ","html":"<span class='verse-line'>{}</span>"},"pv37:18.3":{"pli":"Murajaālambaratūriyaghuṭṭho, ","html":"<span class='verse-line'>{}</span>"},"pv37:18.4":{"pli":"Abhivanditosi thutivandanāya. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:19.1":{"pli":"So modasi nārigaṇappabodhano, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:19.2":{"pli":"Vimānapāsādavare manorame; ","html":"<span class='verse-line'>{}</span>"},"pv37:19.3":{"pli":"Acintiyo sabbaguṇūpapanno, ","html":"<span class='verse-line'>{}</span>"},"pv37:19.4":{"pli":"Rājā yathā vessavaṇo naḷinyā. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:20.1":{"pli":"Devo nu āsi udavāsi yakkho, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:20.2":{"pli":"Udāhu devindo manussabhūto; ","html":"<span class='verse-line'>{}</span>"},"pv37:20.3":{"pli":"Pucchanti taṁ vāṇijā satthavāhā, ","html":"<span class='verse-line'>{}</span>"},"pv37:20.4":{"pli":"Ācikkha ko nāma tuvaṁsi yakkho”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:21.1":{"pli":"“Serīsako nāma ahamhi yakkho, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:21.2":{"pli":"Kantāriyo vaṇṇupathamhi gutto; ","html":"<span class='verse-line'>{}</span>"},"pv37:21.3":{"pli":"Imaṁ padesaṁ abhipālayāmi, ","html":"<span class='verse-line'>{}</span>"},"pv37:21.4":{"pli":"Vacanakaro vessavaṇassa rañño”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:22.1":{"pli":"“Adhiccaladdhaṁ pariṇāmajaṁ te, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:22.2":{"pli":"Sayaṅkataṁ udāhu devehi dinnaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv37:22.3":{"pli":"Pucchanti taṁ vāṇijā satthavāhā, ","html":"<span class='verse-line'>{}</span>"},"pv37:22.4":{"pli":"Kathaṁ tayā laddhamidaṁ manuññan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:23.1":{"pli":"“Nādhiccaladdhaṁ na pariṇāmajaṁ me, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:23.2":{"pli":"Na sayaṅkataṁ na hi devehi dinnaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv37:23.3":{"pli":"Sakehi kammehi apāpakehi, ","html":"<span class='verse-line'>{}</span>"},"pv37:23.4":{"pli":"Puññehi me laddhamidaṁ manuññan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:24.1":{"pli":"“Kiṁ te vataṁ kiṁ pana brahmacariyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:24.2":{"pli":"Kissa suciṇṇassa ayaṁ vipāko; ","html":"<span class='verse-line'>{}</span>"},"pv37:24.3":{"pli":"Pucchanti taṁ vāṇijā satthavāhā, ","html":"<span class='verse-line'>{}</span>"},"pv37:24.4":{"pli":"Kathaṁ tayā laddhamidaṁ vimānan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:25.1":{"pli":"“Mamaṁ pāyāsīti ahu samaññā, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:25.2":{"pli":"Rajjaṁ yadā kārayiṁ kosalānaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv37:25.3":{"pli":"Natthikadiṭṭhi kadariyo pāpadhammo, ","html":"<span class='verse-line'>{}</span>"},"pv37:25.4":{"pli":"Ucchedavādī ca tadā ahosiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:26.1":{"pli":"Samaṇo ca kho āsi kumārakassapo, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:26.2":{"pli":"Bahussuto cittakathī uḷāro; ","html":"<span class='verse-line'>{}</span>"},"pv37:26.3":{"pli":"So me tadā dhammakathaṁ abhāsi, ","html":"<span class='verse-line'>{}</span>"},"pv37:26.4":{"pli":"Diṭṭhivisūkāni vinodayī me. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:27.1":{"pli":"Tāhaṁ tassa dhammakathaṁ suṇitvā, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:27.2":{"pli":"Upāsakattaṁ paṭivedayissaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv37:27.3":{"pli":"Pāṇātipātā virato ahosiṁ, ","html":"<span class='verse-line'>{}</span>"},"pv37:27.4":{"pli":"Loke adinnaṁ parivajjayissaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv37:27.5":{"pli":"Amajjapo no ca musā abhāṇiṁ, ","html":"<span class='verse-line'>{}</span>"},"pv37:27.6":{"pli":"Sakena dārena ca ahosi tuṭṭho. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:28.1":{"pli":"Taṁ me vataṁ taṁ pana brahmacariyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:28.2":{"pli":"Tassa suciṇṇassa ayaṁ vipāko; ","html":"<span class='verse-line'>{}</span>"},"pv37:28.3":{"pli":"Teheva kammehi apāpakehi, ","html":"<span class='verse-line'>{}</span>"},"pv37:28.4":{"pli":"Puññehi me laddhamidaṁ vimānan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:29.1":{"pli":"“Saccaṁ kirāhaṁsu narā sapaññā, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:29.2":{"pli":"Anaññathā vacanaṁ paṇḍitānaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv37:29.3":{"pli":"Yahiṁ yahiṁ gacchati puññakammo, ","html":"<span class='verse-line'>{}</span>"},"pv37:29.4":{"pli":"Tahiṁ tahiṁ modati kāmakāmī. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:30.1":{"pli":"Yahiṁ yahiṁ sokapariddavo ca, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:30.2":{"pli":"Vadho ca bandho ca parikkileso; ","html":"<span class='verse-line'>{}</span>"},"pv37:30.3":{"pli":"Tahiṁ tahiṁ gacchati pāpakammo, ","html":"<span class='verse-line'>{}</span>"},"pv37:30.4":{"pli":"Na muccati duggatiyā kadācī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:31.1":{"pli":"“Sammūḷharūpova jano ahosi, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:31.2":{"pli":"Asmiṁ muhutte kalalīkatova; ","html":"<span class='verse-line'>{}</span>"},"pv37:31.3":{"pli":"Janassimassa tuyhañca kumāra, ","html":"<span class='verse-line'>{}</span>"},"pv37:31.4":{"pli":"Appaccayo kena nu kho ahosī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:32.1":{"pli":"“Ime ca sirīsavanā tātā, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:32.2":{"pli":"Dibbā gandhā surabhī sampavanti; ","html":"<span class='verse-line'>{}</span>"},"pv37:32.3":{"pli":"Te sampavāyanti imaṁ vimānaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv37:32.4":{"pli":"Divā ca ratto ca tamaṁ nihantvā. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:33.1":{"pli":"Imesañca kho vassasataccayena, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:33.2":{"pli":"Sipāṭikā phalati ekamekā; ","html":"<span class='verse-line'>{}</span>"},"pv37:33.3":{"pli":"Mānussakaṁ vassasataṁ atītaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv37:33.4":{"pli":"Yadagge kāyamhi idhūpapanno. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:34.1":{"pli":"Disvānahaṁ vassasatāni pañca, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:34.2":{"pli":"Asmiṁ vimāne ṭhatvāna tātā; ","html":"<span class='verse-line'>{}</span>"},"pv37:34.3":{"pli":"Āyukkhayā puññakkhayā cavissaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv37:34.4":{"pli":"Teneva sokena pamucchitosmī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:35.1":{"pli":"“Kathaṁ nu soceyya tathāvidho so, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:35.2":{"pli":"Laddhā vimānaṁ atulaṁ cirāya; ","html":"<span class='verse-line'>{}</span>"},"pv37:35.3":{"pli":"Ye cāpi kho ittaramupapannā, ","html":"<span class='verse-line'>{}</span>"},"pv37:35.4":{"pli":"Te nūna soceyyuṁ parittapuññā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:36.1":{"pli":"“Anucchaviṁ ovadiyañca me taṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:36.2":{"pli":"Yaṁ maṁ tumhe peyyavācaṁ vadetha; ","html":"<span class='verse-line'>{}</span>"},"pv37:36.3":{"pli":"Tumhe ca kho tātā mayānuguttā, ","html":"<span class='verse-line'>{}</span>"},"pv37:36.4":{"pli":"Yenicchakaṁ tena paletha sotthin”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:37.1":{"pli":"“Gantvā mayaṁ sindhusovīrabhūmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:37.2":{"pli":"Dhanatthikā uddayaṁ patthayānā; ","html":"<span class='verse-line'>{}</span>"},"pv37:37.3":{"pli":"Yathāpayogā paripuṇṇacāgā, ","html":"<span class='verse-line'>{}</span>"},"pv37:37.4":{"pli":"Kāhāma serīsamahaṁ uḷāran”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:38.1":{"pli":"“Mā ceva serīsamahaṁ akattha, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:38.2":{"pli":"Sabbañca vo bhavissati yaṁ vadetha; ","html":"<span class='verse-line'>{}</span>"},"pv37:38.3":{"pli":"Pāpāni kammāni vivajjayātha, ","html":"<span class='verse-line'>{}</span>"},"pv37:38.4":{"pli":"Dhammānuyogañca adhiṭṭhahātha. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:39.1":{"pli":"Upāsako atthi imamhi saṅghe, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:39.2":{"pli":"Bahussuto sīlavatūpapanno; ","html":"<span class='verse-line'>{}</span>"},"pv37:39.3":{"pli":"Saddho ca cāgī ca supesalo ca, ","html":"<span class='verse-line'>{}</span>"},"pv37:39.4":{"pli":"Vicakkhaṇo santusito mutīmā. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:40.1":{"pli":"Sañjānamāno na musā bhaṇeyya, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:40.2":{"pli":"Parūpaghātāya na cetayeyya; ","html":"<span class='verse-line'>{}</span>"},"pv37:40.3":{"pli":"Vebhūtikaṁ pesuṇaṁ no kareyya, ","html":"<span class='verse-line'>{}</span>"},"pv37:40.4":{"pli":"Saṇhañca vācaṁ sakhilaṁ bhaṇeyya. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:41.1":{"pli":"Sagāravo sappatisso vinīto, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:41.2":{"pli":"Apāpako adhisīle visuddho; ","html":"<span class='verse-line'>{}</span>"},"pv37:41.3":{"pli":"So mātaraṁ pitarañcāpi jantu, ","html":"<span class='verse-line'>{}</span>"},"pv37:41.4":{"pli":"Dhammena poseti ariyavutti. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:42.1":{"pli":"Maññe so mātāpitūnaṁ kāraṇā, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:42.2":{"pli":"Bhogāni pariyesati na attahetu; ","html":"<span class='verse-line'>{}</span>"},"pv37:42.3":{"pli":"Mātāpitūnañca yo accayena, ","html":"<span class='verse-line'>{}</span>"},"pv37:42.4":{"pli":"Nekkhammapoṇo carissati brahmacariyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:43.1":{"pli":"Ujū avaṅko asaṭho amāyo, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:43.2":{"pli":"Na lesakappena ca vohareyya; ","html":"<span class='verse-line'>{}</span>"},"pv37:43.3":{"pli":"So tādiso sukatakammakārī, ","html":"<span class='verse-line'>{}</span>"},"pv37:43.4":{"pli":"Dhamme ṭhito kinti labhetha dukkhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:44.1":{"pli":"Taṁ kāraṇā pātukatomhi attanā, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:44.2":{"pli":"Tasmā dhammaṁ passatha vāṇijāse; ","html":"<span class='verse-line'>{}</span>"},"pv37:44.3":{"pli":"Aññatra teniha bhasmī bhavetha, ","html":"<span class='verse-line'>{}</span>"},"pv37:44.4":{"pli":"Andhākulā vippanaṭṭhā araññe; ","html":"<span class='verse-line'>{}</span>"},"pv37:44.5":{"pli":"Taṁ khippamānena lahuṁ parena, ","html":"<span class='verse-line'>{}</span>"},"pv37:44.6":{"pli":"Sukho have sappurisena saṅgamo”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:45.1":{"pli":"“Kiṁ nāma so kiñca karoti kammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:45.2":{"pli":"Kiṁ nāmadheyyaṁ kiṁ pana tassa gottaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv37:45.3":{"pli":"Mayampi naṁ daṭṭhukāmamha yakkha, ","html":"<span class='verse-line'>{}</span>"},"pv37:45.4":{"pli":"Yassānukampāya idhāgatosi; ","html":"<span class='verse-line'>{}</span>"},"pv37:45.5":{"pli":"Lābhā hi tassa yassa tuvaṁ pihesī”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:46.1":{"pli":"“Yo kappako sambhavanāmadheyyo, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:46.2":{"pli":"Upāsako kocchaphalūpajīvī; ","html":"<span class='verse-line'>{}</span>"},"pv37:46.3":{"pli":"Jānātha naṁ tumhākaṁ pesiyo so, ","html":"<span class='verse-line'>{}</span>"},"pv37:46.4":{"pli":"Mā kho naṁ hīḷittha supesalo so”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:47.1":{"pli":"“Jānāmase yaṁ tvaṁ pavadesi yakkha, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:47.2":{"pli":"Na kho naṁ jānāma sa edisoti; ","html":"<span class='verse-line'>{}</span>"},"pv37:47.3":{"pli":"Mayampi naṁ pūjayissāma yakkha, ","html":"<span class='verse-line'>{}</span>"},"pv37:47.4":{"pli":"Sutvāna tuyhaṁ vacanaṁ uḷāran”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:48.1":{"pli":"“Ye keci imasmiṁ satthe manussā, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:48.2":{"pli":"Daharā mahantā athavāpi majjhimā; ","html":"<span class='verse-line'>{}</span>"},"pv37:48.3":{"pli":"Sabbeva te ālambantu vimānaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv37:48.4":{"pli":"Passantu puññānaṁ phalaṁ kadariyā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:49.1":{"pli":"Te tattha sabbeva “ahaṁ pure”ti, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:49.2":{"pli":"Taṁ kappakaṁ tattha purakkhatvā; ","html":"<span class='verse-line'>{}</span>"},"pv37:49.3":{"pli":"Sabbeva te ālambiṁsu vimānaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv37:49.4":{"pli":"Masakkasāraṁ viya vāsavassa. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:50.1":{"pli":"Te tattha sabbeva “ahaṁ pure”ti, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:50.2":{"pli":"Upāsakattaṁ paṭivedayiṁsu; ","html":"<span class='verse-line'>{}</span>"},"pv37:50.3":{"pli":"Pāṇātipātā paṭiviratā ahesuṁ, ","html":"<span class='verse-line'>{}</span>"},"pv37:50.4":{"pli":"Loke adinnaṁ parivajjayiṁsu; ","html":"<span class='verse-line'>{}</span>"},"pv37:50.5":{"pli":"Amajjapā no ca musā bhaṇiṁsu, ","html":"<span class='verse-line'>{}</span>"},"pv37:50.6":{"pli":"Sakena dārena ca ahesuṁ tuṭṭhā. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:51.1":{"pli":"Te tattha sabbeva “ahaṁ pure”ti, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:51.2":{"pli":"Upāsakattaṁ paṭivedayitvā; ","html":"<span class='verse-line'>{}</span>"},"pv37:51.3":{"pli":"Pakkāmi sattho anumodamāno, ","html":"<span class='verse-line'>{}</span>"},"pv37:51.4":{"pli":"Yakkhiddhiyā anumato punappunaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:52.1":{"pli":"Gantvāna te sindhusovīrabhūmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:52.2":{"pli":"Dhanatthikā uddayaṁ patthayānā; ","html":"<span class='verse-line'>{}</span>"},"pv37:52.3":{"pli":"Yathāpayogā paripuṇṇalābhā, ","html":"<span class='verse-line'>{}</span>"},"pv37:52.4":{"pli":"Paccāgamuṁ pāṭaliputtamakkhataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:53.1":{"pli":"Gantvāna te saṅgharaṁ sotthivanto, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:53.2":{"pli":"Puttehi dārehi samaṅgibhūtā; ","html":"<span class='verse-line'>{}</span>"},"pv37:53.3":{"pli":"Ānandī vittā sumanā patītā, ","html":"<span class='verse-line'>{}</span>"},"pv37:53.4":{"pli":"Akaṁsu serīsamahaṁ uḷāraṁ; ","html":"<span class='verse-line'>{}</span>"},"pv37:53.5":{"pli":"Serīsakaṁ te pariveṇaṁ māpayiṁsu. ","html":"<span class='verse-line'>{}</span></p>"},"pv37:54.1":{"pli":"Etādisā sappurisāna sevanā, ","html":"<p><span class='verse-line'>{}</span>"},"pv37:54.2":{"pli":"Mahatthikā dhammaguṇāna sevanā; ","html":"<span class='verse-line'>{}</span>"},"pv37:54.3":{"pli":"Ekassa atthāya upāsakassa, ","html":"<span class='verse-line'>{}</span>"},"pv37:54.4":{"pli":"Sabbeva sattā sukhitā ahesunti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv37:55.1":{"pli":"Serīsakapetavatthu dutiyaṁ. ","html":"<p class='endsutta'>{}<br>"},"pv37:55.2":{"pli":"Bhāṇavāraṁ tatiyaṁ. ","html":"{}</p></article>"}},"pv38":{"pv38:0.1":{"pli":"Petavatthu ","html":"<article id='pv38'><header><ul><li class='division'>{}</li>"},"pv38:0.2":{"pli":"Mahāvagga ","html":"<li>{}</li></ul>"},"pv38:0.3":{"pli":"3. Nandakapetavatthu ","html":"<h1 class='sutta-title'>{}</h1></header>"},"pv38:1.1":{"pli":"Rājā piṅgalako nāma, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv38:1.2":{"pli":"Suraṭṭhānaṁ adhipati ahu; ","html":"<span class='verse-line'>{}</span>"},"pv38:1.3":{"pli":"Moriyānaṁ upaṭṭhānaṁ gantvā, ","html":"<span class='verse-line'>{}</span>"},"pv38:1.4":{"pli":"Suraṭṭhaṁ punarāgamā. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:2.1":{"pli":"Uṇhe majjhanhike kāle, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:2.2":{"pli":"Rājā paṅkaṁ upāgami; ","html":"<span class='verse-line'>{}</span>"},"pv38:2.3":{"pli":"Addasa maggaṁ ramaṇīyaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv38:2.4":{"pli":"Petānaṁ taṁ vaṇṇupathaṁ. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv38:3.1":{"pli":"Sārathiṁ āmantayī rājā—","html":"<p>{}</p>"},"pv38:4.1":{"pli":"“Ayaṁ maggo ramaṇīyo, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"pv38:4.2":{"pli":"khemo sovatthiko sivo; ","html":"<span class='verse-line'>{}</span>"},"pv38:4.3":{"pli":"Iminā sārathi yāma, ","html":"<span class='verse-line'>{}</span>"},"pv38:4.4":{"pli":"suraṭṭhānaṁ santike ito”. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:5.1":{"pli":"Tena pāyāsi soraṭṭho, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:5.2":{"pli":"senāya caturaṅginiyā; ","html":"<span class='verse-line'>{}</span>"},"pv38:5.3":{"pli":"Ubbiggarūpo puriso, ","html":"<span class='verse-line'>{}</span>"},"pv38:5.4":{"pli":"soraṭṭhaṁ etadabravi. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:6.1":{"pli":"“Kummaggaṁ paṭipannamhā, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:6.2":{"pli":"bhiṁsanaṁ lomahaṁsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv38:6.3":{"pli":"Purato dissati maggo, ","html":"<span class='verse-line'>{}</span>"},"pv38:6.4":{"pli":"pacchato ca na dissati. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:7.1":{"pli":"Kummaggaṁ paṭipannamhā, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:7.2":{"pli":"yamapurisāna santike; ","html":"<span class='verse-line'>{}</span>"},"pv38:7.3":{"pli":"Amānuso vāyati gandho, ","html":"<span class='verse-line'>{}</span>"},"pv38:7.4":{"pli":"ghoso suyyati dāruṇo”. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:8.1":{"pli":"Saṁviggo rājā soraṭṭho, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:8.2":{"pli":"sārathiṁ etadabravi; ","html":"<span class='verse-line'>{}</span>"},"pv38:8.3":{"pli":"“Kummaggaṁ paṭipannamhā, ","html":"<span class='verse-line'>{}</span>"},"pv38:8.4":{"pli":"bhiṁsanaṁ lomahaṁsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv38:8.5":{"pli":"Purato dissati maggo, ","html":"<span class='verse-line'>{}</span>"},"pv38:8.6":{"pli":"pacchato ca na dissati. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:9.1":{"pli":"Kummaggaṁ paṭipannamhā, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:9.2":{"pli":"yamapurisāna santike; ","html":"<span class='verse-line'>{}</span>"},"pv38:9.3":{"pli":"Amānuso vāyati gandho, ","html":"<span class='verse-line'>{}</span>"},"pv38:9.4":{"pli":"ghoso suyyati dāruṇo”. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:10.1":{"pli":"Hatthikkhandhaṁ samāruyha, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:10.2":{"pli":"Olokento catuddisaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv38:10.3":{"pli":"Addasa nigrodhaṁ ramaṇīyaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv38:10.4":{"pli":"Pādapaṁ chāyāsampannaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv38:10.5":{"pli":"Nīlabbhavaṇṇasadisaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv38:10.6":{"pli":"Meghavaṇṇasirīnibhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:11.1":{"pli":"Sārathiṁ āmantayī rājā, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:11.2":{"pli":"“kiṁ eso dissati brahā; ","html":"<span class='verse-line'>{}</span>"},"pv38:11.3":{"pli":"Nīlabbhavaṇṇasadiso, ","html":"<span class='verse-line'>{}</span>"},"pv38:11.4":{"pli":"meghavaṇṇasirīnibho”. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:12.1":{"pli":"“Nigrodho so mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:12.2":{"pli":"pādapo chāyāsampanno; ","html":"<span class='verse-line'>{}</span>"},"pv38:12.3":{"pli":"Nīlabbhavaṇṇasadiso, ","html":"<span class='verse-line'>{}</span>"},"pv38:12.4":{"pli":"meghavaṇṇasirīnibho”. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:13.1":{"pli":"Tena pāyāsi soraṭṭho, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:13.2":{"pli":"yena so dissate brahā; ","html":"<span class='verse-line'>{}</span>"},"pv38:13.3":{"pli":"Nīlabbhavaṇṇasadiso, ","html":"<span class='verse-line'>{}</span>"},"pv38:13.4":{"pli":"meghavaṇṇasirīnibho. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:14.1":{"pli":"Hatthikkhandhato oruyha, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:14.2":{"pli":"rājā rukkhaṁ upāgami; ","html":"<span class='verse-line'>{}</span>"},"pv38:14.3":{"pli":"Nisīdi rukkhamūlasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"pv38:14.4":{"pli":"sāmacco saparijjano; ","html":"<span class='verse-line'>{}</span>"},"pv38:14.5":{"pli":"Pūraṁ pānīyasarakaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv38:14.6":{"pli":"pūve vitte ca addasa. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:15.1":{"pli":"Puriso ca devavaṇṇī, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:15.2":{"pli":"sabbābharaṇabhūsito; ","html":"<span class='verse-line'>{}</span>"},"pv38:15.3":{"pli":"Upasaṅkamitvā rājānaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv38:15.4":{"pli":"soraṭṭhaṁ etadabravi. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:16.1":{"pli":"“Svāgataṁ te mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:16.2":{"pli":"atho te adurāgataṁ; ","html":"<span class='verse-line'>{}</span>"},"pv38:16.3":{"pli":"Pivatu devo pānīyaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv38:16.4":{"pli":"pūve khāda arindama”. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:17.1":{"pli":"Pivitvā rājā pānīyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:17.2":{"pli":"sāmacco saparijjano; ","html":"<span class='verse-line'>{}</span>"},"pv38:17.3":{"pli":"Pūve khāditvā pitvā ca, ","html":"<span class='verse-line'>{}</span>"},"pv38:17.4":{"pli":"soraṭṭho etadabravi. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:18.1":{"pli":"“Devatā nusi gandhabbo, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:18.2":{"pli":"adu sakko purindado; ","html":"<span class='verse-line'>{}</span>"},"pv38:18.3":{"pli":"Ajānantā taṁ pucchāma, ","html":"<span class='verse-line'>{}</span>"},"pv38:18.4":{"pli":"kathaṁ jānemu taṁ mayan”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:19.1":{"pli":"“Nāmhi devo na gandhabbo, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:19.2":{"pli":"nāpi sakko purindado; ","html":"<span class='verse-line'>{}</span>"},"pv38:19.3":{"pli":"Peto ahaṁ mahārāja, ","html":"<span class='verse-line'>{}</span>"},"pv38:19.4":{"pli":"suraṭṭhā idha māgato”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:20.1":{"pli":"“Kiṁsīlo kiṁsamācāro, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:20.2":{"pli":"suraṭṭhasmiṁ pure tuvaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv38:20.3":{"pli":"Kena te brahmacariyena, ","html":"<span class='verse-line'>{}</span>"},"pv38:20.4":{"pli":"ānubhāvo ayaṁ tavā”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:21.1":{"pli":"“Taṁ suṇohi mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:21.2":{"pli":"arindama raṭṭhavaḍḍhana; ","html":"<span class='verse-line'>{}</span>"},"pv38:21.3":{"pli":"Amaccā pārisajjā ca, ","html":"<span class='verse-line'>{}</span>"},"pv38:21.4":{"pli":"brāhmaṇo ca purohito. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:22.1":{"pli":"Suraṭṭhasmiṁ ahaṁ deva, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:22.2":{"pli":"puriso pāpacetaso; ","html":"<span class='verse-line'>{}</span>"},"pv38:22.3":{"pli":"Micchādiṭṭhi ca dussīlo, ","html":"<span class='verse-line'>{}</span>"},"pv38:22.4":{"pli":"kadariyo paribhāsako. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:23.1":{"pli":"Dadantānaṁ karontānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:23.2":{"pli":"vārayissaṁ bahujjanaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv38:23.3":{"pli":"Aññesaṁ dadamānānaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv38:23.4":{"pli":"antarāyakaro ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:24.1":{"pli":"Vipāko natthi dānassa, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:24.2":{"pli":"saṁyamassa kuto phalaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv38:24.3":{"pli":"Natthi ācariyo nāma, ","html":"<span class='verse-line'>{}</span>"},"pv38:24.4":{"pli":"adantaṁ ko damessati. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:25.1":{"pli":"Samatulyāni bhūtāni, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:25.2":{"pli":"kuto jeṭṭhāpacāyiko; ","html":"<span class='verse-line'>{}</span>"},"pv38:25.3":{"pli":"Natthi balaṁ vīriyaṁ vā, ","html":"<span class='verse-line'>{}</span>"},"pv38:25.4":{"pli":"kuto uṭṭhānaporisaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:26.1":{"pli":"Natthi dānaphalaṁ nāma, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:26.2":{"pli":"na visodheti verinaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv38:26.3":{"pli":"Laddheyyaṁ labhate macco, ","html":"<span class='verse-line'>{}</span>"},"pv38:26.4":{"pli":"niyatipariṇāmajaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:27.1":{"pli":"Natthi mātā pitā bhātā, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:27.2":{"pli":"loko natthi ito paraṁ; ","html":"<span class='verse-line'>{}</span>"},"pv38:27.3":{"pli":"Natthi dinnaṁ natthi hutaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv38:27.4":{"pli":"sunihitaṁ na vijjati. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:28.1":{"pli":"Yopi haneyya purisaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:28.2":{"pli":"parassa chindate siraṁ; ","html":"<span class='verse-line'>{}</span>"},"pv38:28.3":{"pli":"Na koci kañci hanati, ","html":"<span class='verse-line'>{}</span>"},"pv38:28.4":{"pli":"sattannaṁ vivaramantare. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:29.1":{"pli":"Acchejjābhejjo hi jīvo, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:29.2":{"pli":"Aṭṭhaṁso guḷaparimaṇḍalo; ","html":"<span class='verse-line'>{}</span>"},"pv38:29.3":{"pli":"Yojanānaṁ sataṁ pañca, ","html":"<span class='verse-line'>{}</span>"},"pv38:29.4":{"pli":"Ko jīvaṁ chettumarahati. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:30.1":{"pli":"Yathā suttaguḷe khitte, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:30.2":{"pli":"nibbeṭhentaṁ palāyati; ","html":"<span class='verse-line'>{}</span>"},"pv38:30.3":{"pli":"Evamevaṁ ca so jīvo, ","html":"<span class='verse-line'>{}</span>"},"pv38:30.4":{"pli":"nibbeṭhento palāyati. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:31.1":{"pli":"Yathā gāmato nikkhamma, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:31.2":{"pli":"aññaṁ gāmaṁ pavīsati; ","html":"<span class='verse-line'>{}</span>"},"pv38:31.3":{"pli":"Evamevaṁ ca so jīvo, ","html":"<span class='verse-line'>{}</span>"},"pv38:31.4":{"pli":"aññaṁ bondiṁ pavīsati. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:32.1":{"pli":"Yathā gehato nikkhamma, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:32.2":{"pli":"aññaṁ gehaṁ pavīsati; ","html":"<span class='verse-line'>{}</span>"},"pv38:32.3":{"pli":"Evamevaṁ ca so jīvo, ","html":"<span class='verse-line'>{}</span>"},"pv38:32.4":{"pli":"aññaṁ bondiṁ pavīsati. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:33.1":{"pli":"Cullāsīti mahākappino, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:33.2":{"pli":"satasahassāni hi; ","html":"<span class='verse-line'>{}</span>"},"pv38:33.3":{"pli":"Ye bālā ye ca paṇḍitā, ","html":"<span class='verse-line'>{}</span>"},"pv38:33.4":{"pli":"saṁsāraṁ khepayitvāna; ","html":"<span class='verse-line'>{}</span>"},"pv38:33.5":{"pli":"Dukkhassantaṁ karissare. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:34.1":{"pli":"Mitāni sukhadukkhāni, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:34.2":{"pli":"doṇehi piṭakehi ca; ","html":"<span class='verse-line'>{}</span>"},"pv38:34.3":{"pli":"Jino sabbaṁ pajānāti, ","html":"<span class='verse-line'>{}</span>"},"pv38:34.4":{"pli":"sammūḷhā itarā pajā. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:35.1":{"pli":"Evaṁdiṭṭhi pure āsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:35.2":{"pli":"sammūḷho mohapāruto; ","html":"<span class='verse-line'>{}</span>"},"pv38:35.3":{"pli":"Micchādiṭṭhi ca dussīlo, ","html":"<span class='verse-line'>{}</span>"},"pv38:35.4":{"pli":"kadariyo paribhāsako. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:36.1":{"pli":"Oraṁ me chahi māsehi, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:36.2":{"pli":"kālakiriyā bhavissati; ","html":"<span class='verse-line'>{}</span>"},"pv38:36.3":{"pli":"Ekantakaṭukaṁ ghoraṁ, ","html":"<span class='verse-line'>{}</span>"},"pv38:36.4":{"pli":"nirayaṁ papatissahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:37.1":{"pli":"Catukkaṇṇaṁ catudvāraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:37.2":{"pli":"vibhattaṁ bhāgaso mitaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv38:37.3":{"pli":"Ayopākārapariyantaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv38:37.4":{"pli":"ayasā paṭikujjitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:38.1":{"pli":"Tassa ayomayā bhūmi, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:38.2":{"pli":"jalitā tejasā yutā; ","html":"<span class='verse-line'>{}</span>"},"pv38:38.3":{"pli":"Samantā yojanasataṁ, ","html":"<span class='verse-line'>{}</span>"},"pv38:38.4":{"pli":"pharitvā tiṭṭhati sabbadā. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:39.1":{"pli":"Vassāni satasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:39.2":{"pli":"ghoso suyyati tāvade; ","html":"<span class='verse-line'>{}</span>"},"pv38:39.3":{"pli":"Lakkho eso mahārāja, ","html":"<span class='verse-line'>{}</span>"},"pv38:39.4":{"pli":"satabhāgavassakoṭiyo. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:40.1":{"pli":"Koṭisatasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:40.2":{"pli":"niraye paccare janā; ","html":"<span class='verse-line'>{}</span>"},"pv38:40.3":{"pli":"Micchādiṭṭhī ca dussīlā, ","html":"<span class='verse-line'>{}</span>"},"pv38:40.4":{"pli":"ye ca ariyūpavādino. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:41.1":{"pli":"Tatthāhaṁ dīghamaddhānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:41.2":{"pli":"dukkhaṁ vedissa vedanaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv38:41.3":{"pli":"Phalaṁ pāpassa kammassa, ","html":"<span class='verse-line'>{}</span>"},"pv38:41.4":{"pli":"tasmā socāmahaṁ bhusaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:42.1":{"pli":"Taṁ suṇohi mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:42.2":{"pli":"arindama raṭṭhavaḍḍhana; ","html":"<span class='verse-line'>{}</span>"},"pv38:42.3":{"pli":"Dhītā mayhaṁ mahārāja, ","html":"<span class='verse-line'>{}</span>"},"pv38:42.4":{"pli":"uttarā bhaddamatthu te. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:43.1":{"pli":"Karoti bhaddakaṁ kammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:43.2":{"pli":"sīlesuposathe ratā; ","html":"<span class='verse-line'>{}</span>"},"pv38:43.3":{"pli":"Saññatā saṁvibhāgī ca, ","html":"<span class='verse-line'>{}</span>"},"pv38:43.4":{"pli":"vadaññū vītamaccharā. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:44.1":{"pli":"Akhaṇḍakārī sikkhāya, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:44.2":{"pli":"suṇhā parakulesu ca; ","html":"<span class='verse-line'>{}</span>"},"pv38:44.3":{"pli":"Upāsikā sakyamunino, ","html":"<span class='verse-line'>{}</span>"},"pv38:44.4":{"pli":"sambuddhassa sirīmato. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:45.1":{"pli":"Bhikkhu ca sīlasampanno, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:45.2":{"pli":"gāmaṁ piṇḍāya pāvisi; ","html":"<span class='verse-line'>{}</span>"},"pv38:45.3":{"pli":"Okkhittacakkhu satimā, ","html":"<span class='verse-line'>{}</span>"},"pv38:45.4":{"pli":"guttadvāro susaṁvuto. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:46.1":{"pli":"Sapadānaṁ caramāno, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:46.2":{"pli":"agamā taṁ nivesanaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv38:46.3":{"pli":"‘Tamaddasa mahārāja, ","html":"<span class='verse-line'>{}</span>"},"pv38:46.4":{"pli":"uttarā bhaddamatthu te’. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:47.1":{"pli":"Pūraṁ pānīyasarakaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:47.2":{"pli":"pūve vitte ca sā adā; ","html":"<span class='verse-line'>{}</span>"},"pv38:47.3":{"pli":"‘Pitā me kālakato bhante, ","html":"<span class='verse-line'>{}</span>"},"pv38:47.4":{"pli":"tassetaṁ upakappatu’. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:48.1":{"pli":"Samanantarānuddiṭṭhe, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:48.2":{"pli":"vipāko udapajjatha; ","html":"<span class='verse-line'>{}</span>"},"pv38:48.3":{"pli":"Bhuñjāmi kāmakāmīhaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv38:48.4":{"pli":"rājā vessavaṇo yathā. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:49.1":{"pli":"Taṁ suṇohi mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:49.2":{"pli":"arindama raṭṭhavaḍḍhana; ","html":"<span class='verse-line'>{}</span>"},"pv38:49.3":{"pli":"Sadevakassa lokassa, ","html":"<span class='verse-line'>{}</span>"},"pv38:49.4":{"pli":"buddho aggo pavuccati; ","html":"<span class='verse-line'>{}</span>"},"pv38:49.5":{"pli":"Taṁ buddhaṁ saraṇaṁ gaccha, ","html":"<span class='verse-line'>{}</span>"},"pv38:49.6":{"pli":"saputtadāro arindama. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:50.1":{"pli":"Aṭṭhaṅgikena maggena, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:50.2":{"pli":"phusanti amataṁ padaṁ; ","html":"<span class='verse-line'>{}</span>"},"pv38:50.3":{"pli":"Taṁ dhammaṁ saraṇaṁ gaccha, ","html":"<span class='verse-line'>{}</span>"},"pv38:50.4":{"pli":"saputtadāro arindama. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:51.1":{"pli":"Cattāro ca paṭipannā, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:51.2":{"pli":"cattāro ca phale ṭhitā; ","html":"<span class='verse-line'>{}</span>"},"pv38:51.3":{"pli":"Esa saṅgho ujubhūto, ","html":"<span class='verse-line'>{}</span>"},"pv38:51.4":{"pli":"paññāsīlasamāhito; ","html":"<span class='verse-line'>{}</span>"},"pv38:51.5":{"pli":"Taṁ saṅghaṁ saraṇaṁ gaccha, ","html":"<span class='verse-line'>{}</span>"},"pv38:51.6":{"pli":"saputtadāro arindama. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:52.1":{"pli":"Pāṇātipātā viramassu khippaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:52.2":{"pli":"Loke adinnaṁ parivajjayassu; ","html":"<span class='verse-line'>{}</span>"},"pv38:52.3":{"pli":"Amajjapo mā ca musā abhāṇi, ","html":"<span class='verse-line'>{}</span>"},"pv38:52.4":{"pli":"Sakena dārena ca hohi tuṭṭho”ti. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:53.1":{"pli":"“Atthakāmosi me yakkha, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:53.2":{"pli":"hitakāmosi devate; ","html":"<span class='verse-line'>{}</span>"},"pv38:53.3":{"pli":"Karomi tuyhaṁ vacanaṁ, ","html":"<span class='verse-line'>{}</span>"},"pv38:53.4":{"pli":"tvaṁsi ācariyo mama. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:54.1":{"pli":"Upemi saraṇaṁ buddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:54.2":{"pli":"dhammañcāpi anuttaraṁ; ","html":"<span class='verse-line'>{}</span>"},"pv38:54.3":{"pli":"Saṅghañca naradevassa, ","html":"<span class='verse-line'>{}</span>"},"pv38:54.4":{"pli":"gacchāmi saraṇaṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:55.1":{"pli":"Pāṇātipātā viramāmi khippaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:55.2":{"pli":"Loke adinnaṁ parivajjayāmi; ","html":"<span class='verse-line'>{}</span>"},"pv38:55.3":{"pli":"Amajjapo no ca musā bhaṇāmi, ","html":"<span class='verse-line'>{}</span>"},"pv38:55.4":{"pli":"Sakena dārena ca homi tuṭṭho. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:56.1":{"pli":"Ophuṇāmi mahāvāte, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:56.2":{"pli":"nadiyā sīghagāmiyā; ","html":"<span class='verse-line'>{}</span>"},"pv38:56.3":{"pli":"Vamāmi pāpikaṁ diṭṭhiṁ, ","html":"<span class='verse-line'>{}</span>"},"pv38:56.4":{"pli":"buddhānaṁ sāsane rato”. ","html":"<span class='verse-line'>{}</span></p>"},"pv38:57.1":{"pli":"Idaṁ vatvāna soraṭṭho, ","html":"<p><span class='verse-line'>{}</span>"},"pv38:57.2":{"pli":"viramitvā pāpadassanā; ","html":"<span class='verse-line'>{}</span>"},"pv38:57.3":{"pli":"Namo bhagavato katvā, ","html":"<span class='verse-line'>{}</span>"},"pv38:57.4":{"pli":"pāmokkho rathamāruhīti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"pv38:58.1":{"pli":"Nandakapetavatthu tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}