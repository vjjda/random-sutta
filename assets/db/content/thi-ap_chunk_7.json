{"thi-ap25":{"thi-ap25:0.1":{"pli":"Therīapadāna ","html":"<article id='thi-ap25'><header><ul><li class='division'>{}</li>"},"thi-ap25:0.2":{"pli":"Kuṇḍalakesīvagga ","html":"<li>{}</li></ul>"},"thi-ap25:0.3":{"pli":"5 Nandātherīapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"thi-ap25:1.1":{"pli":"“Padumuttaro nāma jino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"thi-ap25:1.2":{"pli":"sabbadhammāna pāragū; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:1.3":{"pli":"Ito satasahassamhi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:1.4":{"pli":"kappe uppajji nāyako. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:2.1":{"pli":"Ovādako viññāpako, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:2.2":{"pli":"tārako sabbapāṇinaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:2.3":{"pli":"Desanākusalo buddho, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:2.4":{"pli":"tāresi janataṁ bahuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:3.1":{"pli":"Anukampako kāruṇiko, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:3.2":{"pli":"hitesī sabbapāṇinaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:3.3":{"pli":"Sampatte titthiye sabbe, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:3.4":{"pli":"pañcasīle patiṭṭhapi. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:4.1":{"pli":"Evaṁ nirākulaṁ āsi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:4.2":{"pli":"suññataṁ titthiyehi ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:4.3":{"pli":"Vicittaṁ arahantehi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:4.4":{"pli":"vasībhūtehi tādibhi. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:5.1":{"pli":"Ratanānaṭṭhapaññāsaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:5.2":{"pli":"uggatova mahāmuni; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:5.3":{"pli":"Kañcanagghiyasaṅkāso, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:5.4":{"pli":"bāttiṁsavaralakkhaṇo. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:6.1":{"pli":"Vassasatasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:6.2":{"pli":"āyu vijjati tāvade; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:6.3":{"pli":"Tāvatā tiṭṭhamāno so, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:6.4":{"pli":"tāresi janataṁ bahuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:7.1":{"pli":"Tadāhaṁ haṁsavatiyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:7.2":{"pli":"jātā seṭṭhikule ahuṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:7.3":{"pli":"Nānāratanapajjote, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:7.4":{"pli":"mahāsukhasamappitā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:8.1":{"pli":"Upetvā taṁ mahāvīraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:8.2":{"pli":"assosiṁ dhammadesanaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:8.3":{"pli":"Amataṁ paramassādaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:8.4":{"pli":"paramatthanivedakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:9.1":{"pli":"Tadā nimantayitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:9.2":{"pli":"sasaṅghaṁ lokanāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:9.3":{"pli":"Datvā tassa mahādānaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:9.4":{"pli":"pasannā sehi pāṇibhi. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:10.1":{"pli":"Jhāyinīnaṁ bhikkhunīnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:10.2":{"pli":"aggaṭṭhānamapatthayiṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:10.3":{"pli":"Nipacca sirasā dhīraṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:10.4":{"pli":"sasaṅghaṁ lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:11.1":{"pli":"Tadā adantadamako, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:11.2":{"pli":"tilokasaraṇo pabhū; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:11.3":{"pli":"Byākāsi narasārathi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:11.4":{"pli":"‘lacchase taṁ supatthitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:12.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:12.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:12.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:12.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:13.1":{"pli":"Tassa dhammesu dāyādā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:13.2":{"pli":"orasā dhammanimmitā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:13.3":{"pli":"Nandāti nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:13.4":{"pli":"hessati satthu sāvikā’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:14.1":{"pli":"Taṁ sutvā muditā hutvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:14.2":{"pli":"yāvajīvaṁ tadā jinaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:14.3":{"pli":"Mettacittā paricariṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:14.4":{"pli":"paccayehi vināyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:15.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:15.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:15.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:15.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:16.1":{"pli":"Tato cutā yāmamagaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:16.2":{"pli":"tatohaṁ tusitaṁ gatā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:16.3":{"pli":"Tato ca nimmānaratiṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:16.4":{"pli":"vasavattipuraṁ tato. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:17.1":{"pli":"Yattha yatthūpapajjāmi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:17.2":{"pli":"tassa kammassa vāhasā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:17.3":{"pli":"Tattha tattheva rājūnaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:17.4":{"pli":"mahesittamakārayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:18.1":{"pli":"Tato cutā manussatte, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:18.2":{"pli":"rājānaṁ cakkavattinaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:18.3":{"pli":"Maṇḍalīnañca rājūnaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:18.4":{"pli":"mahesittamakārayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:19.1":{"pli":"Sampattiṁ anubhotvāna, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:19.2":{"pli":"devesu manujesu ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:19.3":{"pli":"Sabbattha sukhitā hutvā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:19.4":{"pli":"nekakappesu saṁsariṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:20.1":{"pli":"Pacchime bhave sampatte, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:20.2":{"pli":"suramme kapilavhaye; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:20.3":{"pli":"Rañño suddhodanassāhaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:20.4":{"pli":"dhītā āsiṁ aninditā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:21.1":{"pli":"Siriyā rūpiniṁ disvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:21.2":{"pli":"nanditaṁ āsi taṁ kulaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:21.3":{"pli":"Tena nandāti me nāmaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:21.4":{"pli":"sundaraṁ pavaraṁ ahu. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:22.1":{"pli":"Yuvatīnañca sabbāsaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:22.2":{"pli":"kalyāṇīti ca vissutā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:22.3":{"pli":"Tasmimpi nagare ramme, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:22.4":{"pli":"ṭhapetvā taṁ yasodharaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:23.1":{"pli":"Jeṭṭho bhātā tilokaggo, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:23.2":{"pli":"pacchimo arahā tathā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:23.3":{"pli":"Ekākinī gahaṭṭhāhaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:23.4":{"pli":"mātarā paricoditā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:24.1":{"pli":"‘Sākiyamhi kule jātā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:24.2":{"pli":"putte buddhānujā tuvaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:24.3":{"pli":"Nandenapi vinā bhūtā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:24.4":{"pli":"agāre kiṁ nu acchasi. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:25.1":{"pli":"Jarāvasānaṁ yobbaññaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:25.2":{"pli":"rūpaṁ asucisammataṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:25.3":{"pli":"Rogantamapicārogyaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:25.4":{"pli":"jīvitaṁ maraṇantikaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:26.1":{"pli":"Idampi te subhaṁ rūpaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:26.2":{"pli":"sasīkantaṁ manoharaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:26.3":{"pli":"Bhūsanānaṁ alaṅkāraṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:26.4":{"pli":"sirisaṅghāṭasannibhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:27.1":{"pli":"Puñjitaṁ lokasāraṁva, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:27.2":{"pli":"nayanānaṁ rasāyanaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:27.3":{"pli":"Puññānaṁ kittijananaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:27.4":{"pli":"ukkākakulanandanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:28.1":{"pli":"Na cireneva kālena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:28.2":{"pli":"jarā samadhisessati; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:28.3":{"pli":"Vihāya gehaṁ kāruññe, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:28.4":{"pli":"cara dhammamanindite’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:29.1":{"pli":"Sutvāhaṁ mātu vacanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:29.2":{"pli":"pabbajiṁ anagāriyaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:29.3":{"pli":"Dehena na tu cittena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:29.4":{"pli":"rūpayobbanalāḷitā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:30.1":{"pli":"Mahatā ca payattena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:30.2":{"pli":"jhānajjhena paraṁ mama; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:30.3":{"pli":"Kātuñca vadate mātā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:30.4":{"pli":"na cāhaṁ tattha ussukā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:31.1":{"pli":"Tato mahākāruṇiko, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:31.2":{"pli":"disvā maṁ kāmalālasaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:31.3":{"pli":"Nibbindanatthaṁ rūpasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:31.4":{"pli":"mama cakkhupathe jino. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:32.1":{"pli":"Sakena ānubhāvena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:32.2":{"pli":"itthiṁ māpesi sobhiniṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:32.3":{"pli":"Dassanīyaṁ suruciraṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:32.4":{"pli":"mamatopi surūpiniṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:33.1":{"pli":"Tamahaṁ vimhitā disvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:33.2":{"pli":"ativimhitadehiniṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:33.3":{"pli":"Cintayiṁ ‘saphalaṁ meti, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:33.4":{"pli":"nettalābhañca mānusaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:34.1":{"pli":"Tamahaṁ ehi subhage, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:34.2":{"pli":"yenattho taṁ vadehi me; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:34.3":{"pli":"Kulaṁ te nāmagottañca, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:34.4":{"pli":"vada me yadi te piyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:35.1":{"pli":"Na vañcakālo subhage, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:35.2":{"pli":"ucchaṅge maṁ nivāsaya; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:35.3":{"pli":"Sīdantīva mamaṅgāni, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:35.4":{"pli":"pasuppaya muhuttakaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:36.1":{"pli":"Tato sīsaṁ mamaṅge sā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:36.2":{"pli":"katvā sayi sulocanā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:36.3":{"pli":"Tassā nalāṭe patitā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:36.4":{"pli":"luddhā paramadāruṇā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:37.1":{"pli":"Saha tassā nipātena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:37.2":{"pli":"piḷakā upapajjatha; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:37.3":{"pli":"Pagghariṁsu pabhinnā ca, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:37.4":{"pli":"kuṇapā pubbalohitā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:38.1":{"pli":"Pabhinnaṁ vadanañcāpi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:38.2":{"pli":"kuṇapaṁ pūtigandhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:38.3":{"pli":"Uddhumātaṁ vinilañca, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:38.4":{"pli":"pubbañcāpi sarīrakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:39.1":{"pli":"Sā paveditasabbaṅgī, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:39.2":{"pli":"nissasantī muhuṁ muhuṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:39.3":{"pli":"Vedayantī sakaṁ dukkhaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:39.4":{"pli":"karuṇaṁ paridevayi. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:40.1":{"pli":"‘Dukkhena dukkhitā homi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:40.2":{"pli":"phusayanti ca vedanā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:40.3":{"pli":"Mahādukkhe nimuggamhi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:40.4":{"pli":"saraṇaṁ hohi me sakhī. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:41.1":{"pli":"Kuhiṁ vadanasobhaṁ te, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:41.2":{"pli":"kuhiṁ te tuṅganāsikā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:41.3":{"pli":"Tambabimbavaroṭṭhaṁ te, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:41.4":{"pli":"vadanaṁ te kuhiṁ gataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:42.1":{"pli":"Kuhiṁ sasīnibhaṁ vaṇṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:42.2":{"pli":"kambugīvā kuhiṁ gatā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:42.3":{"pli":"Doḷālolāva te kaṇṇā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:42.4":{"pli":"vevaṇṇaṁ samupāgatā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:43.1":{"pli":"Makuḷakhārakākārā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:43.2":{"pli":"kalikāva payodharā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:43.3":{"pli":"Pabhinnā pūtikuṇapā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:43.4":{"pli":"duṭṭhagandhittamāgatā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:44.1":{"pli":"Vedimajjhāva sussoṇī, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:44.2":{"pli":"sūnāva nītakibbisā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:44.3":{"pli":"Jātā amejjhabharitā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:44.4":{"pli":"aho rūpamasassataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:45.1":{"pli":"Sabbaṁ sarīrasañjātaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:45.2":{"pli":"pūtigandhaṁ bhayānakaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:45.3":{"pli":"Susānamiva bībhacchaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:45.4":{"pli":"ramante yattha bālisā’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:46.1":{"pli":"Tadā mahākāruṇiko, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:46.2":{"pli":"bhātā me lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:46.3":{"pli":"Disvā saṁviggacittaṁ maṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:46.4":{"pli":"imā gāthā abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:47.1":{"pli":"‘Āturaṁ kuṇapaṁ pūtiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:47.2":{"pli":"passa nande samussayaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:47.3":{"pli":"Asubhāya cittaṁ bhāvehi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:47.4":{"pli":"ekaggaṁ susamāhitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:48.1":{"pli":"Yathā idaṁ tathā etaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:48.2":{"pli":"yathā etaṁ tathā idaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:48.3":{"pli":"Duggandhaṁ pūtikaṁ vāti, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:48.4":{"pli":"bālānaṁ abhinanditaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:49.1":{"pli":"Evametaṁ avekkhantī, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:49.2":{"pli":"rattindivamatanditā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:49.3":{"pli":"Tato sakāya paññāya, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:49.4":{"pli":"abhinibbijjha dakkhasi’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:50.1":{"pli":"Tatohaṁ atisaṁviggā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:50.2":{"pli":"sutvā gāthā subhāsitā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:50.3":{"pli":"Tatraṭṭhitāvahaṁ santī, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:50.4":{"pli":"arahattamapāpuṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:51.1":{"pli":"Yattha yattha nisinnāhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:51.2":{"pli":"sadā jhānaparāyaṇā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:51.3":{"pli":"Jino tasmiṁ guṇe tuṭṭho, ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:51.4":{"pli":"etadagge ṭhapesi maṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:52.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:52.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:52.3":{"pli":"viharāmi anāsavā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:53.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:53.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:53.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap25:54.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap25:54.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap25:54.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"thi-ap25:55.1":{"pli":"Itthaṁ sudaṁ nandā bhikkhunī janapadakalyāṇī imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"thi-ap25:56.1":{"pli":"Nandātheriyāpadānaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"thi-ap26":{"thi-ap26:0.1":{"pli":"Therīapadāna ","html":"<article id='thi-ap26'><header><ul><li class='division'>{}</li>"},"thi-ap26:0.2":{"pli":"Kuṇḍalakesīvagga ","html":"<li>{}</li></ul>"},"thi-ap26:0.3":{"pli":"Soṇātherīapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"thi-ap26:1.1":{"pli":"“Padumuttaro nāma jino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"thi-ap26:1.2":{"pli":"sabbadhammāna pāragū; ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:1.3":{"pli":"Ito satasahassamhi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:1.4":{"pli":"kappe uppajji nāyako. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap26:2.1":{"pli":"Tadā seṭṭhikule jātā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap26:2.2":{"pli":"sukhitā pūjitā piyā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:2.3":{"pli":"Upetvā taṁ munivaraṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:2.4":{"pli":"assosiṁ madhuraṁ vacaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap26:3.1":{"pli":"Āraddhavīriyānaggaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap26:3.2":{"pli":"vaṇṇesi bhikkhuniṁ jino; ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:3.3":{"pli":"Taṁ sutvā muditā hutvā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:3.4":{"pli":"kāraṁ katvāna satthuno. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap26:4.1":{"pli":"Abhivādiya sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap26:4.2":{"pli":"ṭhānaṁ taṁ patthayiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:4.3":{"pli":"Anumodi mahāvīro, ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:4.4":{"pli":"‘sijjhataṁ paṇidhī tava. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap26:5.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap26:5.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:5.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:5.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap26:6.1":{"pli":"Tassa dhammesu dāyādā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap26:6.2":{"pli":"orasā dhammanimmitā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:6.3":{"pli":"Soṇāti nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:6.4":{"pli":"hessati satthu sāvikā’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap26:7.1":{"pli":"Taṁ sutvā muditā hutvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap26:7.2":{"pli":"yāvajīvaṁ tadā jinaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:7.3":{"pli":"Mettacittā paricariṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:7.4":{"pli":"paccayehi vināyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap26:8.1":{"pli":"Tena kammena sukatena, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap26:8.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:8.3":{"pli":"Jahitvā mānusaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:8.4":{"pli":"tāvatiṁsamagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap26:9.1":{"pli":"Pacchime ca bhave dāni, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap26:9.2":{"pli":"jātā seṭṭhikule ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:9.3":{"pli":"Sāvatthiyaṁ puravare, ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:9.4":{"pli":"iddhe phīte mahaddhane. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap26:10.1":{"pli":"Yadā ca yobbanappattā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap26:10.2":{"pli":"gantvā patikulaṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:10.3":{"pli":"Dasa puttāni ajaniṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:10.4":{"pli":"surūpāni visesato. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap26:11.1":{"pli":"Sukhedhitā ca te sabbe, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap26:11.2":{"pli":"jananettamanoharā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:11.3":{"pli":"Amittānampi rucitā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:11.4":{"pli":"mama pageva te piyā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap26:12.1":{"pli":"Tato mayhaṁ akāmāya, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap26:12.2":{"pli":"dasaputtapurakkhato; ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:12.3":{"pli":"Pabbajittha sa me bhattā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:12.4":{"pli":"devadevassa sāsane. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap26:13.1":{"pli":"Tadekikā vicintesiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap26:13.2":{"pli":"‘jīvitenālamatthu me; ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:13.3":{"pli":"Cattāya patiputtehi, ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:13.4":{"pli":"vuḍḍhāya ca varākiyā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap26:14.1":{"pli":"Ahampi tattha gacchissaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap26:14.2":{"pli":"sampatto yattha me pati’; ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:14.3":{"pli":"Evāhaṁ cintayitvāna, ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:14.4":{"pli":"pabbajiṁ anagāriyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap26:15.1":{"pli":"Tato ca maṁ bhikkhuniyo, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap26:15.2":{"pli":"ekaṁ bhikkhunupassaye; ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:15.3":{"pli":"Vihāya gacchumovādaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:15.4":{"pli":"‘tāpehi udakaṁ’ iti. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap26:16.1":{"pli":"Tadā udakamāhitvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap26:16.2":{"pli":"okiritvāna kumbhiyā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:16.3":{"pli":"Culle ṭhapetvā āsīnā, ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:16.4":{"pli":"tato cittaṁ samādahiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap26:17.1":{"pli":"Khandhe aniccato disvā, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap26:17.2":{"pli":"dukkhato ca anattato; ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:17.3":{"pli":"Khepetvā āsave sabbe, ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:17.4":{"pli":"arahattamapāpuṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap26:18.1":{"pli":"Tadāgantvā bhikkhuniyo, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap26:18.2":{"pli":"uṇhodakamapucchisuṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:18.3":{"pli":"Tejodhātumadhiṭṭhāya, ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:18.4":{"pli":"khippaṁ santāpayiṁ jalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap26:19.1":{"pli":"Vimhitā tā jinavaraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap26:19.2":{"pli":"etamatthamasāvayuṁ; ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:19.3":{"pli":"Taṁ sutvā mudito nātho, ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:19.4":{"pli":"imaṁ gāthaṁ abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap26:20.1":{"pli":"‘Yo ca vassasataṁ jīve, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap26:20.2":{"pli":"kusīto hīnavīriyo; ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:20.3":{"pli":"Ekāhaṁ jīvitaṁ seyyo, ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:20.4":{"pli":"vīriyamārabhato daḷhaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap26:21.1":{"pli":"Ārādhito mahāvīro, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap26:21.2":{"pli":"mayā suppaṭipattiyā; ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:21.3":{"pli":"Āraddhavīriyānaggaṁ, ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:21.4":{"pli":"mamāha sa mahāmuni. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap26:22.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap26:22.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:22.3":{"pli":"viharāmi anāsavā. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap26:23.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap26:23.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:23.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"thi-ap26:24.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"thi-ap26:24.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"thi-ap26:24.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"thi-ap26:25.1":{"pli":"Itthaṁ sudaṁ soṇā bhikkhunī imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"thi-ap26:26.1":{"pli":"Soṇātheriyāpadānaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}