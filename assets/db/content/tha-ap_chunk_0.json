class='verse-line'>{}</span>"},"tha-ap1:69.3":{"pli":"Sadevakaṁ hāsayanto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:69.4":{"pli":"buddho loke bhavāmahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap1:70.1":{"pli":"Disā dasavidhā loke, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap1:70.2":{"pli":"yāyato natthi antakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:70.3":{"pli":"Tasmiñca disābhāgamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:70.4":{"pli":"buddhakhettā asaṅkhiyā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap1:71.1":{"pli":"Pabhā pakittitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap1:71.2":{"pli":"yamakā raṁsivāhanā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:71.3":{"pli":"Etthantare raṁsijālaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:71.4":{"pli":"āloko vipulo bhave. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap1:72.1":{"pli":"Ettake lokadhātumhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap1:72.2":{"pli":"sabbe passantu maṁ janā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:72.3":{"pli":"Sabbe maṁ anuvattantu, ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:72.4":{"pli":"yāva brahmanivesanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap1:73.1":{"pli":"Visiṭṭhamadhunādena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap1:73.2":{"pli":"amatabherimāhaniṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:73.3":{"pli":"Etthantare janā sabbe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:73.4":{"pli":"suṇantu madhuraṁ giraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap1:74.1":{"pli":"Dhammameghena vassante, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap1:74.2":{"pli":"sabbe hontu anāsavā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:74.3":{"pli":"Yettha pacchimakā sattā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:74.4":{"pli":"sotāpannā bhavantu te. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap1:75.1":{"pli":"Datvā dātabbakaṁ dānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap1:75.2":{"pli":"sīlaṁ pūretvā asesato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:75.3":{"pli":"Nekkhammapāramiṁ gantvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:75.4":{"pli":"patto sambodhimuttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap1:76.1":{"pli":"Paṇḍite paripucchitvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap1:76.2":{"pli":"katvā vīriyamuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:76.3":{"pli":"Khantiyā pāramiṁ gantvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:76.4":{"pli":"patto sambodhimuttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap1:77.1":{"pli":"Katvā daḷhamadhiṭṭhānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap1:77.2":{"pli":"saccapārami pūriya; ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:77.3":{"pli":"Mettāya pāramiṁ gantvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:77.4":{"pli":"patto sambodhimuttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap1:78.1":{"pli":"Lābhālābhe sukhe dukkhe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap1:78.2":{"pli":"sammāne cāvamānane; ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:78.3":{"pli":"Sabbattha samako hutvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:78.4":{"pli":"patto sambodhimuttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap1:79.1":{"pli":"Kosajjaṁ bhayato disvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap1:79.2":{"pli":"vīriyañcāpi khemato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:79.3":{"pli":"Āraddhavīriyā hotha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:79.4":{"pli":"esā buddhānusāsanī. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap1:80.1":{"pli":"Vivādaṁ bhayato disvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap1:80.2":{"pli":"avivādañca khemato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:80.3":{"pli":"Samaggā sakhilā hotha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:80.4":{"pli":"esā buddhānusāsanī. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap1:81.1":{"pli":"Pamādaṁ bhayato disvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap1:81.2":{"pli":"appamādañca khemato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:81.3":{"pli":"Bhāvethaṭṭhaṅgikaṁ maggaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:81.4":{"pli":"esā buddhānusāsanī. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap1:82.1":{"pli":"Samāgatā bahū buddhā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap1:82.2":{"pli":"arahantā ca sabbaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:82.3":{"pli":"Sambuddhe arahante ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:82.4":{"pli":"vandamānā namassatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap1:83.1":{"pli":"Evaṁ acintiyā buddhā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap1:83.2":{"pli":"buddhadhammā acintiyā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:83.3":{"pli":"Acintiye pasannānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:83.4":{"pli":"vipāko hoti acintiyo”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap1:84.1":{"pli":"Itthaṁ sudaṁ bhagavā attano buddhacariyaṁ sambhāvayamāno buddhāpadāniyaṁ nāma dhammapariyāyaṁ abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap1:85.1":{"pli":"Buddhāpadānaṁ samattaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap10":{"tha-ap10:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap10'><header><ul><li class='division'>{}</li>"},"tha-ap10:0.2":{"pli":"Buddhavagga ","html":"<li>{}</li></ul>"},"tha-ap10:0.3":{"pli":"Piṇḍolabhāradvājattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap10:1.1":{"pli":"“Padumuttaro nāma jino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap10:1.2":{"pli":"sayambhū aggapuggalo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap10:1.3":{"pli":"Purato himavantassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap10:1.4":{"pli":"cittakūṭe vasī tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap10:2.1":{"pli":"Abhītarūpo tatthāsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap10:2.2":{"pli":"migarājā catukkamo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap10:2.3":{"pli":"Tassa saddaṁ suṇitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap10:2.4":{"pli":"vikkhambhanti bahujjanā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap10:3.1":{"pli":"Suphullaṁ padumaṁ gayha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap10:3.2":{"pli":"upagacchiṁ narāsabhaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap10:3.3":{"pli":"Vuṭṭhitassa samādhimhā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap10:3.4":{"pli":"buddhassa abhiropayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap10:4.1":{"pli":"Catuddisaṁ namassitvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap10:4.2":{"pli":"buddhaseṭṭhaṁ naruttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap10:4.3":{"pli":"Sakaṁ cittaṁ pasādetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap10:4.4":{"pli":"sīhanādaṁ nadiṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap10:5.1":{"pli":"Padumuttaro lokavidū, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap10:5.2":{"pli":"āhutīnaṁ paṭiggaho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap10:5.3":{"pli":"Sakāsane nisīditvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap10:5.4":{"pli":"imā gāthā abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap10:6.1":{"pli":"Buddhassa giramaññāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap10:6.2":{"pli":"Sabbe devā samāgatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap10:6.3":{"pli":"‘Āgato vadataṁ seṭṭho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap10:6.4":{"pli":"Dhammaṁ sossāma taṁ mayaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap10:7.1":{"pli":"Tesaṁ hāsaparetānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap10:7.2":{"pli":"purato lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap10:7.3":{"pli":"Mama saddaṁ pakittesi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap10:7.4":{"pli":"dīghadassī mahāmuni. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap10:8.1":{"pli":"Yenidaṁ padumaṁ dinnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap10:8.2":{"pli":"sīhanādo ca nādito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap10:8.3":{"pli":"Tamahaṁ kittayissāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap10:8.4":{"pli":"suṇātha mama bhāsato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap10:9.1":{"pli":"Ito aṭṭhamake kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap10:9.2":{"pli":"cakkavattī bhavissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap10:9.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap10:9.4":{"pli":"catudīpamhi issaro. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap10:10.1":{"pli":"Kārayissati issariyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap10:10.2":{"pli":"mahiyā catusaṭṭhiyā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap10:10.3":{"pli":"Padumo nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap10:10.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap10:11.1":{"pli":"Kappasatasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap10:11.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap10:11.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap10:11.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap10:12.1":{"pli":"Pakāsite pāvacane, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap10:12.2":{"pli":"brahmabandhu bhavissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap10:12.3":{"pli":"Brahmaññā abhinikkhamma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap10:12.4":{"pli":"pabbajissati tāvade. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap10:13.1":{"pli":"Padhānapahitatto so, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap10:13.2":{"pli":"upasanto nirūpadhi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap10:13.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap10:13.4":{"pli":"nibbāyissatināsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap10:14.1":{"pli":"Vijane pantaseyyamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap10:14.2":{"pli":"vāḷamigasamākule; ","html":"<span class='verse-line'>{}</span>"},"tha-ap10:14.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap10:14.4":{"pli":"nibbāyissatināsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap10:15.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap10:15.2":{"pli":"vimokkhāpi ca aṭṭhime; ","html":"<span class='verse-line'>{}</span>"},"tha-ap10:15.3":{"pli":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap10:15.4":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap10:16.1":{"pli":"Itthaṁ sudaṁ āyasmā piṇḍolabhāradvājo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap10:17.1":{"pli":"Piṇḍolabhāradvājattherassāpadānaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap100":{"tha-ap100:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap100'><header><ul><li class='division'>{}</li>"},"tha-ap100:0.2":{"pli":"Sudhāvagga ","html":"<li>{}</li></ul>"},"tha-ap100:0.3":{"pli":"Senāsanadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap100:1.1":{"pli":"“Siddhatthassa bhagavato, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap100:1.2":{"pli":"adāsiṁ paṇṇasantharaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap100:1.3":{"pli":"Samantā upahārañca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap100:1.4":{"pli":"kusumaṁ okiriṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap100:2.1":{"pli":"Pāsādevaṁ guṇaṁ rammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap100:2.2":{"pli":"Anubhomi mahārahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap100:2.3":{"pli":"Mahagghāni ca pupphāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap100:2.4":{"pli":"Sayanebhisavanti me. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap100:3.1":{"pli":"Sayanehaṁ tuvaṭṭāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap100:3.2":{"pli":"vicitte pupphasanthate; ","html":"<span class='verse-line'>{}</span>"},"tha-ap100:3.3":{"pli":"Pupphavuṭṭhi ca sayane, ","html":"<span class='verse-line'>{}</span>"},"tha-ap100:3.4":{"pli":"abhivassati tāvade. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap100:4.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap100:4.2":{"pli":"adāsiṁ paṇṇasantharaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap100:4.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap100:4.4":{"pli":"santharassa idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap100:5.1":{"pli":"Tiṇasantharakā nāma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap100:5.2":{"pli":"sattete cakkavattino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap100:5.3":{"pli":"Ito te pañcame kappe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap100:5.4":{"pli":"uppajjiṁsu janādhipā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap100:6.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap100:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap100:6.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap100:7.1":{"pli":"Itthaṁ sudaṁ āyasmā senāsanadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap100:8.1":{"pli":"Senāsanadāyakattherassāpadānaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap101":{"tha-ap101:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap101'><header><ul><li class='division'>{}</li>"},"tha-ap101:0.2":{"pli":"Sudhāvagga ","html":"<li>{}</li></ul>"},"tha-ap101:0.3":{"pli":"Veyyāvaccakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap101:1.1":{"pli":"“Vipassissa bhagavato, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap101:1.2":{"pli":"mahāpūgagaṇo ahu; ","html":"<span class='verse-line'>{}</span>"},"tha-ap101:1.3":{"pli":"Veyyāvaccakaro āsiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap101:1.4":{"pli":"sabbakiccesu vāvaṭo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap101:2.1":{"pli":"Deyyadhammo ca me natthi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap101:2.2":{"pli":"sugatassa mahesino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap101:2.3":{"pli":"Avandiṁ satthuno pāde, ","html":"<span class='verse-line'>{}</span>"},"tha-ap101:2.4":{"pli":"vippasannena cetasā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap101:3.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap101:3.2":{"pli":"veyyāvaccaṁ akāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap101:3.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap101:3.4":{"pli":"veyyāvaccassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap101:4.1":{"pli":"Ito ca aṭṭhame kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap101:4.2":{"pli":"rājā āsiṁ sucintito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap101:4.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap101:4.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap101:5.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap101:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap101:5.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap101:6.1":{"pli":"Itthaṁ sudaṁ āyasmā veyyāvaccako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap101:7.1":{"pli":"Veyyāvaccakattherassāpadānaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}