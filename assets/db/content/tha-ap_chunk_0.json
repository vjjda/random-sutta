aṁ upenti maṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap1:59.1":{"pli":"Pathabyā pabbate ceva, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap1:59.2":{"pli":"ākāse udake vane; ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:59.3":{"pli":"Yaṁ yaṁ hatthaṁ pasāremi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:59.4":{"pli":"dibbā bhakkhā upenti maṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap1:60.1":{"pli":"Pathabyā pabbate ceva, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap1:60.2":{"pli":"ākāse udake vane; ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:60.3":{"pli":"Yaṁ yaṁ hatthaṁ pasāremi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:60.4":{"pli":"ratanā sabbe upenti maṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap1:61.1":{"pli":"Pathabyā pabbate ceva, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap1:61.2":{"pli":"ākāse udake vane; ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:61.3":{"pli":"Yaṁ yaṁ hatthaṁ pasāremi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:61.4":{"pli":"sabbe gandhā upenti maṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap1:62.1":{"pli":"Pathabyā pabbate ceva, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap1:62.2":{"pli":"ākāse udake vane; ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:62.3":{"pli":"Yaṁ yaṁ hatthaṁ pasāremi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:62.4":{"pli":"sabbe yānā upenti maṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap1:63.1":{"pli":"Pathabyā pabbate ceva, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap1:63.2":{"pli":"ākāse udake vane; ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:63.3":{"pli":"Yaṁ yaṁ hatthaṁ pasāremi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap1:63.4":{"pli":"sabbe mālā upenti maṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap1:64.1":{"pli":"Pathabyā pabbate ce