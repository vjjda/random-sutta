{"tha-ap299":{"tha-ap299:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap299'><header><ul><li class='division'>{}</li>"},"tha-ap299:0.2":{"pli":"Citakapūjakavagga ","html":"<li>{}</li></ul>"},"tha-ap299:0.3":{"pli":"7 Desakittakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap299:1.1":{"pli":"“Upasālakanāmohaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap299:1.2":{"pli":"ahosiṁ brāhmaṇo tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap299:1.3":{"pli":"Kānanaṁ vanamogāḷhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap299:1.4":{"pli":"lokajeṭṭhaṁ narāsabhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap299:2.1":{"pli":"Disvāna vandiṁ pādesu, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap299:2.2":{"pli":"lokāhutipaṭiggahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap299:2.3":{"pli":"Pasannacittaṁ maṁ ñatvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap299:2.4":{"pli":"buddho antaradhāyatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap299:3.1":{"pli":"Kānanā abhinikkhamma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap299:3.2":{"pli":"buddhaseṭṭhamanussariṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap299:3.3":{"pli":"Taṁ desaṁ kittayitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap299:3.4":{"pli":"kappaṁ saggamhi modahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap299:4.1":{"pli":"Dvenavute ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap299:4.2":{"pli":"yaṁ desamabhikittayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap299:4.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap299:4.4":{"pli":"kittanāya idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap299:5.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap299:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap299:5.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap299:6.1":{"pli":"Itthaṁ sudaṁ āyasmā desakittako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap299:7.1":{"pli":"Desakittakattherassāpadānaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}