alahatthiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap105:1.1":{"pli":"“Tivarāyaṁ nivāsīhaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap105:1.2":{"pli":"ahosiṁ māliko tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap105:1.3":{"pli":"Addasaṁ virajaṁ buddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap105:1.4":{"pli":"siddhatthaṁ lokapūjitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap105:2.1":{"pli":"Pasannacitto sumano, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap105:2.2":{"pli":"pupphahatthamadāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap105:2.3":{"pli":"Yattha yatthupapajjāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap105:2.4":{"pli":"tassa kammassa vāhasā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap105:3.1":{"pli":"Anubhomi phalaṁ iṭṭhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap105:3.2":{"pli":"pubbe sukatamattano; ","html":"<span class='verse-line'>{}</span>"},"tha-ap105:3.3":{"pli":"Parikkhitto sumallehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap105:3.4":{"pli":"pupphadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap105:4.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap105:4.2":{"pli":"yaṁ pupphamabhiropayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap105:4.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap105:4.4":{"pli":"pupphapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap105:5.1":{"pli":"Catunnavutupādāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap105:5.2":{"pli":"ṭhapetvā vattamānakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap105:5.3":{"pli":"Pañcarājasatā tattha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap105:5.4":{"pli":"najjasamasanāmakā. ","html":"<span class='verse-line'>{}</spa