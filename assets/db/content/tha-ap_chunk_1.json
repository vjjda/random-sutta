pan class='verse-line'>{}</span>"},"tha-ap108:2.2":{"pli":"ākāse ukkhipiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap108:2.3":{"pli":"Sampaṭicchi mahāvīro, ","html":"<span class='verse-line'>{}</span>"},"tha-ap108:2.4":{"pli":"buddho kāruṇiko isi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap108:3.1":{"pli":"Antalikkhe ṭhito satthā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap108:3.2":{"pli":"padumuttaranāmako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap108:3.3":{"pli":"Mama saṅkappamaññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap108:3.4":{"pli":"imaṁ gāthaṁ abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap108:4.1":{"pli":"‘Iminā dakadānena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap108:4.2":{"pli":"pītiuppādanena ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap108:4.3":{"pli":"Kappasatasahassampi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap108:4.4":{"pli":"duggatiṁ nupapajjati’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap108:5.1":{"pli":"Tena kammena dvipadinda, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap108:5.2":{"pli":"lokajeṭṭha narāsabha; ","html":"<span class='verse-line'>{}</span>"},"tha-ap108:5.3":{"pli":"Pattomhi acalaṁ ṭhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap108:5.4":{"pli":"hitvā jayaparājayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap108:6.1":{"pli":"Sahassarājanāmena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap108:6.2":{"pli":"tayo te cakkavattino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap108:6.3":{"pli":"Pañcasaṭṭhikappasate, ","html":"<span class='verse-line'>{}</span>"},"tha-ap108:6.4":{"pli":"cāturantā janādhipā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap108:7.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap108:7.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap108:7.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap108:8.1":{"pli":"Itthaṁ sudaṁ āyasmā udakapūjako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap108:9.1":{"pli":"Udakapūjakattherassāpadānaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap109":{"tha-ap109:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap109'><header><ul><li class='division'>{}</li>"},"tha-ap109:0.2":{"pli":"Bhikkhadāyivagga ","html":"<li>{}</li></ul>"},"tha-ap109:0.3":{"pli":"Naḷamāliyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap109:1.1":{"pli":"“Padumuttarabuddhassa, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap109:1.2":{"pli":"lokajeṭṭhassa tādino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap109:1.3":{"pli":"Tiṇatthare nisinnassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap109:1.4":{"pli":"upasantassa tādino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap109:2.1":{"pli":"Naḷamālaṁ gahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap109:2.2":{"pli":"bandhitvā bījaniṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap109:2.3":{"pli":"Buddhassa upanāmesiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap109:2.4":{"pli":"dvipadindassa tādino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap109:3.1":{"pli":"Paṭiggahetvā sabbaññū, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap109:3.2":{"pli":"bījaniṁ lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap109:3.3":{"pli":"Mama saṅkappamaññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap109:3.4":{"pli":"imaṁ gāthaṁ abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap109:4.1":{"pli":"‘Yathā me kāyo nibbāti, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap109:4.2":{"pli":"pariḷāho na vijjati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap109:4.3":{"pli":"Tatheva tividhaggīhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap109:4.4":{"pli":"cittaṁ tava vimuccatu’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap109:5.1":{"pli":"Sabbe devā samāgacchuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap109:5.2":{"pli":"ye keci vananissitā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap109:5.3":{"pli":"Sossāma buddhavacanaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap109:5.4":{"pli":"hāsayantañca dāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap109:6.1":{"pli":"Nisinno bhagavā tattha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap109:6.2":{"pli":"devasaṅghapurakkhato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap109:6.3":{"pli":"Dāyakaṁ sampahaṁsento, ","html":"<span class='verse-line'>{}</span>"},"tha-ap109:6.4":{"pli":"imā gāthā abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap109:7.1":{"pli":"‘Iminā bījanidānena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap109:7.2":{"pli":"cittassa paṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap109:7.3":{"pli":"Subbato nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap109:7.4":{"pli":"cakkavattī bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap109:8.1":{"pli":"Tena kammāvasesena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap109:8.2":{"pli":"sukkamūlena codito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap109:8.3":{"pli":"Māluto nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap109:8.4":{"pli":"cakkavattī bhavissati’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap109:9.1":{"pli":"Iminā bījanidānena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap109:9.2":{"pli":"sammānavipulena ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap109:9.3":{"pli":"Kappasatasahassampi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap109:9.4":{"pli":"duggatiṁ nupapajjati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap109:10.1":{"pli":"Tiṁsakappasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap109:10.2":{"pli":"subbatā aṭṭhatiṁsa te; ","html":"<span class='verse-line'>{}</span>"},"tha-ap109:10.3":{"pli":"Ekūnatiṁsasahasse, ","html":"<span class='verse-line'>{}</span>"},"tha-ap109:10.4":{"pli":"aṭṭha mālutanāmakā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap109:11.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap109:11.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap109:11.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap109:12.1":{"pli":"Itthaṁ sudaṁ āyasmā naḷamāliyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap109:13.1":{"pli":"Naḷamāliyattherassāpadānaṁ sattamaṁ. ","html":"<p class='endsutta'>{}<br>"},"tha-ap109:13.2":{"pli":"Sattamabhāṇavāraṁ. ","html":"{}</p></article>"}},"tha-ap11":{"tha-ap11:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap11'><header><ul><li class='division'>{}</li>"},"tha-ap11:0.2":{"pli":"Buddhavagga ","html":"<li>{}</li></ul>"},"tha-ap11:0.3":{"pli":"Khadiravaniyarevatattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap11:1.1":{"pli":"“Gaṅgā bhāgīrathī nāma, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap11:1.2":{"pli":"himavantā pabhāvitā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:1.3":{"pli":"Kutitthe nāviko āsiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:1.4":{"pli":"orime ca tariṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap11:2.1":{"pli":"Padumuttaro nāyako, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap11:2.2":{"pli":"sambuddho dvipaduttamo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:2.3":{"pli":"Vasī satasahassehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:2.4":{"pli":"gaṅgātīramupāgato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap11:3.1":{"pli":"Bahū nāvā samānetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap11:3.2":{"pli":"vaḍḍhakīhi susaṅkhataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:3.3":{"pli":"Nāvāya chadanaṁ katvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:3.4":{"pli":"paṭimāniṁ narāsabhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap11:4.1":{"pli":"Āgantvāna ca sambuddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap11:4.2":{"pli":"ārūhi tañca nāvakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:4.3":{"pli":"Vārimajjhe ṭhito satthā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:4.4":{"pli":"imā gāthā abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap11:5.1":{"pli":"‘Yo so tāresi sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap11:5.2":{"pli":"saṅghañcāpi anāsavaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:5.3":{"pli":"Tena cittappasādena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:5.4":{"pli":"devaloke ramissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap11:6.1":{"pli":"Nibbattissati te byamhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap11:6.2":{"pli":"sukataṁ nāvasaṇṭhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:6.3":{"pli":"Ākāse pupphachadanaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:6.4":{"pli":"dhārayissati sabbadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap11:7.1":{"pli":"Aṭṭhapaññāsakappamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap11:7.2":{"pli":"tārako nāma khattiyo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:7.3":{"pli":"Cāturanto vijitāvī, ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:7.4":{"pli":"cakkavattī bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap11:8.1":{"pli":"Sattapaññāsakappamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap11:8.2":{"pli":"cammako nāma khattiyo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:8.3":{"pli":"Uggacchantova sūriyo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:8.4":{"pli":"jotissati mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap11:9.1":{"pli":"Kappasatasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap11:9.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:9.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:9.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap11:10.1":{"pli":"Tidasā so cavitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap11:10.2":{"pli":"manussattaṁ gamissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:10.3":{"pli":"Revato nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:10.4":{"pli":"brahmabandhu bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap11:11.1":{"pli":"Agārā nikkhamitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap11:11.2":{"pli":"sukkamūlena codito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:11.3":{"pli":"Gotamassa bhagavato, ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:11.4":{"pli":"sāsane pabbajissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap11:12.1":{"pli":"So pacchā pabbajitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap11:12.2":{"pli":"yuttayogo vipassako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:12.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:12.4":{"pli":"nibbāyissatināsavo’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap11:13.1":{"pli":"Vīriyaṁ me dhuradhorayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap11:13.2":{"pli":"Yogakkhemādhivāhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:13.3":{"pli":"Dhāremi antimaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:13.4":{"pli":"Sammāsambuddhasāsane. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap11:14.1":{"pli":"Satasahasse kataṁ kammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap11:14.2":{"pli":"phalaṁ dassesi me idha; ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:14.3":{"pli":"Sumutto saravegova, ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:14.4":{"pli":"kilese jhāpayī mama. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap11:15.1":{"pli":"Tato maṁ vananirataṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap11:15.2":{"pli":"disvā lokantagū muni; ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:15.3":{"pli":"Vanavāsibhikkhūnaggaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:15.4":{"pli":"paññapesi mahāmati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap11:16.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap11:16.2":{"pli":"vimokkhāpi ca aṭṭhime; ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:16.3":{"pli":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap11:16.4":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap11:17.1":{"pli":"Itthaṁ sudaṁ āyasmā khadiravaniyo revato thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap11:18.1":{"pli":"Khadiravaniyarevatattherassāpadānaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap110":{"tha-ap110:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap110'><header><ul><li class='division'>{}</li>"},"tha-ap110:0.2":{"pli":"Bhikkhadāyivagga ","html":"<li>{}</li></ul>"},"tha-ap110:0.3":{"pli":"8 Āsanupaṭṭhāhakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap110:1.1":{"pli":"“Kānanaṁ vanamogayha, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap110:1.2":{"pli":"appasaddaṁ nirākulaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap110:1.3":{"pli":"Sīhāsanaṁ mayā dinnaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap110:1.4":{"pli":"atthadassissa tādino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap110:2.1":{"pli":"Mālāhatthaṁ gahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap110:2.2":{"pli":"katvā ca naṁ padakkhiṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap110:2.3":{"pli":"Satthāraṁ payirupāsitvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap110:2.4":{"pli":"pakkāmiṁ uttarāmukho. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap110:3.1":{"pli":"Tena kammena dvipadinda, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap110:3.2":{"pli":"lokajeṭṭha narāsabha; ","html":"<span class='verse-line'>{}</span>"},"tha-ap110:3.3":{"pli":"Sannibbāpemi attānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap110:3.4":{"pli":"bhavā sabbe samūhatā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap110:4.1":{"pli":"Aṭṭhārasakappasate, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap110:4.2":{"pli":"yaṁ dānamadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap110:4.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap110:4.4":{"pli":"sīhāsanassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap110:5.1":{"pli":"Ito sattakappasate, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap110:5.2":{"pli":"sannibbāpaka khattiyo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap110:5.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap110:5.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap110:6.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap110:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap110:6.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap110:7.1":{"pli":"Itthaṁ sudaṁ āyasmā āsanupaṭṭhāhako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap110:8.1":{"pli":"Āsanupaṭṭhāhakattherassāpadānaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap111":{"tha-ap111:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap111'><header><ul><li class='division'>{}</li>"},"tha-ap111:0.2":{"pli":"Bhikkhadāyivagga ","html":"<li>{}</li></ul>"},"tha-ap111:0.3":{"pli":"Biḷālidāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap111:1.1":{"pli":"“Himavantassāvidūre, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap111:1.2":{"pli":"vasāmi paṇṇasanthare; ","html":"<span class='verse-line'>{}</span>"},"tha-ap111:1.3":{"pli":"Ghāsesu gedhamāpanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap111:1.4":{"pli":"seyyasīlo cahaṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap111:2.1":{"pli":"Khaṇantālu kalambāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap111:2.2":{"pli":"biḷālitakkalāni ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap111:2.3":{"pli":"Kolaṁ bhallātakaṁ billaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap111:2.4":{"pli":"āhatvā paṭiyāditaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap111:3.1":{"pli":"Padumuttaro lokavidū, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap111:3.2":{"pli":"āhutīnaṁ paṭiggaho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap111:3.3":{"pli":"Mama saṅkappamaññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap111:3.4":{"pli":"āgacchi mama santikaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap111:4.1":{"pli":"Upāgataṁ mahānāgaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap111:4.2":{"pli":"devadevaṁ narāsabhaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap111:4.3":{"pli":"Biḷāliṁ paggahetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap111:4.4":{"pli":"pattamhi okiriṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap111:5.1":{"pli":"Paribhuñji mahāvīro, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap111:5.2":{"pli":"tosayanto mamaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap111:5.3":{"pli":"Paribhuñjitvāna sabbaññū, ","html":"<span class='verse-line'>{}</span>"},"tha-ap111:5.4":{"pli":"imaṁ gāthaṁ abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap111:6.1":{"pli":"‘Sakaṁ cittaṁ pasādetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap111:6.2":{"pli":"biḷāliṁ me adā tuvaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap111:6.3":{"pli":"Kappānaṁ satasahassaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap111:6.4":{"pli":"duggatiṁ nupapajjasi’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap111:7.1":{"pli":"Carimaṁ vattate mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap111:7.2":{"pli":"bhavā sabbe samūhatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap111:7.3":{"pli":"Dhāremi antimaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap111:7.4":{"pli":"sammāsambuddhasāsane. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap111:8.1":{"pli":"Catupaññāsito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap111:8.2":{"pli":"sumekhaliyasavhayo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap111:8.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap111:8.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap111:9.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap111:9.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap111:9.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap111:10.1":{"pli":"Itthaṁ sudaṁ āyasmā biḷālidāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap111:11.1":{"pli":"Biḷālidāyakattherassāpadānaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap112":{"tha-ap112:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap112'><header><ul><li class='division'>{}</li>"},"tha-ap112:0.2":{"pli":"Bhikkhadāyivagga ","html":"<li>{}</li></ul>"},"tha-ap112:0.3":{"pli":"Reṇupūjakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap112:1.1":{"pli":"“Suvaṇṇavaṇṇaṁ sambuddhaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap112:1.2":{"pli":"Sataraṁsiṁva bhāṇumaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap112:1.3":{"pli":"Obhāsentaṁ disā sabbā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap112:1.4":{"pli":"Uḷurājaṁva pūritaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap112:2.1":{"pli":"Purakkhataṁ sāvakehi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap112:2.2":{"pli":"sāgareheva medaniṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap112:2.3":{"pli":"Nāgaṁ paggayha reṇūhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap112:2.4":{"pli":"vipassissābhiropayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap112:3.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap112:3.2":{"pli":"yaṁ reṇumabhiropayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap112:3.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap112:3.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap112:4.1":{"pli":"Paṇṇatālīsito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap112:4.2":{"pli":"reṇu nāmāsi khattiyo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap112:4.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap112:4.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap112:5.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap112:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap112:5.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap112:6.1":{"pli":"Itthaṁ sudaṁ āyasmā reṇupūjako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap112:7.1":{"pli":"Reṇupūjakattherassāpadānaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap112:8.1":{"pli":"Bhikkhadāyivaggo ekādasamo. ","html":"<p class='endsection'>{}</p>"},"tha-ap112:9.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"tha-ap112:10.1":{"pli":"Bhikkhadāyī ñāṇasaññī, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"tha-ap112:10.2":{"pli":"hatthiyo padapūjako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap112:10.3":{"pli":"Muṭṭhipupphī udakado, ","html":"<span class='verse-line'>{}</span>"},"tha-ap112:10.4":{"pli":"naḷamāli upaṭṭhako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap112:10.5":{"pli":"Biḷālidāyī reṇu ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap112:10.6":{"pli":"gāthāyo cha ca saṭṭhi ca. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"tha-ap113":{"tha-ap113:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap113'><header><ul><li class='division'>{}</li>"},"tha-ap113:0.2":{"pli":"Mahāparivāravagga ","html":"<li>{}</li></ul>"},"tha-ap113:0.3":{"pli":"1 Mahāparivārakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap113:1.1":{"pli":"“Vipassī nāma bhagavā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap113:1.2":{"pli":"lokajeṭṭho narāsabho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap113:1.3":{"pli":"Aṭṭhasaṭṭhisahassehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap113:1.4":{"pli":"pāvisi bandhumaṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap113:2.1":{"pli":"Nagarā abhinikkhamma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap113:2.2":{"pli":"agamaṁ dīpacetiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap113:2.3":{"pli":"Addasaṁ virajaṁ buddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap113:2.4":{"pli":"āhutīnaṁ paṭiggahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap113:3.1":{"pli":"Cullāsītisahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap113:3.2":{"pli":"yakkhā mayhaṁ upantike; ","html":"<span class='verse-line'>{}</span>"},"tha-ap113:3.3":{"pli":"Upaṭṭhahanti sakkaccaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap113:3.4":{"pli":"indaṁva tidasā gaṇā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap113:4.1":{"pli":"Bhavanā abhinikkhamma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap113:4.2":{"pli":"dussaṁ paggayhahaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap113:4.3":{"pli":"Sirasā abhivādesiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap113:4.4":{"pli":"tañcādāsiṁ mahesino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap113:5.1":{"pli":"Aho buddhā aho dhammā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap113:5.2":{"pli":"aho no satthu sampadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap113:5.3":{"pli":"Buddhassa ānubhāvena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap113:5.4":{"pli":"vasudhāyaṁ pakampatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap113:6.1":{"pli":"Tañca acchariyaṁ disvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap113:6.2":{"pli":"abbhutaṁ lomahaṁsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap113:6.3":{"pli":"Buddhe cittaṁ pasādemi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap113:6.4":{"pli":"dvipadindamhi tādine. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap113:7.1":{"pli":"Sohaṁ cittaṁ pasādetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap113:7.2":{"pli":"dussaṁ datvāna satthuno; ","html":"<span class='verse-line'>{}</span>"},"tha-ap113:7.3":{"pli":"Saraṇañca upāgacchiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap113:7.4":{"pli":"sāmacco saparijjano. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap113:8.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap113:8.2":{"pli":"yaṁ kammamakariṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap113:8.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap113:8.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap113:9.1":{"pli":"Ito pannarase kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap113:9.2":{"pli":"soḷasāsuṁ suvāhanā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap113:9.3":{"pli":"Sattaratanasampannā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap113:9.4":{"pli":"cakkavattī mahabbalā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap113:10.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap113:10.2":{"pli":"vimokkhāpi ca aṭṭhime; ","html":"<span class='verse-line'>{}</span>"},"tha-ap113:10.3":{"pli":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap113:10.4":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap113:11.1":{"pli":"Itthaṁ sudaṁ āyasmā mahāparivārako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap113:12.1":{"pli":"Mahāparivārakattherassāpadānaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}