:{"pli":"Samantagandhanāmāsuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap106:4.2":{"pli":"terasa cakkavattino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap106:4.3":{"pli":"Ito pañcamake kappe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap106:4.4":{"pli":"cāturantā janādhipā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap106:5.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap106:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap106:5.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap106:6.1":{"pli":"Itthaṁ sudaṁ āyasmā padapūjako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap106:7.1":{"pli":"Padapūjakattherassāpadānaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap107":{"tha-ap107:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap107'><header><ul><li class='division'>{}</li>"},"tha-ap107:0.2":{"pli":"Bhikkhadāyivagga ","html":"<li>{}</li></ul>"},"tha-ap107:0.3":{"pli":"Muṭṭhipupphiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap107:1.1":{"pli":"“Sudassanoti nāmena, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap107:1.2":{"pli":"mālākāro ahaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap107:1.3":{"pli":"Addasaṁ virajaṁ buddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap107:1.4":{"pli":"lokajeṭṭhaṁ narāsabhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap107:2.1":{"pli":"Jātipupphaṁ gahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap107:2.2":{"pli":"pūjayiṁ padumuttaraṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap107:2.3":{"pli":"Visuddhacakkhu sumano, ","html":"<span class='verse-line'>{}</span>"},"tha-ap107:2.4":{"pli":"dibbacakkhuṁ samajjhagaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap107:3.1":{"pli":"Etissā pupphapū