{"ja533":{"ja533:0.1":{"pli":"Jātaka ","html":"<article id='ja533'><header><ul><li class='division'>{}</li>"},"ja533:0.2":{"pli":"Asītinipāta ","html":"<li>{}</li>"},"ja533:0.3":{"pli":"Cūḷahaṁsavagga ","html":"<li>{}</li></ul>"},"ja533:0.4":{"pli":"1 Cūḷahaṁsajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja533:1.1":{"pli":"“Sumukha anupacinantā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja533:1.2":{"pli":"pakkamanti vihaṅgamā; ","html":"<span class='verse-line'>{}</span>"},"ja533:1.3":{"pli":"Gaccha tuvampi mā kaṅkhi, ","html":"<span class='verse-line'>{}</span>"},"ja533:1.4":{"pli":"natthi baddhe sahāyatā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:2.1":{"pli":"“Gacche vāhaṁ na vā gacche, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:2.2":{"pli":"na tena amaro siyaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja533:2.3":{"pli":"Sukhitaṁ taṁ upāsitvā, ","html":"<span class='verse-line'>{}</span>"},"ja533:2.4":{"pli":"dukkhitaṁ taṁ kathaṁ jahe. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:3.1":{"pli":"Maraṇaṁ vā tayā saddhiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:3.2":{"pli":"jīvitaṁ vā tayā vinā; ","html":"<span class='verse-line'>{}</span>"},"ja533:3.3":{"pli":"Tadeva maraṇaṁ seyyo, ","html":"<span class='verse-line'>{}</span>"},"ja533:3.4":{"pli":"yañce jīve tayā vinā. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:4.1":{"pli":"Nesa dhammo mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:4.2":{"pli":"yaṁ taṁ evaṁ gataṁ jahe; ","html":"<span class='verse-line'>{}</span>"},"ja533:4.3":{"pli":"Yā gati tuyhaṁ sā mayhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja533:4.4":{"pli":"ruccate vihagādhipa”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:5.1":{"pli":"“Kā nu pāsena baddhassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:5.2":{"pli":"gati aññā mahānasā; ","html":"<span class='verse-line'>{}</span>"},"ja533:5.3":{"pli":"Sā kathaṁ cetayānassa, ","html":"<span class='verse-line'>{}</span>"},"ja533:5.4":{"pli":"muttassa tava ruccati. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:6.1":{"pli":"Kaṁ vā tvaṁ passase atthaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:6.2":{"pli":"mama tuyhañca pakkhima; ","html":"<span class='verse-line'>{}</span>"},"ja533:6.3":{"pli":"Ñātīnaṁ vāvasiṭṭhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja533:6.4":{"pli":"ubhinnaṁ jīvitakkhaye. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:7.1":{"pli":"Yaṁ na kañcanadepiñcha, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:7.2":{"pli":"Andhena tamasā gataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja533:7.3":{"pli":"Tādise sañcajaṁ pāṇaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja533:7.4":{"pli":"Kamatthamabhijotaye”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:8.1":{"pli":"“Kathaṁ nu patataṁ seṭṭha, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:8.2":{"pli":"Dhamme atthaṁ na bujjhasi; ","html":"<span class='verse-line'>{}</span>"},"ja533:8.3":{"pli":"Dhammo apacito santo, ","html":"<span class='verse-line'>{}</span>"},"ja533:8.4":{"pli":"Atthaṁ dasseti pāṇinaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:9.1":{"pli":"Sohaṁ dhammaṁ apekkhāno, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:9.2":{"pli":"dhammā catthaṁ samuṭṭhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja533:9.3":{"pli":"Bhattiñca tayi sampassaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja533:9.4":{"pli":"nāvakaṅkhāmi jīvitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:10.1":{"pli":"Addhā eso sataṁ dhammo, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:10.2":{"pli":"yo mitto mittamāpade; ","html":"<span class='verse-line'>{}</span>"},"ja533:10.3":{"pli":"Na caje jīvitassāpi, ","html":"<span class='verse-line'>{}</span>"},"ja533:10.4":{"pli":"hetudhammamanussaraṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:11.1":{"pli":"“Svāyaṁ dhammo ca te ciṇṇo, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:11.2":{"pli":"bhatti ca viditā mayi; ","html":"<span class='verse-line'>{}</span>"},"ja533:11.3":{"pli":"Kāmaṁ karassu mayhetaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja533:11.4":{"pli":"gacchevānumato mayā. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:12.1":{"pli":"Api tvevaṁ gate kāle, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:12.2":{"pli":"yaṁ khaṇḍaṁ ñātinaṁ mayā; ","html":"<span class='verse-line'>{}</span>"},"ja533:12.3":{"pli":"Tayā taṁ buddhisampannaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja533:12.4":{"pli":"assa paramasaṁvutaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:13.1":{"pli":"Iccevaṁ mantayantānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:13.2":{"pli":"Ariyānaṁ ariyavuttinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja533:13.3":{"pli":"Paccadissatha nesādo, ","html":"<span class='verse-line'>{}</span>"},"ja533:13.4":{"pli":"Āturānamivantako. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:14.1":{"pli":"Te sattumabhisañcikkha, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:14.2":{"pli":"dīgharattaṁ hitā dijā; ","html":"<span class='verse-line'>{}</span>"},"ja533:14.3":{"pli":"Tuṇhīmāsittha ubhayo, ","html":"<span class='verse-line'>{}</span>"},"ja533:14.4":{"pli":"na sañcalesumāsanā. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:15.1":{"pli":"Dhataraṭṭhe ca disvāna, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:15.2":{"pli":"samuḍḍente tato tato; ","html":"<span class='verse-line'>{}</span>"},"ja533:15.3":{"pli":"Abhikkamatha vegena, ","html":"<span class='verse-line'>{}</span>"},"ja533:15.4":{"pli":"dijasattu dijādhipe. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:16.1":{"pli":"So ca vegenabhikkamma, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:16.2":{"pli":"āsajja parame dije; ","html":"<span class='verse-line'>{}</span>"},"ja533:16.3":{"pli":"Paccakamittha nesādo, ","html":"<span class='verse-line'>{}</span>"},"ja533:16.4":{"pli":"baddhā iti vicintayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:17.1":{"pli":"Ekaṁva baddhamāsīnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:17.2":{"pli":"abaddhañca punāparaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja533:17.3":{"pli":"Āsajja baddhamāsīnaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja533:17.4":{"pli":"pekkhamānamadīnavaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:18.1":{"pli":"Tato so vimatoyeva, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:18.2":{"pli":"paṇḍare ajjhabhāsatha; ","html":"<span class='verse-line'>{}</span>"},"ja533:18.3":{"pli":"Pavaḍḍhakāye āsīne, ","html":"<span class='verse-line'>{}</span>"},"ja533:18.4":{"pli":"dijasaṅghagaṇādhipe. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:19.1":{"pli":"“Yannu pāsena mahatā, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:19.2":{"pli":"baddho na kurute disaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja533:19.3":{"pli":"Atha kasmā abaddho tvaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja533:19.4":{"pli":"balī pakkhi na gacchasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:20.1":{"pli":"Kiṁ nu tyāyaṁ dijo hoti, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:20.2":{"pli":"mutto baddhaṁ upāsasi; ","html":"<span class='verse-line'>{}</span>"},"ja533:20.3":{"pli":"Ohāya sakuṇā yanti, ","html":"<span class='verse-line'>{}</span>"},"ja533:20.4":{"pli":"kiṁ eko avahīyasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:21.1":{"pli":"“Rājā me so dijāmitta, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:21.2":{"pli":"sakhā pāṇasamo ca me; ","html":"<span class='verse-line'>{}</span>"},"ja533:21.3":{"pli":"Neva naṁ vijahissāmi, ","html":"<span class='verse-line'>{}</span>"},"ja533:21.4":{"pli":"yāva kālassa pariyāyaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:22.1":{"pli":"“Kathaṁ panāyaṁ vihaṅgo, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:22.2":{"pli":"nāddasa pāsamoḍḍitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja533:22.3":{"pli":"Padañhetaṁ mahantānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja533:22.4":{"pli":"boddhumarahanti āpadaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:23.1":{"pli":"“Yadā parābhavo hoti, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:23.2":{"pli":"poso jīvitasaṅkhaye; ","html":"<span class='verse-line'>{}</span>"},"ja533:23.3":{"pli":"Atha jālañca pāsañca, ","html":"<span class='verse-line'>{}</span>"},"ja533:23.4":{"pli":"āsajjāpi na bujjhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:24.1":{"pli":"Api tveva mahāpañña, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:24.2":{"pli":"pāsā bahuvidhā tatā; ","html":"<span class='verse-line'>{}</span>"},"ja533:24.3":{"pli":"Guyhamāsajja bajjhanti, ","html":"<span class='verse-line'>{}</span>"},"ja533:24.4":{"pli":"athevaṁ jīvitakkhaye”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:25.1":{"pli":"“Api nāyaṁ tayā saddhiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:25.2":{"pli":"saṁvāsassa sukhudrayo; ","html":"<span class='verse-line'>{}</span>"},"ja533:25.3":{"pli":"Api no anumaññāsi, ","html":"<span class='verse-line'>{}</span>"},"ja533:25.4":{"pli":"api no jīvitaṁ dade”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:26.1":{"pli":"“Na ceva me tvaṁ baddhosi, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:26.2":{"pli":"napi icchāmi te vadhaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja533:26.3":{"pli":"Kāmaṁ khippamito gantvā, ","html":"<span class='verse-line'>{}</span>"},"ja533:26.4":{"pli":"jīva tvaṁ anigho ciraṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:27.1":{"pli":"“Nevāhametamicchāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:27.2":{"pli":"aññatretassa jīvitā; ","html":"<span class='verse-line'>{}</span>"},"ja533:27.3":{"pli":"Sace ekena tuṭṭhosi, ","html":"<span class='verse-line'>{}</span>"},"ja533:27.4":{"pli":"muñcetaṁ mañca bhakkhaya. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:28.1":{"pli":"Ārohapariṇāhena, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:28.2":{"pli":"tulyāsmā vayasā ubho; ","html":"<span class='verse-line'>{}</span>"},"ja533:28.3":{"pli":"Na te lābhena jīvatthi, ","html":"<span class='verse-line'>{}</span>"},"ja533:28.4":{"pli":"etena niminā tuvaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:29.1":{"pli":"Tadiṅgha samapekkhassu, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:29.2":{"pli":"hotu giddhi tavamhasu; ","html":"<span class='verse-line'>{}</span>"},"ja533:29.3":{"pli":"Maṁ pubbe bandha pāsena, ","html":"<span class='verse-line'>{}</span>"},"ja533:29.4":{"pli":"pacchā muñca dijādhipaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:30.1":{"pli":"Tāvadeva ca te lābho, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:30.2":{"pli":"katāssa yācanāya ca; ","html":"<span class='verse-line'>{}</span>"},"ja533:30.3":{"pli":"Mitti ca dhataraṭṭhehi, ","html":"<span class='verse-line'>{}</span>"},"ja533:30.4":{"pli":"yāvajīvāya te siyā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:31.1":{"pli":"“Passantu no mahāsaṅghā, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:31.2":{"pli":"tayā muttaṁ ito gataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja533:31.3":{"pli":"Mittāmaccā ca bhaccā ca, ","html":"<span class='verse-line'>{}</span>"},"ja533:31.4":{"pli":"puttadārā ca bandhavā. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:32.1":{"pli":"Na ca te tādisā mittā, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:32.2":{"pli":"bahūnaṁ idha vijjati; ","html":"<span class='verse-line'>{}</span>"},"ja533:32.3":{"pli":"Yathā tvaṁ dhataraṭṭhassa, ","html":"<span class='verse-line'>{}</span>"},"ja533:32.4":{"pli":"pāṇasādhāraṇo sakhā. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:33.1":{"pli":"So te sahāyaṁ muñcāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:33.2":{"pli":"hotu rājā tavānugo; ","html":"<span class='verse-line'>{}</span>"},"ja533:33.3":{"pli":"Kāmaṁ khippamito gantvā, ","html":"<span class='verse-line'>{}</span>"},"ja533:33.4":{"pli":"ñātimajjhe virocatha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:34.1":{"pli":"“So patīto pamuttena, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:34.2":{"pli":"bhattunā bhattugāravo; ","html":"<span class='verse-line'>{}</span>"},"ja533:34.3":{"pli":"Ajjhabhāsatha vakkaṅgo, ","html":"<span class='verse-line'>{}</span>"},"ja533:34.4":{"pli":"vācaṁ kaṇṇasukhaṁ bhaṇaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:35.1":{"pli":"Evaṁ luddaka nandassu, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:35.2":{"pli":"saha sabbehi ñātibhi; ","html":"<span class='verse-line'>{}</span>"},"ja533:35.3":{"pli":"Yathāhamajja nandāmi, ","html":"<span class='verse-line'>{}</span>"},"ja533:35.4":{"pli":"muttaṁ disvā dijādhipaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:36.1":{"pli":"“Ehi taṁ anusikkhāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:36.2":{"pli":"Yathā tvamapi lacchase; ","html":"<span class='verse-line'>{}</span>"},"ja533:36.3":{"pli":"Lābhaṁ tavāyaṁ dhataraṭṭho, ","html":"<span class='verse-line'>{}</span>"},"ja533:36.4":{"pli":"Pāpaṁ kiñci na dakkhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:37.1":{"pli":"Khippamantepuraṁ netvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:37.2":{"pli":"rañño dassehi no ubho; ","html":"<span class='verse-line'>{}</span>"},"ja533:37.3":{"pli":"Abaddhe pakatibhūte, ","html":"<span class='verse-line'>{}</span>"},"ja533:37.4":{"pli":"kāje ubhayato ṭhite. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:38.1":{"pli":"Dhataraṭṭhā mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:38.2":{"pli":"haṁsādhipatino ime; ","html":"<span class='verse-line'>{}</span>"},"ja533:38.3":{"pli":"Ayañhi rājā haṁsānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja533:38.4":{"pli":"ayaṁ senāpatītaro. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:39.1":{"pli":"Asaṁsayaṁ imaṁ disvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:39.2":{"pli":"haṁsarājaṁ narādhipo; ","html":"<span class='verse-line'>{}</span>"},"ja533:39.3":{"pli":"Patīto sumano vitto, ","html":"<span class='verse-line'>{}</span>"},"ja533:39.4":{"pli":"bahuṁ dassati te dhanaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:40.1":{"pli":"Tassa taṁ vacanaṁ sutvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:40.2":{"pli":"kammunā upapādayi; ","html":"<span class='verse-line'>{}</span>"},"ja533:40.3":{"pli":"Khippamantepuraṁ gantvā, ","html":"<span class='verse-line'>{}</span>"},"ja533:40.4":{"pli":"rañño haṁse adassayi; ","html":"<span class='verse-line'>{}</span>"},"ja533:40.5":{"pli":"Abaddhe pakatibhūte, ","html":"<span class='verse-line'>{}</span>"},"ja533:40.6":{"pli":"kāje ubhayato ṭhite. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:41.1":{"pli":"“Dhataraṭṭhā mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:41.2":{"pli":"haṁsādhipatino ime; ","html":"<span class='verse-line'>{}</span>"},"ja533:41.3":{"pli":"Ayañhi rājā haṁsānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja533:41.4":{"pli":"ayaṁ senāpatītaro”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:42.1":{"pli":"“Kathaṁ panime vihaṅgā, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:42.2":{"pli":"tava hatthattamāgatā; ","html":"<span class='verse-line'>{}</span>"},"ja533:42.3":{"pli":"Kathaṁ luddo mahantānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja533:42.4":{"pli":"issare idha ajjhagā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:43.1":{"pli":"“Vihitā santime pāsā, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:43.2":{"pli":"pallalesu janādhipa; ","html":"<span class='verse-line'>{}</span>"},"ja533:43.3":{"pli":"Yaṁ yadāyatanaṁ maññe, ","html":"<span class='verse-line'>{}</span>"},"ja533:43.4":{"pli":"dijānaṁ pāṇarodhanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:44.1":{"pli":"Tādisaṁ pāsamāsajja, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:44.2":{"pli":"haṁsarājā abajjhatha; ","html":"<span class='verse-line'>{}</span>"},"ja533:44.3":{"pli":"Taṁ abaddho upāsīno, ","html":"<span class='verse-line'>{}</span>"},"ja533:44.4":{"pli":"mamāyaṁ ajjhabhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:45.1":{"pli":"Sudukkaraṁ anariyehi, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:45.2":{"pli":"dahate bhāvamuttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja533:45.3":{"pli":"Bhatturatthe parakkanto, ","html":"<span class='verse-line'>{}</span>"},"ja533:45.4":{"pli":"dhammayutto vihaṅgamo. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:46.1":{"pli":"Attanāyaṁ cajitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:46.2":{"pli":"jīvitaṁ jīvitāraho; ","html":"<span class='verse-line'>{}</span>"},"ja533:46.3":{"pli":"Anutthunanto āsīno, ","html":"<span class='verse-line'>{}</span>"},"ja533:46.4":{"pli":"bhattu yācittha jīvitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:47.1":{"pli":"Tassa taṁ vacanaṁ sutvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:47.2":{"pli":"pasādamahamajjhagā; ","html":"<span class='verse-line'>{}</span>"},"ja533:47.3":{"pli":"Tato naṁ pāmuciṁ pāsā, ","html":"<span class='verse-line'>{}</span>"},"ja533:47.4":{"pli":"anuññāsiṁ sukhena ca. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:48.1":{"pli":"So patīto pamuttena, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:48.2":{"pli":"bhattunā bhattugāravo; ","html":"<span class='verse-line'>{}</span>"},"ja533:48.3":{"pli":"Ajjhabhāsatha vakkaṅgo, ","html":"<span class='verse-line'>{}</span>"},"ja533:48.4":{"pli":"vācaṁ kaṇṇasukhaṁ bhaṇaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:49.1":{"pli":"‘Evaṁ luddaka nandassu, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:49.2":{"pli":"saha sabbehi ñātibhi; ","html":"<span class='verse-line'>{}</span>"},"ja533:49.3":{"pli":"Yathāhamajja nandāmi, ","html":"<span class='verse-line'>{}</span>"},"ja533:49.4":{"pli":"muttaṁ disvā dijādhipaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:50.1":{"pli":"Ehi taṁ anusikkhāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:50.2":{"pli":"yathā tvamapi lacchase; ","html":"<span class='verse-line'>{}</span>"},"ja533:50.3":{"pli":"Lābhaṁ tavāyaṁ dhataraṭṭho, ","html":"<span class='verse-line'>{}</span>"},"ja533:50.4":{"pli":"pāpaṁ kiñci na dakkhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:51.1":{"pli":"Khippamantepuraṁ netvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:51.2":{"pli":"rañño dassehi no ubho; ","html":"<span class='verse-line'>{}</span>"},"ja533:51.3":{"pli":"Abaddhe pakatibhūte, ","html":"<span class='verse-line'>{}</span>"},"ja533:51.4":{"pli":"kāje ubhayato ṭhite. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:52.1":{"pli":"“Dhataraṭṭhā mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:52.2":{"pli":"haṁsādhipatino ime; ","html":"<span class='verse-line'>{}</span>"},"ja533:52.3":{"pli":"Ayañhi rājā haṁsānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja533:52.4":{"pli":"ayaṁ senāpatītaro”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:53.1":{"pli":"Asaṁsayaṁ imaṁ disvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:53.2":{"pli":"haṁsarājaṁ narādhipo; ","html":"<span class='verse-line'>{}</span>"},"ja533:53.3":{"pli":"Patīto sumano vitto, ","html":"<span class='verse-line'>{}</span>"},"ja533:53.4":{"pli":"bahuṁ dassati te dhanaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:54.1":{"pli":"Evametassa vacanā, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:54.2":{"pli":"ānītāme ubho mayā; ","html":"<span class='verse-line'>{}</span>"},"ja533:54.3":{"pli":"Ettheva hi ime āsuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja533:54.4":{"pli":"ubho anumatā mayā. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:55.1":{"pli":"Soyaṁ evaṁ gato pakkhī, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:55.2":{"pli":"dijo paramadhammiko; ","html":"<span class='verse-line'>{}</span>"},"ja533:55.3":{"pli":"Mādisassa hi luddassa, ","html":"<span class='verse-line'>{}</span>"},"ja533:55.4":{"pli":"janayeyyātha maddavaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:56.1":{"pli":"Upāyanañca te deva, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:56.2":{"pli":"nāññaṁ passāmi edisaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja533:56.3":{"pli":"Sabbasākuṇikāgāme, ","html":"<span class='verse-line'>{}</span>"},"ja533:56.4":{"pli":"taṁ passa manujādhipa”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:57.1":{"pli":"Disvā nisinnaṁ rājānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:57.2":{"pli":"pīṭhe sovaṇṇaye subhe; ","html":"<span class='verse-line'>{}</span>"},"ja533:57.3":{"pli":"Ajjhabhāsatha vakkaṅgo, ","html":"<span class='verse-line'>{}</span>"},"ja533:57.4":{"pli":"vācaṁ kaṇṇasukhaṁ bhaṇaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:58.1":{"pli":"“Kaccinnu bhoto kusalaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:58.2":{"pli":"kacci bhoto anāmayaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja533:58.3":{"pli":"Kacci raṭṭhamidaṁ phītaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja533:58.4":{"pli":"dhammena manusāsasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:59.1":{"pli":"“Kusalañceva me haṁsa, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:59.2":{"pli":"Atho haṁsa anāmayaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja533:59.3":{"pli":"Atho raṭṭhamidaṁ phītaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja533:59.4":{"pli":"Dhammena manusāsahaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:60.1":{"pli":"“Kacci bhoto amaccesu, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:60.2":{"pli":"doso koci na vijjati; ","html":"<span class='verse-line'>{}</span>"},"ja533:60.3":{"pli":"Kacci ca te tavatthesu, ","html":"<span class='verse-line'>{}</span>"},"ja533:60.4":{"pli":"nāvakaṅkhanti jīvitaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:61.1":{"pli":"“Athopi me amaccesu, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:61.2":{"pli":"doso koci na vijjati; ","html":"<span class='verse-line'>{}</span>"},"ja533:61.3":{"pli":"Athopi te mamatthesu, ","html":"<span class='verse-line'>{}</span>"},"ja533:61.4":{"pli":"nāvakaṅkhanti jīvitaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:62.1":{"pli":"“Kacci te sādisī bhariyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:62.2":{"pli":"assavā piyabhāṇinī; ","html":"<span class='verse-line'>{}</span>"},"ja533:62.3":{"pli":"Puttarūpayasūpetā, ","html":"<span class='verse-line'>{}</span>"},"ja533:62.4":{"pli":"tava chandavasānugā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:63.1":{"pli":"“Atho me sādisī bhariyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:63.2":{"pli":"assavā piyabhāṇinī; ","html":"<span class='verse-line'>{}</span>"},"ja533:63.3":{"pli":"Puttarūpayasūpetā, ","html":"<span class='verse-line'>{}</span>"},"ja533:63.4":{"pli":"mama chandavasānugā. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:64.1":{"pli":"Bhavantaṁ kacci nu mahā- ","html":"<p><span class='verse-line'>{}</span>"},"ja533:64.2":{"pli":"sattuhatthattataṁ gato; ","html":"<span class='verse-line'>{}</span>"},"ja533:64.3":{"pli":"Dukkhamāpajji vipulaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja533:64.4":{"pli":"tasmiṁ paṭhamamāpade. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:65.1":{"pli":"Kacci yantāpatitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:65.2":{"pli":"daṇḍena samapothayi; ","html":"<span class='verse-line'>{}</span>"},"ja533:65.3":{"pli":"Evametesaṁ jammānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja533:65.4":{"pli":"pātikaṁ bhavati tāvade”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:66.1":{"pli":"“Khemamāsi mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:66.2":{"pli":"evamāpadiyā sati; ","html":"<span class='verse-line'>{}</span>"},"ja533:66.3":{"pli":"Na cāyaṁ kiñci rasmāsu, ","html":"<span class='verse-line'>{}</span>"},"ja533:66.4":{"pli":"sattūva samapajjatha. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:67.1":{"pli":"Paccagamittha nesādo, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:67.2":{"pli":"pubbeva ajjhabhāsatha; ","html":"<span class='verse-line'>{}</span>"},"ja533:67.3":{"pli":"Tadāyaṁ sumukhoyeva, ","html":"<span class='verse-line'>{}</span>"},"ja533:67.4":{"pli":"paṇḍito paccabhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:68.1":{"pli":"Tassa taṁ vacanaṁ sutvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:68.2":{"pli":"pasādamayamajjhagā; ","html":"<span class='verse-line'>{}</span>"},"ja533:68.3":{"pli":"Tato maṁ pāmucī pāsā, ","html":"<span class='verse-line'>{}</span>"},"ja533:68.4":{"pli":"anuññāsi sukhena ca. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:69.1":{"pli":"Idañca sumukheneva, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:69.2":{"pli":"etadatthāya cintitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja533:69.3":{"pli":"Bhoto sakāsegamanaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja533:69.4":{"pli":"etassa dhanamicchatā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:70.1":{"pli":"“Svāgatañcevidaṁ bhavataṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:70.2":{"pli":"patīto casmi dassanā; ","html":"<span class='verse-line'>{}</span>"},"ja533:70.3":{"pli":"Eso cāpi bahuṁ vittaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja533:70.4":{"pli":"labhataṁ yāvadicchati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:71.1":{"pli":"Santappayitvā nesādaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:71.2":{"pli":"bhogehi manujādhipo; ","html":"<span class='verse-line'>{}</span>"},"ja533:71.3":{"pli":"Ajjhabhāsatha vakkaṅgaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja533:71.4":{"pli":"vācaṁ kaṇṇasukhaṁ bhaṇaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:72.1":{"pli":"“Yaṁ khalu dhammamādhīnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:72.2":{"pli":"vaso vattati kiñcanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja533:72.3":{"pli":"Sabbatthissariyaṁ tava, ","html":"<span class='verse-line'>{}</span>"},"ja533:72.4":{"pli":"taṁ pasāsa yadicchatha. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:73.1":{"pli":"Dānatthaṁ upabhottuṁ vā, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:73.2":{"pli":"yaṁ caññaṁ upakappati; ","html":"<span class='verse-line'>{}</span>"},"ja533:73.3":{"pli":"Etaṁ dadāmi vo vittaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja533:73.4":{"pli":"issariyaṁ vissajāmi vo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:74.1":{"pli":"“Yathā ca myāyaṁ sumukho, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:74.2":{"pli":"ajjhabhāseyya paṇḍito; ","html":"<span class='verse-line'>{}</span>"},"ja533:74.3":{"pli":"Kāmasā buddhisampanno, ","html":"<span class='verse-line'>{}</span>"},"ja533:74.4":{"pli":"taṁ myāssa paramappiyaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:75.1":{"pli":"“Ahaṁ khalu mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:75.2":{"pli":"nāgarājārivantaraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja533:75.3":{"pli":"Paṭivattuṁ na sakkomi, ","html":"<span class='verse-line'>{}</span>"},"ja533:75.4":{"pli":"na me so vinayo siyā. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:76.1":{"pli":"Amhākañceva so seṭṭho, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:76.2":{"pli":"tvañca uttamasattavo; ","html":"<span class='verse-line'>{}</span>"},"ja533:76.3":{"pli":"Bhūmipālo manussindo, ","html":"<span class='verse-line'>{}</span>"},"ja533:76.4":{"pli":"pūjā bahūhi hetuhi. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:77.1":{"pli":"Tesaṁ ubhinnaṁ bhaṇataṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:77.2":{"pli":"vattamāne vinicchaye; ","html":"<span class='verse-line'>{}</span>"},"ja533:77.3":{"pli":"Nantaraṁ paṭivattabbaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja533:77.4":{"pli":"pessena manujādhipa”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:78.1":{"pli":"“Dhammena kira nesādo, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:78.2":{"pli":"paṇḍito aṇḍajo iti; ","html":"<span class='verse-line'>{}</span>"},"ja533:78.3":{"pli":"Na heva akatattassa, ","html":"<span class='verse-line'>{}</span>"},"ja533:78.4":{"pli":"nayo etādiso siyā. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:79.1":{"pli":"Evaṁ aggapakatimā, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:79.2":{"pli":"evaṁ uttamasattavo; ","html":"<span class='verse-line'>{}</span>"},"ja533:79.3":{"pli":"Yāvatatthi mayā diṭṭhā, ","html":"<span class='verse-line'>{}</span>"},"ja533:79.4":{"pli":"nāññaṁ passāmi edisaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:80.1":{"pli":"Tuṭṭhosmi vo pakatiyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:80.2":{"pli":"vākyena madhurena ca; ","html":"<span class='verse-line'>{}</span>"},"ja533:80.3":{"pli":"Eso cāpi mamacchando, ","html":"<span class='verse-line'>{}</span>"},"ja533:80.4":{"pli":"ciraṁ passeyya vo ubho”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:81.1":{"pli":"“Yaṁ kiccaṁ parame mitte, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:81.2":{"pli":"katamasmāsu taṁ tayā; ","html":"<span class='verse-line'>{}</span>"},"ja533:81.3":{"pli":"Pattā nissaṁsayaṁ tyāmhā, ","html":"<span class='verse-line'>{}</span>"},"ja533:81.4":{"pli":"bhattirasmāsu yā tava. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:82.1":{"pli":"Aduñca nūna sumahā, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:82.2":{"pli":"ñātisaṅghassa mantaraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja533:82.3":{"pli":"Adassanena asmākaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja533:82.4":{"pli":"dukkhaṁ bahūsu pakkhisu. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:83.1":{"pli":"Tesaṁ sokavighātāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:83.2":{"pli":"Tayā anumatā mayaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja533:83.3":{"pli":"Taṁ padakkhiṇato katvā, ","html":"<span class='verse-line'>{}</span>"},"ja533:83.4":{"pli":"Ñātiṁ passemurindama. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:84.1":{"pli":"Addhāhaṁ vipulaṁ pītiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:84.2":{"pli":"bhavataṁ vindāmi dassanā; ","html":"<span class='verse-line'>{}</span>"},"ja533:84.3":{"pli":"Eso cāpi mahā attho, ","html":"<span class='verse-line'>{}</span>"},"ja533:84.4":{"pli":"ñātivissāsanā siyā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:85.1":{"pli":"Idaṁ vatvā dhataraṭṭho, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:85.2":{"pli":"haṁsarājā narādhipaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja533:85.3":{"pli":"Uttamaṁ javamanvāya, ","html":"<span class='verse-line'>{}</span>"},"ja533:85.4":{"pli":"ñātisaṅghaṁ upāgamuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:86.1":{"pli":"Te aroge anuppatte, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:86.2":{"pli":"disvāna parame dije; ","html":"<span class='verse-line'>{}</span>"},"ja533:86.3":{"pli":"Kekāti makaruṁ haṁsā, ","html":"<span class='verse-line'>{}</span>"},"ja533:86.4":{"pli":"puthusaddo ajāyatha. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:87.1":{"pli":"Te patītā pamuttena, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:87.2":{"pli":"bhattunā bhattugāravā; ","html":"<span class='verse-line'>{}</span>"},"ja533:87.3":{"pli":"Samantā parikiriṁsu, ","html":"<span class='verse-line'>{}</span>"},"ja533:87.4":{"pli":"aṇḍajā laddhapaccayā. ","html":"<span class='verse-line'>{}</span></p>"},"ja533:88.1":{"pli":"Evaṁ mittavataṁ atthā, ","html":"<p><span class='verse-line'>{}</span>"},"ja533:88.2":{"pli":"sabbe honti padakkhiṇā; ","html":"<span class='verse-line'>{}</span>"},"ja533:88.3":{"pli":"Haṁsā yathā dhataraṭṭhā, ","html":"<span class='verse-line'>{}</span>"},"ja533:88.4":{"pli":"ñātisaṅghaṁ upāgamunti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja533:89.1":{"pli":"Cūḷahaṁsajātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}