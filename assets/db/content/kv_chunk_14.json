{"kv17.1":{"kv17.1:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv17.1'><header><ul><li class='division'>{}</li>"},"kv17.1:0.2":{"pli":"Niggahapaṇṇāsaka ","html":"<li>{}</li>"},"kv17.1:0.3":{"pli":"Sattarasamavagga ","html":"<li>{}</li></ul>"},"kv17.1:0.4":{"pli":"Atthiarahatopuññūpacayotikathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv17.1:1.1":{"pli":"Atthi arahato puññūpacayoti? ","html":"<p data-doxy='orthodox'>{}"},"kv17.1:1.2":{"pli":"Āmantā. ","html":"{}"},"kv17.1:1.3":{"pli":"Atthi arahato apuññūpacayoti? ","html":"{}"},"kv17.1:1.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv17.1:1.5":{"pli":"natthi arahato apuññūpacayoti? ","html":"{}"},"kv17.1:1.6":{"pli":"Āmantā. ","html":"{}"},"kv17.1:1.7":{"pli":"Natthi arahato puññūpacayoti? ","html":"{}"},"kv17.1:1.8":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv17.1:2.1":{"pli":"Atthi arahato puññūpacayoti? ","html":"<p data-doxy='orthodox'>{}"},"kv17.1:2.2":{"pli":"Āmantā. ","html":"{}"},"kv17.1:2.3":{"pli":"Arahā puññābhisaṅkhāraṁ abhisaṅkharoti, āneñjābhisaṅkhāraṁ abhisaṅkharoti, gatisaṁvattaniyaṁ kammaṁ karoti, bhavasaṁvattaniyaṁ kammaṁ karoti, issariyasaṁvattaniyaṁ kammaṁ karoti, adhipaccasaṁvattaniyaṁ kammaṁ karoti, mahābhogasaṁvattaniyaṁ kammaṁ karoti, mahāparivārasaṁvattaniyaṁ kammaṁ karoti, devasobhagyasaṁvattaniyaṁ kammaṁ karoti, manussasobhagyasaṁvattaniyaṁ kammaṁ karotīti? ","html":"{}"},"kv17.1:2.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv17.1:3.1":{"pli":"Atthi arahato puññūpacayoti? ","html":"<p data-doxy='orthodox'>{}"},"kv17.1:3.2":{"pli":"Āmantā. ","html":"{}"},"kv17.1:3.3":{"pli":"Arahā ācinātīti? ","html":"{}"},"kv17.1:3.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv17.1:3.5":{"pli":"arahā apacinātīti? ","html":"{}"},"kv17.1:3.6":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv17.1:3.7":{"pli":"arahā pajahatīti …pe… ","html":"{}"},"kv17.1:3.8":{"pli":"arahā upādiyatīti …pe… ","html":"{}"},"kv17.1:3.9":{"pli":"arahā visinetīti …pe… ","html":"{}"},"kv17.1:3.10":{"pli":"arahā ussinetīti …pe… ","html":"{}"},"kv17.1:3.11":{"pli":"arahā vidhūpetīti …pe… ","html":"{}"},"kv17.1:3.12":{"pli":"arahā sandhūpetīti? ","html":"{}"},"kv17.1:3.13":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv17.1:3.14":{"pli":"nanu arahā nevācināti na apacināti apacinitvā ṭhitoti? ","html":"{}"},"kv17.1:3.15":{"pli":"Āmantā. ","html":"{}"},"kv17.1:3.16":{"pli":"Hañci arahā nevācināti nāpacināti apacinitvā ṭhito, no ca vata re vattabbe—","html":"{}"},"kv17.1:3.17":{"pli":"“atthi arahato puññūpacayo”ti. ","html":"{}</p>"},"kv17.1:4.1":{"pli":"Nanu arahā neva pajahati na upādiyati pajahitvā ṭhito, neva visineti na ussineti visinetvā ṭhito, neva vidhūpeti na sandhūpeti vidhūpetvā ṭhitoti? ","html":"<p data-doxy='orthodox'>{}"},"kv17.1:4.2":{"pli":"Āmantā. ","html":"{}"},"kv17.1:4.3":{"pli":"Hañci arahā neva vidhūpeti na sandhūpeti vidhūpetvā ṭhito, no ca vata re vattabbe—","html":"{}"},"kv17.1:4.4":{"pli":"“atthi arahato puññūpacayo”ti. ","html":"{}</p>"},"kv17.1:5.1":{"pli":"Natthi arahato puññūpacayoti? ","html":"<p data-doxy='heterodox'>{}"},"kv17.1:5.2":{"pli":"Āmantā. ","html":"{}"},"kv17.1:5.3":{"pli":"Arahā dānaṁ dadeyyāti? ","html":"{}"},"kv17.1:5.4":{"pli":"Āmantā. ","html":"{}"},"kv17.1:5.5":{"pli":"Hañci arahā dānaṁ dadeyya, no ca vata re vattabbe—","html":"{}"},"kv17.1:5.6":{"pli":"“natthi arahato puññūpacayo”ti. ","html":"{}</p>"},"kv17.1:6.1":{"pli":"Arahā cīvaraṁ dadeyya …pe… ","html":"<p data-doxy='heterodox'>{}"},"kv17.1:6.2":{"pli":"piṇḍapātaṁ dadeyya … ","html":"{}"},"kv17.1:6.3":{"pli":"senāsanaṁ dadeyya … ","html":"{}"},"kv17.1:6.4":{"pli":"gilānapaccayabhesajjaparikkhāraṁ dadeyya … ","html":"{}"},"kv17.1:6.5":{"pli":"khādanīyaṁ dadeyya … ","html":"{}"},"kv17.1:6.6":{"pli":"bhojanīyaṁ dadeyya … ","html":"{}"},"kv17.1:6.7":{"pli":"pānīyaṁ dadeyya … ","html":"{}"},"kv17.1:6.8":{"pli":"cetiyaṁ vandeyya … ","html":"{}"},"kv17.1:6.9":{"pli":"cetiye mālaṁ āropeyya … ","html":"{}"},"kv17.1:6.10":{"pli":"gandhaṁ āropeyya … ","html":"{}"},"kv17.1:6.11":{"pli":"vilepanaṁ āropeyya …pe… ","html":"{}"},"kv17.1:6.12":{"pli":"cetiyaṁ abhidakkhiṇaṁ kareyyāti? ","html":"{}"},"kv17.1:6.13":{"pli":"Āmantā. ","html":"{}"},"kv17.1:6.14":{"pli":"Hañci arahā cetiyaṁ abhidakkhiṇaṁ kareyya, no ca vata re vattabbe—","html":"{}"},"kv17.1:6.15":{"pli":"“natthi arahato puññūpacayo”ti. ","html":"{}</p>"},"kv17.1:6.16":{"pli":"Atthi arahato puññūpacayotikathā niṭṭhitā. ","html":"<p class='endsutta'>{}</p></article>"}},"kv17.10":{"kv17.10:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv17.10'><header><ul><li class='division'>{}</li>"},"kv17.10:0.2":{"pli":"Mahāpaṇṇāsaka ","html":"<li>{}</li>"},"kv17.10:0.3":{"pli":"Sattarasamavagga ","html":"<li>{}</li></ul>"},"kv17.10:0.4":{"pli":"Navattabbaṁbuddhassadinnaṁmahapphalantikathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv17.10:1.1":{"pli":"Na vattabbaṁ—","html":"<p data-doxy='orthodox'>{}"},"kv17.10:1.2":{"pli":"“buddhassa dinnaṁ mahapphalan”ti? ","html":"{}"},"kv17.10:1.3":{"pli":"Āmantā. ","html":"{}"},"kv17.10:1.4":{"pli":"Nanu bhagavā dvipadānaṁ aggo, dvipadānaṁ seṭṭho, dvipadānaṁ pamokkho, dvipadānaṁ uttamo, dvipadānaṁ pavaro asamo asamasamo appaṭisamo appaṭibhāgo appaṭipuggaloti? ","html":"{}"},"kv17.10:1.5":{"pli":"Āmantā. ","html":"{}"},"kv17.10:1.6":{"pli":"Hañci bhagavā dvipadānaṁ aggo, dvipadānaṁ seṭṭho, dvipadānaṁ pamokkho, dvipadānaṁ uttamo, dvipadānaṁ pavaro asamo asamasamo appaṭisamo appaṭibhāgo appaṭipuggalo, tena vata re vattabbe—","html":"{}"},"kv17.10:1.7":{"pli":"“buddhassa dinnaṁ mahapphalan”ti. ","html":"{}</p>"},"kv17.10:2.1":{"pli":"Na vattabbaṁ—","html":"<p data-doxy='orthodox'>{}"},"kv17.10:2.2":{"pli":"“buddhassa dinnaṁ mahapphalan”ti? ","html":"{}"},"kv17.10:2.3":{"pli":"Āmantā. ","html":"{}"},"kv17.10:2.4":{"pli":"Atthi koci buddhena samasamo—","html":"{}"},"kv17.10:2.5":{"pli":"sīlena samādhinā paññāyāti? ","html":"{}"},"kv17.10:2.6":{"pli":"Natthi. ","html":"{}"},"kv17.10:2.7":{"pli":"Hañci natthi koci buddhena samasamo—","html":"{}"},"kv17.10:2.8":{"pli":"sīlena samādhinā paññāya, tena vata re vattabbe—","html":"{}"},"kv17.10:2.9":{"pli":"“buddhassa dinnaṁ mahapphalan”ti. ","html":"{}</p>"},"kv17.10:3.1":{"pli":"Na vattabbaṁ—","html":"<p data-doxy='orthodox'>{}"},"kv17.10:3.2":{"pli":"“buddhassa dinnaṁ mahapphalan”ti? ","html":"{}"},"kv17.10:3.3":{"pli":"Āmantā. ","html":"{}"},"kv17.10:3.4":{"pli":"Nanu vuttaṁ bhagavatā—","html":"{}</p>"},"kv17.10:4.1":{"pli":"“Nayimasmiṁ vā loke parasmiṁ vā pana, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"kv17.10:4.2":{"pli":"Buddhena seṭṭho ca samo ca vijjati; ","html":"<span class='verse-line'>{}</span>"},"kv17.10:4.3":{"pli":"Yamāhuneyyānaṁ aggataṁ gato, ","html":"<span class='verse-line'>{}</span>"},"kv17.10:4.4":{"pli":"Puññatthikānaṁ vipulapphalesinan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"kv17.10:5.1":{"pli":"Attheva suttantoti? ","html":"<p>{}"},"kv17.10:5.2":{"pli":"Āmantā. ","html":"{}"},"kv17.10:5.3":{"pli":"Tena hi buddhassa dinnaṁ mahapphalanti. ","html":"{}</p>"},"kv17.10:5.4":{"pli":"Na vattabbaṁ buddhassa dinnaṁ mahapphalantikathā niṭṭhitā. ","html":"<p class='endsutta'>{}</p></article>"}},"kv17.11":{"kv17.11:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv17.11'><header><ul><li class='division'>{}</li>"},"kv17.11:0.2":{"pli":"Mahāpaṇṇāsaka ","html":"<li>{}</li>"},"kv17.11:0.3":{"pli":"Sattarasamavagga ","html":"<li>{}</li></ul>"},"kv17.11:0.4":{"pli":"Dakkhiṇāvisuddhikathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv17.11:1.1":{"pli":"Dāyakatova dānaṁ visujjhati, no paṭiggāhakatoti? ","html":"<p data-doxy='orthodox'>{}"},"kv17.11:1.2":{"pli":"Āmantā. ","html":"{}"},"kv17.11:1.3":{"pli":"Nanu atthi keci paṭiggāhakā āhuneyyā pāhuneyyā dakkhiṇeyyā añjalikaraṇīyā anuttaraṁ puññakkhettaṁ lokassāti? ","html":"{}"},"kv17.11:1.4":{"pli":"Āmantā. ","html":"{}"},"kv17.11:1.5":{"pli":"Hañci atthi keci paṭiggāhakā āhuneyyā pāhuneyyā dakkhiṇeyyā añjalikaraṇīyā anuttaraṁ puññakkhettaṁ lokassa, no ca vata re vattabbe—","html":"{}"},"kv17.11:1.6":{"pli":"“dāyakatova dānaṁ visujjhati, no paṭiggāhakato”ti. ","html":"{}</p>"},"kv17.11:2.1":{"pli":"Dāyakatova dānaṁ visujjhati, no paṭiggāhakatoti? ","html":"<p data-doxy='orthodox'>{}"},"kv17.11:2.2":{"pli":"Āmantā. ","html":"{}"},"kv17.11:2.3":{"pli":"Nanu cattāro purisayugā aṭṭha purisapuggalā dakkhiṇeyyā vuttā bhagavatāti? ","html":"{}"},"kv17.11:2.4":{"pli":"Āmantā. ","html":"{}"},"kv17.11:2.5":{"pli":"Hañci cattāro purisayugā aṭṭha purisapuggalā dakkhiṇeyyā vuttā bhagavatā, no ca vata re vattabbe—","html":"{}"},"kv17.11:2.6":{"pli":"“dāyakatova dānaṁ visujjhati, no paṭiggāhakato”ti. ","html":"{}</p>"},"kv17.11:3.1":{"pli":"Dāyakatova dānaṁ visujjhati, no paṭiggāhakatoti? ","html":"<p data-doxy='orthodox'>{}"},"kv17.11:3.2":{"pli":"Āmantā. ","html":"{}"},"kv17.11:3.3":{"pli":"Nanu atthi keci sotāpanne dānaṁ datvā dakkhiṇaṁ ārādhentīti? ","html":"{}"},"kv17.11:3.4":{"pli":"Āmantā. ","html":"{}"},"kv17.11:3.5":{"pli":"Hañci atthi keci sotāpanne dānaṁ datvā dakkhiṇaṁ ārādhenti, no ca vata re vattabbe—","html":"{}"},"kv17.11:3.6":{"pli":"“dāyakatova dānaṁ visujjhati, no paṭiggāhakato”ti. ","html":"{}</p>"},"kv17.11:4.1":{"pli":"Nanu atthi keci sakadāgāmissa …pe… ","html":"<p data-doxy='orthodox'>{}"},"kv17.11:4.2":{"pli":"anāgāmissa …pe… ","html":"{}"},"kv17.11:4.3":{"pli":"arahato dānaṁ datvā dakkhiṇaṁ ārādhentīti? ","html":"{}"},"kv17.11:4.4":{"pli":"Āmantā. ","html":"{}"},"kv17.11:4.5":{"pli":"Hañci atthi keci arahato dānaṁ datvā dakkhiṇaṁ ārādhenti, no ca vata re vattabbe—","html":"{}"},"kv17.11:4.6":{"pli":"“dāyakatova dānaṁ visujjhati, no paṭiggāhakato”ti. ","html":"{}</p>"},"kv17.11:5.1":{"pli":"Paṭiggāhakato dānaṁ visujjhatīti? ","html":"<p data-doxy='heterodox'>{}"},"kv17.11:5.2":{"pli":"Āmantā. ","html":"{}"},"kv17.11:5.3":{"pli":"Añño aññassa kārako, parakataṁ sukhadukkhaṁ, añño karoti añño paṭisaṁvedetīti? ","html":"{}"},"kv17.11:5.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv17.11:6.1":{"pli":"Dāyakatova dānaṁ visujjhati, no paṭiggāhakatoti? ","html":"<p data-doxy='orthodox'>{}"},"kv17.11:6.2":{"pli":"Āmantā. ","html":"{}"},"kv17.11:6.3":{"pli":"Nanu vuttaṁ bhagavatā—","html":"{}"},"kv17.11:6.4":{"pli":"“catasso kho imā, ānanda, dakkhiṇā visuddhiyo. ","html":"{}"},"kv17.11:6.5":{"pli":"Katamā catasso? ","html":"{}"},"kv17.11:6.6":{"pli":"Atthānanda, dakkhiṇā dāyakato visujjhati, no paṭiggāhakato; ","html":"{}"},"kv17.11:6.7":{"pli":"atthānanda, dakkhiṇā paṭiggāhakato visujjhati, no dāyakato; ","html":"{}"},"kv17.11:6.8":{"pli":"atthānanda, dakkhiṇā dāyakato ceva visujjhati paṭiggāhakato ca; ","html":"{}"},"kv17.11:6.9":{"pli":"atthānanda, dakkhiṇā neva dāyakato visujjhati, no paṭiggāhakato. ","html":"{}"},"kv17.11:6.10":{"pli":"Imā kho, ānanda, catasso dakkhiṇā visuddhiyo”ti. ","html":"{}"},"kv17.11:6.11":{"pli":"Attheva suttantoti? ","html":"{}"},"kv17.11:6.12":{"pli":"Āmantā. ","html":"{}"},"kv17.11:6.13":{"pli":"Tena hi na vattabbaṁ—","html":"{}"},"kv17.11:6.14":{"pli":"“dāyakatova dānaṁ visujjhati, no paṭiggāhakato”ti. ","html":"{}</p>"},"kv17.11:6.15":{"pli":"Dakkhiṇāvisuddhikathā niṭṭhitā. ","html":"<p class='endsutta'>{}<br>"},"kv17.11:6.16":{"pli":"Sattarasamo vaggo. ","html":"{}</p>"},"kv17.11:6.17":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"kv17.11:7.1":{"pli":"Atthi arahato puññūpacayo, ","html":"<p class='uddana'>{}"},"kv17.11:7.2":{"pli":"natthi arahato akālamaccu, ","html":"{}"},"kv17.11:7.3":{"pli":"sabbamidaṁ kammato, ","html":"{}"},"kv17.11:7.4":{"pli":"indriyabaddhaññeva dukkhaṁ, ","html":"{}"},"kv17.11:7.5":{"pli":"ṭhapetvā ariyamaggaṁ avasesā saṅkhārā dukkhā, ","html":"{}"},"kv17.11:7.6":{"pli":"saṅgho dakkhiṇaṁ paṭiggaṇhāti, ","html":"{}"},"kv17.11:7.7":{"pli":"saṅgho dakkhiṇaṁ visodheti, ","html":"{}"},"kv17.11:7.8":{"pli":"saṅgho bhuñjati pivati khādati sāyati, ","html":"{}"},"kv17.11:7.9":{"pli":"saṅghassa dinnaṁ mahapphalaṁ, ","html":"{}"},"kv17.11:7.10":{"pli":"atthi dānaṁ visuddhiyāti. ","html":"{}</p></article>"}},"kv17.2":{"kv17.2:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv17.2'><header><ul><li class='division'>{}</li>"},"kv17.2:0.2":{"pli":"Mahāpaṇṇāsaka ","html":"<li>{}</li>"},"kv17.2:0.3":{"pli":"Sattarasamavagga ","html":"<li>{}</li></ul>"},"kv17.2:0.4":{"pli":"Natthiarahatoakālamaccūtikathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv17.2:1.1":{"pli":"Natthi arahato akālamaccūti? ","html":"<p data-doxy='orthodox'>{}"},"kv17.2:1.2":{"pli":"Āmantā. ","html":"{}"},"kv17.2:1.3":{"pli":"Natthi arahantaghātakoti? ","html":"{}"},"kv17.2:1.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv17.2:1.5":{"pli":"atthi arahantaghātakoti? ","html":"{}"},"kv17.2:1.6":{"pli":"Āmantā. ","html":"{}"},"kv17.2:1.7":{"pli":"Atthi arahato akālamaccūti? ","html":"{}"},"kv17.2:1.8":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv17.2:1.9":{"pli":"natthi arahato akālamaccūti? ","html":"{}"},"kv17.2:1.10":{"pli":"Āmantā. ","html":"{}"},"kv17.2:1.11":{"pli":"Yo arahantaṁ jīvitā voropeti, sati jīvite jīvitāvasese jīvitā voropeti, asati jīvite jīvitāvasese jīvitā voropetīti? ","html":"{}"},"kv17.2:1.12":{"pli":"Sati jīvite jīvitāvasese jīvitā voropetīti. ","html":"{}"},"kv17.2:1.13":{"pli":"Hañci sati jīvite jīvitāvasese jīvitā voropeti, no ca vata re vattabbe—","html":"{}"},"kv17.2:1.14":{"pli":"“natthi arahato akālamaccū”ti. ","html":"{}"},"kv17.2:1.15":{"pli":"Asati jīvite jīvitāvasese jīvitā voropetīti, natthi arahantaghātakoti? ","html":"{}"},"kv17.2:1.16":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv17.2:2.1":{"pli":"Natthi arahato akālamaccūti? ","html":"<p data-doxy='orthodox'>{}"},"kv17.2:2.2":{"pli":"Āmantā. ","html":"{}"},"kv17.2:2.3":{"pli":"Arahato kāye visaṁ na kameyya, satthaṁ na kameyya, aggi na kameyyāti? ","html":"{}"},"kv17.2:2.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv17.2:2.5":{"pli":"nanu arahato kāye visaṁ kameyya, satthaṁ kameyya, aggi kameyyāti? ","html":"{}"},"kv17.2:2.6":{"pli":"Āmantā. ","html":"{}"},"kv17.2:2.7":{"pli":"Hañci arahato kāye visaṁ kameyya, satthaṁ kameyya, aggi kameyya, no ca vata re vattabbe—","html":"{}"},"kv17.2:2.8":{"pli":"“natthi arahato akālamaccū”ti. ","html":"{}</p>"},"kv17.2:3.1":{"pli":"Arahato kāye visaṁ na kameyya, satthaṁ na kameyya, aggi na kameyyāti? ","html":"<p data-doxy='orthodox'>{}"},"kv17.2:3.2":{"pli":"Āmantā. ","html":"{}"},"kv17.2:3.3":{"pli":"Natthi arahantaghātakoti? ","html":"{}"},"kv17.2:3.4":{"pli":"Na hevaṁ vattabbe …pe…. ","html":"{}</p>"},"kv17.2:4.1":{"pli":"Atthi arahato akālamaccūti? ","html":"<p data-doxy='heterodox'>{}"},"kv17.2:4.2":{"pli":"Āmantā. ","html":"{}"},"kv17.2:4.3":{"pli":"Nanu vuttaṁ bhagavatā—","html":"{}"},"kv17.2:4.4":{"pli":"“nāhaṁ, bhikkhave, sañcetanikānaṁ kammānaṁ katānaṁ upacitānaṁ appaṭisaṁveditvā byantībhāvaṁ vadāmi; ","html":"{}"},"kv17.2:4.5":{"pli":"tañca kho diṭṭheva dhamme upapajjaṁ vā apare vā pariyāye”ti. ","html":"{}"},"kv17.2:4.6":{"pli":"Attheva suttantoti? ","html":"{}"},"kv17.2:4.7":{"pli":"Āmantā. ","html":"{}"},"kv17.2:4.8":{"pli":"Tena hi natthi arahato akālamaccūti. ","html":"{}</p>"},"kv17.2:4.9":{"pli":"Natthi arahato akālamaccūtikathā niṭṭhitā. ","html":"<p class='endsutta'>{}</p></article>"}},"kv17.3":{"kv17.3:0.1":{"pli":"Kathāvatthu ","html":"<article id='kv17.3'><header><ul><li class='division'>{}</li>"},"kv17.3:0.2":{"pli":"Mahāpaṇṇāsaka ","html":"<li>{}</li>"},"kv17.3:0.3":{"pli":"Sattarasamavagga ","html":"<li>{}</li></ul>"},"kv17.3:0.4":{"pli":"Sabbamidaṅkammatotikathā ","html":"<h1 class='sutta-title'>{}</h1></header>"},"kv17.3:1.1":{"pli":"Sabbamidaṁ kammatoti? ","html":"<p data-doxy='orthodox'>{}"},"kv17.3:1.2":{"pli":"Āmantā. ","html":"{}"},"kv17.3:1.3":{"pli":"Kammampi kammatoti? ","html":"{}"},"kv17.3:1.4":{"pli":"Na hevaṁ vattabbe …pe… ","html":"{}"},"kv17.3:1.5":{"pli":"sabbamidaṁ kammatoti? ","html":"{}"},"kv17.3:1.6":{"pli":"Āmantā. ","html":"{}"},"kv17.3:1.7":{"pli":"Sabbamidaṁ pubbekatahetūti? ","html":"{}"},"kv17.3:1.8":{"pli":"Na heva