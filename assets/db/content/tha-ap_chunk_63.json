tml":"<span class='verse-line'>{}</span>"},"tha-ap98:2.4":{"pli":"suvimuttaṁ anāsavaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap98:3.1":{"pli":"Sammukhā viya sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap98:3.2":{"pli":"vipassiṁ lokanāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap98:3.3":{"pli":"Pāṭaliṁ abhivādetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap98:3.4":{"pli":"tattha kālaṅkato ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap98:4.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap98:4.2":{"pli":"yaṁ bodhimabhipūjayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap98:4.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap98:4.4":{"pli":"bodhipūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap98:5.1":{"pli":"Samantapāsādikā nāma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap98:5.2":{"pli":"terasāsiṁsu rājino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap98:5.3":{"pli":"Ito tettiṁsakappamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap98:5.4":{"pli":"cakkavattī mahabbalā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap98:6.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap98:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap98:6.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap98:7.1":{"pli":"Itthaṁ sudaṁ āyasmā tipupphiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap98:8.1":{"pli":"Tipupphiyattherassāpadānaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap99":{"tha-ap99:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap99'><header><ul><li class='division'>{}</li>"},"tha-ap99:0.2":{"pli":"Sudhāvagga ","html":"<li>{}</li></ul>"},"tha-ap99:0.3":{"pli":"Madhupiṇḍikattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap99:1.1":{"pli":"“Vipine kānane disvā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap99:1.2":{"pli":"appasadde nirākule; ","html":"<span class='verse-line'>{}</span>"},"tha-ap99:1.3":{"pli":"Siddhatthaṁ isinaṁ seṭṭhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap99:1.4":{"pli":"āhutīnaṁ paṭiggahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap99:2.1":{"pli":"Nibbutattaṁ mahānāgaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap99:2.2":{"pli":"nisabhājāniyaṁ yathā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap99:2.3":{"pli":"Osadhiṁva virocantaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap99:2.4":{"pli":"devasaṅghanamassitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap99:3.1":{"pli":"Vitti mamāhu tāvade, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap99:3.2":{"pli":"ñāṇaṁ uppajji tāvade; ","html":"<span class='verse-line'>{}</span>"},"tha-ap99:3.3":{"pli":"Vuṭṭhitassa samādhimhā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap99:3.4":{"pli":"madhuṁ datvāna satthuno. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap99:4.1":{"pli":"Vanditvā satthuno pāde, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap99:4.2":{"pli":"pakkāmiṁ pācināmukho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap99:4.3":{"pli":"Catuttiṁsamhi kappamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap99:4.4":{"pli":"rājā āsiṁ sudassano. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap99:5.1":{"pli":"Madhu bhisehi savati, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap99:5.2":{"pli":"bhojanamhi ca tāvade; ","html":"<span class='verse-line'>{}</span>"},"tha-ap99:5.3":{"pli":"Madhuvassaṁ pavassittha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap99:5.4":{"pli":"pubbakammassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap99:6.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap99:6.2":{"pli":"yaṁ madhuṁ adadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap99:6.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap99:6.4":{"pli":"madhudānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap99:7.1":{"pli":"Catuttiṁse ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap99:7.2":{"pli":"cattāro te sudassanā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap99:7.3":{"pli":"Sattaratanasampannā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap99:7.4":{"pli":"cakkavattī mahabbalā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap99:8.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap99:8.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap99:8.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap99:9.1":{"pli":"Itthaṁ sudaṁ āyasmā madhupiṇḍiko thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap99:10.1":{"pli":"Madhupiṇḍikattherassāpadānaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}