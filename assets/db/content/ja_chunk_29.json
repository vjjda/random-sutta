{"ja511":{"ja511:0.1":{"pli":"Jātaka ","html":"<article id='ja511'><header><ul><li class='division'>{}</li>"},"ja511:0.2":{"pli":"Tiṁsanipāta ","html":"<li>{}</li>"},"ja511:0.3":{"pli":"Kiṁchandavagga ","html":"<li>{}</li></ul>"},"ja511:0.4":{"pli":"1. Kiṁchandajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja511:1.1":{"pli":"“Kiṁchando kimadhippāyo, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja511:1.2":{"pli":"eko sammasi ghammani; ","html":"<span class='verse-line'>{}</span>"},"ja511:1.3":{"pli":"Kiṁ patthayāno kiṁ esaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja511:1.4":{"pli":"kena atthena brāhmaṇa”. ","html":"<span class='verse-line'>{}</span></p>"},"ja511:2.1":{"pli":"“Yathā mahā vāridharo, ","html":"<p><span class='verse-line'>{}</span>"},"ja511:2.2":{"pli":"kumbho supariṇāhavā; ","html":"<span class='verse-line'>{}</span>"},"ja511:2.3":{"pli":"Tathūpamaṁ ambapakkaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja511:2.4":{"pli":"vaṇṇagandharasuttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja511:3.1":{"pli":"Taṁ vuyhamānaṁ sotena, ","html":"<p><span class='verse-line'>{}</span>"},"ja511:3.2":{"pli":"disvānāmalamajjhime; ","html":"<span class='verse-line'>{}</span>"},"ja511:3.3":{"pli":"Pāṇīhi naṁ gahetvāna, ","html":"<span class='verse-line'>{}</span>"},"ja511:3.4":{"pli":"agyāyatanamāhariṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja511:4.1":{"pli":"Tato kadalipattesu, ","html":"<p><span class='verse-line'>{}</span>"},"ja511:4.2":{"pli":"nikkhipitvā sayaṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja511:4.3":{"pli":"Satthena naṁ vikappetvā, ","html":"<span class='verse-line'>{}</span>"},"ja511:4.4":{"pli":"khuppipāsaṁ ahāsi me. ","html":"<span class='verse-line'>{}</span></p>"},"ja511:5.1":{"pli":"Sohaṁ apetadaratho, ","html":"<p><span class='verse-line'>{}</span>"},"ja511:5.2":{"pli":"Byantībhūto dukhakkhamo; ","html":"<span class='verse-line'>{}</span>"},"ja511:5.3":{"pli":"Assādaṁ nādhigacchāmi, ","html":"<span class='verse-line'>{}</span>"},"ja511:5.4":{"pli":"Phalesvaññesu kesuci. ","html":"<span class='verse-line'>{}</span></p>"},"ja511:6.1":{"pli":"Sosetvā nūna maraṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja511:6.2":{"pli":"taṁ mamaṁ āvahissati; ","html":"<span class='verse-line'>{}</span>"},"ja511:6.3":{"pli":"Ambaṁ yassa phalaṁ sādu, ","html":"<span class='verse-line'>{}</span>"},"ja511:6.4":{"pli":"madhuraggaṁ manoramaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja511:6.5":{"pli":"Yamuddhariṁ vuyhamānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja511:6.6":{"pli":"udadhismā mahaṇṇave. ","html":"<span class='verse-line'>{}</span></p>"},"ja511:7.1":{"pli":"Akkhātaṁ te mayā sabbaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja511:7.2":{"pli":"yasmā upavasāmahaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja511:7.3":{"pli":"Rammaṁ pati nisinnosmi, ","html":"<span class='verse-line'>{}</span>"},"ja511:7.4":{"pli":"puthulomāyutā puthu. ","html":"<span class='verse-line'>{}</span></p>"},"ja511:8.1":{"pli":"Tvañca kho meva akkhāhi, ","html":"<p><span class='verse-line'>{}</span>"},"ja511:8.2":{"pli":"attānamapalāyini; ","html":"<span class='verse-line'>{}</span>"},"ja511:8.3":{"pli":"Kā vā tvamasi kalyāṇi, ","html":"<span class='verse-line'>{}</span>"},"ja511:8.4":{"pli":"kissa vā tvaṁ sumajjhime. ","html":"<span class='verse-line'>{}</span></p>"},"ja511:9.1":{"pli":"Ruppapaṭṭapalimaṭṭhīva, ","html":"<p><span class='verse-line'>{}</span>"},"ja511:9.2":{"pli":"byagghīva girisānujā; ","html":"<span class='verse-line'>{}</span>"},"ja511:9.3":{"pli":"Yā santi nāriyo devesu, ","html":"<span class='verse-line'>{}</span>"},"ja511:9.4":{"pli":"devānaṁ paricārikā. ","html":"<span class='verse-line'>{}</span></p>"},"ja511:10.1":{"pli":"Yā ca manussalokasmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja511:10.2":{"pli":"Rūpenānvāgatitthiyo; ","html":"<span class='verse-line'>{}</span>"},"ja511:10.3":{"pli":"Rūpena te sadisī natthi, ","html":"<span class='verse-line'>{}</span>"},"ja511:10.4":{"pli":"Devesu gandhabbamanussaloke; ","html":"<span class='verse-line'>{}</span>"},"ja511:10.5":{"pli":"Puṭṭhāsi me cārupubbaṅgi, ","html":"<span class='verse-line'>{}</span>"},"ja511:10.6":{"pli":"Brūhi nāmañca bandhave”. ","html":"<span class='verse-line'>{}</span></p>"},"ja511:11.1":{"pli":"“Yaṁ tvaṁ pati nisinnosi, ","html":"<p><span class='verse-line'>{}</span>"},"ja511:11.2":{"pli":"rammaṁ brāhmaṇa kosikiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja511:11.3":{"pli":"Sāhaṁ bhusālayāvutthā, ","html":"<span class='verse-line'>{}</span>"},"ja511:11.4":{"pli":"varavārivahoghasā. ","html":"<span class='verse-line'>{}</span></p>"},"ja511:12.1":{"pli":"Nānādumagaṇākiṇṇā, ","html":"<p><span class='verse-line'>{}</span>"},"ja511:12.2":{"pli":"bahukā girikandarā; ","html":"<span class='verse-line'>{}</span>"},"ja511:12.3":{"pli":"Mameva pamukhā honti, ","html":"<span class='verse-line'>{}</span>"},"ja511:12.4":{"pli":"abhisandanti pāvuse. ","html":"<span class='verse-line'>{}</span></p>"},"ja511:13.1":{"pli":"Atho bahū vanatodā, ","html":"<p><span class='verse-line'>{}</span>"},"ja511:13.2":{"pli":"nīlavārivahindharā; ","html":"<span class='verse-line'>{}</span>"},"ja511:13.3":{"pli":"Bahukā nāgavittodā, ","html":"<span class='verse-line'>{}</span>"},"ja511:13.4":{"pli":"abhisandanti vārinā. ","html":"<span class='verse-line'>{}</span></p>"},"ja511:14.1":{"pli":"Tā ambajambulabujā, ","html":"<p><span class='verse-line'>{}</span>"},"ja511:14.2":{"pli":"nīpā tālā cudumbarā; ","html":"<span class='verse-line'>{}</span>"},"ja511:14.3":{"pli":"Bahūni phalajātāni, ","html":"<span class='verse-line'>{}</span>"},"ja511:14.4":{"pli":"āvahanti abhiṇhaso. ","html":"<span class='verse-line'>{}</span></p>"},"ja511:15.1":{"pli":"Yaṁ kiñci ubhato tīre, ","html":"<p><span class='verse-line'>{}</span>"},"ja511:15.2":{"pli":"phalaṁ patati ambuni; ","html":"<span class='verse-line'>{}</span>"},"ja511:15.3":{"pli":"Asaṁsayaṁ taṁ sotassa, ","html":"<span class='verse-line'>{}</span>"},"ja511:15.4":{"pli":"phalaṁ hoti vasānugaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja511:16.1":{"pli":"Etadaññāya medhāvi, ","html":"<p><span class='verse-line'>{}</span>"},"ja511:16.2":{"pli":"puthupañña suṇohi me; ","html":"<span class='verse-line'>{}</span>"},"ja511:16.3":{"pli":"Mā rocaya mabhisaṅgaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja511:16.4":{"pli":"paṭisedha janādhipa. ","html":"<span class='verse-line'>{}</span></p>"},"ja511:17.1":{"pli":"Na vāhaṁ vaḍḍhavaṁ maññe, ","html":"<p><span class='verse-line'>{}</span>"},"ja511:17.2":{"pli":"Yaṁ tvaṁ raṭṭhābhivaḍḍhana; ","html":"<span class='verse-line'>{}</span>"},"ja511:17.3":{"pli":"Āceyyamāno rājisi, ","html":"<span class='verse-line'>{}</span>"},"ja511:17.4":{"pli":"Maraṇaṁ abhikaṅkhasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja511:18.1":{"pli":"Tassa jānanti pitaro, ","html":"<p><span class='verse-line'>{}</span>"},"ja511:18.2":{"pli":"gandhabbā ca sadevakā; ","html":"<span class='verse-line'>{}</span>"},"ja511:18.3":{"pli":"Ye cāpi isayo loke, ","html":"<span class='verse-line'>{}</span>"},"ja511:18.4":{"pli":"saññatattā tapassino; ","html":"<span class='verse-line'>{}</span>"},"ja511:18.5":{"pli":"Asaṁsayaṁ tepi jānanti, ","html":"<span class='verse-line'>{}</span>"},"ja511:18.6":{"pli":"paṭṭhabhūtā yasassino”. ","html":"<span class='verse-line'>{}</span></p>"},"ja511:19.1":{"pli":"“Evaṁ viditvā vidū sabbadhammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja511:19.2":{"pli":"Viddhaṁsanaṁ cavanaṁ jīvitassa; ","html":"<span class='verse-line'>{}</span>"},"ja511:19.3":{"pli":"Na cīyatī tassa narassa pāpaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja511:19.4":{"pli":"Sace na ceteti vadhāya tassa. ","html":"<span class='verse-line'>{}</span></p>"},"ja511:20.1":{"pli":"Isipūgasamaññāte, ","html":"<p><span class='verse-line'>{}</span>"},"ja511:20.2":{"pli":"evaṁ lokyā viditā sati; ","html":"<span class='verse-line'>{}</span>"},"ja511:20.3":{"pli":"Anariyaparisambhāse, ","html":"<span class='verse-line'>{}</span>"},"ja511:20.4":{"pli":"pāpakammaṁ jigīsasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja511:21.1":{"pli":"Sace ahaṁ marissāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja511:21.2":{"pli":"tīre te puthusussoṇi; ","html":"<span class='verse-line'>{}</span>"},"ja511:21.3":{"pli":"Asaṁsayaṁ taṁ asiloko, ","html":"<span class='verse-line'>{}</span>"},"ja511:21.4":{"pli":"mayi pete āgamissati. ","html":"<span class='verse-line'>{}</span></p>"},"ja511:22.1":{"pli":"Tasmā hi pāpakaṁ kammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja511:22.2":{"pli":"rakkhasseva sumajjhime; ","html":"<span class='verse-line'>{}</span>"},"ja511:22.3":{"pli":"Mā taṁ sabbo jano pacchā, ","html":"<span class='verse-line'>{}</span>"},"ja511:22.4":{"pli":"pakuṭṭhāyi mayi mate”. ","html":"<span class='verse-line'>{}</span></p>"},"ja511:23.1":{"pli":"“Aññātametaṁ avisayhasāhi, ","html":"<p><span class='verse-line'>{}</span>"},"ja511:23.2":{"pli":"Attānamambañca dadāmi te taṁ; ","html":"<span class='verse-line'>{}</span>"},"ja511:23.3":{"pli":"So duccaje kāmaguṇe pahāya, ","html":"<span class='verse-line'>{}</span>"},"ja511:23.4":{"pli":"Santiñca dhammañca adhiṭṭhitosi. ","html":"<span class='verse-line'>{}</span></p>"},"ja511:24.1":{"pli":"Yo hitvā pubbasaññogaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja511:24.2":{"pli":"pacchā saṁyojane ṭhito; ","html":"<span class='verse-line'>{}</span>"},"ja511:24.3":{"pli":"Adhammañceva carati, ","html":"<span class='verse-line'>{}</span>"},"ja511:24.4":{"pli":"pāpañcassa pavaḍḍhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja511:25.1":{"pli":"Ehi taṁ pāpayissāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja511:25.2":{"pli":"kāmaṁ appossuko bhava; ","html":"<span class='verse-line'>{}</span>"},"ja511:25.3":{"pli":"Upānayāmi sītasmiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja511:25.4":{"pli":"viharāhi anussuko. ","html":"<span class='verse-line'>{}</span></p>"},"ja511:26.1":{"pli":"Taṁ puppharasamattebhi, ","html":"<p><span class='verse-line'>{}</span>"},"ja511:26.2":{"pli":"vakkaṅgehi arindama; ","html":"<span class='verse-line'>{}</span>"},"ja511:26.3":{"pli":"Koñcā mayūrā diviyā, ","html":"<span class='verse-line'>{}</span>"},"ja511:26.4":{"pli":"kolaṭṭhimadhusāḷikā; ","html":"<span class='verse-line'>{}</span>"},"ja511:26.5":{"pli":"Kūjitā haṁsapūgehi, ","html":"<span class='verse-line'>{}</span>"},"ja511:26.6":{"pli":"kokilettha pabodhare. ","html":"<span class='verse-line'>{}</span></p>"},"ja511:27.1":{"pli":"Ambettha vippasākhaggā, ","html":"<p><span class='verse-line'>{}</span>"},"ja511:27.2":{"pli":"palālakhalasannibhā; ","html":"<span class='verse-line'>{}</span>"},"ja511:27.3":{"pli":"Kosambasaḷalā nīpā, ","html":"<span class='verse-line'>{}</span>"},"ja511:27.4":{"pli":"pakkatālavilambino”. ","html":"<span class='verse-line'>{}</span></p>"},"ja511:28.1":{"pli":"“Mālī tiriṭī kāyūrī, ","html":"<p><span class='verse-line'>{}</span>"},"ja511:28.2":{"pli":"aṅgadī candanussado; ","html":"<span class='verse-line'>{}</span>"},"ja511:28.3":{"pli":"Rattiṁ tvaṁ paricāresi, ","html":"<span class='verse-line'>{}</span>"},"ja511:28.4":{"pli":"divā vedesi vedanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja511:29.1":{"pli":"Soḷasitthisahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja511:29.2":{"pli":"yā temā paricārikā; ","html":"<span class='verse-line'>{}</span>"},"ja511:29.3":{"pli":"Evaṁ mahānubhāvosi, ","html":"<span class='verse-line'>{}</span>"},"ja511:29.4":{"pli":"abbhuto lomahaṁsano. ","html":"<span class='verse-line'>{}</span></p>"},"ja511:30.1":{"pli":"Kiṁ kammamakarī pubbe, ","html":"<p><span class='verse-line'>{}</span>"},"ja511:30.2":{"pli":"pāpaṁ attadukhāvahaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja511:30.3":{"pli":"Yaṁ karitvā manussesu, ","html":"<span class='verse-line'>{}</span>"},"ja511:30.4":{"pli":"piṭṭhimaṁsāni khādasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja511:31.1":{"pli":"“Ajjhenāni paṭiggayha, ","html":"<p><span class='verse-line'>{}</span>"},"ja511:31.2":{"pli":"kāmesu gadhito ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja511:31.3":{"pli":"Acariṁ dīghamaddhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja511:31.4":{"pli":"paresaṁ ahitāyahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja511:32.1":{"pli":"Yo piṭṭhimaṁsiko hoti, ","html":"<p><span class='verse-line'>{}</span>"},"ja511:32.2":{"pli":"evaṁ ukkacca khādati; ","html":"<span class='verse-line'>{}</span>"},"ja511:32.3":{"pli":"Yathāhaṁ ajja khādāmi, ","html":"<span class='verse-line'>{}</span>"},"ja511:32.4":{"pli":"piṭṭhimaṁsāni attano”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja511:33.1":{"pli":"Kiṁchandajātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja512":{"ja512:0.1":{"pli":"Jātaka ","html":"<article id='ja512'><header><ul><li class='division'>{}</li>"},"ja512:0.2":{"pli":"Tiṁsanipāta ","html":"<li>{}</li>"},"ja512:0.3":{"pli":"Kiṁchandavagga ","html":"<li>{}</li></ul>"},"ja512:0.4":{"pli":"2. Kumbhajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja512:1.1":{"pli":"“Ko pāturāsī tidivā nabhamhi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja512:1.2":{"pli":"Obhāsayaṁ saṁvariṁ candimāva; ","html":"<span class='verse-line'>{}</span>"},"ja512:1.3":{"pli":"Gattehi te rasmiyo niccharanti, ","html":"<span class='verse-line'>{}</span>"},"ja512:1.4":{"pli":"Sateratā vijjurivantalikkhe. ","html":"<span class='verse-line'>{}</span></p>"},"ja512:2.1":{"pli":"So chinnavātaṁ kamasī aghamhi, ","html":"<p><span class='verse-line'>{}</span>"},"ja512:2.2":{"pli":"Vehāyasaṁ gacchasi tiṭṭhasī ca; ","html":"<span class='verse-line'>{}</span>"},"ja512:2.3":{"pli":"Iddhī nu te vatthukatā subhāvitā, ","html":"<span class='verse-line'>{}</span>"},"ja512:2.4":{"pli":"Anaddhagūnaṁ api devatānaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja512:3.1":{"pli":"Vehāyasaṁ gammamāgamma tiṭṭhasi, ","html":"<p><span class='verse-line'>{}</span>"},"ja512:3.2":{"pli":"Kumbhaṁ kiṇāthāti yametamatthaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja512:3.3":{"pli":"Ko vā tuvaṁ kissa vā tāya kumbho, ","html":"<span class='verse-line'>{}</span>"},"ja512:3.4":{"pli":"Akkhāhi me brāhmaṇa etamatthaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja512:4.1":{"pli":"“Na sappikumbho napi telakumbho, ","html":"<p><span class='verse-line'>{}</span>"},"ja512:4.2":{"pli":"Na phāṇitassa na madhussa kumbho; ","html":"<span class='verse-line'>{}</span>"},"ja512:4.3":{"pli":"Kumbhassa vajjāni anappakāni, ","html":"<span class='verse-line'>{}</span>"},"ja512:4.4":{"pli":"Dose bahū kumbhagate suṇātha. ","html":"<span class='verse-line'>{}</span></p>"},"ja512:5.1":{"pli":"Gaḷeyya yaṁ pitvā pate papātaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja512:5.2":{"pli":"Sobbhaṁ guhaṁ candaniyoḷigallaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja512:5.3":{"pli":"Bahumpi bhuñjeyya abhojaneyyaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja512:5.4":{"pli":"Tassā puṇṇaṁ kumbhamimaṁ kiṇātha. ","html":"<span class='verse-line'>{}</span></p>"},"ja512:6.1":{"pli":"Yaṁ pitva cittasmimanesamāno, ","html":"<p><span class='verse-line'>{}</span>"},"ja512:6.2":{"pli":"Āhiṇḍatī goriva bhakkhasādī; ","html":"<span class='verse-line'>{}</span>"},"ja512:6.3":{"pli":"Anāthamāno upagāyati naccati ca, ","html":"<span class='verse-line'>{}</span>"},"ja512:6.4":{"pli":"Tassā puṇṇaṁ kumbhamimaṁ kiṇātha. ","html":"<span class='verse-line'>{}</span></p>"},"ja512:7.1":{"pli":"Yaṁ ve pivitvā acelova naggo, ","html":"<p><span class='verse-line'>{}</span>"},"ja512:7.2":{"pli":"Careyya gāme visikhantarāni; ","html":"<span class='verse-line'>{}</span>"},"ja512:7.3":{"pli":"Sammūḷhacitto ativelasāyī, ","html":"<span class='verse-line'>{}</span>"},"ja512:7.4":{"pli":"Tassā puṇṇaṁ kumbhamimaṁ kiṇātha. ","html":"<span class='verse-line'>{}</span></p>"},"ja512:8.1":{"pli":"Yaṁ pitva uṭṭhāya pavedhamāno, ","html":"<p><span class='verse-line'>{}</span>"},"ja512:8.2":{"pli":"Sīsañca bāhuñca pacālayanto; ","html":"<span class='verse-line'>{}</span>"},"ja512:8.3":{"pli":"So naccatī dārukaṭallakova, ","html":"<span class='verse-line'>{}</span>"},"ja512:8.4":{"pli":"Tassā puṇṇaṁ kumbhamimaṁ kiṇātha. ","html":"<span class='verse-line'>{}</span></p>"},"ja512:9.1":{"pli":"Yaṁ ve pivitvā aggidaḍḍhā sayanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja512:9.2":{"pli":"Atho sigālehipi khāditāse; ","html":"<span class='verse-line'>{}</span>"},"ja512:9.3":{"pli":"Bandhaṁ vadhaṁ bhogajāniñcupenti, ","html":"<span class='verse-line'>{}</span>"},"ja512:9.4":{"pli":"Tassā puṇṇaṁ kumbhamimaṁ kiṇātha. ","html":"<span class='verse-line'>{}</span></p>"},"ja512:10.1":{"pli":"Yaṁ pitva bhāseyya abhāsaneyyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja512:10.2":{"pli":"Sabhāyamāsīno apetavattho; ","html":"<span class='verse-line'>{}</span>"},"ja512:10.3":{"pli":"Sammakkhito vantagato byasanno, ","html":"<span class='verse-line'>{}</span>"},"ja512:10.4":{"pli":"Tassā puṇṇaṁ kumbhamimaṁ kiṇātha. ","html":"<span class='verse-line'>{}</span></p>"},"ja512:11.1":{"pli":"Yaṁ ve pivitvā ukkaṭṭho āvilakkho, ","html":"<p><span class='verse-line'>{}</span>"},"ja512:11.2":{"pli":"Mameva sabbā pathavīti maññe; ","html":"<span class='verse-line'>{}</span>"},"ja512:11.3":{"pli":"Na me samo cāturantopi rājā, ","html":"<span class='verse-line'>{}</span>"},"ja512:11.4":{"pli":"Tassā puṇṇaṁ kumbhamimaṁ kiṇātha. ","html":"<span class='verse-line'>{}</span></p>"},"ja512:12.1":{"pli":"Mānātimānā kalahāni pesuṇī, ","html":"<p><span class='verse-line'>{}</span>"},"ja512:12.2":{"pli":"Dubbaṇṇinī naggayinī palāyinī; ","html":"<span class='verse-line'>{}</span>"},"ja512:12.3":{"pli":"Corāna dhuttāna gatī niketo, ","html":"<span class='verse-line'>{}</span>"},"ja512:12.4":{"pli":"Tassā puṇṇaṁ kumbhamimaṁ kiṇātha. ","html":"<span class='verse-line'>{}</span></p>"},"ja512:13.1":{"pli":"Iddhāni phītāni kulāni assu, ","html":"<p><span class='verse-line'>{}</span>"},"ja512:13.2":{"pli":"Anekasāhassadhanāni loke; ","html":"<span class='verse-line'>{}</span>"},"ja512:13.3":{"pli":"Ucchinnadāyajjakatānimāya, ","html":"<span class='verse-line'>{}</span>"},"ja512:13.4":{"pli":"Tassā puṇṇaṁ kumbhamimaṁ kiṇātha. ","html":"<span class='verse-line'>{}</span></p>"},"ja512:14.1":{"pli":"Dhaññaṁ dhanaṁ rajataṁ jātarūpaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja512:14.2":{"pli":"Khettaṁ gavaṁ yattha vināsayanti; ","html":"<span class='verse-line'>{}</span>"},"ja512:14.3":{"pli":"Ucchedanī vittavataṁ kulānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja512:14.4":{"pli":"Tassā puṇṇaṁ kumbhamimaṁ kiṇātha. ","html":"<span class='verse-line'>{}</span></p>"},"ja512:15.1":{"pli":"Yaṁ ve pitvā dittarūpova poso, ","html":"<p><span class='verse-line'>{}</span>"},"ja512:15.2":{"pli":"Akkosati mātaraṁ pitarañca; ","html":"<span class='verse-line'>{}</span>"},"ja512:15.3":{"pli":"Sassumpi gaṇheyya athopi suṇhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja512:15.4":{"pli":"Tassā puṇṇaṁ kumbhamimaṁ kiṇātha. ","html":"<span class='verse-line'>{}</span></p>"},"ja512:16.1":{"pli":"Yaṁ ve pitvā dittarūpāva nārī, ","html":"<p><span class='verse-line'>{}</span>"},"ja512:16.2":{"pli":"Akkosatī sasuraṁ sāmikañca; ","html":"<span class='verse-line'>{}</span>"},"ja512:16.3":{"pli":"Dāsampi gaṇhe paricārakampi, ","html":"<span class='verse-line'>{}</span>"},"ja512:16.4":{"pli":"Tassā puṇṇaṁ kumbhamimaṁ kiṇātha. ","html":"<span class='verse-line'>{}</span></p>"},"ja512:17.1":{"pli":"Yaṁ ve pivitvāna haneyya poso, ","html":"<p><span class='verse-line'>{}</span>"},"ja512:17.2":{"pli":"Dhamme ṭhitaṁ samaṇaṁ brāhmaṇaṁ vā; ","html":"<span class='verse-line'>{}</span>"},"ja512:17.3":{"pli":"Gacche apāyampi tatonidānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja512:17.4":{"pli":"Tassā puṇṇaṁ kumbhamimaṁ kiṇātha. ","html":"<span class='verse-line'>{}</span></p>"},"ja512:18.1":{"pli":"Yaṁ ve pivitvā duccaritaṁ caranti, ","html":"<p><span class='verse-line'>{}</span>"},"ja512:18.2":{"pli":"Kāyena vācāya ca cetasā ca; ","html":"<span class='verse-line'>{}</span>"},"ja512:18.3":{"pli":"Nirayaṁ vajanti duccaritaṁ caritvā, ","html":"<span class='verse-line'>{}</span>"},"ja512:18.4":{"pli":"Tassā puṇṇaṁ kumbhamimaṁ kiṇātha. ","html":"<span class='verse-line'>{}</span></p>"},"ja512:19.1":{"pli":"Yaṁ yācamānā na labhanti pubbe, ","html":"<p><span class='verse-line'>{}</span>"},"ja512:19.2":{"pli":"Bahuṁ hiraññampi pariccajantā; ","html":"<span class='verse-line'>{}</span>"},"ja512:19.3":{"pli":"So taṁ pivitvā alikaṁ bhaṇāti, ","html":"<span class='verse-line'>{}</span>"},"ja512:19.4":{"pli":"Tassā puṇṇaṁ kumbhamimaṁ kiṇātha. ","html":"<span class='verse-line'>{}</span></p>"},"ja512:20.1":{"pli":"Yaṁ ve pitvā pesane pesiyanto, ","html":"<p><span class='verse-line'>{}</span>"},"ja512:20.2":{"pli":"Accāyike karaṇīyamhi jāte; ","html":"<span class='verse-line'>{}</span>"},"ja512:20.3":{"pli":"Atthampi so nappajānāti vutto, ","html":"<span class='verse-line'>{}</span>"},"ja512:20.4":{"pli":"Tassā puṇṇaṁ kumbhamimaṁ kiṇātha. ","html":"<span class='verse-line'>{}</span></p>"},"ja512:21.1":{"pli":"Hirīmanāpi ahirīkabhāvaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja512:21.2":{"pli":"Pātuṁ karonti madanāya mattā; ","html":"<span class='verse-line'>{}</span>"},"ja512:21.3":{"pli":"Dhīrāpi santā bahukaṁ bhaṇanti, ","html":"<span class='verse-line'>{}</span>"},"ja512:21.4":{"pli":"Tassā puṇṇaṁ kumbhamimaṁ kiṇātha. ","html":"<span class='verse-line'>{}</span></p>"},"ja512:22.1":{"pli":"Yaṁ ve pitvā ekathūpā sayanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja512:22.2":{"pli":"Anāsakā thaṇḍiladukkhaseyyaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja512:22.3":{"pli":"Dubbaṇṇiyaṁ āyasakyañcupenti, ","html":"<span class='verse-line'>{}</span>"},"ja512:22.4":{"pli":"Tassā puṇṇaṁ kumbhamimaṁ kiṇātha. ","html":"<span class='verse-line'>{}</span></p>"},"ja512:23.1":{"pli":"Yaṁ ve pitvā pattakhandhā sayanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja512:23.2":{"pli":"Gāvo kuṭahatāva na hi vāruṇiyā; ","html":"<span class='verse-line'>{}</span>"},"ja512:23.3":{"pli":"Vego narena susahoriva, ","html":"<span class='verse-line'>{}</span>"},"ja512:23.4":{"pli":"Tassā puṇṇaṁ kumbhamimaṁ kiṇātha. ","html":"<span class='verse-line'>{}</span></p>"},"ja512:24.1":{"pli":"Yaṁ manussā vivajjenti, ","html":"<p><span class='verse-line'>{}</span>"},"ja512:24.2":{"pli":"sappaṁ ghoravisamiva; ","html":"<span class='verse-line'>{}</span>"},"ja512:24.3":{"pli":"Taṁ loke visasamānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja512:24.4":{"pli":"ko naro pātumarahati. ","html":"<span class='verse-line'>{}</span></p>"},"ja512:25.1":{"pli":"Yaṁ ve pitvā andhakaveṇḍaputtā, ","html":"<p><span class='verse-line'>{}</span>"},"ja512:25.2":{"pli":"Samuddatīre paricārayantā; ","html":"<span class='verse-line'>{}</span>"},"ja512:25.3":{"pli":"Upakkamuṁ musalehaññamaññaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja512:25.4":{"pli":"Tassā puṇṇaṁ kumbhamimaṁ kiṇātha. ","html":"<span class='verse-line'>{}</span></p>"},"ja512:26.1":{"pli":"Yaṁ ve pitvā pubbadevā pamattā, ","html":"<p><span class='verse-line'>{}</span>"},"ja512:26.2":{"pli":"Tidivā cutā sassatiyā samāya; ","html":"<span class='verse-line'>{}</span>"},"ja512:26.3":{"pli":"Taṁ tādisaṁ majjamimaṁ niratthakaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja512:26.4":{"pli":"Jānaṁ mahārāja kathaṁ piveyya. ","html":"<span class='verse-line'>{}</span></p>"},"ja512:27.1":{"pli":"Nayimasmiṁ kumbhasmiṁ dadhi vā madhu vā, ","html":"<p><span class='verse-line'>{}</span>"},"ja512:27.2":{"pli":"Evaṁ abhiññāya kiṇāhi rāja; ","html":"<span class='verse-line'>{}</span>"},"ja512:27.3":{"pli":"Evañhimaṁ kumbhagatā mayā te, ","html":"<span class='verse-line'>{}</span>"},"ja512:27.4":{"pli":"Akkhātarūpaṁ tava sabbamitta”. ","html":"<span class='verse-line'>{}</span></p>"},"ja512:28.1":{"pli":"“Na me pitā vā athavāpi mātā, ","html":"<p><span class='verse-line'>{}</span>"},"ja512:28.2":{"pli":"Etādisā yādisako tuvaṁsi; ","html":"<span class='verse-line'>{}</span>"},"ja512:28.3":{"pli":"Hitānukampī paramatthakāmo, ","html":"<span class='verse-line'>{}</span>"},"ja512:28.4":{"pli":"Sohaṁ karissaṁ vacanaṁ tavajja. ","html":"<span class='verse-line'>{}</span></p>"},"ja512:29.1":{"pli":"Dadāmi te gāmavarāni pañca, ","html":"<p><span class='verse-line'>{}</span>"},"ja512:29.2":{"pli":"Dāsīsataṁ satta gavaṁsatāni; ","html":"<span class='verse-line'>{}</span>"},"ja512:29.3":{"pli":"Ājaññayutte ca rathe dasa ime, ","html":"<span class='verse-line'>{}</span>"},"ja512:29.4":{"pli":"Ācariyo hosi mamatthakāmo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja512:30.1":{"pli":"“Taveva dāsīsatamatthu rāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja512:30.2":{"pli":"Gāmā ca gāvo ca taveva hontu; ","html":"<span class='verse-line'>{}</span>"},"ja512:30.3":{"pli":"Ājaññayuttā ca rathā taveva, ","html":"<span class='verse-line'>{}</span>"},"ja512:30.4":{"pli":"Sakkohamasmī tidasānamindo. ","html":"<span class='verse-line'>{}</span></p>"},"ja512:31.1":{"pli":"Maṁsodanaṁ sappipāyāsaṁ bhuñja, ","html":"<p><span class='verse-line'>{}</span>"},"ja512:31.2":{"pli":"Khādassu ca tvaṁ madhumāsapūve; ","html":"<span class='verse-line'>{}</span>"},"ja512:31.3":{"pli":"Evaṁ tuvaṁ dhammarato janinda, ","html":"<span class='verse-line'>{}</span>"},"ja512:31.4":{"pli":"Anindito saggamupehi ṭhānan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja512:32.1":{"pli":"Kumbhajātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja513":{"ja513:0.1":{"pli":"Jātaka ","html":"<article id='ja513'><header><ul><li class='division'>{}</li>"},"ja513:0.2":{"pli":"Tiṁsanipāta ","html":"<li>{}</li>"},"ja513:0.3":{"pli":"Kiṁchandavagga ","html":"<li>{}</li></ul>"},"ja513:0.4":{"pli":"3. Jayaddisajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja513:1.1":{"pli":"“Cirassaṁ vata me udapādi ajja, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja513:1.2":{"pli":"Bhakkho mahā sattamibhattakāle; ","html":"<span class='verse-line'>{}</span>"},"ja513:1.3":{"pli":"Kutosi ko vāsi tadiṅgha brūhi, ","html":"<span class='verse-line'>{}</span>"},"ja513:1.4":{"pli":"Ācikkha jātiṁ vidito yathāsi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:2.1":{"pli":"“Pañcālarājā migavaṁ paviṭṭho, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:2.2":{"pli":"Jayaddiso nāma yadissuto te; ","html":"<span class='verse-line'>{}</span>"},"ja513:2.3":{"pli":"Carāmi kacchāni vanāni cāhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja513:2.4":{"pli":"Pasadaṁ imaṁ khāda mamajja muñca”. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:3.1":{"pli":"“Seneva tvaṁ paṇasi sassamāno, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:3.2":{"pli":"Mamesa bhakkho pasado yaṁ vadesi; ","html":"<span class='verse-line'>{}</span>"},"ja513:3.3":{"pli":"Taṁ khādiyāna pasadaṁ jighaññaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja513:3.4":{"pli":"Khādissaṁ pacchā na vilāpakālo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:4.1":{"pli":"“Na catthi mokkho mama nikkayena, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:4.2":{"pli":"Gantvāna paccāgamanāya paṇhe; ","html":"<span class='verse-line'>{}</span>"},"ja513:4.3":{"pli":"Taṁ saṅgaraṁ brāhmaṇassappadāya, ","html":"<span class='verse-line'>{}</span>"},"ja513:4.4":{"pli":"Saccānurakkhī punarāvajissaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:5.1":{"pli":"“Kiṁ kammajātaṁ anutappate tvaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:5.2":{"pli":"Pattaṁ samīpaṁ maraṇassa rāja; ","html":"<span class='verse-line'>{}</span>"},"ja513:5.3":{"pli":"Ācikkha me taṁ api sakkuṇemu, ","html":"<span class='verse-line'>{}</span>"},"ja513:5.4":{"pli":"Anujānituṁ āgamanāya paṇhe”. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:6.1":{"pli":"“Katā mayā brāhmaṇassa dhanāsā, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:6.2":{"pli":"Taṁ saṅgaraṁ paṭimukkaṁ na muttaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja513:6.3":{"pli":"Taṁ saṅgaraṁ brāhmaṇassappadāya, ","html":"<span class='verse-line'>{}</span>"},"ja513:6.4":{"pli":"Saccānurakkhī punarāvajissaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:7.1":{"pli":"“Yā te katā brāhmaṇassa dhanāsā, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:7.2":{"pli":"Taṁ saṅgaraṁ paṭimukkaṁ na muttaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja513:7.3":{"pli":"Taṁ saṅgaraṁ brāhmaṇassappadāya, ","html":"<span class='verse-line'>{}</span>"},"ja513:7.4":{"pli":"Saccānurakkhī punarāvajassu”. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:8.1":{"pli":"Mutto ca so porisādassa hatthā, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:8.2":{"pli":"Gantvā sakaṁ mandiraṁ kāmakāmī; ","html":"<span class='verse-line'>{}</span>"},"ja513:8.3":{"pli":"Taṁ saṅgaraṁ brāhmaṇassappadāya, ","html":"<span class='verse-line'>{}</span>"},"ja513:8.4":{"pli":"Āmantayī puttamalīnasattaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:9.1":{"pli":"“Ajjeva rajjaṁ abhisiñcayassu, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:9.2":{"pli":"Dhammaṁ cara sesu paresu cāpi; ","html":"<span class='verse-line'>{}</span>"},"ja513:9.3":{"pli":"Adhammakāro ca te māhu raṭṭhe, ","html":"<span class='verse-line'>{}</span>"},"ja513:9.4":{"pli":"Gacchāmahaṁ porisādassa ñatte”. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:10.1":{"pli":"“Kiṁ kamma kubbaṁ tava deva pāva, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:10.2":{"pli":"Nārādhayī taṁ tadicchāmi sotuṁ; ","html":"<span class='verse-line'>{}</span>"},"ja513:10.3":{"pli":"Yamajja rajjamhi udassaye tuvaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja513:10.4":{"pli":"Rajjampi niccheyyaṁ tayā vināhaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:11.1":{"pli":"“Na kammunā vā vacasā va tāta, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:11.2":{"pli":"Aparādhitohaṁ tuviyaṁ sarāmi; ","html":"<span class='verse-line'>{}</span>"},"ja513:11.3":{"pli":"Sandhiñca katvā purisādakena, ","html":"<span class='verse-line'>{}</span>"},"ja513:11.4":{"pli":"Saccānurakkhī punāhaṁ gamissaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:12.1":{"pli":"“Ahaṁ gamissāmi idheva hohi, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:12.2":{"pli":"Natthi tato jīvato vippamokkho; ","html":"<span class='verse-line'>{}</span>"},"ja513:12.3":{"pli":"Sace tuvaṁ gacchasiyeva rāja, ","html":"<span class='verse-line'>{}</span>"},"ja513:12.4":{"pli":"Ahampi gacchāmi ubho na homa”. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:13.1":{"pli":"“Addhā hi tāta satānesa dhammo, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:13.2":{"pli":"Maraṇā ca me dukkhataraṁ tadassa; ","html":"<span class='verse-line'>{}</span>"},"ja513:13.3":{"pli":"Kammāsapādo taṁ yadā pacitvā, ","html":"<span class='verse-line'>{}</span>"},"ja513:13.4":{"pli":"Pasayha khāde bhidā rukkhasūle”. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:14.1":{"pli":"“Pāṇena te pāṇamahaṁ nimissaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:14.2":{"pli":"Mā tvaṁ agā porisādassa ñatte; ","html":"<span class='verse-line'>{}</span>"},"ja513:14.3":{"pli":"Etañca te pāṇamahaṁ nimissaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja513:14.4":{"pli":"Tasmā mataṁ jīvitassa vaṇṇemi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:15.1":{"pli":"Tato have dhitimā rājaputto, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:15.2":{"pli":"Vanditvā mātu ca pitu ca pāde; ","html":"<span class='verse-line'>{}</span>"},"ja513:15.3":{"pli":"Dukhinissa mātā nipatā pathabyā, ","html":"<span class='verse-line'>{}</span>"},"ja513:15.4":{"pli":"Pitāssa paggayha bhujāni kandati. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:16.1":{"pli":"Taṁ gacchantaṁ tāva pitā viditvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:16.2":{"pli":"Parammukho vandati pañjalīko; ","html":"<span class='verse-line'>{}</span>"},"ja513:16.3":{"pli":"“Somo ca rājā varuṇo ca rājā, ","html":"<span class='verse-line'>{}</span>"},"ja513:16.4":{"pli":"Pajāpatī candimā sūriyo ca; ","html":"<span class='verse-line'>{}</span>"},"ja513:16.5":{"pli":"Etehi gutto purisādakamhā, ","html":"<span class='verse-line'>{}</span>"},"ja513:16.6":{"pli":"Anuññāto sotthi paccehi tāta”. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:17.1":{"pli":"“Yaṁ daṇḍakirañño gatassa mātā, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:17.2":{"pli":"Rāmassakāsi sotthānaṁ suguttā; ","html":"<span class='verse-line'>{}</span>"},"ja513:17.3":{"pli":"Taṁ te ahaṁ sotthānaṁ karomi, ","html":"<span class='verse-line'>{}</span>"},"ja513:17.4":{"pli":"Etena saccena sarantu devā; ","html":"<span class='verse-line'>{}</span>"},"ja513:17.5":{"pli":"Anuññāto sotthi paccehi putta”. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:18.1":{"pli":"“Āvī raho vāpi manopadosaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:18.2":{"pli":"Nāhaṁ sare jātu malīnasatte; ","html":"<span class='verse-line'>{}</span>"},"ja513:18.3":{"pli":"Etena saccena sarantu devā, ","html":"<span class='verse-line'>{}</span>"},"ja513:18.4":{"pli":"Anuññāto sotthi paccehi bhātika”. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:19.1":{"pli":"“Yasmā ca me anadhimanosi sāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:19.2":{"pli":"Na cāpi me manasā appiyosi; ","html":"<span class='verse-line'>{}</span>"},"ja513:19.3":{"pli":"Etena saccena sarantu devā, ","html":"<span class='verse-line'>{}</span>"},"ja513:19.4":{"pli":"Anuññāto sotthi paccehi sāmi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:20.1":{"pli":"“Brahā ujū cārumukho kutosi, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:20.2":{"pli":"Na maṁ pajānāsi vane vasantaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja513:20.3":{"pli":"Luddaṁ maṁ ñatvā ‘purisādako’ti, ","html":"<span class='verse-line'>{}</span>"},"ja513:20.4":{"pli":"Ko sotthimājānamidhāvajeyya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:21.1":{"pli":"“Jānāmi ludda purisādako tvaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:21.2":{"pli":"Na taṁ na jānāmi vane vasantaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja513:21.3":{"pli":"Ahañca puttosmi jayaddisassa, ","html":"<span class='verse-line'>{}</span>"},"ja513:21.4":{"pli":"Mamajja khāda pituno pamokkhā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:22.1":{"pli":"“Jānāmi puttoti jayaddisassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:22.2":{"pli":"Tathā hi vo mukhavaṇṇo ubhinnaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja513:22.3":{"pli":"Sudukkaraññeva kataṁ tavedaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja513:22.4":{"pli":"Yo mattumicche pituno pamokkhā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:23.1":{"pli":"“Na dukkaraṁ kiñci mahettha maññe, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:23.2":{"pli":"Yo mattumicche pituno pamokkhā; ","html":"<span class='verse-line'>{}</span>"},"ja513:23.3":{"pli":"Mātu ca hetu paraloka gantvā, ","html":"<span class='verse-line'>{}</span>"},"ja513:23.4":{"pli":"Sukhena saggena ca sampayutto”. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:24.1":{"pli":"“Ahañca kho attano pāpakiriyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:24.2":{"pli":"Āvī raho vāpi sare na jātu; ","html":"<span class='verse-line'>{}</span>"},"ja513:24.3":{"pli":"Saṅkhātajātīmaraṇohamasmi, ","html":"<span class='verse-line'>{}</span>"},"ja513:24.4":{"pli":"Yatheva me idha tathā parattha. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:25.1":{"pli":"Khādajja maṁ dāni mahānubhāva, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:25.2":{"pli":"Karassu kiccāni imaṁ sarīraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja513:25.3":{"pli":"Rukkhassa vā te papatāmi aggā, ","html":"<span class='verse-line'>{}</span>"},"ja513:25.4":{"pli":"Chādayamāno mayhaṁ tvamadesi maṁsaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:26.1":{"pli":"“Idañca te ruccati rājaputta, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:26.2":{"pli":"Cajesi pāṇaṁ pituno pamokkhā; ","html":"<span class='verse-line'>{}</span>"},"ja513:26.3":{"pli":"Tasmā hi so tvaṁ taramānarūpo, ","html":"<span class='verse-line'>{}</span>"},"ja513:26.4":{"pli":"Sambhañja kaṭṭhāni jalehi aggiṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:27.1":{"pli":"Tato have dhitimā rājaputto, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:27.2":{"pli":"Dāruṁ samāhatvā mahantamaggiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja513:27.3":{"pli":"Sandīpayitvā paṭivedayittha, ","html":"<span class='verse-line'>{}</span>"},"ja513:27.4":{"pli":"“Ādīpito dāni mahāyamaggi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:28.1":{"pli":"“Khādajja maṁ dāni pasayhakāri, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:28.2":{"pli":"Kiṁ maṁ muhuṁ pekkhasi haṭṭhalomo; ","html":"<span class='verse-line'>{}</span>"},"ja513:28.3":{"pli":"Tathā tathā tuyhamahaṁ karomi, ","html":"<span class='verse-line'>{}</span>"},"ja513:28.4":{"pli":"Yathā yathā maṁ chādayamāno adesi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:29.1":{"pli":"“Ko tādisaṁ arahati khāditāye, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:29.2":{"pli":"Dhamme ṭhitaṁ saccavādiṁ vadaññuṁ; ","html":"<span class='verse-line'>{}</span>"},"ja513:29.3":{"pli":"Muddhāpi tassa viphaleyya sattadhā, ","html":"<span class='verse-line'>{}</span>"},"ja513:29.4":{"pli":"Yo tādisaṁ saccavādiṁ adeyya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:30.1":{"pli":"“Idañhi so brāhmaṇaṁ maññamāno, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:30.2":{"pli":"Saso avāsesi sake sarīre; ","html":"<span class='verse-line'>{}</span>"},"ja513:30.3":{"pli":"Teneva so candimā devaputto, ","html":"<span class='verse-line'>{}</span>"},"ja513:30.4":{"pli":"Sasatthuto kāmaduhajja yakkha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:31.1":{"pli":"“Cando yathā rāhumukhā pamutto, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:31.2":{"pli":"Virocate pannaraseva bhāṇumā; ","html":"<span class='verse-line'>{}</span>"},"ja513:31.3":{"pli":"Evaṁ tuvaṁ porisādā pamutto, ","html":"<span class='verse-line'>{}</span>"},"ja513:31.4":{"pli":"Viroca kapile mahānubhāva; ","html":"<span class='verse-line'>{}</span>"},"ja513:31.5":{"pli":"Āmodayaṁ pitaraṁ mātarañca, ","html":"<span class='verse-line'>{}</span>"},"ja513:31.6":{"pli":"Sabbo ca te nandatu ñātipakkho”. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:32.1":{"pli":"Tato have dhitimā rājaputto, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:32.2":{"pli":"Katañjalī pariyāya porisādaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja513:32.3":{"pli":"Anuññāto sotthi sukhī arogo, ","html":"<span class='verse-line'>{}</span>"},"ja513:32.4":{"pli":"Paccāgamā kapilamalīnasatto. ","html":"<span class='verse-line'>{}</span></p>"},"ja513:33.1":{"pli":"Taṁ negamā jānapadā ca sabbe, ","html":"<p><span class='verse-line'>{}</span>"},"ja513:33.2":{"pli":"Hatthārohā rathikā pattikā ca; ","html":"<span class='verse-line'>{}</span>"},"ja513:33.3":{"pli":"Namassamānā pañjalikā upāgamuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja513:33.4":{"pli":"“Namatthu te dukkarakārakosī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja513:34.1":{"pli":"Jayaddisajātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}