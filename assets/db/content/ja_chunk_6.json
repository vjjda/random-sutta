{"ja285":{"ja285:0.1":{"pli":"Jātaka ","html":"<article id='ja285'><header><ul><li class='division'>{}</li>"},"ja285:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja285:0.3":{"pli":"Abbhantaravagga ","html":"<li>{}</li></ul>"},"ja285:0.4":{"pli":"5. Maṇisūkarajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja285:1.1":{"pli":"“Dariyā satta vassāni, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja285:1.2":{"pli":"tiṁsamattā vasāmase; ","html":"<span class='verse-line'>{}</span>"},"ja285:1.3":{"pli":"Haññāma maṇino ābhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja285:1.4":{"pli":"iti no mantanaṁ ahu. ","html":"<span class='verse-line'>{}</span></p>"},"ja285:2.1":{"pli":"Yāvatā maṇiṁ ghaṁsāma, ","html":"<p><span class='verse-line'>{}</span>"},"ja285:2.2":{"pli":"bhiyyo vodāyate maṇi; ","html":"<span class='verse-line'>{}</span>"},"ja285:2.3":{"pli":"Idañca dāni pucchāma, ","html":"<span class='verse-line'>{}</span>"},"ja285:2.4":{"pli":"kiṁ kiccaṁ idha maññasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja285:3.1":{"pli":"“Ayaṁ maṇi veḷūriyo, ","html":"<p><span class='verse-line'>{}</span>"},"ja285:3.2":{"pli":"akāco vimalo subho; ","html":"<span class='verse-line'>{}</span>"},"ja285:3.3":{"pli":"Nāssa sakkā siriṁ hantuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja285:3.4":{"pli":"apakkamatha sūkarā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja285:4.1":{"pli":"Maṇisūkarajātakaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja286":{"ja286:0.1":{"pli":"Jātaka ","html":"<article id='ja286'><header><ul><li class='division'>{}</li>"},"ja286:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja286:0.3":{"pli":"Abbhantaravagga ","html":"<li>{}</li></ul>"},"ja286:0.4":{"pli":"6. Sālūkajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja286:1.1":{"pli":"“Mā sālūkassa pihayi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja286:1.2":{"pli":"āturannāni bhuñjati; ","html":"<span class='verse-line'>{}</span>"},"ja286:1.3":{"pli":"Appossukko bhusaṁ khāda, ","html":"<span class='verse-line'>{}</span>"},"ja286:1.4":{"pli":"etaṁ dīghāyulakkhaṇaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja286:2.1":{"pli":"Idāni so idhāgantvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja286:2.2":{"pli":"atithī yuttasevako; ","html":"<span class='verse-line'>{}</span>"},"ja286:2.3":{"pli":"Atha dakkhasi sālūkaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja286:2.4":{"pli":"sayantaṁ musaluttaraṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja286:3.1":{"pli":"Vikantaṁ sūkaraṁ disvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja286:3.2":{"pli":"sayantaṁ musaluttaraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja286:3.3":{"pli":"Jaraggavā vicintesuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja286:3.4":{"pli":"varamhākaṁ bhusāmivāti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja286:4.1":{"pli":"Sālūkajātakaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja287":{"ja287:0.1":{"pli":"Jātaka ","html":"<article id='ja287'><header><ul><li class='division'>{}</li>"},"ja287:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja287:0.3":{"pli":"Abbhantaravagga ","html":"<li>{}</li></ul>"},"ja287:0.4":{"pli":"7. Lābhagarahajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja287:1.1":{"pli":"“Nānummatto nāpisuṇo, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja287:1.2":{"pli":"nānaṭo nākutūhalo; ","html":"<span class='verse-line'>{}</span>"},"ja287:1.3":{"pli":"Mūḷhesu labhate lābhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja287:1.4":{"pli":"esā te anusāsanī”. ","html":"<span class='verse-line'>{}</span></p>"},"ja287:2.1":{"pli":"“Dhiratthu taṁ yasalābhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja287:2.2":{"pli":"dhanalābhañca brāhmaṇa; ","html":"<span class='verse-line'>{}</span>"},"ja287:2.3":{"pli":"Yā vutti vinipātena, ","html":"<span class='verse-line'>{}</span>"},"ja287:2.4":{"pli":"adhammacaraṇena vā. ","html":"<span class='verse-line'>{}</span></p>"},"ja287:3.1":{"pli":"Api ce pattamādāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja287:3.2":{"pli":"anagāro paribbaje; ","html":"<span class='verse-line'>{}</span>"},"ja287:3.3":{"pli":"Esāva jīvikā seyyo, ","html":"<span class='verse-line'>{}</span>"},"ja287:3.4":{"pli":"yā cādhammena esanā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja287:4.1":{"pli":"Lābhagarahajātakaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja288":{"ja288:0.1":{"pli":"Jātaka ","html":"<article id='ja288'><header><ul><li class='division'>{}</li>"},"ja288:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja288:0.3":{"pli":"Abbhantaravagga ","html":"<li>{}</li></ul>"},"ja288:0.4":{"pli":"8. Macchuddānajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja288:1.1":{"pli":"“Agghanti macchā adhikaṁ sahassaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja288:1.2":{"pli":"Na so atthi yo imaṁ saddaheyya; ","html":"<span class='verse-line'>{}</span>"},"ja288:1.3":{"pli":"Mayhañca assu idha satta māsā, ","html":"<span class='verse-line'>{}</span>"},"ja288:1.4":{"pli":"Ahampi taṁ macchuddānaṁ kiṇeyyaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja288:2.1":{"pli":"“Macchānaṁ bhojanaṁ datvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja288:2.2":{"pli":"mama dakkhiṇamādisi; ","html":"<span class='verse-line'>{}</span>"},"ja288:2.3":{"pli":"Taṁ dakkhiṇaṁ sarantiyā, ","html":"<span class='verse-line'>{}</span>"},"ja288:2.4":{"pli":"kataṁ apacitiṁ tayā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja288:3.1":{"pli":"“Paduṭṭhacittassa na phāti hoti, ","html":"<p><span class='verse-line'>{}</span>"},"ja288:3.2":{"pli":"Na cāpi taṁ devatā pūjayanti; ","html":"<span class='verse-line'>{}</span>"},"ja288:3.3":{"pli":"Yo bhātaraṁ pettikaṁ sāpateyyaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja288:3.4":{"pli":"Avañcayī dukkaṭakammakārī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja288:4.1":{"pli":"Macchuddānajātakaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja289":{"ja289:0.1":{"pli":"Jātaka ","html":"<article id='ja289'><header><ul><li class='division'>{}</li>"},"ja289:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja289:0.3":{"pli":"Abbhantaravagga ","html":"<li>{}</li></ul>"},"ja289:0.4":{"pli":"9. Nānāchandajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja289:1.1":{"pli":"“Nānāchandā mahārāja, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja289:1.2":{"pli":"ekāgāre vasāmase; ","html":"<span class='verse-line'>{}</span>"},"ja289:1.3":{"pli":"Ahaṁ gāmavaraṁ icche, ","html":"<span class='verse-line'>{}</span>"},"ja289:1.4":{"pli":"brāhmaṇī ca gavaṁ sataṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja289:2.1":{"pli":"Putto ca ājaññarathaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja289:2.2":{"pli":"kaññā ca maṇikuṇḍalaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja289:2.3":{"pli":"Yā cesā puṇṇikā jammī, ","html":"<span class='verse-line'>{}</span>"},"ja289:2.4":{"pli":"udukkhalaṁbhikaṅkhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja289:3.1":{"pli":"“Brāhmaṇassa gāmavaraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja289:3.2":{"pli":"brāhmaṇiyā gavaṁ sataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja289:3.3":{"pli":"Puttassa ājaññarathaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja289:3.4":{"pli":"kaññāya maṇikuṇḍalaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja289:3.5":{"pli":"Yañcetaṁ puṇṇikaṁ jammiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja289:3.6":{"pli":"paṭipādethudukkhalan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja289:4.1":{"pli":"Nānāchandajātakaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja29":{"ja29:0.1":{"pli":"Jātaka ","eng":"Stories of Past Lives 29 ","html":"<article id='ja29'><header><ul><li class='division'>{}</li>"},"ja29:0.2":{"pli":"Ekakanipāta ","eng":"The Book of the Ones ","html":"<li>{}</li>"},"ja29:0.3":{"pli":"Kuruṅgavagga ","eng":"The Four-horned Antelope ","html":"<li>{}</li></ul>"},"ja29:0.4":{"pli":"9. Kaṇhajātaka ","eng":"The Ox Named Black: a past life story ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja29:1.1":{"pli":"“Yato yato garu dhuraṁ, ","eng":"No matter how heavy the load, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>","comm":"An ox raised by an old woman earns money for his “mother” by pulling a heavy load across a deep river. "},"ja29:1.2":{"pli":"yato gambhīravattanī; ","eng":"or how deep the passage, ","html":"<span class='verse-line'>{}</span>"},"ja29:1.3":{"pli":"Tadāssu kaṇhaṁ yuñjanti, ","eng":"when they harness Black, ","html":"<span class='verse-line'>{}</span>"},"ja29:1.4":{"pli":"svāssu taṁ vahate dhuran”ti. ","eng":"he pulls that load. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja29:2.1":{"pli":"Kaṇhajātakaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja290":{"ja290:0.1":{"pli":"Jātaka ","html":"<article id='ja290'><header><ul><li class='division'>{}</li>"},"ja290:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja290:0.3":{"pli":"Abbhantaravagga ","html":"<li>{}</li></ul>"},"ja290:0.4":{"pli":"10. Sīlavīmaṁsakajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja290:1.1":{"pli":"“Sīlaṁ kireva kalyāṇaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja290:1.2":{"pli":"sīlaṁ loke anuttaraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja290:1.3":{"pli":"Passa ghoraviso nāgo, ","html":"<span class='verse-line'>{}</span>"},"ja290:1.4":{"pli":"sīlavāti na haññati. ","html":"<span class='verse-line'>{}</span></p>"},"ja290:2.1":{"pli":"Sohaṁ sīlaṁ samādissaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja290:2.2":{"pli":"loke anumataṁ sivaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja290:2.3":{"pli":"Ariyavuttisamācāro, ","html":"<span class='verse-line'>{}</span>"},"ja290:2.4":{"pli":"yena vuccati sīlavā. ","html":"<span class='verse-line'>{}</span></p>"},"ja290:3.1":{"pli":"Ñātīnañca piyo hoti, ","html":"<p><span class='verse-line'>{}</span>"},"ja290:3.2":{"pli":"mittesu ca virocati; ","html":"<span class='verse-line'>{}</span>"},"ja290:3.3":{"pli":"Kāyassa bhedā sugatiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja290:3.4":{"pli":"upapajjati sīlavā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja290:4.1":{"pli":"Sīlavīmaṁsakajātakaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja290:4.2":{"pli":"Abbhantaravaggo catuttho. ","html":"<p class='endvagga'>{}</p>"},"ja290:5.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja290:6.1":{"pli":"Duma kaṁsavaruttamabyagghamigā, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja290:6.2":{"pli":"Maṇayo maṇi sālukamavhayano; ","html":"<span class='verse-line'>{}</span>"},"ja290:6.3":{"pli":"Anusāsaniyopi ca macchavaro, ","html":"<span class='verse-line'>{}</span>"},"ja290:6.4":{"pli":"Maṇikuṇḍalakena kirena dasāti. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"ja291":{"ja291:0.1":{"pli":"Jātaka ","html":"<article id='ja291'><header><ul><li class='division'>{}</li>"},"ja291:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja291:0.3":{"pli":"Kumbhavagga ","html":"<li>{}</li></ul>"},"ja291:0.4":{"pli":"1. Surāghaṭajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja291:1.1":{"pli":"“Sabbakāmadadaṁ kumbhaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja291:1.2":{"pli":"kuṭaṁ laddhāna dhuttako; ","html":"<span class='verse-line'>{}</span>"},"ja291:1.3":{"pli":"Yāva naṁ anupāleti, ","html":"<span class='verse-line'>{}</span>"},"ja291:1.4":{"pli":"tāva so sukhamedhati. ","html":"<span class='verse-line'>{}</span></p>"},"ja291:2.1":{"pli":"Yadā matto ca ditto ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja291:2.2":{"pli":"pamādā kumbhamabbhidā; ","html":"<span class='verse-line'>{}</span>"},"ja291:2.3":{"pli":"Tadā naggo ca pottho ca, ","html":"<span class='verse-line'>{}</span>"},"ja291:2.4":{"pli":"pacchā bālo vihaññati. ","html":"<span class='verse-line'>{}</span></p>"},"ja291:3.1":{"pli":"Evameva yo dhanaṁ laddhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja291:3.2":{"pli":"Pamatto paribhuñjati; ","html":"<span class='verse-line'>{}</span>"},"ja291:3.3":{"pli":"Pacchā tappati dummedho, ","html":"<span class='verse-line'>{}</span>"},"ja291:3.4":{"pli":"Kuṭaṁ bhitvāva dhuttako”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja291:4.1":{"pli":"Surāghaṭajātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja292":{"ja292:0.1":{"pli":"Jātaka ","html":"<article id='ja292'><header><ul><li class='division'>{}</li>"},"ja292:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja292:0.3":{"pli":"Kumbhavagga ","html":"<li>{}</li></ul>"},"ja292:0.4":{"pli":"2. Supattajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja292:1.1":{"pli":"“Bārāṇasyaṁ mahārāja, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja292:1.2":{"pli":"kākarājā nivāsako; ","html":"<span class='verse-line'>{}</span>"},"ja292:1.3":{"pli":"Asītiyā sahassehi, ","html":"<span class='verse-line'>{}</span>"},"ja292:1.4":{"pli":"supatto parivārito. ","html":"<span class='verse-line'>{}</span></p>"},"ja292:2.1":{"pli":"Tassa dohaḷinī bhariyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja292:2.2":{"pli":"Suphassā bhakkhitumicchati; ","html":"<span class='verse-line'>{}</span>"},"ja292:2.3":{"pli":"Rañño mahānase pakkaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja292:2.4":{"pli":"Paccagghaṁ rājabhojanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja292:3.1":{"pli":"Tesāhaṁ pahito dūto, ","html":"<p><span class='verse-line'>{}</span>"},"ja292:3.2":{"pli":"rañño camhi idhāgato; ","html":"<span class='verse-line'>{}</span>"},"ja292:3.3":{"pli":"Bhattu apacitiṁ kummi, ","html":"<span class='verse-line'>{}</span>"},"ja292:3.4":{"pli":"nāsāyamakaraṁ vaṇan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja292:4.1":{"pli":"Supattajātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja293":{"ja293:0.1":{"pli":"Jātaka ","html":"<article id='ja293'><header><ul><li class='division'>{}</li>"},"ja293:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja293:0.3":{"pli":"Kumbhavagga ","html":"<li>{}</li></ul>"},"ja293:0.4":{"pli":"3. Kāyanibbindajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja293:1.1":{"pli":"“Phuṭṭhassa me aññatarena byādhinā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja293:1.2":{"pli":"Rogena bāḷhaṁ dukhitassa ruppato; ","html":"<span class='verse-line'>{}</span>"},"ja293:1.3":{"pli":"Parisussati khippamidaṁ kaḷevaraṁ, ","html":"<span class='verse-line'>{}</span>"},"ja293:1.4":{"pli":"Pupphaṁ yathā paṁsuni ātape kataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja293:2.1":{"pli":"Ajaññaṁ jaññasaṅkhātaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja293:2.2":{"pli":"asuciṁ sucisammataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja293:2.3":{"pli":"Nānākuṇapaparipūraṁ, ","html":"<span class='verse-line'>{}</span>"},"ja293:2.4":{"pli":"jaññarūpaṁ apassato. ","html":"<span class='verse-line'>{}</span></p>"},"ja293:3.1":{"pli":"Dhiratthumaṁ āturaṁ pūtikāyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja293:3.2":{"pli":"Jegucchiyaṁ assuciṁ byādhidhammaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja293:3.3":{"pli":"Yatthappamattā adhimucchitā pajā, ","html":"<span class='verse-line'>{}</span>"},"ja293:3.4":{"pli":"Hāpenti maggaṁ sugatūpapattiyā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja293:4.1":{"pli":"Kāyanibbindajātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja294":{"ja294:0.1":{"pli":"Jātaka ","html":"<article id='ja294'><header><ul><li class='division'>{}</li>"},"ja294:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja294:0.3":{"pli":"Kumbhavagga ","html":"<li>{}</li></ul>"},"ja294:0.4":{"pli":"4. Jambukhādakajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja294:1.1":{"pli":"“Koyaṁ bindussaro vaggu, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja294:1.2":{"pli":"saravantānamuttamo; ","html":"<span class='verse-line'>{}</span>"},"ja294:1.3":{"pli":"Accuto jambusākhāya, ","html":"<span class='verse-line'>{}</span>"},"ja294:1.4":{"pli":"moracchāpova kūjati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja294:2.1":{"pli":"“Kulaputtova jānāti, ","html":"<p><span class='verse-line'>{}</span>"},"ja294:2.2":{"pli":"kulaputtaṁ pasaṁsituṁ; ","html":"<span class='verse-line'>{}</span>"},"ja294:2.3":{"pli":"Byagghacchāpasarīvaṇṇa, ","html":"<span class='verse-line'>{}</span>"},"ja294:2.4":{"pli":"bhuñja samma dadāmi te”. ","html":"<span class='verse-line'>{}</span></p>"},"ja294:3.1":{"pli":"“Cirassaṁ vata passāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja294:3.2":{"pli":"musāvādī samāgate; ","html":"<span class='verse-line'>{}</span>"},"ja294:3.3":{"pli":"Vantādaṁ kuṇapādañca, ","html":"<span class='verse-line'>{}</span>"},"ja294:3.4":{"pli":"aññamaññaṁ pasaṁsake”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja294:4.1":{"pli":"Jambukhādakajātakaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja295":{"ja295:0.1":{"pli":"Jātaka ","html":"<article id='ja295'><header><ul><li class='division'>{}</li>"},"ja295:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja295:0.3":{"pli":"Kumbhavagga ","html":"<li>{}</li></ul>"},"ja295:0.4":{"pli":"5. Antajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja295:1.1":{"pli":"“Usabhasseva te khandho, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja295:1.2":{"pli":"sīhasseva vijambhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja295:1.3":{"pli":"Migarāja namo tyatthu, ","html":"<span class='verse-line'>{}</span>"},"ja295:1.4":{"pli":"api kiñci labhāmase”. ","html":"<span class='verse-line'>{}</span></p>"},"ja295:2.1":{"pli":"“Kulaputtova jānāti, ","html":"<p><span class='verse-line'>{}</span>"},"ja295:2.2":{"pli":"kulaputtaṁ pasaṁsituṁ; ","html":"<span class='verse-line'>{}</span>"},"ja295:2.3":{"pli":"Mayūragīvasaṅkāsa, ","html":"<span class='verse-line'>{}</span>"},"ja295:2.4":{"pli":"ito pariyāhi vāyasa”. ","html":"<span class='verse-line'>{}</span></p>"},"ja295:3.1":{"pli":"“Migānaṁ siṅgālo anto, ","html":"<p><span class='verse-line'>{}</span>"},"ja295:3.2":{"pli":"pakkhīnaṁ pana vāyaso; ","html":"<span class='verse-line'>{}</span>"},"ja295:3.3":{"pli":"Eraṇḍo anto rukkhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja295:3.4":{"pli":"tayo antā samāgatā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja295:4.1":{"pli":"Antajātakaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja296":{"ja296:0.1":{"pli":"Jātaka ","html":"<article id='ja296'><header><ul><li class='division'>{}</li>"},"ja296:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja296:0.3":{"pli":"Kumbhavagga ","html":"<li>{}</li></ul>"},"ja296:0.4":{"pli":"6. Samuddajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja296:1.1":{"pli":"“Ko nāyaṁ loṇatoyasmiṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja296:1.2":{"pli":"samantā paridhāvati; ","html":"<span class='verse-line'>{}</span>"},"ja296:1.3":{"pli":"Macche makare ca vāreti, ","html":"<span class='verse-line'>{}</span>"},"ja296:1.4":{"pli":"ūmīsu ca vihaññati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja296:2.1":{"pli":"“Anantapāyī sakuṇo, ","html":"<p><span class='verse-line'>{}</span>"},"ja296:2.2":{"pli":"atittoti disāsuto; ","html":"<span class='verse-line'>{}</span>"},"ja296:2.3":{"pli":"Samuddaṁ pātumicchāmi, ","html":"<span class='verse-line'>{}</span>"},"ja296:2.4":{"pli":"sāgaraṁ saritaṁ patiṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja296:3.1":{"pli":"“So ayaṁ hāyati ceva, ","html":"<p><span class='verse-line'>{}</span>"},"ja296:3.2":{"pli":"pūrate ca mahodadhi; ","html":"<span class='verse-line'>{}</span>"},"ja296:3.3":{"pli":"Nāssa nāyati pītanto, ","html":"<span class='verse-line'>{}</span>"},"ja296:3.4":{"pli":"apeyyo kira sāgaro”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja296:4.1":{"pli":"Samuddajātakaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja297":{"ja297:0.1":{"pli":"Jātaka ","html":"<article id='ja297'><header><ul><li class='division'>{}</li>"},"ja297:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja297:0.3":{"pli":"Kumbhavagga ","html":"<li>{}</li></ul>"},"ja297:0.4":{"pli":"7. Kāmavilāpajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja297:1.1":{"pli":"“Ucce sakuṇa ḍemāna, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja297:1.2":{"pli":"pattayāna vihaṅgama; ","html":"<span class='verse-line'>{}</span>"},"ja297:1.3":{"pli":"Vajjāsi kho tvaṁ vāmūruṁ, ","html":"<span class='verse-line'>{}</span>"},"ja297:1.4":{"pli":"ciraṁ kho sā karissati. ","html":"<span class='verse-line'>{}</span></p>"},"ja297:2.1":{"pli":"Idaṁ kho sā na jānāti, ","html":"<p><span class='verse-line'>{}</span>"},"ja297:2.2":{"pli":"asiṁ sattiñca oḍḍitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja297:2.3":{"pli":"Sā caṇḍī kāhati kodhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja297:2.4":{"pli":"taṁ me tapati no idaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja297:3.1":{"pli":"Esa uppalasannāho, ","html":"<p><span class='verse-line'>{}</span>"},"ja297:3.2":{"pli":"nikkhañcussīsakohitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja297:3.3":{"pli":"Kāsikañca muduṁ vatthaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja297:3.4":{"pli":"tappetu dhanikā piyā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja297:4.1":{"pli":"Kāmavilāpajātakaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja298":{"ja298:0.1":{"pli":"Jātaka ","html":"<article id='ja298'><header><ul><li class='division'>{}</li>"},"ja298:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja298:0.3":{"pli":"Kumbhavagga ","html":"<li>{}</li></ul>"},"ja298:0.4":{"pli":"8. Udumbarajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja298:1.1":{"pli":"“Udumbarā cime pakkā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja298:1.2":{"pli":"nigrodhā ca kapitthanā; ","html":"<span class='verse-line'>{}</span>"},"ja298:1.3":{"pli":"Ehi nikkhama bhuñjassu, ","html":"<span class='verse-line'>{}</span>"},"ja298:1.4":{"pli":"kiṁ jighacchāya miyyasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja298:2.1":{"pli":"“Evaṁ so suhito hoti, ","html":"<p><span class='verse-line'>{}</span>"},"ja298:2.2":{"pli":"yo vuḍḍhamapacāyati; ","html":"<span class='verse-line'>{}</span>"},"ja298:2.3":{"pli":"Yathāhamajja suhito, ","html":"<span class='verse-line'>{}</span>"},"ja298:2.4":{"pli":"dumapakkāni māsito”. ","html":"<span class='verse-line'>{}</span></p>"},"ja298:3.1":{"pli":"“Yaṁ vanejo vanejassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja298:3.2":{"pli":"vañceyya kapino kapi; ","html":"<span class='verse-line'>{}</span>"},"ja298:3.3":{"pli":"Daharo kapi saddheyya, ","html":"<span class='verse-line'>{}</span>"},"ja298:3.4":{"pli":"na hi jiṇṇo jarākapī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja298:4.1":{"pli":"Udumbarajātakaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja299":{"ja299:0.1":{"pli":"Jātaka ","html":"<article id='ja299'><header><ul><li class='division'>{}</li>"},"ja299:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja299:0.3":{"pli":"Kumbhavagga ","html":"<li>{}</li></ul>"},"ja299:0.4":{"pli":"9. Komāraputtajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja299:1.1":{"pli":"“Pure tuvaṁ sīlavataṁ sakāse, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja299:1.2":{"pli":"Okkantikaṁ kīḷasi assamamhi; ","html":"<span class='verse-line'>{}</span>"},"ja299:1.3":{"pli":"Karohare makkaṭiyāni makkaṭa, ","html":"<span class='verse-line'>{}</span>"},"ja299:1.4":{"pli":"Na taṁ mayaṁ sīlavataṁ ramāma”. ","html":"<span class='verse-line'>{}</span></p>"},"ja299:2.1":{"pli":"“Sutā hi mayhaṁ paramā visuddhi, ","html":"<p><span class='verse-line'>{}</span>"},"ja299:2.2":{"pli":"Komāraputtassa bahussutassa; ","html":"<span class='verse-line'>{}</span>"},"ja299:2.3":{"pli":"Mā dāni maṁ maññi tuvaṁ yathā pure, ","html":"<span class='verse-line'>{}</span>"},"ja299:2.4":{"pli":"Jhānānuyutto viharāmi āvuso”. ","html":"<span class='verse-line'>{}</span></p>"},"ja299:3.1":{"pli":"“Sacepi selasmi vapeyya bījaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja299:3.2":{"pli":"Devo ca vasse na hi taṁ virūḷhe; ","html":"<span class='verse-line'>{}</span>"},"ja299:3.3":{"pli":"Sutā hi te sā paramā visuddhi, ","html":"<span class='verse-line'>{}</span>"},"ja299:3.4":{"pli":"Ārā tuvaṁ makkaṭa jhānabhūmiyā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja299:4.1":{"pli":"Komāraputtajātakaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja3":{"ja3:0.1":{"pli":"Jātaka ","eng":"Stories of Past Lives 3 ","html":"<article id='ja3'><header><ul><li class='division'>{}</li>"},"ja3:0.2":{"pli":"Ekakanipāta ","eng":"The Book of the Ones ","html":"<li>{}</li>"},"ja3:0.3":{"pli":"Apaṇṇakavagga ","eng":"Unfailing ","html":"<li>{}</li></ul>"},"ja3:0.4":{"pli":"3. Serivavāṇijajātaka ","eng":"The Wanton Merchant: a past life story ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja3:1.1":{"pli":"“Idha ce naṁ virādhesi, ","eng":"If you fail to achieve ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>","comm":"This verse is mostly the same as <a href='index.html?q=an8.29#15.1'>AN 8.29:15.1</a>, which I believe is referring to the same story. The commentary tells of a fraudulent merchant who tried to trick a poor woman into thinking her gold vase was worthless. "},"ja3:1.2":{"pli":"saddhammassa niyāmataṁ; ","eng":"certainty regarding the true teaching ","html":"<span class='verse-line'>{}</span>"},"ja3:1.3":{"pli":"Ciraṁ tvaṁ anutappesi, ","eng":"you’ll regret it for a long time, ","html":"<span class='verse-line'>{}</span>"},"ja3:1.4":{"pli":"serivāyaṁva vāṇijo”ti. ","eng":"like this wanton merchant. ","html":"<span class='verse-line'>{}</span></p></blockquote>","comm":"The commentary says his name was <i lang='pi' translate='no'>serivā</i>, but this seems implausible, as it is supposed to be after the city of Seri, but that does not appear anywhere else, nor does it play a role in the story. Rather, read <i lang='pi' translate='no'>seri</i> as “wanton”, for which see <i lang='pi' translate='no'>svairī</i> in Chāndogya Upaniṣad 5.11.5. <i lang='pi' translate='no'>Serivā</i> is the possessive form, “wanton one”. "},"ja3:2.1":{"pli":"Serivavāṇijajātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja30":{"ja30:0.1":{"pli":"Jātaka ","eng":"Stories of Past Lives 30 ","html":"<article id='ja30'><header><ul><li class='division'>{}</li>"},"ja30:0.2":{"pli":"Ekakanipāta ","eng":"The Book of the Ones ","html":"<li>{}</li>"},"ja30:0.3":{"pli":"Kuruṅgavagga ","eng":"The Four-horned Antelope ","html":"<li>{}</li></ul>"},"ja30:0.4":{"pli":"10. Munikajātaka ","eng":"The Pig Named Munika: a past life story ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja30:1.1":{"pli":"“Mā munikassa pihayi, ","eng":"Envy not what is Munika’s, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>","comm":"A hard-working ox is jealous of the rice scoffed by the pig Munika, but his brother tells him not to worry, as the pig is being fattened for the feast. "},"ja30:1.2":{"pli":"āturannāni bhuñjati; ","eng":"for he eats the food of the terminally ill. ","html":"<span class='verse-line'>{}</span>"},"ja30:1.3":{"pli":"Appossukko bhusaṁ khāda, ","eng":"Don’t worry, just eat your chaff, ","html":"<span class='verse-line'>{}</span>"},"ja30:1.4":{"pli":"etaṁ dīghāyulakkhaṇan”ti. ","eng":"this is a mark of long life. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja30:2.1":{"pli":"Munikajātakaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja30:2.2":{"pli":"Kuruṅgavaggo tatiyo. ","html":"<p class='endvagga'>{}</p>"},"ja30:3.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja30:4.1":{"pli":"Kuruṅgassa kukkuragojavaro, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja30:4.2":{"pli":"Puna vāḷavassasirivhayano; ","html":"<span class='verse-line'>{}</span>"},"ja30:4.3":{"pli":"Mahiḷāmukhanāmanuññavaro, ","html":"<span class='verse-line'>{}</span>"},"ja30:4.4":{"pli":"Vahate dhura munikena dasāti. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"ja300":{"ja300:0.1":{"pli":"Jātaka ","html":"<article id='ja300'><header><ul><li class='division'>{}</li>"},"ja300:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja300:0.3":{"pli":"Kumbhavagga ","html":"<li>{}</li></ul>"},"ja300:0.4":{"pli":"10. Vakajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja300:1.1":{"pli":"“Parapāṇarodhā jīvanto, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja300:1.2":{"pli":"maṁsalohitabhojano; ","html":"<span class='verse-line'>{}</span>"},"ja300:1.3":{"pli":"Vako vataṁ samādāya, ","html":"<span class='verse-line'>{}</span>"},"ja300:1.4":{"pli":"upapajji uposathaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja300:2.1":{"pli":"Tassa sakko vataññāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja300:2.2":{"pli":"ajarūpenupāgami; ","html":"<span class='verse-line'>{}</span>"},"ja300:2.3":{"pli":"Vītatapo ajjhappatto, ","html":"<span class='verse-line'>{}</span>"},"ja300:2.4":{"pli":"bhañji lohitapo tapaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja300:3.1":{"pli":"Evameva idhekacce, ","html":"<p><span class='verse-line'>{}</span>"},"ja300:3.2":{"pli":"Samādānamhi dubbalā; ","html":"<span class='verse-line'>{}</span>"},"ja300:3.3":{"pli":"Lahuṁ karonti attānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja300:3.4":{"pli":"Vakova ajakāraṇā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja300:4.1":{"pli":"Vakajātakaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja300:4.2":{"pli":"Kumbhavaggo pañcamo. ","html":"<p class='endvagga'>{}</p>"},"ja300:5.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja300:6.1":{"pli":"Varakumbha supattasirivhayano, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja300:6.2":{"pli":"Sucisammata bindusaro cusabho; ","html":"<span class='verse-line'>{}</span>"},"ja300:6.3":{"pli":"Saritaṁpati caṇḍi jarākapinā, ","html":"<span class='verse-line'>{}</span>"},"ja300:6.4":{"pli":"Atha makkaṭiyā vakakena dasāti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja300:7.1":{"pli":"Atha vagguddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja300:8.1":{"pli":"Saṅkappo padumo ceva, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja300:8.2":{"pli":"Udapānena tatiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja300:8.3":{"pli":"Abbhantaraṁ ghaṭabhedaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja300:8.4":{"pli":"Tikanipātamhilaṅkatanti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja300:9.1":{"pli":"Tikanipātaṁ niṭṭhitaṁ. ","html":"<p class='endsection'>{}</p></article>"}},"ja301":{"ja301:0.1":{"pli":"Jātaka ","html":"<article id='ja301'><header><ul><li class='division'>{}</li>"},"ja301:0.2":{"pli":"Catukkanipāta ","html":"<li>{}</li>"},"ja301:0.3":{"pli":"Kāliṅgavagga ","html":"<li>{}</li></ul>"},"ja301:0.4":{"pli":"1. Cūḷakāliṅgajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja301:1.1":{"pli":"“Vivarathimāsaṁ dvāraṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja301:1.2":{"pli":"Nagaraṁ pavisantu aruṇarājassa; ","html":"<span class='verse-line'>{}</span>"},"ja301:1.3":{"pli":"Sīhena susiṭṭhena, ","html":"<span class='verse-line'>{}</span>"},"ja301:1.4":{"pli":"Surakkhitaṁ nandisenena”. ","html":"<span class='verse-line'>{}</span></p>"},"ja301:2.1":{"pli":"“Jayo kaliṅgānamasayhasāhinaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja301:2.2":{"pli":"Parājayo anayo assakānaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja301:2.3":{"pli":"Icceva te bhāsitaṁ brahmacāri, ","html":"<span class='verse-line'>{}</span>"},"ja301:2.4":{"pli":"Na ujjubhūtā vitathaṁ bhaṇanti”. ","html":"<span class='verse-line'>{}</span></p>"},"ja301:3.1":{"pli":"“Devā musāvādamupātivattā, ","html":"<p><span class='verse-line'>{}</span>"},"ja301:3.2":{"pli":"Saccaṁ dhanaṁ paramaṁ tesu sakka; ","html":"<span class='verse-line'>{}</span>"},"ja301:3.3":{"pli":"Taṁ te musā bhāsitaṁ devarāja, ","html":"<span class='verse-line'>{}</span>"},"ja301:3.4":{"pli":"Kiṁ vā paṭicca maghavā mahinda”. ","html":"<span class='verse-line'>{}</span></p>"},"ja301:4.1":{"pli":"“Nanu te sutaṁ brāhmaṇa bhaññamāne, ","html":"<p><span class='verse-line'>{}</span>"},"ja301:4.2":{"pli":"Devā na issanti purisaparakkamassa; ","html":"<span class='verse-line'>{}</span>"},"ja301:4.3":{"pli":"Damo samādhi manaso abhejjo, ","html":"<span class='verse-line'>{}</span>"},"ja301:4.4":{"pli":"Abyaggatā nikkamanañca kāle; ","html":"<span class='verse-line'>{}</span>"},"ja301:4.5":{"pli":"Daḷhañca viriyaṁ purisaparakkamo ca, ","html":"<span class='verse-line'>{}</span>"},"ja301:4.6":{"pli":"Teneva āsi vijayo assakānan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja301:5.1":{"pli":"Cūḷakāliṅgajātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja302":{"ja302:0.1":{"pli":"Jātaka ","html":"<article id='ja302'><header><ul><li class='division'>{}</li>"},"ja302:0.2":{"pli":"Catukkanipāta ","html":"<li>{}</li>"},"ja302:0.3":{"pli":"Kāliṅgavagga ","html":"<li>{}</li></ul>"},"ja302:0.4":{"pli":"2. Mahāassārohajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja302:1.1":{"pli":"“Adeyyesu dadaṁ dānaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja302:1.2":{"pli":"deyyesu nappavecchati; ","html":"<span class='verse-line'>{}</span>"},"ja302:1.3":{"pli":"Āpāsu byasanaṁ patto, ","html":"<span class='verse-line'>{}</span>"},"ja302:1.4":{"pli":"sahāyaṁ nādhigacchati. ","html":"<span class='verse-line'>{}</span></p>"},"ja302:2.1":{"pli":"Nādeyyesu dadaṁ dānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja302:2.2":{"pli":"deyyesu yo pavecchati; ","html":"<span class='verse-line'>{}</span>"},"ja302:2.3":{"pli":"Āpāsu byasanaṁ patto, ","html":"<span class='verse-line'>{}</span>"},"ja302:2.4":{"pli":"sahāyamadhigacchati. ","html":"<span class='verse-line'>{}</span></p>"},"ja302:3.1":{"pli":"Saññogasambhogavisesadassanaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja302:3.2":{"pli":"Anariyadhammesu saṭhesu nassati; ","html":"<span class='verse-line'>{}</span>"},"ja302:3.3":{"pli":"Katañca ariyesu ca ajjavesu, ","html":"<span class='verse-line'>{}</span>"},"ja302:3.4":{"pli":"Mahapphalaṁ hoti aṇumpi tādisu. ","html":"<span class='verse-line'>{}</span></p>"},"ja302:4.1":{"pli":"Yo pubbe katakalyāṇo, ","html":"<p><span class='verse-line'>{}</span>"},"ja302:4.2":{"pli":"Akā loke sudukkaraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja302:4.3":{"pli":"Pacchā kayirā na vā kayirā, ","html":"<span class='verse-line'>{}</span>"},"ja302:4.4":{"pli":"Accantaṁ pūjanāraho”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja302:5.1":{"pli":"Mahāassārohajātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja303":{"ja303:0.1":{"pli":"Jātaka ","html":"<article id='ja303'><header><ul><li class='division'>{}</li>"},"ja303:0.2":{"pli":"Catukkanipāta ","html":"<li>{}</li>"},"ja303:0.3":{"pli":"Kāliṅgavagga ","html":"<li>{}</li></ul>"},"ja303:0.4":{"pli":"3. Ekarājajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja303:1.1":{"pli":"“Anuttare kāmaguṇe samiddhe, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja303:1.2":{"pli":"Bhutvāna pubbe vasī ekarāja; ","html":"<span class='verse-line'>{}</span>"},"ja303:1.3":{"pli":"So dāni dugge narakamhi khitto, ","html":"<span class='verse-line'>{}</span>"},"ja303:1.4":{"pli":"Nappajjahe vaṇṇabalaṁ purāṇaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja303:2.1":{"pli":"“Pubbeva khantī ca tapo ca mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja303:2.2":{"pli":"Sampatthitā dubbhisena ahosi; ","html":"<span class='verse-line'>{}</span>"},"ja303:2.3":{"pli":"Taṁ dāni laddhāna kathaṁ nu rāja, ","html":"<span class='verse-line'>{}</span>"},"ja303:2.4":{"pli":"Jahe ahaṁ vaṇṇabalaṁ purāṇaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja303:3.1":{"pli":"Sabbā kirevaṁ pariniṭṭhitāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja303:3.2":{"pli":"Yasassinaṁ paññavantaṁ visayha; ","html":"<span class='verse-line'>{}</span>"},"ja303:3.3":{"pli":"Yaso ca laddhā purimaṁ uḷāraṁ, ","html":"<span class='verse-line'>{}</span>"},"ja303:3.4":{"pli":"Nappajjahe vaṇṇabalaṁ purāṇaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja303:4.1":{"pli":"Panujja dukkhena sukhaṁ janinda, ","html":"<p><span class='verse-line'>{}</span>"},"ja303:4.2":{"pli":"Sukhena vā dukkhamasayhasāhi; ","html":"<span class='verse-line'>{}</span>"},"ja303:4.3":{"pli":"Ubhayattha santo abhinibbutattā, ","html":"<span class='verse-line'>{}</span>"},"ja303:4.4":{"pli":"Sukhe ca dukkhe ca bhavanti tulyā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja303:5.1":{"pli":"Ekarājajātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja304":{"ja304:0.1":{"pli":"Jātaka ","html":"<article id='ja304'><header><ul><li class='division'>{}</li>"},"ja304:0.2":{"pli":"Catukkanipāta ","html":"<li>{}</li>"},"ja304:0.3":{"pli":"Kāliṅgavagga ","html":"<li>{}</li></ul>"},"ja304:0.4":{"pli":"4. Daddarajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja304:1.1":{"pli":"“Imāni maṁ daddara tāpayanti, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja304:1.2":{"pli":"Vācāduruttāni manussaloke; ","html":"<span class='verse-line'>{}</span>"},"ja304:1.3":{"pli":"Maṇḍūkabhakkhā udakantasevī, ","html":"<span class='verse-line'>{}</span>"},"ja304:1.4":{"pli":"Āsīvisaṁ maṁ avisā sapanti”. ","html":"<span class='verse-line'>{}</span></p>"},"ja304:2.1":{"pli":"“Sakā raṭṭhā pabbājito, ","html":"<p><span class='verse-line'>{}</span>"},"ja304:2.2":{"pli":"aññaṁ janapadaṁ gato; ","html":"<span class='verse-line'>{}</span>"},"ja304:2.3":{"pli":"Mahantaṁ koṭṭhaṁ kayirātha, ","html":"<span class='verse-line'>{}</span>"},"ja304:2.4":{"pli":"duruttānaṁ nidhetave. ","html":"<span class='verse-line'>{}</span></p>"},"ja304:3.1":{"pli":"Yattha posaṁ na jānanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja304:3.2":{"pli":"jātiyā vinayena vā; ","html":"<span class='verse-line'>{}</span>"},"ja304:3.3":{"pli":"Na tattha mānaṁ kayirātha, ","html":"<span class='verse-line'>{}</span>"},"ja304:3.4":{"pli":"vasamaññātake jane. ","html":"<span class='verse-line'>{}</span></p>"},"ja304:4.1":{"pli":"Videsavāsaṁ vasato, ","html":"<p><span class='verse-line'>{}</span>"},"ja304:4.2":{"pli":"jātavedasamenapi; ","html":"<span class='verse-line'>{}</span>"},"ja304:4.3":{"pli":"Khamitabbaṁ sapaññena, ","html":"<span class='verse-line'>{}</span>"},"ja304:4.4":{"pli":"api dāsassa tajjitan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja304:5.1":{"pli":"Daddarajātakaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja305":{"ja305:0.1":{"pli":"Jātaka ","html":"<article id='ja305'><header><ul><li class='division'>{}</li>"},"ja305:0.2":{"pli":"Catukkanipāta ","html":"<li>{}</li>"},"ja305:0.3":{"pli":"Kāliṅgavagga ","html":"<li>{}</li></ul>"},"ja305:0.4":{"pli":"5. Sīlavīmaṁsanajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja305:1.1":{"pli":"“Natthi loke raho nāma, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja305:1.2":{"pli":"pāpakammaṁ pakubbato; ","html":"<span class='verse-line'>{}</span>"},"ja305:1.3":{"pli":"Passanti vanabhūtāni, ","html":"<span class='verse-line'>{}</span>"},"ja305:1.4":{"pli":"taṁ bālo maññatī raho. ","html":"<span class='verse-line'>{}</span></p>"},"ja305:2.1":{"pli":"Ahaṁ raho na passāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja305:2.2":{"pli":"suññaṁ vāpi na vijjati; ","html":"<span class='verse-line'>{}</span>"},"ja305:2.3":{"pli":"Yattha aññaṁ na passāmi, ","html":"<span class='verse-line'>{}</span>"},"ja305:2.4":{"pli":"asuññaṁ hoti taṁ mayā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja305:3.1":{"pli":"“Dujjacco ca sujacco ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja305:3.2":{"pli":"nando ca sukhavaḍḍhito; ","html":"<span class='verse-line'>{}</span>"},"ja305:3.3":{"pli":"Vejjo ca addhuvasīlo ca, ","html":"<span class='verse-line'>{}</span>"},"ja305:3.4":{"pli":"te dhammaṁ jahu matthikā. ","html":"<span class='verse-line'>{}</span></p>"},"ja305:4.1":{"pli":"Brāhmaṇo ca kathaṁ jahe, ","html":"<p><span class='verse-line'>{}</span>"},"ja305:4.2":{"pli":"sabbadhammāna pāragū; ","html":"<span class='verse-line'>{}</span>"},"ja305:4.3":{"pli":"Yo dhammamanupāleti, ","html":"<span class='verse-line'>{}</span>"},"ja305:4.4":{"pli":"dhitimā saccanikkamo”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja305:5.1":{"pli":"Sīlavīmaṁsanajātakaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja306":{"ja306:0.1":{"pli":"Jātaka ","html":"<article id='ja306'><header><ul><li class='division'>{}</li>"},"ja306:0.2":{"pli":"Catukkanipāta ","html":"<li>{}</li>"},"ja306:0.3":{"pli":"Kāliṅgavagga ","html":"<li>{}</li></ul>"},"ja306:0.4":{"pli":"6. Sujātājātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja306:1.1":{"pli":"“Kimaṇḍakā ime deva, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja306:1.2":{"pli":"nikkhittā kaṁsamallake; ","html":"<span class='verse-line'>{}</span>"},"ja306:1.3":{"pli":"Upalohitakā vaggū, ","html":"<span class='verse-line'>{}</span>"},"ja306:1.4":{"pli":"taṁ me akkhāhi pucchito”. ","html":"<span class='verse-line'>{}</span></p>"},"ja306:2.1":{"pli":"“Yāni pure tuvaṁ devi, ","html":"<p><span class='verse-line'>{}</span>"},"ja306:2.2":{"pli":"bhaṇḍu nantakavāsinī; ","html":"<span class='verse-line'>{}</span>"},"ja306:2.3":{"pli":"Ucchaṅgahatthā pacināsi, ","html":"<span class='verse-line'>{}</span>"},"ja306:2.4":{"pli":"tassā te koliyaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja306:3.1":{"pli":"Uḍḍayhate na ramati, ","html":"<p><span class='verse-line'>{}</span>"},"ja306:3.2":{"pli":"bhogā vippajahanti taṁ; ","html":"<span class='verse-line'>{}</span>"},"ja306:3.3":{"pli":"Tatthevimaṁ paṭinetha, ","html":"<span class='verse-line'>{}</span>"},"ja306:3.4":{"pli":"yattha kolaṁ pacissati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja306:4.1":{"pli":"“Honti hete mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja306:4.2":{"pli":"iddhippattāya nāriyā; ","html":"<span class='verse-line'>{}</span>"},"ja306:4.3":{"pli":"Khama deva sujātāya, ","html":"<span class='verse-line'>{}</span>"},"ja306:4.4":{"pli":"māssā kujjha rathesabhā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja306:5.1":{"pli":"Sujātājātakaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja307":{"ja307:0.1":{"pli":"Jātaka ","html":"<article id='ja307'><header><ul><li class='division'>{}</li>"},"ja307:0.2":{"pli":"Catukkanipāta ","html":"<li>{}</li>"},"ja307:0.3":{"pli":"Kāliṅgavagga ","html":"<li>{}</li></ul>"},"ja307:0.4":{"pli":"7. Palāsajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja307:1.1":{"pli":"“Acetanaṁ brāhmaṇa assuṇantaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja307:1.2":{"pli":"Jāno ajānantamimaṁ palāsaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja307:1.3":{"pli":"Āraddhaviriyo dhuvaṁ appamatto, ","html":"<span class='verse-line'>{}</span>"},"ja307:1.4":{"pli":"Sukhaseyyaṁ pucchasi kissa hetu”. ","html":"<span class='verse-line'>{}</span></p>"},"ja307:2.1":{"pli":"“Dūre suto ceva brahā ca rukkho, ","html":"<p><span class='verse-line'>{}</span>"},"ja307:2.2":{"pli":"Dese ṭhito bhūtanivāsarūpo; ","html":"<span class='verse-line'>{}</span>"},"ja307:2.3":{"pli":"Tasmā namassāmi imaṁ palāsaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja307:2.4":{"pli":"Ye cettha bhūtā te dhanassa hetu”. ","html":"<span class='verse-line'>{}</span></p>"},"ja307:3.1":{"pli":"“So te karissāmi yathānubhāvaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja307:3.2":{"pli":"Kataññutaṁ brāhmaṇa pekkhamāno; ","html":"<span class='verse-line'>{}</span>"},"ja307:3.3":{"pli":"Kathañhi āgamma sataṁ sakāse, ","html":"<span class='verse-line'>{}</span>"},"ja307:3.4":{"pli":"Moghāni te assu pariphanditāni. ","html":"<span class='verse-line'>{}</span></p>"},"ja307:4.1":{"pli":"Yo tindukarukkhassa paro pilakkho, ","html":"<p><span class='verse-line'>{}</span>"},"ja307:4.2":{"pli":"Parivārito pubbayañño uḷāro; ","html":"<span class='verse-line'>{}</span>"},"ja307:4.3":{"pli":"Tassesa mūlasmiṁ nidhi nikhāto, ","html":"<span class='verse-line'>{}</span>"},"ja307:4.4":{"pli":"Adāyādo gaccha taṁ uddharāhī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja307:5.1":{"pli":"Palāsajātakaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}