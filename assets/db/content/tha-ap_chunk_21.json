e'>{}</span>"},"tha-ap331:3.4":{"pli":"imaṁ gāthaṁ abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap331:4.1":{"pli":"‘Yo me cittaṁ pasādetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap331:4.2":{"pli":"pupphacchattaṁ adhārayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap331:4.3":{"pli":"Tena cittappasādena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap331:4.4":{"pli":"duggatiṁ so na gacchati’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap331:5.1":{"pli":"Idaṁ vatvāna sambuddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap331:5.2":{"pli":"siddhattho lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap331:5.3":{"pli":"Uyyojetvāna parisaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap331:5.4":{"pli":"vehāsaṁ nabhamuggami. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap331:6.1":{"pli":"Vuṭṭhite naradevamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap331:6.2":{"pli":"setacchattampi vuṭṭhahi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap331:6.3":{"pli":"Purato buddhaseṭṭhassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap331:6.4":{"pli":"gacchati chattamuttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap331:7.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap331:7.2":{"pli":"yaṁ chattaṁ abhiropayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap331:7.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap331:7.4":{"pli":"pupphacchattassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap331:8.1":{"pli":"Catusattatikappamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap331:8.2":{"pli":"aṭṭha jalasikhā ahū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap331:8.3":{"pli":"Sattaratanasampannā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap331:8.4":{"pli":"cakkavattī mahabbalā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap331:9.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap331:9.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap331:9.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap331:10.1":{"pli":"Itthaṁ sudaṁ āyasmā pupphacchattiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap331:11.1":{"pli":"Pupphacchattiyattherassāpadānaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap332":{"tha-ap332:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap332'><header><ul><li class='division'>{}</li>"},"tha-ap332:0.2":{"pli":"Umāpupphiyavagga ","html":"<li>{}</li></ul>"},"tha-ap332:0.3":{"pli":"Saparivārachattadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap332:1.1":{"pli":"“Padumuttaro lokavidū, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap332:1.2":{"pli":"āhutīnaṁ paṭiggaho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:1.3":{"pli":"Ākāse jalavuṭṭhīva, ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:1.4":{"pli":"vassate dhammavuṭṭhiyā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap332:2.1":{"pli":"Tamaddasāsiṁ sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap332:2.2":{"pli":"desentaṁ amataṁ padaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:2.3":{"pli":"Sakaṁ cittaṁ pasādetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:2.4":{"pli":"agamāsiṁ sakaṁ gharaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap332:3.1":{"pli":"Chattaṁ alaṅkataṁ gayha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap332:3.2":{"pli":"upagacchiṁ naruttamaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:3.3":{"pli":"Haṭṭho haṭṭhena cittena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:3.4":{"pli":"ākāse ukkhipiṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap332:4.1":{"pli":"Susaṅgahitayānaṁva, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap332:4.2":{"pli":"dantova sāvakuttamo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:4.3":{"pli":"Upagantvāna sambuddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:4.4":{"pli":"matthake sampatiṭṭhahi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap332:5.1":{"pli":"Anukampako kāruṇiko, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap332:5.2":{"pli":"buddho lokagganāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:5.3":{"pli":"Bhikkhusaṅghe nisīditvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:5.4":{"pli":"imā gāthā abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap332:6.1":{"pli":"‘Yena chattamidaṁ dinnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap332:6.2":{"pli":"alaṅkataṁ manoramaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:6.3":{"pli":"Tena cittappasādena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:6.4":{"pli":"duggatiṁ so na gacchati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap332:7.1":{"pli":"Sattakkhattuñca devesu, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap332:7.2":{"pli":"devarajjaṁ karissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:7.3":{"pli":"Bāttiṁsakkhattuñca rājā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:7.4":{"pli":"cakkavattī bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap332:8.1":{"pli":"Kappasatasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap332:8.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:8.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:8.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap332:9.1":{"pli":"Tassa dhammesu dāyādo, ","html":"<p>