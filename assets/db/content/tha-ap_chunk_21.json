{"tha-ap329":{"tha-ap329:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap329'><header><ul><li class='division'>{}</li>"},"tha-ap329:0.2":{"pli":"Umāpupphiyavagga ","html":"<li>{}</li></ul>"},"tha-ap329:0.3":{"pli":"Nigguṇḍipupphiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap329:1.1":{"pli":"“Yadā devo devakāyā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap329:1.2":{"pli":"cavate āyusaṅkhayā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:1.3":{"pli":"Tayo saddā niccharanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:1.4":{"pli":"devānaṁ anumodataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap329:2.1":{"pli":"‘Ito bho sugatiṁ gaccha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap329:2.2":{"pli":"manussānaṁ sahabyataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:2.3":{"pli":"Manussabhūto saddhamme, ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:2.4":{"pli":"labha saddhaṁ anuttaraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap329:3.1":{"pli":"Sā te saddhā niviṭṭhāssa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap329:3.2":{"pli":"mūlajātā patiṭṭhitā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:3.3":{"pli":"Yāvajīvaṁ asaṁhīrā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:3.4":{"pli":"saddhamme suppavedite. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap329:4.1":{"pli":"Kāyena kusalaṁ katvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap329:4.2":{"pli":"vācāya kusalaṁ bahuṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:4.3":{"pli":"Manasā kusalaṁ katvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:4.4":{"pli":"abyāpajjaṁ nirūpadhiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap329:5.1":{"pli":"Tato opadhikaṁ puññaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap329:5.2":{"pli":"katvā dānena taṁ bahuṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:5.3":{"pli":"Aññepi macce saddhamme, ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:5.4":{"pli":"brahmacariye nivesaya’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap329:6.1":{"pli":"Imāya anukampāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap329:6.2":{"pli":"devādevaṁ yadā vidū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:6.3":{"pli":"Cavantaṁ anumodanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:6.4":{"pli":"ehi deva punappunaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap329:7.1":{"pli":"‘Saṁvego me tadā āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap329:7.2":{"pli":"devasaṅghe samāgate; ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:7.3":{"pli":"Kaṁsu nāma ahaṁ yoniṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:7.4":{"pli":"gamissāmi ito cuto’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap329:8.1":{"pli":"Mama saṁvegamaññāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap329:8.2":{"pli":"samaṇo bhāvitindriyo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:8.3":{"pli":"Mamuddharitukāmo so, ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:8.4":{"pli":"āgacchi mama santikaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap329:9.1":{"pli":"Sumano nāma nāmena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap329:9.2":{"pli":"padumuttarasāvako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:9.3":{"pli":"Atthadhammānusāsitvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:9.4":{"pli":"saṁvejesi mamaṁ tadā. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap329:10.1":{"pli":"Dvādasamaṁ bhāṇavāraṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap329:11.1":{"pli":"Tassāhaṁ vacanaṁ sutvā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap329:11.2":{"pli":"buddhe cittaṁ pasādayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:11.3":{"pli":"Taṁ dhīraṁ abhivādetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:11.4":{"pli":"tattha kālaṅkato ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap329:12.1":{"pli":"Upapajjiṁ sa tattheva, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap329:12.2":{"pli":"sukkamūlena codito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:12.3":{"pli":"Vasanto mātukucchimhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:12.4":{"pli":"puna dhāreti mātuyā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap329:13.1":{"pli":"Tamhā kāyā cavitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap329:13.2":{"pli":"tidase upapajjahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:13.3":{"pli":"Etthantare na passāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:13.4":{"pli":"domanassamahaṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap329:14.1":{"pli":"Tāvatiṁsā cavitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap329:14.2":{"pli":"mātukucchiṁ samokkamiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:14.3":{"pli":"Nikkhamitvāna kucchimhā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:14.4":{"pli":"kaṇhasukkaṁ ajānahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap329:15.1":{"pli":"Jātiyā sattavassova, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap329:15.2":{"pli":"ārāmaṁ pāvisiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:15.3":{"pli":"Gotamassa bhagavato, ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:15.4":{"pli":"sakyaputtassa tādino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap329:16.1":{"pli":"Vitthārike pāvacane, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap329:16.2":{"pli":"bāhujaññamhi sāsane; ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:16.3":{"pli":"Addasaṁ sāsanakare, ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:16.4":{"pli":"bhikkhavo tattha satthuno. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap329:17.1":{"pli":"Sāvatthi nāma nagaraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap329:17.2":{"pli":"rājā tatthāsi kosalo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:17.3":{"pli":"Rathena nāgayuttena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:17.4":{"pli":"upesi bodhimuttamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap329:18.1":{"pli":"Tassāhaṁ nāgaṁ disvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap329:18.2":{"pli":"pubbakammaṁ anussariṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:18.3":{"pli":"Añjaliṁ paggahetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:18.4":{"pli":"samayaṁ agamāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap329:19.1":{"pli":"Jātiyā sattavassova, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap329:19.2":{"pli":"pabbajiṁ anagāriyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:19.3":{"pli":"Yo so buddhaṁ upaṭṭhāsi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:19.4":{"pli":"ānando nāma sāvako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap329:20.1":{"pli":"Gatimā dhitimā ceva, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap329:20.2":{"pli":"satimā ca bahussuto; ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:20.3":{"pli":"Rañño cittaṁ pasādento, ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:20.4":{"pli":"niyyādesi mahājuti. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap329:21.1":{"pli":"Tassāhaṁ dhammaṁ sutvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap329:21.2":{"pli":"pubbakammaṁ anussariṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:21.3":{"pli":"Tattheva ṭhitako santo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:21.4":{"pli":"arahattamapāpuṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap329:22.1":{"pli":"Ekaṁsaṁ cīvaraṁ katvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap329:22.2":{"pli":"sire katvāna añjaliṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:22.3":{"pli":"Sambuddhaṁ abhivādetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:22.4":{"pli":"imaṁ vācaṁ udīrayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap329:23.1":{"pli":"‘Padumuttarabuddhassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap329:23.2":{"pli":"dvipadindassa satthuno; ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:23.3":{"pli":"Nigguṇḍipupphaṁ paggayha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:23.4":{"pli":"sīhāsane ṭhapesahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap329:24.1":{"pli":"Tena kammena dvipadinda, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap329:24.2":{"pli":"lokajeṭṭha narāsabha; ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:24.3":{"pli":"Pattomhi acalaṁ ṭhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:24.4":{"pli":"hitvā jayaparājayaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap329:25.1":{"pli":"Pañcavīsasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap329:25.2":{"pli":"kappānaṁ manujādhipā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:25.3":{"pli":"Abbudanirabbudāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:25.4":{"pli":"aṭṭhaṭṭhāsiṁsu khattiyā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap329:26.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap329:26.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap329:26.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap329:27.1":{"pli":"Itthaṁ sudaṁ āyasmā nigguṇḍipupphiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap329:28.1":{"pli":"Nigguṇḍipupphiyattherassāpadānaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap33":{"tha-ap33:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap33'><header><ul><li class='division'>{}</li>"},"tha-ap33:0.2":{"pli":"Kuṇḍadhānavagga ","html":"<li>{}</li></ul>"},"tha-ap33:0.3":{"pli":"Kuṇḍadhānattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap33:1.1":{"pli":"“Sattāhaṁ paṭisallīnaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap33:1.2":{"pli":"sayambhuṁ aggapuggalaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:1.3":{"pli":"Pasannacitto sumano, ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:1.4":{"pli":"buddhaseṭṭhaṁ upaṭṭhahiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap33:2.1":{"pli":"Vuṭṭhitaṁ kālamaññāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap33:2.2":{"pli":"padumuttaraṁ mahāmuniṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:2.3":{"pli":"Mahantiṁ kadalīkaṇṇiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:2.4":{"pli":"gahetvā upagacchahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap33:3.1":{"pli":"Paṭiggahetvā bhagavā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap33:3.2":{"pli":"sabbaññū lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:3.3":{"pli":"Mama cittaṁ pasādento, ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:3.4":{"pli":"paribhuñji mahāmuni. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap33:4.1":{"pli":"Paribhuñjitvā sambuddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap33:4.2":{"pli":"satthavāho anuttaro; ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:4.3":{"pli":"Sakāsane nisīditvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:4.4":{"pli":"imā gāthā abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap33:5.1":{"pli":"‘Ye ca santi samitāro, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap33:5.2":{"pli":"yakkhā imamhi pabbate; ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:5.3":{"pli":"Araññe bhūtabhabyāni, ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:5.4":{"pli":"suṇantu vacanaṁ mama. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap33:6.1":{"pli":"Yo so buddhaṁ upaṭṭhāsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap33:6.2":{"pli":"migarājaṁva kesariṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:6.3":{"pli":"Tamahaṁ kittayissāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:6.4":{"pli":"suṇātha mama bhāsato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap33:7.1":{"pli":"Ekādasañcakkhattuṁ so, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap33:7.2":{"pli":"devarājā bhavissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:7.3":{"pli":"Catutiṁsatikkhattuñca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:7.4":{"pli":"cakkavattī bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap33:8.1":{"pli":"Kappasatasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap33:8.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:8.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:8.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap33:9.1":{"pli":"Akkositvāna samaṇe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap33:9.2":{"pli":"sīlavante anāsave; ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:9.3":{"pli":"Pāpakammavipākena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:9.4":{"pli":"nāmadheyyaṁ labhissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap33:10.1":{"pli":"Tassa dhamme sudāyādo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap33:10.2":{"pli":"oraso dhammanimmito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:10.3":{"pli":"Kuṇḍadhānoti nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:10.4":{"pli":"sāvako so bhavissati’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap33:11.1":{"pli":"Pavivekamanuyutto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap33:11.2":{"pli":"jhāyī jhānarato ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:11.3":{"pli":"Tosayitvāna satthāraṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:11.4":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap33:12.1":{"pli":"Sāvakehi parivuto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap33:12.2":{"pli":"bhikkhusaṅghapurakkhato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:12.3":{"pli":"Bhikkhusaṅghe nisīditvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:12.4":{"pli":"salākaṁ gāhayī jino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap33:13.1":{"pli":"Ekaṁsaṁ cīvaraṁ katvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap33:13.2":{"pli":"vanditvā lokanāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:13.3":{"pli":"Vadataṁ varassa purato, ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:13.4":{"pli":"paṭhamaṁ aggahesahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap33:14.1":{"pli":"Tena kammena bhagavā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap33:14.2":{"pli":"dasasahassikampako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:14.3":{"pli":"Bhikkhusaṅghe nisīditvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:14.4":{"pli":"aggaṭṭhāne ṭhapesi maṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap33:15.1":{"pli":"Vīriyaṁ me dhuradhorayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap33:15.2":{"pli":"yogakkhemādhivāhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:15.3":{"pli":"Dhāremi antimaṁ dehaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:15.4":{"pli":"sammāsambuddhasāsane. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap33:16.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap33:16.2":{"pli":"vimokkhāpi ca aṭṭhime; ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:16.3":{"pli":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap33:16.4":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap33:17.1":{"pli":"Itthaṁ sudaṁ āyasmā kuṇḍadhāno thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap33:18.1":{"pli":"Kuṇḍadhānattherassāpadānaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap330":{"tha-ap330:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap330'><header><ul><li class='division'>{}</li>"},"tha-ap330:0.2":{"pli":"Umāpupphiyavagga ","html":"<li>{}</li></ul>"},"tha-ap330:0.3":{"pli":"8 Sumanāveḷiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap330:1.1":{"pli":"“Vessabhussa bhagavato, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap330:1.2":{"pli":"lokajeṭṭhassa tādino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap330:1.3":{"pli":"Sabbe janā samāgamma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap330:1.4":{"pli":"mahāpūjaṁ karonti te. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap330:2.1":{"pli":"Sudhāya piṇḍaṁ katvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap330:2.2":{"pli":"āveḷaṁ sumanāyahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap330:2.3":{"pli":"Sīhāsanassa purato, ","html":"<span class='verse-line'>{}</span>"},"tha-ap330:2.4":{"pli":"abhiropesahaṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap330:3.1":{"pli":"Sabbe janā samāgamma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap330:3.2":{"pli":"pekkhanti pupphamuttamaṁ; ","html":"<spa