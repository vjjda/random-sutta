tidasaṁ puraṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:14.3":{"pli":"Saṁsaritvānupubbena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:14.4":{"pli":"mānusaṁ punarāgamiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap332:15.1":{"pli":"Okkantaṁ mātukucchiṁ maṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap332:15.2":{"pli":"setacchattaṁ adhārayuṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:15.3":{"pli":"Jātiyā sattavassohaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:15.4":{"pli":"pabbajiṁ anagāriyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap332:16.1":{"pli":"Sunando nāma nāmena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap332:16.2":{"pli":"brāhmaṇo mantapāragū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:16.3":{"pli":"Phalikaṁ chattamādāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:16.4":{"pli":"sāvakaggassa so tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap332:17.1":{"pli":"Anumodi mahāvīro, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap332:17.2":{"pli":"sāriputto mahākathī; ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:17.3":{"pli":"Sutvānumodanaṁ tassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:17.4":{"pli":"pubbakammamanussariṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap332:18.1":{"pli":"Añjaliṁ paggahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap332:18.2":{"pli":"sakaṁ cittaṁ pasādayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:18.3":{"pli":"Saritvā purimaṁ kammaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:18.4":{"pli":"arahattamapāpuṇiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap332:19.1":{"pli":"Uṭṭhāya āsanā tamhā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap332:19.2":{"pli":"sire katvāna añjaliṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:19.3":{"pli":"Sambuddhaṁ abhivādetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:19.4":{"pli":"imaṁ vācaṁ udīrayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap332:20.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap332:20.2":{"pli":"buddho loke anuttaro; ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:20.3":{"pli":"Padumuttaro lokavidū, ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:20.4":{"pli":"āhutīnaṁ paṭiggaho. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap332:21.1":{"pli":"Tassa chattaṁ mayā dinnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap332:21.2":{"pli":"vicittaṁ samalaṅkataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:21.3":{"pli":"Ubho hatthehi paggaṇhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:21.4":{"pli":"sayambhū aggapuggalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap332:22.1":{"pli":"Aho buddhā aho dhammā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap332:22.2":{"pli":"aho no satthusampadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:22.3":{"pli":"Ekacchattassa dānena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:22.4":{"pli":"duggatiṁ nupapajjahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap332:23.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap332:23.2":{"pli":"bhavā sabbe samūhatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:23.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:23.4":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap332:24.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap332:24.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:24.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap332:25.1":{"pli":"Itthaṁ sudaṁ āyasmā saparivārachattadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap332:26.1":{"pli":"Saparivārachattadāyakattherassāpadānaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap332:27.1":{"pli":"Umāpupphiyavaggo tettiṁsatimo. ","html":"<p class='endsection'>{}</p>"},"tha-ap332:28.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"tha-ap332:29.1":{"pli":"Umāpupphañca pulinaṁ, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"tha-ap332:29.2":{"pli":"hāso yañño nimittako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:29.3":{"pli":"Saṁsāvako nigguṇḍī ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:29.4":{"pli":"sumanaṁ pupphachattako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:29.5":{"pli":"Saparivārachatto ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap332:29.6":{"pli":"gāthā sattasatuttarāti. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"tha-ap333":{"tha-ap333:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap333'><header><ul><li class='division'>{}</li>"},"tha-ap333:0.2":{"pli":"Gandhodakavagga ","html":"<li>{}</li></ul>"},"tha-ap333:0.3":{"pli":"Gandhadhūpiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap333:1.1":{"pli":"“Siddhatthassa bhagavato, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap333:1.2":{"pli":"gandhadhūpaṁ adāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap333:1.3":{"pli":"Sumanehi paṭicchannaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap333:1.4":{"pli":"buddhānucchavikañca taṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap333:2.1":{"pli":"Kañcanagghiyasaṅkāsaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap333:2.2":{"pli":"buddhaṁ lokagganāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap333:2.3":{"pli":"Indīvaraṁva jalitaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap333:2.4":{"pli":"ādittaṁva hutāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap333:3.1":{"pli":"Byagghusabhaṁva pavaraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap333:3.2":{"pli":"abhijātaṁva kesariṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap333:3.3":{"pli":"Nisinnaṁ samaṇānaggaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap333:3.4":{"pli":"bhikkhusaṅghapurakkhataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap333:4.1":{"pli":"Disvā cittaṁ pasādetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap333:4.2":{"pli":"paggahetvāna añjaliṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap333:4.3":{"pli":"Vanditvā satthuno pāde, ","html":"<span class='verse-line'>{}</span>"},"tha-ap333:4.4":{"pli":"pakkāmiṁ uttarāmukho. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap333:5.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap333:5.2":{"pli":"yaṁ gandhamadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap333:5.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap333:5.4":{"pli":"gandhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap333:6.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap333:6.2":{"pli":"vimokkhāpi ca aṭṭhime; ","html":"<span class='verse-line'>{}</span>"},"tha-ap333:6.3":{"pli":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap333:6.4":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap333:7.1":{"pli":"Itthaṁ sudaṁ āyasmā gandhadhūpiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap333:8.1":{"pli":"Gandhadhūpiyattherassāpadānaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap334":{"tha-ap334:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap334'><header><ul><li class='division'>{}</li>"},"tha-ap334:0.2":{"pli":"Gandhodakavagga ","html":"<li>{}</li></ul>"},"tha-ap334:0.3":{"pli":"Udakapūjakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap334:1.1":{"pli":"“Suvaṇṇavaṇṇaṁ sambuddhaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap334:1.2":{"pli":"Gacchantaṁ anilañjase; ","html":"<span class='verse-line'>{}</span>"},"tha-ap334:1.3":{"pli":"Ghatāsanaṁva jalitaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap334:1.4":{"pli":"Ādittaṁva hutāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap334:2.1":{"pli":"Pāṇinā udakaṁ gayha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap334:2.2":{"pli":"ākāse ukkhipiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap334:2.3":{"pli":"Sampaṭicchi mahāvīro, ","html":"<span class='verse-line'>{}</span>"},"tha-ap334:2.4":{"pli":"buddho kāruṇiko isi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap334:3.1":{"pli":"Antalikkhe ṭhito satthā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap334:3.2":{"pli":"padumuttaranāmako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap334:3.3":{"pli":"Mama saṅkappamaññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap334:3.4":{"pli":"imaṁ gāthamabhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap334:4.1":{"pli":"‘Iminā dakadānena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap334:4.2":{"pli":"pītiuppādanena ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap334:4.3":{"pli":"Kappasatasahassampi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap334:4.4":{"pli":"duggatiṁ nupapajjati’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap334:5.1":{"pli":"Tena kammena dvipadinda, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap334:5.2":{"pli":"lokajeṭṭha narāsabha; ","html":"<span class='verse-line'>{}</span>"},"tha-ap334:5.3":{"pli":"Pattomhi acalaṁ ṭhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap334:5.4":{"pli":"hitvā jayaparājayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap334:6.1":{"pli":"Sahassarājanāmena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap334:6.2":{"pli":"tayo ca cakkavattino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap334:6.3":{"pli":"Pañcasaṭṭhikappasate, ","html":"<span class='verse-line'>{}</span>"},"tha-ap334:6.4":{"pli":"cāturantā janādhipā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap334:7.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap334:7.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap334:7.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap334:8.1":{"pli":"Itthaṁ sudaṁ āyasmā udakapūjako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap334:9.1":{"pli":"Udakapūjakattherassāpadānaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap335":{"tha-ap335:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap335'><header><ul><li class='division'>{}</li>"},"tha-ap335:0.2":{"pli":"Gandhodakavagga ","html":"<li>{}</li></ul>"},"tha-ap335:0.3":{"pli":"Punnāgapupphiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap335:1.1":{"pli":"“Kānanaṁ vanamogayha, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap335:1.2":{"pli":"vasāmi luddako ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap335:1.3":{"pli":"Punnāgaṁ pupphitaṁ disvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap335:1.4":{"pli":"buddhaseṭṭhaṁ anussariṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap335:2.1":{"pli":"Taṁ pupphaṁ ocinitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap335:2.2":{"pli":"sugandhaṁ gandhitaṁ subhaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap335:2.3":{"pli":"Thūpaṁ katvāna puline, ","html":"<span class='verse-line'>{}</span>"},"tha-ap335:2.4":{"pli":"buddhassa abhiropayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap335:3.1":{"pli":"Dvenavute ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap335:3.2":{"pli":"yaṁ pupphamabhipūjayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap335:3.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap335:3.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap335:4.1":{"pli":"Ekamhi navute kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap335:4.2":{"pli":"eko āsiṁ tamonudo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap335:4.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap335:4.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap335:5.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap335:5.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap335:5.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap335:6.1":{"pli":"Itthaṁ sudaṁ āyasmā punnāgapupphiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap335:7.1":{"pli":"Punnāgapupphiyattherassāpadānaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}