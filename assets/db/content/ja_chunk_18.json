{"ja455":{"ja455:0.1":{"pli":"Jātaka ","html":"<article id='ja455'><header><ul><li class='division'>{}</li>"},"ja455:0.2":{"pli":"Ekādasakanipāta ","html":"<li>{}</li>"},"ja455:0.3":{"pli":"Mātuposakavagga ","html":"<li>{}</li></ul>"},"ja455:0.4":{"pli":"1. Mātuposakajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja455:1.1":{"pli":"“Tassa nāgassa vippavāsena, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja455:1.2":{"pli":"Virūḷhā sallakī ca kuṭajā ca; ","html":"<span class='verse-line'>{}</span>"},"ja455:1.3":{"pli":"Kuruvindakaravīrā bhisasāmā ca, ","html":"<span class='verse-line'>{}</span>"},"ja455:1.4":{"pli":"Nivāte pupphitā ca kaṇikārā. ","html":"<span class='verse-line'>{}</span></p>"},"ja455:2.1":{"pli":"Kocideva suvaṇṇakāyurā, ","html":"<p><span class='verse-line'>{}</span>"},"ja455:2.2":{"pli":"Nāgarājaṁ bharanti piṇḍena; ","html":"<span class='verse-line'>{}</span>"},"ja455:2.3":{"pli":"Yattha rājā rājakumāro vā, ","html":"<span class='verse-line'>{}</span>"},"ja455:2.4":{"pli":"Kavacamabhihessati achambhito”. ","html":"<span class='verse-line'>{}</span></p>"},"ja455:3.1":{"pli":"“Gaṇhāhi nāga kabaḷaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja455:3.2":{"pli":"mā nāga kisako bhava; ","html":"<span class='verse-line'>{}</span>"},"ja455:3.3":{"pli":"Bahūni rājakiccāni, ","html":"<span class='verse-line'>{}</span>"},"ja455:3.4":{"pli":"tāni nāga karissasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja455:4.1":{"pli":"“Sā nūnasā kapaṇikā, ","html":"<p><span class='verse-line'>{}</span>"},"ja455:4.2":{"pli":"andhā apariṇāyikā; ","html":"<span class='verse-line'>{}</span>"},"ja455:4.3":{"pli":"Khāṇuṁ pādena ghaṭṭeti, ","html":"<span class='verse-line'>{}</span>"},"ja455:4.4":{"pli":"giriṁ caṇḍoraṇaṁ pati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja455:5.1":{"pli":"“Kā nu te sā mahānāga, ","html":"<p><span class='verse-line'>{}</span>"},"ja455:5.2":{"pli":"andhā apariṇāyikā; ","html":"<span class='verse-line'>{}</span>"},"ja455:5.3":{"pli":"Khāṇuṁ pādena ghaṭṭeti, ","html":"<span class='verse-line'>{}</span>"},"ja455:5.4":{"pli":"giriṁ caṇḍoraṇaṁ pati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja455:6.1":{"pli":"“Mātā me sā mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja455:6.2":{"pli":"andhā apariṇāyikā; ","html":"<span class='verse-line'>{}</span>"},"ja455:6.3":{"pli":"Khāṇuṁ pādena ghaṭṭeti, ","html":"<span class='verse-line'>{}</span>"},"ja455:6.4":{"pli":"giriṁ caṇḍoraṇaṁ pati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja455:7.1":{"pli":"“Muñcathetaṁ mahānāgaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja455:7.2":{"pli":"yoyaṁ bharati mātaraṁ; ","html":"<span class='verse-line'>{}</span>"},"ja455:7.3":{"pli":"Sametu mātarā nāgo, ","html":"<span class='verse-line'>{}</span>"},"ja455:7.4":{"pli":"saha sabbehi ñātibhi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja455:8.1":{"pli":"“Mutto ca bandhanā nāgo, ","html":"<p><span class='verse-line'>{}</span>"},"ja455:8.2":{"pli":"muttamādāya kuñjaro; ","html":"<span class='verse-line'>{}</span>"},"ja455:8.3":{"pli":"Muhuttaṁ assāsayitvā, ","html":"<span class='verse-line'>{}</span>"},"ja455:8.4":{"pli":"agamā yena pabbato. ","html":"<span class='verse-line'>{}</span></p>"},"ja455:9.1":{"pli":"Tato so naḷiniṁ gantvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja455:9.2":{"pli":"sītaṁ kuñjarasevitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja455:9.3":{"pli":"Soṇḍāyūdakamāhatvā, ","html":"<span class='verse-line'>{}</span>"},"ja455:9.4":{"pli":"mātaraṁ abhisiñcatha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja455:10.1":{"pli":"“Koyaṁ anariyo devo, ","html":"<p><span class='verse-line'>{}</span>"},"ja455:10.2":{"pli":"akālenapi vassati; ","html":"<span class='verse-line'>{}</span>"},"ja455:10.3":{"pli":"Gato me atrajo putto, ","html":"<span class='verse-line'>{}</span>"},"ja455:10.4":{"pli":"yo mayhaṁ paricārako”. ","html":"<span class='verse-line'>{}</span></p>"},"ja455:11.1":{"pli":"“Uṭṭhehi amma kiṁ sesi, ","html":"<p><span class='verse-line'>{}</span>"},"ja455:11.2":{"pli":"āgato tyāhamatrajo; ","html":"<span class='verse-line'>{}</span>"},"ja455:11.3":{"pli":"Muttomhi kāsirājena, ","html":"<span class='verse-line'>{}</span>"},"ja455:11.4":{"pli":"vedehena yasassinā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja455:12.1":{"pli":"“Ciraṁ jīvatu so rājā, ","html":"<p><span class='verse-line'>{}</span>"},"ja455:12.2":{"pli":"kāsīnaṁ raṭṭhavaḍḍhano; ","html":"<span class='verse-line'>{}</span>"},"ja455:12.3":{"pli":"Yo me puttaṁ pamocesi, ","html":"<span class='verse-line'>{}</span>"},"ja455:12.4":{"pli":"sadā vuddhāpacāyikan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja455:13.1":{"pli":"Mātuposakajātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja456":{"ja456:0.1":{"pli":"Jātaka ","html":"<article id='ja456'><header><ul><li class='division'>{}</li>"},"ja456:0.2":{"pli":"Ekādasakanipāta ","html":"<li>{}</li>"},"ja456:0.3":{"pli":"Mātuposakavagga ","html":"<li>{}</li></ul>"},"ja456:0.4":{"pli":"2. Juṇhajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja456:1.1":{"pli":"“Suṇohi mayhaṁ vacanaṁ janinda, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja456:1.2":{"pli":"Atthena juṇhamhi idhānupatto; ","html":"<span class='verse-line'>{}</span>"},"ja456:1.3":{"pli":"Na brāhmaṇe addhike tiṭṭhamāne, ","html":"<span class='verse-line'>{}</span>"},"ja456:1.4":{"pli":"Gantabbamāhu dvipadindaseṭṭha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja456:2.1":{"pli":"“Suṇomi tiṭṭhāmi vadehi brahme, ","html":"<p><span class='verse-line'>{}</span>"},"ja456:2.2":{"pli":"Yenāsi atthena idhānupatto; ","html":"<span class='verse-line'>{}</span>"},"ja456:2.3":{"pli":"Kaṁ vā tvamatthaṁ mayi patthayāno, ","html":"<span class='verse-line'>{}</span>"},"ja456:2.4":{"pli":"Idhāgamā brahme tadiṅgha brūhi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja456:3.1":{"pli":"“Dadāhi me gāmavarāni pañca, ","html":"<p><span class='verse-line'>{}</span>"},"ja456:3.2":{"pli":"Dāsīsataṁ satta gavaṁsatāni; ","html":"<span class='verse-line'>{}</span>"},"ja456:3.3":{"pli":"Parosahassañca suvaṇṇanikkhe, ","html":"<span class='verse-line'>{}</span>"},"ja456:3.4":{"pli":"Bhariyā ca me sādisī dve dadāhi. ","html":"<span class='verse-line'>{}</span></p>"},"ja456:4.1":{"pli":"Tapo nu te brāhmaṇa bhiṁsarūpo, ","html":"<p><span class='verse-line'>{}</span>"},"ja456:4.2":{"pli":"Mantā nu te brāhmaṇa cittarūpā; ","html":"<span class='verse-line'>{}</span>"},"ja456:4.3":{"pli":"Yakkhā nu te assavā santi keci, ","html":"<span class='verse-line'>{}</span>"},"ja456:4.4":{"pli":"Atthaṁ vā me abhijānāsi kattaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja456:5.1":{"pli":"Na me tapo atthi na cāpi mantā, ","html":"<p><span class='verse-line'>{}</span>"},"ja456:5.2":{"pli":"Yakkhāpi me assavā natthi keci; ","html":"<span class='verse-line'>{}</span>"},"ja456:5.3":{"pli":"Atthampi te nābhijānāmi kattaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja456:5.4":{"pli":"Pubbe ca kho saṅgatimattamāsi. ","html":"<span class='verse-line'>{}</span></p>"},"ja456:6.1":{"pli":"Paṭhamaṁ idaṁ dassanaṁ jānato me, ","html":"<p><span class='verse-line'>{}</span>"},"ja456:6.2":{"pli":"Na tābhijānāmi ito puratthā; ","html":"<span class='verse-line'>{}</span>"},"ja456:6.3":{"pli":"Akkhāhi me pucchito etamatthaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja456:6.4":{"pli":"Kadā kuhiṁ vā ahu saṅgamo no. ","html":"<span class='verse-line'>{}</span></p>"},"ja456:7.1":{"pli":"Gandhārarājassa puramhi ramme, ","html":"<p><span class='verse-line'>{}</span>"},"ja456:7.2":{"pli":"Avasimhase takkasīlāyaṁ deva; ","html":"<span class='verse-line'>{}</span>"},"ja456:7.3":{"pli":"Tatthandhakāramhi timīsikāyaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja456:7.4":{"pli":"Aṁsena aṁsaṁ samaghaṭṭayimha. ","html":"<span class='verse-line'>{}</span></p>"},"ja456:8.1":{"pli":"Te tattha ṭhatvāna ubho janinda, ","html":"<p><span class='verse-line'>{}</span>"},"ja456:8.2":{"pli":"Sārāṇiyaṁ vītisārayimha tattha; ","html":"<span class='verse-line'>{}</span>"},"ja456:8.3":{"pli":"Sāyeva no saṅgatimattamāsi, ","html":"<span class='verse-line'>{}</span>"},"ja456:8.4":{"pli":"Tato na pacchā na pure ahosi. ","html":"<span class='verse-line'>{}</span></p>"},"ja456:9.1":{"pli":"Yadā kadāci manujesu brahme, ","html":"<p><span class='verse-line'>{}</span>"},"ja456:9.2":{"pli":"Samāgamo sappurisena hoti; ","html":"<span class='verse-line'>{}</span>"},"ja456:9.3":{"pli":"Na paṇḍitā saṅgatisanthavāni, ","html":"<span class='verse-line'>{}</span>"},"ja456:9.4":{"pli":"Pubbe kataṁ vāpi vināsayanti. ","html":"<span class='verse-line'>{}</span></p>"},"ja456:10.1":{"pli":"Bālāva kho saṅgatisanthavāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja456:10.2":{"pli":"Pubbe kataṁ vāpi vināsayanti; ","html":"<span class='verse-line'>{}</span>"},"ja456:10.3":{"pli":"Bahumpi bālesu kataṁ vinassati, ","html":"<span class='verse-line'>{}</span>"},"ja456:10.4":{"pli":"Tathā hi bālā akataññurūpā. ","html":"<span class='verse-line'>{}</span></p>"},"ja456:11.1":{"pli":"Dhīrā ca kho saṅgatisanthavāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja456:11.2":{"pli":"Pubbe kataṁ vāpi na nāsayanti; ","html":"<span class='verse-line'>{}</span>"},"ja456:11.3":{"pli":"Appampi dhīresu kataṁ na nassati, ","html":"<span class='verse-line'>{}</span>"},"ja456:11.4":{"pli":"Tathā hi dhīrā sukataññurūpā. ","html":"<span class='verse-line'>{}</span></p>"},"ja456:12.1":{"pli":"Dadāmi te gāmavarāni pañca, ","html":"<p><span class='verse-line'>{}</span>"},"ja456:12.2":{"pli":"Dāsīsataṁ satta gavaṁsatāni; ","html":"<span class='verse-line'>{}</span>"},"ja456:12.3":{"pli":"Parosahassañca suvaṇṇanikkhe, ","html":"<span class='verse-line'>{}</span>"},"ja456:12.4":{"pli":"Bhariyā ca te sādisī dve dadāmi. ","html":"<span class='verse-line'>{}</span></p>"},"ja456:13.1":{"pli":"Evaṁ sataṁ hoti samecca rāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja456:13.2":{"pli":"Nakkhattarājāriva tārakānaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja456:13.3":{"pli":"Āpūratī kāsipatī tathāhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja456:13.4":{"pli":"Tayāpi me saṅgamo ajja laddho”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja456:14.1":{"pli":"Juṇhajātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja457":{"ja457:0.1":{"pli":"Jātaka ","html":"<article id='ja457'><header><ul><li class='division'>{}</li>"},"ja457:0.2":{"pli":"Ekādasakanipāta ","html":"<li>{}</li>"},"ja457:0.3":{"pli":"Mātuposakavagga ","html":"<li>{}</li></ul>"},"ja457:0.4":{"pli":"3. Dhammadevaputtajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja457:1.1":{"pli":"“Yasokaro puññakarohamasmi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja457:1.2":{"pli":"Sadātthuto samaṇabrāhmaṇānaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja457:1.3":{"pli":"Maggāraho devamanussapūjito, ","html":"<span class='verse-line'>{}</span>"},"ja457:1.4":{"pli":"Dhammo ahaṁ dehi adhamma maggaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja457:2.1":{"pli":"“Adhammayānaṁ daḷhamāruhitvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja457:2.2":{"pli":"Asantasanto balavāhamasmi; ","html":"<span class='verse-line'>{}</span>"},"ja457:2.3":{"pli":"Sa kissa hetumhi tavajja dajjaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja457:2.4":{"pli":"Maggaṁ ahaṁ dhamma adinnapubbaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja457:3.1":{"pli":"“Dhammo have pāturahosi pubbe, ","html":"<p><span class='verse-line'>{}</span>"},"ja457:3.2":{"pli":"Pacchā adhammo udapādi loke; ","html":"<span class='verse-line'>{}</span>"},"ja457:3.3":{"pli":"Jeṭṭho ca seṭṭho ca sanantano ca, ","html":"<span class='verse-line'>{}</span>"},"ja457:3.4":{"pli":"Uyyāhi jeṭṭhassa kaniṭṭha maggā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja457:4.1":{"pli":"“Na yācanāya napi pātirūpā, ","html":"<p><span class='verse-line'>{}</span>"},"ja457:4.2":{"pli":"Na arahatā tehaṁ dadeyyaṁ maggaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja457:4.3":{"pli":"Yuddhañca no hotu ubhinnamajja, ","html":"<span class='verse-line'>{}</span>"},"ja457:4.4":{"pli":"Yuddhamhi yo jessati tassa maggo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja457:5.1":{"pli":"“Sabbā disā anuvisaṭohamasmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja457:5.2":{"pli":"Mahabbalo amitayaso atulyo; ","html":"<span class='verse-line'>{}</span>"},"ja457:5.3":{"pli":"Guṇehi sabbehi upetarūpo, ","html":"<span class='verse-line'>{}</span>"},"ja457:5.4":{"pli":"Dhammo adhamma tvaṁ kathaṁ vijessasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja457:6.1":{"pli":"Lohena ve haññati jātarūpaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja457:6.2":{"pli":"Na jātarūpena hananti lohaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja457:6.3":{"pli":"Sace adhammo hañchati dhammamajja, ","html":"<span class='verse-line'>{}</span>"},"ja457:6.4":{"pli":"Ayo suvaṇṇaṁ viya dassaneyyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja457:7.1":{"pli":"Sace tuvaṁ yuddhabalo adhamma, ","html":"<p><span class='verse-line'>{}</span>"},"ja457:7.2":{"pli":"Na tuyha vuḍḍhā ca garū ca atthi; ","html":"<span class='verse-line'>{}</span>"},"ja457:7.3":{"pli":"Maggañca te dammi piyāppiyena, ","html":"<span class='verse-line'>{}</span>"},"ja457:7.4":{"pli":"Vācāduruttānipi te khamāmi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja457:8.1":{"pli":"“Idañca sutvā vacanaṁ adhammo, ","html":"<p><span class='verse-line'>{}</span>"},"ja457:8.2":{"pli":"Avaṁsiro patito uddhapādo; ","html":"<span class='verse-line'>{}</span>"},"ja457:8.3":{"pli":"‘Yuddhatthiko ce na labhāmi yuddhaṁ’, ","html":"<span class='verse-line'>{}</span>"},"ja457:8.4":{"pli":"Ettāvatā hoti hato adhammo. ","html":"<span class='verse-line'>{}</span></p>"},"ja457:9.1":{"pli":"Khantībalo yuddhabalaṁ vijetvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja457:9.2":{"pli":"Hantvā adhammaṁ nihanitva bhūmyā; ","html":"<span class='verse-line'>{}</span>"},"ja457:9.3":{"pli":"Pāyāsi vitto abhiruyha sandanaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja457:9.4":{"pli":"Maggeneva atibalo saccanikkamo. ","html":"<span class='verse-line'>{}</span></p>"},"ja457:10.1":{"pli":"Mātā pitā samaṇabrāhmaṇā ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja457:10.2":{"pli":"Asammānitā yassa sake agāre; ","html":"<span class='verse-line'>{}</span>"},"ja457:10.3":{"pli":"Idheva nikkhippa sarīradehaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja457:10.4":{"pli":"Kāyassa bhedā nirayaṁ vajanti te; ","html":"<span class='verse-line'>{}</span>"},"ja457:10.5":{"pli":"Yathā adhammo patito avaṁsiro. ","html":"<span class='verse-line'>{}</span></p>"},"ja457:11.1":{"pli":"Mātā pitā samaṇabrāhmaṇā ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja457:11.2":{"pli":"Susammānitā yassa sake agāre; ","html":"<span class='verse-line'>{}</span>"},"ja457:11.3":{"pli":"Idheva nikkhippa sarīradehaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja457:11.4":{"pli":"Kāyassa bhedā sugatiṁ vajanti te; ","html":"<span class='verse-line'>{}</span>"},"ja457:11.5":{"pli":"Yathāpi dhammo abhiruyha sandanan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja457:12.1":{"pli":"Dhammadevaputtajātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja458":{"ja458:0.1":{"pli":"Jātaka ","html":"<article id='ja458'><header><ul><li class='division'>{}</li>"},"ja458:0.2":{"pli":"Ekādasakanipāta ","html":"<li>{}</li>"},"ja458:0.3":{"pli":"Mātuposakavagga ","html":"<li>{}</li></ul>"},"ja458:0.4":{"pli":"4. Udayajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja458:1.1":{"pli":"“Ekā nisinnā suci saññatūrū, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja458:1.2":{"pli":"Pāsādamāruyha aninditaṅgī; ","html":"<span class='verse-line'>{}</span>"},"ja458:1.3":{"pli":"Yācāmi taṁ kinnaranettacakkhu, ","html":"<span class='verse-line'>{}</span>"},"ja458:1.4":{"pli":"Imekarattiṁ ubhayo vasema”. ","html":"<span class='verse-line'>{}</span></p>"},"ja458:2.1":{"pli":"“Okiṇṇantaraparikhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja458:2.2":{"pli":"daḷhamaṭṭālakoṭṭhakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja458:2.3":{"pli":"Rakkhitaṁ khaggahatthehi, ","html":"<span class='verse-line'>{}</span>"},"ja458:2.4":{"pli":"duppavesamidaṁ puraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja458:3.1":{"pli":"Daharassa yuvino cāpi, ","html":"<p><span class='verse-line'>{}</span>"},"ja458:3.2":{"pli":"āgamo ca na vijjati; ","html":"<span class='verse-line'>{}</span>"},"ja458:3.3":{"pli":"Atha kena nu vaṇṇena, ","html":"<span class='verse-line'>{}</span>"},"ja458:3.4":{"pli":"saṅgamaṁ icchase mayā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja458:4.1":{"pli":"“Yakkhohamasmi kalyāṇi, ","html":"<p><span class='verse-line'>{}</span>"},"ja458:4.2":{"pli":"Āgatosmi tavantike; ","html":"<span class='verse-line'>{}</span>"},"ja458:4.3":{"pli":"Tvaṁ maṁ nandaya bhaddante, ","html":"<span class='verse-line'>{}</span>"},"ja458:4.4":{"pli":"Puṇṇakaṁsaṁ dadāmi te”. ","html":"<span class='verse-line'>{}</span></p>"},"ja458:5.1":{"pli":"“Devaṁ va yakkhaṁ atha vā manussaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja458:5.2":{"pli":"Na patthaye udayamaticca aññaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja458:5.3":{"pli":"Gaccheva tvaṁ yakkha mahānubhāva, ","html":"<span class='verse-line'>{}</span>"},"ja458:5.4":{"pli":"Mā cassu gantvā punarāvajittha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja458:6.1":{"pli":"“Yā sā rati uttamā kāmabhoginaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja458:6.2":{"pli":"Yaṁ hetu sattā visamaṁ caranti; ","html":"<span class='verse-line'>{}</span>"},"ja458:6.3":{"pli":"Mā taṁ ratiṁ jīyi tuvaṁ sucimhite, ","html":"<span class='verse-line'>{}</span>"},"ja458:6.4":{"pli":"Dadāmi te rūpiyaṁ kaṁsapūraṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja458:7.1":{"pli":"“Nāriṁ naro nijjhapayaṁ dhanena, ","html":"<p><span class='verse-line'>{}</span>"},"ja458:7.2":{"pli":"Ukkaṁsatī yattha karoti chandaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja458:7.3":{"pli":"Vipaccanīko tava devadhammo, ","html":"<span class='verse-line'>{}</span>"},"ja458:7.4":{"pli":"Paccakkhato thokatarena esi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja458:8.1":{"pli":"“Āyu ca vaṇṇo ca manussaloke, ","html":"<p><span class='verse-line'>{}</span>"},"ja458:8.2":{"pli":"Nihīyati manujānaṁ sugatte; ","html":"<span class='verse-line'>{}</span>"},"ja458:8.3":{"pli":"Teneva vaṇṇena dhanampi tuyhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja458:8.4":{"pli":"Nihīyati jiṇṇatarāsi ajja. ","html":"<span class='verse-line'>{}</span></p>"},"ja458:9.1":{"pli":"Evaṁ me pekkhamānassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja458:9.2":{"pli":"rājaputti yasassini; ","html":"<span class='verse-line'>{}</span>"},"ja458:9.3":{"pli":"Hāyateva tava vaṇṇo, ","html":"<span class='verse-line'>{}</span>"},"ja458:9.4":{"pli":"ahorattānamaccaye”. ","html":"<span class='verse-line'>{}</span></p>"},"ja458:10.1":{"pli":"“Imināva tvaṁ vayasā, ","html":"<p><span class='verse-line'>{}</span>"},"ja458:10.2":{"pli":"rājaputti sumedhase; ","html":"<span class='verse-line'>{}</span>"},"ja458:10.3":{"pli":"Brahmacariyaṁ careyyāsi, ","html":"<span class='verse-line'>{}</span>"},"ja458:10.4":{"pli":"bhiyyo vaṇṇavatī siyā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja458:11.1":{"pli":"“Devā na jīranti yathā manussā, ","html":"<p><span class='verse-line'>{}</span>"},"ja458:11.2":{"pli":"Gattesu tesaṁ valiyo na honti; ","html":"<span class='verse-line'>{}</span>"},"ja458:11.3":{"pli":"Pucchāmi taṁ yakkha mahānubhāva, ","html":"<span class='verse-line'>{}</span>"},"ja458:11.4":{"pli":"Kathaṁ nu devāna sarīradeho”. ","html":"<span class='verse-line'>{}</span></p>"},"ja458:12.1":{"pli":"“Devā na jīranti yathā manussā, ","html":"<p><span class='verse-line'>{}</span>"},"ja458:12.2":{"pli":"Gattesu tesaṁ valiyo na honti; ","html":"<span class='verse-line'>{}</span>"},"ja458:12.3":{"pli":"Suve suve bhiyyatarova tesaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja458:12.4":{"pli":"Dibbo ca vaṇṇo vipulā ca bhogā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja458:13.1":{"pli":"“Kiṁsūdha bhītā janatā anekā, ","html":"<p><span class='verse-line'>{}</span>"},"ja458:13.2":{"pli":"Maggo ca nekāyatanaṁ pavutto; ","html":"<span class='verse-line'>{}</span>"},"ja458:13.3":{"pli":"Pucchāmi taṁ yakkha mahānubhāva, ","html":"<span class='verse-line'>{}</span>"},"ja458:13.4":{"pli":"Katthaṭṭhito paralokaṁ na bhāye”. ","html":"<span class='verse-line'>{}</span></p>"},"ja458:14.1":{"pli":"“Vācaṁ manañca paṇidhāya sammā, ","html":"<p><span class='verse-line'>{}</span>"},"ja458:14.2":{"pli":"Kāyena pāpāni akubbamāno; ","html":"<span class='verse-line'>{}</span>"},"ja458:14.3":{"pli":"Bahunnapānaṁ gharamāvasanto, ","html":"<span class='verse-line'>{}</span>"},"ja458:14.4":{"pli":"Saddho mudū saṁvibhāgī vadaññū; ","html":"<span class='verse-line'>{}</span>"},"ja458:14.5":{"pli":"Saṅgāhako sakhilo saṇhavāco, ","html":"<span class='verse-line'>{}</span>"},"ja458:14.6":{"pli":"Etthaṭṭhito paralokaṁ na bhāye”. ","html":"<span class='verse-line'>{}</span></p>"},"ja458:15.1":{"pli":"“Anusāsasi maṁ yakkha, ","html":"<p><span class='verse-line'>{}</span>"},"ja458:15.2":{"pli":"yathā mātā yathā pitā; ","html":"<span class='verse-line'>{}</span>"},"ja458:15.3":{"pli":"Uḷāravaṇṇaṁ pucchāmi, ","html":"<span class='verse-line'>{}</span>"},"ja458:15.4":{"pli":"ko nu tvamasi subrahā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja458:16.1":{"pli":"“Udayohamasmi kalyāṇi, ","html":"<p><span class='verse-line'>{}</span>"},"ja458:16.2":{"pli":"saṅgarattā idhāgato; ","html":"<span class='verse-line'>{}</span>"},"ja458:16.3":{"pli":"Āmanta kho taṁ gacchāmi, ","html":"<span class='verse-line'>{}</span>"},"ja458:16.4":{"pli":"muttosmi tava saṅgarā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja458:17.1":{"pli":"“Sace kho tvaṁ udayosi, ","html":"<p><span class='verse-line'>{}</span>"},"ja458:17.2":{"pli":"saṅgarattā idhāgato; ","html":"<span class='verse-line'>{}</span>"},"ja458:17.3":{"pli":"Anusāsa maṁ rājaputta, ","html":"<span class='verse-line'>{}</span>"},"ja458:17.4":{"pli":"yathāssa puna saṅgamo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja458:18.1":{"pli":"“Atipatati vayo khaṇo tatheva, ","html":"<p><span class='verse-line'>{}</span>"},"ja458:18.2":{"pli":"Ṭhānaṁ natthi dhuvaṁ cavanti sattā; ","html":"<span class='verse-line'>{}</span>"},"ja458:18.3":{"pli":"Parijiyyati addhuvaṁ sarīraṁ, ","html":"<span class='verse-line'>{}</span>"},"ja458:18.4":{"pli":"Udaye mā pamāda carassu dhammaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja458:19.1":{"pli":"Kasiṇā pathavī dhanassa pūrā, ","html":"<p><span class='verse-line'>{}</span>"},"ja458:19.2":{"pli":"Ekasseva siyā anaññadheyyā; ","html":"<span class='verse-line'>{}</span>"},"ja458:19.3":{"pli":"Tañcāpi jahati avītarāgo, ","html":"<span class='verse-line'>{}</span>"},"ja458:19.4":{"pli":"Udaye mā pamāda carassu dhammaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja458:20.1":{"pli":"Mātā ca pitā ca bhātaro ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja458:20.2":{"pli":"Bhariyā yāpi dhanena hoti kītā; ","html":"<span class='verse-line'>{}</span>"},"ja458:20.3":{"pli":"Te cāpi jahanti aññamaññaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja458:20.4":{"pli":"Udaye mā pamāda carassu dhammaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja458:21.1":{"pli":"Kāyo parabhojananti ñatvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja458:21.2":{"pli":"Saṁsāre sugatiñca duggatiñca; ","html":"<span class='verse-line'>{}</span>"},"ja458:21.3":{"pli":"Ittaravāsoti jāniyāna, ","html":"<span class='verse-line'>{}</span>"},"ja458:21.4":{"pli":"Udaye mā pamāda carassu dhammaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja458:22.1":{"pli":"“Sādhu bhāsatiyaṁ yakkho, ","html":"<p><span class='verse-line'>{}</span>"},"ja458:22.2":{"pli":"appaṁ maccāna jīvitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja458:22.3":{"pli":"Kasirañca parittañca, ","html":"<span class='verse-line'>{}</span>"},"ja458:22.4":{"pli":"tañca dukkhena saṁyutaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja458:22.5":{"pli":"Sāhaṁ ekā pabbajissāmi, ","html":"<span class='verse-line'>{}</span>"},"ja458:22.6":{"pli":"hitvā kāsiṁ surundhanan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja458:23.1":{"pli":"Udayajātakaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja459":{"ja459:0.1":{"pli":"Jātaka ","html":"<article id='ja459'><header><ul><li class='division'>{}</li>"},"ja459:0.2":{"pli":"Ekādasakanipāta ","html":"<li>{}</li>"},"ja459:0.3":{"pli":"Mātuposakavagga ","html":"<li>{}</li></ul>"},"ja459:0.4":{"pli":"5. Pānīyajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja459:1.1":{"pli":"“Mitto mittassa pānīyaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja459:1.2":{"pli":"adinnaṁ paribhuñjisaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja459:1.3":{"pli":"Tena pacchā vijigucchiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja459:1.4":{"pli":"taṁ pāpaṁ pakataṁ mayā; ","html":"<span class='verse-line'>{}</span>"},"ja459:1.5":{"pli":"Mā puna akaraṁ pāpaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja459:1.6":{"pli":"tasmā pabbajito ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja459:2.1":{"pli":"Paradārañca disvāna, ","html":"<p><span class='verse-line'>{}</span>"},"ja459:2.2":{"pli":"chando me udapajjatha; ","html":"<span class='verse-line'>{}</span>"},"ja459:2.3":{"pli":"Tena pacchā vijigucchiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja459:2.4":{"pli":"taṁ pāpaṁ pakataṁ mayā; ","html":"<span class='verse-line'>{}</span>"},"ja459:2.5":{"pli":"Mā puna akaraṁ pāpaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja459:2.6":{"pli":"tasmā pabbajito ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja459:3.1":{"pli":"Pitaraṁ me mahārāja, ","html":"<p><span class='verse-line'>{}</span>"},"ja459:3.2":{"pli":"corā agaṇhu kānane; ","html":"<span class='verse-line'>{}</span>"},"ja459:3.3":{"pli":"Tesāhaṁ pucchito jānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja459:3.4":{"pli":"aññathā naṁ viyākariṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja459:4.1":{"pli":"Tena pacchā vijigucchiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja459:4.2":{"pli":"taṁ pāpaṁ pakataṁ mayā; ","html":"<span class='verse-line'>{}</span>"},"ja459:4.3":{"pli":"Mā puna akaraṁ pāpaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja459:4.4":{"pli":"tasmā pabbajito ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja459:5.1":{"pli":"Pāṇātipātamakaruṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja459:5.2":{"pli":"somayāge upaṭṭhite; ","html":"<span class='verse-line'>{}</span>"},"ja459:5.3":{"pli":"Tesāhaṁ samanuññāsiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja459:6.1":{"pli":"Tena pacchā vijigucchiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja459:6.2":{"pli":"taṁ pāpaṁ pakataṁ mayā; ","html":"<span class='verse-line'>{}</span>"},"ja459:6.3":{"pli":"Mā puna akaraṁ pāpaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja459:6.4":{"pli":"tasmā pabbajito ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja459:7.1":{"pli":"Surāmerayamādhukā, ","html":"<p><span class='verse-line'>{}</span>"},"ja459:7.2":{"pli":"ye janā paṭhamāsu no; ","html":"<span class='verse-line'>{}</span>"},"ja459:7.3":{"pli":"Bahūnaṁ te anatthāya, ","html":"<span class='verse-line'>{}</span>"},"ja459:7.4":{"pli":"majjapānamakappayuṁ; ","html":"<span class='verse-line'>{}</span>"},"ja459:7.5":{"pli":"Tesāhaṁ samanuññāsiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja459:8.1":{"pli":"Tena pacchā vijigucchiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja459:8.2":{"pli":"taṁ pāpaṁ pakataṁ mayā; ","html":"<span class='verse-line'>{}</span>"},"ja459:8.3":{"pli":"Mā puna akaraṁ pāpaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja459:8.4":{"pli":"tasmā pabbajito ahaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja459:9.1":{"pli":"“Dhiratthu subahū kāme, ","html":"<p><span class='verse-line'>{}</span>"},"ja459:9.2":{"pli":"duggandhe bahukaṇṭake; ","html":"<span class='verse-line'>{}</span>"},"ja459:9.3":{"pli":"Ye ahaṁ paṭisevanto, ","html":"<span class='verse-line'>{}</span>"},"ja459:9.4":{"pli":"nālabhiṁ tādisaṁ sukhaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja459:10.1":{"pli":"“Mahassādā sukhā kāmā, ","html":"<p><span class='verse-line'>{}</span>"},"ja459:10.2":{"pli":"Natthi kāmā paraṁ sukhaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja459:10.3":{"pli":"Ye kāme paṭisevanti, ","html":"<span class='verse-line'>{}</span>"},"ja459:10.4":{"pli":"Saggaṁ te upapajjare”. ","html":"<span class='verse-line'>{}</span></p>"},"ja459:11.1":{"pli":"“Appassādā dukhā kāmā, ","html":"<p><span class='verse-line'>{}</span>"},"ja459:11.2":{"pli":"natthi kāmā paraṁ dukhaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja459:11.3":{"pli":"Ye kāme paṭisevanti, ","html":"<span class='verse-line'>{}</span>"},"ja459:11.4":{"pli":"nirayaṁ te upapajjare. ","html":"<span class='verse-line'>{}</span></p>"},"ja459:12.1":{"pli":"Asī yathā sunisito, ","html":"<p><span class='verse-line'>{}</span>"},"ja459:12.2":{"pli":"nettiṁsova supāyiko; ","html":"<span class='verse-line'>{}</span>"},"ja459:12.3":{"pli":"Sattīva urasi khittā, ","html":"<span class='verse-line'>{}</span>"},"ja459:12.4":{"pli":"kāmā dukkhatarā tato. ","html":"<span class='verse-line'>{}</span></p>"},"ja459:13.1":{"pli":"Aṅgārānaṁva jalitaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja459:13.2":{"pli":"kāsuṁ sādhikaporisaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja459:13.3":{"pli":"Phālaṁva divasantattaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja459:13.4":{"pli":"kāmā dukkhatarā tato. ","html":"<span class='verse-line'>{}</span></p>"},"ja459:14.1":{"pli":"Visaṁ yathā halāhalaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja459:14.2":{"pli":"telaṁ pakkuthitaṁ yathā; ","html":"<span class='verse-line'>{}</span>"},"ja459:14.3":{"pli":"Tambaloha vilīnaṁva, ","html":"<span class='verse-line'>{}</span>"},"ja459:14.4":{"pli":"kāmā dukkhatarā tato”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja459:15.1":{"pli":"Pānīyajātakaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja46":{"ja46:0.1":{"pli":"Jātaka ","eng":"Stories of Past Lives 48 ","html":"<article id='ja46'><header><ul><li class='division'>{}</li>"},"ja46:0.2":{"pli":"Ekakanipāta ","eng":"The Book of the Ones ","html":"<li>{}</li>"},"ja46:0.3":{"pli":"Atthakāmavagga ","eng":"Wanting to Help ","html":"<li>{}</li></ul>"},"ja46:0.4":{"pli":"6. Ārāmadūsakajātaka ","eng":"Spoiling the Park: a past life story ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja46:1.1":{"pli":"“Na ve anatthakusalena, ","eng":"Surely not with one who misunderstands the meaning ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>","comm":"A lazy groundskeeper asks the monkeys in the park to water the trees in his absence. They set to work with all good cheer. However, misconstruing the instructions, they pull up each tree to examine the size of the roots before watering, thus ruining the park despite their good intentions. "},"ja46:1.2":{"pli":"atthacariyā sukhāvahā; ","eng":"does good conduct lead to happiness. ","html":"<span class='verse-line'>{}</span>","comm":"The verse plays on two meanings of <i lang='pi' translate='no'>attha</i>. In the opening line, <i lang='pi' translate='no'>attha</i> is “meaning, basis” (as per <a href='index.html?q=snp1.8#1.1'>Snp 1.8:1.1</a> or [an5.169:3.1]), and it is glossed <i lang='pi' translate='no'>āyatane kāraṇe</i> (“reason, cause”). Here it means “good, benefit” and is glossed <i lang='pi' translate='no'>vuḍḍhi</i> (“growth”). "},"ja46:1.3":{"pli":"Hāpeti atthaṁ dummedho, ","eng":"The simpleton destroys the good, ","html":"<span class='verse-line'>{}</span>"},"ja46:1.4":{"pli":"kapi ārāmiko yathā”ti. ","eng":"like the monkey groundskeeper. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja46:2.1":{"pli":"Ārāmadūsakajātakaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja460":{"ja460:0.1":{"pli":"Jātaka ","html":"<article id='ja460'><header><ul><li class='division'>{}</li>"},"ja460:0.2":{"pli":"Ekādasakanipāta ","html":"<li>{}</li>"},"ja460:0.3":{"pli":"Mātuposakavagga ","html":"<li>{}</li></ul>"},"ja460:0.4":{"pli":"6. Yudhañcayajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja460:1.1":{"pli":"“Mittāmaccaparibyūḷhaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja460:1.2":{"pli":"ahaṁ vande rathesabhaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja460:1.3":{"pli":"Pabbajissāmahaṁ rāja, ","html":"<span class='verse-line'>{}</span>"},"ja460:1.4":{"pli":"taṁ devo anumaññatu”. ","html":"<span class='verse-line'>{}</span></p>"},"ja460:2.1":{"pli":"“Sace te ūnaṁ kāmehi, ","html":"<p><span class='verse-line'>{}</span>"},"ja460:2.2":{"pli":"ahaṁ paripūrayāmi te; ","html":"<span class='verse-line'>{}</span>"},"ja460:2.3":{"pli":"Yo taṁ hiṁsati vāremi, ","html":"<span class='verse-line'>{}</span>"},"ja460:2.4":{"pli":"mā pabbaja yudhañcaya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja460:3.1":{"pli":"“Na matthi ūnaṁ kāmehi, ","html":"<p><span class='verse-line'>{}</span>"},"ja460:3.2":{"pli":"hiṁsitā me na vijjati; ","html":"<span class='verse-line'>{}</span>"},"ja460:3.3":{"pli":"Dīpañca kātumicchāmi, ","html":"<span class='verse-line'>{}</span>"},"ja460:3.4":{"pli":"yaṁ jarā nābhikīrati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja460:4.1":{"pli":"“Putto vā pitaraṁ yāce, ","html":"<p><span class='verse-line'>{}</span>"},"ja460:4.2":{"pli":"pitā vā puttamorasaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja460:4.3":{"pli":"Negamo taṁ yāce tāta, ","html":"<span class='verse-line'>{}</span>"},"ja460:4.4":{"pli":"mā pabbaja yudhañcaya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja460:5.1":{"pli":"“Mā maṁ deva nivārehi, ","html":"<p><span class='verse-line'>{}</span>"},"ja460:5.2":{"pli":"pabbajantaṁ rathesabha; ","html":"<span class='verse-line'>{}</span>"},"ja460:5.3":{"pli":"Māhaṁ kāmehi sammatto, ","html":"<span class='verse-line'>{}</span>"},"ja460:5.4":{"pli":"jarāya vasamanvagū”. ","html":"<span class='verse-line'>{}</span></p>"},"ja460:6.1":{"pli":"“Ahaṁ taṁ tāta yācāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja460:6.2":{"pli":"ahaṁ putta nivāraye; ","html":"<span class='verse-line'>{}</span>"},"ja460:6.3":{"pli":"Ciraṁ taṁ daṭṭhumicchāmi, ","html":"<span class='verse-line'>{}</span>"},"ja460:6.4":{"pli":"mā pabbaja yudhañcaya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja460:7.1":{"pli":"“Ussāvova tiṇaggamhi, ","html":"<p><span class='verse-line'>{}</span>"},"ja460:7.2":{"pli":"sūriyuggamanaṁ pati; ","html":"<span class='verse-line'>{}</span>"},"ja460:7.3":{"pli":"Evamāyu manussānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja460:7.4":{"pli":"mā maṁ amma nivāraya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja460:8.1":{"pli":"“Taramāno imaṁ yānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja460:8.2":{"pli":"āropetu rathesabha; ","html":"<span class='verse-line'>{}</span>"},"ja460:8.3":{"pli":"Mā me mātā tarantassa, ","html":"<span class='verse-line'>{}</span>"},"ja460:8.4":{"pli":"antarāyakarā ahu”. ","html":"<span class='verse-line'>{}</span></p>"},"ja460:9.1":{"pli":"“Abhidhāvatha bhaddante, ","html":"<p><span class='verse-line'>{}</span>"},"ja460:9.2":{"pli":"suññaṁ hessati rammakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja460:9.3":{"pli":"Yudhañcayo anuññāto, ","html":"<span class='verse-line'>{}</span>"},"ja460:9.4":{"pli":"sabbadattena rājinā. ","html":"<span class='verse-line'>{}</span></p>"},"ja460:10.1":{"pli":"Yohu seṭṭho sahassassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja460:10.2":{"pli":"yuvā kañcanasannibho; ","html":"<span class='verse-line'>{}</span>"},"ja460:10.3":{"pli":"Soyaṁ kumāro pabbajito, ","html":"<span class='verse-line'>{}</span>"},"ja460:10.4":{"pli":"kāsāyavasano balī”. ","html":"<span class='verse-line'>{}</span></p>"},"ja460:11.1":{"pli":"“Ubho kumārā pabbajitā, ","html":"<p><span class='verse-line'>{}</span>"},"ja460:11.2":{"pli":"yudhañcayo yudhiṭṭhilo; ","html":"<span class='verse-line'>{}</span>"},"ja460:11.3":{"pli":"Pahāya mātāpitaro, ","html":"<span class='verse-line'>{}</span>"},"ja460:11.4":{"pli":"saṅgaṁ chetvāna maccuno”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja460:12.1":{"pli":"Yudhañcayajātakaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja461":{"ja461:0.1":{"pli":"Jātaka ","html":"<article id='ja461'><header><ul><li class='division'>{}</li>"},"ja461:0.2":{"pli":"Ekādasakanipāta ","html":"<li>{}</li>"},"ja461:0.3":{"pli":"Mātuposakavagga ","html":"<li>{}</li></ul>"},"ja461:0.4":{"pli":"7. Dasarathajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja461:1.1":{"pli":"“Etha lakkhaṇa sītā ca, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja461:1.2":{"pli":"ubho otarathodakaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja461:1.3":{"pli":"Evāyaṁ bharato āha, ","html":"<span class='verse-line'>{}</span>"},"ja461:1.4":{"pli":"‘rājā dasaratho mato’”. ","html":"<span class='verse-line'>{}</span></p>"},"ja461:2.1":{"pli":"“Kena rāmappabhāvena, ","html":"<p><span class='verse-line'>{}</span>"},"ja461:2.2":{"pli":"socitabbaṁ na socasi; ","html":"<span class='verse-line'>{}</span>"},"ja461:2.3":{"pli":"Pitaraṁ kālakataṁ sutvā, ","html":"<span class='verse-line'>{}</span>"},"ja461:2.4":{"pli":"na taṁ pasahate dukhaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja461:3.1":{"pli":"“Yaṁ na sakkā nipāletuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja461:3.2":{"pli":"posena lapataṁ bahuṁ; ","html":"<span class='verse-line'>{}</span>"},"ja461:3.3":{"pli":"Sa kissa viññū medhāvī, ","html":"<span class='verse-line'>{}</span>"},"ja461:3.4":{"pli":"attānamupatāpaye. ","html":"<span class='verse-line'>{}</span></p>"},"ja461:4.1":{"pli":"Daharā ca hi vuddhā ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja461:4.2":{"pli":"ye bālā ye ca paṇḍitā; ","html":"<span class='verse-line'>{}</span>"},"ja461:4.3":{"pli":"Aḍḍhā ceva daliddā ca, ","html":"<span class='verse-line'>{}</span>"},"ja461:4.4":{"pli":"sabbe maccuparāyaṇā. ","html":"<span class='verse-line'>{}</span></p>"},"ja461:5.1":{"pli":"Phalānamiva pakkānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja461:5.2":{"pli":"niccaṁ patanato bhayaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja461:5.3":{"pli":"Evaṁ jātāna maccānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja461:5.4":{"pli":"nicca maraṇato bhayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja461:6.1":{"pli":"Sāyameke na dissanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja461:6.2":{"pli":"pāto diṭṭhā bahujjanā; ","html":"<span class='verse-line'>{}</span>"},"ja461:6.3":{"pli":"Pāto eke na dissanti, ","html":"<span class='verse-line'>{}</span>"},"ja461:6.4":{"pli":"sāyaṁ diṭṭhā bahujjanā. ","html":"<span class='verse-line'>{}</span></p>"},"ja461:7.1":{"pli":"Paridevayamāno ce, ","html":"<p><span class='verse-line'>{}</span>"},"ja461:7.2":{"pli":"kiñcidatthaṁ udabbahe; ","html":"<span class='verse-line'>{}</span>"},"ja461:7.3":{"pli":"Sammūḷho hiṁsamattānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja461:7.4":{"pli":"kayirā taṁ vicakkhaṇo. ","html":"<span class='verse-line'>{}</span></p>"},"ja461:8.1":{"pli":"Kiso vivaṇṇo bhavati, ","html":"<p><span class='verse-line'>{}</span>"},"ja461:8.2":{"pli":"hiṁsamattānamattano; ","html":"<span class='verse-line'>{}</span>"},"ja461:8.3":{"pli":"Na tena petā pālenti, ","html":"<span class='verse-line'>{}</span>"},"ja461:8.4":{"pli":"niratthā paridevanā. ","html":"<span class='verse-line'>{}</span></p>"},"ja461:9.1":{"pli":"Yathā saraṇamādittaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja461:9.2":{"pli":"vārinā parinibbaye; ","html":"<span class='verse-line'>{}</span>"},"ja461:9.3":{"pli":"Evampi dhīro sutavā, ","html":"<span class='verse-line'>{}</span>"},"ja461:9.4":{"pli":"medhāvī paṇḍito naro; ","html":"<span class='verse-line'>{}</span>"},"ja461:9.5":{"pli":"Khippamuppatitaṁ sokaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja461:9.6":{"pli":"vāto tūlaṁva dhaṁsaye. ","html":"<span class='verse-line'>{}</span></p>"},"ja461:10.1":{"pli":"Macco ekova acceti, ","html":"<p><span class='verse-line'>{}</span>"},"ja461:10.2":{"pli":"ekova jāyate kule; ","html":"<span class='verse-line'>{}</span>"},"ja461:10.3":{"pli":"Saṁyogaparamā tveva, ","html":"<span class='verse-line'>{}</span>"},"ja461:10.4":{"pli":"sambhogā sabbapāṇinaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja461:11.1":{"pli":"Tasmā hi dhīrassa bahussutassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja461:11.2":{"pli":"Sampassato lokamimaṁ parañca; ","html":"<span class='verse-line'>{}</span>"},"ja461:11.3":{"pli":"Aññāya dhammaṁ hadayaṁ manañca, ","html":"<span class='verse-line'>{}</span>"},"ja461:11.4":{"pli":"Sokā mahantāpi na tāpayanti. ","html":"<span class='verse-line'>{}</span></p>"},"ja461:12.1":{"pli":"Sohaṁ dassañca bhokkhañca, ","html":"<p><span class='verse-line'>{}</span>"},"ja461:12.2":{"pli":"bharissāmi ca ñātake; ","html":"<span class='verse-line'>{}</span>"},"ja461:12.3":{"pli":"Sesañca pālayissāmi, ","html":"<span class='verse-line'>{}</span>"},"ja461:12.4":{"pli":"kiccametaṁ vijānato. ","html":"<span class='verse-line'>{}</span></p>"},"ja461:13.1":{"pli":"Dasa vassasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja461:13.2":{"pli":"saṭṭhi vassasatāni ca; ","html":"<span class='verse-line'>{}</span>"},"ja461:13.3":{"pli":"Kambugīvo mahābāhu, ","html":"<span class='verse-line'>{}</span>"},"ja461:13.4":{"pli":"rāmo rajjamakārayī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja461:14.1":{"pli":"Dasarathajātakaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}