{"tha-ap80":{"tha-ap80:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap80'><header><ul><li class='division'>{}</li>"},"tha-ap80:0.2":{"pli":"Nāgasamālavagga ","html":"<li>{}</li></ul>"},"tha-ap80:0.3":{"pli":"Pāṭalipupphiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap80:1.1":{"pli":"“Suvaṇṇavaṇṇaṁ sambuddhaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap80:1.2":{"pli":"Gacchantaṁ antarāpaṇe; ","html":"<span class='verse-line'>{}</span>"},"tha-ap80:1.3":{"pli":"Kañcanagghiyasaṅkāsaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap80:1.4":{"pli":"Bāttiṁsavaralakkhaṇaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap80:2.1":{"pli":"Seṭṭhiputto tadā āsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap80:2.2":{"pli":"sukhumālo sukhedhito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap80:2.3":{"pli":"Ucchaṅge pāṭalipupphaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap80:2.4":{"pli":"katvāna abhisaṁhariṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap80:3.1":{"pli":"Haṭṭho haṭṭhena cittena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap80:3.2":{"pli":"pupphehi abhipūjayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap80:3.3":{"pli":"Tissaṁ lokaviduṁ nāthaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap80:3.4":{"pli":"naradevaṁ namassahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap80:4.1":{"pli":"Dvenavute ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap80:4.2":{"pli":"yaṁ kammamakariṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap80:4.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap80:4.4":{"pli":"pupphapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap80:5.1":{"pli":"Ito tesaṭṭhikappamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap80:5.2":{"pli":"abhisammatanāmako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap80:5.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap80:5.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap80:6.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap80:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap80:6.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap80:7.1":{"pli":"Itthaṁ sudaṁ āyasmā pāṭalipupphiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap80:8.1":{"pli":"Pāṭalipupphiyattherassāpadānaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap81":{"tha-ap81:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap81'><header><ul><li class='division'>{}</li>"},"tha-ap81:0.2":{"pli":"Nāgasamālavagga ","html":"<li>{}</li></ul>"},"tha-ap81:0.3":{"pli":"Ṭhitañjaliyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap81:1.1":{"pli":"“Migaluddo pure āsiṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap81:1.2":{"pli":"Araññe kānane ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap81:1.3":{"pli":"Tattha addasaṁ sambuddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap81:1.4":{"pli":"Bāttiṁsavaralakkhaṇaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap81:2.1":{"pli":"Tatthāhaṁ añjaliṁ katvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap81:2.2":{"pli":"pakkāmiṁ pācināmukho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap81:2.3":{"pli":"Avidūre nisinnassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap81:2.4":{"pli":"niyake paṇṇasanthare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap81:3.1":{"pli":"Tato me asanīpāto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap81:3.2":{"pli":"matthake nipatī tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap81:3.3":{"pli":"Sohaṁ maraṇakālamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap81:3.4":{"pli":"akāsiṁ punarañjaliṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap81:4.1":{"pli":"Dvenavute ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap81:4.2":{"pli":"añjaliṁ akariṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap81:4.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap81:4.4":{"pli":"añjalissa idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap81:5.1":{"pli":"Catupaṇṇāsakappamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap81:5.2":{"pli":"migaketusanāmako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap81:5.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap81:5.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap81:6.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap81:6.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap81:6.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap81:7.1":{"pli":"Itthaṁ sudaṁ āyasmā ṭhitañjaliyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap81:8.1":{"pli":"Ṭhitañjaliyattherassāpadānaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap82":{"tha-ap82:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap82'><header><ul><li class='division'>{}</li>"},"tha-ap82:0.2":{"pli":"Nāgasamālavagga ","html":"<li>{}</li></ul>"},"tha-ap82:0.3":{"pli":"10 Tipadumiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap82:1.1":{"pli":"“Padumuttaro nāma jino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap82:1.2":{"pli":"sabbadhammāna pāragū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:1.3":{"pli":"Danto dantaparivuto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:1.4":{"pli":"nagarā nikkhamī tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap82:2.1":{"pli":"Nagare haṁsavatiyaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap82:2.2":{"pli":"ahosiṁ māliko tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:2.3":{"pli":"Yaṁ tattha uttamaṁ tīṇi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:2.4":{"pli":"padmapupphāni aggahiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap82:3.1":{"pli":"‘Addasaṁ virajaṁ buddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap82:3.2":{"pli":"paṭimaggantarāpaṇe; ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:3.3":{"pli":"Saha disvāna sambuddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:3.4":{"pli":"evaṁ cintesahaṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap82:4.1":{"pli":"Kiṁ me imehi pupphehi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap82:4.2":{"pli":"rañño upanitehi me; ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:4.3":{"pli":"Gāmaṁ vā gāmakhettaṁ vā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:4.4":{"pli":"sahassaṁ vā labheyyahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap82:5.1":{"pli":"Adantadamanaṁ vīraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap82:5.2":{"pli":"sabbasattasukhāvahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:5.3":{"pli":"Lokanāthaṁ pūjayitvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:5.4":{"pli":"lacchāmi amataṁ dhanaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap82:6.1":{"pli":"Evāhaṁ cintayitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap82:6.2":{"pli":"sakaṁ cittaṁ pasādayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:6.3":{"pli":"Tīṇi lohitake gayha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:6.4":{"pli":"ākāse ukkhipiṁ tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap82:7.1":{"pli":"Mayā ukkhittamattamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap82:7.2":{"pli":"ākāse patthariṁsu te; ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:7.3":{"pli":"Dhāriṁsu matthake tattha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:7.4":{"pli":"uddhaṁvaṇṭā adhomukhā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap82:8.1":{"pli":"Ye keci manujā disvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap82:8.2":{"pli":"ukkuṭṭhiṁ sampavattayuṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:8.3":{"pli":"Devatā antalikkhamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:8.4":{"pli":"sādhukāraṁ pavattayuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap82:9.1":{"pli":"Accheraṁ loke uppannaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap82:9.2":{"pli":"buddhaseṭṭhassa vāhasā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:9.3":{"pli":"Sabbe dhammaṁ suṇissāma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:9.4":{"pli":"pupphānaṁ vāhasā mayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap82:10.1":{"pli":"Padumuttaro lokavidū, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap82:10.2":{"pli":"āhutīnaṁ paṭiggaho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:10.3":{"pli":"Vīthiyañhi ṭhito santo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:10.4":{"pli":"imā gāthā abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap82:11.1":{"pli":"‘Yo so buddhaṁ apūjesi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap82:11.2":{"pli":"rattapadmehi māṇavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:11.3":{"pli":"Tamahaṁ kittayissāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:11.4":{"pli":"suṇātha mama bhāsato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap82:12.1":{"pli":"Tiṁsakappasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap82:12.2":{"pli":"devaloke ramissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:12.3":{"pli":"Tiṁsakappāni devindo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:12.4":{"pli":"devarajjaṁ karissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap82:13.1":{"pli":"Mahāvitthārikaṁ nāma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap82:13.2":{"pli":"byamhaṁ hessati tāvade; ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:13.3":{"pli":"Tiyojanasatubbiddhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:13.4":{"pli":"diyaḍḍhasatavitthataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap82:14.1":{"pli":"Cattārisatasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap82:14.2":{"pli":"niyyūhā ca sumāpitā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:14.3":{"pli":"Kūṭāgāravarūpetā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:14.4":{"pli":"mahāsayanamaṇḍitā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap82:15.1":{"pli":"Koṭisatasahassiyo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap82:15.2":{"pli":"parivāressanti accharā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:15.3":{"pli":"Kusalā naccagītassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:15.4":{"pli":"vāditepi padakkhiṇā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap82:16.1":{"pli":"Etādise byamhavare, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap82:16.2":{"pli":"nārīgaṇasamākule; ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:16.3":{"pli":"Vassissati pupphavasso, ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:16.4":{"pli":"dibbo lohitako sadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap82:17.1":{"pli":"Bhittikhīle nāgadante, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap82:17.2":{"pli":"dvārabāhāya toraṇe; ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:17.3":{"pli":"Cakkamattā lohitakā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:17.4":{"pli":"olambissanti tāvade. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap82:18.1":{"pli":"Pattena pattasañchanne, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap82:18.2":{"pli":"antobyamhavare imaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:18.3":{"pli":"Attharitvā pārupitvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:18.4":{"pli":"tuvaṭṭissanti tāvade. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap82:19.1":{"pli":"Bhavanaṁ parivāretvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap82:19.2":{"pli":"samantā satayojane; ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:19.3":{"pli":"Tepi padmā lohitakā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:19.4":{"pli":"dibbagandhaṁ pavāyare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap82:20.1":{"pli":"Pañcasattatikkhattuñca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap82:20.2":{"pli":"cakkavattī bhavissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:20.3":{"pli":"Padesarajjaṁ vipulaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:20.4":{"pli":"gaṇanāto asaṅkhiyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap82:21.1":{"pli":"Sampattiyo duve bhutvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap82:21.2":{"pli":"anīti anupaddavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:21.3":{"pli":"Sampatte pariyosāne, ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:21.4":{"pli":"nibbānaṁ pāpuṇissati’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap82:22.1":{"pli":"Sudiṭṭho vata me buddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap82:22.2":{"pli":"vāṇijjaṁ supayojitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:22.3":{"pli":"Padmāni tīṇi pūjetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:22.4":{"pli":"anubhosiṁ tisampadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap82:23.1":{"pli":"Ajja me dhammappattassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap82:23.2":{"pli":"vippamuttassa sabbaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:23.3":{"pli":"Supupphitaṁ lohitakaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:23.4":{"pli":"dhārayissati matthake. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap82:24.1":{"pli":"Mama kammaṁ kathentassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap82:24.2":{"pli":"padumuttarasatthuno; ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:24.3":{"pli":"Satapāṇasahassānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:24.4":{"pli":"dhammābhisamayo ahu. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap82:25.1":{"pli":"Satasahassito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap82:25.2":{"pli":"yaṁ buddhamabhipūjayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:25.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:25.4":{"pli":"tipadumānidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap82:26.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap82:26.2":{"pli":"bhavā sabbe samūhatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:26.3":{"pli":"Sabbāsavā parikkhīṇā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:26.4":{"pli":"natthi dāni punabbhavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap82:27.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap82:27.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:27.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap82:28.1":{"pli":"Itthaṁ sudaṁ āyasmā tipadumiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap82:29.1":{"pli":"Tipadumiyattherassāpadānaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"tha-ap82:30.1":{"pli":"Nāgasamālavaggo aṭṭhamo. ","html":"<p class='endsection'>{}</p>"},"tha-ap82:31.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"tha-ap82:32.1":{"pli":"Nāgasamālo padasaññī, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"tha-ap82:32.2":{"pli":"saññakāluvadāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:32.3":{"pli":"Ekasaññī tiṇasanthāro, ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:32.4":{"pli":"sūcipāṭalipupphiyo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:32.5":{"pli":"Ṭhitañjalī tipadumī, ","html":"<span class='verse-line'>{}</span>"},"tha-ap82:32.6":{"pli":"gāthāyo pañcasattati. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"tha-ap83":{"tha-ap83:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap83'><header><ul><li class='division'>{}</li>"},"tha-ap83:0.2":{"pli":"Timiravagga ","html":"<li>{}</li></ul>"},"tha-ap83:0.3":{"pli":"Timirapupphiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap83:1.1":{"pli":"“Candabhāgānadītīre, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap83:1.2":{"pli":"anusotaṁ vajāmahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap83:1.3":{"pli":"Nisinnaṁ samaṇaṁ disvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap83:1.4":{"pli":"vippasannamanāvilaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap83:2.1":{"pli":"Tattha cittaṁ pasādetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap83:2.2":{"pli":"evaṁ cintesahaṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap83:2.3":{"pli":"Tārayissati tiṇṇoyaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap83:2.4":{"pli":"dantoyaṁ damayissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap83:3.1":{"pli":"Assāsissati assattho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap83:3.2":{"pli":"santo ca samayissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap83:3.3":{"pli":"Mocayissati mutto ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap83:3.4":{"pli":"nibbāpessati nibbuto. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap83:4.1":{"pli":"Evāhaṁ cintayitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap83:4.2":{"pli":"siddhatthassa mahesino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap83:4.3":{"pli":"Gahetvā timirapupphaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap83:4.4":{"pli":"matthake okiriṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap83:5.1":{"pli":"Añjaliṁ paggahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap83:5.2":{"pli":"katvā ca naṁ padakkhiṇaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap83:5.3":{"pli":"Vanditvā satthuno pāde, ","html":"<span class='verse-line'>{}</span>"},"tha-ap83:5.4":{"pli":"pakkāmiṁ aparaṁ disaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap83:6.1":{"pli":"Aciraṁ gatamattaṁ maṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap83:6.2":{"pli":"migarājā viheṭhayi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap83:6.3":{"pli":"Papātamanugacchanto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap83:6.4":{"pli":"tattheva papatiṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap83:7.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap83:7.2":{"pli":"yaṁ pupphamabhiropayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap83:7.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap83:7.4":{"pli":"pupphapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap83:8.1":{"pli":"Chappaññāsamhi kappamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap83:8.2":{"pli":"sattevāsuṁ mahāyasā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap83:8.3":{"pli":"Sattaratanasampannā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap83:8.4":{"pli":"cakkavattī mahabbalā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap83:9.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap83:9.2":{"pli":"vimokkhāpi ca aṭṭhime; ","html":"<span class='verse-line'>{}</span>"},"tha-ap83:9.3":{"pli":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap83:9.4":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap83:10.1":{"pli":"Itthaṁ sudaṁ āyasmā timirapupphiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap83:11.1":{"pli":"Timirapupphiyattherassāpadānaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap84":{"tha-ap84:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap84'><header><ul><li class='division'>{}</li>"},"tha-ap84:0.2":{"pli":"Timiravagga ","html":"<li>{}</li></ul>"},"tha-ap84:0.3":{"pli":"Gatasaññakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap84:1.1":{"pli":"“Jātiyā sattavassohaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap84:1.2":{"pli":"pabbajiṁ anagāriyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap84:1.3":{"pli":"Avandiṁ satthuno pāde, ","html":"<span class='verse-line'>{}</span>"},"tha-ap84:1.4":{"pli":"vippasannena cetasā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap84:2.1":{"pli":"Sattanaṅgalakīpupphe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap84:2.2":{"pli":"ākāse ukkhipiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap84:2.3":{"pli":"Tissaṁ buddhaṁ samuddissa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap84:2.4":{"pli":"anantaguṇasāgaraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap84:3.1":{"pli":"Sugatānugataṁ maggaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap84:3.2":{"pli":"pūjetvā haṭṭ