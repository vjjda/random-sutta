ass='verse-line'>{}</span>"},"tha-ap9:11.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap9:11.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap9:11.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap9:12.1":{"pli":"Tidasā so cavitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap9:12.2":{"pli":"manussattaṁ gamissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap9:12.3":{"pli":"Agārā pabbajitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap9:12.4":{"pli":"chabbassāni vasissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap9:13.1":{"pli":"‘Tato sattamake vasse, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap9:13.2":{"pli":"buddho saccaṁ kathessati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap9:13.3":{"pli":"Koṇḍañño nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap9:13.4":{"pli":"paṭhamaṁ sacchikāhiti’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap9:14.1":{"pli":"Nikkhantenānupabbajiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap9:14.2":{"pli":"padhānaṁ sukataṁ mayā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap9:14.3":{"pli":"Kilese jhāpanatthāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap9:14.4":{"pli":"pabbajiṁ anagāriyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap9:15.1":{"pli":"Abhigantvāna sabbaññū, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap9:15.2":{"pli":"buddho loke sadevake; ","html":"<span class='verse-line'>{}</span>"},"tha-ap9:15.3":{"pli":"Isināme migāraññe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap9:15.4":{"pli":"amatabherimāhani. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap9:16.1":{"pli":"So dāni patto amataṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap9:16.2":{"pli":"santipadamanuttaraṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-