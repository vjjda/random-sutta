":{"pli":"Therāpadāna ","html":"<article id='tha-ap88'><header><ul><li class='division'>{}</li>"},"tha-ap88:0.2":{"pli":"Timiravagga ","html":"<li>{}</li></ul>"},"tha-ap88:0.3":{"pli":"6 Dutiyaraṁsisaññakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap88:1.1":{"pli":"“Pabbate himavantamhi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap88:1.2":{"pli":"vākacīradharo ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap88:1.3":{"pli":"Caṅkamañca samārūḷho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap88:1.4":{"pli":"nisīdiṁ pācināmukho. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap88:2.1":{"pli":"Pabbate sugataṁ disvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap88:2.2":{"pli":"phussaṁ jhānarataṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap88:2.3":{"pli":"Añjaliṁ paggahetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap88:2.4":{"pli":"raṁsyā cittaṁ pasādayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap88:3.1":{"pli":"Dvenavute ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap88:3.2":{"pli":"yaṁ saññamalabhiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap88:3.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap88:3.4":{"pli":"raṁsisaññāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap88:4.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap88:4.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap88:4.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap88:5.1":{"pli":"Itthaṁ sudaṁ āyasmā raṁsisaññako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap88:6.1":{"pli":"Dutiyaraṁsisaññakattherassāpadānaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap89":{"tha-ap89:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap89'><header><ul><li class='division'>{}</li>"},"tha-ap89:0.2":{"pli":"Timiravagga ","html":"<li>{}</li></ul>"},"tha-ap89:0.3":{"pli":"Phaladāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap89:1.1":{"pli":"“Pabbate himavantamhi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap89:1.2":{"pli":"kharājinadharo ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap89:1.3":{"pli":"Phussaṁ jinavaraṁ disvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap89:1.4":{"pli":"phalahattho phalaṁ adaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap89:2.1":{"pli":"Yamahaṁ phalamadāsiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap89:2.2":{"pli":"vippasannena cetasā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap89:2.3":{"pli":"Bhave nibbattamānamhi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap89:2.4":{"pli":"phalaṁ nibbattate mama. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap89:3.1":{"pli":"Dvenavute ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap89:3.2":{"pli":"yaṁ phalaṁ adadiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap89:3.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap89:3.4":{"pli":"phaladānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap89:4.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap89:4.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap89:4.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap89:5.1":{"pli":"Itthaṁ sudaṁ āyasmā phaladāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap89:6.1":{"pli":"Phaladāyakattherassāpadānaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap9":{"tha-ap9:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap9'><header><ul><li class='division'>{}</li>"},"tha-ap9:0.2":{"pli":"Buddhavagga ","html":"<li>{}</li></ul>"},"tha-ap9:0.3":{"pli":"9 Aññāsikoṇḍaññattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap9:1.1":{"pli":"“Padumuttarasambuddhaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap9:1.2":{"pli":"lokajeṭṭhaṁ vināyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap9:1.3":{"pli":"Buddhabhūmimanuppattaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap9:1.4":{"pli":"paṭhamaṁ addasaṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap9:2.1":{"pli":"Yāvatā bodhiyā mūle, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap9:2.2":{"pli":"yakkhā sabbe samāgatā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap9:2.3":{"pli":"Sambuddhaṁ parivāretvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap9:2.4":{"pli":"vandanti pañjalīkatā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap9:3.1":{"pli":"Sabbe devā tuṭṭhamanā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap9:3.2":{"pli":"ākāse sañcaranti te; ","html":"<span class='verse-line'>{}</span>"},"tha-ap9:3.3":{"pli":"Buddho ayaṁ anuppatto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap9:3.4":{"pli":"andhakāratamonudo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap9:4.1":{"pli":"Tesaṁ hāsaparetānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap9:4.2":{"pli":"mahānādo avattatha; ","html":"<span class='verse-line'>{}</span>"},"tha-ap9:4.3":{"pli":"Kilese jhāpayissāma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap9:4.4":{"pli":"sammāsambuddhasāsane. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap9:5.1":{"pli":"Devānaṁ giramaññāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap9:5.2":{"pli":"vācāsabhimudīrihaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap9:5.3":{"pli":"Haṭṭho haṭṭhena cittena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap9:5.4":{"pli":"ādibhik