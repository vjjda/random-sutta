{"tha-ap406":{"tha-ap406:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap406'><header><ul><li class='division'>{}</li>"},"tha-ap406:0.2":{"pli":"Metteyyavagga ","html":"<li>{}</li></ul>"},"tha-ap406:0.3":{"pli":"Dhotakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap406:1.1":{"pli":"“Gaṅgā bhāgīrathī nāma, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap406:1.2":{"pli":"himavantā pabhāvitā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:1.3":{"pli":"Haṁsavatiyā dvārena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:1.4":{"pli":"anusandati tāvade. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap406:2.1":{"pli":"Sobhito nāma ārāmo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap406:2.2":{"pli":"gaṅgākūle sumāpito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:2.3":{"pli":"Tattha padumuttaro buddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:2.4":{"pli":"vasate lokanāyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap406:3.1":{"pli":"Tidasehi yathā indo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap406:3.2":{"pli":"manujehi purakkhato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:3.3":{"pli":"Nisīdi tattha bhagavā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:3.4":{"pli":"asambhītova kesarī. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap406:4.1":{"pli":"Nagare haṁsavatiyā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap406:4.2":{"pli":"vasāmi brāhmaṇo ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:4.3":{"pli":"Chaḷaṅgo nāma nāmena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:4.4":{"pli":"evaṁnāmo mahāmuni. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap406:5.1":{"pli":"Aṭṭhārasa sissasatā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap406:5.2":{"pli":"parivārenti maṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:5.3":{"pli":"Tehi sissehi samito, ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:5.4":{"pli":"gaṅgātīraṁ upāgamiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap406:6.1":{"pli":"Tatthaddasāsiṁ samaṇe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap406:6.2":{"pli":"nikkuhe dhotapāpake; ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:6.3":{"pli":"Bhāgīrathiṁ tarantehaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:6.4":{"pli":"evaṁ cintesi tāvade. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap406:7.1":{"pli":"‘Sāyaṁ pātaṁ tarantāme, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap406:7.2":{"pli":"buddhaputtā mahāyasā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:7.3":{"pli":"Vihesayanti attānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:7.4":{"pli":"tesaṁ attā vihaññati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap406:8.1":{"pli":"Sadevakassa lokassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap406:8.2":{"pli":"buddho aggo pavuccati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:8.3":{"pli":"Natthi me dakkhiṇe kāraṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:8.4":{"pli":"gatimaggavisodhanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap406:9.1":{"pli":"Yannūna buddhaseṭṭhassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap406:9.2":{"pli":"setuṁ gaṅgāya kāraye; ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:9.3":{"pli":"Kārāpetvā imaṁ kammaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:9.4":{"pli":"santarāmi imaṁ bhavaṁ’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap406:10.1":{"pli":"Satasahassaṁ datvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap406:10.2":{"pli":"setuṁ kārāpayiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:10.3":{"pli":"Saddahanto kataṁ kāraṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:10.4":{"pli":"vipulaṁ me bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap406:11.1":{"pli":"Kārāpetvāna taṁ setuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap406:11.2":{"pli":"upesiṁ lokanāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:11.3":{"pli":"Sirasi añjaliṁ katvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:11.4":{"pli":"imaṁ vacanamabraviṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap406:12.1":{"pli":"‘Satasahassassa vayaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap406:12.2":{"pli":"datvā kārāpito mayā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:12.3":{"pli":"Tavatthāya mahāsetu, ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:12.4":{"pli":"paṭiggaṇha mahāmune’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap406:13.1":{"pli":"Padumuttaro lokavidū, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap406:13.2":{"pli":"āhutīnaṁ paṭiggaho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:13.3":{"pli":"Bhikkhusaṅghe nisīditvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:13.4":{"pli":"imā gāthā abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap406:14.1":{"pli":"‘Yo me setuṁ akāresi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap406:14.2":{"pli":"pasanno sehi pāṇibhi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:14.3":{"pli":"Tamahaṁ kittayissāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:14.4":{"pli":"suṇātha mama bhāsato. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap406:15.0":{"pli":"4.1. Setudānaānisaṁsa ","html":"<h3>{}</h3>"},"tha-ap406:15.1":{"pli":"Darito pabbatato vā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap406:15.2":{"pli":"rukkhato patitopiyaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:15.3":{"pli":"Cutopi lacchatī ṭhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:15.4":{"pli":"setudānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap406:16.1":{"pli":"Virūḷhamūlasantānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap406:16.2":{"pli":"nigrodhamiva māluto; ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:16.3":{"pli":"Amittā nappasahanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:16.4":{"pli":"setudānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap406:17.1":{"pli":"Nāssa corā pasahanti, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap406:17.2":{"pli":"nātimaññanti khattiyā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:17.3":{"pli":"Sabbe tarissatāmitte, ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:17.4":{"pli":"setudānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap406:18.1":{"pli":"Abbhokāsagataṁ santaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap406:18.2":{"pli":"kaṭhinātapatāpitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:18.3":{"pli":"Puññakammena saṁyuttaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:18.4":{"pli":"na bhavissati vedanā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap406:19.1":{"pli":"Devaloke manusse vā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap406:19.2":{"pli":"hatthiyānaṁ sunimmitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:19.3":{"pli":"Tassa saṅkappamaññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:19.4":{"pli":"nibbattissati tāvade. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap406:20.1":{"pli":"Sahassassā vātajavā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap406:20.2":{"pli":"sindhavā sīghavāhanā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:20.3":{"pli":"Sāyaṁ pātaṁ upessanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:20.4":{"pli":"setudānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap406:21.1":{"pli":"Āgantvāna manussattaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap406:21.2":{"pli":"sukhitoyaṁ bhavissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:21.3":{"pli":"Vehāsaṁ manujasseva, ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:21.4":{"pli":"hatthiyānaṁ bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap406:22.1":{"pli":"Kappasatasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap406:22.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:22.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:22.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap406:23.1":{"pli":"Tassa dhammesu dāyādo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap406:23.2":{"pli":"oraso dhammanimmito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:23.3":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:23.4":{"pli":"nibbāyissatināsavo’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap406:24.1":{"pli":"Aho me sukataṁ kammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap406:24.2":{"pli":"jalajuttamanāmake; ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:24.3":{"pli":"Tattha kāraṁ karitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:24.4":{"pli":"pattohaṁ āsavakkhayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap406:25.1":{"pli":"Padhānaṁ pahitattomhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap406:25.2":{"pli":"upasanto nirūpadhi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:25.3":{"pli":"Nāgova bandhanaṁ chetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:25.4":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap406:26.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap406:26.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:26.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap406:27.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap406:27.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:27.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap406:28.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap406:28.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap406:28.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap406:29.1":{"pli":"Itthaṁ sudaṁ āyasmā dhotako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap406:30.1":{"pli":"Dhotakattherassāpadānaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap407":{"tha-ap407:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap407'><header><ul><li class='division'>{}</li>"},"tha-ap407:0.2":{"pli":"Metteyyavagga ","html":"<li>{}</li></ul>"},"tha-ap407:0.3":{"pli":"5 Upasivattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap407:1.1":{"pli":"“Himavantassāvidūre, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap407:1.2":{"pli":"anomo nāma pabbato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:1.3":{"pli":"Assamo sukato mayhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:1.4":{"pli":"paṇṇasālā sumāpitā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:2.1":{"pli":"Nadī ca sandatī tattha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:2.2":{"pli":"supatitthā manoramā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:2.3":{"pli":"Anūpatitthe jāyanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:2.4":{"pli":"padumuppalakā bahū. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:3.1":{"pli":"Pāṭhīnā pāvusā macchā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:3.2":{"pli":"balajā muñjarohitā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:3.3":{"pli":"Macchakacchapasañchannā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:3.4":{"pli":"nadikā sandate tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:4.1":{"pli":"Timirā pupphitā tattha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:4.2":{"pli":"asokā khuddamālakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:4.3":{"pli":"Punnāgā giripunnāgā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:4.4":{"pli":"sampavanti mamassamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:5.1":{"pli":"Kuṭajā pupphitā tattha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:5.2":{"pli":"tiṇasūlavanāni ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:5.3":{"pli":"Sālā ca saḷalā tattha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:5.4":{"pli":"campakā pupphitā bahū. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:6.1":{"pli":"Ajjunā atimuttā ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:6.2":{"pli":"mahānāmā ca pupphitā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:6.3":{"pli":"Asanā madhugandhī ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:6.4":{"pli":"pupphitā te mamassame. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:7.1":{"pli":"Uddālakā pāṭalikā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:7.2":{"pli":"yūthikā ca piyaṅgukā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:7.3":{"pli":"Bimbijālakasañchannā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:7.4":{"pli":"samantā aḍḍhayojanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:8.1":{"pli":"Mātaggārā sattaliyo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:8.2":{"pli":"pāṭalī sinduvārakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:8.3":{"pli":"Aṅkolakā bahū tattha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:8.4":{"pli":"tālakuṭṭhi ca pupphitā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:8.5":{"pli":"Seleyyakā bahū tattha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:8.6":{"pli":"pupphitā mama assame. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:9.1":{"pli":"Etesu pupphajātesu, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:9.2":{"pli":"sobhanti pādapā bahū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:9.3":{"pli":"Samantā tena gandhena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:9.4":{"pli":"vāyate mama assamo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:10.1":{"pli":"Harītakā āmalakā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:10.2":{"pli":"ambajambuvibhītakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:10.3":{"pli":"Kolā bhallātakā billā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:10.4":{"pli":"phārusakaphalāni ca. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:11.1":{"pli":"Tindukā ca piyālā ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:11.2":{"pli":"madhukā kāsumārayo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:11.3":{"pli":"Labujā panasā tattha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:11.4":{"pli":"kadalī badarīphalā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:12.1":{"pli":"Ambāṭakā bahū tattha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:12.2":{"pli":"vallikāraphalāni ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:12.3":{"pli":"Bījapūrasapāriyo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:12.4":{"pli":"phalitā mama assame. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:13.1":{"pli":"Āḷakā isimuggā ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:13.2":{"pli":"tato modaphalā bahū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:13.3":{"pli":"Avaṭā pakkabharitā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:13.4":{"pli":"pilakkhudumbarāni ca. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:14.1":{"pli":"Pipphalī marīcā tattha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:14.2":{"pli":"nigrodhā ca kapitthanā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:14.3":{"pli":"Udumbarakā bahavo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:14.4":{"pli":"kaṇḍupaṇṇā ca hariyo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:15.1":{"pli":"Ete caññe ca bahavo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:15.2":{"pli":"phalitā assame mama; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:15.3":{"pli":"Puppharukkhāpi bahavo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:15.4":{"pli":"pupphitā mama assame. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:16.1":{"pli":"Āluvā ca kaḷambā ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:16.2":{"pli":"biḷālī takkalāni ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:16.3":{"pli":"Ālakā tālakā ceva, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:16.4":{"pli":"vijjanti assame mama. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:17.1":{"pli":"Assamassāvidūre me, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:17.2":{"pli":"mahājātassaro ahu; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:17.3":{"pli":"Acchodako sītajalo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:17.4":{"pli":"supatittho manoramo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:18.1":{"pli":"Padumuppalā bahū tattha, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:18.2":{"pli":"puṇḍarīkasamāyutā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:18.3":{"pli":"Mandālakehi sañchannā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:18.4":{"pli":"nānāgandhasameritā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:19.1":{"pli":"Gabbhaṁ gaṇhanti padumā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:19.2":{"pli":"aññe pupphanti kesarī; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:19.3":{"pli":"Opupphapattā tiṭṭhanti, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:19.4":{"pli":"padumākaṇṇikā bahū. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:20.1":{"pli":"Madhu bhisamhā savati, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:20.2":{"pli":"khīraṁ sappi mulāḷibhi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:20.3":{"pli":"Samantā tena gandhena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:20.4":{"pli":"nānāgandhasameritā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:21.1":{"pli":"Kumudā ambagandhi ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:21.2":{"pli":"nayitā dissare bahū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:21.3":{"pli":"Jātassarassānukūlaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:21.4":{"pli":"ketakā pupphitā bahū. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:22.1":{"pli":"Suphullā bandhujīvā ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:22.2":{"pli":"setavārī sugandhikā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:22.3":{"pli":"Kumbhilā susumārā ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:22.4":{"pli":"gahakā tattha jāyare. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:23.1":{"pli":"Uggāhakā ajagarā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:23.2":{"pli":"tattha jātassare bahū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:23.3":{"pli":"Pāṭhīnā pāvusā macchā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:23.4":{"pli":"balajā muñjarohitā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:24.1":{"pli":"Macchakacchapasañchannā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:24.2":{"pli":"atho papaṭakāhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:24.3":{"pli":"Pārevatā ravihaṁsā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:24.4":{"pli":"kukutthā ca nadīcarā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:25.1":{"pli":"Dindibhā cakkavākā ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:25.2":{"pli":"pampakā jīvajīvakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:25.3":{"pli":"Kalandakā ukkusā ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:25.4":{"pli":"senakā uddharā bahū. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:26.1":{"pli":"Koṭṭhakā sukapotā ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:26.2":{"pli":"tuliyā camarā bahū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:26.3":{"pli":"Kāreniyo ca tilakā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:26.4":{"pli":"upajīvanti taṁ saraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:27.1":{"pli":"Sīhā byagghā ca dīpī ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:27.2":{"pli":"acchakokataracchakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:27.3":{"pli":"Vānarā kinnarā ceva, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:27.4":{"pli":"dissanti mama assame. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:28.1":{"pli":"Tāni gandhāni ghāyanto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:28.2":{"pli":"bhakkhayanto phalānahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:28.3":{"pli":"Gandhodakaṁ pivanto ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:28.4":{"pli":"vasāmi mama assame. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:29.1":{"pli":"Eṇīmigā varāhā ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:29.2":{"pli":"pasadā khuddarūpakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:29.3":{"pli":"Aggikā jotikā ceva, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:29.4":{"pli":"vasanti mama assame. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:30.1":{"pli":"Haṁsā koñcā mayūrā ca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:30.2":{"pli":"sālikāpi ca kokilā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:30.3":{"pli":"Majjārikā bahū tattha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:30.4":{"pli":"kosikā poṭṭhasīsakā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:31.1":{"pli":"Pisācā dānavā ceva, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:31.2":{"pli":"kumbhaṇḍā rakkhasā bahū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:31.3":{"pli":"Garuḷā pannagā ceva, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:31.4":{"pli":"vasanti mama assame. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:32.1":{"pli":"Mahānubhāvā isayo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:32.2":{"pli":"santacittā samāhitā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:32.3":{"pli":"Kamaṇḍaludharā sabbe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:32.4":{"pli":"ajinuttaravāsanā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:32.5":{"pli":"Jaṭābhārabharitāva, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:32.6":{"pli":"vasanti mama assame. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:33.1":{"pli":"Yugamattañca pekkhantā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:33.2":{"pli":"nipakā santavuttino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:33.3":{"pli":"Lābhālābhena santuṭṭhā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:33.4":{"pli":"vasanti mama assame. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:34.1":{"pli":"Vākacīraṁ dhunantā te, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:34.2":{"pli":"phoṭentājinacammakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:34.3":{"pli":"Sabalehi upatthaddhā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:34.4":{"pli":"gacchanti ambare tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:35.1":{"pli":"Na te dakaṁ āharanti, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:35.2":{"pli":"kaṭṭhaṁ vā aggidārukaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:35.3":{"pli":"Sayañca upasampannā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:35.4":{"pli":"pāṭihīrassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:36.1":{"pli":"Lohadoṇiṁ gahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:36.2":{"pli":"vanamajjhe vasanti te; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:36.3":{"pli":"Kuñjarāva mahānāgā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:36.4":{"pli":"asambhītāva kesarī. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:37.1":{"pli":"Aññe gacchanti goyānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:37.2":{"pli":"aññe pubbavidehakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:37.3":{"pli":"Aññe ca uttarakuruṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:37.4":{"pli":"sakaṁ balamavassitā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:38.1":{"pli":"Tato piṇḍaṁ āharitvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:38.2":{"pli":"paribhuñjanti ekato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:38.3":{"pli":"Sabbesaṁ pakkamantānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:38.4":{"pli":"uggatejāna tādinaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:39.1":{"pli":"Ajinacammasaddena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:39.2":{"pli":"vanaṁ saddāyate tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:39.3":{"pli":"Edisā te mahāvīra, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:39.4":{"pli":"sissā uggatapā mama. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:40.1":{"pli":"Parivuto ahaṁ tehi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:40.2":{"pli":"vasāmi mama assame; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:40.3":{"pli":"Tositā sakakammena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:40.4":{"pli":"vinītāpi samāgatā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:41.1":{"pli":"Ārādhayiṁsu maṁ ete, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:41.2":{"pli":"sakakammābhilāsino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:41.3":{"pli":"Sīlavanto ca nipakā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:41.4":{"pli":"appamaññāsu kovidā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:42.1":{"pli":"Padumuttaro lokavidū, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:42.2":{"pli":"āhutīnaṁ paṭiggaho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:42.3":{"pli":"Samayaṁ saṁviditvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:42.4":{"pli":"upagacchi vināyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:43.1":{"pli":"Upagantvāna sambuddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:43.2":{"pli":"ātāpī nipako muni; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:43.3":{"pli":"Pattaṁ paggayha sambuddho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:43.4":{"pli":"bhikkhāya mamupāgami. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:44.1":{"pli":"Upāgataṁ mahāvīraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:44.2":{"pli":"jalajuttamanāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:44.3":{"pli":"Tiṇasantharaṁ paññāpetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:44.4":{"pli":"sālapupphehi okiriṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:45.1":{"pli":"Nisādetvāna sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:45.2":{"pli":"haṭṭho saṁviggamānaso; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:45.3":{"pli":"Khippaṁ pabbatamāruyha, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:45.4":{"pli":"agaḷuṁ aggahiṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:46.1":{"pli":"Kumbhamattaṁ gahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:46.2":{"pli":"panasaṁ devagandhikaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:46.3":{"pli":"Khandhe āropayitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:46.4":{"pli":"upagacchiṁ vināyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:47.1":{"pli":"Phalaṁ buddhassa datvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:47.2":{"pli":"agaḷuṁ anulimpahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:47.3":{"pli":"Pasannacitto sumano, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:47.4":{"pli":"buddhaseṭṭhaṁ avandihaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:48.1":{"pli":"Padumuttaro lokavidū, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:48.2":{"pli":"āhutīnaṁ paṭiggaho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:48.3":{"pli":"Isimajjhe nisīditvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:48.4":{"pli":"imā gāthā abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:49.1":{"pli":"‘Yo me phalañca agaḷuṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:49.2":{"pli":"āsanañca adāsi me; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:49.3":{"pli":"Tamahaṁ kittayissāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:49.4":{"pli":"suṇātha mama bhāsato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:50.1":{"pli":"Gāme vā yadi vāraññe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:50.2":{"pli":"pabbhāresu guhāsu vā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:50.3":{"pli":"Imassa cittamaññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:50.4":{"pli":"nibbattissati bhojanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:51.1":{"pli":"Devaloke manusse vā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:51.2":{"pli":"upapanno ayaṁ naro; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:51.3":{"pli":"Bhojanehi ca vatthehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:51.4":{"pli":"parisaṁ tappayissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:52.1":{"pli":"Upapajjati yaṁ yoniṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:52.2":{"pli":"devattaṁ atha mānusaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:52.3":{"pli":"Akkhobhabhogo hutvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:52.4":{"pli":"saṁsarissatiyaṁ naro. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:53.1":{"pli":"Tiṁsakappasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:53.2":{"pli":"devaloke ramissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:53.3":{"pli":"Sahassakkhattuṁ rājā ca, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:53.4":{"pli":"cakkavattī bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:54.1":{"pli":"Ekasattatikkhattuñca, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:54.2":{"pli":"devarajjaṁ karissati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:54.3":{"pli":"Padesarajjaṁ vipulaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:54.4":{"pli":"gaṇanāto asaṅkhiyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:55.1":{"pli":"Kappasatasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:55.2":{"pli":"okkākakulasambhavo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:55.3":{"pli":"Gotamo nāma gottena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:55.4":{"pli":"satthā loke bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:56.1":{"pli":"Tassa dhammesu dāyādo, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:56.2":{"pli":"oraso dhammanimmito; ","html":"{}"},"tha-ap407:56.3":{"pli":"(…) ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:56.4":{"pli":"Sabbāsave pariññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:56.5":{"pli":"viharissatināsavo’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:57.1":{"pli":"Suladdhalābho laddho me, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:57.2":{"pli":"yohaṁ addakkhiṁ nāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:57.3":{"pli":"Tisso vijjā anuppattā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:57.4":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:58.1":{"pli":"Gāme vā yadi vāraññe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:58.2":{"pli":"pabbhāresu guhāsu vā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:58.3":{"pli":"Mama saṅkappamaññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:58.4":{"pli":"bhojanaṁ hoti me sadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:59.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:59.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:59.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:60.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:60.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:60.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap407:61.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap407:61.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap407:61.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap407:62.1":{"pli":"Itthaṁ sudaṁ āyasmā upasivo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap407:63.1":{"pli":"Upasivattherassāpadānaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap408":{"tha-ap408:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap408'><header><ul><li class='division'>{}</li>"},"tha-ap408:0.2":{"pli":"Metteyyavagga ","html":"<li>{}</li></ul>"},"tha-ap408:0.3":{"pli":"Nandakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap408:1.1":{"pli":"“Migaluddo pure āsiṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap408:1.2":{"pli":"Araññe kānane ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:1.3":{"pli":"Pasadaṁ migamesanto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:1.4":{"pli":"Sayambhuṁ addasaṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap408:2.1":{"pli":"Anuruddho nāma sambuddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap408:2.2":{"pli":"sayambhū aparājito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:2.3":{"pli":"Vivekakāmo so dhīro, ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:2.4":{"pli":"vanamajjhogahī tadā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap408:3.1":{"pli":"Catudaṇḍe gahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap408:3.2":{"pli":"catuṭṭhāne ṭhapesahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:3.3":{"pli":"Maṇḍapaṁ sukataṁ katvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:3.4":{"pli":"padmapupphehi chādayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap408:4.1":{"pli":"Maṇḍapaṁ chādayitvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap408:4.2":{"pli":"sayambhuṁ abhivādayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:4.3":{"pli":"Dhanuṁ tattheva nikkhippa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:4.4":{"pli":"pabbajiṁ anagāriyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap408:5.1":{"pli":"Naciraṁ pabbajitassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap408:5.2":{"pli":"byādhi me udapajjatha; ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:5.3":{"pli":"Pubbakammaṁ saritvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:5.4":{"pli":"tattha kālaṅkato ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap408:6.1":{"pli":"Pubbakammena saṁyutto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap408:6.2":{"pli":"tusitaṁ agamāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:6.3":{"pli":"Tattha soṇṇamayaṁ byamhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:6.4":{"pli":"nibbattati yadicchakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap408:7.1":{"pli":"Sahassayuttaṁ hayavāhiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap408:7.2":{"pli":"dibbayānamadhiṭṭhito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:7.3":{"pli":"Āruhitvāna taṁ yānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:7.4":{"pli":"gacchāmahaṁ yadicchakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap408:8.1":{"pli":"Tato me niyyamānassa, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap408:8.2":{"pli":"devabhūtassa me sato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:8.3":{"pli":"Samantā yojanasataṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:8.4":{"pli":"maṇḍapo me dharīyati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap408:9.1":{"pli":"Sayanehaṁ tuvaṭṭāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap408:9.2":{"pli":"acchanne pupphasanthate; ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:9.3":{"pli":"Antalikkhā ca padumā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:9.4":{"pli":"vassante niccakālikaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap408:10.1":{"pli":"Marīcike phandamāne, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap408:10.2":{"pli":"tappamāne ca ātape; ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:10.3":{"pli":"Na maṁ tāpeti ātāpo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:10.4":{"pli":"maṇḍapassa idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap408:11.1":{"pli":"Duggatiṁ samatikkanto, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap408:11.2":{"pli":"apāyā pihitā mama; ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:11.3":{"pli":"Maṇḍape rukkhamūle vā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:11.4":{"pli":"santāpo me na vijjati. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap408:12.1":{"pli":"Mahīsaññaṁ adhiṭṭhāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap408:12.2":{"pli":"loṇatoyaṁ tarāmahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:12.3":{"pli":"Tassa me sukataṁ kammaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:12.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap408:13.1":{"pli":"Apathampi pathaṁ katvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap408:13.2":{"pli":"gacchāmi anilañjase; ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:13.3":{"pli":"Aho me sukataṁ kammaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:13.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap408:14.1":{"pli":"Pubbenivāsaṁ jānāmi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap408:14.2":{"pli":"dibbacakkhu visodhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:14.3":{"pli":"Āsavā me parikkhīṇā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:14.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap408:15.1":{"pli":"Jahitā purimā jāti, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap408:15.2":{"pli":"buddhassa oraso ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:15.3":{"pli":"Dāyādomhi ca saddhamme, ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:15.4":{"pli":"buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap408:16.1":{"pli":"Ārādhitomhi sugataṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap408:16.2":{"pli":"Gotamaṁ sakyapuṅgavaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:16.3":{"pli":"Dhammadhajo dhammadāyādo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:16.4":{"pli":"Buddhapūjāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap408:17.1":{"pli":"Upaṭṭhitvāna sambuddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap408:17.2":{"pli":"gotamaṁ sakyapuṅgavaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:17.3":{"pli":"Pāraṅgamaniyaṁ maggaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:17.4":{"pli":"apucchiṁ lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap408:18.1":{"pli":"Ajjhiṭṭho kathayī buddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap408:18.2":{"pli":"gambhīraṁ nipuṇaṁ padaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:18.3":{"pli":"Tassāhaṁ dhammaṁ sutvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:18.4":{"pli":"pattomhi āsavakkhayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap408:19.1":{"pli":"Aho me sukataṁ kammaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap408:19.2":{"pli":"parimuttomhi jātiyā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:19.3":{"pli":"Sabbāsavaparikkhīṇo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:19.4":{"pli":"natthi dāni punabbhavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap408:20.1":{"pli":"Kilesā jhāpitā mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap408:20.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:20.3":{"pli":"viharāmi anāsavo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap408:21.1":{"pli":"Svāgataṁ vata me āsi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap408:21.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:21.3":{"pli":"kataṁ buddhassa sāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap408:22.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap408:22.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap408:22.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap408:23.1":{"pli":"Itthaṁ sudaṁ āyasmā nandako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap408:24.1":{"pli":"Nandakattherassāpadānaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}