{"ja488":{"ja488:0.1":{"pli":"Jātaka ","html":"<article id='ja488'><header><ul><li class='division'>{}</li>"},"ja488:0.2":{"pli":"Pakiṇṇakanipāta ","html":"<li>{}</li>"},"ja488:0.3":{"pli":"Sālikedāravagga ","html":"<li>{}</li></ul>"},"ja488:0.4":{"pli":"5. Bhisajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja488:1.1":{"pli":"“Assaṁ gavaṁ rajataṁ jātarūpaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja488:1.2":{"pli":"Bhariyañca so idha labhataṁ manāpaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja488:1.3":{"pli":"Puttehi dārehi samaṅgi hotu, ","html":"<span class='verse-line'>{}</span>"},"ja488:1.4":{"pli":"Bhisāni te brāhmaṇa yo ahāsi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja488:2.1":{"pli":"“Mālañca so kāsikacandanañca, ","html":"<p><span class='verse-line'>{}</span>"},"ja488:2.2":{"pli":"Dhāretu puttassa bahū bhavantu; ","html":"<span class='verse-line'>{}</span>"},"ja488:2.3":{"pli":"Kāmesu tibbaṁ kurutaṁ apekkhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja488:2.4":{"pli":"Bhisāni te brāhmaṇa yo ahāsi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja488:3.1":{"pli":"“Pahūtadhañño kasimā yasassī, ","html":"<p><span class='verse-line'>{}</span>"},"ja488:3.2":{"pli":"Putte gihī dhanimā sabbakāme; ","html":"<span class='verse-line'>{}</span>"},"ja488:3.3":{"pli":"Vayaṁ apassaṁ gharamāvasātu, ","html":"<span class='verse-line'>{}</span>"},"ja488:3.4":{"pli":"Bhisāni te brāhmaṇa yo ahāsi. ","html":"<span class='verse-line'>{}</span></p>"},"ja488:4.1":{"pli":"So khattiyo hotu pasayhakārī, ","html":"<p><span class='verse-line'>{}</span>"},"ja488:4.2":{"pli":"Rājābhirājā balavā yasassī; ","html":"<span class='verse-line'>{}</span>"},"ja488:4.3":{"pli":"Sa cāturantaṁ mahimāvasātu, ","html":"<span class='verse-line'>{}</span>"},"ja488:4.4":{"pli":"Bhisāni te brāhmaṇa yo ahāsi. ","html":"<span class='verse-line'>{}</span></p>"},"ja488:5.1":{"pli":"So brāhmaṇo hotu avītarāgo, ","html":"<p><span class='verse-line'>{}</span>"},"ja488:5.2":{"pli":"Muhuttanakkhattapathesu yutto; ","html":"<span class='verse-line'>{}</span>"},"ja488:5.3":{"pli":"Pūjetu naṁ raṭṭhapatī yasassī, ","html":"<span class='verse-line'>{}</span>"},"ja488:5.4":{"pli":"Bhisāni te brāhmaṇa yo ahāsi. ","html":"<span class='verse-line'>{}</span></p>"},"ja488:6.1":{"pli":"Ajjhāyakaṁ sabbasamantavedaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja488:6.2":{"pli":"Tapassīnaṁ maññatu sabbaloko; ","html":"<span class='verse-line'>{}</span>"},"ja488:6.3":{"pli":"Pūjentu naṁ jānapadā samecca, ","html":"<span class='verse-line'>{}</span>"},"ja488:6.4":{"pli":"Bhisāni te brāhmaṇa yo ahāsi. ","html":"<span class='verse-line'>{}</span></p>"},"ja488:7.1":{"pli":"Catussadaṁ gāmavaraṁ samiddhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja488:7.2":{"pli":"Dinnañhi so bhuñjatu vāsavena; ","html":"<span class='verse-line'>{}</span>"},"ja488:7.3":{"pli":"Avītarāgo maraṇaṁ upetu, ","html":"<span class='verse-line'>{}</span>"},"ja488:7.4":{"pli":"Bhisāni te brāhmaṇa yo ahāsi. ","html":"<span class='verse-line'>{}</span></p>"},"ja488:8.1":{"pli":"So gāmaṇī hotu sahāyamajjhe, ","html":"<p><span class='verse-line'>{}</span>"},"ja488:8.2":{"pli":"Naccehi gītehi pamodamāno; ","html":"<span class='verse-line'>{}</span>"},"ja488:8.3":{"pli":"So rājato byasana mālattha kiñci, ","html":"<span class='verse-line'>{}</span>"},"ja488:8.4":{"pli":"Bhisāni te brāhmaṇa yo ahāsi. ","html":"<span class='verse-line'>{}</span></p>"},"ja488:9.1":{"pli":"Yaṁ ekarājā pathaviṁ vijetvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja488:9.2":{"pli":"Itthīsahassāna ṭhapetu aggaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja488:9.3":{"pli":"Sīmantinīnaṁ pavarā bhavātu, ","html":"<span class='verse-line'>{}</span>"},"ja488:9.4":{"pli":"Bhisāni te brāhmaṇa yā ahāsi. ","html":"<span class='verse-line'>{}</span></p>"},"ja488:10.1":{"pli":"Isīnañhi sā sabbasamāgatānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja488:10.2":{"pli":"Bhuñjeyya sāduṁ avikampamānā; ","html":"<span class='verse-line'>{}</span>"},"ja488:10.3":{"pli":"Carātu lābhena vikatthamānā, ","html":"<span class='verse-line'>{}</span>"},"ja488:10.4":{"pli":"Bhisāni te brāhmaṇa yā ahāsi. ","html":"<span class='verse-line'>{}</span></p>"},"ja488:11.1":{"pli":"Āvāsiko hotu mahāvihāre, ","html":"<p><span class='verse-line'>{}</span>"},"ja488:11.2":{"pli":"Navakammiko hotu gajaṅgalāyaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja488:11.3":{"pli":"Ālokasandhiṁ divasaṁ karotu, ","html":"<span class='verse-line'>{}</span>"},"ja488:11.4":{"pli":"Bhisāni te brāhmaṇa yo ahāsi. ","html":"<span class='verse-line'>{}</span></p>"},"ja488:12.1":{"pli":"So bajjhatū pāsasatehi chabbhi, ","html":"<p><span class='verse-line'>{}</span>"},"ja488:12.2":{"pli":"Rammā vanā niyyatu rājadhāniṁ; ","html":"<span class='verse-line'>{}</span>"},"ja488:12.3":{"pli":"Tuttehi so haññatu pācanehi, ","html":"<span class='verse-line'>{}</span>"},"ja488:12.4":{"pli":"Bhisāni te brāhmaṇa yo ahāsi. ","html":"<span class='verse-line'>{}</span></p>"},"ja488:13.1":{"pli":"Alakkamālī tipukaṇṇaviddho, ","html":"<p><span class='verse-line'>{}</span>"},"ja488:13.2":{"pli":"Laṭṭhīhato sappamukhaṁ upetu; ","html":"<span class='verse-line'>{}</span>"},"ja488:13.3":{"pli":"Sakacchabandho visikhaṁ carātu, ","html":"<span class='verse-line'>{}</span>"},"ja488:13.4":{"pli":"Bhisāni te brāhmaṇa yo ahāsi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja488:14.1":{"pli":"“Yo ve anaṭṭhaṁva naṭṭhanti cāha, ","html":"<p><span class='verse-line'>{}</span>"},"ja488:14.2":{"pli":"Kāmeva so labhataṁ bhuñjatañca; ","html":"<span class='verse-line'>{}</span>"},"ja488:14.3":{"pli":"Agāramajjhe maraṇaṁ upetu, ","html":"<span class='verse-line'>{}</span>"},"ja488:14.4":{"pli":"Yo vā bhonto saṅkati kañcideva”. ","html":"<span class='verse-line'>{}</span></p>"},"ja488:15.1":{"pli":"“Yadesamānā vicaranti loke, ","html":"<p><span class='verse-line'>{}</span>"},"ja488:15.2":{"pli":"Iṭṭhañca kantañca bahūnametaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja488:15.3":{"pli":"Piyaṁ manuññaṁ cidha jīvaloke, ","html":"<span class='verse-line'>{}</span>"},"ja488:15.4":{"pli":"Kasmā isayo nappasaṁsanti kāme”. ","html":"<span class='verse-line'>{}</span></p>"},"ja488:16.1":{"pli":"“Kāmesu ve haññare bajjhare ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja488:16.2":{"pli":"Kāmesu dukkhañca bhayañca jātaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja488:16.3":{"pli":"Kāmesu bhūtādhipatī pamattā, ","html":"<span class='verse-line'>{}</span>"},"ja488:16.4":{"pli":"Pāpāni kammāni karonti mohā. ","html":"<span class='verse-line'>{}</span></p>"},"ja488:17.1":{"pli":"Te pāpadhammā pasavetva pāpaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja488:17.2":{"pli":"Kāyassa bhedā nirayaṁ vajanti; ","html":"<span class='verse-line'>{}</span>"},"ja488:17.3":{"pli":"Ādīnavaṁ kāmaguṇesu disvā, ","html":"<span class='verse-line'>{}</span>"},"ja488:17.4":{"pli":"Tasmā isayo nappasaṁsanti kāme”. ","html":"<span class='verse-line'>{}</span></p>"},"ja488:18.1":{"pli":"“Vīmaṁsamāno isino bhisāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja488:18.2":{"pli":"Tīre gahetvāna thale nidhesiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja488:18.3":{"pli":"Suddhā apāpā isayo vasanti, ","html":"<span class='verse-line'>{}</span>"},"ja488:18.4":{"pli":"Etāni te brahmacārī bhisāni”. ","html":"<span class='verse-line'>{}</span></p>"},"ja488:19.1":{"pli":"“Na te naṭā no pana kīḷaneyyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja488:19.2":{"pli":"Na bandhavā no pana te sahāyā; ","html":"<span class='verse-line'>{}</span>"},"ja488:19.3":{"pli":"Kismiṁ vupatthambha sahassanetta, ","html":"<span class='verse-line'>{}</span>"},"ja488:19.4":{"pli":"Isīhi tvaṁ kīḷasi devarāja”. ","html":"<span class='verse-line'>{}</span></p>"},"ja488:20.1":{"pli":"“Ācariyo mesi pitā ca mayhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja488:20.2":{"pli":"Esā patiṭṭhā khalitassa brahme; ","html":"<span class='verse-line'>{}</span>"},"ja488:20.3":{"pli":"Ekāparādhaṁ khama bhūripañña, ","html":"<span class='verse-line'>{}</span>"},"ja488:20.4":{"pli":"Na paṇḍitā kodhabalā bhavanti”. ","html":"<span class='verse-line'>{}</span></p>"},"ja488:21.1":{"pli":"“Suvāsitaṁ isinaṁ ekarattaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja488:21.2":{"pli":"Yaṁ vāsavaṁ bhūtapatiddasāma; ","html":"<span class='verse-line'>{}</span>"},"ja488:21.3":{"pli":"Sabbeva bhonto sumanā bhavantu, ","html":"<span class='verse-line'>{}</span>"},"ja488:21.4":{"pli":"Yaṁ brāhmaṇo paccupādī bhisāni”. ","html":"<span class='verse-line'>{}</span></p>"},"ja488:22.1":{"pli":"“Ahañca sāriputto ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja488:22.2":{"pli":"moggallāno ca kassapo; ","html":"<span class='verse-line'>{}</span>"},"ja488:22.3":{"pli":"Anuruddho puṇṇo ānando, ","html":"<span class='verse-line'>{}</span>"},"ja488:22.4":{"pli":"tadāsuṁ satta bhātaro. ","html":"<span class='verse-line'>{}</span></p>"},"ja488:23.1":{"pli":"Bhaginī uppalavaṇṇā ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja488:23.2":{"pli":"dāsī khujjuttarā tadā; ","html":"<span class='verse-line'>{}</span>"},"ja488:23.3":{"pli":"Citto gahapati dāso, ","html":"<span class='verse-line'>{}</span>"},"ja488:23.4":{"pli":"yakkho sātāgiro tadā. ","html":"<span class='verse-line'>{}</span></p>"},"ja488:24.1":{"pli":"Pālileyyo tadā nāgo, ","html":"<p><span class='verse-line'>{}</span>"},"ja488:24.2":{"pli":"madhudo seṭṭhavānaro; ","html":"<span class='verse-line'>{}</span>"},"ja488:24.3":{"pli":"Kāḷudāyī tadā sakko, ","html":"<span class='verse-line'>{}</span>"},"ja488:24.4":{"pli":"evaṁ dhāretha jātakanti”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja488:25.1":{"pli":"Bhisajātakaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja489":{"ja489:0.1":{"pli":"Jātaka ","html":"<article id='ja489'><header><ul><li class='division'>{}</li>"},"ja489:0.2":{"pli":"Pakiṇṇakanipāta ","html":"<li>{}</li>"},"ja489:0.3":{"pli":"Sālikedāravagga ","html":"<li>{}</li></ul>"},"ja489:0.4":{"pli":"6. Surucijātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja489:1.1":{"pli":"“Mahesī surucino bhariyā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja489:1.2":{"pli":"Ānītā paṭhamaṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja489:1.3":{"pli":"Dasa vassasahassāni, ","html":"<span class='verse-line'>{}</span>"},"ja489:1.4":{"pli":"Yaṁ maṁ surucimānayi. ","html":"<span class='verse-line'>{}</span></p>"},"ja489:2.1":{"pli":"Sāhaṁ brāhmaṇa rājānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja489:2.2":{"pli":"vedehaṁ mithilaggahaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja489:2.3":{"pli":"Nābhijānāmi kāyena, ","html":"<span class='verse-line'>{}</span>"},"ja489:2.4":{"pli":"vācāya uda cetasā; ","html":"<span class='verse-line'>{}</span>"},"ja489:2.5":{"pli":"Suruciṁ atimaññittha, ","html":"<span class='verse-line'>{}</span>"},"ja489:2.6":{"pli":"āvi vā yadi vā raho. ","html":"<span class='verse-line'>{}</span></p>"},"ja489:3.1":{"pli":"Etena saccavajjena, ","html":"<p data-counter='11'><span class='verse-line'>{}</span>"},"ja489:3.2":{"pli":"putto uppajjataṁ ise; ","html":"<span class='verse-line'>{}</span>"},"ja489:3.3":{"pli":"Musā me bhaṇamānāya, ","html":"<span class='verse-line'>{}</span>"},"ja489:3.4":{"pli":"muddhā phalatu sattadhā. ","html":"<span class='verse-line'>{}</span></p>"},"ja489:4.1":{"pli":"Bhattu mama sassu mātā, ","html":"<p><span class='verse-line'>{}</span>"},"ja489:4.2":{"pli":"pitā cāpi ca sassuro; ","html":"<span class='verse-line'>{}</span>"},"ja489:4.3":{"pli":"Te maṁ brahme vinetāro, ","html":"<span class='verse-line'>{}</span>"},"ja489:4.4":{"pli":"yāva aṭṭhaṁsu jīvitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja489:5.1":{"pli":"Sāhaṁ ahiṁsāratinī, ","html":"<p><span class='verse-line'>{}</span>"},"ja489:5.2":{"pli":"kāmasā dhammacārinī; ","html":"<span class='verse-line'>{}</span>"},"ja489:5.3":{"pli":"Sakkaccaṁ te upaṭṭhāsiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja489:5.4":{"pli":"rattindivamatanditā. ","html":"<span class='verse-line'>{}</span></p>"},"ja489:6.1":{"pli":"Etena saccavajjena, ","html":"<p data-counter='21'><span class='verse-line'>{}</span>"},"ja489:6.2":{"pli":"putto uppajjataṁ ise; ","html":"<span class='verse-line'>{}</span>"},"ja489:6.3":{"pli":"Musā me bhaṇamānāya, ","html":"<span class='verse-line'>{}</span>"},"ja489:6.4":{"pli":"muddhā phalatu sattadhā. ","html":"<span class='verse-line'>{}</span></p>"},"ja489:7.1":{"pli":"Soḷasitthisahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja489:7.2":{"pli":"sahabhariyāni brāhmaṇa; ","html":"<span class='verse-line'>{}</span>"},"ja489:7.3":{"pli":"Tāsu issā vā kodho vā, ","html":"<span class='verse-line'>{}</span>"},"ja489:7.4":{"pli":"nāhu mayhaṁ kudācanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja489:8.1":{"pli":"Hitena tāsaṁ nandāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja489:8.2":{"pli":"na ca me kāci appiyā; ","html":"<span class='verse-line'>{}</span>"},"ja489:8.3":{"pli":"Attānaṁvānukampāmi, ","html":"<span class='verse-line'>{}</span>"},"ja489:8.4":{"pli":"sadā sabbā sapattiyo. ","html":"<span class='verse-line'>{}</span></p>"},"ja489:9.1":{"pli":"Etena saccavajjena, ","html":"<p data-counter='31'><span class='verse-line'>{}</span>"},"ja489:9.2":{"pli":"putto uppajjataṁ ise; ","html":"<span class='verse-line'>{}</span>"},"ja489:9.3":{"pli":"Musā me bhaṇamānāya, ","html":"<span class='verse-line'>{}</span>"},"ja489:9.4":{"pli":"muddhā phalatu sattadhā. ","html":"<span class='verse-line'>{}</span></p>"},"ja489:10.1":{"pli":"Dāse kammakare pesse, ","html":"<p><span class='verse-line'>{}</span>"},"ja489:10.2":{"pli":"ye caññe anujīvino; ","html":"<span class='verse-line'>{}</span>"},"ja489:10.3":{"pli":"Pesemi sahadhammena, ","html":"<span class='verse-line'>{}</span>"},"ja489:10.4":{"pli":"sadā pamuditindriyā. ","html":"<span class='verse-line'>{}</span></p>"},"ja489:11.1":{"pli":"Etena saccavajjena, ","html":"<p data-counter='41'><span class='verse-line'>{}</span>"},"ja489:11.2":{"pli":"putto uppajjataṁ ise; ","html":"<span class='verse-line'>{}</span>"},"ja489:11.3":{"pli":"Musā me bhaṇamānāya, ","html":"<span class='verse-line'>{}</span>"},"ja489:11.4":{"pli":"muddhā phalatu sattadhā. ","html":"<span class='verse-line'>{}</span></p>"},"ja489:12.1":{"pli":"Samaṇe brāhmaṇe cāpi, ","html":"<p><span class='verse-line'>{}</span>"},"ja489:12.2":{"pli":"aññe cāpi vanibbake; ","html":"<span class='verse-line'>{}</span>"},"ja489:12.3":{"pli":"Tappemi annapānena, ","html":"<span class='verse-line'>{}</span>"},"ja489:12.4":{"pli":"sadā payatapāṇinī. ","html":"<span class='verse-line'>{}</span></p>"},"ja489:13.1":{"pli":"Etena saccavajjena, ","html":"<p data-counter='51'><span class='verse-line'>{}</span>"},"ja489:13.2":{"pli":"putto uppajjataṁ ise; ","html":"<span class='verse-line'>{}</span>"},"ja489:13.3":{"pli":"Musā me bhaṇamānāya, ","html":"<span class='verse-line'>{}</span>"},"ja489:13.4":{"pli":"muddhā phalatu sattadhā. ","html":"<span class='verse-line'>{}</span></p>"},"ja489:14.1":{"pli":"Cātuddasiṁ pañcaddasiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja489:14.2":{"pli":"Yā ca pakkhassa aṭṭhamī; ","html":"<span class='verse-line'>{}</span>"},"ja489:14.3":{"pli":"Pāṭihāriyapakkhañca, ","html":"<span class='verse-line'>{}</span>"},"ja489:14.4":{"pli":"Aṭṭhaṅgasusamāgataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja489:14.5":{"pli":"Uposathaṁ upavasāmi, ","html":"<span class='verse-line'>{}</span>"},"ja489:14.6":{"pli":"Sadā sīlesu saṁvutā. ","html":"<span class='verse-line'>{}</span></p>"},"ja489:15.1":{"pli":"Etena saccavajjena, ","html":"<p data-counter='61'><span class='verse-line'>{}</span>"},"ja489:15.2":{"pli":"putto uppajjataṁ ise; ","html":"<span class='verse-line'>{}</span>"},"ja489:15.3":{"pli":"Musā me bhaṇamānāya, ","html":"<span class='verse-line'>{}</span>"},"ja489:15.4":{"pli":"muddhā phalatu sattadhā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja489:16.1":{"pli":"“Sabbeva te dhammaguṇā, ","html":"<p><span class='verse-line'>{}</span>"},"ja489:16.2":{"pli":"rājaputti yasassini; ","html":"<span class='verse-line'>{}</span>"},"ja489:16.3":{"pli":"Saṁvijjanti tayi bhadde, ","html":"<span class='verse-line'>{}</span>"},"ja489:16.4":{"pli":"ye tvaṁ kittesi attani. ","html":"<span class='verse-line'>{}</span></p>"},"ja489:17.1":{"pli":"Khattiyo jātisampanno, ","html":"<p><span class='verse-line'>{}</span>"},"ja489:17.2":{"pli":"abhijāto yasassimā; ","html":"<span class='verse-line'>{}</span>"},"ja489:17.3":{"pli":"Dhammarājā videhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja489:17.4":{"pli":"putto uppajjate tava”. ","html":"<span class='verse-line'>{}</span></p>"},"ja489:18.1":{"pli":"“Dummī rajojalladharo, ","html":"<p><span class='verse-line'>{}</span>"},"ja489:18.2":{"pli":"aghe vehāyasaṁ ṭhito; ","html":"<span class='verse-line'>{}</span>"},"ja489:18.3":{"pli":"Manuññaṁ bhāsase vācaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja489:18.4":{"pli":"yaṁ mayhaṁ hadayaṅgamaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja489:19.1":{"pli":"Devatānusi saggamhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja489:19.2":{"pli":"isi vāsi mahiddhiko; ","html":"<span class='verse-line'>{}</span>"},"ja489:19.3":{"pli":"Ko vāsi tvaṁ anuppatto, ","html":"<span class='verse-line'>{}</span>"},"ja489:19.4":{"pli":"attānaṁ me pavedaya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja489:20.1":{"pli":"“Yaṁ devasaṅghā vandanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja489:20.2":{"pli":"sudhammāyaṁ samāgatā; ","html":"<span class='verse-line'>{}</span>"},"ja489:20.3":{"pli":"Sohaṁ sakko sahassakkho, ","html":"<span class='verse-line'>{}</span>"},"ja489:20.4":{"pli":"āgatosmi tavantike. ","html":"<span class='verse-line'>{}</span></p>"},"ja489:21.1":{"pli":"Itthiyo jīvalokasmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja489:21.2":{"pli":"yā hoti samacārinī; ","html":"<span class='verse-line'>{}</span>"},"ja489:21.3":{"pli":"Medhāvinī sīlavatī, ","html":"<span class='verse-line'>{}</span>"},"ja489:21.4":{"pli":"sassudevā patibbatā. ","html":"<span class='verse-line'>{}</span></p>"},"ja489:22.1":{"pli":"Tādisāya sumedhāya, ","html":"<p><span class='verse-line'>{}</span>"},"ja489:22.2":{"pli":"sucikammāya nāriyā; ","html":"<span class='verse-line'>{}</span>"},"ja489:22.3":{"pli":"Devā dassanamāyanti, ","html":"<span class='verse-line'>{}</span>"},"ja489:22.4":{"pli":"mānusiyā amānusā. ","html":"<span class='verse-line'>{}</span></p>"},"ja489:23.1":{"pli":"Tvañca bhadde suciṇṇena, ","html":"<p><span class='verse-line'>{}</span>"},"ja489:23.2":{"pli":"pubbe sucaritena ca; ","html":"<span class='verse-line'>{}</span>"},"ja489:23.3":{"pli":"Idha rājakule jātā, ","html":"<span class='verse-line'>{}</span>"},"ja489:23.4":{"pli":"sabbakāmasamiddhinī. ","html":"<span class='verse-line'>{}</span></p>"},"ja489:24.1":{"pli":"Ayañca te rājaputti, ","html":"<p><span class='verse-line'>{}</span>"},"ja489:24.2":{"pli":"ubhayattha kaṭaggaho; ","html":"<span class='verse-line'>{}</span>"},"ja489:24.3":{"pli":"Devalokūpapattī ca, ","html":"<span class='verse-line'>{}</span>"},"ja489:24.4":{"pli":"kittī ca idha jīvite. ","html":"<span class='verse-line'>{}</span></p>"},"ja489:25.1":{"pli":"Ciraṁ sumedhe sukhinī, ","html":"<p><span class='verse-line'>{}</span>"},"ja489:25.2":{"pli":"dhammamattani pālaya; ","html":"<span class='verse-line'>{}</span>"},"ja489:25.3":{"pli":"Esāhaṁ tidivaṁ yāmi, ","html":"<span class='verse-line'>{}</span>"},"ja489:25.4":{"pli":"piyaṁ me tava dassanan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja489:26.1":{"pli":"Surucijātakaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja49":{"ja49:0.1":{"pli":"Jātaka ","eng":"Stories of Past Lives 49 ","html":"<article id='ja49'><header><ul><li class='division'>{}</li>"},"ja49:0.2":{"pli":"Ekakanipāta ","eng":"The Book of the Ones ","html":"<li>{}</li>"},"ja49:0.3":{"pli":"Atthakāmavagga ","eng":"Wanting to Help ","html":"<li>{}</li></ul>"},"ja49:0.4":{"pli":"9. Nakkhattajātaka ","eng":"Constellations: a past life story ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja49:1.1":{"pli":"Nakkhattaṁ paṭimānentaṁ, ","eng":"Waiting for a constellation, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>","comm":"A family reneges on its marriage date when told it falls under an unlucky constellation, so the girl marries someone else. "},"ja49:1.2":{"pli":"attho bālaṁ upaccagā; ","eng":"a fool lets the good pass them by. ","html":"<span class='verse-line'>{}</span>"},"ja49:1.3":{"pli":"Attho atthassa nakkhattaṁ, ","eng":"The good is the constellation of the good; ","html":"<span class='verse-line'>{}</span>"},"ja49:1.4":{"pli":"kiṁ karissanti tārakā”ti. ","eng":"for what do the stars matter? ","html":"<span class='verse-line'>{}</span></p></blockquote>","comm":"Compare “what do the hymns matter?” at <a href='index.html?q=dn4#15.5'>DN 4:15.5</a>. "},"ja49:2.1":{"pli":"Nakkhattajātakaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja490":{"ja490:0.1":{"pli":"Jātaka ","html":"<article id='ja490'><header><ul><li class='division'>{}</li>"},"ja490:0.2":{"pli":"Pakiṇṇakanipāta ","html":"<li>{}</li>"},"ja490:0.3":{"pli":"Sālikedāravagga ","html":"<li>{}</li></ul>"},"ja490:0.4":{"pli":"7. Pañcuposathikajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja490:1.1":{"pli":"“Appossukko dāni tuvaṁ kapota, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja490:1.2":{"pli":"Vihaṅgama na tava bhojanattho; ","html":"<span class='verse-line'>{}</span>"},"ja490:1.3":{"pli":"Khudaṁ pipāsaṁ adhivāsayanto, ","html":"<span class='verse-line'>{}</span>"},"ja490:1.4":{"pli":"Kasmā bhavaṁposathiko kapota”. ","html":"<span class='verse-line'>{}</span></p>"},"ja490:2.1":{"pli":"“Ahaṁ pure giddhigato kapotiyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja490:2.2":{"pli":"Asmiṁ padesasmimubho ramāma; ","html":"<span class='verse-line'>{}</span>"},"ja490:2.3":{"pli":"Athaggahī sākuṇiko kapotiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja490:2.4":{"pli":"Akāmako tāya vinā ahosiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja490:3.1":{"pli":"Nānābhavā vippayogena tassā, ","html":"<p data-counter='11'><span class='verse-line'>{}</span>"},"ja490:3.2":{"pli":"Manomayaṁ vedana vedayāmi; ","html":"<span class='verse-line'>{}</span>"},"ja490:3.3":{"pli":"Tasmā ahaṁposathaṁ pālayāmi, ","html":"<span class='verse-line'>{}</span>"},"ja490:3.4":{"pli":"Rāgo mamaṁ mā punarāgamāsi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja490:4.1":{"pli":"“Anujjugāmī uragā dujivha, ","html":"<p><span class='verse-line'>{}</span>"},"ja490:4.2":{"pli":"Dāṭhāvudho ghoravisosi sappa; ","html":"<span class='verse-line'>{}</span>"},"ja490:4.3":{"pli":"Khudaṁ pipāsaṁ adhivāsayanto, ","html":"<span class='verse-line'>{}</span>"},"ja490:4.4":{"pli":"Kasmā bhavaṁposathiko nu dīgha. ","html":"<span class='verse-line'>{}</span></p>"},"ja490:5.1":{"pli":"Usabho ahū balavā gāmikassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja490:5.2":{"pli":"Calakkakū vaṇṇabalūpapanno; ","html":"<span class='verse-line'>{}</span>"},"ja490:5.3":{"pli":"So maṁ akkami taṁ kupito aḍaṁsiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja490:5.4":{"pli":"Dukkhābhitunno maraṇaṁ upāgā. ","html":"<span class='verse-line'>{}</span></p>"},"ja490:6.1":{"pli":"Tato janā nikkhamitvāna gāmā, ","html":"<p data-counter='21'><span class='verse-line'>{}</span>"},"ja490:6.2":{"pli":"Kanditvā roditvā apakkamiṁsu; ","html":"<span class='verse-line'>{}</span>"},"ja490:6.3":{"pli":"Tasmā ahaṁposathaṁ pālayāmi, ","html":"<span class='verse-line'>{}</span>"},"ja490:6.4":{"pli":"Kodho mamaṁ mā punarāgamāsi. ","html":"<span class='verse-line'>{}</span></p>"},"ja490:7.1":{"pli":"Matāna maṁsāni bahū susāne, ","html":"<p><span class='verse-line'>{}</span>"},"ja490:7.2":{"pli":"Manuññarūpaṁ tava bhojane taṁ; ","html":"<span class='verse-line'>{}</span>"},"ja490:7.3":{"pli":"Khudaṁ pipāsaṁ adhivāsayanto, ","html":"<span class='verse-line'>{}</span>"},"ja490:7.4":{"pli":"Kasmā bhavaṁposathiko siṅgāla. ","html":"<span class='verse-line'>{}</span></p>"},"ja490:8.1":{"pli":"Pavisi kucchiṁ mahato gajassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja490:8.2":{"pli":"Kuṇape rato hatthimaṁsesu giddho; ","html":"<span class='verse-line'>{}</span>"},"ja490:8.3":{"pli":"Uṇho ca vāto tikhiṇā ca rasmiyo, ","html":"<span class='verse-line'>{}</span>"},"ja490:8.4":{"pli":"Te sosayuṁ tassa karīsamaggaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja490:9.1":{"pli":"Kiso ca paṇḍū ca ahaṁ bhadante, ","html":"<p><span class='verse-line'>{}</span>"},"ja490:9.2":{"pli":"Na me ahū nikkhamanāya maggo; ","html":"<span class='verse-line'>{}</span>"},"ja490:9.3":{"pli":"Mahā ca megho sahasā pavassi, ","html":"<span class='verse-line'>{}</span>"},"ja490:9.4":{"pli":"So temayī tassa karīsamaggaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja490:10.1":{"pli":"Tato ahaṁ nikkhamisaṁ bhadante, ","html":"<p data-counter='31'><span class='verse-line'>{}</span>"},"ja490:10.2":{"pli":"Cando yathā rāhumukhā pamutto; ","html":"<span class='verse-line'>{}</span>"},"ja490:10.3":{"pli":"Tasmā ahaṁposathaṁ pālayāmi, ","html":"<span class='verse-line'>{}</span>"},"ja490:10.4":{"pli":"Lobho mamaṁ mā punarāgamāsi. ","html":"<span class='verse-line'>{}</span></p>"},"ja490:11.1":{"pli":"Vammīkathūpasmiṁ kipillikāni, ","html":"<p><span class='verse-line'>{}</span>"},"ja490:11.2":{"pli":"Nippothayanto tuvaṁ pure carāsi; ","html":"<span class='verse-line'>{}</span>"},"ja490:11.3":{"pli":"Khudaṁ pipāsaṁ adhivāsayanto, ","html":"<span class='verse-line'>{}</span>"},"ja490:11.4":{"pli":"Kasmā bhavaṁposathiko nu accha. ","html":"<span class='verse-line'>{}</span></p>"},"ja490:12.1":{"pli":"Sakaṁ niketaṁ atihīḷayāno, ","html":"<p><span class='verse-line'>{}</span>"},"ja490:12.2":{"pli":"Atricchatā mallagāmaṁ agacchiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja490:12.3":{"pli":"Tato janā nikkhamitvāna gāmā, ","html":"<span class='verse-line'>{}</span>"},"ja490:12.4":{"pli":"Kodaṇḍakena paripothayiṁsu maṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja490:13.1":{"pli":"So bhinnasīso ruhiramakkhitaṅgo, ","html":"<p data-counter='41'><span class='verse-line'>{}</span>"},"ja490:13.2":{"pli":"Paccāgamāsiṁ sakaṁ niketaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja490:13.3":{"pli":"Tasmā ahaṁposathaṁ pālayāmi, ","html":"<span class='verse-line'>{}</span>"},"ja490:13.4":{"pli":"Atricchatā mā punarāgamāsi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja490:14.1":{"pli":"“Yaṁ no apucchittha tuvaṁ bhadante, ","html":"<p><span class='verse-line'>{}</span>"},"ja490:14.2":{"pli":"Sabbeva byākarimha yathāpajānaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja490:14.3":{"pli":"Mayampi pucchāma tuvaṁ bhadante, ","html":"<span class='verse-line'>{}</span>"},"ja490:14.4":{"pli":"Kasmā bhavaṁposathiko nu brahme”. ","html":"<span class='verse-line'>{}</span></p>"},"ja490:15.1":{"pli":"“Anūpalitto mama assamamhi, ","html":"<p><span class='verse-line'>{}</span>"},"ja490:15.2":{"pli":"Paccekabuddho muhuttaṁ nisīdi; ","html":"<span class='verse-line'>{}</span>"},"ja490:15.3":{"pli":"So maṁ avedī gatimāgatiñca, ","html":"<span class='verse-line'>{}</span>"},"ja490:15.4":{"pli":"Nāmañca gottaṁ caraṇañca sabbaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja490:16.1":{"pli":"Evampahaṁ vandi na tassa pāde, ","html":"<p data-counter='51'><span class='verse-line'>{}</span>"},"ja490:16.2":{"pli":"Na cāpi naṁ mānagatena pucchiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja490:16.3":{"pli":"Tasmā ahaṁposathaṁ pālayāmi, ","html":"<span class='verse-line'>{}</span>"},"ja490:16.4":{"pli":"Māno mamaṁ mā punarāgamāsī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja490:17.1":{"pli":"Pañcuposathikajātakaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja491":{"ja491:0.1":{"pli":"Jātaka ","html":"<article id='ja491'><header><ul><li class='division'>{}</li>"},"ja491:0.2":{"pli":"Pakiṇṇakanipāta ","html":"<li>{}</li>"},"ja491:0.3":{"pli":"Sālikedāravagga ","html":"<li>{}</li></ul>"},"ja491:0.4":{"pli":"8. Mahāmorajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja491:1.1":{"pli":"“Sace hi tyāhaṁ dhanahetu gāhito, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja491:1.2":{"pli":"Mā maṁ vadhī jīvagāhaṁ gahetvā; ","html":"<span class='verse-line'>{}</span>"},"ja491:1.3":{"pli":"Rañño ca maṁ samma upantikaṁ nehi, ","html":"<span class='verse-line'>{}</span>"},"ja491:1.4":{"pli":"Maññe dhanaṁ lacchasinapparūpaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja491:2.1":{"pli":"“Na me ayaṁ tuyha vadhāya ajja, ","html":"<p><span class='verse-line'>{}</span>"},"ja491:2.2":{"pli":"Samāhito cāpadhure khurappo; ","html":"<span class='verse-line'>{}</span>"},"ja491:2.3":{"pli":"Pāsañca tyāhaṁ adhipātayissaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja491:2.4":{"pli":"Yathāsukhaṁ gacchatu morarājā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja491:3.1":{"pli":"“Yaṁ satta vassāni mamānubandhi, ","html":"<p><span class='verse-line'>{}</span>"},"ja491:3.2":{"pli":"Rattindivaṁ khuppipāsaṁ sahanto; ","html":"<span class='verse-line'>{}</span>"},"ja491:3.3":{"pli":"Atha kissa maṁ pāsavasūpanītaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja491:3.4":{"pli":"Pamuttave icchasi bandhanasmā. ","html":"<span class='verse-line'>{}</span></p>"},"ja491:4.1":{"pli":"Pāṇātipātā virato nusajja, ","html":"<p><span class='verse-line'>{}</span>"},"ja491:4.2":{"pli":"Abhayaṁ nu te sabbabhūtesu dinnaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja491:4.3":{"pli":"Yaṁ maṁ tuvaṁ pāsavasūpanītaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja491:4.4":{"pli":"Pamuttave icchasi bandhanasmā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja491:5.1":{"pli":"“Pāṇātipātā viratassa brūhi, ","html":"<p><span class='verse-line'>{}</span>"},"ja491:5.2":{"pli":"Abhayañca yo sabbabhūtesu deti; ","html":"<span class='verse-line'>{}</span>"},"ja491:5.3":{"pli":"Pucchāmi taṁ morarājetamatthaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja491:5.4":{"pli":"Ito cuto kiṁ labhate sukhaṁ so”. ","html":"<span class='verse-line'>{}</span></p>"},"ja491:6.1":{"pli":"“Pāṇātipātā viratassa brūmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja491:6.2":{"pli":"Abhayañca yo sabbabhūtesu deti; ","html":"<span class='verse-line'>{}</span>"},"ja491:6.3":{"pli":"Diṭṭheva dhamme labhate pasaṁsaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja491:6.4":{"pli":"Saggañca so yāti sarīrabhedā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja491:7.1":{"pli":"“Na santi devā iti āhu eke, ","html":"<p><span class='verse-line'>{}</span>"},"ja491:7.2":{"pli":"Idheva jīvo vibhavaṁ upeti; ","html":"<span class='verse-line'>{}</span>"},"ja491:7.3":{"pli":"Tathā phalaṁ sukatadukkaṭānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja491:7.4":{"pli":"Dattupaññattañca vadanti dānaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja491:7.5":{"pli":"Tesaṁ vaco arahataṁ saddahāno, ","html":"<span class='verse-line'>{}</span>"},"ja491:7.6":{"pli":"Tasmā ahaṁ sakuṇe bādhayāmi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja491:8.1":{"pli":"“Cando ca suriyo ca ubho sudassanā, ","html":"<p><span class='verse-line'>{}</span>"},"ja491:8.2":{"pli":"Gacchanti obhāsayamantalikkhe; ","html":"<span class='verse-line'>{}</span>"},"ja491:8.3":{"pli":"Imassa lokassa parassa vā te, ","html":"<span class='verse-line'>{}</span>"},"ja491:8.4":{"pli":"Kathaṁ nu te āhu manussaloke”. ","html":"<span class='verse-line'>{}</span></p>"},"ja491:9.1":{"pli":"“Cando ca suriyo ca ubho sudassanā, ","html":"<p><span class='verse-line'>{}</span>"},"ja491:9.2":{"pli":"Gacchanti obhāsayamantalikkhe; ","html":"<span class='verse-line'>{}</span>"},"ja491:9.3":{"pli":"Parassa lokassa na te imassa, ","html":"<span class='verse-line'>{}</span>"},"ja491:9.4":{"pli":"Devāti te āhu manussaloke”. ","html":"<span class='verse-line'>{}</span></p>"},"ja491:10.1":{"pli":"“Ettheva te nīhatā hīnavādā, ","html":"<p><span class='verse-line'>{}</span>"},"ja491:10.2":{"pli":"Ahetukā ye na vadanti kammaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja491:10.3":{"pli":"Tathā phalaṁ sukatadukkaṭānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja491:10.4":{"pli":"Dattupaññattaṁ ye ca vadanti dānaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja491:11.1":{"pli":"“Addhā hi saccaṁ vacanaṁ tavedaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja491:11.2":{"pli":"Kathañhi dānaṁ aphalaṁ bhaveyya; ","html":"<span class='verse-line'>{}</span>"},"ja491:11.3":{"pli":"Tathā phalaṁ sukatadukkaṭānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja491:11.4":{"pli":"Dattupaññattañca kathaṁ bhaveyya. ","html":"<span class='verse-line'>{}</span></p>"},"ja491:12.1":{"pli":"Kathaṅkaro kintikaro kimācaraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja491:12.2":{"pli":"Kiṁ sevamāno kena tapoguṇena; ","html":"<span class='verse-line'>{}</span>"},"ja491:12.3":{"pli":"Akkhāhi me morarājetamatthaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja491:12.4":{"pli":"Yathā ahaṁ no nirayaṁ pateyyaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja491:13.1":{"pli":"“Ye keci atthi samaṇā pathabyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja491:13.2":{"pli":"Kāsāyavatthā anagāriyā te; ","html":"<span class='verse-line'>{}</span>"},"ja491:13.3":{"pli":"Pātova piṇḍāya caranti kāle, ","html":"<span class='verse-line'>{}</span>"},"ja491:13.4":{"pli":"Vikālacariyā viratā hi santo. ","html":"<span class='verse-line'>{}</span></p>"},"ja491:14.1":{"pli":"Te tattha kālenupasaṅkamitvā, ","html":"<p><span class='verse-line'>{}</span>"},"ja491:14.2":{"pli":"Pucchāhi yaṁ te manaso piyaṁ siyā; ","html":"<span class='verse-line'>{}</span>"},"ja491:14.3":{"pli":"Te te pavakkhanti yathāpajānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja491:14.4":{"pli":"Imassa lokassa parassa catthaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja491:15.1":{"pli":"“Tacaṁva jiṇṇaṁ urago purāṇaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja491:15.2":{"pli":"Paṇḍūpalāsaṁ harito dumova; ","html":"<span class='verse-line'>{}</span>"},"ja491:15.3":{"pli":"Esappahīno mama luddabhāvo, ","html":"<span class='verse-line'>{}</span>"},"ja491:15.4":{"pli":"Jahāmahaṁ luddakabhāvamajja. ","html":"<span class='verse-line'>{}</span></p>"},"ja491:16.1":{"pli":"Ye cāpi me sakuṇā atthi baddhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja491:16.2":{"pli":"Satāninekāni nivesanasmiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja491:16.3":{"pli":"Tesampahaṁ jīvitamajja dammi, ","html":"<span class='verse-line'>{}</span>"},"ja491:16.4":{"pli":"Mokkhañca te pattā sakaṁ niketaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja491:17.1":{"pli":"“Luddo carī pāsahattho araññe, ","html":"<p><span class='verse-line'>{}</span>"},"ja491:17.2":{"pli":"Bādhetu morādhipatiṁ yasassiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja491:17.3":{"pli":"Bandhitvā morādhipatiṁ yasassiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja491:17.4":{"pli":"Dukkhā sa pamucci yathāhaṁ pamutto”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja491:18.1":{"pli":"Mahāmorajātakaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja492":{"ja492:0.1":{"pli":"Jātaka ","html":"<article id='ja492'><header><ul><li class='division'>{}</li>"},"ja492:0.2":{"pli":"Pakiṇṇakanipāta ","html":"<li>{}</li>"},"ja492:0.3":{"pli":"Sālikedāravagga ","html":"<li>{}</li></ul>"},"ja492:0.4":{"pli":"9. Tacchasūkarajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja492:1.1":{"pli":"“Yadesamānā vicarimha, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja492:1.2":{"pli":"pabbatāni vanāni ca; ","html":"<span class='verse-line'>{}</span>"},"ja492:1.3":{"pli":"Anvesaṁ vicariṁ ñātī, ","html":"<span class='verse-line'>{}</span>"},"ja492:1.4":{"pli":"teme adhigatā mayā. ","html":"<span class='verse-line'>{}</span></p>"},"ja492:2.1":{"pli":"Bahuñcidaṁ mūlaphalaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja492:2.2":{"pli":"bhakkho cāyaṁ anappako; ","html":"<span class='verse-line'>{}</span>"},"ja492:2.3":{"pli":"Rammā cimā girīnajjo, ","html":"<span class='verse-line'>{}</span>"},"ja492:2.4":{"pli":"phāsuvāso bhavissati. ","html":"<span class='verse-line'>{}</span></p>"},"ja492:3.1":{"pli":"Idhevāhaṁ vasissāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja492:3.2":{"pli":"saha sabbehi ñātibhi; ","html":"<span class='verse-line'>{}</span>"},"ja492:3.3":{"pli":"Appossukko nirāsaṅkī, ","html":"<span class='verse-line'>{}</span>"},"ja492:3.4":{"pli":"asoko akutobhayo”. ","html":"<span class='verse-line'>{}</span></p>"},"ja492:4.1":{"pli":"“Aññampi leṇaṁ pariyesa, ","html":"<p><span class='verse-line'>{}</span>"},"ja492:4.2":{"pli":"sattu no idha vijjati; ","html":"<span class='verse-line'>{}</span>"},"ja492:4.3":{"pli":"So taccha sūkare hanti, ","html":"<span class='verse-line'>{}</span>"},"ja492:4.4":{"pli":"idhāgantvā varaṁ varaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja492:5.1":{"pli":"“Ko numhākaṁ idha sattu, ","html":"<p><span class='verse-line'>{}</span>"},"ja492:5.2":{"pli":"ko ñātī susamāgate; ","html":"<span class='verse-line'>{}</span>"},"ja492:5.3":{"pli":"Duppadhaṁse padhaṁseti, ","html":"<span class='verse-line'>{}</span>"},"ja492:5.4":{"pli":"taṁ me akkhātha pucchitā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja492:6.1":{"pli":"“Uddhaggarājī migarājā, ","html":"<p><span class='verse-line'>{}</span>"},"ja492:6.2":{"pli":"balī dāṭhāvudho migo; ","html":"<span class='verse-line'>{}</span>"},"ja492:6.3":{"pli":"So taccha sūkare hanti, ","html":"<span class='verse-line'>{}</span>"},"ja492:6.4":{"pli":"idhāgantvā varaṁ varaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja492:7.1":{"pli":"“Na no dāṭhā na vijjanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja492:7.2":{"pli":"balaṁ kāye samohitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja492:7.3":{"pli":"Sabbe samaggā hutvāna, ","html":"<span class='verse-line'>{}</span>"},"ja492:7.4":{"pli":"vasaṁ kāhāma ekakaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja492:8.1":{"pli":"“Hadayaṅgamaṁ kaṇṇasukhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja492:8.2":{"pli":"Vācaṁ bhāsasi tacchaka; ","html":"<span class='verse-line'>{}</span>"},"ja492:8.3":{"pli":"Yopi yuddhe palāyeyya, ","html":"<span class='verse-line'>{}</span>"},"ja492:8.4":{"pli":"Tampi pacchā hanāmase”. ","html":"<span class='verse-line'>{}</span></p>"},"ja492:9.1":{"pli":"“Pāṇātipātā virato nu ajja, ","html":"<p><span class='verse-line'>{}</span>"},"ja492:9.2":{"pli":"Abhayaṁ nu te sabbabhūtesu dinnaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja492:9.3":{"pli":"Dāṭhā nu te migavadhāya na santi, ","html":"<span class='verse-line'>{}</span>"},"ja492:9.4":{"pli":"Yo saṅghapatto kapaṇova jhāyasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja492:10.1":{"pli":"“Na me dāṭhā na vijjanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja492:10.2":{"pli":"Balaṁ kāye samohitaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja492:10.3":{"pli":"Ñātī ca disvāna sāmaggī ekato, ","html":"<span class='verse-line'>{}</span>"},"ja492:10.4":{"pli":"Tasmā ca jhāyāmi vanamhi ekako. ","html":"<span class='verse-line'>{}</span></p>"},"ja492:11.1":{"pli":"Imassudaṁ yanti disodisaṁ pure, ","html":"<p><span class='verse-line'>{}</span>"},"ja492:11.2":{"pli":"Bhayaṭṭitā leṇagavesino puthu; ","html":"<span class='verse-line'>{}</span>"},"ja492:11.3":{"pli":"Te dāni saṅgamma vasanti ekato, ","html":"<span class='verse-line'>{}</span>"},"ja492:11.4":{"pli":"Yatthaṭṭhitā duppasahajja te mayā. ","html":"<span class='verse-line'>{}</span></p>"},"ja492:12.1":{"pli":"Pariṇāyakasampannā, ","html":"<p><span class='verse-line'>{}</span>"},"ja492:12.2":{"pli":"sahitā ekavādino; ","html":"<span class='verse-line'>{}</span>"},"ja492:12.3":{"pli":"Te maṁ samaggā hiṁseyyuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja492:12.4":{"pli":"tasmā nesaṁ na patthaye”. ","html":"<span class='verse-line'>{}</span></p>"},"ja492:13.1":{"pli":"“Ekova indo asure jināti, ","html":"<p><span class='verse-line'>{}</span>"},"ja492:13.2":{"pli":"Ekova seno hanti dije pasayha; ","html":"<span class='verse-line'>{}</span>"},"ja492:13.3":{"pli":"Ekova byaggho migasaṅghapatto, ","html":"<span class='verse-line'>{}</span>"},"ja492:13.4":{"pli":"Varaṁ varaṁ hanti balañhi tādisaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja492:14.1":{"pli":"“Na heva indo na seno, ","html":"<p><span class='verse-line'>{}</span>"},"ja492:14.2":{"pli":"napi byaggho migādhipo; ","html":"<span class='verse-line'>{}</span>"},"ja492:14.3":{"pli":"Samagge sahite ñātī, ","html":"<span class='verse-line'>{}</span>"},"ja492:14.4":{"pli":"na byagghe kurute vase”. ","html":"<span class='verse-line'>{}</span></p>"},"ja492:15.1":{"pli":"“Kumbhīlakā sakuṇakā, ","html":"<p><span class='verse-line'>{}</span>"},"ja492:15.2":{"pli":"saṅghino gaṇacārino; ","html":"<span class='verse-line'>{}</span>"},"ja492:15.3":{"pli":"Sammodamānā ekajjhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja492:15.4":{"pli":"uppatanti ḍayanti ca. ","html":"<span class='verse-line'>{}</span></p>"},"ja492:16.1":{"pli":"Tesañca ḍayamānānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja492:16.2":{"pli":"ekettha apasakkati; ","html":"<span class='verse-line'>{}</span>"},"ja492:16.3":{"pli":"Tañca seno nitāḷeti, ","html":"<span class='verse-line'>{}</span>"},"ja492:16.4":{"pli":"veyyagghiyeva sā gati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja492:17.1":{"pli":"“Ussāhito jaṭilena, ","html":"<p><span class='verse-line'>{}</span>"},"ja492:17.2":{"pli":"luddenāmisacakkhunā; ","html":"<span class='verse-line'>{}</span>"},"ja492:17.3":{"pli":"Dāṭhī dāṭhīsu pakkhandi, ","html":"<span class='verse-line'>{}</span>"},"ja492:17.4":{"pli":"maññamāno yathā pure”. ","html":"<span class='verse-line'>{}</span></p>"},"ja492:18.1":{"pli":"“Sādhu sambahulā ñātī, ","html":"<p><span class='verse-line'>{}</span>"},"ja492:18.2":{"pli":"api rukkhā araññajā; ","html":"<span class='verse-line'>{}</span>"},"ja492:18.3":{"pli":"Sūkarehi samaggehi, ","html":"<span class='verse-line'>{}</span>"},"ja492:18.4":{"pli":"byaggho ekāyane hato”. ","html":"<span class='verse-line'>{}</span></p>"},"ja492:19.1":{"pli":"Brāhmaṇañceva byagghañca, ","html":"<p><span class='verse-line'>{}</span>"},"ja492:19.2":{"pli":"ubho hantvāna sūkarā. ","html":"<span class='verse-line'>{}</span>"},"ja492:19.3":{"pli":"Ānandino pamuditā, ","html":"<span class='verse-line'>{}</span>"},"ja492:19.4":{"pli":"mahānādaṁ panādisuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja492:20.1":{"pli":"Te su udumbaramūlasmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja492:20.2":{"pli":"sūkarā susamāgatā; ","html":"<span class='verse-line'>{}</span>"},"ja492:20.3":{"pli":"Tacchakaṁ abhisiñciṁsu, ","html":"<span class='verse-line'>{}</span>"},"ja492:20.4":{"pli":"“tvaṁ no rājāsi issaro”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja492:21.1":{"pli":"Tacchasūkarajātakaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}