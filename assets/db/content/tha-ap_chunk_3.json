tml":"<span class='verse-line'>{}</span>"},"tha-ap127:2.3":{"pli":"So dāni bhagavā satthā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:2.4":{"pli":"dhammaṁ deseti cakkhumā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap127:3.1":{"pli":"Yasmiñca jāyamānasmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap127:3.2":{"pli":"āloko vipulo ahu; ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:3.3":{"pli":"So dāni bhagavā satthā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:3.4":{"pli":"dhammaṁ deseti cakkhumā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap127:4.1":{"pli":"Yasmiñca jāyamānasmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap127:4.2":{"pli":"saritāyo na sandayuṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:4.3":{"pli":"So dāni bhagavā satthā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:4.4":{"pli":"dhammaṁ deseti cakkhumā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap127:5.1":{"pli":"Yasmiñca jāyamānasmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap127:5.2":{"pli":"avīcaggi na pajjali; ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:5.3":{"pli":"So dāni bhagavā satthā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:5.4":{"pli":"dhammaṁ deseti cakkhumā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap127:6.1":{"pli":"Yasmiñca jāyamānasmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap127:6.2":{"pli":"pakkhisaṅgho na sañcari; ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:6.3":{"pli":"So dāni bhagavā satthā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:6.4":{"pli":"dhammaṁ deseti cakkhumā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap127:7.1":{"pli":"Yasmiñca jāyamānasmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap127:7.2":{"pli":"vātakkhandho na vāyati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:7.3":{"pli":"So dāni bhagavā satthā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:7.4":{"pli":"dhammaṁ deseti cakkhumā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap127:8.1":{"pli":"Yasmiñca jāyamānasmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap127:8.2":{"pli":"sabbaratanāni jotayuṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:8.3":{"pli":"So dāni bhagavā satthā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:8.4":{"pli":"dhammaṁ deseti cakkhumā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap127:9.1":{"pli":"Yasmiñca jāyamānasmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap127:9.2":{"pli":"sattāsuṁ padavikkamā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:9.3":{"pli":"So dāni bhagavā satthā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:9.4":{"pli":"dhammaṁ deseti cakkhumā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap127:10.1":{"pli":"Jātamatto ca sambuddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap127:10.2":{"pli":"disā sabbā vilokayi; ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:10.3":{"pli":"Vācāsabhimudīresi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:10.4":{"pli":"esā buddhāna dhammatā’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap127:11.1":{"pli":"Saṁvejayitvā janataṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap127:11.2":{"pli":"thavitvā lokanāyakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:11.3":{"pli":"Sambuddhaṁ abhivādetvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:11.4":{"pli":"pakkāmiṁ pācināmukho. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap127:12.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap127:12.2":{"pli":"yaṁ buddhamabhithomayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:12.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:12.4":{"pli":"thomanāya idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap127:13.1":{"pli":"Ito navutikappamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap127:13.2":{"pli":"sammukhāthavikavhayo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:13.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:13.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap127:14.1":{"pli":"Pathavīdundubhi nāma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap127:14.2":{"pli":"ekūnanavutimhito; ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:14.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:14.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap127:15.1":{"pli":"Aṭṭhāsītimhito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap127:15.2":{"pli":"obhāso nāma khattiyo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:15.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:15.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap127:16.1":{"pli":"Sattāsītimhito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap127:16.2":{"pli":"saritacchedanavhayo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:16.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:16.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap127:17.1":{"pli":"Agginibbāpano nāma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap127:17.2":{"pli":"kappānaṁ chaḷasītiyā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:17.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:17.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap127:18.1":{"pli":"Gatipacchedano nāma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap127:18.2":{"pli":"kappānaṁ pañcasītiyā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:18.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:18.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap127:19.1":{"pli":"Rājā vātasamo nāma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap127:19.2":{"pli":"kappānaṁ cullasītiyā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:19.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:19.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap127:20.1":{"pli":"Ratanapajjalo nāma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap127:20.2":{"pli":"kappānaṁ teasītiyā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:20.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:20.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap127:21.1":{"pli":"Padavikkamano nāma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap127:21.2":{"pli":"kappānaṁ dveasītiyā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:21.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:21.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap127:22.1":{"pli":"Rājā vilokano nāma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap127:22.2":{"pli":"kappānaṁ ekasītiyā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:22.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap127:22.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap127:23.1":{"pli":"Girasāroti nāmena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap127:23.2":{"pli"