{"tha-ap123":{"tha-ap123:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap123'><header><ul><li class='division'>{}</li>"},"tha-ap123:0.2":{"pli":"Sereyyavagga ","html":"<li>{}</li></ul>"},"tha-ap123:0.3":{"pli":"Sereyyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap123:1.1":{"pli":"“Ajjhāyako mantadharo, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap123:1.2":{"pli":"tiṇṇaṁ vedāna pāragū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap123:1.3":{"pli":"Abbhokāse ṭhito santo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap123:1.4":{"pli":"addasaṁ lokanāyakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap123:2.1":{"pli":"Sīhaṁ yathā vanacaraṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap123:2.2":{"pli":"byaggharājaṁva nittasaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap123:2.3":{"pli":"Tidhāpabhinnamātaṅgaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap123:2.4":{"pli":"kuñjaraṁva mahesinaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap123:3.1":{"pli":"Sereyyakaṁ gahetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap123:3.2":{"pli":"ākāse ukkhipiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap123:3.3":{"pli":"Buddhassa ānubhāvena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap123:3.4":{"pli":"parivārenti sabbaso. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap123:4.1":{"pli":"Adhiṭṭhahi mahāvīro, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap123:4.2":{"pli":"sabbaññū lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap123:4.3":{"pli":"Samantā pupphacchadanā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap123:4.4":{"pli":"okiriṁsu narāsabhaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap123:5.1":{"pli":"Tato sā pupphakañcukā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap123:5.2":{"pli":"antovaṇṭā bahimukhā; ","html":"<span clas