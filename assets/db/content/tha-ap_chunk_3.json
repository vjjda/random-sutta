"},"tha-ap130:5.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap130:5.4":{"pli":"ñāṇasaññāyidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap130:6.1":{"pli":"Ito sattatikappamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap130:6.2":{"pli":"eko pulinapupphiyo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap130:6.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap130:6.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap130:7.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap130:7.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap130:7.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap130:8.1":{"pli":"Itthaṁ sudaṁ āyasmā ñāṇasaññiko thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap130:9.1":{"pli":"Ñāṇasaññikattherassāpadānaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap131":{"tha-ap131:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap131'><header><ul><li class='division'>{}</li>"},"tha-ap131:0.2":{"pli":"Sereyyavagga ","html":"<li>{}</li></ul>"},"tha-ap131:0.3":{"pli":"9 Gaṇṭhipupphiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap131:1.1":{"pli":"“Suvaṇṇavaṇṇo sambuddho, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap131:1.2":{"pli":"vipassī dakkhiṇāraho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap131:1.3":{"pli":"Purakkhato sāvakehi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap131:1.4":{"pli":"ārāmā abhinikkhami. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap131:2.1":{"pli":"Disvānahaṁ buddhaseṭṭhaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap131:2.2":{"pli":"sabbaññuṁ tamanāsakaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap131:2.3":{"pli":"P