1":{"pli":"Therāpadāna ","html":"<article id='tha-ap124'><header><ul><li class='division'>{}</li>"},"tha-ap124:0.2":{"pli":"Sereyyavagga ","html":"<li>{}</li></ul>"},"tha-ap124:0.3":{"pli":"Pupphathūpiyattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap124:1.1":{"pli":"“Himavantassāvidūre, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap124:1.2":{"pli":"kukkuro nāma pabbato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap124:1.3":{"pli":"Vemajjhe tassa vasati, ","html":"<span class='verse-line'>{}</span>"},"tha-ap124:1.4":{"pli":"brāhmaṇo mantapāragū. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap124:2.1":{"pli":"Pañca sissasahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap124:2.2":{"pli":"parivārenti maṁ sadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap124:2.3":{"pli":"Pubbuṭṭhāyī ca te āsuṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap124:2.4":{"pli":"mantesu ca visāradā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap124:3.1":{"pli":"Buddho loke samuppanno, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap124:3.2":{"pli":"taṁ vijānātha no bhavaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap124:3.3":{"pli":"Asītibyañjanānassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap124:3.4":{"pli":"bāttiṁsavaralakkhaṇā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap124:4.1":{"pli":"Byāmappabho jinavaro, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap124:4.2":{"pli":"ādiccova virocati; ","html":"<span class='verse-line'>{}</span>"},"tha-ap124:4.3":{"pli":"Sissānaṁ vacanaṁ sutvā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap124:4.4":{"pli":"brāhmaṇo mantapāragū. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap124:5.1":{"pli":"Assamā abhinikkhamma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap124:5.2":{"pli":"disaṁ pucchati sissake; ","html":"<span class='verse-line'>{}</span>"},"tha-ap124:5.3":{"pli":"Yamhi dese mahāvīro, ","html":"<span class='verse-line'>{}</span>"},"tha-ap124:5.4":{"pli":"vasati lokanāyako. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap124:6.1":{"pli":"Tāhaṁ disaṁ namassissaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap124:6.2":{"pli":"jinaṁ appaṭipuggalaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap124:6.3":{"pli":"Udaggacitto sumano, ","html":"<span class='verse-line'>{}</span>"},"tha-ap124:6.4":{"pli":"pūjesiṁ taṁ tathāgataṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap124:7.1":{"pli":"Etha sissā gamissāma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap124:7.2":{"pli":"dakkhissāma tathāgataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap124:7.3":{"pli":"Vanditvā satthuno pāde, ","html":"<span class='verse-line'>{}</span>"},"tha-ap124:7.4":{"pli":"sossāma jinasāsanaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap124:8.1":{"pli":"Ekāhaṁ abhinikkhamma, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap124:8.2":{"pli":"byādhiṁ paṭilabhiṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap124:8.3":{"pli":"Byādhinā pīḷito santo, ","html":"<span class='verse-line'>{}</span>"},"tha-ap124:8.4":{"pli":"sālaṁ vāsayituṁ gamiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap124:9.1":{"pli":"Sabbe sisse samānetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap124:9.2":{"pli":"apucchiṁ te tathāgataṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap124:9.3":{"pli":"Kīdisaṁ lokanāthassa, ","html":"<span class='verse-line'>{}</span>"},"tha-ap124:9.4":{"pli":"guṇaṁ paramabuddhino. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap124:10.1":{"pli":"Te me puṭṭhā viyākaṁsu, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap124:10.2":{"pli":"Yathā dassāvino tathā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap124:10.3":{"pli":"Sakkaccaṁ buddhaseṭṭhaṁ taṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap124:10.4":{"pli":"Desesuṁ mama sammukhā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap124:11.1":{"pli":"Tesāhaṁ vacanaṁ sutvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap124:11.2":{"pli":"sakaṁ cittaṁ pasādayiṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap124:11.3":{"pli":"Pupphehi thūpaṁ katvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap124:11.4":{"pli":"tattha kālaṅkato ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap124:12.1":{"pli":"Te me sarīraṁ jhāpetvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap124:12.2":{"pli":"agamuṁ buddhasantikaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap124:12.3":{"pli":"Añjaliṁ paggahetvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap124:12.4":{"pli":"satthāramabhivādayuṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap124:13.1":{"pli":"Pupphehi thūpaṁ katvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap124:13.2":{"pli":"sugatassa mahesino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap124:13.3":{"pli":"Kappānaṁ satasahassaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap124:13.4":{"pli":"duggatiṁ nupapajjahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap124:14.1":{"pli":"Cattālīsasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap124:14.2":{"pli":"kappe soḷasa khattiyā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap124:14.3":{"pli":"Nāmenaggisamā nāma, ","html":"<span class='verse-line'>{}</span>"},"tha-ap124:14.4":{"pli":"cakkavattī mahabbalā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap124:15.1":{"pli":"Vīsakappasahassamhi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap124:15.2":{"pli":"rājāno cakkavattino; ","html":"<span class='verse-line'>{}</span>"},"tha-ap124:15.3":{"pli":"Ghatāsanasanāmāva, ","html":"<span class='verse-line'>{}</span>"},"tha-ap124:15.4":{"pli":"aṭṭhattiṁsa mahīpatī. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap124:16.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap124:16.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap124:16.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap124:17.1":{"pli":"Itthaṁ sudaṁ āyasmā pupphathūpiyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap124:18.1":{"pli":"Pupphathūpiyattherassāpadānaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap125":{"tha-ap125:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap125'><header><ul><li class='division'>{}</li>"},"tha-ap125:0.2":{"pli":"Sereyyavagga ","html":"<li>{}</li></ul>"},"tha-ap125:0.3":{"pli":"3 Pāyasadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap125:1.1":{"pli":"“Suvaṇṇavaṇṇo sambuddho, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap125:1.2":{"pli":"Bāttiṁsavaralakkhaṇo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap125:1.3":{"pli":"Pavanā abhinikkhanto, ","html":"<span class='verse-line'>{}</span>"},"tha-ap125:1.4":{"pli":"Bhikkhusaṅghapurakkhato. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap125:2.1":{"pli":"Mahaccā kaṁsapātiyā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap125:2.2":{"pli":"vaḍḍhetvā pāyasaṁ ahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap125:2.3":{"pli":"Āhutiṁ yiṭṭhukāmo so, ","html":"<span class='verse-line'>{}</span>"},"tha-ap125:2.4":{"pli":"upanesiṁ baliṁ ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap125:3.1":{"pli":"Bhagavā tamhi samaye, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap125:3.2":{"pli":"lokajeṭṭho narāsabho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap125:3.3":{"pli":"Caṅkamaṁ susamārūḷho, ","html":"<span class='verse-line'>{}</span>"},"tha-ap125:3.4":{"pli":"ambare anilāyane. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap125:4.1":{"pli":"Tañca acchariyaṁ disvā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap125:4.2":{"pli":"abbhutaṁ lomahaṁsanaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap125:4.3":{"pli":"Ṭhapayitvā kaṁsapātiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap125:4.4":{"pli":"vipassiṁ abhivādayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap125:5.1":{"pli":"Tuvaṁ devosi sabbaññū, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap125:5.2":{"pli":"sadeve sahamānuse; ","html":"<span class='verse-line'>{}</span>"},"tha-ap125:5.3":{"pli":"Anukampaṁ upādāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap125:5.4":{"pli":"paṭigaṇha mahāmuni. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap125:6.1":{"pli":"Paṭiggahesi bhagavā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap125:6.2":{"pli":"sabbaññū lokanāyako; ","html":"<span class='verse-line'>{}</span>"},"tha-ap125:6.3":{"pli":"Mama saṅkappamaññāya, ","html":"<span class='verse-line'>{}</span>"},"tha-ap125:6.4":{"pli":"satthā loke mahāmuni. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap125:7.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap125:7.2":{"pli":"yaṁ dānamadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap125:7.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap125:7.4":{"pli":"pāyasassa idaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap125:8.1":{"pli":"Ekatālīsito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap125:8.2":{"pli":"buddho nāmāsi khattiyo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap125:8.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap125:8.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap125:9.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"th