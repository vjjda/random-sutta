e; ","html":"<span class='verse-line'>{}</span>"},"tha-ap128:3.3":{"pli":"Āhutiṁ yiṭṭhukāmohaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap128:3.4":{"pli":"pitumātusamāgame. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap128:4.1":{"pli":"Tadā vipassī bhagavā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap128:4.2":{"pli":"bhikkhusaṅghapurakkhato; ","html":"<span class='verse-line'>{}</span>"},"tha-ap128:4.3":{"pli":"Obhāsento disā sabbā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap128:4.4":{"pli":"āgacchati narāsabho. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap128:5.1":{"pli":"Āsanaṁ paññapetvāna, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap128:5.2":{"pli":"nimantetvā mahāmuniṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap128:5.3":{"pli":"Santharitvāna taṁ pupphaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap128:5.4":{"pli":"abhinesiṁ sakaṁ gharaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap128:6.1":{"pli":"Yaṁ me atthi sake gehe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap128:6.2":{"pli":"āmisaṁ paccupaṭṭhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap128:6.3":{"pli":"Tāhaṁ buddhassa pādāsiṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap128:6.4":{"pli":"pasanno sehi pāṇibhi. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap128:7.1":{"pli":"Bhuttāviṁ kālamaññāya, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap128:7.2":{"pli":"pupphahatthamadāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap128:7.3":{"pli":"Anumoditvāna sabbaññū, ","html":"<span class='verse-line'>{}</span>"},"tha-ap128:7.4":{"pli":"pakkāmi uttarāmukho. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap128:8.1":{"pli":"Ekanavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap128:8.2":{"pli":"yaṁ pupphamadadiṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap128:8.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap128:8.4":{"pli":"pupphadānassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap128:9.1":{"pli":"Anantaraṁ ito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap128:9.2":{"pli":"rājāhuṁ varadassano; ","html":"<span class='verse-line'>{}</span>"},"tha-ap128:9.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap128:9.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap128:10.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap128:10.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap128:10.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap128:11.1":{"pli":"Itthaṁ sudaṁ āyasmā kusumāsaniyo thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap128:12.1":{"pli":"Kusumāsaniyattherassāpadānaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap129":{"tha-ap129:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap129'><header><ul><li class='division'>{}</li>"},"tha-ap129:0.2":{"pli":"Sereyyavagga ","html":"<li>{}</li></ul>"},"tha-ap129:0.3":{"pli":"Phaladāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap129:1.1":{"pli":"“Ajjhāyako mantadharo, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap129:1.2":{"pli":"tiṇṇaṁ vedāna pāragū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap129:1.3":{"pli":"Himavantassāvidūre, ","html":"<span class='verse-line'>{}</span>"},"tha-ap129:1.4":{"pli":"vasāmi assame ahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap129:2.1":{"pli":"Aggihuttañca me atthi, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap129:2.2":{"pli":"puṇḍarīkaphalāni ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap129:2.3":{"pli":"Puṭake nikkhipitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap129:2.4":{"pli":"dumagge laggitaṁ mayā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap129:3.1":{"pli":"Padumuttaro lokavidū, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap129:3.2":{"pli":"āhutīnaṁ paṭiggaho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap129:3.3":{"pli":"Mamuddharitukāmo so, ","html":"<span class='verse-line'>{}</span>"},"tha-ap129:3.4":{"pli":"bhikkhanto mamupāgami. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap129:4.1":{"pli":"Pasannacitto sumano, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap129:4.2":{"pli":"phalaṁ buddhassadāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap129:4.3":{"pli":"Vittisañjanano mayhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap129:4.4":{"pli":"diṭṭhadhammasukhāvaho. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap129:5.1":{"pli":"Suvaṇṇavaṇṇo sambuddho, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap129:5.2":{"pli":"āhutīnaṁ paṭiggaho; ","html":"<span class='verse-line'>{}</span>"},"tha-ap129:5.3":{"pli":"Antalikkhe ṭhito satthā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap129:5.4":{"pli":"imaṁ gāthaṁ abhāsatha. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap129:6.1":{"pli":"‘Iminā phaladānena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap129:6.2":{"pli":"cetanāpaṇidhīhi ca; ","html":"<span class='verse-line'>{}</span>"},"tha-ap129:6.3":{"pli":"Kappānaṁ satasahassaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap129:6.4":{"pli":"duggatiṁ nupapajjati’. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap129:7.1":{"pli":"Teneva sukkamūlena, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap129:7.2":{"pli":"anubhotvāna sampadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap129:7.3":{"pli":"Pattomhi acalaṁ ṭhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap129:7.4":{"pli":"hitvā jayaparājayaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap129:8.1":{"pli":"Ito sattasate kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap129:8.2":{"pli":"rājā āsiṁ sumaṅgalo; ","html":"<span class='verse-line'>{}</span>"},"tha-ap129:8.3":{"pli":"Sattaratanasampanno, ","html":"<span class='verse-line'>{}</span>"},"tha-ap129:8.4":{"pli":"cakkavattī mahabbalo. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap129:9.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap129:9.2":{"pli":"…pe… ","html":"<span class='verse-line'>{}</span>"},"tha-ap129:9.3":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap129:10.1":{"pli":"Itthaṁ sudaṁ āyasmā phaladāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap129:11.1":{"pli":"Phaladāyakattherassāpadānaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap13":{"tha-ap13:0.1":{"pli":"Therāpadāna ","html":"<article id='tha-ap13'><header><ul><li class='division'>{}</li>"},"tha-ap13:0.2":{"pli":"Sīhāsaniyavagga ","html":"<li>{}</li></ul>"},"tha-ap13:0.3":{"pli":"Sīhāsanadāyakattheraapadāna ","html":"<h1 class='sutta-title'>{}</h1></header>"},"tha-ap13:1.1":{"pli":"“Nibbute lokanāthamhi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"tha-ap13:1.2":{"pli":"siddhatthe dvipaduttame; ","html":"<span class='verse-line'>{}</span>"},"tha-ap13:1.3":{"pli":"Vitthārike pāvacane, ","html":"<span class='verse-line'>{}</span>"},"tha-ap13:1.4":{"pli":"bāhujaññamhi sāsane. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap13:2.1":{"pli":"Pasannacitto sumano, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap13:2.2":{"pli":"sīhāsanamakāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap13:2.3":{"pli":"Sīhāsanaṁ karitvāna, ","html":"<span class='verse-line'>{}</span>"},"tha-ap13:2.4":{"pli":"pādapīṭhamakāsahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap13:3.1":{"pli":"Sīhāsane ca vassante, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap13:3.2":{"pli":"gharaṁ tattha akāsahaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap13:3.3":{"pli":"Tena cittappasādena, ","html":"<span class='verse-line'>{}</span>"},"tha-ap13:3.4":{"pli":"tusitaṁ upapajjahaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap13:4.1":{"pli":"Āyāmena catubbīsa- ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap13:4.2":{"pli":"yojanaṁ āsi tāvade; ","html":"<span class='verse-line'>{}</span>"},"tha-ap13:4.3":{"pli":"Vimānaṁ sukataṁ mayhaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap13:4.4":{"pli":"vitthārena catuddasa. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap13:5.1":{"pli":"Sataṁ kaññāsahassāni, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap13:5.2":{"pli":"parivārenti maṁ sadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap13:5.3":{"pli":"Soṇṇamayañca pallaṅkaṁ, ","html":"<span class='verse-line'>{}</span>"},"tha-ap13:5.4":{"pli":"byamhe āsi sunimmitaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap13:6.1":{"pli":"Hatthiyānaṁ assayānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap13:6.2":{"pli":"dibbayānaṁ upaṭṭhitaṁ; ","html":"<span class='verse-line'>{}</span>"},"tha-ap13:6.3":{"pli":"Pāsādā sivikā ceva, ","html":"<span class='verse-line'>{}</span>"},"tha-ap13:6.4":{"pli":"nibbattanti yadicchakaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap13:7.1":{"pli":"Maṇimayā ca pallaṅkā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap13:7.2":{"pli":"aññe sāramayā bahū; ","html":"<span class='verse-line'>{}</span>"},"tha-ap13:7.3":{"pli":"Nibbattanti mamaṁ sabbe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap13:7.4":{"pli":"sīhāsanassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap13:8.1":{"pli":"Soṇṇamayā rūpimayā, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap13:8.2":{"pli":"phalikāveḷuriyāmayā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap13:8.3":{"pli":"Pādukā abhirūhāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap13:8.4":{"pli":"pādapīṭhassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap13:9.1":{"pli":"Catunnavutito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap13:9.2":{"pli":"yaṁ kammamakariṁ tadā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap13:9.3":{"pli":"Duggatiṁ nābhijānāmi, ","html":"<span class='verse-line'>{}</span>"},"tha-ap13:9.4":{"pli":"puññakammassidaṁ phalaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap13:10.1":{"pli":"Tesattatimhito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap13:10.2":{"pli":"indanāmā tayo janā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap13:10.3":{"pli":"Dvesattatimhito kappe, ","html":"<span class='verse-line'>{}</span>"},"tha-ap13:10.4":{"pli":"tayo sumananāmakā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap13:11.1":{"pli":"Samasattatito kappe, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap13:11.2":{"pli":"tayo varuṇanāmakā; ","html":"<span class='verse-line'>{}</span>"},"tha-ap13:11.3":{"pli":"Sattaratanasampannā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap13:11.4":{"pli":"catudīpamhi issarā. ","html":"<span class='verse-line'>{}</span></p>"},"tha-ap13:12.1":{"pli":"Paṭisambhidā catasso, ","html":"<p><span class='verse-line'>{}</span>"},"tha-ap13:12.2":{"pli":"vimokkhāpi ca aṭṭhime; ","html":"<span class='verse-line'>{}</span>"},"tha-ap13:12.3":{"pli":"Chaḷabhiññā sacchikatā, ","html":"<span class='verse-line'>{}</span>"},"tha-ap13:12.4":{"pli":"kataṁ buddhassa sāsanaṁ”. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"tha-ap13:13.1":{"pli":"Itthaṁ sudaṁ āyasmā sīhāsanadāyako thero imā gāthāyo abhāsitthāti. ","html":"<p>{}</p>"},"tha-ap13:14.1":{"pli":"Sīhāsanadāyakattherassāpadānaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"tha-ap130":{"tha-ap130:0.1":{"p