{"ja26":{"ja26:0.1":{"pli":"Jātaka ","eng":"Stories of Past Lives 26 ","html":"<article id='ja26'><header><ul><li class='division'>{}</li>"},"ja26:0.2":{"pli":"Ekakanipāta ","eng":"The Book of the Ones ","html":"<li>{}</li>"},"ja26:0.3":{"pli":"Kuruṅgavagga ","eng":"The Four-horned Antelope ","html":"<li>{}</li></ul>"},"ja26:0.4":{"pli":"6. Mahiḷāmukhajātaka ","eng":"The Elephant Named Ladyface: a past life story ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja26:1.1":{"pli":"“Purāṇacorāna vaco nisamma, ","eng":"Before, hearing the speech of the bandits, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>","comm":"A good-natured royal elephant was corrupted after overhearing some bandits speaking evilly. "},"ja26:1.2":{"pli":"Mahiḷāmukho pothayamanvacārī; ","eng":"Ladyface went on a rampage. ","html":"<span class='verse-line'>{}</span>"},"ja26:1.3":{"pli":"Susaññatānañhi vaco nisamma, ","eng":"But hearing the speech of the well-restrained, ","html":"<span class='verse-line'>{}</span>"},"ja26:1.4":{"pli":"Gajuttamo sabbaguṇesu aṭṭhā”ti. ","eng":"the supreme elephant is established <j>in all good qualities. ","html":"<span class='verse-line'>{}</span></p></blockquote>","comm":"<i lang='pi' translate='no'>Aṭṭhā</i> is glossed with <i lang='pi' translate='no'>patiṭṭhito</i>. "},"ja26:2.1":{"pli":"Mahiḷāmukhajātakaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja260":{"ja260:0.1":{"pli":"Jātaka ","html":"<article id='ja260'><header><ul><li class='division'>{}</li>"},"ja260:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja260:0.3":{"pli":"Saṅkappavagga ","html":"<li>{}</li></ul>"},"ja260:0.4":{"pli":"10. Dūtajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja260:1.1":{"pli":"“Yassatthā dūramāyanti, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja260:1.2":{"pli":"amittamapi yācituṁ; ","html":"<span class='verse-line'>{}</span>"},"ja260:1.3":{"pli":"Tassūdarassahaṁ dūto, ","html":"<span class='verse-line'>{}</span>"},"ja260:1.4":{"pli":"mā me kujjha rathesabha”. ","html":"<span class='verse-line'>{}</span></p>"},"ja260:2.1":{"pli":"“Yassa divā ca ratto ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja260:2.2":{"pli":"vasamāyanti māṇavā; ","html":"<span class='verse-line'>{}</span>"},"ja260:2.3":{"pli":"Tassūdarassahaṁ dūto, ","html":"<span class='verse-line'>{}</span>"},"ja260:2.4":{"pli":"mā me kujjha rathesabha. ","html":"<span class='verse-line'>{}</span></p>"},"ja260:3.1":{"pli":"Dadāmi te brāhmaṇa rohiṇīnaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja260:3.2":{"pli":"Gavaṁ sahassaṁ saha puṅgavena; ","html":"<span class='verse-line'>{}</span>"},"ja260:3.3":{"pli":"Dūto hi dūtassa kathaṁ na dajjaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja260:3.4":{"pli":"Mayampi tasseva bhavāma dūtā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja260:4.1":{"pli":"Dūtajātakaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja260:4.2":{"pli":"Saṅkappavaggo paṭhamo. ","html":"<p class='endvagga'>{}</p>"},"ja260:5.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja260:6.1":{"pli":"Usukāravaro tilamuṭṭhi maṇi, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja260:6.2":{"pli":"Hayarāja vihaṅgama āsiviso; ","html":"<span class='verse-line'>{}</span>"},"ja260:6.3":{"pli":"Janasandha kahāpaṇavassa puna, ","html":"<span class='verse-line'>{}</span>"},"ja260:6.4":{"pli":"Tiriṭaṁ puna dūtavarena dasāti. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"ja261":{"ja261:0.1":{"pli":"Jātaka ","html":"<article id='ja261'><header><ul><li class='division'>{}</li>"},"ja261:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja261:0.3":{"pli":"Padumavagga ","html":"<li>{}</li></ul>"},"ja261:0.4":{"pli":"1. Padumajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja261:1.1":{"pli":"“Yathā kesā ca massū ca, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja261:1.2":{"pli":"chinnaṁ chinnaṁ virūhati; ","html":"<span class='verse-line'>{}</span>"},"ja261:1.3":{"pli":"Evaṁ rūhatu te nāsā, ","html":"<span class='verse-line'>{}</span>"},"ja261:1.4":{"pli":"padumaṁ dehi yācito”. ","html":"<span class='verse-line'>{}</span></p>"},"ja261:2.1":{"pli":"“Yathā sāradikaṁ bījaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja261:2.2":{"pli":"khette vuttaṁ virūhati; ","html":"<span class='verse-line'>{}</span>"},"ja261:2.3":{"pli":"Evaṁ rūhatu te nāsā, ","html":"<span class='verse-line'>{}</span>"},"ja261:2.4":{"pli":"padumaṁ dehi yācito”. ","html":"<span class='verse-line'>{}</span></p>"},"ja261:3.1":{"pli":"“Ubhopi palapantete, ","html":"<p><span class='verse-line'>{}</span>"},"ja261:3.2":{"pli":"api padmāni dassati; ","html":"<span class='verse-line'>{}</span>"},"ja261:3.3":{"pli":"Vajjuṁ vā te na vā vajjuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja261:3.4":{"pli":"natthi nāsāya rūhanā; ","html":"<span class='verse-line'>{}</span>"},"ja261:3.5":{"pli":"Dehi samma padumāni, ","html":"<span class='verse-line'>{}</span>"},"ja261:3.6":{"pli":"ahaṁ yācāmi yācito”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja261:4.1":{"pli":"Padumajātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja262":{"ja262:0.1":{"pli":"Jātaka ","html":"<article id='ja262'><header><ul><li class='division'>{}</li>"},"ja262:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja262:0.3":{"pli":"Padumavagga ","html":"<li>{}</li></ul>"},"ja262:0.4":{"pli":"2. Mudupāṇijātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja262:1.1":{"pli":"“Pāṇi ce muduko cassa, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja262:1.2":{"pli":"nāgo cassa sukārito; ","html":"<span class='verse-line'>{}</span>"},"ja262:1.3":{"pli":"Andhakāro ca vasseyya, ","html":"<span class='verse-line'>{}</span>"},"ja262:1.4":{"pli":"atha nūna tadā siyā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja262:2.1":{"pli":"“Analā mudusambhāsā, ","html":"<p><span class='verse-line'>{}</span>"},"ja262:2.2":{"pli":"duppūrā tā nadīsamā; ","html":"<span class='verse-line'>{}</span>"},"ja262:2.3":{"pli":"Sīdanti naṁ viditvāna, ","html":"<span class='verse-line'>{}</span>"},"ja262:2.4":{"pli":"ārakā parivajjaye. ","html":"<span class='verse-line'>{}</span></p>"},"ja262:3.1":{"pli":"Yaṁ etā upasevanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja262:3.2":{"pli":"chandasā vā dhanena vā; ","html":"<span class='verse-line'>{}</span>"},"ja262:3.3":{"pli":"Jātavedova saṁ ṭhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja262:3.4":{"pli":"khippaṁ anudahanti nan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja262:4.1":{"pli":"Mudupāṇijātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja263":{"ja263:0.1":{"pli":"Jātaka ","html":"<article id='ja263'><header><ul><li class='division'>{}</li>"},"ja263:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja263:0.3":{"pli":"Padumavagga ","html":"<li>{}</li></ul>"},"ja263:0.4":{"pli":"3. Cūḷapalobhanajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja263:1.1":{"pli":"“Abhijjamāne vārismiṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja263:1.2":{"pli":"sayaṁ āgamma iddhiyā; ","html":"<span class='verse-line'>{}</span>"},"ja263:1.3":{"pli":"Missībhāvitthiyā gantvā, ","html":"<span class='verse-line'>{}</span>"},"ja263:1.4":{"pli":"saṁsīdasi mahaṇṇave. ","html":"<span class='verse-line'>{}</span></p>"},"ja263:2.1":{"pli":"Āvaṭṭanī mahāmāyā, ","html":"<p><span class='verse-line'>{}</span>"},"ja263:2.2":{"pli":"brahmacariyavikopanā; ","html":"<span class='verse-line'>{}</span>"},"ja263:2.3":{"pli":"Sīdanti naṁ viditvāna, ","html":"<span class='verse-line'>{}</span>"},"ja263:2.4":{"pli":"ārakā parivajjaye. ","html":"<span class='verse-line'>{}</span></p>"},"ja263:3.1":{"pli":"Yaṁ etā upasevanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja263:3.2":{"pli":"chandasā vā dhanena vā; ","html":"<span class='verse-line'>{}</span>"},"ja263:3.3":{"pli":"Jātavedova saṁ ṭhānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja263:3.4":{"pli":"khippaṁ anudahanti nan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja263:4.1":{"pli":"Cūḷapalobhanajātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja264":{"ja264:0.1":{"pli":"Jātaka ","html":"<article id='ja264'><header><ul><li class='division'>{}</li>"},"ja264:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja264:0.3":{"pli":"Padumavagga ","html":"<li>{}</li></ul>"},"ja264:0.4":{"pli":"4. Mahāpanādajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja264:1.1":{"pli":"“Panādo nāma so rājā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja264:1.2":{"pli":"yassa yūpo suvaṇṇayo; ","html":"<span class='verse-line'>{}</span>"},"ja264:1.3":{"pli":"Tiriyaṁ soḷasubbedho, ","html":"<span class='verse-line'>{}</span>"},"ja264:1.4":{"pli":"uddhamāhu sahassadhā. ","html":"<span class='verse-line'>{}</span></p>"},"ja264:2.1":{"pli":"Sahassakaṇḍo satageṇḍu, ","html":"<p><span class='verse-line'>{}</span>"},"ja264:2.2":{"pli":"dhajālu haritāmayo; ","html":"<span class='verse-line'>{}</span>"},"ja264:2.3":{"pli":"Anaccuṁ tattha gandhabbā, ","html":"<span class='verse-line'>{}</span>"},"ja264:2.4":{"pli":"cha sahassāni sattadhā. ","html":"<span class='verse-line'>{}</span></p>"},"ja264:3.1":{"pli":"Evametaṁ tadā āsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja264:3.2":{"pli":"yathā bhāsasi bhaddaji; ","html":"<span class='verse-line'>{}</span>"},"ja264:3.3":{"pli":"Sakko ahaṁ tadā āsiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja264:3.4":{"pli":"veyyāvaccakaro tavā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja264:4.1":{"pli":"Mahāpanādajātakaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja265":{"ja265:0.1":{"pli":"Jātaka ","html":"<article id='ja265'><header><ul><li class='division'>{}</li>"},"ja265:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja265:0.3":{"pli":"Padumavagga ","html":"<li>{}</li></ul>"},"ja265:0.4":{"pli":"5. Khurappajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja265:1.1":{"pli":"“Disvā khurappe dhanuveganunne, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja265:1.2":{"pli":"Khagge gahīte tikhiṇe teladhote; ","html":"<span class='verse-line'>{}</span>"},"ja265:1.3":{"pli":"Tasmiṁ bhayasmiṁ maraṇe viyūḷhe, ","html":"<span class='verse-line'>{}</span>"},"ja265:1.4":{"pli":"Kasmā nu te nāhu chambhitattaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja265:2.1":{"pli":"“Disvā khurappe dhanuveganunne, ","html":"<p><span class='verse-line'>{}</span>"},"ja265:2.2":{"pli":"Khagge gahīte tikhiṇe teladhote; ","html":"<span class='verse-line'>{}</span>"},"ja265:2.3":{"pli":"Tasmiṁ bhayasmiṁ maraṇe viyūḷhe, ","html":"<span class='verse-line'>{}</span>"},"ja265:2.4":{"pli":"Vedaṁ alatthaṁ vipulaṁ uḷāraṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja265:3.1":{"pli":"So vedajāto ajjhabhaviṁ amitte, ","html":"<p><span class='verse-line'>{}</span>"},"ja265:3.2":{"pli":"Pubbeva me jīvitamāsi cattaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja265:3.3":{"pli":"Na hi jīvite ālayaṁ kubbamāno, ","html":"<span class='verse-line'>{}</span>"},"ja265:3.4":{"pli":"Sūro kayirā sūrakiccaṁ kadācī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja265:4.1":{"pli":"Khurappajātakaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja266":{"ja266:0.1":{"pli":"Jātaka ","html":"<article id='ja266'><header><ul><li class='division'>{}</li>"},"ja266:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja266:0.3":{"pli":"Padumavagga ","html":"<li>{}</li></ul>"},"ja266:0.4":{"pli":"6. Vātaggasindhavajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja266:1.1":{"pli":"“Yenāsi kisiyā paṇḍu, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja266:1.2":{"pli":"yena bhattaṁ na ruccati; ","html":"<span class='verse-line'>{}</span>"},"ja266:1.3":{"pli":"Ayaṁ so āgato bhattā, ","html":"<span class='verse-line'>{}</span>"},"ja266:1.4":{"pli":"kasmā dāni palāyasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja266:2.1":{"pli":"“Sace panādikeneva, ","html":"<p><span class='verse-line'>{}</span>"},"ja266:2.2":{"pli":"santhavo nāma jāyati; ","html":"<span class='verse-line'>{}</span>"},"ja266:2.3":{"pli":"Yaso hāyati itthīnaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja266:2.4":{"pli":"tasmā tāta palāyahaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja266:3.1":{"pli":"Yasassinaṁ kule jātaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja266:3.2":{"pli":"āgataṁ yā na icchati; ","html":"<span class='verse-line'>{}</span>"},"ja266:3.3":{"pli":"Socati cirarattāya, ","html":"<span class='verse-line'>{}</span>"},"ja266:3.4":{"pli":"vātaggamiva bhaddalīti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja266:4.1":{"pli":"Vātaggasindhavajātakaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja267":{"ja267:0.1":{"pli":"Jātaka ","html":"<article id='ja267'><header><ul><li class='division'>{}</li>"},"ja267:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja267:0.3":{"pli":"Padumavagga ","html":"<li>{}</li></ul>"},"ja267:0.4":{"pli":"7. Kakkaṭakajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja267:1.1":{"pli":"“Siṅgīmigo āyatacakkhunetto, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja267:1.2":{"pli":"Aṭṭhittaco vārisayo alomo; ","html":"<span class='verse-line'>{}</span>"},"ja267:1.3":{"pli":"Tenābhibhūto kapaṇaṁ rudāmi, ","html":"<span class='verse-line'>{}</span>"},"ja267:1.4":{"pli":"Mā heva maṁ pāṇasamaṁ jaheyya”. ","html":"<span class='verse-line'>{}</span></p>"},"ja267:2.1":{"pli":"“Ayya na taṁ jahissāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja267:2.2":{"pli":"kuñjaraṁ saṭṭhihāyanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja267:2.3":{"pli":"Pathabyā cāturantāya, ","html":"<span class='verse-line'>{}</span>"},"ja267:2.4":{"pli":"suppiyo hosi me tuvaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja267:3.1":{"pli":"“Ye kuḷīrā samuddasmiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja267:3.2":{"pli":"gaṅgāya yamunāya ca; ","html":"<span class='verse-line'>{}</span>"},"ja267:3.3":{"pli":"Tesaṁ tvaṁ vārijo seṭṭho, ","html":"<span class='verse-line'>{}</span>"},"ja267:3.4":{"pli":"muñca rodantiyā patin”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja267:4.1":{"pli":"Kakkaṭakajātakaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja268":{"ja268:0.1":{"pli":"Jātaka ","html":"<article id='ja268'><header><ul><li class='division'>{}</li>"},"ja268:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja268:0.3":{"pli":"Padumavagga ","html":"<li>{}</li></ul>"},"ja268:0.4":{"pli":"8. Ārāmadūsakajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja268:1.1":{"pli":"“Yo ve sabbasametānaṁ, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja268:1.2":{"pli":"ahuvā seṭṭhasammato; ","html":"<span class='verse-line'>{}</span>"},"ja268:1.3":{"pli":"Tassāyaṁ edisī paññā, ","html":"<span class='verse-line'>{}</span>"},"ja268:1.4":{"pli":"kimeva itarā pajā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja268:2.1":{"pli":"“Evameva tuvaṁ brahme, ","html":"<p><span class='verse-line'>{}</span>"},"ja268:2.2":{"pli":"anaññāya vinindasi; ","html":"<span class='verse-line'>{}</span>"},"ja268:2.3":{"pli":"Kathaṁ mūlaṁ adisvāna, ","html":"<span class='verse-line'>{}</span>"},"ja268:2.4":{"pli":"rukkhaṁ jaññā patiṭṭhitaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja268:3.1":{"pli":"“Nāhaṁ tumhe vinindāmi, ","html":"<p><span class='verse-line'>{}</span>"},"ja268:3.2":{"pli":"ye caññe vānarā vane; ","html":"<span class='verse-line'>{}</span>"},"ja268:3.3":{"pli":"Vissasenova gārayho, ","html":"<span class='verse-line'>{}</span>"},"ja268:3.4":{"pli":"yassatthā rukkharopakā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja268:4.1":{"pli":"Ārāmadūsakajātakaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja269":{"ja269:0.1":{"pli":"Jātaka ","html":"<article id='ja269'><header><ul><li class='division'>{}</li>"},"ja269:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja269:0.3":{"pli":"Padumavagga ","html":"<li>{}</li></ul>"},"ja269:0.4":{"pli":"9. Sujātajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja269:1.1":{"pli":"“Na hi vaṇṇena sampannā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja269:1.2":{"pli":"mañjukā piyadassanā; ","html":"<span class='verse-line'>{}</span>"},"ja269:1.3":{"pli":"Kharavācā piyā hoti, ","html":"<span class='verse-line'>{}</span>"},"ja269:1.4":{"pli":"asmiṁ loke paramhi ca. ","html":"<span class='verse-line'>{}</span></p>"},"ja269:2.1":{"pli":"Nanu passasimaṁ kāḷiṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja269:2.2":{"pli":"dubbaṇṇaṁ tilakāhataṁ; ","html":"<span class='verse-line'>{}</span>"},"ja269:2.3":{"pli":"Kokilaṁ saṇhavācena, ","html":"<span class='verse-line'>{}</span>"},"ja269:2.4":{"pli":"bahūnaṁ pāṇinaṁ piyaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja269:3.1":{"pli":"Tasmā sakhilavācassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja269:3.2":{"pli":"mantabhāṇī anuddhato; ","html":"<span class='verse-line'>{}</span>"},"ja269:3.3":{"pli":"Atthaṁ dhammañca dīpeti, ","html":"<span class='verse-line'>{}</span>"},"ja269:3.4":{"pli":"madhuraṁ tassa bhāsitan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja269:4.1":{"pli":"Sujātajātakaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja27":{"ja27:0.1":{"pli":"Jātaka ","eng":"Stories of Past Lives 27 ","html":"<article id='ja27'><header><ul><li class='division'>{}</li>"},"ja27:0.2":{"pli":"Ekakanipāta ","eng":"The Book of the Ones ","html":"<li>{}</li>"},"ja27:0.3":{"pli":"Kuruṅgavagga ","eng":"The Four-horned Antelope ","html":"<li>{}</li></ul>"},"ja27:0.4":{"pli":"7. Abhiṇhajātaka ","eng":"Frequent: a past life story ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja27:1.1":{"pli":"“Nālaṁ kabaḷaṁ padātave, ","eng":"It’s not enough to give him a morsel, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>","comm":"A state elephant pines when his friend, a dog, goes missing. "},"ja27:1.2":{"pli":"Na ca piṇḍaṁ na kuse na ghaṁsituṁ; ","eng":"a bite, some grass, or a rubbing-down. ","html":"<span class='verse-line'>{}</span>"},"ja27:1.3":{"pli":"Maññāmi abhiṇhadassanā, ","eng":"I think by seeing the dog often, ","html":"<span class='verse-line'>{}</span>"},"ja27:1.4":{"pli":"Nāgo snehamakāsi kukkure”ti. ","eng":"the elephant grew fond of him. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja27:2.1":{"pli":"Abhiṇhajātakaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja270":{"ja270:0.1":{"pli":"Jātaka ","html":"<article id='ja270'><header><ul><li class='division'>{}</li>"},"ja270:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja270:0.3":{"pli":"Padumavagga ","html":"<li>{}</li></ul>"},"ja270:0.4":{"pli":"10. Ulūkajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja270:1.1":{"pli":"“Sabbehi kira ñātīhi, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja270:1.2":{"pli":"kosiyo issaro kato; ","html":"<span class='verse-line'>{}</span>"},"ja270:1.3":{"pli":"Sace ñātīhi anuññāto, ","html":"<span class='verse-line'>{}</span>"},"ja270:1.4":{"pli":"bhaṇeyyāhaṁ ekavācikaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja270:2.1":{"pli":"“Bhaṇa samma anuññāto, ","html":"<p><span class='verse-line'>{}</span>"},"ja270:2.2":{"pli":"atthaṁ dhammañca kevalaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja270:2.3":{"pli":"Santi hi daharā pakkhī, ","html":"<span class='verse-line'>{}</span>"},"ja270:2.4":{"pli":"paññavanto jutindharā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja270:3.1":{"pli":"“Na me ruccati bhaddaṁ vo, ","html":"<p><span class='verse-line'>{}</span>"},"ja270:3.2":{"pli":"ulūkassābhisecanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja270:3.3":{"pli":"Akkuddhassa mukhaṁ passa, ","html":"<span class='verse-line'>{}</span>"},"ja270:3.4":{"pli":"kathaṁ kuddho karissatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja270:4.1":{"pli":"Ulūkajātakaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja270:4.2":{"pli":"Padumavaggo dutiyo. ","html":"<p class='endvagga'>{}</p>"},"ja270:5.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja270:6.1":{"pli":"Padumuttama nāgasirivhayano, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja270:6.2":{"pli":"Sa-mahaṇṇava yūpa khurappavaro; ","html":"<span class='verse-line'>{}</span>"},"ja270:6.3":{"pli":"Atha bhaddalī kuñjara rukkha puna, ","html":"<span class='verse-line'>{}</span>"},"ja270:6.4":{"pli":"Kharavāca ulūkavarena dasāti. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"ja271":{"ja271:0.1":{"pli":"Jātaka ","html":"<article id='ja271'><header><ul><li class='division'>{}</li>"},"ja271:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja271:0.3":{"pli":"Udapānavagga ","html":"<li>{}</li></ul>"},"ja271:0.4":{"pli":"1. Udapānadūsakajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja271:1.1":{"pli":"“Āraññikassa isino, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja271:1.2":{"pli":"cirarattatapassino; ","html":"<span class='verse-line'>{}</span>"},"ja271:1.3":{"pli":"Kicchākataṁ udapānaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja271:1.4":{"pli":"kathaṁ samma avāhayi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja271:2.1":{"pli":"“Esa dhammo siṅgālānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja271:2.2":{"pli":"yaṁ pitvā ohadāmase; ","html":"<span class='verse-line'>{}</span>"},"ja271:2.3":{"pli":"Pitupitāmahaṁ dhammo, ","html":"<span class='verse-line'>{}</span>"},"ja271:2.4":{"pli":"na taṁ ujjhātumarahasi”. ","html":"<span class='verse-line'>{}</span></p>"},"ja271:3.1":{"pli":"“Yesaṁ vo ediso dhammo, ","html":"<p><span class='verse-line'>{}</span>"},"ja271:3.2":{"pli":"Adhammo pana kīdiso; ","html":"<span class='verse-line'>{}</span>"},"ja271:3.3":{"pli":"Mā vo dhammaṁ adhammaṁ vā, ","html":"<span class='verse-line'>{}</span>"},"ja271:3.4":{"pli":"Addasāma kudācanan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja271:4.1":{"pli":"Udapānadūsakajātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja272":{"ja272:0.1":{"pli":"Jātaka ","html":"<article id='ja272'><header><ul><li class='division'>{}</li>"},"ja272:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja272:0.3":{"pli":"Udapānavagga ","html":"<li>{}</li></ul>"},"ja272:0.4":{"pli":"2. Byagghajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja272:1.1":{"pli":"“Yena mittena saṁsaggā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja272:1.2":{"pli":"yogakkhemo vihiyyati; ","html":"<span class='verse-line'>{}</span>"},"ja272:1.3":{"pli":"Pubbevajjhābhavaṁ tassa, ","html":"<span class='verse-line'>{}</span>"},"ja272:1.4":{"pli":"rukkhe akkhīva paṇḍito. ","html":"<span class='verse-line'>{}</span></p>"},"ja272:2.1":{"pli":"Yena mittena saṁsaggā, ","html":"<p><span class='verse-line'>{}</span>"},"ja272:2.2":{"pli":"yogakkhemo pavaḍḍhati; ","html":"<span class='verse-line'>{}</span>"},"ja272:2.3":{"pli":"Kareyyattasamaṁ vuttiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja272:2.4":{"pli":"sabbakiccesu paṇḍito”. ","html":"<span class='verse-line'>{}</span></p>"},"ja272:3.1":{"pli":"“Etha byagghā nivattavho, ","html":"<p><span class='verse-line'>{}</span>"},"ja272:3.2":{"pli":"Paccupetha mahāvanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja272:3.3":{"pli":"Mā vanaṁ chindi nibyagghaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja272:3.4":{"pli":"Byagghā māhesu nibbanā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja272:4.1":{"pli":"Byagghajātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja273":{"ja273:0.1":{"pli":"Jātaka ","html":"<article id='ja273'><header><ul><li class='division'>{}</li>"},"ja273:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja273:0.3":{"pli":"Udapānavagga ","html":"<li>{}</li></ul>"},"ja273:0.4":{"pli":"3. Kacchapajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja273:1.1":{"pli":"“Ko nu uddhitabhattova, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja273:1.2":{"pli":"pūrahatthova brāhmaṇo; ","html":"<span class='verse-line'>{}</span>"},"ja273:1.3":{"pli":"Kahaṁ nu bhikkhaṁ acari, ","html":"<span class='verse-line'>{}</span>"},"ja273:1.4":{"pli":"kaṁ saddhaṁ upasaṅkami”. ","html":"<span class='verse-line'>{}</span></p>"},"ja273:2.1":{"pli":"“Ahaṁ kapismi dummedho, ","html":"<p><span class='verse-line'>{}</span>"},"ja273:2.2":{"pli":"anāmāsāni āmasiṁ; ","html":"<span class='verse-line'>{}</span>"},"ja273:2.3":{"pli":"Tvaṁ maṁ mocaya bhaddaṁ te, ","html":"<span class='verse-line'>{}</span>"},"ja273:2.4":{"pli":"mutto gaccheyya pabbataṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja273:3.1":{"pli":"“Kacchapā kassapā honti, ","html":"<p><span class='verse-line'>{}</span>"},"ja273:3.2":{"pli":"Koṇḍaññā honti makkaṭā; ","html":"<span class='verse-line'>{}</span>"},"ja273:3.3":{"pli":"Muñca kassapa koṇḍaññaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja273:3.4":{"pli":"Kataṁ methunakaṁ tayā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja273:4.1":{"pli":"Kacchapajātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja274":{"ja274:0.1":{"pli":"Jātaka ","html":"<article id='ja274'><header><ul><li class='division'>{}</li>"},"ja274:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja274:0.3":{"pli":"Udapānavagga ","html":"<li>{}</li></ul>"},"ja274:0.4":{"pli":"4. Lolajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja274:1.1":{"pli":"“Kāyaṁ balākā sikhinī, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja274:1.2":{"pli":"corī laṅghipitāmahā; ","html":"<span class='verse-line'>{}</span>"},"ja274:1.3":{"pli":"Oraṁ balāke āgaccha, ","html":"<span class='verse-line'>{}</span>"},"ja274:1.4":{"pli":"caṇḍo me vāyaso sakhā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja274:2.1":{"pli":"“Nāhaṁ balākā sikhinī, ","html":"<p><span class='verse-line'>{}</span>"},"ja274:2.2":{"pli":"ahaṁ lolosmi vāyaso; ","html":"<span class='verse-line'>{}</span>"},"ja274:2.3":{"pli":"Akatvā vacanaṁ tuyhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja274:2.4":{"pli":"passa lūnosmi āgato”. ","html":"<span class='verse-line'>{}</span></p>"},"ja274:3.1":{"pli":"“Punapāpajjasī samma, ","html":"<p><span class='verse-line'>{}</span>"},"ja274:3.2":{"pli":"sīlañhi tava tādisaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja274:3.3":{"pli":"Na hi mānusakā bhogā, ","html":"<span class='verse-line'>{}</span>"},"ja274:3.4":{"pli":"subhuñjā honti pakkhinā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja274:4.1":{"pli":"Lolajātakaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja275":{"ja275:0.1":{"pli":"Jātaka ","html":"<article id='ja275'><header><ul><li class='division'>{}</li>"},"ja275:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja275:0.3":{"pli":"Udapānavagga ","html":"<li>{}</li></ul>"},"ja275:0.4":{"pli":"5. Rucirajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja275:1.1":{"pli":"“Kāyaṁ balākā rucirā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja275:1.2":{"pli":"kākanīḷasmimacchati; ","html":"<span class='verse-line'>{}</span>"},"ja275:1.3":{"pli":"Caṇḍo kāko sakhā mayhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja275:1.4":{"pli":"yassa cetaṁ kulāvakaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja275:2.1":{"pli":"“Nanu maṁ samma jānāsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja275:2.2":{"pli":"dija sāmākabhojana; ","html":"<span class='verse-line'>{}</span>"},"ja275:2.3":{"pli":"Akatvā vacanaṁ tuyhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja275:2.4":{"pli":"passa lūnosmi āgato”. ","html":"<span class='verse-line'>{}</span></p>"},"ja275:3.1":{"pli":"“Punapāpajjasī samma, ","html":"<p><span class='verse-line'>{}</span>"},"ja275:3.2":{"pli":"sīlañhi tava tādisaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja275:3.3":{"pli":"Na hi mānusakā bhogā, ","html":"<span class='verse-line'>{}</span>"},"ja275:3.4":{"pli":"subhuñjā honti pakkhinā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja275:4.1":{"pli":"Rucirajātakaṁ pañcamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja276":{"ja276:0.1":{"pli":"Jātaka ","html":"<article id='ja276'><header><ul><li class='division'>{}</li>"},"ja276:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja276:0.3":{"pli":"Udapānavagga ","html":"<li>{}</li></ul>"},"ja276:0.4":{"pli":"6. Garudhammajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja276:1.1":{"pli":"“Tava saddhañca sīlañca, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja276:1.2":{"pli":"viditvāna janādhipa; ","html":"<span class='verse-line'>{}</span>"},"ja276:1.3":{"pli":"Vaṇṇaṁ añjanavaṇṇena, ","html":"<span class='verse-line'>{}</span>"},"ja276:1.4":{"pli":"kāliṅgasmiṁ nimimhase”. ","html":"<span class='verse-line'>{}</span></p>"},"ja276:2.1":{"pli":"“Annabhaccā cabhaccā ca, ","html":"<p><span class='verse-line'>{}</span>"},"ja276:2.2":{"pli":"yodha uddissa gacchati; ","html":"<span class='verse-line'>{}</span>"},"ja276:2.3":{"pli":"Sabbe te appaṭikkhippā, ","html":"<span class='verse-line'>{}</span>"},"ja276:2.4":{"pli":"pubbācariyavaco idaṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja276:3.1":{"pli":"Dadāmi vo brāhmaṇā nāgametaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja276:3.2":{"pli":"Rājārahaṁ rājabhoggaṁ yasassinaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja276:3.3":{"pli":"Alaṅkataṁ hemajālābhichannaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja276:3.4":{"pli":"Sasārathiṁ gacchatha yena kāman”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja276:4.1":{"pli":"Garudhammajātakaṁ chaṭṭhaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja277":{"ja277:0.1":{"pli":"Jātaka ","html":"<article id='ja277'><header><ul><li class='division'>{}</li>"},"ja277:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja277:0.3":{"pli":"Udapānavagga ","html":"<li>{}</li></ul>"},"ja277:0.4":{"pli":"7. Romakajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja277:1.1":{"pli":"“Vassāni paññāsa samādhikāni, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja277:1.2":{"pli":"Vasimha selassa guhāya romaka; ","html":"<span class='verse-line'>{}</span>"},"ja277:1.3":{"pli":"Asaṅkamānā abhinibbutattā, ","html":"<span class='verse-line'>{}</span>"},"ja277:1.4":{"pli":"Hatthattamāyanti mamaṇḍajā pure. ","html":"<span class='verse-line'>{}</span></p>"},"ja277:2.1":{"pli":"Te dāni vakkaṅga kimatthamussukā, ","html":"<p><span class='verse-line'>{}</span>"},"ja277:2.2":{"pli":"Bhajanti aññaṁ girikandaraṁ dijā; ","html":"<span class='verse-line'>{}</span>"},"ja277:2.3":{"pli":"Na nūna maññanti mamaṁ yathā pure, ","html":"<span class='verse-line'>{}</span>"},"ja277:2.4":{"pli":"Cirappavutthā atha vā na te ime”. ","html":"<span class='verse-line'>{}</span></p>"},"ja277:3.1":{"pli":"“Jānāma taṁ na mayaṁ sampamūḷhā, ","html":"<p><span class='verse-line'>{}</span>"},"ja277:3.2":{"pli":"Soyeva tvaṁ te mayamasma nāññe; ","html":"<span class='verse-line'>{}</span>"},"ja277:3.3":{"pli":"Cittañca te asmiṁ jane paduṭṭhaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja277:3.4":{"pli":"Ājīvikā tena tamuttasāmā”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja277:4.1":{"pli":"Romakajātakaṁ sattamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja278":{"ja278:0.1":{"pli":"Jātaka ","html":"<article id='ja278'><header><ul><li class='division'>{}</li>"},"ja278:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja278:0.3":{"pli":"Udapānavagga ","html":"<li>{}</li></ul>"},"ja278:0.4":{"pli":"8. Mahiṁsarājajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja278:1.1":{"pli":"“Kimatthamabhisandhāya, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja278:1.2":{"pli":"lahucittassa dubbhino; ","html":"<span class='verse-line'>{}</span>"},"ja278:1.3":{"pli":"Sabbakāmadadasseva, ","html":"<span class='verse-line'>{}</span>"},"ja278:1.4":{"pli":"imaṁ dukkhaṁ titikkhasi. ","html":"<span class='verse-line'>{}</span></p>"},"ja278:2.1":{"pli":"Siṅgena nihanāhetaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja278:2.2":{"pli":"padasā ca adhiṭṭhaha; ","html":"<span class='verse-line'>{}</span>"},"ja278:2.3":{"pli":"Bhiyyo bālā pakujjheyyuṁ, ","html":"<span class='verse-line'>{}</span>"},"ja278:2.4":{"pli":"no cassa paṭisedhako”. ","html":"<span class='verse-line'>{}</span></p>"},"ja278:3.1":{"pli":"“Mamevāyaṁ maññamāno, ","html":"<p><span class='verse-line'>{}</span>"},"ja278:3.2":{"pli":"aññepevaṁ karissati; ","html":"<span class='verse-line'>{}</span>"},"ja278:3.3":{"pli":"Te naṁ tattha vadhissanti, ","html":"<span class='verse-line'>{}</span>"},"ja278:3.4":{"pli":"sā me mutti bhavissatī”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja278:4.1":{"pli":"Mahiṁsarājajātakaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja279":{"ja279:0.1":{"pli":"Jātaka ","html":"<article id='ja279'><header><ul><li class='division'>{}</li>"},"ja279:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja279:0.3":{"pli":"Udapānavagga ","html":"<li>{}</li></ul>"},"ja279:0.4":{"pli":"9. Satapattajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja279:1.1":{"pli":"“Yathā māṇavako panthe, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja279:1.2":{"pli":"siṅgāliṁ vanagocariṁ; ","html":"<span class='verse-line'>{}</span>"},"ja279:1.3":{"pli":"Atthakāmaṁ pavedentiṁ, ","html":"<span class='verse-line'>{}</span>"},"ja279:1.4":{"pli":"anatthakāmāti maññati; ","html":"<span class='verse-line'>{}</span>"},"ja279:1.5":{"pli":"Anatthakāmaṁ satapattaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja279:1.6":{"pli":"atthakāmoti maññati. ","html":"<span class='verse-line'>{}</span></p>"},"ja279:2.1":{"pli":"Evameva idhekacco, ","html":"<p><span class='verse-line'>{}</span>"},"ja279:2.2":{"pli":"puggalo hoti tādiso; ","html":"<span class='verse-line'>{}</span>"},"ja279:2.3":{"pli":"Hitehi vacanaṁ vutto, ","html":"<span class='verse-line'>{}</span>"},"ja279:2.4":{"pli":"paṭigaṇhāti vāmato. ","html":"<span class='verse-line'>{}</span></p>"},"ja279:3.1":{"pli":"Ye ca kho naṁ pasaṁsanti, ","html":"<p><span class='verse-line'>{}</span>"},"ja279:3.2":{"pli":"bhayā ukkaṁsayanti vā; ","html":"<span class='verse-line'>{}</span>"},"ja279:3.3":{"pli":"Tañhi so maññate mittaṁ, ","html":"<span class='verse-line'>{}</span>"},"ja279:3.4":{"pli":"satapattaṁva māṇavo”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja279:4.1":{"pli":"Satapattajātakaṁ navamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja28":{"ja28:0.1":{"pli":"Jātaka ","eng":"Stories of Past Lives 28 ","html":"<article id='ja28'><header><ul><li class='division'>{}</li>"},"ja28:0.2":{"pli":"Ekakanipāta ","eng":"The Book of the Ones ","html":"<li>{}</li>"},"ja28:0.3":{"pli":"Kuruṅgavagga ","eng":"The Four-horned Antelope ","html":"<li>{}</li></ul>"},"ja28:0.4":{"pli":"8. Nandivisālajātaka ","eng":"The Ox Named Nandivisāla: a past life story ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja28:1.1":{"pli":"“Manuññameva bhāseyya, ","eng":"One should only speak sweetly, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>","comm":"A brahmin wagers that his ox, Nandivisāla, can pull a hundred carts. When yelled at, the beast refuses to pull, but when spoken to kindly he pulls the load and wins the bet. | This is the origin story for <a href='index.html?q=pli-tv-bu-vb-pc2'>Bu Pc 2</a>, where the verse has some different readings. "},"ja28:1.2":{"pli":"nāmanuññaṁ kudācanaṁ; ","eng":"never not sweetly. ","html":"<span class='verse-line'>{}</span>"},"ja28:1.3":{"pli":"Manuññaṁ bhāsamānassa, ","eng":"For the one speaking sweetly, ","html":"<span class='verse-line'>{}</span>"},"ja28:1.4":{"pli":"garuṁ bhāraṁ udaddhari; ","eng":"a large load was pulled, ","html":"<span class='verse-line'>{}</span>"},"ja28:1.5":{"pli":"Dhanañca naṁ alābhesi, ","eng":"earning him money, ","html":"<span class='verse-line'>{}</span>"},"ja28:1.6":{"pli":"tena cattamano ahū”ti. ","eng":"and he was satisfied with that. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja28:2.1":{"pli":"Nandivisālajātakaṁ aṭṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja280":{"ja280:0.1":{"pli":"Jātaka ","html":"<article id='ja280'><header><ul><li class='division'>{}</li>"},"ja280:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja280:0.3":{"pli":"Udapānavagga ","html":"<li>{}</li></ul>"},"ja280:0.4":{"pli":"10. Puṭadūsakajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja280:1.1":{"pli":"“Addhā hi nūna migarājā, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja280:1.2":{"pli":"puṭakammassa kovido; ","html":"<span class='verse-line'>{}</span>"},"ja280:1.3":{"pli":"Tathā hi puṭaṁ dūseti, ","html":"<span class='verse-line'>{}</span>"},"ja280:1.4":{"pli":"aññaṁ nūna karissati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja280:2.1":{"pli":"“Na me mātā vā pitā vā, ","html":"<p><span class='verse-line'>{}</span>"},"ja280:2.2":{"pli":"puṭakammassa kovido; ","html":"<span class='verse-line'>{}</span>"},"ja280:2.3":{"pli":"Kataṁ kataṁ kho dūsema, ","html":"<span class='verse-line'>{}</span>"},"ja280:2.4":{"pli":"evaṁ dhammamidaṁ kulaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja280:3.1":{"pli":"“Yesaṁ vo ediso dhammo, ","html":"<p><span class='verse-line'>{}</span>"},"ja280:3.2":{"pli":"Adhammo pana kīdiso; ","html":"<span class='verse-line'>{}</span>"},"ja280:3.3":{"pli":"Mā vo dhammaṁ adhammaṁ vā, ","html":"<span class='verse-line'>{}</span>"},"ja280:3.4":{"pli":"Addasāma kudācanan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja280:4.1":{"pli":"Puṭadūsakajātakaṁ dasamaṁ. ","html":"<p class='endsutta'>{}</p>"},"ja280:4.2":{"pli":"Udapānavaggo tatiyo. ","html":"<p class='endvagga'>{}</p>"},"ja280:5.1":{"pli":"Tassuddānaṁ ","html":"<p class='uddana-intro'>{}</p>"},"ja280:6.1":{"pli":"Udapānavaraṁ vanabyaggha kapi, ","html":"<blockquote class='uddanagatha'><p><span class='verse-line'>{}</span>"},"ja280:6.2":{"pli":"Sikhinī ca balāka ruciravaro; ","html":"<span class='verse-line'>{}</span>"},"ja280:6.3":{"pli":"Sujanādhiparomakadūsa puna, ","html":"<span class='verse-line'>{}</span>"},"ja280:6.4":{"pli":"Satapattavaro puṭakamma dasāti. ","html":"<span class='verse-line'>{}</span></p></blockquote></article>"}},"ja281":{"ja281:0.1":{"pli":"Jātaka ","html":"<article id='ja281'><header><ul><li class='division'>{}</li>"},"ja281:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja281:0.3":{"pli":"Abbhantaravagga ","html":"<li>{}</li></ul>"},"ja281:0.4":{"pli":"1. Abbhantarajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja281:1.1":{"pli":"“Abbhantaro nāma dumo, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja281:1.2":{"pli":"yassa dibyamidaṁ phalaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja281:1.3":{"pli":"Bhutvā dohaḷinī nārī, ","html":"<span class='verse-line'>{}</span>"},"ja281:1.4":{"pli":"cakkavattiṁ vijāyati. ","html":"<span class='verse-line'>{}</span></p>"},"ja281:2.1":{"pli":"Tvampi bhadde mahesīsi, ","html":"<p><span class='verse-line'>{}</span>"},"ja281:2.2":{"pli":"sā cāpi patino piyā; ","html":"<span class='verse-line'>{}</span>"},"ja281:2.3":{"pli":"Āharissati te rājā, ","html":"<span class='verse-line'>{}</span>"},"ja281:2.4":{"pli":"idaṁ abbhantaraṁ phalaṁ”. ","html":"<span class='verse-line'>{}</span></p>"},"ja281:3.1":{"pli":"“Bhatturatthe parakkanto, ","html":"<p><span class='verse-line'>{}</span>"},"ja281:3.2":{"pli":"yaṁ ṭhānamadhigacchati; ","html":"<span class='verse-line'>{}</span>"},"ja281:3.3":{"pli":"Sūro attapariccāgī, ","html":"<span class='verse-line'>{}</span>"},"ja281:3.4":{"pli":"labhamāno bhavāmahan”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja281:4.1":{"pli":"Abbhantarajātakaṁ paṭhamaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja282":{"ja282:0.1":{"pli":"Jātaka ","html":"<article id='ja282'><header><ul><li class='division'>{}</li>"},"ja282:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja282:0.3":{"pli":"Abbhantaravagga ","html":"<li>{}</li></ul>"},"ja282:0.4":{"pli":"2. Seyyajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja282:1.1":{"pli":"“Seyyaṁso seyyaso hoti, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja282:1.2":{"pli":"yo seyyamupasevati; ","html":"<span class='verse-line'>{}</span>"},"ja282:1.3":{"pli":"Ekena sandhiṁ katvāna, ","html":"<span class='verse-line'>{}</span>"},"ja282:1.4":{"pli":"sataṁ vajjhe amocayiṁ. ","html":"<span class='verse-line'>{}</span></p>"},"ja282:2.1":{"pli":"Tasmā sabbena lokena, ","html":"<p><span class='verse-line'>{}</span>"},"ja282:2.2":{"pli":"sandhiṁ katvāna ekato; ","html":"<span class='verse-line'>{}</span>"},"ja282:2.3":{"pli":"Pecca saggaṁ nigaccheyya, ","html":"<span class='verse-line'>{}</span>"},"ja282:2.4":{"pli":"idaṁ suṇātha kāsiyā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja282:3.1":{"pli":"Idaṁ vatvā mahārājā, ","html":"<p><span class='verse-line'>{}</span>"},"ja282:3.2":{"pli":"Kaṁso bārāṇasiggaho; ","html":"<span class='verse-line'>{}</span>"},"ja282:3.3":{"pli":"Dhanuṁ kaṇḍañca nikkhippa, ","html":"<span class='verse-line'>{}</span>"},"ja282:3.4":{"pli":"Saṁyamaṁ ajjhupāgamīti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja282:4.1":{"pli":"Seyyajātakaṁ dutiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja283":{"ja283:0.1":{"pli":"Jātaka ","html":"<article id='ja283'><header><ul><li class='division'>{}</li>"},"ja283:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja283:0.3":{"pli":"Abbhantaravagga ","html":"<li>{}</li></ul>"},"ja283:0.4":{"pli":"3. Vaḍḍhakīsūkarajātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja283:1.1":{"pli":"“Varaṁ varaṁ tvaṁ nihanaṁ pure cari, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja283:1.2":{"pli":"Asmiṁ padese abhibhuyya sūkare; ","html":"<span class='verse-line'>{}</span>"},"ja283:1.3":{"pli":"So dāni eko byapagamma jhāyasi, ","html":"<span class='verse-line'>{}</span>"},"ja283:1.4":{"pli":"Balaṁ nu te byaggha na cajja vijjati”. ","html":"<span class='verse-line'>{}</span></p>"},"ja283:2.1":{"pli":"“Ime sudaṁ yanti disodisaṁ pure, ","html":"<p><span class='verse-line'>{}</span>"},"ja283:2.2":{"pli":"Bhayaṭṭitā leṇagavesino puthū; ","html":"<span class='verse-line'>{}</span>"},"ja283:2.3":{"pli":"Te dāni saṅgamma vasanti ekato, ","html":"<span class='verse-line'>{}</span>"},"ja283:2.4":{"pli":"Yatthaṭṭhitā duppasahajjame mayā”. ","html":"<span class='verse-line'>{}</span></p>"},"ja283:3.1":{"pli":"“Namatthu saṅghāna samāgatānaṁ, ","html":"<p><span class='verse-line'>{}</span>"},"ja283:3.2":{"pli":"Disvā sayaṁ sakhya vadāmi abbhutaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja283:3.3":{"pli":"Byagghaṁ migā yattha jiniṁsu dāṭhino, ","html":"<span class='verse-line'>{}</span>"},"ja283:3.4":{"pli":"Sāmaggiyā dāṭhabalesu muccare”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja283:4.1":{"pli":"Vaḍḍhakīsūkarajātakaṁ tatiyaṁ. ","html":"<p class='endsutta'>{}</p></article>"}},"ja284":{"ja284:0.1":{"pli":"Jātaka ","html":"<article id='ja284'><header><ul><li class='division'>{}</li>"},"ja284:0.2":{"pli":"Tikanipāta ","html":"<li>{}</li>"},"ja284:0.3":{"pli":"Abbhantaravagga ","html":"<li>{}</li></ul>"},"ja284:0.4":{"pli":"4. Sirijātaka ","html":"<h1 class='sutta-title'>{}</h1></header>"},"ja284:1.1":{"pli":"“Yaṁ ussukā saṅgharanti, ","html":"<blockquote class='gatha'><p><span class='verse-line'>{}</span>"},"ja284:1.2":{"pli":"alakkhikā bahuṁ dhanaṁ; ","html":"<span class='verse-line'>{}</span>"},"ja284:1.3":{"pli":"Sippavanto asippā ca, ","html":"<span class='verse-line'>{}</span>"},"ja284:1.4":{"pli":"lakkhivā tāni bhuñjati. ","html":"<span class='verse-line'>{}</span></p>"},"ja284:2.1":{"pli":"Sabbattha katapuññassa, ","html":"<p><span class='verse-line'>{}</span>"},"ja284:2.2":{"pli":"aticcaññeva pāṇino; ","html":"<span class='verse-line'>{}</span>"},"ja284:2.3":{"pli":"Uppajjanti bahū bhogā, ","html":"<span class='verse-line'>{}</span>"},"ja284:2.4":{"pli":"appanāyatanesupi. ","html":"<span class='verse-line'>{}</span></p>"},"ja284:3.1":{"pli":"Kukkuṭo maṇayo daṇḍo, ","html":"<p><span class='verse-line'>{}</span>"},"ja284:3.2":{"pli":"thiyo ca puññalakkhaṇā; ","html":"<span class='verse-line'>{}</span>"},"ja284:3.3":{"pli":"Uppajjanti apāpassa, ","html":"<span class='verse-line'>{}</span>"},"ja284:3.4":{"pli":"katapuññassa jantuno”ti. ","html":"<span class='verse-line'>{}</span></p></blockquote>"},"ja284:4.1":{"pli":"Sirijātakaṁ catutthaṁ. ","html":"<p class='endsutta'>{}</p></article>"}}}